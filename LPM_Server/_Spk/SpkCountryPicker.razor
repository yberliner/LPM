@* Searchable country picker with flags. Usage: <SpkCountryPicker @bind-SelectedIndex="_countryIdx" /> *@

<div class="spk-cpick">
    <button type="button" class="spk-cpick-btn" @onclick="Toggle" @onclick:stopPropagation="true">
        <span class="spk-cpick-flag">@Countries[SelectedIndex].Flag</span>
        <span class="spk-cpick-code">+@Countries[SelectedIndex].DialCode</span>
        <i class="ri-arrow-down-s-line spk-cpick-arrow @(_open ? "spk-cpick-arrow-up" : "")"></i>
    </button>
    @if (_open)
    {
        <div class="spk-cpick-backdrop" @onclick="Close"></div>
        <div class="spk-cpick-drop">
            <div class="spk-cpick-search-wrap">
                <i class="ri-search-line spk-cpick-search-icon"></i>
                <input class="spk-cpick-search" type="text" placeholder="Search country or code..."
                       @bind="_search" @bind:event="oninput" @ref="_searchRef" @onkeydown="OnKey" />
            </div>
            <div class="spk-cpick-list">
                @{ var items = Filtered(); }
                @if (items.Count == 0)
                {
                    <div class="spk-cpick-empty">No results</div>
                }
                @foreach (var (c, idx) in items)
                {
                    var i = idx;
                    <button type="button" class="spk-cpick-item @(i == SelectedIndex ? "spk-cpick-item-active" : "")"
                            @onmousedown="() => Select(i)" @onmousedown:preventDefault @onmousedown:stopPropagation>
                        <span class="spk-cpick-item-flag">@c.Flag</span>
                        <span class="spk-cpick-item-name">@c.Name</span>
                        <span class="spk-cpick-item-dial">+@c.DialCode</span>
                    </button>
                }
            </div>
        </div>
    }
</div>

