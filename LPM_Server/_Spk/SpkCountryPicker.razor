<style>
    .spk-cpick { position: relative; flex: 0 0 auto; }
    .spk-cpick-backdrop { position: fixed; inset: 0; z-index: 99; background: transparent; }
    .spk-cpick-btn {
        display: flex; align-items: center; gap: 6px;
        background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.18);
        border-radius: 10px; padding: 13px 12px; color: #f1f5f9; font-size: 1rem;
        cursor: pointer; min-height: 46px; transition: border-color 0.2s, background 0.2s;
        box-sizing: border-box;
    }
    .spk-cpick-btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(99,102,241,0.4); }
    .spk-cpick-flag { font-size: 1.3rem; line-height: 1; }
    .spk-cpick-code { font-weight: 600; font-variant-numeric: tabular-nums; }
    .spk-cpick-arrow { font-size: 1rem; color: #64748b; transition: transform 0.2s; }
    .spk-cpick-arrow-up { transform: rotate(180deg); }
    .spk-cpick-drop {
        position: absolute; top: calc(100% + 6px); left: 0; z-index: 100;
        width: 320px; max-height: 360px; display: flex; flex-direction: column;
        background: #1e293b; border: 1px solid rgba(99,102,241,0.25);
        border-radius: 14px; box-shadow: 0 16px 48px rgba(0,0,0,0.5);
        animation: spkCpickIn 0.15s ease-out; overflow: hidden;
    }
    @@keyframes spkCpickIn { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:translateY(0); } }
    .spk-cpick-search-wrap { position: relative; padding: 10px 10px 6px; flex-shrink: 0; }
    .spk-cpick-search-icon {
        position: absolute; left: 20px; top: 50%; transform: translateY(-50%);
        color: #475569; font-size: .95rem; pointer-events: none;
    }
    .spk-cpick-search {
        width: 100%; padding: 9px 12px 9px 34px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12);
        border-radius: 8px; color: #f1f5f9; font-size: .95rem; outline: none;
    }
    .spk-cpick-search:focus { border-color: rgba(99,102,241,0.5); }
    .spk-cpick-search::placeholder { color: #475569; }
    .spk-cpick-list {
        overflow-y: auto; flex: 1; padding: 4px 6px 8px;
        scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.1) transparent;
    }
    .spk-cpick-item {
        display: flex; align-items: center; gap: 10px; width: 100%;
        padding: 8px 10px; border: none; background: none; color: #e2e8f0;
        font-size: .9rem; border-radius: 8px; cursor: pointer; text-align: left;
        transition: background 0.12s;
    }
    .spk-cpick-item:hover { background: rgba(99,102,241,0.15); }
    .spk-cpick-item-active { background: rgba(99,102,241,0.2); }
    .spk-cpick-item-flag { font-size: 1.2rem; flex-shrink: 0; }
    .spk-cpick-item-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .spk-cpick-item-dial { color: #64748b; font-size: .82rem; font-variant-numeric: tabular-nums; flex-shrink: 0; }
    .spk-cpick-empty { padding: 16px; text-align: center; color: #475569; font-size: .85rem; }

    @@media (max-width: 768px) { .spk-cpick-drop { width: 280px; } }
    @@media (max-width: 480px) { .spk-cpick-drop { width: 100%; left: 0; right: 0; } }
</style>
