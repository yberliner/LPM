    List<(CountryInfo c, int idx)> Filtered()
    {
        var q = _search.Trim();
        var list = Countries.Select((c, i) => (c, i)).ToList();
        if (string.IsNullOrEmpty(q)) return list;
        return list.Where(x =>
            x.c.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
            x.c.DialCode.Contains(q, StringComparison.OrdinalIgnoreCase) ||
            ($"+{x.c.DialCode}").Contains(q, StringComparison.OrdinalIgnoreCase) ||
            x.c.Iso.Equals(q, StringComparison.OrdinalIgnoreCase)
        ).ToList();
    }

    bool _needsFocus;

    void Toggle()
    {
        _open = !_open;
        _search = "";
        if (_open) _needsFocus = true;
    }

    void Close() { _open = false; _search = ""; }

    async Task Select(int idx)
    {
        _open = false; _search = "";
        SelectedIndex = idx;
        await SelectedIndexChanged.InvokeAsync(idx);
    }

    void OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") Close();
        else if (e.Key == "Enter")
        {
            var f = Filtered();
            if (f.Count > 0) _ = Select(f[0].idx);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_needsFocus && _open)
        {
            _needsFocus = false;
            try { await _searchRef.FocusAsync(); } catch { }
        }
    }

    /// <summary>Parse a stored phone like "+972544994470" into (countryIndex, localDigits).</summary>
    public static (int CountryIndex, string LocalPhone) ParsePhone(string stored)
    {
        if (string.IsNullOrEmpty(stored)) return (0, "");
        if (!stored.StartsWith("+")) return (0, stored);
        var digits = stored[1..];
        var sorted = Countries.Select((c, i) => (c, i)).OrderByDescending(x => x.c.DialCode.Length);
        foreach (var (c, i) in sorted)
            if (digits.StartsWith(c.DialCode))
                return (i, digits[c.DialCode.Length..]);
        return (0, stored);
    }

    /// <summary>Normalize local phone to international format.</summary>
    public static string Normalize(int countryIndex, string localPhone)
    {
        var local = localPhone.Trim();
        if (string.IsNullOrEmpty(local)) return "";
        if (local.StartsWith("0")) local = local[1..];
        local = System.Text.RegularExpressions.Regex.Replace(local, @"[\s\-\(\)]", "");
        if (string.IsNullOrEmpty(local)) return "";
        return $"+{Countries[countryIndex].DialCode}{local}";
    }

    /// <summary>Validate local phone number.</summary>
    public static bool IsValid(int countryIndex, string localPhone)
    {
        var local = localPhone.Trim();
        if (string.IsNullOrEmpty(local)) return false;
        if (local.StartsWith("0")) local = local[1..];
        local = System.Text.RegularExpressions.Regex.Replace(local, @"[\s\-\(\)]", "");
        if (!local.All(char.IsDigit)) return false;
        bool isIsrael = Countries[countryIndex].DialCode == "972";
        return isIsrael ? local.Length == 9 : local.Length >= 7;
    }

    /// <summary>Error message for invalid phone.</summary>
    public static string ErrorMessage(int countryIndex, string localPhone)
    {
        var local = localPhone.Trim();
        if (string.IsNullOrEmpty(local)) return "";
        if (local.StartsWith("0")) local = local[1..];
        local = System.Text.RegularExpressions.Regex.Replace(local, @"[\s\-\(\)]", "");
        if (!local.All(char.IsDigit)) return "Digits only \u2014 no letters or special characters.";
        bool isIsrael = Countries[countryIndex].DialCode == "972";
        if (isIsrael && local.Length != 9) return $"Israeli number must be exactly 9 digits (entered: {local.Length}).";
        if (!isIsrael && local.Length < 7) return "At least 7 digits required.";
        return "";
    }
