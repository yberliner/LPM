@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="spk-rich-editor">
    <div @ref="_editorEl"></div>
</div>

<style>
    .spk-rich-editor .ql-editor {
        min-height: 80px;
        font-size: 0.875rem;
        background: #fffde7 !important;
        color: #1a1a1a !important;
    }
    .spk-rich-editor .ql-toolbar.ql-snow {
        padding: 4px 6px;
        background: #fff9c4 !important;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
    }
    .spk-rich-editor .ql-container.ql-snow {
        border-bottom-left-radius: 4px;
        border-bottom-right-radius: 4px;
        background: #fffde7 !important;
    }
    .spk-rich-editor .ql-toolbar.ql-snow .ql-stroke { stroke: #333 !important; }
    .spk-rich-editor .ql-toolbar.ql-snow .ql-fill  { fill:   #333 !important; }
    .spk-rich-editor .ql-toolbar.ql-snow .ql-picker-label { color: #333 !important; }
    .spk-rich-editor .ql-editor.ql-blank::before { color: #999 !important; }
    /* Size picker labels */
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item::before { content: 'Normal'; }
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='10px']::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='10px']::before { content: 'Tiny'; }
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='14px']::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='14px']::before { content: 'Small'; }
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='18px']::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='18px']::before { content: 'Medium'; }
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='24px']::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='24px']::before { content: 'Large'; }
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='32px']::before,
    .spk-rich-editor .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='32px']::before { content: 'Huge'; }
</style>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private ElementReference _editorEl;
    private DotNetObjectReference<SpkRichEditor>? _dotNetRef;
    private bool _initialized;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("quillInterop.init", _editorEl, Value ?? "", _dotNetRef);
            _initialized = true;
        }
    }

    [JSInvokable]
    public async Task OnContentChanged(string html)
    {
        Value = html;
        await ValueChanged.InvokeAsync(html);
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            try { await JS.InvokeVoidAsync("quillInterop.destroy", _editorEl); }
            catch { }
        }
        _dotNetRef?.Dispose();
    }
}
