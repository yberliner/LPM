@* Shared modal for adding a new person.
   Usage:
     <SpkNewPersonModal @ref="_modal" Title="Add New PC" RequireAllFields="true" OnSaved="HandleSaved" />
     <SpkNewPersonModal @ref="_modal" Title="New Student" Courses="_courses" OnSaved="HandleSaved" />

   Call _modal.Show() to open it.
   OnSaved fires with (FirstName, LastName, Phone, Email, DateOfBirth, Gender, OrgId, Source, Notes, CourseId, Nick).
   When RequireAllFields=true, Phone/Email/Gender/OrgId/Source are mandatory (DOB and Nick are always optional).
*@

@using LPM.Services
@inject LPM.Services.AcademyService AcademySvc
@inject LPM.Services.PcService PcSvc
@inject LPM.Services.LanguageService LS

@if (_visible)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);"
         @onclick="OnBackdropClick">
        <div class="modal-dialog modal-dialog-centered"
             @onclick:stopPropagation="true">
            <div class="modal-content shadow spk-new-person-modal" style="background:#fff; color:#212529;">

                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1a237e,#3949ab); border-bottom:none;">
                    <h6 class="modal-title mb-0" style="color:#fff !important;">
                        <i class="ri-user-add-line me-2 opacity-75" style="color:#fff !important;"></i>@Title
                    </h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="Cancel"></button>
                </div>

                <div class="modal-body" style="background:#fff; color:#212529;">
                    <div class="row g-2">
                        <div class="col-6 col-sm-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.firstName") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   value="@_firstName"
                                   @onchange="e => _firstName = CapVal(e)"
                                   placeholder="@LS.T("pcs.firstName")" />
                        </div>
                        <div class="col-6 col-sm-4">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.lastName") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   value="@_lastName"
                                   @onchange="e => _lastName = CapVal(e)"
                                   placeholder="@LS.T("pcs.lastName")" />
                        </div>
                        <div class="col-6 col-sm-2">
                            <label class="form-label small mb-1">@LS.T("pcs.nick")</label>
                            <input class="form-control form-control-sm"
                                   value="@_nick"
                                   @onchange="e => _nick = CapVal(e)"
                                   placeholder="@LS.T("pcs.nick")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.phone") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_phone" placeholder="@LS.T("pcs.phone")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.email")
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_email" placeholder="@LS.T("pcs.email")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">@LS.T("pcs.dob")</label>
                            <input type="text" class="form-control form-control-sm"
                                   @bind="_dobText" placeholder="dd/mm/yyyy" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.gender") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_sex">
                                <option value="">— @LS.T("common.select") —</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.org") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_orgId">
                                <option value="0">— @LS.T("common.select") —</option>
                                @foreach (var o in _orgOptions)
                                {
                                    <option value="@o.Id">@o.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.source") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_source">
                                <option value="">— @LS.T("common.select") —</option>
                                @foreach (var r in _sourceOptions)
                                {
                                    <option value="@r">@r</option>
                                }
                            </select>
                        </div>

                        @if (Courses != null && Courses.Count > 0)
                        {
                            <div class="col-12">
                                <label class="form-label small mb-1">
                                    <i class="ri-book-2-line me-1" style="color:#7c3aed;"></i>@LS.T("pcs.course") <span class="text-danger">*</span>
                                </label>
                                <select class="form-select form-select-sm" @bind="_courseId">
                                    <option value="0">— @LS.T("common.select") —</option>
                                    @foreach (var c in Courses)
                                    {
                                        <option value="@c.CourseId">@c.Name</option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="col-12">
                            <label class="form-label small mb-1">@LS.T("pcs.notes")</label>
                            <textarea class="form-control form-control-sm" rows="2"
                                      @bind="_notes" placeholder="@LS.T("pcs.notes")"></textarea>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-1 px-2 mt-2 small mb-0">@_error</div>
                    }
                </div>

                @if (_showSimilarWarning && _similarMatches.Count > 0)
                {
                    <div class="spk-dup-warn mx-3 mb-2">
                        <div class="spk-dup-warn-title">
                            <i class="ri-error-warning-line"></i>
                            Similar PCs already exist:
                        </div>
                        <ul class="spk-dup-warn-list">
                            @foreach (var m in _similarMatches)
                            {
                                <li>
                                    <span class="spk-dup-name">@m.Name</span>
                                    <span class="spk-dup-pct">@m.Pct% match</span>
                                </li>
                            }
                        </ul>
                        <div class="spk-dup-warn-msg">
                            Are you sure <strong>"@(_firstName.Trim()) @(_lastName.Trim())"</strong> is a different person?
                        </div>
                    </div>
                }

                <div class="modal-footer py-2" style="background:#f8faff; border-top:1px solid #e8edff;">
                    @if (_showSimilarWarning)
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelSimilarWarning">
                            <i class="ri-arrow-left-line me-1"></i>Go Back
                        </button>
                        <button class="btn btn-sm btn-warning" @onclick="ConfirmAddAnyway">
                            <i class="ri-check-line me-1"></i>Yes, Add Anyway
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-link text-muted" @onclick="Cancel">@LS.T("common.cancel")</button>
                        <button class="btn btn-sm btn-primary" @onclick="Save">
                            <i class="ri-save-line me-1"></i>@LS.T("common.save")
                        </button>
                    }
                </div>

            </div>
        </div>
    </div>
}

<style>
    .spk-new-person-modal .modal-body .form-label { color: #374151 !important; }
    .spk-new-person-modal .modal-body .form-control,
    .spk-new-person-modal .modal-body .form-select {
        background: #fff !important; color: #212529 !important;
        border-color: #ced4da !important;
    }

    /* ── Fuzzy duplicate warning ── */
    .spk-dup-warn {
        background: #fffbeb;
        border-left: 4px solid #f59e0b;
        border-radius: 0 8px 8px 0;
        padding: 12px 14px;
        animation: spkDupSlide 0.3s ease;
    }
    .spk-dup-warn-title {
        font-weight: 700;
        font-size: .88rem;
        color: #92400e;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .spk-dup-warn-title i { font-size: 1.15rem; color: #f59e0b; }
    .spk-dup-warn-list {
        list-style: none;
        padding: 0;
        margin: 0 0 10px;
    }
    .spk-dup-warn-list li {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 5px 10px;
        margin-bottom: 4px;
        background: #fef3c7;
        border-radius: 6px;
        font-size: .84rem;
    }
    .spk-dup-name { font-weight: 600; color: #78350f; }
    .spk-dup-pct {
        font-weight: 700;
        font-size: .76rem;
        padding: 2px 8px;
        border-radius: 10px;
        background: #fbbf24;
        color: #78350f;
    }
    .spk-dup-warn-msg {
        font-size: .82rem;
        color: #92400e;
    }
    @@keyframes spkDupSlide {
        from { opacity: 0; transform: translateY(-8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "Add New Person";
    [Parameter] public bool RequireAllFields { get; set; }
    [Parameter] public List<CourseItem>? Courses { get; set; }
    [Parameter] public HashSet<string>? ExistingFullNames { get; set; }
    [Parameter] public EventCallback<(string FirstName, string LastName, string Phone, string Email,
        string DateOfBirth, string Gender, int OrgId, string Source, string Notes, int CourseId, string Nick)> OnSaved { get; set; }

    List<string> _sourceOptions = [];
    List<(int Id, string Name)> _orgOptions = [];

    string    _firstName = "", _lastName = "", _nick = "";
    string    _phone = "", _email = "", _sex = "";
    static string CapVal(ChangeEventArgs e) => PcService.CapitalizeName(e.Value?.ToString() ?? "");
    int       _orgId;
    string    _source = "";
    string    _notes = "";
    string    _dobText = "";
    int       _courseId;
    string    _error = "";
    bool      _visible;
    string?   _editOriginalFullName;

    // ── Fuzzy duplicate state ──
    bool _showSimilarWarning;
    bool _userConfirmedSimilar;
    List<(string Name, int Pct)> _similarMatches = [];

    protected override void OnInitialized()
    {
        _sourceOptions = AcademySvc.GetAllReferralSources();
        _orgOptions = AcademySvc.GetAllOrganizations();
    }

    public void Show()
    {
        _firstName = _lastName = _nick = _phone = _email = _sex = _error = "";
        _source = _notes = _dobText = "";
        _orgId = 0;
        _courseId = 0;
        _editOriginalFullName = null;
        _showSimilarWarning = false;
        _userConfirmedSimilar = false;
        _similarMatches = [];
        _visible  = true;
        StateHasChanged();
    }

    public void ShowForEdit(string firstName, string lastName, string phone, string email,
        string dateOfBirth, string gender, int orgId, string source, string notes, string nick = "")
    {
        _firstName = firstName;
        _lastName  = lastName;
        _nick      = nick;
        _phone     = phone;
        _email     = email;
        _sex       = gender;
        _orgId     = orgId;
        _source  = source;
        _notes     = notes;
        // Convert yyyy-MM-dd to dd/MM/yyyy for display
        _dobText   = DateOnly.TryParse(dateOfBirth, out var d) ? d.ToString("dd/MM/yyyy") : "";
        _courseId   = 0;
        _error     = "";
        _editOriginalFullName = $"{firstName.Trim()} {lastName.Trim()}";
        _showSimilarWarning = false;
        _userConfirmedSimilar = false;
        _similarMatches = [];
        _visible   = true;
        StateHasChanged();
    }

    /// Parse dd/MM/yyyy text to yyyy-MM-dd for storage, or return empty if blank/invalid.
    string ParseDobText()
    {
        if (string.IsNullOrWhiteSpace(_dobText)) return "";
        if (DateOnly.TryParseExact(_dobText.Trim(), "dd/MM/yyyy", null, System.Globalization.DateTimeStyles.None, out var d))
            return d.ToString("yyyy-MM-dd");
        if (DateOnly.TryParseExact(_dobText.Trim(), "d/M/yyyy", null, System.Globalization.DateTimeStyles.None, out d))
            return d.ToString("yyyy-MM-dd");
        return "";
    }

    async Task Save()
    {
        _error = "";
        if (string.IsNullOrWhiteSpace(_firstName))
            { _error = "First name is required."; return; }
        if (string.IsNullOrWhiteSpace(_lastName))
            { _error = "Last name is required."; return; }
        if (string.IsNullOrWhiteSpace(_phone))
            { _error = "Phone is required."; return; }
        if (RequireAllFields)
        {
            if (string.IsNullOrWhiteSpace(_sex))
                { _error = "Gender is required."; return; }
            if (_orgId <= 0)
                { _error = "Organization is required."; return; }
            if (string.IsNullOrWhiteSpace(_source))
                { _error = "Source is required."; return; }
        }
        if (!string.IsNullOrWhiteSpace(_dobText) && ParseDobText() == "")
            { _error = "Date of birth must be dd/mm/yyyy."; return; }
        if (Courses != null && Courses.Count > 0 && _courseId <= 0)
            { _error = "Please select a course."; return; }

        var fullName = $"{_firstName.Trim()} {_lastName.Trim()}";

        // Only check duplicates when adding (not editing)
        if (_editOriginalFullName == null)
        {
            // Fuzzy similarity check (before exact check)
            if (!_userConfirmedSimilar && ExistingFullNames != null && ExistingFullNames.Count > 0)
            {
                var matches = FindSimilarNames(_firstName.Trim(), _lastName.Trim(), ExistingFullNames);
                if (matches.Count > 0)
                {
                    _similarMatches = matches;
                    _showSimilarWarning = true;
                    return;
                }
            }

            var dup = PcSvc.CheckDuplicatePc(_firstName, _lastName, _nick);
            if (dup == "ACTIVE_DUPLICATE")
            {
                _error = $"An active PC named \"{fullName}\" already exists. Add a nickname to distinguish them.";
                return;
            }
        }

        _visible = false;
        await OnSaved.InvokeAsync((
            _firstName.Trim(), _lastName.Trim(),
            _phone.Trim(), _email.Trim(),
            ParseDobText(), _sex,
            _orgId, _source, _notes.Trim(), _courseId, _nick.Trim()));
    }

    void CancelSimilarWarning()
    {
        _showSimilarWarning = false;
        _userConfirmedSimilar = false;
        _similarMatches = [];
    }

    async Task ConfirmAddAnyway()
    {
        _showSimilarWarning = false;
        _userConfirmedSimilar = true;
        await Save();
    }

    void Cancel() => _visible = false;

    void OnBackdropClick() => _visible = false;

    // ── Fuzzy duplicate detection ──────────────────────────────

    /// <summary>
    /// Find existing names that are similar to the given first+last name.
    /// Returns matches above 80% similarity, sorted by highest first, max 5.
    /// </summary>
    static List<(string Name, int Pct)> FindSimilarNames(string first, string last, HashSet<string> existing)
    {
        var inputFull = $"{first} {last}".ToLowerInvariant();
        var inputSwapped = $"{last} {first}".ToLowerInvariant();
        var inputFirst = first.ToLowerInvariant();
        var inputLast = last.ToLowerInvariant();
        const int threshold = 80;

        var results = new List<(string Name, int Pct)>();

        foreach (var name in existing)
        {
            var existingLower = name.ToLowerInvariant().Trim();
            if (existingLower.Length == 0) continue;

            // Exact match is handled by CheckDuplicatePc — skip here
            if (existingLower == inputFull) continue;

            // Score 1: full name comparison
            int score1 = SimilarityPct(inputFull, existingLower);

            // Score 2: swapped first/last vs existing
            int score2 = SimilarityPct(inputSwapped, existingLower);

            // Score 3: compare first+last parts separately (weighted average)
            int score3 = 0;
            var parts = existingLower.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length == 2)
            {
                int firstSim = SimilarityPct(inputFirst, parts[0]);
                int lastSim  = SimilarityPct(inputLast,  parts[1]);
                score3 = (firstSim + lastSim) / 2;
            }

            int bestScore = Math.Max(score1, Math.Max(score2, score3));
            if (bestScore >= threshold)
                results.Add((name, bestScore));
        }

        return results
            .OrderByDescending(r => r.Pct)
            .Take(5)
            .ToList();
    }

    /// <summary>Returns similarity percentage (0-100) between two strings.</summary>
    static int SimilarityPct(string a, string b)
    {
        if (a.Length == 0 && b.Length == 0) return 100;
        int maxLen = Math.Max(a.Length, b.Length);
        if (maxLen == 0) return 100;
        int dist = LevenshteinDistance(a, b);
        return (int)Math.Round((1.0 - (double)dist / maxLen) * 100);
    }

    /// <summary>Compute Levenshtein edit distance between two strings.</summary>
    static int LevenshteinDistance(string a, string b)
    {
        int n = a.Length, m = b.Length;
        if (n == 0) return m;
        if (m == 0) return n;

        // Use single-row optimization for memory efficiency
        var prev = new int[m + 1];
        var curr = new int[m + 1];

        for (int j = 0; j <= m; j++) prev[j] = j;

        for (int i = 1; i <= n; i++)
        {
            curr[0] = i;
            for (int j = 1; j <= m; j++)
            {
                int cost = a[i - 1] == b[j - 1] ? 0 : 1;
                curr[j] = Math.Min(
                    Math.Min(curr[j - 1] + 1, prev[j] + 1),
                    prev[j - 1] + cost);
            }
            (prev, curr) = (curr, prev);
        }
        return prev[m];
    }
}
