@* Shared modal for adding a new person.
   Usage:
     <SpkNewPersonModal @ref="_modal" Title="Add New XYZ" OnSaved="HandleSaved" />

   Call _modal.Show() to open it.
   OnSaved fires with (FirstName, LastName, Phone, Email, Age?, Sex) on successful save.
*@

@if (_visible)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);"
         @onclick="OnBackdropClick">
        <div class="modal-dialog modal-dialog-centered"
             @onclick:stopPropagation="true">
            <div class="modal-content shadow">

                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0">@Title</h6>
                    <button type="button" class="btn-close" @onclick="Cancel"></button>
                </div>

                <div class="modal-body">
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                First Name <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_firstName" placeholder="First name" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">Last Name</label>
                            <input class="form-control form-control-sm"
                                   @bind="_lastName" placeholder="Last name" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">Phone</label>
                            <input class="form-control form-control-sm"
                                   @bind="_phone" placeholder="Phone number" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">Email</label>
                            <input class="form-control form-control-sm"
                                   @bind="_email" placeholder="Email address" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">Date of Birth</label>
                            <input type="date" class="form-control form-control-sm" @bind="_dob" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">Sex</label>
                            <select class="form-select form-select-sm" @bind="_sex">
                                <option value="">— select —</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-1 px-2 mt-2 small mb-0">@_error</div>
                    }
                </div>

                <div class="modal-footer py-2">
                    <button class="btn btn-sm btn-link text-muted" @onclick="Cancel">Cancel</button>
                    <button class="btn btn-sm btn-primary" @onclick="Save">
                        <i class="ri-save-line me-1"></i>Save
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Title { get; set; } = "Add New Person";
    [Parameter] public EventCallback<(string FirstName, string LastName, string Phone, string Email, string DateOfBirth, string Sex)> OnSaved { get; set; }

    string   _firstName = "", _lastName = "";
    string   _phone = "", _email = "", _sex = "";
    DateOnly? _dob;
    string   _error = "";
    bool     _visible;

    public void Show()
    {
        _firstName = _lastName = _phone = _email = _sex = _error = "";
        _dob     = null;
        _visible = true;
        StateHasChanged();
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_firstName))
        {
            _error = "First name is required.";
            return;
        }
        _visible = false;
        await OnSaved.InvokeAsync((
            _firstName.Trim(), _lastName.Trim(),
            _phone.Trim(), _email.Trim(),
            _dob?.ToString("yyyy-MM-dd") ?? "", _sex));
    }

    void Cancel() => _visible = false;

    void OnBackdropClick() => _visible = false;
}
