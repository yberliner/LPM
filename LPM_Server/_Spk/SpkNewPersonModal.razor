@* Shared modal for adding a new person.
   Usage:
     <SpkNewPersonModal @ref="_modal" Title="Add New PC" RequireAllFields="true" OnSaved="HandleSaved" />
     <SpkNewPersonModal @ref="_modal" Title="New Student" Courses="_courses" OnSaved="HandleSaved" />

   Call _modal.Show() to open it.
   OnSaved fires with (FirstName, LastName, Phone, Email, DateOfBirth, Gender, OrgId, Source, Notes, CourseId).
   When RequireAllFields=true, Phone/Email/Gender/OrgId/Source are mandatory (DOB and ExternalId are always optional).
*@

@using LPM.Services
@inject LPM.Services.AcademyService AcademySvc

@if (_visible)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);"
         @onclick="OnBackdropClick">
        <div class="modal-dialog modal-dialog-centered"
             @onclick:stopPropagation="true">
            <div class="modal-content shadow spk-new-person-modal" style="background:#fff; color:#212529;">

                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1a237e,#3949ab); border-bottom:none;">
                    <h6 class="modal-title mb-0" style="color:#fff !important;">
                        <i class="ri-user-add-line me-2 opacity-75" style="color:#fff !important;"></i>@Title
                    </h6>
                    <button type="button" class="btn-close btn-close-white" @onclick="Cancel"></button>
                </div>

                <div class="modal-body" style="background:#fff; color:#212529;">
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.firstName") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_firstName" placeholder="@LS.T("pcs.firstName")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.lastName") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_lastName" placeholder="@LS.T("pcs.lastName")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.phone") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_phone" placeholder="@LS.T("pcs.phone")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.email") <span class="text-danger">*</span>
                            </label>
                            <input class="form-control form-control-sm"
                                   @bind="_email" placeholder="@LS.T("pcs.email")" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">@LS.T("pcs.dob")</label>
                            <input type="text" class="form-control form-control-sm"
                                   @bind="_dobText" placeholder="dd/mm/yyyy" />
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.gender") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_sex">
                                <option value="">— @LS.T("common.select") —</option>
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>

                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.org") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_orgId">
                                <option value="0">— @LS.T("common.select") —</option>
                                @foreach (var o in _orgOptions)
                                {
                                    <option value="@o.Id">@o.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-6">
                            <label class="form-label small mb-1">
                                @LS.T("pcs.source") @if (RequireAllFields) { <span class="text-danger">*</span> }
                            </label>
                            <select class="form-select form-select-sm" @bind="_source">
                                <option value="">— @LS.T("common.select") —</option>
                                @foreach (var r in _sourceOptions)
                                {
                                    <option value="@r">@r</option>
                                }
                            </select>
                        </div>

                        @if (Courses != null && Courses.Count > 0)
                        {
                            <div class="col-12">
                                <label class="form-label small mb-1">
                                    <i class="ri-book-2-line me-1" style="color:#7c3aed;"></i>@LS.T("pcs.course") <span class="text-danger">*</span>
                                </label>
                                <select class="form-select form-select-sm" @bind="_courseId">
                                    <option value="0">— @LS.T("common.select") —</option>
                                    @foreach (var c in Courses)
                                    {
                                        <option value="@c.CourseId">@c.Name</option>
                                    }
                                </select>
                            </div>
                        }

                        <div class="col-12">
                            <label class="form-label small mb-1">@LS.T("pcs.notes")</label>
                            <textarea class="form-control form-control-sm" rows="2"
                                      @bind="_notes" placeholder="@LS.T("pcs.notes")"></textarea>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-1 px-2 mt-2 small mb-0">@_error</div>
                    }
                </div>

                <div class="modal-footer py-2" style="background:#f8faff; border-top:1px solid #e8edff;">
                    <button class="btn btn-sm btn-link text-muted" @onclick="Cancel">@LS.T("common.cancel")</button>
                    <button class="btn btn-sm btn-primary" @onclick="Save">
                        <i class="ri-save-line me-1"></i>@LS.T("common.save")
                    </button>
                </div>

            </div>
        </div>
    </div>
}

<style>
    .spk-new-person-modal .modal-body .form-label { color: #374151 !important; }
    .spk-new-person-modal .modal-body .form-control,
    .spk-new-person-modal .modal-body .form-select {
        background: #fff !important; color: #212529 !important;
        border-color: #ced4da !important;
    }
</style>

@code {
    [Parameter] public string Title { get; set; } = "Add New Person";
    [Parameter] public bool RequireAllFields { get; set; }
    [Parameter] public List<CourseItem>? Courses { get; set; }
    [Parameter] public HashSet<string>? ExistingFullNames { get; set; }
    [Parameter] public EventCallback<(string FirstName, string LastName, string Phone, string Email,
        string DateOfBirth, string Gender, int OrgId, string Source, string Notes, int CourseId)> OnSaved { get; set; }

    List<string> _sourceOptions = [];
    List<(int Id, string Name)> _orgOptions = [];

    string    _firstName = "", _lastName = "";
    string    _phone = "", _email = "", _sex = "";
    int       _orgId;
    string    _source = "";
    string    _notes = "";
    string    _dobText = "";
    int       _courseId;
    string    _error = "";
    bool      _visible;
    string?   _editOriginalFullName;

    protected override void OnInitialized()
    {
        _sourceOptions = AcademySvc.GetAllReferralSources();
        _orgOptions = AcademySvc.GetAllOrganizations();
    }

    public void Show()
    {
        _firstName = _lastName = _phone = _email = _sex = _error = "";
        _source = _notes = _dobText = "";
        _orgId = 0;
        _courseId = 0;
        _editOriginalFullName = null;
        _visible  = true;
        StateHasChanged();
    }

    public void ShowForEdit(string firstName, string lastName, string phone, string email,
        string dateOfBirth, string gender, int orgId, string source, string notes)
    {
        _firstName = firstName;
        _lastName  = lastName;
        _phone     = phone;
        _email     = email;
        _sex       = gender;
        _orgId     = orgId;
        _source  = source;
        _notes     = notes;
        // Convert yyyy-MM-dd to dd/MM/yyyy for display
        _dobText   = DateOnly.TryParse(dateOfBirth, out var d) ? d.ToString("dd/MM/yyyy") : "";
        _courseId   = 0;
        _error     = "";
        _editOriginalFullName = $"{firstName.Trim()} {lastName.Trim()}";
        _visible   = true;
        StateHasChanged();
    }

    /// Parse dd/MM/yyyy text to yyyy-MM-dd for storage, or return empty if blank/invalid.
    string ParseDobText()
    {
        if (string.IsNullOrWhiteSpace(_dobText)) return "";
        if (DateOnly.TryParseExact(_dobText.Trim(), "dd/MM/yyyy", null, System.Globalization.DateTimeStyles.None, out var d))
            return d.ToString("yyyy-MM-dd");
        if (DateOnly.TryParseExact(_dobText.Trim(), "d/M/yyyy", null, System.Globalization.DateTimeStyles.None, out d))
            return d.ToString("yyyy-MM-dd");
        return "";
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_firstName))
            { _error = "First name is required."; return; }
        if (string.IsNullOrWhiteSpace(_lastName))
            { _error = "Last name is required."; return; }
        if (string.IsNullOrWhiteSpace(_phone))
            { _error = "Phone is required."; return; }
        if (string.IsNullOrWhiteSpace(_email))
            { _error = "Email is required."; return; }
        if (RequireAllFields)
        {
            if (string.IsNullOrWhiteSpace(_sex))
                { _error = "Gender is required."; return; }
            if (_orgId <= 0)
                { _error = "Organization is required."; return; }
            if (string.IsNullOrWhiteSpace(_source))
                { _error = "Source is required."; return; }
        }
        if (!string.IsNullOrWhiteSpace(_dobText) && ParseDobText() == "")
            { _error = "Date of birth must be dd/mm/yyyy."; return; }
        if (Courses != null && Courses.Count > 0 && _courseId <= 0)
            { _error = "Please select a course."; return; }

        var fullName = $"{_firstName.Trim()} {_lastName.Trim()}";
        if (ExistingFullNames != null && ExistingFullNames.Contains(fullName)
            && !string.Equals(fullName, _editOriginalFullName, StringComparison.OrdinalIgnoreCase))
            { _error = $"A person named \"{fullName}\" already exists."; return; }

        _visible = false;
        await OnSaved.InvokeAsync((
            _firstName.Trim(), _lastName.Trim(),
            _phone.Trim(), _email.Trim(),
            ParseDobText(), _sex,
            _orgId, _source, _notes.Trim(), _courseId));
    }

    void Cancel() => _visible = false;

    void OnBackdropClick() => _visible = false;
}
