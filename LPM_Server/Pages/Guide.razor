@page "/Guide"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization

<div class="guide-root">

    @* ── Sidebar ── *@
    <nav class="guide-sidebar">
        <div class="guide-sidebar-inner">
            <div class="guide-sidebar-logo">
                <i class="ri-book-open-line"></i>
                <span>@LS.T("guide.sidebarTitle")</span>
            </div>
            <ul class="guide-nav">
                <li><a href="#overview"    class="guide-nav-link"><i class="ri-home-4-line"></i>@LS.T("guide.nav.overview")</a></li>
                <li><a href="#login"       class="guide-nav-link"><i class="ri-login-box-line"></i>@LS.T("guide.nav.login")</a></li>
                <li><a href="#dashboard"   class="guide-nav-link"><i class="ri-dashboard-line"></i>@LS.T("guide.nav.dashboard")</a></li>
                <li><a href="#pcs"         class="guide-nav-link"><i class="ri-contacts-book-2-line"></i>@LS.T("guide.nav.pcs")</a></li>
                <li><a href="#academy"     class="guide-nav-link"><i class="ri-graduation-cap-line"></i>@LS.T("guide.nav.academy")</a></li>
                <li><a href="#statistics"  class="guide-nav-link"><i class="ri-bar-chart-box-line"></i>@LS.T("guide.nav.statistics")</a></li>
                <li><a href="#management"  class="guide-nav-link"><i class="ri-settings-3-line"></i>@LS.T("guide.nav.management")</a></li>
                <li><a href="#admin"       class="guide-nav-link"><i class="ri-shield-user-line"></i>@LS.T("guide.nav.admin")</a></li>
                <li><a href="#settings"    class="guide-nav-link"><i class="ri-settings-4-line"></i>@LS.T("guide.nav.settings")</a></li>
                <li><a href="#tips"        class="guide-nav-link"><i class="ri-lightbulb-line"></i>@LS.T("guide.nav.tips")</a></li>
            </ul>
        </div>
    </nav>

    @* ── Main content ── *@
    <main class="guide-main">

        @* ── Hero ── *@
        <div class="guide-hero">
            <div class="guide-hero-bg"></div>
            <div class="guide-hero-content">
                <div class="guide-hero-badge"><i class="ri-star-line me-1"></i>@LS.T("guide.hero.badge")</div>
                <h1 class="guide-hero-title">@LS.T("guide.hero.title")</h1>
                <p class="guide-hero-sub">@LS.T("guide.hero.sub")</p>
                <div class="guide-hero-pills">
                    <span class="guide-pill" style="background:#e0e7ff;color:#3730a3;"><i class="ri-dashboard-line me-1"></i>@LS.T("guide.nav.dashboard")</span>
                    <span class="guide-pill" style="background:#fef3c7;color:#92400e;"><i class="ri-contacts-book-2-line me-1"></i>@LS.T("guide.nav.pcs")</span>
                    <span class="guide-pill" style="background:#dcfce7;color:#166534;"><i class="ri-graduation-cap-line me-1"></i>@LS.T("guide.nav.academy")</span>
                    <span class="guide-pill" style="background:#ede9fe;color:#5b21b6;"><i class="ri-bar-chart-box-line me-1"></i>@LS.T("guide.nav.statistics")</span>
                    <span class="guide-pill" style="background:#e0f2fe;color:#0369a1;"><i class="ri-settings-3-line me-1"></i>@LS.T("guide.nav.management")</span>
                    <span class="guide-pill" style="background:#fce7f3;color:#9d174d;"><i class="ri-shield-user-line me-1"></i>@LS.T("guide.nav.admin")</span>
                </div>
            </div>
        </div>

        @* ══════════════════════════════════════════════════════════
           SECTION 1 — OVERVIEW
        ══════════════════════════════════════════════════════════ *@
        <section id="overview" class="guide-section">
            <div class="guide-section-header" style="background:linear-gradient(135deg,#1e3a8a,#3b82f6);">
                <i class="ri-home-4-line guide-section-icon"></i>
                <div>
                    <h2 class="guide-section-title">@LS.T("guide.overview.title")</h2>
                    <p class="guide-section-sub">@LS.T("guide.overview.sub")</p>
                </div>
            </div>
            <div class="guide-section-body">
                <p class="guide-lead">@LS.T("guide.overview.lead")</p>

                <div class="guide-card-grid">
                    <div class="guide-feature-card" style="border-top:4px solid #6366f1;">
                        <div class="guide-feature-icon" style="background:#e0e7ff;color:#4338ca;"><i class="ri-dashboard-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.dashboardTitle")</strong>
                            <p>@LS.T("guide.overview.dashboardDesc")</p>
                        </div>
                    </div>
                    <div class="guide-feature-card" style="border-top:4px solid #f59e0b;">
                        <div class="guide-feature-icon" style="background:#fef3c7;color:#d97706;"><i class="ri-contacts-book-2-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.pcsTitle")</strong>
                            <p>@LS.T("guide.overview.pcsDesc")</p>
                        </div>
                    </div>
                    <div class="guide-feature-card" style="border-top:4px solid #10b981;">
                        <div class="guide-feature-icon" style="background:#d1fae5;color:#059669;"><i class="ri-graduation-cap-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.academyTitle")</strong>
                            <p>@LS.T("guide.overview.academyDesc")</p>
                        </div>
                    </div>
                    <div class="guide-feature-card" style="border-top:4px solid #7c3aed;">
                        <div class="guide-feature-icon" style="background:#ede9fe;color:#6d28d9;"><i class="ri-bar-chart-box-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.statisticsTitle")</strong>
                            <p>@LS.T("guide.overview.statisticsDesc")</p>
                        </div>
                    </div>
                    <div class="guide-feature-card" style="border-top:4px solid #0284c7;">
                        <div class="guide-feature-icon" style="background:#e0f2fe;color:#0369a1;"><i class="ri-settings-3-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.managementTitle")</strong>
                            <p>@LS.T("guide.overview.managementDesc")</p>
                        </div>
                    </div>
                    <div class="guide-feature-card" style="border-top:4px solid #ec4899;">
                        <div class="guide-feature-icon" style="background:#fce7f3;color:#db2777;"><i class="ri-shield-user-line"></i></div>
                        <div class="guide-feature-text">
                            <strong>@LS.T("guide.overview.adminTitle")</strong>
                            <p>@LS.T("guide.overview.adminDesc")</p>
