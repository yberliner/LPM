@page "/Import"
@using LPM.Services
@attribute [Authorize(Roles = "Admin,Customer")]
@inject FolderService FolderSvc
@inject PcService PcSvc
@inject DashboardService DashSvc
@inject ImportJobService ImportJob
@inject LPM.Auth.UserDb UserDb
@inject LPM.Services.SmsService SmsSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@implements IDisposable

<div class="p-3 p-md-4" style="max-width:960px;">

    <h4 class="fw-bold mb-1" style="color:#37474f;">Import PC Folders</h4>
    <span class="text-muted" style="font-size:.82rem;">
        Import a single PC folder or an entire directory of PC folders from your machine.
    </span>

    @{ var job = ImportJob.CurrentJob; }

    @* ── Active/completed job display ── *@
    @if (job != null && job.Status is ImportStatus.Processing or ImportStatus.Complete or ImportStatus.Failed)
    {
        <div class="card mt-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
            <div class="card-header py-2" style="background:rgba(59,130,246,.15); color:#60a5fa; font-size:.85rem;">
                <i class="@(job.Status == ImportStatus.Processing ? "ri-loader-4-line" : job.Status == ImportStatus.Complete ? "ri-check-double-line" : "ri-error-warning-line") me-1"></i>
                <strong>@(job.Status switch {
                    ImportStatus.Processing => "Import in progress...",
                    ImportStatus.Complete => "Import complete!",
                    ImportStatus.Failed => "Import failed",
                    _ => ""
                })</strong>
            </div>
            <div class="card-body py-3">
                @if (job.Status == ImportStatus.Processing)
                {
                    <div class="d-flex align-items-center gap-2 mb-2" style="font-size:.82rem;">
                        <span class="spinner-border spinner-border-sm"></span>
                        <span>@job.CurrentFileName</span>
                    </div>
                }
                <div class="progress mb-2" style="height:8px; background:#334155;">
                    <div class="progress-bar @(job.Status == ImportStatus.Failed ? "bg-danger" : "bg-success")"
                         role="progressbar"
                         style="width:@(job.TotalFiles > 0 ? job.ProcessedFiles * 100 / job.TotalFiles : 0)%; transition:width .3s;"></div>
                </div>
                <div style="font-size:.75rem; color:#94a3b8;">
                    @job.ProcessedFiles / @job.TotalFiles files —
                    @job.SkippedFiles skipped —
                    @job.NewPcsCreated new PCs —
                    @job.SessionsCreated sessions
                </div>
                @if (job.Status == ImportStatus.Failed && !string.IsNullOrEmpty(job.ErrorMessage))
                {
                    <div class="alert alert-danger mt-2 py-1" style="font-size:.8rem;">
                        <i class="ri-error-warning-line me-1"></i>@job.ErrorMessage
                    </div>
                }
                @if (job.Status == ImportStatus.Complete)
                {
                    <div class="alert alert-success mt-2 py-1 mb-0" style="font-size:.8rem;">
                        <i class="ri-check-double-line me-1"></i>All files processed successfully.
                    </div>
                }
            </div>
            @if (job.Status is ImportStatus.Complete or ImportStatus.Failed)
            {
                <div class="card-footer py-2" style="border-color:#334155;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearJob">
                        <i class="ri-close-line me-1"></i>Clear &amp; Start New Import
                    </button>
                </div>
            }
        </div>
    }
    else
    {
        @* ── Normal import UI ── *@

        <div class="btn-group mt-3 mb-3" role="group">
            <button class="btn btn-sm @(_bulkMode ? "btn-outline-primary" : "btn-primary")"
                    @onclick="() => { _bulkMode = false; ResetState(); }">
                <i class="ri-folder-line me-1"></i>Single PC
            </button>
            <button class="btn btn-sm @(_bulkMode ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => { _bulkMode = true; ResetState(); }">
                <i class="ri-folders-line me-1"></i>All PC Folders
            </button>
        </div>

        <div class="mb-2" style="font-size:.82rem; color:#64748b;">
            @if (_bulkMode)
            {
                <span>Select the <strong>root directory</strong> containing all PC folders.</span>
            }
            else
            {
                <span>Select a <strong>single PC folder</strong> (e.g. <code>25-John Doe</code>) containing Front Cover, Back Cover, WorkSheets.</span>
            }
        </div>

        @if (_bulkMode)
        {
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="namesOnlyCheck"
                       checked="@_namesOnly"
                       @onchange="e => { _namesOnly = (bool)(e.Value ?? false); ResetState(); }" />
                <label class="form-check-label" for="namesOnlyCheck" style="font-size:.85rem; color:#e2e8f0; cursor:pointer;">
                    Import PC Names Only
                    <span style="font-size:.75rem; color:#94a3b8; margin-left:6px;">(adds PCs to database without importing files)</span>
                </label>
            </div>
        }

        <input type="file" id="import-folder-input" webkitdirectory directory multiple
               style="display:none;" @onchange="OnFolderSelected" />

        <button class="btn btn-primary d-flex align-items-center gap-2" disabled="@(_uploading || _scanning)"
                @onclick="OpenFolderPicker">
            <i class="ri-folder-open-line"></i>Select Folder
        </button>

        @* ── Scanning animation ── *@
        @if (_scanning)
        {
            <div class="mt-4 d-flex flex-column align-items-center justify-content-center gap-3" style="min-height:140px;">
                <div style="position:relative; width:56px; height:56px;">
                    <div style="position:absolute; inset:0; border-radius:50%;
                                border:3px solid rgba(99,102,241,.15);
                                border-top-color:#6366f1;
                                animation:spin .8s linear infinite;"></div>
                    <div style="position:absolute; inset:8px; border-radius:50%;
                                border:3px solid rgba(99,102,241,.08);
                                border-bottom-color:#a5b4fc;
                                animation:spin 1.2s linear infinite reverse;"></div>
                </div>
                <div style="font-size:.85rem; color:#94a3b8; letter-spacing:.04em;">
                    Scanning folders&hellip;
                </div>
                <button class="btn btn-sm btn-outline-secondary" style="font-size:.75rem;" @onclick="CancelScanning">
                    <i class="ri-close-line me-1"></i>Cancel
                </button>
            </div>
            <style>@@keyframes spin { to { transform:rotate(360deg); } }</style>
        }

        @* ════════════════════════════════════════════════════════════
           NAMES-ONLY PREVIEW
           ════════════════════════════════════════════════════════════ *@
        @if (_namesOnly && _namesOnlyRows.Count > 0)
        {
            <div class="card mt-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                <div class="card-header py-2 d-flex align-items-center gap-2"
                     style="background:rgba(99,102,241,.15); color:#a5b4fc; font-size:.85rem; border-color:rgba(99,102,241,.2);">
                    <i class="ri-user-add-line"></i>
                    <strong>@_namesOnlyRows.Count(r => !r.IsArchive) PC(s) to process — @_namesOnlyRows.Count(r => r.IsArchive) archive(s) ignored</strong>
                </div>
                <div class="card-body p-0 table-responsive">
                    <table class="table table-sm mb-0" style="font-size:.78rem; color:#e2e8f0;">
                        <thead>
                            <tr style="background:rgba(0,0,0,.25); color:#94a3b8;">
                                <th style="padding:7px 12px;">Folder Name</th>
                                <th style="padding:7px 12px;">Type</th>
                                <th style="padding:7px 12px;">PC Name / Matched PC</th>
                                <th style="padding:7px 12px;">Target Path</th>
                                <th style="padding:7px 12px;">Username</th>
                                <th style="padding:7px 12px;">Password</th>
                                <th style="padding:7px 12px;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @* Amber alert for solos where empty PC will be auto-created *@
                            @{ var willCreateEmptyNames = _namesOnlyRows.Where(r => r.IsSolo && r.SoloWillCreateEmpty).ToList(); }
                            @if (willCreateEmptyNames.Count > 0)
                            {
                                <tr>
                                    <td colspan="7" style="padding:0;">
                                        <div class="mx-2 my-2 p-3 rounded-3 border"
                                             style="border-color:#d97706 !important; background:rgba(217,119,6,.1); animation:pulse-amber 1.2s ease-in-out infinite;">
                                            <div class="d-flex align-items-center gap-2 mb-1">
                                                <i class="ri-user-add-fill" style="color:#f59e0b; font-size:1.2rem;"></i>
                                                <strong style="color:#f59e0b; font-size:.88rem;">@willCreateEmptyNames.Count Solo folder(s) have no matching regular PC — an empty PC record will be created for each</strong>
                                            </div>
                                            <ul class="mb-0 ps-3" style="font-size:.8rem; color:#fcd34d;">
                                                @foreach (var u in willCreateEmptyNames)
                                                {
                                                    <li><code style="color:#fcd34d;">@u.FolderName</code> → new empty PC <strong>@u.PcName</strong> will be created</li>
                                                }
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                            @foreach (var row in _namesOnlyRows)
                            {
                                @if (row.IsArchive)
                                {
                                    <tr style="opacity:.35; border-bottom:1px solid rgba(255,255,255,.04);">
                                        <td style="padding:5px 12px; text-decoration:line-through; color:#94a3b8;">
                                            <i class="ri-archive-line me-1"></i>@row.FolderName
                                        </td>
                                        <td colspan="5" style="padding:5px 12px; color:#64748b; font-style:italic;">Archive [@row.FolderName]</td>
                                        <td style="padding:5px 12px;"><span style="color:#475569; font-size:.72rem;">Ignored</span></td>
                                    </tr>
                                }
                                else if (row.IsSolo && row.SoloWillCreateEmpty)
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04); animation:pulse-row-amber 1.2s ease-in-out infinite;">
                                        <td style="padding:5px 12px; color:#94a3b8; font-size:.74rem;">@row.FolderName</td>
                                        <td style="padding:5px 12px;"><span class="badge" style="background:rgba(217,119,6,.3); color:#fcd34d; font-size:.68rem;">Solo</span></td>
                                        <td style="padding:5px 12px; color:#fcd34d;">@row.PcName</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.72rem; color:#fbbf24;">@row.SoloTargetPath ⚡</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.76rem; color:#7dd3fc;">@row.Username</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.76rem; color:#fde68a;">@row.Password</td>
                                        <td style="padding:5px 12px;">
                                            @if (row.ResultMessage != null)
                                            {
                                                <span style="color:@(row.ResultOk ? "#22c55e" : "#f87171"); font-size:.72rem;">@row.ResultMessage</span>
                                            }
                                            else
                                            {
                                                <span style="color:#fbbf24; font-size:.72rem;">New empty PC</span>
                                            }
                                        </td>
                                    </tr>
                                }
                                else if (row.IsSolo)
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04); background:rgba(168,85,247,.06);">
                                        <td style="padding:5px 12px; color:#94a3b8; font-size:.74rem;">@row.FolderName</td>
                                        <td style="padding:5px 12px;"><span class="badge" style="background:rgba(168,85,247,.3); color:#c4b5fd; font-size:.68rem;">Solo</span></td>
                                        <td style="padding:5px 12px; color:#c4b5fd;">@row.MatchedPcName</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.72rem; color:@(row.SoloMatchedViaBatch ? "#fbbf24" : "#94a3b8");">@row.SoloTargetPath@(row.SoloMatchedViaBatch ? " ⚡" : "")</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.76rem; color:#7dd3fc;">@row.Username</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.76rem; color:#fde68a;">@row.Password</td>
                                        <td style="padding:5px 12px;">
                                            @if (row.ResultMessage != null)
                                            {
                                                <span style="color:@(row.ResultOk ? "#22c55e" : "#f87171"); font-size:.72rem;">@row.ResultMessage</span>
                                            }
                                            else
                                            {
                                                <span style="color:@(row.UserAlreadyExists ? "#fbbf24" : "#22c55e"); font-size:.72rem;">
                                                    @(row.UserAlreadyExists ? "User Exists" : "New User")
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04);">
                                        <td style="padding:5px 12px; color:#94a3b8; font-size:.74rem;">@row.FolderName</td>
                                        <td style="padding:5px 12px;"><span style="font-size:.72rem; color:#94a3b8;">Regular</span></td>
                                        <td style="padding:5px 12px;">@row.FirstName @row.LastName</td>
                                        <td style="padding:5px 12px; font-family:monospace; font-size:.72rem; color:#94a3b8;">
                                            @(row.PcAlreadyExists ? $"{row.PcName}" : $"new → {row.PcName}")
                                        </td>
                                        <td style="padding:5px 12px; color:#475569;">—</td>
                                        <td style="padding:5px 12px; color:#475569;">—</td>
                                        <td style="padding:5px 12px;">
                                            @if (row.ResultMessage != null)
                                            {
                                                <span style="color:@(row.ResultOk ? "#22c55e" : "#f87171"); font-size:.72rem;">@row.ResultMessage</span>
                                            }
                                            else if (row.PcAlreadyExists)
                                            {
                                                <span style="color:#fbbf24; font-size:.72rem;">Existing PC</span>
                                            }
                                            else
                                            {
                                                <span style="color:#22c55e; font-size:.72rem;">New PC</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <div class="card-footer py-2 d-flex align-items-center gap-2" style="border-color:#334155;">
                    @if (!_namesOnlyDone)
                    {
                        <button class="btn btn-sm btn-success d-flex align-items-center gap-1"
                                disabled="@_namesOnlyBusy"
                                @onclick="ExecuteNamesOnlyImport">
                            @if (_namesOnlyBusy)
                            { <span class="spinner-border spinner-border-sm"></span> }
                            else
                            { <i class="ri-check-line"></i> }
                            Go
                        </button>
                    }
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelNamesOnly">
                        <i class="ri-close-line me-1"></i>@(_namesOnlyDone ? "Close" : "Cancel")
                    </button>
                    @if (_namesOnlyDone)
                    {
                        <span style="font-size:.78rem; color:#22c55e;">
                            <i class="ri-checkbox-circle-fill me-1"></i>Done — @_namesOnlyRows.Count(r => !r.IsArchive && r.ResultOk) PC(s) processed.
                        </span>
                    }
                </div>
            </div>
        }

        @* ════════════════════════════════════════════════════════════
           PC NAMES + SUMMARY (full import mode)
           ════════════════════════════════════════════════════════════ *@
        @if (_manifest.Count > 0 && !_uploading && !_namesOnly)
        {
            @* Flashing amber alert for solos with no matching regular PC — empty PC will be auto-created *@
            var willCreateEmpty = _manifest.Where(p => p.IsSolo && p.SoloWillCreateEmpty).ToList();
            @if (willCreateEmpty.Count > 0)
            {
                <div class="mt-3 p-3 rounded-3 border"
                     style="border-color:#d97706 !important; background:rgba(217,119,6,.1); animation:pulse-amber 1.2s ease-in-out infinite;">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="ri-user-add-fill" style="color:#f59e0b; font-size:1.3rem;"></i>
                        <strong style="color:#f59e0b; font-size:.92rem;">@willCreateEmpty.Count Solo folder(s) have no matching regular PC — an empty PC record will be created for each</strong>
                    </div>
                    <ul class="mb-0 ps-3" style="font-size:.82rem; color:#fcd34d;">
                        @foreach (var u in willCreateEmpty)
                        {
                            <li><code style="color:#fcd34d;">@u.FolderName</code> → new empty PC <strong>@u.PcName</strong> will be created</li>
                        }
                    </ul>
                </div>
                <style>
                    @@keyframes pulse-amber {
                        0%, 100% { box-shadow: 0 0 0 0 rgba(217,119,6,.5); }
                        50% { box-shadow: 0 0 0 8px rgba(217,119,6,0); }
                    }
                </style>
            }

            <div class="card mt-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                <div class="card-header py-2 d-flex align-items-center gap-3" style="background:rgba(34,197,94,.12); color:#22c55e; font-size:.85rem; border-color:rgba(34,197,94,.2);">
                    <span><i class="ri-user-search-line me-1"></i><strong>@_manifest.Count(p => !p.IsSolo) regular + @_manifest.Count(p => p.IsSolo && !p.SoloUnmatched) solo PC(s) — verify before import</strong></span>
                </div>
                <div class="card-body p-0" style="overflow-x:auto;">
                    <table class="table table-sm mb-0" style="font-size:.8rem; color:#e2e8f0; min-width:820px;">
                        <thead>
                            <tr style="background:rgba(0,0,0,.2); color:#94a3b8;">
                                <th style="padding:8px 12px; width:16%;">Folder</th>
                                <th style="padding:8px 12px; width:8%;">Type</th>
                                <th style="padding:8px 12px; width:18%;">PC Name</th>
                                <th style="padding:8px 12px; width:20%;">Target Path</th>
                                <th style="padding:8px 12px; width:7%; text-align:center;">Front</th>
                                <th style="padding:8px 12px; width:7%; text-align:center;">Back</th>
                                <th style="padding:8px 12px; width:7%; text-align:center;">WS</th>
                                <th style="padding:8px 12px; width:5%; text-align:center;">Att.</th>
                                <th style="padding:8px 12px; width:6%; text-align:center;">Total</th>
                                <th style="padding:8px 12px; width:6%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pc in _manifest)
                            {
                                var inclFiles = pc.Files.Where(f => f.Include).ToList();

                                @if (pc.IsSolo && pc.SoloWillCreateEmpty)
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04); animation:pulse-row-amber 1.2s ease-in-out infinite;">
                                        <td style="padding:6px 12px; color:#94a3b8; font-size:.74rem;"><i class="ri-folder-line me-1"></i>@pc.FolderName</td>
                                        <td style="padding:6px 12px;"><span class="badge" style="background:rgba(217,119,6,.3); color:#fcd34d; font-size:.68rem;">Solo</span></td>
                                        <td style="padding:6px 12px; color:#fcd34d;">@pc.PcName</td>
                                        <td style="padding:6px 12px; font-family:monospace; font-size:.72rem; color:#fbbf24;">@pc.SoloTargetPath ⚡</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Front_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Back_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "WorkSheets")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Attachment")</td>
                                        <td style="padding:6px 12px; text-align:center; font-weight:600;">@inclFiles.Count</td>
                                        <td style="padding:6px 12px;"><span style="color:#fbbf24; font-size:.72rem;">New empty PC</span></td>
                                    </tr>
                                    <style>@@keyframes pulse-row-amber { 0%,100%{background:rgba(217,119,6,.08);} 50%{background:rgba(217,119,6,.22);} }</style>
                                }
                                else if (pc.IsSolo)
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04); background:rgba(168,85,247,.06);">
                                        <td style="padding:6px 12px; color:#94a3b8; font-size:.74rem;"><i class="ri-folder-line me-1"></i>@pc.FolderName</td>
                                        <td style="padding:6px 12px;"><span class="badge" style="background:rgba(168,85,247,.3); color:#c4b5fd; font-size:.68rem;">Solo</span></td>
                                        <td style="padding:6px 12px; color:#c4b5fd;">@pc.MatchedPcName</td>
                                        <td style="padding:6px 12px; font-family:monospace; font-size:.72rem; color:@(pc.SoloMatchedViaBatch ? "#fbbf24" : "#94a3b8");">@pc.SoloTargetPath@(pc.SoloMatchedViaBatch ? " ⚡" : "")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Front_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Back_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "WorkSheets")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Attachment")</td>
                                        <td style="padding:6px 12px; text-align:center; font-weight:600;">@inclFiles.Count</td>
                                        <td style="padding:6px 12px;"><span style="color:#22c55e; font-size:.72rem;">Matched</span></td>
                                    </tr>
                                }
                                else
                                {
                                    <tr style="border-bottom:1px solid rgba(255,255,255,.04);">
                                        <td style="padding:6px 12px; color:#94a3b8; font-size:.74rem;"><i class="ri-folder-line me-1"></i>@pc.FolderName</td>
                                        <td style="padding:6px 12px;"><span style="font-size:.72rem; color:#94a3b8;">Regular</span></td>
                                        <td style="padding:6px 12px;">@pc.PcName</td>
                                        <td style="padding:6px 12px; font-family:monospace; font-size:.72rem; color:#94a3b8;">@(pc.ExistingPcId.HasValue ? $"{pc.ExistingPcId.Value}-{pc.PcName}" : $"(new) {pc.PcName}")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Front_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Back_Cover")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "WorkSheets")</td>
                                        <td style="padding:6px 12px; text-align:center;">@inclFiles.Count(f => f.Section == "Attachment")</td>
                                        <td style="padding:6px 12px; text-align:center; font-weight:600;">@inclFiles.Count</td>
                                        <td style="padding:6px 12px;">
                                            @if (pc.ExistingPcId.HasValue)
                                            { <span style="color:#22c55e; font-size:.72rem;">Existing</span> }
                                            else
                                            { <span style="color:#fbbf24; font-size:.72rem;">New PC</span> }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ════════════════════════════════════════════════════════════
           COVER FILES WITH CHECKBOXES (single mode only)
           ════════════════════════════════════════════════════════════ *@
        @if (!_bulkMode && _manifest.Count > 0 && !_uploading)
        {
            var coverFiles = _manifest.SelectMany(pc => pc.Files)
                .Where(f => f.Section is "Front_Cover" or "Back_Cover").ToList();
            if (coverFiles.Count > 0)
            {
            <div class="card mt-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                <div class="card-header py-2 d-flex align-items-center" style="background:rgba(251,191,36,.12); color:#fbbf24; font-size:.85rem; border-color:rgba(251,191,36,.2);">
                    <i class="ri-file-settings-line me-1"></i>
                    <strong>Cover Files</strong>
                    <span class="ms-2" style="font-size:.72rem; opacity:.7;">
                        @coverFiles.Count(f => f.Include) of @coverFiles.Count selected — uncheck to skip
                    </span>
                    <button class="btn btn-sm ms-auto py-0 px-2" style="color:#fbbf24; font-size:.7rem;"
                            @onclick="() => { var allOn = coverFiles.All(x => x.Include); foreach (var f in coverFiles) { f.Include = !allOn; if (f.AlreadyExists) f.OverrideExisting = !allOn; } }">
                        Toggle All
                    </button>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0" style="font-size:.78rem; color:#e2e8f0;">
                        <thead>
                            <tr style="background:rgba(0,0,0,.2); color:#94a3b8;">
                                <th style="padding:6px 12px; width:5%;"></th>
                                <th style="padding:6px 12px; width:28%;">File</th>
                                <th style="padding:6px 12px; width:11%;">Section</th>
                                <th style="padding:6px 12px; width:11%;">Status</th>
                                <th style="padding:6px 12px; width:30%;">Folder Item</th>
                                <th style="padding:6px 12px; width:15%; text-align:right;">Size</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var file in coverFiles)
                            {
                                var f = file;
                                var cm = _coverMappings.FirstOrDefault(
                                    c => c.FileName == f.FileName && c.Section == f.Section);
                                <tr style="border-bottom:1px solid rgba(255,255,255,.03); opacity:@(f.Include ? "1" : "0.4");">
                                    <td style="padding:4px 12px; text-align:center;">
                                        @if (f.AlreadyExists)
                                        {
                                            <input type="checkbox" checked="@f.OverrideExisting"
                                                   @onchange="() => { f.OverrideExisting = !f.OverrideExisting; f.Include = f.OverrideExisting; }" />
                                        }
                                        else
                                        {
                                            <input type="checkbox" checked="@f.Include"
                                                   @onchange="() => f.Include = !f.Include" />
                                        }
                                    </td>
                                    <td style="padding:4px 12px;">
                                        <i class="ri-file-pdf-2-line me-1" style="color:@(f.AlreadyExists ? "#fbbf24" : "#ef5350"); font-size:.7rem;"></i>@f.FileName
                                    </td>
                                    <td style="padding:4px 12px; color:#94a3b8;">@f.Section.Replace("_", " ")</td>
                                    <td style="padding:4px 12px;">
                                        @if (f.AlreadyExists)
                                        {
                                            <span style="color:#fbbf24; font-size:.72rem;">
                                                <i class="ri-error-warning-line me-1"></i>Exists
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="color:#22c55e; font-size:.72rem;">New</span>
                                        }
                                    </td>
                                    <td style="padding:4px 12px;">
                                        @if (cm != null)
                                        {
                                            var mapping = cm;
                                            var sectionItems = _folderItems.Where(fi => fi.Section == mapping.Section).ToList();
                                            <select class="form-select form-select-sm"
                                                    style="background:#0f172a; color:#e2e8f0; border-color:#475569; font-size:.72rem; padding:2px 6px;"
                                                    value="@mapping.AssignedItemId"
                                                    @onchange="e => mapping.AssignedItemId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0">
                                                <option value="0">— None —</option>
                                                @foreach (var item in sectionItems)
                                                {
                                                    <option value="@item.ItemId">@item.Name</option>
                                                }
                                            </select>
                                        }
                                    </td>
                                    <td style="padding:4px 12px; text-align:right; color:#64748b;">
                                        @FormatBytes(f.Size)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            }
        }

        @* ════════════════════════════════════════════════════════════
           DISK SPACE + START IMPORT
           ════════════════════════════════════════════════════════════ *@
        @if (_manifest.Count > 0 && !_uploading && !_namesOnly)
        {
            <div class="card mt-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center flex-wrap gap-3" style="font-size:.82rem;">
                        <div>
                            <i class="ri-hard-drive-2-line me-1" style="color:#60a5fa;"></i>
                            <strong>Needed:</strong>
                            <span style="color:#fbbf24;">@FormatBytes(_totalSizeBytes)</span>
                        </div>
                        <div>
                            <i class="ri-database-2-line me-1" style="color:#60a5fa;"></i>
                            <strong>Free space:</strong>
                            <span style="color:@(_freeSpaceBytes > _totalSizeBytes * 2 ? "#22c55e" : _freeSpaceBytes > _totalSizeBytes ? "#fbbf24" : "#ef4444");">
                                @FormatBytes(_freeSpaceBytes)
                            </span>
                        </div>
                        @if (_freeSpaceBytes < _totalSizeBytes * 2)
                        {
                            <span style="color:#ef4444; font-size:.75rem;">
                                <i class="ri-error-warning-line me-1"></i>Low disk space — need at least 2x for processing
                            </span>
                        }
                    </div>
                </div>
                <div class="card-footer py-2 d-flex align-items-center gap-2" style="border-color:#334155;">
                    <button class="btn btn-sm btn-success d-flex align-items-center gap-1"
                            disabled="@(_freeSpaceBytes < _totalSizeBytes)"
                            @onclick="StartUploadAndImport">
                        <i class="ri-upload-2-line"></i>Start Import
                    </button>
                    <span style="font-size:.72rem; color:#64748b;">
                        @_manifest.Sum(m => m.Files.Count(f => f.Include)) files to import across @_manifest.Count PC(s)
                        @{ var skippedCount = _manifest.Sum(m => m.Files.Count(f => !f.Include && f.AlreadyExists)); }
                        @{ var overrideCount = _manifest.Sum(m => m.Files.Count(f => f.OverrideExisting)); }
                        @if (skippedCount > 0)
                        {
                            <span style="color:#64748b;"> — @skippedCount skipped</span>
                        }
                        @if (overrideCount > 0)
                        {
                            <span style="color:#fbbf24;"> — @overrideCount override(s)</span>
                        }
                    </span>
                </div>
            </div>
        }

        @* ── Upload progress (Phase 1) ── *@
        @if (_uploading)
        {
            <div class="mt-3">
                <div class="d-flex align-items-center gap-2 mb-1" style="font-size:.82rem;">
                    <span class="spinner-border spinner-border-sm"></span>
                    <span>Uploading files to server... @_uploadedCount / @_totalFileCount</span>
                </div>
                <div class="progress" style="height:8px; background:#334155;">
                    <div class="progress-bar bg-info" role="progressbar"
                         style="width:@(_totalFileCount > 0 ? _uploadedCount * 100 / _totalFileCount : 0)%; transition:width .3s;"></div>
                </div>
                <div class="mt-1" style="font-size:.72rem; color:#94a3b8;">
                    Stay on this page until upload completes. Processing will continue in the background.
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-3 py-2" style="font-size:.82rem;">
                <i class="ri-error-warning-line me-1"></i>@_errorMessage
            </div>
        }
    }
</div>

@code {
    bool _bulkMode;
    bool _namesOnly;
    bool _namesOnlyBusy;
    bool _namesOnlyDone;
    List<NamesOnlyRow> _namesOnlyRows = [];

    bool _scanning;
    bool _uploading;
    string _errorMessage = "";
    int _uploadedCount, _totalFileCount;
    int? _userId;
    string _logUsername = "";
    long _totalSizeBytes;
    long _freeSpaceBytes;

    List<DashboardService.FolderItem> _folderItems = [];
    List<LocalPcManifest> _manifest = [];
    List<CoverMappingLocal> _coverMappings = [];

    class NamesOnlyRow
    {
        public string FolderName    { get; set; } = "";
        public string PcName        { get; set; } = "";
        public string FirstName     { get; set; } = "";
        public string LastName      { get; set; } = "";
        public bool   IsSolo        { get; set; }
        public bool   IsArchive     { get; set; }
        // Solo match info
        public int?   MatchedPcId         { get; set; }
        public string MatchedPcName       { get; set; } = "";
        public string SoloTargetPath      { get; set; } = "";
        public bool   SoloUnmatched       { get; set; }
        public bool   SoloMatchedViaBatch { get; set; }
        public bool   SoloWillCreateEmpty { get; set; }
        // Solo user info
        public string Username      { get; set; } = "";
        public string Password      { get; set; } = "";
        public bool   PcAlreadyExists   { get; set; }
        public bool   UserAlreadyExists { get; set; }
        public string? ResultMessage    { get; set; }
        public bool    ResultOk         { get; set; }
    }

    class LocalFileEntry
    {
        public int FileIndex { get; set; }
        public string RelativePath { get; set; } = "";
        public string FileName { get; set; } = "";
        public string Section { get; set; } = "";
        public string? ParentSessionFile { get; set; }
        public long Size { get; set; }
        public string? LastModified { get; set; }
        public bool Include { get; set; } = true;
        public bool AlreadyExists { get; set; }
        public bool OverrideExisting { get; set; }
    }
    class LocalPcManifest
    {
        public string FolderName { get; set; } = "";
        public string PcName { get; set; } = "";
        public int? ExistingPcId { get; set; }
        public bool IsSolo { get; set; }
        // Solo-specific: resolved after ParseManifest
        public int? MatchedPcId { get; set; }       // null = not yet in DB (will be created in batch)
        public string MatchedPcName { get; set; } = "";
        public string SoloTargetPath { get; set; } = "";
        public bool SoloUnmatched { get; set; }         // no match found — empty PC will be created
        public bool SoloMatchedViaBatch { get; set; }   // matched via non-solo in same import batch
        public bool SoloWillCreateEmpty { get; set; }   // alias for clarity in UI
        public List<LocalFileEntry> Files { get; set; } = [];
    }
    class CoverMappingLocal
    {
        public string FileName { get; set; } = "";
        public string Section { get; set; } = "";
        public string PcName { get; set; } = "";
        public string PcFolderName { get; set; } = "";
        public int AssignedItemId { get; set; }
    }
    record ManifestEntry(int index, string relativePath, long size, string lastModified);

    protected override async Task OnInitializedAsync()
    {
        _folderItems = DashSvc.GetFolderItems();
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _logUsername = auth.User.Identity?.Name ?? "";
        _userId = DashSvc.GetUserIdByUsername(_logUsername);
        ImportJob.OnProgressChanged += OnJobProgress;
    }

    void OnJobProgress() => _ = InvokeAsync(StateHasChanged);

    public void Dispose() => ImportJob.OnProgressChanged -= OnJobProgress;

    void ClearJob() => ImportJob.ClearJob();


    void ResetState()
    {
        _manifest.Clear();
        _coverMappings.Clear();
        _namesOnlyRows.Clear();
        _namesOnlyBusy = false;
        _namesOnlyDone = false;
        _errorMessage = "";
        _uploadedCount = _totalFileCount = 0;
        _totalSizeBytes = _freeSpaceBytes = 0;
    }

    async Task OpenFolderPicker()
    {
        ResetState();
        _scanning = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("folderImport.openPicker", "import-folder-input");
    }

    void CancelScanning()
    {
        _scanning = false;
        StateHasChanged();
    }

    async Task OnFolderSelected()
    {
        _errorMessage = "";
        // _scanning already set to true in OpenFolderPicker
        try
        {

        var entries = await JS.InvokeAsync<List<ManifestEntry>>("folderImport.readManifest", "import-folder-input");
        if (entries == null || entries.Count == 0) { _errorMessage = "No files found."; return; }

        // Names-only mode: just scan folder names, no file content needed
        if (_namesOnly && _bulkMode)
        {
            BuildNamesOnlyPreview(entries);
            return; // finally block clears _scanning
        }

        var supportedExts = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
            { ".pdf", ".doc", ".docx", ".odt", ".rtf" };
        entries = entries.Where(e => supportedExts.Contains(Path.GetExtension(e.relativePath))).ToList();
        if (entries.Count == 0) { _errorMessage = "No supported files found (PDF, DOC, DOCX)."; return; }

        ParseManifest(entries);
        ResolveSoloMatches();
        MarkExistingFiles();

        // Only build cover mappings for single mode
        if (!_bulkMode)
            BuildCoverMappings();

        // Calculate disk space (only for files to be imported)
        _totalSizeBytes = _manifest.SelectMany(pc => pc.Files).Where(f => f.Include).Sum(f => f.Size);
        _freeSpaceBytes = FolderSvc.GetFreeSpaceBytes();

        }
        finally
        {
            _scanning = false;
            StateHasChanged();
        }
    }

    void BuildNamesOnlyPreview(List<ManifestEntry> entries)
    {
        _namesOnlyRows.Clear();
        _namesOnlyDone = false;

        // Use the same section-detection logic as ParseManifest to find the actual PC folder
        // (the folder immediately above WorkSheets / Front Cover / Back Cover),
        // regardless of nesting depth. Deduplicate by folder name (case insensitive).
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        foreach (var e in entries)
        {
            var parts = e.relativePath.Split('/');
            if (parts.Length < 3) continue;

            string? section = null;
            int sectionIdx = -1;

            for (int i = 0; i < parts.Length - 1; i++)
            {
                var seg = parts[i];
                if (seg.EndsWith("_att", StringComparison.OrdinalIgnoreCase))
                {
                    section = "Attachment";
                    break;
                }
                var detected = DetectSection(seg);
                if (detected != null) { section = detected; sectionIdx = i; }
            }

            // For attachments, find the WorkSheets parent index
            if (section == "Attachment")
                for (int i = 0; i < parts.Length - 1; i++)
                    if (DetectSection(parts[i]) != null) sectionIdx = i;

            if (section == null || sectionIdx <= 0) continue;

            var pcFolder = parts[sectionIdx - 1];

            // Deduplicate — same folder name already handled
            if (!seen.Add(pcFolder)) continue;

            // If ANY segment in the path contains "archive" → show as ignored
            var isArchive = parts.Any(p => p.Contains("archive", StringComparison.OrdinalIgnoreCase));
            if (isArchive)
            {
                _namesOnlyRows.Add(new NamesOnlyRow { FolderName = pcFolder, IsArchive = true });
                continue;
            }

            var isSolo = System.Text.RegularExpressions.Regex.IsMatch(
                pcFolder, @"(?<!\w)solo(?!\w)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);

            var stripped = System.Text.RegularExpressions.Regex.Replace(pcFolder.Trim(), @"^\d+-\s*", "");
            var pcName = PcService.StripNoiseWords(stripped);
            if (string.IsNullOrWhiteSpace(pcName)) pcName = stripped.Trim();

            var nameParts = pcName.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            var firstName = nameParts.Length > 0 ? nameParts[0] : pcName;
            var lastName  = nameParts.Length > 1 ? nameParts[1] : "Unknown";

            var (existingId, _) = TryFindPc(pcName);

            var row = new NamesOnlyRow
            {
                FolderName      = pcFolder,
                PcName          = pcName,
                FirstName       = firstName,
                LastName        = lastName,
                IsSolo          = isSolo,
                PcAlreadyExists = existingId.HasValue,
            };

            if (isSolo)
            {
                // Precompute username/password — solo match resolved in second pass below
                var fn = ImportJobService.NormalizeToAscii(firstName);
                var ln = ImportJobService.NormalizeToAscii(lastName);
                row.Username = $"{fn}.{ln}";
                row.Password = $"{fn}1992";
            }

            _namesOnlyRows.Add(row);
        }

        // Second pass: resolve solo matches (DB + batch)
        var batchNonSoloNames = _namesOnlyRows
            .Where(r => !r.IsSolo && !r.IsArchive)
            .ToLookup(r => r.PcName, StringComparer.OrdinalIgnoreCase);

        foreach (var row in _namesOnlyRows.Where(r => r.IsSolo && !r.IsArchive))
        {
            var matchedId = PcSvc.FindPcByName(row.PcName);
            if (matchedId.HasValue)
            {
                row.MatchedPcId       = matchedId;
                row.MatchedPcName     = FolderSvc.GetPcName(matchedId.Value) ?? row.PcName;
                row.SoloTargetPath    = FolderSvc.GetSoloFolderName(matchedId.Value);
                row.UserAlreadyExists = UserDb.UsernameExists(row.Username);
            }
            else if (batchNonSoloNames.Contains(row.PcName))
            {
                row.SoloMatchedViaBatch = true;
                row.MatchedPcName       = row.PcName;
                row.SoloTargetPath      = $"(new) {row.PcName} Solo";
                row.UserAlreadyExists   = UserDb.UsernameExists(row.Username);
            }
            else
            {
                // No match anywhere — will auto-create an empty regular PC
                row.SoloUnmatched       = true;
                row.SoloWillCreateEmpty = true;
                row.MatchedPcName       = row.PcName;
                row.SoloTargetPath      = $"(new) {row.PcName} Solo";
                row.UserAlreadyExists   = UserDb.UsernameExists(row.Username);
            }
        }

        // Sort: regular PCs first (A-Z), solo PCs next (A-Z), archives at bottom
        _namesOnlyRows = [.. _namesOnlyRows.OrderBy(r => r.IsArchive ? 2 : r.IsSolo ? 1 : 0).ThenBy(r => r.FolderName)];
    }

    async Task ExecuteNamesOnlyImport()
    {
        _namesOnlyBusy = true;
        StateHasChanged();
        await Task.Yield();

        foreach (var row in _namesOnlyRows.Where(r => !r.IsArchive))
        {
            try
            {
                if (row.IsSolo)
                {
                    // Resolve PC: prefer pre-matched id, then DB lookup, then create empty
                    var resolvedId = row.MatchedPcId ?? PcSvc.FindPcByName(row.PcName);
                    bool createdEmpty = false;
                    if (resolvedId == null)
                    {
                        // No match — create an empty PC
                        var (newId, _) = PcSvc.FindOrCreatePcByName(row.PcName);
                        resolvedId   = newId;
                        createdEmpty = true;
                    }
                    var pcId = resolvedId.Value;
                    if (!row.UserAlreadyExists && !string.IsNullOrEmpty(row.Username))
                    {
                        UserDb.CreateUser(pcId, row.Username, row.Password, "Solo", "Staff", null, true);
                        row.ResultMessage = createdEmpty ? "Empty PC created + user created" : "Solo matched + user created";
                        var (_, phone) = PcSvc.GetPersonContact(pcId);
                        if (!string.IsNullOrWhiteSpace(phone))
                        {
                            var msg = $"Welcome to LPM!\nUsername: {row.Username}\nPassword: {row.Password}\nSite: lpmanager.cv";
                            _ = SmsSvc.SendSmsAsync(phone, msg);
                        }
                    }
                    else
                    {
                        row.ResultMessage = createdEmpty ? "Empty PC created" : "Solo matched";
                    }
                    row.ResultOk = true;
                }
                else
                {
                    var (pcId, wasCreated) = PcSvc.FindOrCreatePcByName(row.PcName);
                    row.ResultMessage = wasCreated ? "PC created" : "Already exists";
                    row.ResultOk = true;
                }
            }
            catch (Exception ex)
            {
                row.ResultMessage = $"Error: {ex.Message}";
                row.ResultOk = false;
            }
        }

        _namesOnlyBusy = false;
        _namesOnlyDone = true;
        StateHasChanged();
    }

    void CancelNamesOnly()
    {
        _namesOnlyRows.Clear();
        _namesOnlyDone = false;
    }

    // ── Parsing ──

    static string? DetectSection(string folderName)
    {
        var lower = folderName.ToLowerInvariant().Replace("_", " ").Replace("-", " ");
        if (lower.Contains("front") && lower.Contains("cover")) return "Front_Cover";
        if (lower.Contains("back") && lower.Contains("cover")) return "Back_Cover";
        if (lower.Contains("worksheet")) return "WorkSheets";
        return null;
    }

    void ParseManifest(List<ManifestEntry> entries)
    {
        _manifest.Clear();
        var pcGroups = new Dictionary<string, List<(ManifestEntry Entry, string Section, string FileName, string? ParentSession)>>(StringComparer.OrdinalIgnoreCase);

        foreach (var e in entries)
        {
            var parts = e.relativePath.Split('/');
            if (parts.Length < 3) continue;

            // Skip any file under an "Archive" folder (case insensitive)
            if (parts.Any(p => p.Contains("archive", StringComparison.OrdinalIgnoreCase))) continue;

            var fileName = parts[^1];
            string? section = null;
            string? pcFolder = null;
            string? parentSession = null;
            int sectionIdx = -1;

            for (int i = 0; i < parts.Length - 1; i++)
            {
                var seg = parts[i];
                if (seg.EndsWith("_att", StringComparison.OrdinalIgnoreCase))
                {
                    parentSession = seg[..^4] + ".pdf";
                    section = "Attachment";
                    break;
                }
                var detected = DetectSection(seg);
                if (detected != null)
                {
                    section = detected;
                    sectionIdx = i;
                }
            }

            if (section == null) continue;

            if (section == "Attachment")
            {
                for (int i = 0; i < parts.Length - 1; i++)
                    if (DetectSection(parts[i]) != null) sectionIdx = i;
            }

            if (sectionIdx <= 0) continue;
            pcFolder = parts[sectionIdx - 1];

            if (!pcGroups.ContainsKey(pcFolder)) pcGroups[pcFolder] = [];
            pcGroups[pcFolder].Add((e, section, fileName, parentSession));
        }

        foreach (var (folder, files) in pcGroups)
        {
            var isSolo = System.Text.RegularExpressions.Regex.IsMatch(
                folder, @"(?<!\w)solo(?!\w)", System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            var stripped = System.Text.RegularExpressions.Regex.Replace(folder.Trim(), @"^\d+-\s*", "");
            var pcName = PcService.StripNoiseWords(stripped);
            if (string.IsNullOrWhiteSpace(pcName)) pcName = stripped.Trim();
            var (existingId, _) = TryFindPc(pcName);
            var importFiles = files.Select(f => new LocalFileEntry
            {
                FileIndex = f.Entry.index, RelativePath = f.Entry.relativePath,
                FileName = f.FileName, Section = f.Section,
                ParentSessionFile = f.ParentSession, Size = f.Entry.size,
                LastModified = f.Entry.lastModified
            }).ToList();
            _manifest.Add(new LocalPcManifest
            {
                FolderName = folder, PcName = pcName,
                ExistingPcId = existingId, IsSolo = isSolo, Files = importFiles
            });
        }
    }

    void ResolveSoloMatches()
    {
        // Build a lookup of non-solo PC names in this batch (may not exist in DB yet)
        var batchNonSoloNames = _manifest
            .Where(p => !p.IsSolo)
            .ToLookup(p => p.PcName, StringComparer.OrdinalIgnoreCase);

        foreach (var pc in _manifest.Where(p => p.IsSolo))
        {
            // TryFindPc already ran in ParseManifest and set ExistingPcId (DB lookup)
            pc.MatchedPcId = pc.ExistingPcId;

            if (pc.MatchedPcId.HasValue)
            {
                // Found in DB already
                pc.MatchedPcName  = FolderSvc.GetPcName(pc.MatchedPcId.Value) ?? pc.PcName;
                pc.SoloTargetPath = FolderSvc.GetSoloFolderName(pc.MatchedPcId.Value);
            }
            else if (batchNonSoloNames.Contains(pc.PcName))
            {
                // Matched via a non-solo PC being imported in the same batch
                pc.SoloMatchedViaBatch = true;
                pc.MatchedPcName  = pc.PcName;
                pc.SoloTargetPath = $"(new) {pc.PcName} Solo";
                pc.SoloUnmatched  = false;
            }
            else
            {
                // No match anywhere — will auto-create an empty regular PC
                pc.SoloUnmatched       = true;
                pc.SoloWillCreateEmpty = true;
                pc.MatchedPcName       = pc.PcName;
                pc.SoloTargetPath      = $"(new) {pc.PcName} Solo";
            }
        }
        // Sort: non-solo first (A-Z), solo last (A-Z)
        _manifest = [.. _manifest.OrderBy(p => p.IsSolo ? 1 : 0).ThenBy(p => p.PcName)];
    }

    void MarkExistingFiles()
    {
        foreach (var pc in _manifest)
        {
            int? checkId = pc.IsSolo ? pc.MatchedPcId : pc.ExistingPcId;
            if (!checkId.HasValue) continue;
            var pcId = checkId.Value;

            foreach (var file in pc.Files)
            {
                bool exists;
                if (pc.IsSolo)
                {
                    if (file.Section == "Attachment" && file.ParentSessionFile != null)
                        exists = FolderSvc.SoloAttachmentFileExists(pcId, file.ParentSessionFile, file.FileName);
                    else if (file.Section is "Front_Cover" or "Back_Cover" or "WorkSheets")
                        exists = FolderSvc.SoloSectionFileExists(pcId, file.Section, file.FileName);
                    else
                        exists = false;

                    if (!exists && FolderService.ConvertibleExtensions.Contains(Path.GetExtension(file.FileName)))
                    {
                        var pdfName = Path.GetFileNameWithoutExtension(file.FileName) + ".pdf";
                        if (file.Section == "Attachment" && file.ParentSessionFile != null)
                            exists = FolderSvc.SoloAttachmentFileExists(pcId, file.ParentSessionFile, pdfName);
                        else if (file.Section is "Front_Cover" or "Back_Cover" or "WorkSheets")
                            exists = FolderSvc.SoloSectionFileExists(pcId, file.Section, pdfName);
                    }
                }
                else
                {
                    if (file.Section == "Attachment" && file.ParentSessionFile != null)
                        exists = FolderSvc.AttachmentFileExists(pcId, file.ParentSessionFile, file.FileName);
                    else if (file.Section is "Front_Cover" or "Back_Cover" or "WorkSheets")
                        exists = FolderSvc.SectionFileExists(pcId, file.Section, file.FileName);
                    else
                        exists = false;

                    if (!exists && FolderService.ConvertibleExtensions.Contains(Path.GetExtension(file.FileName)))
                    {
                        var pdfName = Path.GetFileNameWithoutExtension(file.FileName) + ".pdf";
                        if (file.Section == "Attachment" && file.ParentSessionFile != null)
                            exists = FolderSvc.AttachmentFileExists(pcId, file.ParentSessionFile, pdfName);
                        else if (file.Section is "Front_Cover" or "Back_Cover" or "WorkSheets")
                            exists = FolderSvc.SectionFileExists(pcId, file.Section, pdfName);
                    }
                }

                if (exists)
                {
                    file.AlreadyExists = true;
                    file.Include = false;
                }
            }
        }
    }

    (int? PcId, bool Found) TryFindPc(string pcName)
    {
        var allPcs = PcSvc.GetAllPcs();
        var match = allPcs.FirstOrDefault(p => p.FullName.Equals(pcName, StringComparison.OrdinalIgnoreCase));
        if (match != null) return (match.PcId, true);
        var parts = pcName.Split(' ', 2, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        var fullName = $"{(parts.Length > 0 ? parts[0] : pcName)} {(parts.Length > 1 ? parts[1] : "")}".Trim();
        match = allPcs.FirstOrDefault(p => p.FullName.Equals(fullName, StringComparison.OrdinalIgnoreCase));
        return match != null ? (match.PcId, true) : (null, false);
    }

    // ── Cover mapping (single mode only) ──

    static readonly Dictionary<string, string[]> ItemKeywords = new(StringComparer.OrdinalIgnoreCase)
    {
        { "Case Progress Sheet", new[] { "case progress", "progress sheet", "cps" } },
        { "Yellow Sheet",        new[] { "yellow" } },
        { "OCA Graph",           new[] { "oca" } },
        { "Program - Main",      new[] { "program main", "main program", "program-main", "prog main" } },
        { "Program - Sub",       new[] { "program sub", "sub program", "program-sub", "prog sub" } },
        { "Folder Summary",      new[] { "summary", "folder summary" } },
        { "Dn Flow Table",       new[] { "dn flow", "flow table", "dnflow" } },
        { "FES",                  new[] { "fes" } },
        { "Routing Form",        new[] { "routing" } },
        { "Invoice Form",        new[] { "invoice" } },
    };

    int AutoMatchItem(string fileName, string section)
    {
        var nameNoExt = Path.GetFileNameWithoutExtension(fileName);
        var normalized = StripDatePrefix(nameNoExt).Replace("_", " ").Replace("-", " ").Replace(".", " ");
        var lower = normalized.ToLowerInvariant();
        var sectionItems = _folderItems.Where(fi => fi.Section == section).ToList();

        foreach (var item in sectionItems)
        {
            if (ItemKeywords.TryGetValue(item.Name, out var keywords))
                foreach (var kw in keywords)
                    if (lower.Contains(kw)) return item.ItemId;

            var itemWords = item.Name.ToLowerInvariant().Replace("-", " ").Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (itemWords.Any(w => w.Length >= 3 && lower.Contains(w)))
                return item.ItemId;
        }
        return 0;
    }

    static string StripDatePrefix(string name)
    {
        if (name.Length >= 7 && name[..6].All(char.IsDigit) && !char.IsDigit(name[6]))
            return name[6..].TrimStart(' ', '_', '-');
        if (name.Length >= 9 && name[2] == '-' && name[5] == '-' && name[8] == '_')
            return name[9..];
        return name;
    }

    void BuildCoverMappings()
    {
        _coverMappings.Clear();
        foreach (var pc in _manifest)
        {
            foreach (var f in pc.Files.Where(f => (f.Section is "Front_Cover" or "Back_Cover") && !f.AlreadyExists))
            {
                _coverMappings.Add(new CoverMappingLocal
                {
                    FileName = f.FileName,
                    Section = f.Section,
                    PcName = pc.PcName,
                    PcFolderName = pc.FolderName,
                    AssignedItemId = AutoMatchItem(f.FileName, f.Section)
                });
            }
        }
    }

    // ── Upload + background import ──

    async Task StartUploadAndImport()
    {
        if (!_userId.HasValue) { _errorMessage = "User not identified."; return; }

        // Filter to included files only
        var includedFiles = _manifest
            .SelectMany(pc => pc.Files.Where(f => f.Include).Select(f => (Pc: pc, File: f)))
            .ToList();

        _totalFileCount = includedFiles.Count;
        Console.WriteLine($"[Import] Started import: {_manifest.Count} PCs, {includedFiles.Count} files by '{_logUsername}'");
        var jobId = ImportJob.TryStartUpload(_userId.Value, _totalFileCount);
        if (jobId == null) { _errorMessage = "An import is already in progress."; return; }

        _uploading = true;
        _uploadedCount = 0;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            foreach (var (pc, file) in includedFiles)
            {
                var base64 = await JS.InvokeAsync<string>("folderImport.readFileAsBase64",
                    "import-folder-input", file.FileIndex);
                if (!string.IsNullOrEmpty(base64))
                {
                    var bytes = Convert.FromBase64String(base64);
                    ImportJob.RecordFileUploaded(jobId, pc.FolderName, file.Section,
                        file.FileName, bytes, file.ParentSessionFile);
                }
                _uploadedCount++;
                await InvokeAsync(StateHasChanged);
            }

            var svcManifest = _manifest
                .Where(pc => true) // all PCs included — unmatched solos get empty PC auto-created
                .Select(pc => new ImportPcManifest(
                    pc.FolderName, pc.PcName,
                    pc.IsSolo ? pc.MatchedPcId : pc.ExistingPcId, // solo: null = batch match, resolved at job time
                    pc.Files.Where(f => f.Include).Select(f => new ImportFileManifest(
                        f.RelativePath, f.FileName, f.Section, f.ParentSessionFile, f.LastModified, f.OverrideExisting
                    )).ToList(),
                    pc.IsSolo
                ))
                .Where(pc => pc.Files.Count > 0)
                .ToList();

            var svcCoverMappings = _coverMappings.Select(m =>
                new ImportCoverMapping(m.FileName, m.Section, m.PcFolderName, m.AssignedItemId)
            ).ToList();

            ImportJob.StartProcessing(jobId, svcManifest, svcCoverMappings);
            _manifest.Clear();
            _coverMappings.Clear();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Upload failed: {ex.Message}";
        }
        finally
        {
            _uploading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1073741824) return $"{bytes / 1048576.0:F1} MB";
        return $"{bytes / 1073741824.0:F2} GB";
    }
