@page "/Statistics"
@using System.Globalization
@using LPM.Services
@using ApexCharts
@attribute [Authorize(Roles = "Admin,Customer")]
@inject StatisticsService StatSvc
@inject DashboardService DashSvc
@inject PdfService PdfService
@inject SessionManagerLauncher SmLauncher
@inject IJSRuntime JS
@implements IDisposable

<style>
    /* ── Per-cell hover breakdown tooltip (audit / csolo / effort) ─────── */
    .stat-cell { cursor: pointer; position: relative; transition: background 140ms ease, box-shadow 140ms ease; }
    .stat-cell:has(.badge):hover { background: rgba(99,102,241,0.08); }
    .stat-cell-active { background: rgba(99,102,241,0.14) !important; box-shadow: inset 0 0 0 1px rgba(99,102,241,0.35); }

    .stat-tooltip {
        position: fixed;
        z-index: 10050;
        width: min(520px, calc(100vw - 24px));
        max-height: 70vh;
        background: #ffffff;
        border-radius: 14px;
        box-shadow: 0 24px 60px rgba(17,24,39,0.22), 0 2px 6px rgba(17,24,39,0.08), 0 0 0 1px rgba(17,24,39,0.05);
        opacity: 0;
        transform: translateY(10px) scale(0.96);
        transform-origin: 50% 0%;
        transition: opacity 200ms cubic-bezier(.2,.9,.25,1.0), transform 220ms cubic-bezier(.2,.9,.25,1.0);
        pointer-events: auto;
        overflow: visible;
        --stat-tip-arrow-x: 50%;
    }
    .stat-tooltip.stat-tooltip-above { transform-origin: 50% 100%; transform: translateY(-10px) scale(0.96); }
    .stat-tooltip.stat-tooltip-show { opacity: 1; transform: translateY(0) scale(1); }
    .stat-tooltip.stat-tooltip-hide {
        transition: opacity 140ms ease-in, transform 140ms ease-in;
        opacity: 0;
        transform: translateY(4px) scale(0.985);
        pointer-events: none;
    }
    /* Arrow/caret pointing at the cell */
    .stat-tooltip::before {
        content: "";
        position: absolute;
        left: var(--stat-tip-arrow-x);
        width: 14px; height: 14px;
        background: #fff;
        transform: translateX(-50%) rotate(45deg);
        box-shadow: -1px -1px 0 0 rgba(17,24,39,0.05);
    }
    .stat-tooltip.stat-tooltip-below::before { top: -6px; }
    .stat-tooltip.stat-tooltip-above::before { bottom: -6px; box-shadow: 1px 1px 0 0 rgba(17,24,39,0.05); }

    .stat-tooltip-inner { display: flex; flex-direction: column; max-height: 70vh; overflow: hidden; border-radius: 14px; }
    .stat-tooltip-header {
        padding: 14px 18px 12px;
        color: #fff;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 14px 14px 0 0;
        flex-shrink: 0;
    }
    .stat-tooltip-header.stat-chip-audit  { background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); }
    .stat-tooltip-header.stat-chip-csolo  { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); }
    .stat-tooltip-header.stat-chip-cs     { background: linear-gradient(135deg, #ec4899 0%, #be185d 100%); }
    .stat-tooltip-header.stat-chip-effort { background: linear-gradient(135deg, #06b6d4 0%, #0891b2 100%); }
    .stat-tooltip-header.stat-chip-total  { background: linear-gradient(135deg, #4338ca 0%, #6366f1 50%, #a855f7 100%); }

    /* Total-cell formula layout */
    .stat-formula { padding: 14px 18px 6px; display: flex; flex-direction: column; gap: 8px; }
    .stat-formula-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 9px 12px; border-radius: 9px;
        background: #f9fafb; border: 1px solid #eef2f7;
        animation: statFormulaRowIn 320ms cubic-bezier(.2,.9,.25,1.0) both;
    }
    .stat-formula-row.fr-audit  { background: linear-gradient(90deg, #eff6ff 0%, #ffffff 100%); border-color: #dbeafe; }
    .stat-formula-row.fr-csolo  { background: linear-gradient(90deg, #fff7ed 0%, #ffffff 100%); border-color: #fed7aa; }
    .stat-formula-row.fr-cs     { background: linear-gradient(90deg, #fdf2f8 0%, #ffffff 100%); border-color: #fbcfe8; opacity: 0.88; }
    .stat-formula-row.fr-effort { background: linear-gradient(90deg, #ecfeff 0%, #ffffff 100%); border-color: #a5f3fc; }
    .stat-formula-row:nth-child(1) { animation-delay: 40ms; }
    .stat-formula-row:nth-child(2) { animation-delay: 100ms; }
    .stat-formula-row:nth-child(3) { animation-delay: 160ms; }
    .stat-formula-row:nth-child(4) { animation-delay: 220ms; }
    .stat-formula-label {
        display: flex; align-items: center; gap: 8px;
        font-weight: 600; font-size: 0.88rem; color: #111827;
    }
    .stat-formula-dot {
        width: 10px; height: 10px; border-radius: 50%;
        box-shadow: 0 0 0 2px rgba(255,255,255,0.8);
    }
    .stat-formula-dot.d-audit  { background: #2563eb; }
    .stat-formula-dot.d-csolo  { background: #d97706; }
    .stat-formula-dot.d-cs     { background: #ec4899; }
    .stat-formula-dot.d-effort { background: #0891b2; }
    .stat-formula-op { font-size: 0.78rem; color: #6b7280; font-weight: 700; margin-left: 4px; }
    .stat-formula-op.op-plus { color: #16a34a; }
    .stat-formula-op.op-excl { color: #9ca3af; font-style: italic; }
    .stat-formula-value {
        font-weight: 800; color: #111827; font-variant-numeric: tabular-nums;
        font-size: 0.95rem; white-space: nowrap;
    }
    .stat-formula-note { font-size: 0.72rem; color: #9ca3af; margin-left: 8px; font-weight: 500; }
    .stat-formula-row.fr-cs .stat-formula-value { color: #9ca3af; text-decoration: line-through; }

    .stat-formula-divider {
        height: 2px;
        background: linear-gradient(90deg, transparent 0%, #e5e7eb 20%, #e5e7eb 80%, transparent 100%);
        margin: 6px 4px 2px;
        animation: statFormulaDividerIn 360ms cubic-bezier(.2,.9,.25,1.0) 240ms both;
    }
    .stat-formula-sum {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 14px; margin: 0 0 10px;
        border-radius: 11px;
        background: linear-gradient(135deg, rgba(99,102,241,0.12) 0%, rgba(168,85,247,0.14) 100%);
        border: 1.5px solid rgba(99,102,241,0.3);
        animation: statFormulaSumIn 420ms cubic-bezier(.2,.9,.25,1.0) 320ms both;
    }
    .stat-formula-sum-label { font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: #4338ca; }
    .stat-formula-sum-value {
        font-size: 1.3rem; font-weight: 900; color: #312e81;
        font-variant-numeric: tabular-nums;
        text-shadow: 0 1px 0 rgba(255,255,255,0.6);
    }
    @@keyframes statFormulaRowIn {
        from { opacity: 0; transform: translateX(-14px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    @@keyframes statFormulaDividerIn {
        from { opacity: 0; transform: scaleX(0.3); }
        to   { opacity: 1; transform: scaleX(1); }
    }
    @@keyframes statFormulaSumIn {
        from { opacity: 0; transform: translateY(10px) scale(0.94); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .stat-tooltip-title { font-size: 0.95rem; font-weight: 700; letter-spacing: 0.01em; }
    .stat-tooltip-subtitle { font-size: 0.78rem; opacity: 0.92; margin-top: 2px; }

    .stat-tooltip-body {
        overflow-y: auto; overflow-x: hidden; flex: 1 1 auto; min-height: 0;
        padding: 0; background: #ffffff;
        scrollbar-width: thin; scrollbar-color: #c7d2fe transparent;
        overscroll-behavior: contain;
    }
    .stat-tooltip-body::-webkit-scrollbar { width: 10px; }
    .stat-tooltip-body::-webkit-scrollbar-thumb {
        background: #c7d2fe; border-radius: 5px; border: 2px solid #ffffff;
    }
    .stat-tooltip-body::-webkit-scrollbar-thumb:hover { background: #a5b4fc; }
    .stat-tooltip-body::-webkit-scrollbar-track { background: transparent; }
    .stat-tooltip-loading,
    .stat-tooltip-error,
    .stat-tt-empty { padding: 22px 18px; text-align: center; color: #6b7280; font-size: 0.88rem; }
    .stat-tooltip-error { color: #dc2626; }

    .stat-tooltip-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
    .stat-tooltip-table thead th {
        position: sticky; top: 0; z-index: 1;
        background: #f9fafb;
        font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase;
        color: #6b7280; font-weight: 700;
        padding: 9px 10px; border-bottom: 1px solid #e5e7eb; text-align: left;
    }
    .stat-tooltip-table tbody td {
        padding: 9px 10px; border-bottom: 1px solid #f3f4f6; vertical-align: middle;
    }
    .stat-tooltip-table tbody tr {
        animation: statTtRowIn 280ms cubic-bezier(.2,.9,.25,1.0) both;
    }
    .stat-tooltip-table tbody tr:nth-child(1)  { animation-delay: 20ms; }
    .stat-tooltip-table tbody tr:nth-child(2)  { animation-delay: 40ms; }
    .stat-tooltip-table tbody tr:nth-child(3)  { animation-delay: 60ms; }
    .stat-tooltip-table tbody tr:nth-child(4)  { animation-delay: 80ms; }
    .stat-tooltip-table tbody tr:nth-child(5)  { animation-delay: 100ms; }
    .stat-tooltip-table tbody tr:nth-child(6)  { animation-delay: 120ms; }
    .stat-tooltip-table tbody tr:nth-child(7)  { animation-delay: 140ms; }
    .stat-tooltip-table tbody tr:nth-child(8)  { animation-delay: 160ms; }
    .stat-tooltip-table tbody tr:nth-child(n+9) { animation-delay: 180ms; }
    .stat-tooltip-table tbody tr:hover { background: #f9fafb; }
    .stat-tt-idx  { width: 36px; color: #9ca3af; font-variant-numeric: tabular-nums; text-align: right; }
    .stat-tt-pc   { font-weight: 600; color: #111827; }
    .stat-tt-date { width: 92px; color: #6b7280; font-variant-numeric: tabular-nums; white-space: nowrap; }
    .stat-tt-dur  {
        width: 108px; text-align: right; font-weight: 700; color: #111827;
        font-variant-numeric: tabular-nums; white-space: nowrap;
    }
    @@keyframes statTtRowIn {
        from { opacity: 0; transform: translateY(6px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .stat-tooltip-footer {
        display: flex; justify-content: space-between; align-items: center;
        padding: 11px 18px;
        border-top: 1px solid #e5e7eb;
        background: #f9fafb;
        border-radius: 0 0 14px 14px;
        flex-shrink: 0;
    }
    .stat-tooltip-table tbody tr.stat-tt-clickable { cursor: pointer; }
    .stat-tooltip-table tbody tr.stat-tt-clickable:hover { background: #eef2ff; }
    .stat-tooltip-table tbody tr.stat-tt-clickable:active { background: #e0e7ff; }
    .stat-tt-count { font-size: 0.8rem; color: #6b7280; }
    .stat-tt-sum   { font-size: 1rem; font-weight: 800; color: #111827; font-variant-numeric: tabular-nums; }

    @@media (max-width: 540px) {
        .stat-tooltip { width: min(520px, calc(100vw - 16px)); }
        .stat-tooltip-header { padding: 12px 14px 10px; }
        .stat-tooltip-footer { padding: 10px 14px; }
        .stat-tt-date { width: 76px; font-size: 0.78rem; }
    }

    .stat-card-gradient-purple { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }

    .stat-card-gradient-dark   { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); }
    .stat-metric-box {
        border-radius: 12px; padding: 12px 8px; text-align: center;
        transition: transform 0.15s; position: relative; color: #212529;
    }
    .stat-metric-box:hover { transform: translateY(-2px); }
    .stat-metric-box .value     { font-size: 1.45rem; font-weight: 700; line-height: 1.15; }
    .stat-metric-box .main-lbl  { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; margin-top: 2px; color: #374151; }
    .stat-metric-box .sub-lbl   { font-size: 0.67rem; color: #6b7280; margin-top: 1px; }
    .leaderboard-row { transition: background 0.1s; }
    .leaderboard-row:hover { background: rgba(99,102,241,0.05) !important; }
    .sort-th { transition: background 0.1s; }
    .sort-th:hover { background: rgba(99,102,241,0.08); }
    .sort-th span { font-size: 0.65rem; margin-left: 4px; display: inline-block; }
    .name-pill {
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 20px; padding: 3px 9px; font-size: 0.78rem; font-weight: 700;
        color: #fff; white-space: nowrap; flex-shrink: 0;
    }
    .progress-thin { height: 3px; border-radius: 2px; background: #e9ecef; }
    .progress-thin .bar { height: 3px; border-radius: 2px; }
    .badge-time  { background: #e8f0fe; color: #1a73e8; font-size: 0.82rem; font-weight: 600; }
    .badge-green { background: #e6f4ea; color: #1e8e3e; font-size: 0.82rem; font-weight: 600; }
    .badge-orange { background: #fff3e0; color: #e65100; font-size: 0.82rem; font-weight: 600; }
    .badge-cs     { background: #fce7f3; color: #9d174d; font-size: 0.82rem; font-weight: 600; border: 1px solid #f9a8d4; }
    .day-tab-btn { border-radius: 20px !important; font-size: 0.82rem; padding: 5px 12px; }
    /* ── Avatar hover popup ── */
    .name-pill { transition: transform 0.18s ease, filter 0.18s ease; }
    .avatar-wrap { position: relative; display: inline-flex; cursor: default; }
    .avatar-wrap:hover .name-pill {
        transform: scale(1.12);
        filter: brightness(1.12) drop-shadow(0 4px 10px rgba(0,0,0,0.28));
    }
    .avatar-hover-card {
        position: absolute;
        top: calc(100% + 10px);
        left: 50%;
        transform: translateX(-50%) scale(0.82) translateY(-8px);
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.18s ease, transform 0.22s cubic-bezier(0.34,1.56,0.64,1);
        z-index: 9999;
        background: #fff;
        border-radius: 16px;
        padding: 14px 16px 12px;
        box-shadow: 0 16px 48px rgba(0,0,0,0.18), 0 2px 8px rgba(0,0,0,0.08);
        text-align: center;
        min-width: 108px;
    }
    .avatar-wrap:hover .avatar-hover-card {
        opacity: 1;
        transform: translateX(-50%) scale(1) translateY(0);
    }
    .avatar-big-circle {
        width: 54px; height: 54px; border-radius: 50%;
        background: var(--av-color);
        color: #fff; font-size: 1.5rem; font-weight: 800; letter-spacing: -1px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 8px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.22);
        animation: avatar-pop 0.22s cubic-bezier(0.34,1.56,0.64,1) both;
    }
    @@keyframes avatar-pop {
        from { transform: scale(0.6); opacity: 0; }
        to   { transform: scale(1);   opacity: 1; }
    }
    .av-name { font-size: 0.78rem; font-weight: 700; color: #111827; white-space: nowrap; }
    .av-sub  { font-size: 0.7rem;  color: #6b7280; margin-top: 3px; white-space: nowrap; }
    .panel-period-label {
        font-size: 0.7rem; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase;
        color: #6b7280; display: flex; align-items: center; gap: 4px; margin-bottom: 8px;
    }
    @@media (max-width: 768px) {
        .px-3 { padding-left: 10px !important; padding-right: 10px !important; }
        .day-tab-btn { font-size: .75rem; padding: 3px 8px; }
    }
    @@media (max-width: 480px) {
        .day-tab-btn { font-size: .72rem; padding: 2px 6px; min-height: 36px; touch-action: manipulation; }
        .stat-card-gradient-purple, .stat-card-gradient-green, .stat-card-gradient-blue { padding: 10px 12px !important; }
        .av-avatar { width: 28px !important; height: 28px !important; font-size: .7rem !important; }
        .av-name { font-size: .73rem; }
        .av-sub  { font-size: .65rem; }
    }
    @@media print {
        .no-print { display: none !important; }
        .card { box-shadow: none !important; border: 1px solid #dee2e6 !important; }
    }
</style>

<div class="px-3 pb-5">

    @* ── Org filter pills ── *@
    <div class="d-flex align-items-center flex-wrap gap-2 pt-2 pb-1 no-print">
        <span class="fw-semibold me-1" style="font-size:0.85rem;color:#6b7280;">
            <i class="ri-filter-3-line me-1"></i>Org:
        </span>
        <div class="btn-group" role="group" aria-label="Organization filter">
            <button type="button"
                    class="btn btn-sm rounded-pill me-1 @(_selOrg == 0 ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SelectOrg(0)">All</button>
            <button type="button"
                    class="btn btn-sm rounded-pill me-1 @(_selOrg == 1 ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SelectOrg(1)">Haifa</button>
            <button type="button"
                    class="btn btn-sm rounded-pill @(_selOrg == 2 ? "btn-primary" : "btn-outline-primary")"
                    @onclick="() => SelectOrg(2)">Riga</button>
        </div>
    </div>

    @* ── Week nav ── *@
    <div class="d-flex align-items-center flex-wrap gap-2 py-2 border-bottom mb-3 no-print">
        <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick="PrevWeek">
            <i class="ri-arrow-left-s-line"></i> @LS.T("common.prev")
        </button>
        <span class="fw-semibold" style="font-size:0.95rem;">
            @LS.T("stats.week"): @DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
        </span>
        <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick="NextWeek"
                disabled="@(_weekStart >= DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today)))">
            @LS.T("common.next") <i class="ri-arrow-right-s-line"></i>
        </button>
        <button class="btn btn-sm btn-outline-secondary ms-auto rounded-pill" @onclick="PrintStats">
            <i class="ri-printer-line me-1"></i>@LS.T("common.printPDF")
        </button>
    </div>

    @* ── Day selector tabs ── *@
    <div class="d-flex flex-wrap gap-2 mb-4 no-print">
        @for (int i = 0; i < 7; i++)
        {
            var idx      = i;
            var day      = _weekStart.AddDays(idx);
            var isFuture = day > DateOnly.FromDateTime(DateTime.Today);
            var isSel    = idx == _selDay;
            var dStat    = _dayStats[idx];
            var hasData  = dStat.Staff.Count > 0 || dStat.AcademyCount > 0;

            <button class="btn btn-sm day-tab-btn @(isSel ? "btn-primary shadow-sm" : (hasData ? "btn-outline-primary" : "btn-outline-secondary")) @(isFuture ? "opacity-40" : "")"
                    @onclick="() => SelectDay(idx)"
                    disabled="@isFuture">
                @day.ToString("ddd dd/MM", CultureInfo.InvariantCulture)
                @if (hasData)
                {
                    <span class="badge rounded-pill ms-1"
                          style="background:@(isSel?"#fff":"#6366f1");color:@(isSel?"#6366f1":"#fff");font-size:0.7rem;">
                        @(dStat.Staff.Count > 0 ? Fmt(dStat.Staff.Sum(s => s.TotalSec)) : dStat.AcademyCount.ToString())
                    </span>
                }
            </button>
        }
    </div>

    @* ── Two-column layout ── *@
    <div class="row g-3">

        @* ── LEFT: Week Leaderboard + Month Leaderboard + Hours by Org ── *@
        <div class="col-xl-7 col-lg-7 d-flex flex-column gap-3">

            @* ── Week Leaderboard (full table style) ── *@
            @{ var weekStaffList = GetWeekStaff(); }
            <div class="card border-0 shadow-sm" style="border-radius:14px;">
                <div class="card-header border-0 py-3 stat-card-gradient-purple" style="border-radius:14px 14px 0 0;cursor:pointer;"
                     @onclick="() => _weekLeaderExpanded = !_weekLeaderExpanded">
                    <div class="d-flex align-items-start justify-content-between text-white">
                        <div>
                            <h6 class="mb-0 fw-bold fs-14">
                                <i class="@(_weekLeaderExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line") me-1" style="font-size:1.1rem;"></i>
                                <i class="ri-trophy-fill me-1"></i>@LS.T("stats.weekLeaderboard")
                            </h6>
                            <div class="opacity-75 mt-1" style="font-size:0.8rem;">
                                @DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="fw-bold fs-4 text-white lh-1">@Fmt(weekStaffList.Sum(s => s.TotalSec))</div>
                            <div class="opacity-75 mt-1" style="font-size:0.75rem;">@LS.T("stats.weekTotal")</div>
                        </div>
                    </div>
                </div>

                @if (_weekLeaderExpanded)
                {
                <div class="card-body p-0">
                    @{
                        // Compute weekMax from the WHOLE list (not [0]) so the progress bar always
                        // scales against the true max regardless of current sort column.
                        var weekMax = weekStaffList.Count > 0 ? weekStaffList.Max(s => s.TotalSec) : 1;
                        var wkSorted = SortStaff(weekStaffList, _wkSort, _wkSortDesc);
                        int wRank  = 1;
                    }
                    @if (weekStaffList.Count == 0)
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="ri-calendar-event-line d-block mb-2 opacity-40" style="font-size:2.5rem;"></i>
                            <div class="fw-semibold">@LS.T("stats.noDataWeek")</div>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table mb-0" style="font-size:0.9rem;">
                                <thead style="background:#f8f9fa;">
                                    <tr class="text-muted" style="font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">
                                        <th class="ps-3 fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("name")'>
                                            @LS.T("stats.staffMember") <span style="@SortArrowStyle(_wkSort,"name")">@SortArrow(_wkSort,_wkSortDesc,"name")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("audit")'>
                                            @LS.T("stats.auditing") <span style="@SortArrowStyle(_wkSort,"audit")">@SortArrow(_wkSort,_wkSortDesc,"audit")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("csolo")'>
                                            @LS.T("stats.csSolo") <span style="@SortArrowStyle(_wkSort,"csolo")">@SortArrow(_wkSort,_wkSortDesc,"csolo")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("cs")'>
                                            CS <span style="@SortArrowStyle(_wkSort,"cs")">@SortArrow(_wkSort,_wkSortDesc,"cs")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("effort")'>
                                            Extra Effort <span style="@SortArrowStyle(_wkSort,"effort")">@SortArrow(_wkSort,_wkSortDesc,"effort")</span>
                                        </th>
                                        <th class="text-center fw-semibold pe-3 sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnWkSort("total")'>
                                            @LS.T("stats.total") <span style="@SortArrowStyle(_wkSort,"total")">@SortArrow(_wkSort,_wkSortDesc,"total")</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in wkSorted)
                                    {
                                        var pct       = weekMax > 0 ? (int)(s.TotalSec * 100.0 / weekMax) : 0;
                                        var avColor   = ColorForStaff(s.PersonId);
                                        var firstName = s.Name.Split(' ')[0];
                                        <tr class="leaderboard-row border-bottom">
                                            <td class="ps-3 align-middle">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="avatar-wrap" style="--av-color:@avColor;">
                                                        <span class="name-pill" style="background:@avColor;">
                                                            @if (wRank == 1) { <i class="ri-medal-fill me-1" style="font-size:11px;"></i> }
                                                            @firstName
                                                        </span>
                                                        <div class="avatar-hover-card">
                                                            <div class="avatar-big-circle">@(firstName.Length > 0 ? firstName[0].ToString().ToUpper() : "?")</div>
                                                            <div class="av-name">@s.Name</div>
                                                            <div class="av-sub">#@wRank · @Fmt(s.TotalSec)</div>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold">@s.Name</div>
                                                        <div class="progress-thin mt-1" style="width:90px;">
                                                            <div class="bar" style="width:@pct%;background:@avColor;"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="audit" data-stat-staff-id="@s.PersonId" data-stat-staff-name="@s.Name" data-stat-start="@_weekStart.ToString("yyyy-MM-dd")" data-stat-end="@_weekStart.AddDays(6).ToString("yyyy-MM-dd")">
                                                @if (s.AuditSec > 0)
                                                { <span class="badge rounded-pill badge-time">@Fmt(s.AuditSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="csolo" data-stat-staff-id="@s.PersonId" data-stat-staff-name="@s.Name" data-stat-start="@_weekStart.ToString("yyyy-MM-dd")" data-stat-end="@_weekStart.AddDays(6).ToString("yyyy-MM-dd")">
                                                @if (s.SoloCsSec > 0)
                                                { <span class="badge rounded-pill badge-orange">@Fmt(s.SoloCsSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="cs" data-stat-staff-id="@s.PersonId" data-stat-staff-name="@s.Name" data-stat-start="@_weekStart.ToString("yyyy-MM-dd")" data-stat-end="@_weekStart.AddDays(6).ToString("yyyy-MM-dd")">
                                                @if (s.CsSec > 0)
                                                { <span class="badge rounded-pill badge-cs">@Fmt(s.CsSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="effort" data-stat-staff-id="@s.PersonId" data-stat-staff-name="@s.Name" data-stat-start="@_weekStart.ToString("yyyy-MM-dd")" data-stat-end="@_weekStart.AddDays(6).ToString("yyyy-MM-dd")">
                                                @if (s.EffortSec > 0)
                                                { <span class="badge rounded-pill" style="background:#cffafe;color:#0e7490;border:1px solid #06b6d4;">@Fmt(s.EffortSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle pe-3 stat-cell" data-stat-metric="total" data-stat-staff-name="@s.Name" data-stat-audit="@s.AuditSec" data-stat-csolo="@s.SoloCsSec" data-stat-cs="@s.CsSec" data-stat-effort="@s.EffortSec" data-stat-total="@s.TotalSec">
                                                <span class="fw-bold">@Fmt(s.TotalSec)</span>
                                            </td>
                                        </tr>
                                        wRank++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                }
            </div>

            @* ── Month Leaderboard ── *@
            @if (_monthStaff.Count > 0)
            {
                <div class="card border-0 shadow-sm" style="border-radius:14px;">
                    <div class="card-header border-0 py-3" style="border-radius:14px 14px 0 0;background:linear-gradient(135deg,#4338ca 0%,#6366f1 100%);cursor:pointer;"
                         @onclick="() => _monthLeaderExpanded = !_monthLeaderExpanded">
                        <div class="d-flex align-items-start justify-content-between text-white">
                            <div>
                                <h6 class="mb-0 fw-bold" style="font-size:0.95rem;">
                                    <i class="@(_monthLeaderExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line") me-1" style="font-size:1.1rem;"></i>
                                    <i class="ri-bar-chart-box-line me-1"></i><strong>@_monthLabel</strong> Leaderboard
                                </h6>
                                <div class="opacity-75 mt-1" style="font-size:0.78rem;">
                                    @DayLabel(_monthStart) – @DayLabel(_monthEnd) · @_monthWeekCount weeks
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold fs-4 text-white lh-1">@Fmt(_monthStaff.Sum(s => s.TotalSec))</div>
                                <div class="opacity-75 mt-1" style="font-size:0.75rem;">Month Total</div>
                            </div>
                        </div>
                    </div>
                    @if (_monthLeaderExpanded)
                    {
                    <div class="card-body p-0">
                        @{
                            // Compute mMax from the WHOLE list — bar should reflect true max regardless of sort
                            int mMax    = _monthStaff.Max(s => s.TotalSec);
                            var moSorted = SortStaff(_monthStaff, _moSort, _moSortDesc);
                            int mRank   = 1;
                        }
                        <div class="table-responsive">
                            <table class="table mb-0" style="font-size:0.9rem;">
                                <thead style="background:#f5f3ff;">
                                    <tr style="font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;color:#6b7280;">
                                        <th class="ps-3 fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("name")'>
                                            @LS.T("stats.staffMember") <span style="@SortArrowStyle(_moSort,"name")">@SortArrow(_moSort,_moSortDesc,"name")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("audit")'>
                                            @LS.T("stats.auditing") <span style="@SortArrowStyle(_moSort,"audit")">@SortArrow(_moSort,_moSortDesc,"audit")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("csolo")'>
                                            @LS.T("stats.csSolo") <span style="@SortArrowStyle(_moSort,"csolo")">@SortArrow(_moSort,_moSortDesc,"csolo")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("cs")'>
                                            CS <span style="@SortArrowStyle(_moSort,"cs")">@SortArrow(_moSort,_moSortDesc,"cs")</span>
                                        </th>
                                        <th class="text-center fw-semibold sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("effort")'>
                                            Extra Effort <span style="@SortArrowStyle(_moSort,"effort")">@SortArrow(_moSort,_moSortDesc,"effort")</span>
                                        </th>
                                        <th class="text-center fw-semibold pe-3 sort-th" style="cursor:pointer;user-select:none;" @onclick='() => OnMoSort("total")'>
                                            @LS.T("stats.total") <span style="@SortArrowStyle(_moSort,"total")">@SortArrow(_moSort,_moSortDesc,"total")</span>
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ms in moSorted)
                                    {
                                        var mPct      = mMax > 0 ? (int)(ms.TotalSec * 100.0 / mMax) : 0;
                                        var mColor    = ColorForStaff(ms.PersonId);
                                        var firstName = ms.Name.Split(' ')[0];
                                        <tr class="leaderboard-row border-bottom">
                                            <td class="ps-3 align-middle">
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="avatar-wrap" style="--av-color:@mColor;">
                                                        <span class="name-pill" style="background:@mColor;">
                                                            @if (mRank == 1) { <i class="ri-medal-fill me-1" style="font-size:11px;"></i> }
                                                            @firstName
                                                        </span>
                                                        <div class="avatar-hover-card">
                                                            <div class="avatar-big-circle">@(firstName.Length > 0 ? firstName[0].ToString().ToUpper() : "?")</div>
                                                            <div class="av-name">@ms.Name</div>
                                                            <div class="av-sub">#@mRank · @Fmt(ms.TotalSec)</div>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <div class="fw-semibold">@ms.Name</div>
                                                        <div class="progress-thin mt-1" style="width:90px;">
                                                            <div class="bar" style="width:@mPct%;background:@mColor;"></div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="audit" data-stat-staff-id="@ms.PersonId" data-stat-staff-name="@ms.Name" data-stat-start="@_monthStart.ToString("yyyy-MM-dd")" data-stat-end="@_monthEnd.ToString("yyyy-MM-dd")">
                                                @if (ms.AuditSec > 0)
                                                { <span class="badge rounded-pill badge-time">@Fmt(ms.AuditSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="csolo" data-stat-staff-id="@ms.PersonId" data-stat-staff-name="@ms.Name" data-stat-start="@_monthStart.ToString("yyyy-MM-dd")" data-stat-end="@_monthEnd.ToString("yyyy-MM-dd")">
                                                @if (ms.SoloCsSec > 0)
                                                { <span class="badge rounded-pill badge-orange">@Fmt(ms.SoloCsSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="cs" data-stat-staff-id="@ms.PersonId" data-stat-staff-name="@ms.Name" data-stat-start="@_monthStart.ToString("yyyy-MM-dd")" data-stat-end="@_monthEnd.ToString("yyyy-MM-dd")">
                                                @if (ms.CsSec > 0)
                                                { <span class="badge rounded-pill badge-cs">@Fmt(ms.CsSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle stat-cell" data-stat-metric="effort" data-stat-staff-id="@ms.PersonId" data-stat-staff-name="@ms.Name" data-stat-start="@_monthStart.ToString("yyyy-MM-dd")" data-stat-end="@_monthEnd.ToString("yyyy-MM-dd")">
                                                @if (ms.EffortSec > 0)
                                                { <span class="badge rounded-pill" style="background:#cffafe;color:#0e7490;border:1px solid #06b6d4;">@Fmt(ms.EffortSec)</span> }
                                                else { <span class="text-muted small">–</span> }
                                            </td>
                                            <td class="text-center align-middle pe-3 stat-cell" data-stat-metric="total" data-stat-staff-name="@ms.Name" data-stat-audit="@ms.AuditSec" data-stat-csolo="@ms.SoloCsSec" data-stat-cs="@ms.CsSec" data-stat-effort="@ms.EffortSec" data-stat-total="@ms.TotalSec">
                                                <span class="fw-bold" style="color:#4338ca;">@Fmt(ms.TotalSec)</span>
                                            </td>
                                        </tr>
                                        mRank++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    }
                </div>
            }

            @* ── Hours by Organization card ── *@
            <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">
                <div class="card-header border-0 py-2 px-3 bg-white border-bottom">
                    <div class="panel-period-label">
                        <i class="ri-map-pin-2-line text-primary"></i>
                        @LS.T("stats.pcOriginLabel")
                    </div>
                </div>
                <div class="card-body px-3 py-3">
                    @if (_originHours.Count == 0)
                    {
                        <div class="text-muted small text-center py-2">@LS.T("stats.noSessionDataWeek")</div>
                    }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var oh in _originHours)
                            {
                                var (ohBg, ohColor) = OriginStyle(oh.Origin);
                                <div class="col">
                                    <div class="stat-metric-box" style="background:@ohBg;">
                                        <div class="value" style="color:@ohColor;">@Fmt(oh.Seconds)</div>
                                        <div class="main-lbl">@oh.Origin</div>
                                        <div class="sub-lbl">@LS.T("stats.auditingHours")</div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

        </div>

        @* ── RIGHT: Day snapshot + Week totals + Month totals ── *@
        <div class="col-xl-5 col-lg-5 d-flex flex-column gap-3">

            @* ─ Day snapshot ─ *@
            <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">
                <div class="card-header border-0 py-2 px-3 bg-white border-bottom">
                    <div class="panel-period-label">
                        <i class="ri-sun-line text-warning"></i>
                        @LS.T("stats.daySnapshot") — @_dayStats[_selDay].Date.ToString("dddd dd/MM/yyyy", CultureInfo.InvariantCulture)
                    </div>
                </div>
                <div class="card-body px-3 py-3">
                    <div class="row g-2">
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#f0f4ff;">
                                <div class="value" style="color:#6366f1;">@Fmt(_dayStats[_selDay].Staff.Sum(s => s.AuditSec + s.SoloCsSec))</div>
                                <div class="main-lbl">@LS.T("stats.auditingTime")</div>
                                <div class="sub-lbl">@LS.T("stats.hrsWorked")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#eff6ff;">
                                <div class="value" style="color:#2563eb;">@_dayStats[_selDay].PcCount</div>
                                <div class="main-lbl">@LS.T("stats.pcs")</div>
                                <div class="sub-lbl">@LS.T("stats.clientsSeen")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#f0fdf4;">
                                <div class="value" style="color:#16a34a;">@_dayStats[_selDay].AcademyCount</div>
                                <div class="main-lbl">@LS.T("stats.students")</div>
                                <div class="sub-lbl">@LS.T("stats.academyVisits")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#fff7ed;">
                                <div class="value" style="color:#ea580c;">@_dayStats[_selDay].BodyInShop</div>
                                <div class="main-lbl">Attendance</div>
                                <div class="sub-lbl">@LS.T("stats.uniqueVisitors")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#ecfeff;">
                                <div class="value" style="color:#0891b2;">@Fmt(_dayStats[_selDay].EffortSec)</div>
                                <div class="main-lbl">Effort</div>
                                <div class="sub-lbl">Extra time</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ─ Week totals ─ *@
            <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">
                <div class="card-header border-0 py-2 px-3 bg-white border-bottom">
                    <div class="panel-period-label">
                        <i class="ri-calendar-2-line text-primary"></i>
                        @LS.T("stats.weekTotals") — @DayLabel(_weekStart) @LS.T("stats.to") @DayLabel(_weekStart.AddDays(6))
                    </div>
                </div>
                <div class="card-body px-3 py-3">
                    @{ var ws = CurrentWeekSummary; }
                    <div class="row g-2 mb-3">
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#f0f4ff;">
                                <div class="value" style="color:#6366f1;">@Fmt(ws?.TotalAuditCsSec ?? 0)</div>
                                <div class="main-lbl">@LS.T("stats.auditingTime")</div>
                                <div class="sub-lbl">@LS.T("stats.allStaffSold")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#eff6ff;">
                                <div class="value" style="color:#2563eb;">@(ws?.PcCount ?? 0)</div>
                                <div class="main-lbl">@LS.T("stats.pcs")</div>
                                <div class="sub-lbl">@LS.T("stats.uniqueWeek")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#f0fdf4;">
                                <div class="value" style="color:#16a34a;">@(ws?.AcademyCount ?? 0)</div>
                                <div class="main-lbl">@LS.T("stats.students")</div>
                                <div class="sub-lbl">@LS.T("stats.uniqueWeek")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#fff7ed;">
                                <div class="value" style="color:#ea580c;">@(ws?.BodyInShop ?? 0)</div>
                                <div class="main-lbl">Attendance</div>
                                <div class="sub-lbl">@LS.T("stats.uniqueWeek")</div>
                            </div>
                        </div>
                        <div class="col-6 col-md">
                            <div class="stat-metric-box" style="background:#ecfeff;">
                                <div class="value" style="color:#0891b2;">@Fmt(ws?.EffortSec ?? 0)</div>
                                <div class="main-lbl">Effort</div>
                                <div class="sub-lbl">Extra time</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* ─ Month totals ─ *@
            @if (_monthSummary != null)
            {
                <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden;">
                    <div class="card-header border-0 py-3" style="border-radius:14px 14px 0 0;background:linear-gradient(135deg,#4338ca 0%,#6366f1 100%);">
                        <div class="d-flex align-items-start justify-content-between text-white">
                            <div>
                                <h6 class="mb-0 fw-bold" style="font-size:0.95rem;">
                                    <i class="ri-calendar-line me-2"></i>@_monthLabel
                                </h6>
                                <div class="opacity-75 mt-1" style="font-size:0.78rem;">
                                    @DayLabel(_monthStart) – @DayLabel(_monthEnd) · @_monthWeekCount weeks
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="fw-bold fs-4 text-white lh-1">@Fmt(_monthSummary.TotalAuditCsSec)</div>
                                <div class="opacity-75 mt-1" style="font-size:0.75rem;">Month Total</div>
                            </div>
                        </div>
                    </div>
                    <div class="card-body px-3 py-3">
                        <div class="row g-2">
                            <div class="col-6 col-md">
                                <div class="stat-metric-box" style="background:#eef2ff;">
                                    <div class="value" style="color:#4338ca;">@Fmt(_monthSummary.TotalAuditCsSec)</div>
                                    <div class="main-lbl">@LS.T("stats.auditingTime")</div>
                                    <div class="sub-lbl">All staff</div>
                                </div>
                            </div>
                            <div class="col-6 col-md">
                                <div class="stat-metric-box" style="background:#eff6ff;">
                                    <div class="value" style="color:#2563eb;">@_monthSummary.PcCount</div>
                                    <div class="main-lbl">@LS.T("stats.pcs")</div>
                                    <div class="sub-lbl">Unique month</div>
                                </div>
                            </div>
                            <div class="col-6 col-md">
                                <div class="stat-metric-box" style="background:#f0fdf4;">
                                    <div class="value" style="color:#16a34a;">@_monthSummary.AcademyCount</div>
                                    <div class="main-lbl">@LS.T("stats.students")</div>
                                    <div class="sub-lbl">Unique month</div>
                                </div>
                            </div>
                            <div class="col-6 col-md">
                                <div class="stat-metric-box" style="background:#fff7ed;">
                                    <div class="value" style="color:#ea580c;">@_monthSummary.BodyInShop</div>
                                    <div class="main-lbl">Attendance</div>
                                    <div class="sub-lbl">Unique month</div>
                                </div>
                            </div>
                            <div class="col-6 col-md">
                                <div class="stat-metric-box" style="background:#ecfeff;">
                                    <div class="value" style="color:#0891b2;">@Fmt(_monthSummary.EffortSec)</div>
                                    <div class="main-lbl">Effort</div>
                                    <div class="sub-lbl">Extra time</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

        </div>
    </div>

    @* ── Weekly History Chart (collapsible) ── *@
    <div class="card border-0 shadow-sm mt-4" style="border-radius:14px;overflow:hidden;">
        <div class="card-header border-0 py-3 px-3 stat-card-gradient-dark" style="cursor:pointer;"
             @onclick="() => _weekHistoryExpanded = !_weekHistoryExpanded">
            <div style="color:#fff;">
                <h6 class="mb-0 fw-bold" style="color:#fff;font-size:0.95rem;">
                    <i class="@(_weekHistoryExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line") me-1" style="font-size:1.1rem;"></i>
                    <i class="ri-bar-chart-grouped-fill me-1"></i>@LS.T("stats.weeklyHistory")
                </h6>
                <div class="mt-1" style="font-size:0.8rem;color:rgba(255,255,255,0.7);">
                    @LS.T("stats.lastWeeks1") @_weekHistory.Count @LS.T("stats.lastWeeks2")
                </div>
            </div>
        </div>
        @if (_weekHistoryExpanded)
        {
        <div class="card-body py-2 px-2" style="background:linear-gradient(180deg,#16213e 0%,#0f1729 100%);">
            <ApexChart TItem="WeekStatSummary"
                       Options="@_chartOptions"
                       Height="300"
                       @key="_chartKey">
                <ApexPointSeries TItem="WeekStatSummary"
                                 Items="@_chartHistory"
