    protected override void OnInitialized()
    {
        _weekStart = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));

        // Select today's slot within the week
        var today = DateOnly.FromDateTime(DateTime.Today);
        _selDay = 0;
        for (int i = 6; i >= 0; i--)
        {
            if (_weekStart.AddDays(i) <= today) { _selDay = i; break; }
        }

        LoadWeek();
    }

    void LoadWeek()
    {
        _dayStats     = StatSvc.GetWeekDayStats(_weekStart, OrgFilter);
        _weekHistory  = StatSvc.GetWeeklySummaries(_weekStart, 20, OrgFilter);
        _chartHistory = _weekHistory.Where(w => w.TotalAuditCsSec > 0 || w.PcCount > 0 || w.AcademyCount > 0 || w.BodyInShop > 0 || w.EffortSec > 0).ToList();
        _originHours  = StatSvc.GetWeekOriginHours(_weekStart, OrgFilter);
        _chartKey++;
        LoadMonth();
    }

    void LoadMonth()
    {
        var weeks = GetMonthWeeks(_weekStart);
        _monthWeekCount = weeks.Count;
        if (weeks.Count == 0)
        {
            _monthSummary = null;
            _monthStaff = [];
            _monthOriginHours = [];
            return;
        }
        _monthStart = weeks[0];
        _monthEnd   = weeks[^1].AddDays(6);
        _monthLabel = _monthStart.ToString("MMMM yyyy", CultureInfo.InvariantCulture);
        _monthSummary     = StatSvc.GetMonthSummary(_monthStart, _monthEnd, OrgFilter);
        _monthStaff       = StatSvc.GetMonthStaffLeaderboard(_monthStart, _monthEnd, OrgFilter);
        _monthOriginHours = StatSvc.GetMonthOriginHours(_monthStart, _monthEnd, OrgFilter);
        _monthHistory     = StatSvc.GetMonthlySummaries(_weekStart, 12, OrgFilter);
        _chartMonthHistory = _monthHistory.Where(m => m.TotalAuditCsSec > 0 || m.PcCount > 0 || m.AcademyCount > 0 || m.BodyInShop > 0 || m.EffortSec > 0).ToList();
        _monthChartKey++;
    }

    void SelectOrg(int org)
    {
        if (_selOrg == org) return;
        _selOrg = org;
        LoadWeek();
    }

    static List<DateOnly> GetMonthWeeks(DateOnly weekStart)
    {
        var month = weekStart.Month;
        var year  = weekStart.Year;
        var d = new DateOnly(year, month, 1);
        while (d.DayOfWeek != DayOfWeek.Thursday) d = d.AddDays(1);
        var weeks = new List<DateOnly>();
        while (d.Month == month)
        {
            weeks.Add(d);
            d = d.AddDays(7);
        }
        return weeks;
    }

    List<StaffStatRow> GetWeekStaff() =>
        _dayStats
            .SelectMany(d => d.Staff)
            .GroupBy(s => s.PersonId)
            .Select(g => new StaffStatRow(g.Key, g.First().Name, g.Sum(x => x.AuditSec), g.Sum(x => x.SoloCsSec), g.Sum(x => x.EffortSec), g.Sum(x => x.CsSec)))
            .Where(s => s.TotalSec > 0)
            .OrderByDescending(s => s.TotalSec)
            .ToList();

    static (string bg, string color) OriginStyle(string origin) => origin switch
    {
        "Haifa"       => ("#f5f3ff", "#7c3aed"),
        "Riga"        => ("#f0fdfa", "#0d9488"),
        "from Abroad" => ("#fff7ed", "#ea580c"),
        _             => ("#f9fafb", "#6b7280"),
    };

    void SelectDay(int idx) => _selDay = idx;

    void PrevWeek()
    {
        _weekStart = _weekStart.AddDays(-7);
        _selDay    = 0;
        LoadWeek();
    }

    void NextWeek()
    {
        var maxWeek = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));
        if (_weekStart >= maxWeek) return;
        _weekStart = _weekStart.AddDays(7);
        _selDay    = 0;
        LoadWeek();
    }

    async Task PrintStats()
    {
        var weekStaff = GetWeekStaff();
        var pdfBytes = PdfService.GenerateStatisticsPdf(
            _weekStart, weekStaff, _dayStats, _weekHistory, CurrentWeekSummary, _originHours,
            monthStaff: _monthStaff,
            monthSummary: _monthSummary,
            monthOriginHours: _monthOriginHours,
            monthLabel: _monthLabel,
            monthWeekCount: _monthWeekCount,
            monthStart: _monthStart,
            monthEnd: _monthEnd,
            monthHistory: _monthHistory,
            orgLabel: OrgLabel);
        await JS.InvokeVoidAsync("downloadFile", $"Statistics_{OrgLabel}_{_weekStart:yyyy_MM_dd}.pdf", Convert.ToBase64String(pdfBytes));
    }

    static string DayLabel(DateOnly d) =>
        d.ToString("ddd dd/MM", CultureInfo.InvariantCulture);

    static string Fmt(int s) =>
        s <= 0 ? "0:00" : $"{s / 3600}:{(s % 3600) / 60:D2}";

    // ── Per-staff deterministic color (cross-page consistent with MainHeader) ──
    // Deterministic per-staff color: golden-angle hue rotation guarantees a stable, unique
    // hue for every PersonId (no fixed-palette modulo collisions like tami=104 vs carmela=14
    // both landing on slot 14). Same input → same output forever, across pages and sessions.
    static string ColorForStaff(int personId)
    {
        const double GOLDEN_ANGLE = 137.50776405003785;
        var idx = Math.Abs((long)personId);
        var hue = ((idx * GOLDEN_ANGLE) % 360.0 + 360.0) % 360.0;
        return HslToHex(hue, 0.65, 0.50);
    }

    static string HslToHex(double h, double s, double l)
    {
        var c = (1 - Math.Abs(2 * l - 1)) * s;
        var x = c * (1 - Math.Abs(((h / 60.0) % 2) - 1));
        var m = l - c / 2;
        double r, g, b;
        if      (h <  60) { r = c; g = x; b = 0; }
        else if (h < 120) { r = x; g = c; b = 0; }
        else if (h < 180) { r = 0; g = c; b = x; }
        else if (h < 240) { r = 0; g = x; b = c; }
        else if (h < 300) { r = x; g = 0; b = c; }
        else              { r = c; g = 0; b = x; }
        int R = (int)Math.Round((r + m) * 255);
        int G = (int)Math.Round((g + m) * 255);
        int B = (int)Math.Round((b + m) * 255);
        return $"#{R:X2}{G:X2}{B:X2}";
    }

    // ── Sort state per leaderboard table (persisted in localStorage) ──
    string _wkSort = "total"; bool _wkSortDesc = true;
    string _moSort = "total"; bool _moSortDesc = true;
    bool   _sortPrefsLoaded;

    // Known column keys; anything else falls back to "total"
    static readonly HashSet<string> _validSortCols = new(StringComparer.Ordinal) {
        "name", "audit", "csolo", "cs", "effort", "total"
    };

    void ApplySortPref(string? raw, ref string col, ref bool desc)
    {
        col = "total"; desc = true;
        if (string.IsNullOrEmpty(raw)) return;
        var parts = raw.Split(':');
        if (parts.Length != 2) return;
        if (!_validSortCols.Contains(parts[0])) return;
        col  = parts[0];
        desc = parts[1] == "desc";
    }

    string SortPrefString(string col, bool desc) => $"{col}:{(desc ? "desc" : "asc")}";

    async Task SaveWkSortAsync()
    {
        try { await JS.InvokeVoidAsync("localStorage.setItem", "lpm-stats-sort-wk", SortPrefString(_wkSort, _wkSortDesc)); }
        catch { /* private mode / disabled storage */ }
    }
    async Task SaveMoSortAsync()
    {
        try { await JS.InvokeVoidAsync("localStorage.setItem", "lpm-stats-sort-mo", SortPrefString(_moSort, _moSortDesc)); }
        catch { }
    }

    void OnWkSort(string col)
    {
        if (_wkSort == col) _wkSortDesc = !_wkSortDesc;
        else { _wkSort = col; _wkSortDesc = (col != "name"); }   // numeric defaults DESC, name defaults ASC
        _ = SaveWkSortAsync();
    }
    void OnMoSort(string col)
    {
        if (_moSort == col) _moSortDesc = !_moSortDesc;
        else { _moSort = col; _moSortDesc = (col != "name"); }
        _ = SaveMoSortAsync();
    }

    // Sort helper — returns sorted list (does not mutate input)
    List<StaffStatRow> SortStaff(List<StaffStatRow> list, string col, bool desc)
    {
        IOrderedEnumerable<StaffStatRow> q = col switch {
            "name"   => desc ? list.OrderByDescending(s => s.Name, StringComparer.OrdinalIgnoreCase)
                             : list.OrderBy(s => s.Name, StringComparer.OrdinalIgnoreCase),
            "audit"  => desc ? list.OrderByDescending(s => s.AuditSec)  : list.OrderBy(s => s.AuditSec),
            "csolo"  => desc ? list.OrderByDescending(s => s.SoloCsSec) : list.OrderBy(s => s.SoloCsSec),
            "cs"     => desc ? list.OrderByDescending(s => s.CsSec)     : list.OrderBy(s => s.CsSec),
            "effort" => desc ? list.OrderByDescending(s => s.EffortSec) : list.OrderBy(s => s.EffortSec),
            _        => desc ? list.OrderByDescending(s => s.TotalSec)  : list.OrderBy(s => s.TotalSec),
        };
        return q.ToList();
    }

    // Arrow indicator HTML char per column — active gets ▲/▼, inactive gets faded ↕
    string SortArrow(string activeCol, bool activeDesc, string thisCol)
    {
        if (activeCol != thisCol) return "↕";
        return activeDesc ? "▼" : "▲";
    }
    string SortArrowStyle(string activeCol, string thisCol) =>
        activeCol == thisCol ? "opacity:1;" : "opacity:.35;";

    DotNetObjectReference<Statistics>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("lpmStatsTooltip.register", _dotNetRef); }
            catch { /* JS module not yet loaded — ignore, click-to-open won't work */ }
        }

        if (!firstRender || _sortPrefsLoaded) return;
        _sortPrefsLoaded = true;
        try
        {
            var wk = await JS.InvokeAsync<string?>("localStorage.getItem", "lpm-stats-sort-wk");
            var mo = await JS.InvokeAsync<string?>("localStorage.getItem", "lpm-stats-sort-mo");
            ApplySortPref(wk, ref _wkSort, ref _wkSortDesc);
            ApplySortPref(mo, ref _moSort, ref _moSortDesc);
            StateHasChanged();
        }
        catch { /* localStorage unavailable — keep defaults */ }
    }

    [JSInvokable]
    public void OpenSession(int sessionId)
    {
        if (sessionId <= 0) return;
        SmLauncher.RequestOpen(sessionId);
    }

    public void Dispose()
    {
        try { _ = JS.InvokeVoidAsync("lpmStatsTooltip.unregister"); } catch { /* circuit closing */ }
        _dotNetRef?.Dispose();
        _dotNetRef = null;
    }
