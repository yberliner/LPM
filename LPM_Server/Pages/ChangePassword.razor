@page "/ChangePassword"
@layout CustomLayout
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="auth-bg">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-xxl-4 col-xl-5 col-lg-5 col-md-6 col-sm-8 col-12">
                <div class="auth-card">

                    <div class="auth-card-icon-wrap" style="background:linear-gradient(135deg,#1e40af,#6366f1);">
                        <i class="ri-lock-password-line"></i>
                    </div>

                    <h4 class="auth-card-title">Set Your Password</h4>
                    <p class="auth-card-sub">Choose a new password to secure your account.</p>

                    @if (_error is not null)
                    {
                        <div class="auth-alert auth-alert-danger">
                            <i class="ri-error-warning-line"></i> @_error
                        </div>
                    }

                    <div class="auth-field">
                        <label class="auth-label">New Password</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon"><i class="ri-lock-line"></i></span>
                            <input @ref="_pwdInput" type="@(_showPwd ? "text" : "password")"
                                   class="auth-input" placeholder="Enter new password"
                                   @bind="_newPwd" @bind:event="oninput"
                                   @onkeydown="HandleKey" />
                            <button class="auth-eye-btn" type="button" @onclick="() => _showPwd = !_showPwd">
                                <i class="@(_showPwd ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                        </div>
                    </div>

                    <div class="auth-field">
                        <label class="auth-label">Confirm Password</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon"><i class="ri-lock-line"></i></span>
                            <input type="@(_showConfirm ? "text" : "password")"
                                   class="auth-input" placeholder="Repeat new password"
                                   @bind="_confirm" @bind:event="oninput"
                                   @onkeydown="HandleKey" />
                            <button class="auth-eye-btn" type="button" @onclick="() => _showConfirm = !_showConfirm">
                                <i class="@(_showConfirm ? "ri-eye-off-line" : "ri-eye-line")"></i>
                            </button>
                        </div>
                    </div>

                    <button class="auth-submit-btn" @onclick="Submit" disabled="@_loading">
                        @if (_loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="ri-check-line me-2"></i>
                        }
                        Set Password &amp; Continue
                    </button>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    string _newPwd = "", _confirm = "";
    bool _showPwd, _showConfirm, _loading;
    string? _error;
    ElementReference _pwdInput;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (q["error"] == "empty") _error = "Password cannot be empty.";
        if (q["error"] == "mismatch") _error = "Passwords do not match.";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) await JS.InvokeVoidAsync("eval",
            "setTimeout(()=>{var el=document.querySelector('.auth-input');if(el)el.focus();},100)");
    }

    async Task HandleKey(KeyboardEventArgs e) { if (e.Key == "Enter") await Submit(); }

    async Task Submit()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_newPwd)) { _error = "Password cannot be empty."; return; }
        if (_newPwd != _confirm) { _error = "Passwords do not match."; return; }
        _loading = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("lpmPostForm", "/loginpost-changepwd",
            new Dictionary<string, string> { ["newPassword"] = _newPwd });
    }
}

<style>
    .auth-bg {
        min-height: 100vh;
        background: radial-gradient(ellipse at 60% 40%, #1e293b 0%, #0f172a 100%);
        display: flex;
        align-items: center;
    }
    .auth-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 40px 36px 36px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        backdrop-filter: blur(12px);
        text-align: center;
    }
    .auth-card-icon-wrap {
        width: 64px; height: 64px; border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px; font-size: 1.8rem; color: #fff;
        box-shadow: 0 8px 24px rgba(99,102,241,0.4);
    }
    .auth-card-title { color: #f1f5f9; font-size: 1.4rem; font-weight: 700; margin-bottom: 6px; }
    .auth-card-sub { color: #94a3b8; font-size: .9rem; margin-bottom: 28px; }
    .auth-alert { border-radius: 10px; padding: 10px 14px; font-size: .85rem;
                  display: flex; align-items: center; gap: 8px; margin-bottom: 18px; text-align: left; }
    .auth-alert-danger { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
    .auth-field { text-align: left; margin-bottom: 16px; }
    .auth-label { display: block; font-size: .8rem; font-weight: 600; color: #94a3b8;
                  letter-spacing: .05em; text-transform: uppercase; margin-bottom: 6px; }
    .auth-input-wrap { position: relative; display: flex; align-items: center; }
    .auth-input-icon { position: absolute; left: 14px; color: #475569; font-size: 1rem; pointer-events: none; }
    .auth-input {
        width: 100%; padding: 11px 44px 11px 40px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px; color: #f1f5f9; font-size: .95rem; outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .auth-input:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,0.2); }
    .auth-input::placeholder { color: #475569; }
    .auth-eye-btn { position: absolute; right: 12px; background: none; border: none;
                    color: #475569; cursor: pointer; font-size: 1rem; padding: 4px; }
    .auth-eye-btn:hover { color: #94a3b8; }
    .auth-submit-btn {
        width: 100%; margin-top: 8px; padding: 13px;
        background: linear-gradient(135deg, #1e40af, #6366f1);
        border: none; border-radius: 12px; color: #fff;
        font-size: 1rem; font-weight: 600; cursor: pointer;
        transition: opacity .2s, transform .1s;
        box-shadow: 0 4px 16px rgba(99,102,241,0.4);
    }
    .auth-submit-btn:hover:not(:disabled) { opacity: .9; transform: translateY(-1px); }
    .auth-submit-btn:disabled { opacity: .6; cursor: not-allowed; }
</style>
