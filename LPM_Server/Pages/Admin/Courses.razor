@page "/Admin/Courses"
@attribute [Authorize(Roles = "Admin,Customer")]
@inject LPM.Services.CourseService CourseSvc
@using Microsoft.AspNetCore.Authorization
@using LPM.Services

<div class="p-3 p-md-4 cr-courses-page">

    <div class="d-flex align-items-center mb-4 gap-3">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--default-text-color);">
                <i class="ri-book-2-line me-2" style="color:#7986cb;"></i>@LS.T("courses.title")
            </h4>
            <span class="text-muted" style="font-size:0.82rem;">@LS.T("courses.subtitle")</span>
        </div>
    </div>

    @* ── Courses (combined add + list) ── *@
    <div class="card shadow-sm mb-4" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#f0f4ff;color:#212529;border-radius:12px 12px 0 0;border-bottom:1px solid #dce6ff;cursor:pointer;"
             @onclick="() => _showCourses = !_showCourses">
            <span class="fw-semibold small" style="color:#3949ab;">
                <i class="ri-book-2-line me-1"></i>@LS.T("courses.title")
            </span>
            <span class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill" style="background:#e0e7ff;color:#3949ab;font-size:.75rem;">
                    @_courses.Count
                </span>
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showCourses ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showCourses)
        {
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3 small">@LS.T("courses.courseName")</th>
                        <th class="small">Book</th>
                        <th class="small text-end">Book Price</th>
                        <th style="width:130px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in _courses)
                    {
                        <tr>
                            <td class="ps-3 align-middle">
                                @if (_editId == c.CourseId)
                                {
                                    <input class="form-control form-control-sm" style="max-width:220px;"
                                           @bind="_editName" @bind:event="oninput"
                                           @onkeydown="OnEditKeyDown" />
                                }
                                else
                                {
                                    <span class="fw-medium">@c.Name</span>
                                }
                            </td>
                            <td class="align-middle">
                                @if (_editId == c.CourseId)
                                {
                                    <input class="form-control form-control-sm" style="max-width:180px;"
                                           @bind="_editBook" @bind:event="oninput"
                                           @onkeydown="OnEditKeyDown" />
                                }
                                else
                                {
                                    <span class="text-muted">@(string.IsNullOrEmpty(c.Book) ? "—" : c.Book)</span>
                                }
                            </td>
                            <td class="align-middle text-end">
                                @if (_editId == c.CourseId)
                                {
                                    <input type="number" class="form-control form-control-sm" style="max-width:100px;margin-left:auto;"
                                           @bind="_editBookPrice" @bind:event="oninput"
                                           @onkeydown="OnEditKeyDown" />
                                }
                                else
                                {
                                    <span class="text-muted">@(c.BookPrice > 0 ? $"₪{c.BookPrice}" : "—")</span>
                                }
                            </td>
                            <td class="text-end pe-3 align-middle">
                                @if (_editId == c.CourseId)
                                {
                                    <button class="btn btn-sm btn-primary py-0 px-2 me-1" @onclick="SaveEdit">
                                        <i class="ri-save-line"></i>
                                    </button>
                                    <button class="btn btn-sm btn-link text-muted py-0 px-1"
                                            @onclick="() => _editId = null">@LS.T("common.cancel")</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-link text-primary py-0 px-1"
                                            title="Edit" @onclick="() => StartEdit(c)">
                                        <i class="ri-edit-line"></i>
                                    </button>
                                    <button class="btn btn-sm btn-link text-danger py-0 px-1"
                                            title="Delete" @onclick="() => DeleteCourse(c.CourseId)">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:#f8faff;color:#212529;">
                        <td class="ps-3 py-2">
                            <input class="form-control form-control-sm" style="max-width:220px;"
                                   placeholder="@LS.T("courses.newCoursePlaceholder")"
                                   @bind="_newName" @bind:event="oninput"
                                   @onkeydown="OnAddKeyDown" />
                            @if (!string.IsNullOrEmpty(_addError))
                            {
                                <div class="text-danger small mt-1">@_addError</div>
                            }
                        </td>
                        <td class="py-2">
                            <input class="form-control form-control-sm" style="max-width:180px;"
                                   placeholder="Book name"
                                   @bind="_newBook" @bind:event="oninput"
                                   @onkeydown="OnAddKeyDown" />
                        </td>
                        <td class="py-2 text-end">
                            <input type="number" class="form-control form-control-sm" style="max-width:100px;margin-left:auto;"
                                   placeholder="Price"
                                   @bind="_newBookPrice" @bind:event="oninput"
                                   @onkeydown="OnAddKeyDown" />
                        </td>
                        <td class="text-end pe-3 py-2 align-middle">
                            <button class="btn btn-sm btn-primary" @onclick="AddCourse"
                                    disabled="@string.IsNullOrWhiteSpace(_newName)">
                                <i class="ri-add-line me-1"></i>@LS.T("common.add")
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
          </div>
        </div>
        }
    </div>

    @* ── Books ── *@
    <div class="card shadow-sm mb-4" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#e8f5e9;color:#212529;border-radius:12px 12px 0 0;border-bottom:1px solid #c8e6c9;cursor:pointer;"
             @onclick="() => _showBooks = !_showBooks">
            <span class="fw-semibold small" style="color:#2e7d32;">
                <i class="ri-book-open-line me-1"></i>Books
            </span>
            <span class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill" style="background:#c8e6c9;color:#2e7d32;font-size:.75rem;">
                    @_books.Count
                </span>
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showBooks ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showBooks)
        {
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3 small">Book Name</th>
                        <th class="small text-end">Price</th>
                        <th style="width:130px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _books)
                    {
                        <tr>
                            <td class="ps-3 align-middle">
                                @if (_editBkId == b.BookId)
                                {
                                    <input class="form-control form-control-sm" style="max-width:280px;"
                                           @bind="_editBkName" @bind:event="oninput"
                                           @onkeydown="OnEditBkKeyDown" />
                                }
                                else
                                {
                                    <span class="fw-medium">@b.Name</span>
                                }
                            </td>
                            <td class="align-middle text-end">
                                @if (_editBkId == b.BookId)
                                {
                                    <input type="number" class="form-control form-control-sm" style="max-width:100px;margin-left:auto;"
                                           @bind="_editBkPrice" @bind:event="oninput"
                                           @onkeydown="OnEditBkKeyDown" />
                                }
                                else
                                {
                                    <span class="text-muted">@(b.Price > 0 ? $"₪{b.Price}" : "—")</span>
                                }
                            </td>
                            <td class="text-end pe-3 align-middle">
                                @if (_editBkId == b.BookId)
                                {
                                    <button class="btn btn-sm btn-success py-0 px-2 me-1" @onclick="SaveEditBook">
                                        <i class="ri-save-line"></i>
                                    </button>
                                    <button class="btn btn-sm btn-link text-muted py-0 px-1"
                                            @onclick="() => _editBkId = null">@LS.T("common.cancel")</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-link text-primary py-0 px-1"
                                            title="Edit" @onclick="() => StartEditBook(b)">
                                        <i class="ri-edit-line"></i>
                                    </button>
                                    <button class="btn btn-sm btn-link text-danger py-0 px-1"
                                            title="Delete" @onclick="() => DeleteBook(b.BookId)">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr style="background:#f1f8f2;color:#212529;">
                        <td class="ps-3 py-2">
                            <input class="form-control form-control-sm" style="max-width:280px;"
                                   placeholder="New book name"
                                   @bind="_newBkName" @bind:event="oninput"
                                   @onkeydown="OnAddBkKeyDown" />
                            @if (!string.IsNullOrEmpty(_addBkError))
                            {
                                <div class="text-danger small mt-1">@_addBkError</div>
                            }
                        </td>
                        <td class="py-2 text-end">
                            <input type="number" class="form-control form-control-sm" style="max-width:100px;margin-left:auto;"
                                   placeholder="Price"
                                   @bind="_newBkPrice" @bind:event="oninput"
                                   @onkeydown="OnAddBkKeyDown" />
                        </td>
                        <td class="text-end pe-3 py-2 align-middle">
                            <button class="btn btn-sm btn-success" @onclick="AddBook"
                                    disabled="@string.IsNullOrWhiteSpace(_newBkName)">
                                <i class="ri-add-line me-1"></i>@LS.T("common.add")
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
          </div>
        </div>
        }
    </div>

    @* ── Financial Config ── *@
    <div class="card shadow-sm mb-4" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#fff8e1;color:#212529;border-radius:12px 12px 0 0;border-bottom:1px solid #ffe082;cursor:pointer;"
             @onclick="() => _showFinConfig = !_showFinConfig">
            <span class="fw-semibold small" style="color:#f57f17;">
                <i class="ri-settings-3-line me-1"></i>@LS.T("courses.financialConfig")
            </span>
            <span class="d-flex align-items-center gap-2">
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showFinConfig ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showFinConfig)
        {
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3 small" style="width:50%;">Setting</th>
                        <th class="small">Value</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.vatPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgVatPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.ccCommissionPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCcCommissionPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.reserveDeductPct")</td>
                        <td><input type="number" step="0.01" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgReserveDeductPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle" colspan="2">
                            <div class="fw-medium mb-1">@LS.T("courses.academyInstructors")</div>
                            <div class="d-flex gap-2 flex-wrap">
                                @for (int idx = 0; idx < 4; idx++)
                                {
                                    var i = idx;
                                    <select class="form-select form-select-sm" style="max-width:160px;"
                                            value="@_cfgInstructors[i]"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _cfgInstructors[i] = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var u in _coreUsers)
                                        {
                                            <option value="@u.Id">@u.FullName</option>
                                        }
                                    </select>
                                }
                            </div>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr style="background:#fffde7;">
                        <td class="ps-3 py-2">
                            @if (!string.IsNullOrEmpty(_cfgMsg))
                            {
                                <span class="small @(_cfgIsError ? "text-danger" : "text-success")">@_cfgMsg</span>
                            }
                        </td>
                        <td class="py-2">
                            <button class="btn btn-sm btn-warning" @onclick="SaveFinancialConfig">
                                <i class="ri-save-line me-1"></i>@LS.T("common.save")
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
          </div>
        </div>
        }
    </div>

    @* ── Enrollment report ── *@
    <div class="card shadow-sm mb-4" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#f8fafc;border-radius:12px 12px 0 0;border-bottom:1px solid #e2e8f0;cursor:pointer;"
             @onclick="() => _showEnrollments = !_showEnrollments">
            <span class="fw-semibold small">
                <i class="ri-group-line me-1"></i>@LS.T("courses.enrollments")
            </span>
            <span class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill" style="background:#e0e7ff;color:#3949ab;font-size:.75rem;">
                    @_enrollments.Count
                </span>
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showEnrollments ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showEnrollments)
        {
        <div class="card-body p-0">
            @if (_enrollments.Count == 0)
            {
                <div class="text-center py-4 text-muted small">@LS.T("courses.noEnrollments")</div>
            }
            else
            {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0" style="font-size:.8rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">@LS.T("courses.pc")</th>
                            <th>@LS.T("courses.course")</th>
                            <th class="text-end">@LS.T("courses.paid")</th>
                            <th>@LS.T("courses.registrar")</th>
                            <th>@LS.T("courses.referral")</th>
                            <th class="text-center">@LS.T("courses.visits")</th>
                            <th class="text-center">@LS.T("common.status")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var e in _enrollments)
                        {
                            <tr>
                                <td class="ps-3 fw-medium">@e.PCFullName</td>
                                <td>@e.CourseName</td>
                                <td class="text-end">@(e.PaidAmount > 0 ? $"₪{e.PaidAmount}" : "—")</td>
                                <td class="text-muted">@(e.RegistrarName ?? "—")</td>
                                <td class="text-muted">@(e.ReferralName ?? "—")</td>
                                <td class="text-center fw-semibold" style="color:#34d399;">@e.VisitCount</td>
                                <td class="text-center">
                                    @if (e.DateFinished == null)
                                    {
                                        <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.7rem;">@LS.T("common.active")</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-size:.7rem;" title="Finished @e.DateFinished">@LS.T("courses.done")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
        </div>
        }
    </div>

</div>

<style>
    .cr-courses-page { max-width: 960px; }

    @@media (max-width: 480px) {
        .cr-courses-page { padding-left: 10px !important; padding-right: 10px !important; }
        .cr-courses-page .table { font-size: 0.78rem; }
        .cr-courses-page .table td, .cr-courses-page .table th { padding: 5px 6px; }
        .cr-courses-page .btn { min-height: 36px; touch-action: manipulation; }
        .cr-courses-page .form-control-sm { font-size: 1rem; min-height: 38px; }
        .cr-courses-page .d-flex.gap-3 { gap: 8px !important; }
    }
</style>

@code {
    // ── Collapse state ──
    bool _showCourses     = true;
    bool _showBooks        = true;
    bool _showFinConfig    = true;
    bool _showEnrollments  = true;

    // ── Courses state ──
    List<CourseItem>           _courses     = [];
    List<CourseEnrollmentItem> _enrollments = [];
    string _newName      = "";
    string _newBook      = "";
    int    _newBookPrice = 0;
    string _addError     = "";
    int?   _editId;
    string _editName      = "";
    string _editBook      = "";
    int    _editBookPrice = 0;

    // ── Books state ──
    List<BookItem> _books      = [];
    string _newBkName  = "";
    int    _newBkPrice = 0;
    string _addBkError = "";
    int?   _editBkId;
    string _editBkName  = "";
    int    _editBkPrice = 0;

    // ── Financial Config state ──
    double _cfgVatPct;
    double _cfgCcCommissionPct;
    double _cfgAuditRegistrarPct;
    double _cfgCourseRegistrarPct;
    double _cfgAuditReferralPct;
    double _cfgCourseReferralPct;
    double _cfgReserveDeductPct;
    int[] _cfgInstructors = new int[4];
    List<(int Id, string FullName)> _coreUsers = [];
    string _cfgMsg = "";
    bool   _cfgIsError;

    protected override void OnInitialized() => Reload();

    void Reload()
    {
        _courses     = CourseSvc.GetAllCourses();
        _enrollments = CourseSvc.GetCourseEnrollmentReport();
        _books       = CourseSvc.GetAllBooks();
        LoadFinancialConfig();
    }

    void LoadFinancialConfig()
    {
        _coreUsers = CourseSvc.GetCoreUsers();
        var cfg = CourseSvc.GetFinancialConfig();
        _cfgVatPct             = cfg.VatPct;
        _cfgCcCommissionPct    = cfg.CcCommissionPct;
        _cfgAuditRegistrarPct  = cfg.AuditRegistrarPct;
        _cfgCourseRegistrarPct = cfg.CourseRegistrarPct;
        _cfgAuditReferralPct   = cfg.AuditReferralPct;
        _cfgCourseReferralPct  = cfg.CourseReferralPct;
        _cfgReserveDeductPct   = cfg.ReserveDeductPct;
        _cfgMsg = "";

        // Parse stored IDs into the 4 dropdown slots
        _cfgInstructors = new int[4];
        var ids = cfg.AcademyInstructorIds
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Where(s => int.TryParse(s, out _))
            .Select(int.Parse)
            .ToArray();
        for (int i = 0; i < Math.Min(ids.Length, 4); i++)
            _cfgInstructors[i] = ids[i];
    }

    void SaveFinancialConfig()
    {
        var cleanIds = string.Join(",", _cfgInstructors.Where(id => id > 0));
        CourseSvc.UpdateFinancialConfig(
            _cfgVatPct, _cfgCcCommissionPct,
            _cfgAuditRegistrarPct, _cfgCourseRegistrarPct,
            _cfgAuditReferralPct, _cfgCourseReferralPct,
            _cfgReserveDeductPct, cleanIds);
        _cfgMsg = LS.T("courses.configSaved");
        _cfgIsError = false;
    }

    // ── Courses CRUD ──

    void AddCourse()
    {
        if (string.IsNullOrWhiteSpace(_newName)) { _addError = LS.T("courses.nameRequired"); return; }
        _addError = "";
        Console.WriteLine($"[Courses] Added course '{_newName.Trim()}' by 'admin'");
        CourseSvc.AddCourse(_newName.Trim(), _newBook.Trim(), _newBookPrice);
        _newName = ""; _newBook = ""; _newBookPrice = 0;
        Reload();
    }

    void OnAddKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") AddCourse(); }

    void StartEdit(CourseItem c)
    {
        _editId = c.CourseId; _editName = c.Name;
        _editBook = c.Book; _editBookPrice = c.BookPrice;
    }

    void SaveEdit()
    {
        if (_editId.HasValue && !string.IsNullOrWhiteSpace(_editName))
        {
            Console.WriteLine($"[Courses] Updated course {_editId.Value} to '{_editName.Trim()}' by 'admin'");
            CourseSvc.UpdateCourse(_editId.Value, _editName.Trim(), _editBook.Trim(), _editBookPrice);
        }
        _editId = null;
        Reload();
    }

    void OnEditKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") SaveEdit(); }

    void DeleteCourse(int id)
    {
        Console.WriteLine($"[Courses] Deleted course {id} by 'admin'");
        CourseSvc.DeleteCourse(id);
        Reload();
    }

    // ── Books CRUD ──

    void AddBook()
    {
        if (string.IsNullOrWhiteSpace(_newBkName)) { _addBkError = "Book name is required"; return; }
        _addBkError = "";
        Console.WriteLine($"[Courses] Added book '{_newBkName.Trim()}' price={_newBkPrice} by 'admin'");
        CourseSvc.AddBook(_newBkName.Trim(), _newBkPrice);
        _newBkName = ""; _newBkPrice = 0;
        Reload();
    }

    void OnAddBkKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") AddBook(); }

    void StartEditBook(BookItem b)
    {
        _editBkId = b.BookId; _editBkName = b.Name; _editBkPrice = b.Price;
    }

    void SaveEditBook()
    {
        if (_editBkId.HasValue && !string.IsNullOrWhiteSpace(_editBkName))
        {
            Console.WriteLine($"[Courses] Updated book {_editBkId.Value} to '{_editBkName.Trim()}' price={_editBkPrice} by 'admin'");
            CourseSvc.UpdateBook(_editBkId.Value, _editBkName.Trim(), _editBkPrice);
        }
        _editBkId = null;
        Reload();
    }

    void OnEditBkKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") SaveEditBook(); }

    void DeleteBook(int id)
    {
        Console.WriteLine($"[Courses] Deleted book {id} by 'admin'");
        CourseSvc.DeleteBook(id);
        Reload();
    }
}
