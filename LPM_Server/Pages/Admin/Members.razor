@page "/Admin/Members"
@attribute [Authorize(Roles = "Admin")]
@inject LPM.Services.AcademyService AcademySvc
@using Microsoft.AspNetCore.Authorization
@using LPM.Services

<div class="p-3 p-md-4" style="max-width:820px;">

    <div class="d-flex align-items-center mb-3 gap-3">
        <div>
            <h4 class="mb-0 fw-bold" style="color:#1e3a5f;">
                <i class="ri-group-line me-2" style="color:#3949ab;"></i>@LS.T("members.title")
            </h4>
            <span class="text-muted" style="font-size:0.82rem;">
                @LS.T("members.description")
            </span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.78rem;">
                @_members.Count(m => m.IsActive) @LS.T("members.active")
            </span>
            <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-size:.78rem;">
                @_members.Count(m => !m.IsActive) @LS.T("members.inactive")
            </span>
        </div>
    </div>

    @* ── Filter bar ── *@
    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
        <div class="input-group input-group-sm" style="max-width:260px;">
            <span class="input-group-text"><i class="ri-search-line"></i></span>
            <input class="form-control" placeholder="@LS.T("members.searchPlaceholder")"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="btn-group btn-group-sm" role="group">
            <button class="btn @(_filter == "all"      ? "btn-primary" : "btn-outline-secondary")"
                    @onclick='() => _filter = "all"'>@LS.T("common.all")</button>
            <button class="btn @(_filter == "active"   ? "btn-success" : "btn-outline-secondary")"
                    @onclick='() => _filter = "active"'>@LS.T("common.active")</button>
            <button class="btn @(_filter == "inactive" ? "btn-secondary" : "btn-outline-secondary")"
                    @onclick='() => _filter = "inactive"'>@LS.T("common.inactive")</button>
        </div>
    </div>

    @* ── Conflict resolution panel ── *@
    @if (_conflictPersonId > 0)
    {
        <div class="card border-warning mb-3" style="border-radius:10px;">
            <div class="card-body py-3">
                <h6 class="fw-bold mb-1" style="color:#92400e;">
                    <i class="ri-error-warning-line me-1"></i>@LS.T("members.nameConflict")
                </h6>
                <p class="text-muted small mb-3">
                    @((MarkupString)string.Format(LS.T("members.conflictDesc"), $"<strong>{_conflictCurrentName}</strong>"))
                </p>
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label small mb-1">@LS.T("members.firstName")</label>
                        <input class="form-control form-control-sm" @bind="_editFirstName" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">@LS.T("members.lastName")</label>
                        <input class="form-control form-control-sm" @bind="_editLastName" />
                    </div>
                    <div class="col-auto">
                        <label class="form-label small mb-1">@LS.T("members.externalId") <span class="text-muted">@LS.T("members.optional")</span></label>
                        <input class="form-control form-control-sm" style="width:140px;"
                               placeholder="@LS.T("members.extIdPlaceholder")" @bind="_editExternalId" />
                    </div>
                    <div class="col-auto d-flex gap-2">
                        <button class="btn btn-sm btn-success" @onclick="ConfirmReactivate">
                            <i class="ri-eye-line me-1"></i>@LS.T("members.reactivate")
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelConflict">@LS.T("common.cancel")</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_conflictError))
                {
                    <div class="text-danger small mt-2"><i class="ri-alert-line me-1"></i>@_conflictError</div>
                }
            </div>
        </div>
    }

    @* ── Table ── *@
    <div class="card shadow-sm" style="border-radius:12px;border:none;">
        <div class="card-body p-0">
            @if (!Filtered.Any())
            {
                <div class="text-center py-5 text-muted small">@LS.T("members.noMatch")</div>
            }
            else
            {
                <table class="table table-sm table-hover mb-0" style="font-size:.85rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">@LS.T("common.name")</th>
                            <th>@LS.T("members.phone")</th>
                            <th>@LS.T("members.roles")</th>
                            <th class="text-center">@LS.T("common.status")</th>
                            <th class="text-center pe-3">@LS.T("members.action")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Filtered)
                        {
                            <tr style="opacity:@(m.IsActive ? "1" : ".55");">
                                <td class="ps-3 align-middle fw-medium" style="color:#1e293b;">
                                    @m.FullName
                                    @if (!string.IsNullOrEmpty(m.ExternalId))
                                    {
                                        <span class="ms-1 text-muted" style="font-size:.72rem;font-weight:400;">(#@m.ExternalId)</span>
                                    }
                                </td>
                                <td class="align-middle text-muted">
                                    @(string.IsNullOrEmpty(m.Phone) ? "—" : m.Phone)
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex gap-1 flex-wrap">
                                        @if (m.IsPC)
                                        {
                                            <span class="badge rounded-pill" style="background:#fef3c7;color:#92400e;font-size:.68rem;">@LS.T("members.badgePC")</span>
                                        }
                                        @if (m.IsAcademyStudent)
                                        {
                                            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.68rem;">@LS.T("members.badgeAcademy")</span>
                                        }
                                        @if (m.IsStaff)
                                        {
                                            <span class="badge rounded-pill" style="background:#e0e7ff;color:#3730a3;font-size:.68rem;">@LS.T("members.badgeStaff")</span>
                                        }
                                    </div>
                                </td>
                                <td class="text-center align-middle">
                                    @if (m.IsActive)
                                    {
                                        <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.72rem;">
                                            <i class="ri-check-line me-1"></i>@LS.T("common.active")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-size:.72rem;">
                                            <i class="ri-eye-off-line me-1"></i>@LS.T("common.inactive")
                                        </span>
                                    }
                                </td>
                                <td class="text-center pe-3 align-middle">
                                    @if (m.IsActive)
                                    {
                                        <button class="btn btn-sm btn-outline-danger py-0 px-2"
                                                style="font-size:.75rem;"
                                                title="@LS.T("members.deactivateTitle")"
                                                @onclick="() => Toggle(m.PersonId, false)">
                                            <i class="ri-eye-off-line me-1"></i>@LS.T("members.deactivate")
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success py-0 px-2"
                                                style="font-size:.75rem;"
                                                title="@LS.T("members.reactivateTitle")"
                                                @onclick="() => Toggle(m.PersonId, true)">
                                            <i class="ri-eye-line me-1"></i>@LS.T("members.reactivate")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

</div>

@code {
    List<MemberAdminItem> _members = [];
    string _search = "";
    string _filter = "all";

    // Conflict resolution state
    int    _conflictPersonId;
    string _conflictCurrentName = "";
    string _editFirstName  = "";
    string _editLastName   = "";
    string _editExternalId = "";
    string _conflictError  = "";

    IEnumerable<MemberAdminItem> Filtered => _members
        .Where(m => _filter switch {
            "active"   => m.IsActive,
            "inactive" => !m.IsActive,
            _          => true
        })
        .Where(m => string.IsNullOrWhiteSpace(_search) ||
                    m.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    m.Phone.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override void OnInitialized() => _members = AcademySvc.GetAllMembersForAdmin();

    void Toggle(int personId, bool active)
    {
        if (active)
        {
            var m = _members.First(x => x.PersonId == personId);
            bool conflict = _members.Any(x => x.PersonId != personId && x.IsActive && x.FullName == m.FullName);
            if (conflict)
            {
                _conflictPersonId    = personId;
                _conflictCurrentName = m.FullName;
                _editFirstName       = m.FirstName;
                _editLastName        = m.LastName;
                _editExternalId      = "";
                _conflictError       = "";
                return;
            }
        }
        AcademySvc.SetPersonActive(personId, active);
        _members = AcademySvc.GetAllMembersForAdmin();
    }

    void ConfirmReactivate()
    {
        if (string.IsNullOrWhiteSpace(_editFirstName))
        { _conflictError = LS.T("members.firstNameRequired"); return; }

        var newName = $"{_editFirstName.Trim()} {_editLastName.Trim()}".Trim();
        bool stillConflicts = _members.Any(x => x.PersonId != _conflictPersonId && x.IsActive && x.FullName == newName);

        if (stillConflicts && string.IsNullOrWhiteSpace(_editExternalId))
        { _conflictError = LS.T("members.nameStillTaken"); return; }

        AcademySvc.UpdateAndActivatePerson(
            _conflictPersonId,
            _editFirstName,
            _editLastName,
            string.IsNullOrWhiteSpace(_editExternalId) ? null : _editExternalId.Trim());

        CancelConflict();
        _members = AcademySvc.GetAllMembersForAdmin();
    }

    void CancelConflict()
    {
        _conflictPersonId    = 0;
        _conflictCurrentName = "";
        _editFirstName       = "";
        _editLastName        = "";
        _editExternalId      = "";
        _conflictError       = "";
    }
}
