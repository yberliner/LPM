@page "/Admin/Members"
@attribute [Authorize(Roles = "Admin,Customer")]
@inject LPM.Services.AcademyService AcademySvc
@inject LPM.Services.PcService PcSvc
@inject LPM.Services.DashboardService DashSvc
@using Microsoft.AspNetCore.Authorization
@using LPM.Services

<div class="p-3 p-md-4 mb-members-page">

    <div class="d-flex align-items-center mb-3 gap-2 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold" style="color:var(--default-text-color);">
                <i class="ri-group-line me-2" style="color:#7986cb;"></i>@LS.T("members.title")
            </h4>
            <span class="text-muted" style="font-size:0.82rem;">
                @LS.T("members.description")
            </span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2">
            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.78rem;">
                @_members.Count(m => m.IsActive) @LS.T("members.active")
            </span>
            <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-size:.78rem;">
                @_members.Count(m => !m.IsActive) @LS.T("members.inactive")
            </span>
        </div>
    </div>

    @* ── Filter bar ── *@
    <div class="d-flex gap-2 mb-3 align-items-center flex-wrap">
        <div class="input-group input-group-sm mb-members-search">
            <span class="input-group-text"><i class="ri-search-line"></i></span>
            <input class="form-control" placeholder="@LS.T("members.searchPlaceholder")"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="btn-group btn-group-sm" role="group">
            <button class="btn @(_filter == "all"      ? "btn-primary" : "btn-outline-secondary")"
                    @onclick='() => _filter = "all"'>@LS.T("common.all")</button>
            <button class="btn @(_filter == "active"   ? "btn-success" : "btn-outline-secondary")"
                    @onclick='() => _filter = "active"'>@LS.T("common.active")</button>
            <button class="btn @(_filter == "inactive" ? "btn-secondary" : "btn-outline-secondary")"
                    @onclick='() => _filter = "inactive"'>@LS.T("common.inactive")</button>
        </div>
    </div>

    @* ── Conflict resolution panel ── *@
    @if (_conflictPersonId > 0)
    {
        <div class="card border-warning mb-3" style="border-radius:10px;">
            <div class="card-body py-3">
                <h6 class="fw-bold mb-1" style="color:#fbbf24;">
                    <i class="ri-error-warning-line me-1"></i>@LS.T("members.nameConflict")
                </h6>
                <p class="text-muted small mb-3">
                    @((MarkupString)string.Format(LS.T("members.conflictDesc"), $"<strong>{_conflictCurrentName}</strong>"))
                </p>
                <div class="row g-2 align-items-end">
                    <div class="col-12 col-sm-auto">
                        <label class="form-label small mb-1">@LS.T("members.firstName")</label>
                        <input class="form-control form-control-sm" @bind="_editFirstName" />
                    </div>
                    <div class="col-12 col-sm-auto">
                        <label class="form-label small mb-1">@LS.T("members.lastName")</label>
                        <input class="form-control form-control-sm" @bind="_editLastName" />
                    </div>
                    <div class="col-12 col-sm-auto">
                        <label class="form-label small mb-1">@LS.T("pcs.nick") <span class="text-muted">@LS.T("members.optional")</span></label>
                        <input class="form-control form-control-sm"
                               placeholder="@LS.T("pcs.nick")" @bind="_editNick" />
                    </div>
                    <div class="col-12 col-sm-auto d-flex gap-2">
                        <button class="btn btn-sm btn-success flex-fill flex-sm-grow-0" @onclick="ConfirmReactivate">
                            <i class="ri-eye-line me-1"></i>@LS.T("members.reactivate")
                        </button>
                        <button class="btn btn-sm btn-outline-secondary flex-fill flex-sm-grow-0" @onclick="CancelConflict">@LS.T("common.cancel")</button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_conflictError))
                {
                    <div class="text-danger small mt-2"><i class="ri-alert-line me-1"></i>@_conflictError</div>
                }
            </div>
        </div>
    }

    @* ── Table ── *@
    <div class="card shadow-sm" style="border-radius:12px;border:none;">
        <div class="card-body p-0">
            @if (!Filtered.Any())
            {
                <div class="text-center py-5 text-muted small">@LS.T("members.noMatch")</div>
            }
            else
            {
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0" style="font-size:.85rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3" style="cursor:pointer;user-select:none;" @onclick='() => SetSort("name")'>
                                @LS.T("common.name")
                                @if (_sortBy == "name")
                                {
                                    <i class="ri-arrow-@(_sortAsc ? "up" : "down")-s-line ms-1" style="font-size:.7rem;"></i>
                                }
                            </th>
                            <th>@LS.T("members.phone")</th>
                            <th>@LS.T("members.roles")</th>
                            <th class="d-none d-sm-table-cell" style="cursor:pointer;user-select:none;" @onclick='() => SetSort("lastVisit")'>
                                @LS.T("members.lastVisited")
                                @if (_sortBy == "lastVisit")
                                {
                                    <i class="ri-arrow-@(_sortAsc ? "up" : "down")-s-line ms-1" style="font-size:.7rem;"></i>
                                }
                            </th>
                            <th class="text-center" style="cursor:pointer;user-select:none;" @onclick='() => SetSort("status")'>
                                @LS.T("common.status")
                                @if (_sortBy == "status")
                                {
                                    <i class="ri-arrow-@(_sortAsc ? "up" : "down")-s-line ms-1" style="font-size:.7rem;"></i>
                                }
                            </th>
                            <th class="text-center" style="width:50px;">@LS.T("common.edit")</th>
                            <th class="text-center pe-3">@LS.T("members.action")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Filtered)
                        {
                            <tr style="opacity:@(m.IsActive ? "1" : ".55");">
                                <td class="ps-3 align-middle fw-medium" style="color:@(m.IsPC && _soloPcIds.Contains(m.PersonId) ? "#ea580c" : "var(--default-text-color)");">
                                    @m.FullName
                                    @if (m.IsPC && _soloPcIds.Contains(m.PersonId))
                                    {
                                        <span style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:3px;background:#ea580c;color:#fff;font-size:.58rem;font-weight:700;margin-left:3px;vertical-align:middle;">S</span>
                                    }
                                    @if (!string.IsNullOrEmpty(m.Nick))
                                    {
                                        <span class="ms-1 text-muted" style="font-size:.72rem;font-weight:400;">(@m.Nick)</span>
                                    }
                                </td>
                                <td class="align-middle text-muted">
                                    @(string.IsNullOrEmpty(m.Phone) ? "—" : m.Phone)
                                </td>
                                <td class="align-middle">
                                    <div class="d-flex gap-1 flex-wrap">
                                        @if (m.IsPC)
                                        {
                                            <span class="badge rounded-pill" style="background:#fef3c7;color:#92400e;font-size:.68rem;">@LS.T("members.badgePC")</span>
                                        }
                                        @if (m.IsAcademyStudent)
                                        {
                                            <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.68rem;">@LS.T("members.badgeAcademy")</span>
                                        }
                                        @if (m.IsStaff)
                                        {
                                            <span class="badge rounded-pill" style="background:#e0e7ff;color:#3730a3;font-size:.68rem;">@LS.T("members.badgeStaff")</span>
                                        }
                                    </div>
                                </td>
                                <td class="d-none d-sm-table-cell align-middle text-muted">
                                    @if (m.LastVisitDate != null)
                                    {
                                        @m.LastVisitDate
                                    }
                                    else
                                    {
                                        <span style="opacity:.4;">—</span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    @if (m.IsActive)
                                    {
                                        <span class="badge rounded-pill" style="background:#d1fae5;color:#065f46;font-size:.72rem;">
                                            <i class="ri-check-line me-1"></i>@LS.T("common.active")
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill" style="background:#f1f5f9;color:#64748b;font-size:.72rem;">
                                            <i class="ri-eye-off-line me-1"></i>@LS.T("common.inactive")
                                        </span>
                                    }
                                </td>
                                <td class="text-center align-middle">
                                    <button class="btn btn-sm btn-outline-primary py-0 px-1"
                                            style="font-size:.78rem; border-radius:6px;"
                                            title="@LS.T("common.edit")"
                                            @onclick="() => OpenEdit(m.PersonId)">
                                        <i class="ri-pencil-line"></i>
                                    </button>
                                </td>
                                <td class="text-center pe-3 align-middle">
                                    @if (m.IsActive)
                                    {
                                        <button class="btn btn-sm btn-outline-danger py-0 px-2"
                                                style="font-size:.75rem;"
                                                title="@LS.T("members.deactivateTitle")"
                                                @onclick="() => Toggle(m.PersonId, false)">
                                            <i class="ri-eye-off-line me-1"></i>@LS.T("members.deactivate")
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success py-0 px-2"
                                                style="font-size:.75rem;"
                                                title="@LS.T("members.reactivateTitle")"
                                                @onclick="() => Toggle(m.PersonId, true)">
                                            <i class="ri-eye-line me-1"></i>@LS.T("members.reactivate")
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
        </div>
    </div>

</div>

<style>
    .mb-members-page { max-width: 820px; }

    /* Search box: capped on desktop, flexible on mobile */
    .mb-members-search { max-width: 260px; flex: 1 1 180px; }

    /* Table action buttons — larger touch targets */
    .mb-members-page .table .btn {
        min-height: 32px;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
    }

    /* Sort header cells — big enough to tap */
    .mb-members-page .table th[style*="cursor:pointer"] {
        touch-action: manipulation;
    }

    @@media (max-width: 576px) {
        .mb-members-page { max-width: 100%; padding-left: 10px !important; padding-right: 10px !important; }

        /* Search fills the row on mobile */
        .mb-members-search { max-width: 100%; flex: 1 1 100%; }

        /* Filter buttons a bit taller for touch */
        .mb-members-page .btn-group .btn { min-height: 36px; font-size: 0.8rem; }

        /* Table: tighter font, more touch-friendly buttons */
        .mb-members-page .table { font-size: 0.78rem; }
        .mb-members-page .table td, .mb-members-page .table th { padding: 6px 4px; }
        .mb-members-page .table td.ps-3, .mb-members-page .table th.ps-3 { padding-left: 8px !important; }
        .mb-members-page .table td.pe-3, .mb-members-page .table th.pe-3 { padding-right: 8px !important; }
        .mb-members-page .table .btn { min-height: 36px; font-size: 0.72rem; padding: 4px 8px; }

        /* Conflict panel inputs full-width */
        .mb-members-page .form-control-sm { font-size: 1rem; min-height: 40px; }
    }
</style>

<SpkNewPersonModal @ref="_editModal" Title="@LS.T("common.edit")" RequireAllFields="false" ExistingFullNames="_existingNames" OnSaved="SaveEdit" />

@code {
    List<MemberAdminItem> _members = [];
    HashSet<int> _soloPcIds = new();
    string _search = "";
    string _filter = "all";
    string _sortBy = "name";
    bool   _sortAsc = true;

    // Conflict resolution state
    int    _conflictPersonId;
    string _conflictCurrentName = "";
    string _editFirstName  = "";
    string _editLastName   = "";
    string _editNick = "";
    string _conflictError  = "";

    IEnumerable<MemberAdminItem> Filtered
    {
        get
        {
            var q = _members
                .Where(m => _filter switch {
                    "active"   => m.IsActive,
                    "inactive" => !m.IsActive,
                    _          => true
                })
                .Where(m => string.IsNullOrWhiteSpace(_search) ||
                            m.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                            m.Phone.Contains(_search, StringComparison.OrdinalIgnoreCase));

            if (_sortBy == "lastVisit")
            {
                q = _sortAsc
                    ? q.OrderBy(m => m.LastVisitDate ?? "").ThenBy(m => m.FullName)
                    : q.OrderByDescending(m => m.LastVisitDate ?? "").ThenBy(m => m.FullName);
            }
            else if (_sortBy == "status")
            {
                q = _sortAsc
                    ? q.OrderBy(m => m.IsActive ? 0 : 1).ThenBy(m => m.FullName)
                    : q.OrderBy(m => m.IsActive ? 1 : 0).ThenBy(m => m.FullName);
            }
            else
            {
                q = _sortAsc
                    ? q.OrderBy(m => m.FullName)
                    : q.OrderByDescending(m => m.FullName);
            }
            return q;
        }
    }

    void SetSort(string col)
    {
        if (_sortBy == col) _sortAsc = !_sortAsc;
        else { _sortBy = col; _sortAsc = col == "name"; }
    }

    protected override void OnInitialized()
    {
        _members   = AcademySvc.GetAllMembersForAdmin();
        _soloPcIds = DashSvc.GetSoloPcIds();
    }

    void Toggle(int personId, bool active)
    {
        if (active)
        {
            var m = _members.First(x => x.PersonId == personId);
            bool conflict = _members.Any(x => x.PersonId != personId && x.IsActive && x.FullName == m.FullName);
            if (conflict)
            {
                _conflictPersonId    = personId;
                _conflictCurrentName = m.FullName;
                _editFirstName       = m.FirstName;
                _editLastName        = m.LastName;
                _editNick      = "";
                _conflictError       = "";
                return;
            }
        }
        Console.WriteLine($"[Members] Toggled member {personId} active={active} by 'admin'");
        AcademySvc.SetPersonActive(personId, active);
        _members = AcademySvc.GetAllMembersForAdmin();
    }

    void ConfirmReactivate()
    {
        if (string.IsNullOrWhiteSpace(_editFirstName))
        { _conflictError = LS.T("members.firstNameRequired"); return; }

        var newName = $"{_editFirstName.Trim()} {_editLastName.Trim()}".Trim();
        bool stillConflicts = _members.Any(x => x.PersonId != _conflictPersonId && x.IsActive && x.FullName == newName);

        if (stillConflicts && string.IsNullOrWhiteSpace(_editNick))
        { _conflictError = LS.T("members.nameStillTaken"); return; }

        Console.WriteLine($"[Members] Reactivated member {_conflictPersonId} as '{_editFirstName} {_editLastName}' by 'admin'");
        AcademySvc.UpdateAndActivatePerson(
            _conflictPersonId,
            _editFirstName,
            _editLastName,
            string.IsNullOrWhiteSpace(_editNick) ? null : _editNick.Trim());

        CancelConflict();
        _members = AcademySvc.GetAllMembersForAdmin();
    }

    void CancelConflict()
    {
        _conflictPersonId    = 0;
        _conflictCurrentName = "";
        _editFirstName       = "";
        _editLastName        = "";
        _editNick      = "";
        _conflictError       = "";
    }

    // ── Edit member ──
    SpkNewPersonModal _editModal = null!;
    HashSet<string>? _existingNames;
    int _editingPersonId;

    void OpenEdit(int personId)
    {
        var detail = AcademySvc.GetPersonDetail(personId);
        if (detail == null) return;
        _editingPersonId = personId;
        _existingNames = new HashSet<string>(
            _members.Where(m => m.PersonId != personId).Select(m => m.FullName),
            StringComparer.OrdinalIgnoreCase);
        _editModal.ShowForEdit(
            detail.FirstName, detail.LastName,
            detail.Phone, detail.Email,
            detail.DateOfBirth, detail.Gender,
            detail.OrgId, detail.Source, detail.Notes, detail.Nick);
    }

    void SaveEdit((string FirstName, string LastName, string Phone, string Email,
        string DateOfBirth, string Gender, int OrgId, string Source, string Notes, int CourseId, string Nick) d)
    {
        Console.WriteLine($"[Members] Updated member {_editingPersonId} — '{d.FirstName} {d.LastName}' by 'admin'");
        AcademySvc.UpdatePerson(_editingPersonId,
            d.FirstName, d.LastName, d.Nick,
            d.Phone, d.Email, d.Notes,
            d.DateOfBirth, d.Gender, orgId: d.OrgId > 0 ? d.OrgId : null);
        _members = AcademySvc.GetAllMembersForAdmin();
    }
}
