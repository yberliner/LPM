@page "/Admin/Diagnostics"
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Cryptography
@using Microsoft.Data.Sqlite
@inject IConfiguration Config

<PageTitle>Diagnostics — LPM</PageTitle>

<div class="container-fluid py-4" style="max-width:900px;">
    <h4 class="fw-bold mb-1">Diagnostics</h4>
    <p class="text-muted mb-4" style="font-size:.85rem;">
        Creates a new copy of the current database with all data tables cleared and a single
        <strong>admin / Admin1992</strong> user seeded. The live database is never touched.
    </p>

    @if (!string.IsNullOrEmpty(_resultPath))
    {
        <div class="alert alert-success d-flex align-items-center gap-2">
            <i class="ri-checkbox-circle-line" style="font-size:1.3rem;"></i>
            <div>
                <strong>Done.</strong> File created:<br />
                <code style="font-size:.82rem; word-break:break-all;">@_resultPath</code>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }

    <button class="btn btn-danger d-flex align-items-center gap-2"
            disabled="@_busy"
            @onclick="CreateEmptyDbCopy">
        @if (_busy)
        {
            <span class="spinner-border spinner-border-sm"></span>
            <span>Working…</span>
        }
        else
        {
            <i class="ri-database-2-line"></i>
            <span>Create Empty DB Copy</span>
        }
    </button>

    @* ── core_* tables ── *@
    <div class="cedb-group-header mt-4">
        <i class="ri-user-line me-1"></i>core_* tables
    </div>
    @foreach (var t in _coreTables) { @TableSection(t) }

    @* ── sys_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-settings-3-line me-1"></i>sys_* tables
    </div>
    @foreach (var t in _sysTables) { @TableSection(t) }

    @* ── lkp_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-price-tag-3-line me-1"></i>lkp_* tables
    </div>
    @foreach (var t in _lkpTables) { @TableSection(t) }

    @* ── sess_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-calendar-line me-1"></i>sess_* tables <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(last 200 rows)</span>
    </div>
    @foreach (var t in _sessTables) { @TableSection(t) }

    @* ── cs_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-user-star-line me-1"></i>cs_* tables <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(last 200 rows)</span>
    </div>
    @foreach (var t in _csTables) { @TableSection(t) }

    @* ── fin_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-money-dollar-circle-line me-1"></i>fin_* tables <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(last 200 rows)</span>
    </div>
    @foreach (var t in _finTables) { @TableSection(t) }

    @* ── acad_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-graduation-cap-line me-1"></i>acad_* tables <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(last 200 rows)</span>
    </div>
    @foreach (var t in _acadTables) { @TableSection(t) }
</div>

@* Inline component so we don't need a separate file *@
@code {
    // ── Generic table display ──────────────────────────────────────────────
    record TableData(string Name, string Icon, List<string> Columns, List<List<string>> Rows);

    RenderFragment<TableData> TableSection => t =>
        @<div class="cedb-section mt-3">
            <div class="cedb-section-title cedb-section-toggle" @onclick="() => ToggleSection(t.Name)">
                <i class="@t.Icon me-1"></i>@t.Name
                <span class="cedb-count">@t.Rows.Count row@(t.Rows.Count != 1 ? "s" : "")</span>
                <i class="ri-arrow-down-s-line cedb-chevron @(_collapsed.Contains(t.Name) ? "cedb-chevron-up" : "")"></i>
            </div>
            @if (!_collapsed.Contains(t.Name))
            {
                @if (t.Rows.Count == 0)
                {
                    <div class="cedb-empty">No rows</div>
                }
                else
                {
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>
                                    @foreach (var col in t.Columns)
                                    {
                                        <th>@col</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in t.Rows)
                                {
                                    <tr>
                                        @for (int i = 0; i < t.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>;

    // ── State ────────────────────────────────────────────────────────────────
    HashSet<string> _collapsed = [];
    void ToggleSection(string name) { if (!_collapsed.Remove(name)) _collapsed.Add(name); }

    bool _busy;
    string _resultPath = "";
    string _error = "";
    List<TableData> _coreTables = [];
    List<TableData> _sysTables  = [];
    List<TableData> _lkpTables  = [];
    List<TableData> _sessTables = [];
    List<TableData> _csTables   = [];
    List<TableData> _finTables  = [];
    List<TableData> _acadTables = [];

    protected override void OnInitialized() => LoadLiveTables();

    void LoadLiveTables()
    {
        var cs = $"Data Source={Config["Database:Path"] ?? "lifepower.db"}";
        using var conn = new SqliteConnection(cs);
        conn.Open();

        // PasswordHash and TotpSecret omitted — sensitive
        _coreTables =
        [
            Load(conn, "core_users",   "ri-user-settings-line",  "ORDER BY Id",       ["PasswordHash", "TotpSecret"]),
            Load(conn, "core_persons", "ri-contacts-line",        "ORDER BY PersonId"),
            Load(conn, "core_pcs",     "ri-computer-line",        "ORDER BY PcId"),
        ];

        _sysTables =
        [
            Load(conn, "sys_staff_pc_list",   "ri-shield-check-line",   "ORDER BY Id"),
            Load(conn, "sys_staff_messages",  "ri-message-2-line",      "ORDER BY Id"),
            Load(conn, "sys_weekly_remarks",  "ri-calendar-check-line", "ORDER BY Id"),
            Load(conn, "sys_trusted_devices", "ri-device-line",         "ORDER BY CreatedAt"),
        ];

        _lkpTables =
        [
            Load(conn, "lkp_grades",           "ri-medal-line",         "ORDER BY SortOrder"),
            Load(conn, "lkp_courses",          "ri-book-line",          "ORDER BY CourseId"),
            Load(conn, "lkp_cs_status",        "ri-flag-line",          "ORDER BY SortOrder"),
            Load(conn, "lkp_folder_items",     "ri-folder-line",        "ORDER BY Section, ItemId"),
            Load(conn, "lkp_organizations",    "ri-building-line",      "ORDER BY OrgId"),
            Load(conn, "lkp_referral_sources", "ri-link-m",             "ORDER BY ReferralId"),
            Load(conn, "lkp_shortcuts",        "ri-keyboard-line",      "ORDER BY Id"),
        ];

        _sessTables =
        [
            Load(conn, "sess_sessions",       "ri-calendar-event-line", "ORDER BY SessionId       DESC LIMIT 200"),
            Load(conn, "sess_misc_charges",   "ri-coins-line",          "ORDER BY MiscChargeId    DESC LIMIT 200"),
            Load(conn, "sess_folder_summary", "ri-file-text-line",      "ORDER BY Id              DESC LIMIT 200"),
            Load(conn, "sess_meetings",       "ri-time-line",           "ORDER BY MeetingId       DESC LIMIT 200"),
        ];

        _csTables =
        [
            Load(conn, "cs_reviews",          "ri-shield-star-line",    "ORDER BY CsReviewId      DESC LIMIT 200"),
            Load(conn, "cs_work_log",         "ri-todo-line",           "ORDER BY CsWorkLogId     DESC LIMIT 200"),
            Load(conn, "cs_case_supervisors", "ri-user-star-line",      "ORDER BY CsId            DESC LIMIT 200"),
        ];

        _finTables =
        [
            Load(conn, "fin_purchases",       "ri-shopping-cart-line",  "ORDER BY PurchaseId      DESC LIMIT 200"),
            Load(conn, "fin_purchase_items",  "ri-list-check",          "ORDER BY PurchaseItemId  DESC LIMIT 200"),
            Load(conn, "fin_payments",        "ri-bank-card-line",      "ORDER BY PaymentId       DESC LIMIT 200"),
            Load(conn, "fin_payment_methods", "ri-secure-payment-line", "ORDER BY PaymentMethodId DESC LIMIT 200"),
        ];

        _acadTables =
        [
            Load(conn, "acad_attendance",      "ri-check-double-line",  "ORDER BY StudentId       DESC LIMIT 200"),
            Load(conn, "acad_student_courses", "ri-book-open-line",     "ORDER BY StudentCourseId DESC LIMIT 200"),
        ];
    }

    TableData Load(SqliteConnection conn, string table, string icon,
                   string orderBy = "", string[]? skipCols = null)
    {
        var skip = new HashSet<string>(skipCols ?? [], StringComparer.OrdinalIgnoreCase);
        var cols = new List<string>();
        var rows = new List<List<string>>();
        try
        {
            using var cmd = conn.CreateCommand();
            cmd.CommandText = $"SELECT * FROM {table} {orderBy}";
            using var r = cmd.ExecuteReader();
            for (int i = 0; i < r.FieldCount; i++)
                if (!skip.Contains(r.GetName(i))) cols.Add(r.GetName(i));
            while (r.Read())
            {
                var row = new List<string>();
                for (int i = 0; i < r.FieldCount; i++)
                    if (!skip.Contains(r.GetName(i)))
                        row.Add(r.IsDBNull(i) ? "" : r.GetValue(i).ToString() ?? "");
                rows.Add(row);
            }
        }
        catch (Exception ex)
        {
            cols = [$"Error: {ex.Message}"];
        }
        return new TableData(table, icon, cols, rows);
    }

    // ── Create action ────────────────────────────────────────────────────────
    async Task CreateEmptyDbCopy()
    {
        _busy = true; _resultPath = ""; _error = "";
        try
        {
            await Task.Run(DoCreate);
        }
        catch (Exception ex)
        {
            _error = $"Failed: {ex.Message}";
            Console.WriteLine($"[CreateEmptyDb] Error: {ex}");
        }
        finally
        {
            _busy = false;
            LoadLiveTables();
        }
    }

    void DoCreate()
    {
        var srcPath = Config["Database:Path"] ?? "lifepower.db";
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        var dir = Path.GetDirectoryName(Path.GetFullPath(srcPath)) ?? ".";
        var name = Path.GetFileNameWithoutExtension(srcPath);
        var destPath = Path.Combine(dir, $"{name}_empty_{timestamp}.db");

        // 1. Copy the live DB via the SQLite backup API so the result is a fully
        //    checkpointed, self-contained file (no -wal / -shm companion files).
        using var src = new Microsoft.Data.Sqlite.SqliteConnection($"Data Source={srcPath}");
        src.Open();
        using var conn = new Microsoft.Data.Sqlite.SqliteConnection($"Data Source={destPath};Pooling=False");
        conn.Open();
        src.BackupDatabase(conn);
        src.Close();
        Console.WriteLine($"[CreateEmptyDb] Copied '{srcPath}' → '{destPath}'");

        // 2. Clear all data tables
        using var cmd = conn.CreateCommand();

        cmd.CommandText = "PRAGMA foreign_keys = OFF";
        cmd.ExecuteNonQuery();

        foreach (var table in new[]
        {
            // Financial
            "fin_payment_methods", "fin_purchase_items", "fin_purchases", "fin_payments",
            // Academic
            "acad_attendance", "acad_student_courses",
            // Sessions
            "sess_folder_summary", "sess_misc_charges", "sess_sessions", "sess_auditors", "sess_meetings",
            // CS
            "cs_work_log", "cs_reviews", "cs_case_supervisors",
            // System
            "sys_weekly_remarks", "sys_auditor_pc_permissions",
            "sys_staff_messages", "sys_staff_pc_list", "sys_trusted_devices",
            // Core (last — referenced by others)
            "core_user_roles", "core_users", "core_pcs", "core_persons",
        })
        {
            cmd.CommandText = $"DELETE FROM {table}";
            cmd.Parameters.Clear();
            try { cmd.ExecuteNonQuery(); }
            catch (Exception ex)
            {
                // Table may not exist in older schema versions — skip silently
                Console.WriteLine($"[CreateEmptyDb] Skipped table '{table}': {ex.Message}");
            }
        }

        // Reset SQLite auto-increment counters
        cmd.CommandText = "DELETE FROM sqlite_sequence WHERE name IN " +
            "('core_persons','core_pcs','core_users','sess_sessions','cs_reviews'," +
            "'fin_purchases','fin_purchase_items','fin_payments','fin_payment_methods')";
        try { cmd.ExecuteNonQuery(); } catch { /* sqlite_sequence may not exist */ }

        // 3. Seed admin user
        //    core_persons row
        cmd.CommandText = @"
            INSERT INTO core_persons (FirstName, LastName, Phone, Email, DateOfBirth, Gender, Org, Source, Notes, Nick)
            VALUES ('Admin', '', '', '', '', '', NULL, NULL, '', '')";
        cmd.Parameters.Clear();
        cmd.ExecuteNonQuery();

        cmd.CommandText = "SELECT last_insert_rowid()";
        var personId = (long)cmd.ExecuteScalar()!;

        //    core_pcs row (admin is also a PC entry to satisfy FK)
        cmd.CommandText = "INSERT INTO core_pcs (PcId) VALUES (@pid)";
        cmd.Parameters.Clear();
        cmd.Parameters.AddWithValue("@pid", personId);
        try { cmd.ExecuteNonQuery(); } catch { /* core_pcs may not require every person */ }

        //    core_users row
        var passwordHash = HashPassword("Admin1992");
        cmd.CommandText = @"
            INSERT INTO core_users
                (PersonId, Username, PasswordHash, StaffRole, UserType, GradeId, AllowAll,
                 IsActive, MustChangePassword, ContactConfirmed)
            VALUES (@pid, 'admin', @h, 'Auditor', 'Admin', NULL, 1, 1, 0, 1)";
        cmd.Parameters.Clear();
        cmd.Parameters.AddWithValue("@pid", personId);
        cmd.Parameters.AddWithValue("@h", passwordHash);
        cmd.ExecuteNonQuery();

        cmd.CommandText = "PRAGMA foreign_keys = ON";
        cmd.Parameters.Clear();
        cmd.ExecuteNonQuery();

        // Switch to DELETE journal mode — ensures the output is a single portable file
        // with no -wal / -shm companion files that would appear when it is opened elsewhere.
        cmd.CommandText = "PRAGMA journal_mode=DELETE;";
        cmd.ExecuteNonQuery();

        Console.WriteLine($"[CreateEmptyDb] Seeded admin user. Empty DB ready at '{destPath}'");
        _resultPath = destPath;
    }

    // PBKDF2-SHA256 — identical to UserDb.HashPassword
    static string HashPassword(string password)
    {
        const int iterations = 260000;
        byte[] salt = RandomNumberGenerator.GetBytes(16);
        using var kdf = new Rfc2898DeriveBytes(password, salt, iterations, HashAlgorithmName.SHA256);
        byte[] hash = kdf.GetBytes(32);
        return $"pbkdf2_sha256${iterations}${Convert.ToBase64String(salt)}${Convert.ToBase64String(hash)}";
    }
}

<style>
    .cedb-group-header {
        font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em;
        color: #475569; padding: 4px 0 2px;
        border-bottom: 2px solid #e2e8f0; margin-bottom: 2px;
    }
    .cedb-section { }
    .cedb-section-title {
        font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em;
        color: #64748b; margin-bottom: 6px; margin-top: 10px;
        display: flex; align-items: center; gap: 6px;
    }
    .cedb-section-title::after { content:''; flex:1; height:1px; background:#e2e8f0; }
    .cedb-section-toggle { cursor: pointer; user-select: none; }
    .cedb-section-toggle:hover { color: #3b82f6; }
    .cedb-chevron { font-size: .9rem; margin-left: 2px; transition: transform .2s ease; transform: rotate(0deg); flex-shrink: 0; }
    .cedb-chevron-up { transform: rotate(-180deg); }
    .cedb-count { font-weight: 400; font-size: .68rem; color: #94a3b8; text-transform: none; letter-spacing: 0; }
    .cedb-empty { font-size: .75rem; color: #94a3b8; font-style: italic; padding: 4px 0; }
    .cedb-table-wrap { overflow-x: auto; border-radius: 8px; border: 1px solid #e2e8f0; }
    .cedb-table { width: 100%; border-collapse: collapse; font-size: .72rem; }
    .cedb-table th {
        padding: 4px 10px; background: #f8fafc; color: #94a3b8;
        font-weight: 700; font-size: .6rem; text-transform: uppercase; letter-spacing: .05em;
        border-bottom: 1px solid #e2e8f0; white-space: nowrap;
    }
    .cedb-table td { padding: 3px 10px; border-bottom: 1px solid #f1f5f9; color: var(--default-text-color, #1e293b); white-space: nowrap; line-height: 1.3; }
    .cedb-table tbody tr:last-child td { border-bottom: none; }
    .cedb-table tbody tr:hover { background: rgba(99,102,241,.04); }
    .cedb-table code { font-size: .68rem; background: rgba(0,0,0,.06); padding: 0 4px; border-radius: 3px; color: #6366f1; }
</style>
