@code {
    // ── Filter state ──────────────────────────────────────────────
    private bool    _includeApproved = false;
    private string  _fromDateStr = "";
    private string  _toDateStr   = "";
    private string? _filterError;

    // ── Sessions data ─────────────────────────────────────────────
    private List<AuditorSessionGroup>              _groups      = new();
    private Dictionary<(int aud, int pc), PcDefaults> _pcDefaults  = new();
    private Dictionary<int, RowEdit>               _rowEdits    = new();
    private Dictionary<int, string?>               _auditorAvatars = new();
    private Dictionary<int, List<LPM.Services.Wallet>> _pcWallets = new();
    // Top-row "apply to all" wallet selection per (auditor, PC) group
    private Dictionary<(int aud, int pc), int> _pcTopWallet   = new();
    // Top-row wallet selection per (CS, PC) group
    private Dictionary<(int cs,  int pc), int> _csTopWallet   = new();

    // Last auditing purchase per PC — populated once per LoadData. Key = PcId.
    private Dictionary<int, LPM.Services.LastAuditingPurchase> _pcLastPurchase = new();

    // Currently-shown last-purchase popup
    private LPM.Services.LastAuditingPurchase? _lastPurchaseDetail;
    private string _lastPurchasePcName = "";

    void ShowLastPurchase(int pcId)
    {
        if (!_pcLastPurchase.TryGetValue(pcId, out var lp)) return;
        _lastPurchaseDetail = lp;
        _lastPurchasePcName = _groups.SelectMany(g => g.PcGroups).FirstOrDefault(pg => pg.PcId == pcId)?.PcName
                              ?? _csGroups.SelectMany(g => g.PcGroups).FirstOrDefault(pg => pg.PcId == pcId)?.PcName
                              ?? $"PC {pcId}";
    }

    void CloseLastPurchase() { _lastPurchaseDetail = null; }

    // Inline "Last rate: …" line shown beneath each PC name. Reused at all 3 render sites
    // (auditor multi-session header, auditor single-session row, CS reviews header).
    // When the displayed sessions for this PC have rates that differ from the last-auditing-
    // purchase rate, the line glows amber and hovering reveals an explanation card.
    // Default overload — used by the Sessions-section call sites (mismatch glow ENABLED).
    RenderFragment RenderLastRate(int pcId) => RenderLastRate(pcId, checkMismatch: true);

    // Mismatch detection is computed only over Sessions-section rows, so the CS Reviews
    // header passes checkMismatch:false to avoid glowing/popup'ing for the same PcId.
    RenderFragment RenderLastRate(int pcId, bool checkMismatch) => @<div class="sa-pc-rate-line @((checkMismatch && _pcRateMismatch.ContainsKey(pcId)) ? "is-mismatch" : "")"
                                                      @onmouseenter="(e) => { if (checkMismatch) OnRateMismatchEnter(e, pcId); }"
                                                      @onmouseleave="OnRateMismatchLeave">
        @if (_pcLastPurchase.TryGetValue(pcId, out var __lp))
        {
            <span>Last rate:</span>
            <span class="sa-pc-rate-val">@CurrencySymbolFromCode(__lp.Currency)@RoundRateCents(__lp.RateCentsPerHour)/hr</span>
            @if (checkMismatch && _pcRateMismatch.ContainsKey(pcId))
            {
                <i class="ri-alert-line sa-pc-rate-warn" title="Rate mismatch — hover for details"></i>
            }
            <button type="button" class="sa-pc-rate-btn" @onclick="() => ShowLastPurchase(pcId)"
                    title="Show last auditing purchase details">
                <i class="ri-information-line"></i>
            </button>
            @* Per-line hover card — DOM-nested so cursor can move onto card without dismissing it.
               Only shown when checkMismatch is true (Sessions section); CS Reviews never sees it. *@
            @if (checkMismatch && _rateHoverPcId == pcId && _pcRateMismatch.TryGetValue(pcId, out var __mm))
            {
                <div class="sa-rate-card is-active"
                     style="top:@(_rateHoverY + 18)px; left:min(@(_rateHoverX + 14)px, calc(100vw - 432px));">
                    <div class="sa-rate-card-head">
                        <i class="ri-alert-line"></i>
                        <span class="sa-rate-card-title">Rate Mismatch — @__mm.PcName</span>
                    </div>
                    <div class="sa-rate-card-body">
                        <div class="sa-rate-card-section">
                            <div class="sa-rate-card-label">Last auditing purchase rate</div>
                            <div class="sa-rate-card-bigval">
                                @CurrencySymbolFromCode(__mm.Currency)@RoundRateCents(__mm.LastRateCents)<span style="font-size:.7rem;opacity:.7;">/hr</span>
                            </div>
                        </div>
                        <div class="sa-rate-card-section">
                            <div class="sa-rate-card-label">But sessions in this view are priced at</div>
                            @{ int __ri = 0; }
                            @foreach (var __b in __mm.MismatchBuckets)
                            {
                                var __i = __ri++;
                                <div class="sa-rate-card-row" style="--row-i: @__i;">
                                    <i class="ri-arrow-right-s-line sa-rate-card-row-arrow"></i>
                                    <span class="sa-rate-card-row-rate">@CurrencySymbolFromCode(__mm.Currency)@RoundRateCents(__b.RateCents)<span style="font-size:.7rem;opacity:.65;">/hr</span></span>
                                    <span class="sa-rate-card-row-count">@__b.Count session@(__b.Count == 1 ? "" : "s")</span>
                                    <span class="sa-rate-card-row-date">first: @__b.FirstDate</span>
                                </div>
                            }
                        </div>
                        <div class="sa-rate-card-foot">
                            Likely the rate was overridden manually when approving these sessions, or the
                            most-recent purchase was created after the sessions were billed. Click the
                            <i class="ri-information-line"></i> button to see the full purchase details.
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <span>Last rate: —</span>
        }
    </div>;

    static string CurrencySymbolFromCode(string code) => code switch
    {
        "USD" => "$",
        "EUR" => "€",
        "GBP" => "£",
        _     => "₪",
    };

    // Organization filter — 0=All, 1=Haifa, 2=Riga (mirrors Statistics tab)
    private int    _selOrg;
    private int?   OrgFilter => _selOrg == 0 ? (int?)null : _selOrg;

    // "Mismatched rates only" toggle — when on, hide PCs whose entered rate matches the
    // last billed rate (within the existing ±5/hr tolerance used by _pcRateMismatch).
    private bool   _mismatchOnly;

    string PcWalletCurrency(int pcId)
    {
        // If any top-row selection exists for this PC, use that wallet's currency
        foreach (var kv in _pcTopWallet)
            if (kv.Key.pc == pcId)
            {
                var w = _pcWallets.GetValueOrDefault(pcId)?.FirstOrDefault(x => x.WalletId == kv.Value);
                if (w != null) return w.Currency;
            }
        foreach (var kv in _csTopWallet)
            if (kv.Key.pc == pcId)
            {
                var w = _pcWallets.GetValueOrDefault(pcId)?.FirstOrDefault(x => x.WalletId == kv.Value);
                if (w != null) return w.Currency;
            }
        return _pcCurrency.GetValueOrDefault(pcId, "ILS");
    }

    void OnTopWalletChanged(int auditorId, int pcId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        // No-op if already set to the same wallet (prevents spurious propagation on initial render)
        if (_pcTopWallet.TryGetValue((auditorId, pcId), out var existing) && existing == wid) return;
        _pcTopWallet[(auditorId, pcId)] = wid;
        // Apply to every session in this (auditor, PC) group — only update sessions that differ
        var audGroup = _groups.FirstOrDefault(g => g.AuditorId == auditorId);
        var pcGroup  = audGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup == null) return;
        for (int i = 0; i < pcGroup.Sessions.Count; i++)
        {
            var s = pcGroup.Sessions[i];
            if (s.WalletId == wid) continue;
            WalletSvc.SetSessionWallet(s.SessionId, wid);
            pcGroup.Sessions[i] = s with { WalletId = wid };
        }
    }

    void OnCsTopWalletChanged(int csId, int pcId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        if (_csTopWallet.TryGetValue((csId, pcId), out var existing) && existing == wid) return;
        _csTopWallet[(csId, pcId)] = wid;
        var csGroup = _csGroups.FirstOrDefault(g => g.CsId == csId);
        var pcGroup = csGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup == null) return;
        for (int i = 0; i < pcGroup.Reviews.Count; i++)
        {
            var rev = pcGroup.Reviews[i];
            if (rev.WalletId == wid) continue;
            WalletSvc.SetCsReviewWallet(rev.CsReviewId, wid);
            pcGroup.Reviews[i] = rev with { WalletId = wid };
        }
    }

    void OnSessionWalletChanged(int sessionId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        WalletSvc.SetSessionWallet(sessionId, wid);
        // Update local model so the dropdown reflects the new state
        foreach (var g in _groups)
        foreach (var pg in g.PcGroups)
        {
            var idx = pg.Sessions.FindIndex(s => s.SessionId == sessionId);
            if (idx >= 0)
            {
                pg.Sessions[idx] = pg.Sessions[idx] with { WalletId = wid };
                return;
            }
        }
    }

    void OnCsReviewWalletChanged(int csReviewId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        WalletSvc.SetCsReviewWallet(csReviewId, wid);
        foreach (var g in _csGroups)
        foreach (var pg in g.PcGroups)
        {
            var idx = pg.Reviews.FindIndex(r => r.CsReviewId == csReviewId);
            if (idx >= 0)
            {
                pg.Reviews[idx] = pg.Reviews[idx] with { WalletId = wid };
                return;
            }
        }
    }

