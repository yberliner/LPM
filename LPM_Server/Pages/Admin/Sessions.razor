@page "/Admin/Sessions"
@attribute [Authorize(Roles = "Admin")]
@using LPM.Services
@using LPM.Auth
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@inject DashboardService DashSvc
@inject LPM.Services.PcService PcSvc
@inject UserDb UserDb
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject LPM.Services.WalletService WalletSvc
@inject LPM.Services.SessionManagerLauncher SmLauncher
@inject IJSRuntime JS

<div class="sa-page p-3 p-md-4">

    @* Top offset — pushes the page header DOWN so the fixed quick-nav bar
       (rendered below at top:4.25rem) doesn't overlay it. Only needed when the bar is shown. *@
    @if (!_loading && (_groups.Count + _csGroups.Count) > 1)
    {
        <div class="sa-page-bar-offset" aria-hidden="true"></div>
    }

    @* ── Page Header ── *@
    <div class="d-flex align-items-center mb-3 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold sa-title">@LS.T("sessions.title")</h4>
            <span class="text-muted" style="font-size:0.82rem;">@LS.T("sessions.subtitle")</span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
            @if (_sessDraft > 0)
            {
                <span class="badge rounded-pill text-bg-warning px-3 py-2" style="font-size:0.77rem;">
                    <i class="ri-time-line me-1"></i>@_sessDraft @LS.T("sessions.sessionPending")
                </span>
            }
            @if (_csNotDone > 0)
            {
                <span class="badge rounded-pill sa-badge-cs-draft px-3 py-2" style="font-size:0.77rem;">
                    <i class="ri-user-star-line me-1"></i>@_csNotDone @LS.T("sessions.csPending")
                </span>
            }
            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    @onclick="() => LoadData()" disabled="@_loading">
                <i class="ri-refresh-line @(_loading ? "sa-spin" : "")"></i> @LS.T("common.refresh")
            </button>
        </div>
    </div>

    @* ── Filter bar ── *@
    <div class="card border-0 shadow-sm mb-4 sa-filter-card">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3 flex-wrap">

                @* Mode selector – segmented control *@
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted fw-semibold" style="font-size:0.8rem;">@LS.T("sessions.show")</span>
                    <div class="btn-group sa-seg" role="group">
                        <button type="button"
                                class="btn btn-sm @(!_includeApproved ? "sa-seg-active" : "sa-seg-inactive")"
                                @onclick="SwitchToDraftOnly">
                            <i class="ri-file-list-line me-1"></i>@LS.T("sessions.pendingOnly")
                        </button>
                        <button type="button"
                                class="btn btn-sm @(_includeApproved ? "sa-seg-active" : "sa-seg-inactive")"
                                @onclick="SwitchToIncludeApproved">
                            <i class="ri-checkbox-circle-line me-1"></i>@LS.T("sessions.includeApproved")
                        </button>
                    </div>
                </div>

                @* Date range — only shown in "Include Approved" mode *@
                @if (_includeApproved)
                {
                    <div class="sa-filter-divider d-none d-sm-block"></div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <span class="text-muted" style="font-size:0.8rem;">@LS.T("common.from")</span>
                        <input type="date" class="form-control form-control-sm sa-date-input"
                               value="@_fromDateStr"
                               @onchange="e => _fromDateStr = e.Value?.ToString() ?? string.Empty" />
                        <span class="text-muted" style="font-size:0.8rem;">@LS.T("common.to")</span>
                        <input type="date" class="form-control form-control-sm sa-date-input"
                               value="@_toDateStr"
                               @onchange="e => _toDateStr = e.Value?.ToString() ?? string.Empty" />
                        <button class="btn btn-sm sa-btn-apply d-flex align-items-center gap-1"
                                @onclick="ApplyApprovedFilter" disabled="@_loading">
                            <i class="ri-search-line"></i> @LS.T("common.apply")
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_filterError))
                    {
                        <span class="text-danger small d-flex align-items-center gap-1">
                            <i class="ri-error-warning-line"></i>@_filterError
                        </span>
                    }
                }

                @* Org filter — chip group, mirrors Statistics tab *@
                <div class="sa-filter-divider d-none d-sm-block"></div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-semibold" style="font-size:0.8rem;color:#6b7280;">
                        <i class="ri-filter-3-line me-1"></i>Org:
                    </span>
                    <div class="btn-group" role="group" aria-label="Organization filter">
                        <button type="button"
                                class="btn btn-sm rounded-pill me-1 @(_selOrg == 0 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(0)" disabled="@_loading">All</button>
                        <button type="button"
                                class="btn btn-sm rounded-pill me-1 @(_selOrg == 1 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(1)" disabled="@_loading">Haifa</button>
                        <button type="button"
                                class="btn btn-sm rounded-pill @(_selOrg == 2 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(2)" disabled="@_loading">Riga</button>
                    </div>
                </div>

                @* "Mismatched rates only" toggle + on-hover explainer popover *@
                <div class="sa-filter-divider d-none d-sm-block"></div>
                <div class="sa-mismatch-toggle">
                    <div class="form-check form-switch d-flex align-items-center gap-2 m-0">
                        <input type="checkbox" role="switch" id="sa-mismatch-only"
                               class="form-check-input m-0" style="cursor:pointer;"
                               checked="@_mismatchOnly"
                               @onchange="e => _mismatchOnly = (bool)(e.Value ?? false)"
                               disabled="@_loading" />
                        <label for="sa-mismatch-only" class="form-check-label fw-semibold m-0"
                               style="font-size:0.8rem;color:#6b7280;cursor:pointer;">
                            <i class="ri-error-warning-line me-1" style="color:#f59e0b;"></i>Mismatched rates only
                        </label>
                    </div>

                    @* Hover-only animated explainer card *@
                    <div class="sa-mismatch-pop" role="tooltip" aria-hidden="true">
                        <div class="sa-mp-arrow"></div>
                        <div class="sa-mp-card">
                            <div class="sa-mp-header">
                                <span class="sa-mp-header-glow"></span>
                                <i class="ri-magic-line"></i>
                                <span class="sa-mp-title">Mismatched Rates Filter</span>
                            </div>
                            <div class="sa-mp-body">
                                <p class="sa-mp-desc">
                                    Hides PCs whose entered <strong>Rate/hr</strong> already matches the
                                    <strong>last billed rate</strong>. Only PCs that need a second look stay on screen.
                                </p>

                                <div class="sa-mp-demo">
                                    @* Match — would be filtered out *@
                                    <div class="sa-mp-row sa-mp-row-match">
                                        <div class="sa-mp-row-head">
                                            <i class="ri-checkbox-circle-fill"></i>
                                            <span class="sa-mp-row-label">Match</span>
                                            <span class="sa-mp-pill sa-mp-pill-out">hidden</span>
                                        </div>
                                        <div class="sa-mp-rates">
                                            <span class="sa-mp-chip">Rate <strong>₪150</strong>/hr</span>
                                            <i class="ri-arrow-left-right-line sa-mp-arrow-i"></i>
                                            <span class="sa-mp-chip sa-mp-chip-last">Last <strong>₪148</strong>/hr</span>
                                        </div>
                                        <div class="sa-mp-bar"><div class="sa-mp-bar-fill sa-mp-bar-fill-ok"></div></div>
                                    </div>

                                    @* Mismatch — kept *@
                                    <div class="sa-mp-row sa-mp-row-bad">
                                        <div class="sa-mp-row-head">
                                            <i class="ri-error-warning-fill"></i>
                                            <span class="sa-mp-row-label">Mismatch</span>
                                            <span class="sa-mp-pill sa-mp-pill-keep">shown</span>
                                        </div>
                                        <div class="sa-mp-rates">
                                            <span class="sa-mp-chip">Rate <strong>₪200</strong>/hr</span>
                                            <i class="ri-arrow-left-right-line sa-mp-arrow-i sa-mp-arrow-bad"></i>
                                            <span class="sa-mp-chip sa-mp-chip-last sa-mp-chip-glow">Last <strong>₪150</strong>/hr</span>
                                        </div>
                                        <div class="sa-mp-bar"><div class="sa-mp-bar-fill sa-mp-bar-fill-bad"></div></div>
                                    </div>
                                </div>

                                <div class="sa-mp-footer">
                                    <i class="ri-ruler-line"></i>
                                    <span>Tolerance <strong>±5/hr</strong> · ignores tiny rounding</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Quick-jump nav bar — fixed below the app header, always visible Excel-freeze style.
       Combined bar: Auditors on the left, CS Reviewers on the right. *@
    @if (!_loading && (_groups.Count + _csGroups.Count) > 1)
    {
        <div class="sa-quick-nav">
            <div class="sa-quick-nav-strip">
                @if (_groups.Count > 0)
                {
                    <div class="sa-quick-nav-label sa-quick-nav-label-aud" title="Auditors">
                        <i class="ri-user-voice-line"></i>
                    </div>
                    @foreach (var g in _groups)
                    {
                        var firstName = string.IsNullOrWhiteSpace(g.AuditorName) ? "?" : g.AuditorName.Split(' ')[0];
                        <button type="button" class="sa-quick-nav-chip sa-quick-nav-chip-aud"
                                data-target="sa-aud-@g.AuditorId"
                                title="Jump to @g.AuditorName"
                                @onclick="() => JumpToAuditor(g.AuditorId)">
                            <span class="sa-quick-nav-avatar sa-quick-nav-avatar-aud">@(g.AuditorName.Length > 0 ? char.ToUpper(g.AuditorName[0]) : '?')</span>
                            <span class="sa-quick-nav-name">@firstName</span>
                        </button>
                    }
                }
                @if (_groups.Count > 0 && _csGroups.Count > 0)
                {
                    <div class="sa-quick-nav-divider"></div>
                }
                @if (_csGroups.Count > 0)
                {
                    <div class="sa-quick-nav-label sa-quick-nav-label-cs" title="CS Reviewers">
                        <i class="ri-user-star-line"></i>
                    </div>
                    @foreach (var c in _csGroups)
                    {
                        var firstName = string.IsNullOrWhiteSpace(c.CsName) ? "?" : c.CsName.Split(' ')[0];
                        <button type="button" class="sa-quick-nav-chip sa-quick-nav-chip-cs"
                                data-target="sa-cs-@c.CsId"
                                title="Jump to @c.CsName"
                                @onclick="() => JumpToCs(c.CsId)">
                            <span class="sa-quick-nav-avatar sa-quick-nav-avatar-cs">@(c.CsName.Length > 0 ? char.ToUpper(c.CsName[0]) : '?')</span>
                            <span class="sa-quick-nav-name">@firstName</span>
                        </button>
                    }
                }
            </div>
        </div>
        <div class="sa-quick-nav-spacer" aria-hidden="true"></div>
    }

    @* ══════════════════════════════════════════════════════════
       SECTION 1 — SESSIONS
       ══════════════════════════════════════════════════════════ *@
    <div class="sa-collapse-header mb-3" @onclick="() => _sessCollapsed = !_sessCollapsed">
        <div class="d-flex align-items-center gap-2">
            <i class="ri-arrow-down-s-line sa-chevron @(_sessCollapsed ? "sa-chevron-collapsed" : "")"></i>
            <i class="ri-calendar-check-line" style="font-size:1.05rem;"></i>
            <span>@LS.T("sessions.sessions")</span>
            @if (_sessDraft > 0)    { <span class="badge rounded-pill sa-badge-pending ms-2">@_sessDraft @LS.T("sessions.pending")</span> }
            @if (_sessApproved > 0) { <span class="badge rounded-pill sa-badge-approved-sm ms-1">@_sessApproved @LS.T("sessions.approved")</span> }
        </div>
    </div>

    @if (_sessCollapsed) { }
    else if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <div class="text-muted">@LS.T("common.loading")</div>
        </div>
    }
    else if (_groups.Count == 0)
    {
        <div class="sa-empty-block mb-4">
            <i class="ri-check-double-line" style="font-size:1.8rem;color:#16a34a;"></i>
            <div class="fw-semibold mt-2">@LS.T("sessions.noSessions")</div>
            <div class="small" style="color:#6b7280;">@(_includeApproved ? "No sessions in the selected date range." : "No pending sessions for approval.")</div>
        </div>
    }
    else
    {
        @foreach (var group in _groups)
        {
            // "Mismatched rates only": filter PcGroups to those flagged in _pcRateMismatch.
            // Built once per auditor so the header counts and the loop body see the same set.
            var visiblePcGroups = _mismatchOnly
                ? group.PcGroups.Where(pg => _pcRateMismatch.ContainsKey(pg.PcId)).ToList()
                : group.PcGroups;
            if (visiblePcGroups.Count == 0) { continue; }

            int gDraft    = visiblePcGroups.Sum(pg => pg.Sessions.Count(s => s.VerifiedStatus != "Approved"));
            int gApproved = visiblePcGroups.Sum(pg => pg.Sessions.Count(s => s.VerifiedStatus == "Approved"));
            var audAvatar = _auditorAvatars.GetValueOrDefault(group.AuditorId);

            <div class="card border-0 shadow-sm mb-4 sa-auditor-card" id="sa-aud-@group.AuditorId">
                <div class="card-header d-flex align-items-center gap-3 py-3 px-4 border-0 sa-auditor-header">
                    @if (audAvatar != null) { <img src="@audAvatar" class="sa-avatar-img" alt="@group.AuditorName" /> }
                    else { <div class="sa-avatar">@(group.AuditorName.Length > 0 ? char.ToUpper(group.AuditorName[0]) : '?')</div> }
                    <div class="text-white lh-sm">
                        <div class="fw-semibold" style="font-size:1rem;">@group.AuditorName</div>
                        <div style="font-size:0.71rem;opacity:.72;">
                            @visiblePcGroups.Count PC@(visiblePcGroups.Count != 1 ? "s" : "")
                            @if (gDraft > 0)    { <span> · @gDraft @LS.T("sessions.pending")</span> }
                            @if (gApproved > 0) { <span> · @gApproved @LS.T("sessions.approved")</span> }
                        </div>
                    </div>
                </div>

                @{ bool firstPc = true; }
                @foreach (var pcGroup in visiblePcGroups)
                {
                    var pcKey      = (group.AuditorId, pcGroup.PcId);
                    var pcDef      = _pcDefaults[pcKey];
                    int pcTotal    = pcGroup.Sessions.Count;
                    int pcDraft    = pcGroup.Sessions.Count(s => s.VerifiedStatus != "Approved");
                    int pcApproved = pcGroup.Sessions.Count(s => s.VerifiedStatus == "Approved");
                    bool isNewPc   = pcDef.ChargeRate == 0 && pcDef.Salary == 0;

                    @if (!firstPc) { <div class="sa-pc-divider"></div> }
                    firstPc = false;

                    @if (pcTotal > 1)
                    {
                        <div class="d-flex align-items-center gap-3 px-4 py-2 sa-pc-header flex-wrap">
                            <div class="d-flex flex-column gap-1">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="sa-pc-dot @(isNewPc ? "sa-pc-dot-new" : "")"></div>
                                    <span class="fw-semibold @(isNewPc ? "sa-pc-name-new" : "sa-pc-name")">@pcGroup.PcName</span>
                                    @if (isNewPc)
                                    {
                                        <span class="sa-pc-new-badge" title="This auditor has never had an approved session for this PC. Set Rate and Salary before approving.">
                                            <i class="ri-sparkling-2-fill"></i>
                                            <span>* new PC</span>
                                        </span>
                                    }
                                    @if (pcDraft > 0)    { <span class="badge rounded-pill sa-badge-pending">@pcDraft @LS.T("sessions.pending")</span> }
                                    @if (pcApproved > 0) { <span class="badge rounded-pill sa-badge-approved-sm">@pcApproved @LS.T("sessions.approved")</span> }
                                </div>
                                @RenderLastRate(pcGroup.PcId)
                            </div>
                            <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
                                <span class="sa-input-label" style="color:#6b7280;">Set all:</span>
                                @{ var pcWalletsTop = _pcWallets.GetValueOrDefault(pcGroup.PcId) ?? new(); }
                                @if (pcWalletsTop.Count > 1)
                                {
                                    <select class="form-select form-select-sm" style="width:170px; font-size:.78rem;"
                                            value="@(_pcTopWallet.GetValueOrDefault((group.AuditorId, pcGroup.PcId), pcGroup.Sessions.FirstOrDefault()?.WalletId ?? 0))"
                                            @onchange="e => OnTopWalletChanged(group.AuditorId, pcGroup.PcId, e.Value?.ToString())">
                                        @foreach (var w in pcWalletsTop)
                                        {
                                            <option value="@w.WalletId">@w.Name (@w.Currency)</option>
                                        }
                                    </select>
                                }
                                <div class="input-group input-group-sm sa-rate-input" style="width:125px;">
                                    <span class="input-group-text">@PcCurrSym(pcGroup.PcId) Rate</span>
                                    <input type="number" class="form-control" placeholder="0" min="0" step="0.01"
                                           value="@pcDef.ChargeRate.ToString(CultureInfo.InvariantCulture)" onfocus="this.select()"
                                           @onchange="e => PropagateRate(group.AuditorId, pcGroup.PcId,
                                               double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var rv) ? rv : pcDef.ChargeRate,
                                               pcDef.Salary)" />
                                </div>
                                <div class="input-group input-group-sm sa-rate-input" style="width:135px;">
                                    <span class="input-group-text">@PcCurrSym(pcGroup.PcId) Sal.</span>
                                    <input type="number" class="form-control" placeholder="0" min="0" step="0.01"
                                           value="@pcDef.Salary.ToString(CultureInfo.InvariantCulture)" onfocus="this.select()"
                                           @onchange="e => PropagateRate(group.AuditorId, pcGroup.PcId,
                                               pcDef.ChargeRate,
                                               double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var sv) ? sv : pcDef.Salary)" />
                                </div>
                                <button class="btn btn-sm sa-btn-approve-all d-flex align-items-center gap-1"
                                        @onclick="() => SubmitAllForPc(group.AuditorId, pcGroup.PcId)" disabled="@_busy">
                                    <i class="ri-check-double-line"></i>@LS.T("common.submitAll") (@pcTotal)
                                </button>
                            </div>
                        </div>
                    }

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 sa-table">
                            <thead>
                                <tr class="sa-thead">
                                    <th class="ps-4">@LS.T("common.date")</th>
                                    <th>Name</th>
                                    <th style="width:92px;">ID</th>
                                    <th class="text-center">@LS.T("sessions.duration")</th>
                                    <th class="text-center">@LS.T("sessions.admin")</th>
                                    <th class="text-center">@LS.T("sessions.free")</th>
                                    <th style="width:140px;">Wallet</th>
                                    <th style="min-width:135px; width:135px;">@LS.T("sessions.rate") @PcCurrSym(pcGroup.PcId)/hr</th>
                                    <th style="min-width:135px; width:135px;">@LS.T("sessions.salary") @PcCurrSym(pcGroup.PcId)/hr</th>
                                    <th style="width:105px;">@LS.T("common.status")</th>
                                    <th class="pe-4" style="width:130px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in pcGroup.Sessions)
                                {
                                    bool isApproved = s.VerifiedStatus == "Approved";
                                    var edit = _rowEdits[s.SessionId];
                                    <tr class="@(isApproved ? "sa-row-approved" : "sa-row-draft")"
                                        @oncontextmenu="e => OpenCtxSess(e, s.SessionId, s.IsFree)"
                                        @oncontextmenu:preventDefault="true">
                                        <td class="ps-4 py-2">
                                            @if (pcTotal == 1)
                                            {
                                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                                    <div class="sa-pc-dot @(isNewPc ? "sa-pc-dot-new" : "")"></div>
                                                    <span class="fw-semibold @(isNewPc ? "sa-pc-name-new" : "sa-pc-name")">@pcGroup.PcName</span>
                                                    @if (isNewPc)
                                                    {
                                                        <span class="sa-pc-new-badge" title="This auditor has never had an approved session for this PC. Set Rate and Salary before approving.">
                                                            <i class="ri-sparkling-2-fill"></i>
                                                            <span>* new PC</span>
                                                        </span>
                                                    }
                                                </div>
                                                @RenderLastRate(pcGroup.PcId)
                                            }
                                            <span class="fw-semibold sa-date">@FormatDate(s.CreatedAt)</span>
                                        </td>
                                        <td class="py-2 sa-sess-name" title="@s.Name">@s.Name</td>
                                        <td class="py-2">
                                            <span class="sa-id-sess" title="Session ID">sess #@s.SessionId</span>
                                        </td>
                                        <td class="text-center py-2 @(s.LengthSec > 10800 ? "wr-warn-cell" : "")">
                                            @if (s.LengthSec > 10800)
                                            {
                                                <span class="wr-warn-value">@DashboardService.Fmt(s.LengthSec)</span>
                                                <span class="wr-warn-tip">
                                                    <strong><i class="ri-alert-fill me-1"></i>Duration over 3 hours</strong>
                                                    <span>Typical sessions are 1–2.5 hours. Please verify the length wasn't mistyped — e.g.&nbsp;<code>3:30</code> instead of <code>0:30</code>.</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill bg-light border text-dark px-2" style="font-size:0.78rem;">@DashboardService.Fmt(s.LengthSec)</span>
                                            }
                                        </td>
                                        <td class="text-center py-2 @(s.AdminSec > 1800 ? "wr-warn-cell" : "")" style="@(s.AdminSec > 1800 ? "" : "font-size:0.83rem;color:#6b7280;")">
                                            @if (s.AdminSec > 1800)
                                            {
                                                <span class="wr-warn-value">@DashboardService.Fmt(s.AdminSec)</span>
                                                <span class="wr-warn-tip">
                                                    <strong><i class="ri-alert-fill me-1"></i>Admin time over 30 minutes</strong>
                                                    <span>Admin time is usually under 20&nbsp;min. Common typo: <code>3:00</code> instead of <code>0:03</code>. Please confirm.</span>
                                                </span>
                                            }
                                            else
                                            {
                                                @DashboardService.Fmt(s.AdminSec)
                                            }
                                        </td>
                                        <td class="text-center py-2">@if (s.IsFree) { <span class="badge sa-badge-free">FREE</span> }</td>
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @{ var pcWallets = _pcWallets.GetValueOrDefault(pcGroup.PcId) ?? new(); }
                                            @if (pcWallets.Count <= 1)
                                            {
                                                var w = pcWallets.FirstOrDefault(x => x.WalletId == (s.WalletId ?? 0)) ?? pcWallets.FirstOrDefault();
                                                if (w != null)
                                                {
                                                    <span class="badge" style="background:#dbeafe; color:#1e40af; font-size:.72rem;">@w.Name (@w.Currency)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            }
                                            else
                                            {
                                                <select class="form-select form-select-sm sa-row-input"
                                                        style="font-size:.78rem;"
                                                        value="@(s.WalletId ?? 0)"
                                                        @onchange="e => OnSessionWalletChanged(s.SessionId, e.Value?.ToString())">
                                                    @foreach (var w in pcWallets)
                                                    {
                                                        <option value="@w.WalletId">@w.Name (@w.Currency)</option>
                                                    }
                                                </select>
                                            }
                                        </td>
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @if (s.IsFree)
                                            {
                                                <span class="sa-free-badge">FREE — ignored</span>
                                            }
                                            else
                                            {
                                                <input type="number" class="form-control form-control-sm sa-row-input" @bind="edit.ChargeRate" @bind:culture="CultureInfo.InvariantCulture" min="0" step="0.01" onfocus="this.select()" />
                                            }
                                        </td>
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @if (s.IsFree)
                                            {
                                                <span class="sa-free-badge">FREE — @PcCurrSym(pcGroup.PcId)0</span>
                                            }
                                            else
                                            {
                                                <input type="number" class="form-control form-control-sm sa-row-input" @bind="edit.Salary" @bind:culture="CultureInfo.InvariantCulture" min="0" step="0.01" onfocus="this.select()" />
                                            }
                                        </td>
                                        <td class="py-2">
                                            @if (isApproved) { <span class="badge sa-badge-status-approved"><i class="ri-check-line me-1"></i>@LS.T("sessions.approvedStatus")</span> }
                                            else             { <span class="badge sa-badge-status-draft">@LS.T("sessions.pendingStatus")</span> }
                                        </td>
                                        <td class="pe-4 py-1">
                                            <div class="d-flex align-items-center gap-1">
                                                <button class="btn btn-sm d-flex align-items-center gap-1 @(isApproved ? "sa-btn-update" : "sa-btn-submit")"
                                                        @onclick="() => SubmitOne(s.SessionId)" disabled="@_busy">
                                                    <i class="@(isApproved ? "ri-pencil-line" : "ri-check-line")"></i>
                                                    @(isApproved ? LS.T("common.update") : LS.T("common.submit"))
                                                </button>
                                                <button type="button" class="sa-action-btn" title="Edit in Session Manager"
                                                        @onclick="() => OpenInSessionManager(s.SessionId)">
                                                    <i class="ri-database-2-line"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }

    @* ══════════════════════════════════════════════════════════
       SECTION 2 — CS REVIEWS
       ══════════════════════════════════════════════════════════ *@

    @* Animated violet divider — visually separates the auditor Sessions section
       from the CS Reviews section below. Glows + arrows bounce to draw the eye. *@
    <div class="sa-section-divider" role="separator" aria-label="Switching to CS Reviews section">
        <span class="sa-section-divider-line"></span>
        <span class="sa-section-divider-pill">
            <i class="ri-arrow-down-line sa-section-divider-arrow"></i>
            <i class="ri-user-star-line sa-section-divider-icon"></i>
            <span class="sa-section-divider-text">Below — CS Reviews Section</span>
            <i class="ri-arrow-down-line sa-section-divider-arrow"></i>
        </span>
        <span class="sa-section-divider-line"></span>
    </div>

    <div class="sa-collapse-header sa-collapse-header-cs mt-5 mb-3" @onclick="() => _csCollapsed = !_csCollapsed">
        <div class="d-flex align-items-center gap-2">
            <i class="ri-arrow-down-s-line sa-chevron @(_csCollapsed ? "sa-chevron-collapsed" : "")"></i>
            <i class="ri-user-star-line" style="font-size:1.05rem;"></i>
            <span>@LS.T("sessions.csReviews")</span>
            @if (_csNotDone > 0)    { <span class="badge rounded-pill sa-badge-pending ms-2">@_csNotDone @LS.T("sessions.pending")</span> }
            @if (_csDone > 0) { <span class="badge rounded-pill sa-badge-approved-sm ms-1">@_csDone @LS.T("sessions.approved")</span> }
        </div>
    </div>

    @if (_csCollapsed) { }
    else if (!_loading && _csGroups.Count == 0)
    {
        <div class="sa-empty-block mb-4">
            <i class="ri-user-star-line" style="font-size:1.8rem;color:#4a7fc1;"></i>
            <div class="fw-semibold mt-2">@LS.T("sessions.noCSReviews")</div>
            <div class="small" style="color:#6b7280;">@(_includeApproved ? "No CS reviews in the selected date range." : "No pending CS reviews for approval.")</div>
        </div>
    }
    else if (!_loading)
    {
        @foreach (var csGroup in _csGroups)
        {
            int cgNotDone = csGroup.PcGroups.Sum(pg => pg.Reviews.Count(r => r.CsStatus != "Approved"));
            int cgDone    = csGroup.PcGroups.Sum(pg => pg.Reviews.Count(r => r.CsStatus == "Approved"));
            var csAvatar   = _csAvatars.GetValueOrDefault(csGroup.CsId);

            <div class="card border-0 shadow-sm mb-4 sa-auditor-card" id="sa-cs-@csGroup.CsId">
                <div class="card-header d-flex align-items-center gap-3 py-3 px-4 border-0 sa-cs-card-header">
                    @if (csAvatar != null) { <img src="@csAvatar" class="sa-avatar-img" alt="@csGroup.CsName" /> }
                    else { <div class="sa-avatar sa-avatar-cs">@(csGroup.CsName.Length > 0 ? char.ToUpper(csGroup.CsName[0]) : '?')</div> }
                    <div class="text-white lh-sm">
                        <div class="fw-semibold" style="font-size:1rem;">@csGroup.CsName</div>
                        <div style="font-size:0.71rem;opacity:.72;">
                            @csGroup.PcGroups.Count PC@(csGroup.PcGroups.Count != 1 ? "s" : "")
                            @if (cgNotDone > 0) { <span> · @cgNotDone @LS.T("sessions.pending")</span> }
                            @if (cgDone > 0)    { <span> · @cgDone @LS.T("sessions.approved")</span> }
                        </div>
                    </div>
                </div>

                @{ bool firstCsPc = true; }
                @foreach (var pcGroup in csGroup.PcGroups)
                {
                    var csPcKey    = (csGroup.CsId, pcGroup.PcId);
                    double csPcDef = _csPcDefaults.GetValueOrDefault(csPcKey);
                    int csPcTotal  = pcGroup.Reviews.Count;
                    int csPcNotDone = pcGroup.Reviews.Count(r => r.CsStatus != "Approved");
                    int csPcDone    = pcGroup.Reviews.Count(r => r.CsStatus == "Approved");

                    @if (!firstCsPc) { <div class="sa-pc-divider"></div> }
                    firstCsPc = false;

                    <div class="d-flex align-items-center gap-3 px-4 py-2 sa-pc-header flex-wrap">
                        <div class="d-flex flex-column gap-1">
                            <div class="d-flex align-items-center gap-2">
                                <div class="sa-pc-dot sa-pc-dot-cs"></div>
                                <span class="fw-semibold sa-pc-name">@pcGroup.PcName</span>
                                @if (csPcNotDone > 0) { <span class="badge rounded-pill sa-badge-pending">@csPcNotDone @LS.T("sessions.pending")</span> }
                                @if (csPcDone > 0)    { <span class="badge rounded-pill sa-badge-approved-sm">@csPcDone @LS.T("sessions.approved")</span> }
                            </div>
                            @* CS Reviews section — never glows on rate mismatch (mismatch is a Sessions-only concept) *@
                            @RenderLastRate(pcGroup.PcId, checkMismatch: false)
                        </div>
                        <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
                            <span class="sa-input-label" style="color:#6b7280;">Set all:</span>
                            @{ var csPcWalletsTop = _pcWallets.GetValueOrDefault(pcGroup.PcId) ?? new(); }
                            @if (csPcWalletsTop.Count > 1)
                            {
                                <select class="form-select form-select-sm" style="width:170px; font-size:.78rem;"
                                        value="@(_csTopWallet.GetValueOrDefault((csGroup.CsId, pcGroup.PcId), pcGroup.Reviews.FirstOrDefault()?.WalletId ?? 0))"
                                        @onchange="e => OnCsTopWalletChanged(csGroup.CsId, pcGroup.PcId, e.Value?.ToString())">
                                    @foreach (var w in csPcWalletsTop)
                                    {
                                        <option value="@w.WalletId">@w.Name (@w.Currency)</option>
                                    }
                                </select>
                            }
                            <div class="input-group input-group-sm sa-rate-input" style="width:140px;">
                                <span class="input-group-text">@PcCurrSym(pcGroup.PcId) CS Sal.</span>
                                <input type="number" class="form-control" placeholder="0" min="0" step="0.01"
                                       value="@csPcDef.ToString(CultureInfo.InvariantCulture)" onfocus="this.select()"
                                       @onchange="e => PropagateCSRate(csGroup.CsId, pcGroup.PcId,
                                           double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var csv) ? csv : csPcDef)" />
                            </div>
                            <button class="btn btn-sm sa-btn-cs-all d-flex align-items-center gap-1"
                                    @onclick="() => SubmitAllCsForPc(csGroup.CsId, pcGroup.PcId)" disabled="@_busy">
                                <i class="ri-check-double-line"></i>@LS.T("common.submitAll") (@csPcTotal)
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 sa-table">
                            <thead>
                                <tr class="sa-cs-thead">
                                    <th class="ps-4">Date</th>
                                    <th>Name</th>
                                    <th style="width:92px;">ID</th>
                                    <th style="width:140px;">CS By</th>
                                    <th class="text-center">Review Duration</th>
                                    <th style="width:140px;">Wallet</th>
                                    @if (pcGroup.Reviews.Any(r => r.IsSolo))
                                    {
                                        <th style="min-width:135px; width:135px;">Rate @PcCurrSym(pcGroup.PcId)/hr</th>
                                    }
                                    <th style="min-width:135px; width:135px;">CS Salary @PcCurrSym(pcGroup.PcId)/hr</th>
                                    <th style="width:105px;">Status</th>
                                    <th class="pe-4" style="width:130px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ bool _hasSoloInGroup = pcGroup.Reviews.Any(r => r.IsSolo); }
                                @foreach (var rev in pcGroup.Reviews)
                                {
                                    bool csApproved = rev.CsStatus == "Approved";
                                    bool rowIsFree  = rev.IsSolo && rev.Notes == "Free";
                                    var csSalary    = _csRowEdits.GetValueOrDefault(rev.CsReviewId);
                                    <tr class="@(csApproved ? "sa-row-approved" : "sa-row-draft")"
                                        @oncontextmenu="e => OpenCtxCs(e, rev.CsReviewId, rowIsFree, rev.IsSolo)"
                                        @oncontextmenu:preventDefault="@rev.IsSolo">
                                        <td class="ps-4 py-2">
                                            <span class="fw-semibold sa-date">@FormatDate(rev.CreatedAt)</span>
                                        </td>
                                        <td class="py-2 sa-sess-name" title="@rev.Name">@rev.Name</td>
                                        <td class="py-2">
                                            <span class="sa-id-sess" title="Session ID">sess #@rev.SessionId</span>
                                        </td>
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @if (_editingCsPersonId == rev.CsReviewId)
                                            {
                                                <select class="form-select form-select-sm sa-row-input"
                                                        value="@rev.CsId"
                                                        @onchange="e => OnCsPersonChanged(rev.CsReviewId, e.Value?.ToString())"
                                                        @onblur="() => _editingCsPersonId = null">
                                                    @foreach (var staff in _csStaffList)
                                                    {
                                                        <option value="@staff.PersonId">@staff.FullName</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <span class="sa-cs-name-editable" @onclick="() => _editingCsPersonId = rev.CsReviewId"
                                                      title="Click to reassign">
                                                    <i class="ri-user-line" style="font-size:.72rem;opacity:.5;"></i>
                                                    @CsStaffName(rev.CsId)
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center py-2">
                                            <span class="badge rounded-pill bg-light border text-dark px-2" style="font-size:0.78rem;">@DashboardService.Fmt(rev.ReviewLengthSeconds)</span>
                                            @if (rev.IsSolo)
                                            {
                                                <span class="ms-1" style="background:linear-gradient(135deg,#7c3aed,#a855f7);color:#fff;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:10px;letter-spacing:.3px;">Solo</span>
                                                @if (rev.Notes == "Free")
                                                {
                                                    <span class="ms-1" style="background:#d1fae5;color:#065f46;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:10px;">Free</span>
                                                }
                                                else if (rev.Notes == "Bill")
                                                {
                                                    <span class="ms-1" style="background:#fee2e2;color:#991b1b;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:10px;">Bill</span>
                                                }
                                            }
                                        </td>
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @{ var csPcWallets = _pcWallets.GetValueOrDefault(pcGroup.PcId) ?? new(); }
                                            @if (csPcWallets.Count <= 1)
                                            {
                                                var cw = csPcWallets.FirstOrDefault(x => x.WalletId == (rev.WalletId ?? 0)) ?? csPcWallets.FirstOrDefault();
                                                if (cw != null)
                                                {
                                                    <span class="badge" style="background:#dbeafe; color:#1e40af; font-size:.72rem;">@cw.Name (@cw.Currency)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">—</span>
                                                }
                                            }
                                            else
                                            {
                                                <select class="form-select form-select-sm sa-row-input"
                                                        style="font-size:.78rem;"
                                                        value="@(rev.WalletId ?? 0)"
                                                        @onchange="e => OnCsReviewWalletChanged(rev.CsReviewId, e.Value?.ToString())">
                                                    @foreach (var cw in csPcWallets)
                                                    {
                                                        <option value="@cw.WalletId">@cw.Name (@cw.Currency)</option>
                                                    }
                                                </select>
                                            }
                                        </td>
                                        @if (_hasSoloInGroup)
                                        {
                                            <td class="py-1" @oncontextmenu:stopPropagation="true">
                                                @if (rev.IsSolo)
                                                {
                                                    @if (rowIsFree)
                                                    {
                                                        <span class="sa-free-badge">FREE — ignored</span>
                                                    }
                                                    else
                                                    {
                                                        <input type="number" class="form-control form-control-sm sa-row-input"
                                                               value="@_csRateEdits.GetValueOrDefault(rev.CsReviewId).ToString(CultureInfo.InvariantCulture)" min="0" step="0.01" onfocus="this.select()"
                                                               @onchange="e => { if (double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var v)) _csRateEdits[rev.CsReviewId] = v; }" />
                                                    }
                                                }
                                            </td>
                                        }
                                        <td class="py-1" @oncontextmenu:stopPropagation="true">
                                            @if (rowIsFree)
                                            {
                                                <span class="sa-free-badge">FREE — @PcCurrSym(pcGroup.PcId)0</span>
                                            }
                                            else
                                            {
                                                <input type="number" class="form-control form-control-sm sa-row-input"
                                                       value="@csSalary.ToString(CultureInfo.InvariantCulture)" min="0" step="0.01" onfocus="this.select()"
                                                       @onchange="e => { if (double.TryParse(e.Value?.ToString(), NumberStyles.Any, CultureInfo.InvariantCulture, out var v)) _csRowEdits[rev.CsReviewId] = v; }" />
                                            }
                                        </td>
                                        <td class="py-2">
                                            @if (csApproved) { <span class="badge sa-badge-status-approved"><i class="ri-check-line me-1"></i>@LS.T("sessions.approvedStatus")</span> }
                                            else             { <span class="badge sa-badge-status-draft">@LS.T("sessions.pendingStatus")</span> }
                                        </td>
                                        <td class="pe-4 py-1">
                                            <div class="d-flex align-items-center gap-1">
                                                <button class="btn btn-sm d-flex align-items-center gap-1 @(csApproved ? "sa-btn-update" : "sa-btn-submit")"
                                                        @onclick="() => SubmitOneCsReview(rev.CsReviewId)" disabled="@_busy">
                                                    <i class="@(csApproved ? "ri-pencil-line" : "ri-check-line")"></i>
                                                    @(csApproved ? LS.T("common.update") : LS.T("common.submit"))
                                                </button>
                                                <button type="button" class="sa-action-btn" title="Edit in Session Manager"
                                                        @onclick="() => OpenInSessionManager(rev.SessionId)">
                                                    <i class="ri-database-2-line"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    }

    @* ── Right-click Free/Bill context menu ── *@
    @if (_ctxOpen)
    {
        <div class="sa-ctx-overlay" @onclick="() => _ctxOpen = false"
             @oncontextmenu="() => _ctxOpen = false" @oncontextmenu:preventDefault="true"></div>
        <div class="sa-ctx-menu" style="@($"top:{(int)_ctxY}px;left:{(int)_ctxX}px;")">
            <button type="button" class="sa-ctx-item" @onclick="ToggleFreeBill">
                <i class="ri-swap-line me-2"></i>@(_ctxIsFree ? "Mark as Billable" : "Mark as Free")
            </button>
        </div>
    }

    @* ── "Last auditing purchase" detail popup ── *@
    @if (_lastPurchaseDetail != null)
    {
        <div class="sa-lp-overlay" @onclick="CloseLastPurchase"></div>
        <div class="sa-lp-card">
            <div class="sa-lp-head">
                <i class="ri-receipt-line me-2"></i>
                <span>Last auditing purchase</span>
                <span class="sa-lp-pcname">— @_lastPurchasePcName</span>
                <button type="button" class="sa-lp-close" @onclick="CloseLastPurchase" title="Close">
                    <i class="ri-close-line"></i>
                </button>
            </div>
            <div class="sa-lp-body">
                <div class="sa-lp-row"><span class="sa-lp-lbl">Date</span><span class="sa-lp-val">@FormatDateShort(_lastPurchaseDetail.PurchaseDate)</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Hours bought</span><span class="sa-lp-val">@_lastPurchaseDetail.Hours.ToString("0.##")</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Amount paid</span><span class="sa-lp-val">@CurrencySymbolFromCode(_lastPurchaseDetail.Currency)@Math.Round(_lastPurchaseDetail.Amount, MidpointRounding.AwayFromZero).ToString("0")</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Rate</span><span class="sa-lp-val sa-lp-rate">@CurrencySymbolFromCode(_lastPurchaseDetail.Currency)@RoundRateCents(_lastPurchaseDetail.RateCentsPerHour)/hr</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Currency</span><span class="sa-lp-val">@_lastPurchaseDetail.Currency</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Wallet</span><span class="sa-lp-val">@(string.IsNullOrEmpty(_lastPurchaseDetail.WalletName) ? "—" : _lastPurchaseDetail.WalletName)</span></div>
                <div class="sa-lp-row"><span class="sa-lp-lbl">Status</span><span class="sa-lp-val">@_lastPurchaseDetail.Status</span></div>
            </div>
        </div>
    }

</div>

@* ── Toast ── *@
@if (!string.IsNullOrEmpty(_msg))
{
    <div class="position-fixed bottom-0 end-0 p-4" style="z-index:1200;">
        <div class="toast show align-items-center border-0 shadow-lg @(_msgIsError ? "text-bg-danger" : "text-bg-success")"
             role="alert" style="min-width:300px;border-radius:12px;">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2 fw-semibold">
                    <i class="@(_msgIsError ? "ri-error-warning-line" : "ri-checkbox-circle-line") fs-5"></i>
                    @_msg
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick='() => _msg = null'></button>
            </div>
        </div>
    </div>
}

<style>
    .sa-page  { max-width: 1200px; }

    /* Collapse headers */
    .sa-collapse-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 10px 16px; border-radius: 10px; cursor: pointer; user-select: none;
        background: linear-gradient(135deg, #1e3a5f 0%, #2d5a8e 100%);
        border: 1px solid #1e3a5f; font-size: 0.9rem; font-weight: 700;
        color: #fff; text-transform: uppercase; letter-spacing: .08em;
        transition: background .2s, box-shadow .2s;
    }
    .sa-collapse-header:hover { background: linear-gradient(135deg, #163050 0%, #24507e 100%); box-shadow: 0 2px 8px rgba(0,0,0,.15); }
    .sa-collapse-header-cs { background: linear-gradient(135deg, #5b21b6 0%, #8b5cf6 100%); border-color: #5b21b6; }
    .sa-collapse-header-cs:hover { background: linear-gradient(135deg, #4c1d95 0%, #7c3aed 100%); }

    /* ── Animated divider between Sessions and CS Reviews sections ── */
    .sa-section-divider {
        display: flex; align-items: center; gap: 12px;
        margin: 36px 0 18px;
        animation: sa-section-divider-in 700ms cubic-bezier(.2,.9,.25,1) both;
    }
    .sa-section-divider-line {
        flex-grow: 1; height: 2px;
        background: linear-gradient(90deg, transparent, #c4b5fd 30%, #8b5cf6 50%, #c4b5fd 70%, transparent);
        background-size: 200% 100%;
        animation: sa-section-divider-shimmer 4s ease-in-out infinite;
    }
    .sa-section-divider-pill {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 8px 18px;
        background: linear-gradient(135deg, #5b21b6, #7c3aed, #a855f7);
        background-size: 200% 200%;
        animation: sa-section-divider-grad 6s ease-in-out infinite,
                   sa-section-divider-pulse 2.4s ease-in-out infinite;
        color: #fff; font-weight: 700; font-size: .82rem;
        letter-spacing: .04em; text-transform: uppercase;
        border-radius: 999px;
        box-shadow: 0 4px 12px rgba(124,58,237,.35),
                    0 0 0 1px rgba(255,255,255,.15) inset,
                    0 0 24px rgba(168,85,247,.4);
        white-space: nowrap;
    }
    .sa-section-divider-text { line-height: 1; }
    .sa-section-divider-icon { font-size: 1rem; }
    .sa-section-divider-arrow {
        font-size: 1.05rem; line-height: 1;
        animation: sa-section-divider-bounce 1.4s ease-in-out infinite;
    }
    .sa-section-divider-arrow:last-child { animation-delay: .2s; }

    @@keyframes sa-section-divider-in {
        from { opacity: 0; transform: translateY(-8px) scale(.96); }
        to   { opacity: 1; transform: translateY(0)    scale(1); }
    }
    @@keyframes sa-section-divider-pulse {
        0%, 100% { box-shadow: 0 4px 12px rgba(124,58,237,.35),
                               0 0 0 1px rgba(255,255,255,.15) inset,
                               0 0 24px rgba(168,85,247,.4); }
        50%      { box-shadow: 0 6px 20px rgba(124,58,237,.5),
                               0 0 0 1px rgba(255,255,255,.25) inset,
                               0 0 36px rgba(168,85,247,.7); }
    }
    @@keyframes sa-section-divider-grad {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
    }
    @@keyframes sa-section-divider-shimmer {
        0%, 100% { background-position: 200% 50%; }
        50%      { background-position: 0%   50%; }
    }
    @@keyframes sa-section-divider-bounce {
        0%, 100% { transform: translateY(0);   opacity: .85; }
        50%      { transform: translateY(3px); opacity: 1;   }
    }

    .sa-chevron { font-size: 1.2rem; transition: transform .25s ease; color: #fff; }
    .sa-chevron-collapsed { transform: rotate(-90deg); }
    .sa-title { color: #fff; }

    /* Section labels */
    .sa-section-label { display: flex; align-items: center; font-size: 0.9rem; font-weight: 700; color: var(--default-text-color); text-transform: uppercase; letter-spacing: .08em; border-bottom: 2px solid #dce3f0; padding-bottom: 8px; }
    .sa-section-label-cs { color: #7cb3f0; border-color: #c7d7f0; }
    .sa-badge-cs-draft { background: #dbeafe; color: #1e40af; }

    /* Empty block */
    .sa-empty-block { text-align: center; padding: 36px; background: #f8faff; border-radius: 12px; border: 1px dashed #c7d7f0; color: #212529; }

    /* Filter card */
    .sa-filter-card { border-radius: 12px; }
    .sa-filter-divider { width: 1px; height: 28px; background: #dee2e6; }

    /* Segmented control */
    .sa-seg { border-radius: 8px; overflow: hidden; border: 1px solid #dee2e6; }
    .sa-seg .btn { border: none; border-radius: 0; font-size: 0.8rem; font-weight: 600; padding: 5px 14px; }
    .sa-seg-active   { background: #1e3a5f !important; color: #fff !important; }
    .sa-seg-inactive { background: #fff !important; color: #6c757d !important; }
    .sa-seg-inactive:hover { background: #f1f3f9 !important; color: #1e3a5f !important; }

    /* Date input / Apply */
    .sa-date-input { font-size: 0.83rem; border-color: #ced4da; color: #212529; background-color: #fff; min-width: 130px; flex: 1 1 130px; max-width: 160px; min-height: 38px; touch-action: manipulation; }
    .sa-date-input:focus { border-color: #2d6a9f; box-shadow: none; }

    @@media (max-width: 480px) {
        .sa-page { padding-left: 10px !important; padding-right: 10px !important; }
        .sa-date-input { max-width: 100%; font-size: 1rem; }
        .sa-filter-card .card-body { padding: 10px 12px !important; }
        .sa-page .table { font-size: 0.78rem; }
    }
    .sa-btn-apply { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.8rem; font-weight: 600; }
    .sa-btn-apply:hover:not(:disabled) { background: #1e3a5f; color: #fff; }

    /* Cards */
    .sa-auditor-card { border-radius: 14px; overflow: hidden; }
    .sa-auditor-card:hover { box-shadow: 0 6px 28px rgba(30,58,95,.13) !important; transition: box-shadow .25s; }
    .sa-auditor-header  { background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%); }
    .sa-cs-card-header  { background: linear-gradient(135deg, #5b21b6 0%, #8b5cf6 100%); }

    /* Avatars */
    .sa-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.3); color: #fff; font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sa-avatar-img { width: 40px; height: 40px; border-radius: 50%; border: 2px solid rgba(255,255,255,.45); object-fit: cover; flex-shrink: 0; }

    /* PC sub-section */
    .sa-pc-divider { height: 7px; background: linear-gradient(90deg, #2d6a9f 0%, #dce3f0 100%); margin: 0; }
    .sa-pc-header  { background: #f4f7fc; color: #212529; min-height: 54px; }
    .sa-pc-dot     { width: 8px; height: 8px; border-radius: 50%; background: #2d6a9f; flex-shrink: 0; }
    .sa-pc-dot-cs  { background: #7c3aed; }
    .sa-pc-name    { font-size: 0.9rem; color: #1e3a5f; }

    /* ── New-PC indicator (auditor has never had an approved session for this PC) ── */
    .sa-pc-dot-new {
        background: #f97316 !important;
        box-shadow: 0 0 0 0 rgba(249,115,22,0.6);
        animation: sa-newpc-dot-pulse 1.6s ease-in-out infinite;
    }
    @@keyframes sa-newpc-dot-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.55); }
        50%      { box-shadow: 0 0 0 6px rgba(249,115,22,0.0); }
    }
    .sa-pc-name-new {
        font-size: 0.92rem;
        font-weight: 700 !important;
        background: linear-gradient(90deg, #c2410c 0%, #ea580c 50%, #f97316 100%);
        -webkit-background-clip: text; background-clip: text; color: transparent;
        animation: sa-newpc-name-shimmer 2.4s ease-in-out infinite;
        background-size: 200% auto;
    }
    @@keyframes sa-newpc-name-shimmer {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
    }
    .sa-pc-new-badge {
        display: inline-flex; align-items: center; gap: 5px;
        margin-inline-start: 4px;
        padding: 3px 10px;
        border-radius: 999px;
        background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 50%, #fed7aa 100%);
        color: #9a3412;
        border: 1.5px solid #f97316;
        font-size: 0.7rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        box-shadow: 0 0 0 0 rgba(249,115,22,0.55);
        animation: sa-newpc-badge-pulse 1.6s ease-in-out infinite;
        white-space: nowrap;
    }
    .sa-pc-new-badge i {
        color: #ea580c;
        font-size: 0.85rem;
        animation: sa-newpc-spark 2s ease-in-out infinite;
    }
    @@keyframes sa-newpc-badge-pulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(249,115,22,0.55), 0 2px 6px -2px rgba(249,115,22,0.4);
            transform: translateY(0) scale(1);
        }
        50%      {
            box-shadow: 0 0 0 8px rgba(249,115,22,0.0), 0 4px 14px -2px rgba(249,115,22,0.55);
            transform: translateY(-1px) scale(1.04);
        }
    }
    @@keyframes sa-newpc-spark {
        0%, 100% { transform: rotate(0deg)   scale(1);   opacity: 1;   }
        25%      { transform: rotate(-15deg) scale(1.18); opacity: 0.85; }
        50%      { transform: rotate(0deg)   scale(1);   opacity: 1;   }
        75%      { transform: rotate(15deg)  scale(1.18); opacity: 0.85; }
    }

    .sa-input-label{ font-size: 0.72rem; white-space: nowrap; }

    /* "Set all" inputs */
    .sa-rate-input .input-group-text { background: #fff; border-color: #ced4da; font-size: 0.75rem; color: #6c757d; white-space: nowrap; }
    .sa-rate-input .form-control { font-size: 0.85rem; border-color: #ced4da; color: #212529; background-color: #fff; }
    .sa-rate-input:focus-within .input-group-text,
    .sa-rate-input:focus-within .form-control { border-color: #2d6a9f; box-shadow: none; }

    /* Row-level inputs */
    .sa-row-input { font-size: 0.83rem; border-color: #dee2e6; border-radius: 6px; padding: 3px 8px; color: #212529; background-color: #fff; }
    .sa-row-input:focus { border-color: #2d6a9f; box-shadow: none; }

    /* Table headers */
    .sa-table { font-size: 0.85rem; }
    .sa-thead tr { background: #eef1f8; color: #212529; }
    .sa-thead th { font-size: 0.69rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #6c757d; padding-top: 7px; padding-bottom: 7px; border-bottom: 1px solid #dce3f0; border-top: none; }
    .sa-cs-thead tr { background: #f5f3ff; color: #212529; }
    .sa-cs-thead th { font-size: 0.69rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #7c3aed; padding-top: 6px; padding-bottom: 6px; border-bottom: 1px solid #e9d5ff; border-top: none; }

    /* Row states */
    .sa-row-draft td     { border-bottom: 1px solid #f0f2f8; transition: background .12s; background: #f8f9fa; color: #212529; }
    .sa-row-draft:hover td  { background: #f5f7ff; }
    .sa-row-approved td  { border-bottom: 1px solid #bbf7d0; background: #f0fdf4; color: #212529; }
    .sa-row-approved:hover td { background: #dcfce7; }
    .sa-date { color: #1e3a5f; }

    /* Badges */
    .sa-badge-pending      { background: #fef3c7; color: #92400e; font-size: 0.68rem; }
    .sa-badge-approved-sm  { background: #d1fae5; color: #065f46; font-size: 0.68rem; }
    .sa-badge-free         { background: #ede9fe; color: #5b21b6; font-size: 0.68rem; }

    /* ── Warning cells (Duration > 3:00, Admin > 0:30) ──
       Big red value with a pulsing aura + animated tooltip on hover. */
    .wr-warn-cell {
        position: relative !important;
        overflow: visible !important;
        cursor: help;
    }
    .wr-warn-value {
        display: inline-block;
        font-size: 1.05rem;
        font-weight: 900;
        color: #fff;
        background: linear-gradient(135deg, #ef4444, #dc2626);
        padding: 5px 12px;
        border-radius: 8px;
        font-variant-numeric: tabular-nums;
        letter-spacing: .02em;
        box-shadow:
            0 2px 6px rgba(220, 38, 38, .35),
            0 0 0 0 rgba(220, 38, 38, .55);
        animation: wrWarnPulse 1.6s ease-in-out infinite;
        transition: transform .18s ease, box-shadow .2s ease;
    }
    @@keyframes wrWarnPulse {
        0%, 100% {
            box-shadow: 0 2px 6px rgba(220, 38, 38, .35),
                        0 0 0 0 rgba(220, 38, 38, .55);
        }
        50% {
            box-shadow: 0 2px 6px rgba(220, 38, 38, .55),
                        0 0 0 10px rgba(220, 38, 38, 0);
        }
    }
    .wr-warn-cell:hover .wr-warn-value {
        transform: scale(1.06);
        box-shadow: 0 4px 14px rgba(220, 38, 38, .55);
        animation-play-state: paused;
    }

    /* Animated tooltip — slides + fades in on hover */
    .wr-warn-tip {
        position: absolute;
        top: calc(100% + 10px);
        left: 50%;
        transform: translate(-50%, -6px) scale(.94);
        z-index: 60;
        width: 280px;
        background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
        color: #fef3c7;
        border: 1px solid rgba(239, 68, 68, .55);
        border-radius: 10px;
        padding: 10px 12px;
        font-size: .78rem;
        line-height: 1.45;
        font-weight: 500;
        text-align: left;
        white-space: normal;
        opacity: 0;
        pointer-events: none;
        box-shadow:
            0 14px 36px rgba(0, 0, 0, .45),
            0 0 24px rgba(239, 68, 68, .25);
        transition: opacity .22s ease, transform .28s cubic-bezier(.175, .885, .32, 1.275);
        cursor: default;
    }
    .wr-warn-tip::before {
        content: '';
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 7px solid transparent;
        border-bottom-color: #1e293b;
        filter: drop-shadow(0 -2px 1px rgba(239, 68, 68, .35));
    }
    .wr-warn-tip strong {
        display: block;
        font-size: .82rem;
        color: #fbbf24;
        font-weight: 800;
        letter-spacing: .02em;
        margin-bottom: 4px;
        text-shadow: 0 0 8px rgba(251, 191, 36, .35);
    }
    .wr-warn-tip span {
        display: block;
        color: #e2e8f0;
        font-weight: 400;
    }
    .wr-warn-tip code {
        background: rgba(239, 68, 68, .18);
        color: #fecaca;
        padding: 1px 6px;
        border-radius: 4px;
        font-family: ui-monospace, monospace;
        font-weight: 700;
    }
    .wr-warn-cell:hover .wr-warn-tip,
    .wr-warn-cell:focus-within .wr-warn-tip {
        opacity: 1;
        transform: translate(-50%, 0) scale(1);
        pointer-events: auto;
    }
    .sa-badge-status-draft    { background: #fef3c7; color: #92400e; font-size: 0.73rem; }
    .sa-badge-status-approved { background: #d1fae5; color: #065f46; font-size: 0.73rem; }

    /* Action buttons */
    .sa-btn-approve-all { background: rgba(255,255,255,.92); color: #1e3a5f; border: 1px solid rgba(45,106,159,.4); font-size: 0.78rem; border-radius: 7px; font-weight: 600; }
    .sa-btn-approve-all:hover:not(:disabled) { background: #fff; border-color: #2d6a9f; }
    .sa-btn-submit { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.78rem; padding: 3px 10px; font-weight: 600; }
    .sa-btn-submit:hover:not(:disabled) { background: #1e3a5f; color: #fff; }
    .sa-btn-update { background: transparent; color: #2d6a9f; border: 1px solid #2d6a9f; border-radius: 7px; font-size: 0.78rem; padding: 3px 10px; font-weight: 600; }
    .sa-btn-update:hover:not(:disabled) { background: #2d6a9f; color: #fff; }
    .sa-btn-cs-all { background: #4a7fc1; color: #fff; border: none; border-radius: 7px; font-size: 0.75rem; font-weight: 600; }
    .sa-btn-cs-all:hover:not(:disabled) { background: #1e3a5f; color: #fff; }

    /* Editable date — subtle hover cue */
    .sa-date-editable { cursor: pointer; border-bottom: 1px dashed transparent; transition: border-color .15s; }
    .sa-date-editable:hover { border-bottom-color: #2d6a9f; }

    /* Editable CS name — subtle hover cue */
    .sa-cs-name-editable { cursor: pointer; font-size: 0.8rem; color: #1e3a5f; border-bottom: 1px dashed transparent; transition: border-color .15s; display: inline-flex; align-items: center; gap: 4px; }
    .sa-cs-name-editable:hover { border-bottom-color: #4a7fc1; }

    /* Spinner */
    .sa-spin { display: inline-block; animation: sa-spin-anim 1s linear infinite; }
    @@keyframes sa-spin-anim { to { transform: rotate(360deg); } }

    /* Free solo CS badge */
    .sa-free-badge {
        display: inline-block;
        font-size: .68rem; font-weight: 700; letter-spacing: .03em;
        color: #dc2626; background: #fef2f2;
        border: 1px solid #fca5a5; border-radius: 6px;
        padding: 2px 8px; white-space: nowrap;
        animation: sa-free-pulse 1.5s ease-in-out infinite;
    }
    @@keyframes sa-free-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(220,38,38,.3); }
        50%      { box-shadow: 0 0 0 4px rgba(220,38,38,.15); }
    }

    /* ── Quick-jump nav bar ── Excel-freeze style: always pinned below the app header */
    .sa-quick-nav {
        position: fixed;
        top: 4.25rem;                /* matches .app-header height */
        left: 0; right: 0;           /* mobile default — full width */
        z-index: 99;                 /* below app-header (z-index:100), above cards */
        display: flex; align-items: center;
        background: rgba(255,255,255,.97);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid rgba(148,163,184,.25);
        padding: 8px 18px;
        box-shadow: 0 6px 14px rgba(15,23,42,.08);
    }
    /* Desktop: sidebar is 15rem wide — inset the bar so chips aren't covered */
    @@media (min-width: 992px) {
        .sa-quick-nav { left: 15rem; }
    }
    .sa-quick-nav-spacer {
        height: 60px;                /* matches bar height — pushes user cards loop below the bar */
        margin: 6px 0 4px;
    }
    /* Pushes the page header DOWN by the bar's height when the bar is rendered.
       Without this, the fixed bar at top:4.25rem overlays the page title + filter row. */
    .sa-page-bar-offset {
        height: 80px;
    }
    .sa-quick-nav-strip {
        flex: 1 1 auto;
        display: flex; align-items: center; gap: 6px;
        overflow-x: auto; overflow-y: visible;
        scrollbar-width: thin;
        padding: 2px 2px 6px;
        min-height: 44px;
    }
    .sa-quick-nav-strip::-webkit-scrollbar { height: 6px; }
    .sa-quick-nav-strip::-webkit-scrollbar-thumb { background: rgba(100,116,139,.35); border-radius: 3px; }
    .sa-quick-nav-label {
        flex: 0 0 auto;
        width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 8px;
        color: #fff; font-size: 1rem;
    }
    .sa-quick-nav-label-aud { background: linear-gradient(135deg,#1e40af,#3b82f6); }
    .sa-quick-nav-label-cs  { background: linear-gradient(135deg,#3730a3,#6366f1); }
    .sa-quick-nav-divider {
        flex: 0 0 auto;
        width: 1px; height: 24px;
        background: rgba(148,163,184,.4);
        margin: 0 4px;
    }
    .sa-quick-nav-chip {
        flex: 0 0 auto;
        display: inline-flex; align-items: center; gap: 6px;
        padding: 6px 10px;
        border: 1px solid rgba(148,163,184,.35);
        background: #f8fafc;
        border-radius: 999px;
        font-size: .78rem; font-weight: 600; color: #334155;
        cursor: pointer;
        white-space: nowrap;
        transition: transform .12s ease, box-shadow .15s ease, border-color .15s ease, background .15s ease;
        min-height: 34px;
    }
    .sa-quick-nav-chip:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(59,130,246,.18);
    }
    .sa-quick-nav-chip-aud:hover { border-color: #3b82f6; background: #eff6ff; color: #1d4ed8; }
    .sa-quick-nav-chip-cs:hover  { border-color: #6366f1; background: #eef2ff; color: #3730a3; }
    .sa-quick-nav-chip:active { transform: translateY(0); }
    .sa-quick-nav-chip-aud.sa-quick-nav-chip-active {
        border-color: #2563eb;
        background: linear-gradient(135deg, #dbeafe, #bfdbfe);
        color: #1e3a8a;
        box-shadow: 0 0 0 3px rgba(37,99,235,.25), 0 4px 10px rgba(37,99,235,.2);
        transform: translateY(-1px);
    }
    .sa-quick-nav-chip-aud.sa-quick-nav-chip-active .sa-quick-nav-avatar-aud {
        background: linear-gradient(135deg,#2563eb,#1d4ed8);
    }
    .sa-quick-nav-chip-cs.sa-quick-nav-chip-active {
        border-color: #4f46e5;
        background: linear-gradient(135deg, #e0e7ff, #c7d2fe);
        color: #312e81;
        box-shadow: 0 0 0 3px rgba(79,70,229,.25), 0 4px 10px rgba(79,70,229,.2);
        transform: translateY(-1px);
    }
    .sa-quick-nav-chip-cs.sa-quick-nav-chip-active .sa-quick-nav-avatar-cs {
        background: linear-gradient(135deg,#4f46e5,#4338ca);
    }
    .sa-quick-nav-avatar {
        width: 22px; height: 22px; border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        color: #fff; font-size: .7rem; font-weight: 700;
        flex: 0 0 auto;
    }
    .sa-quick-nav-avatar-aud { background: linear-gradient(135deg,#1e40af,#3b82f6); }
    .sa-quick-nav-avatar-cs  { background: linear-gradient(135deg,#3730a3,#6366f1); }
    .sa-quick-nav-name { letter-spacing: .1px; }

    /* Highlight flash when jumping to a card */
    @@keyframes sa-highlight-flash {
        0%   { box-shadow: 0 0 0 0 rgba(59,130,246,.55); }
        60%  { box-shadow: 0 0 0 6px rgba(59,130,246,.25); }
        100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
    }
    .sa-auditor-card.sa-flash { animation: sa-highlight-flash 1.6s ease; }

    /* ── Session ID chip / Name cell / Edit icon / Context menu ── */
    .sa-id-sess {
        display: inline-block;
        background: #f1f5f9; color: #64748b;
        padding: 1px 6px; border-radius: 4px;
        font-size: .68rem; font-weight: 600;
        font-variant-numeric: tabular-nums; letter-spacing: .2px;
        white-space: nowrap;
    }
    .sa-sess-name {
        font-size: .82rem; color: #334155;
        max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sa-action-btn {
        background: rgba(249,115,22,.1);
        border: 1px solid rgba(249,115,22,.25);
        color: #ea580c;
        border-radius: 6px;
        width: 28px; height: 28px;
        display: inline-flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: .95rem;
        transition: background .12s, transform .12s, box-shadow .12s;
    }
    .sa-action-btn:hover {
        background: #f97316; color: #fff;
        transform: translateY(-1px);
        box-shadow: 0 3px 8px rgba(249,115,22,.3);
    }
    .sa-action-btn:active { transform: translateY(0); }

    .sa-ctx-overlay { position: fixed; inset: 0; z-index: 1040; background: transparent; }
    .sa-ctx-menu {
        position: fixed; z-index: 1041;
        background: #fff;
        border: 1px solid rgba(100,116,139,.25);
        border-radius: 8px;
        box-shadow: 0 8px 22px rgba(15,23,42,.18);
        padding: 4px; min-width: 180px;
    }
    .sa-ctx-item {
        display: flex; align-items: center;
        width: 100%; padding: 8px 12px;
        background: transparent; border: 0;
        font-size: .85rem; color: #1e293b;
        border-radius: 6px; cursor: pointer;
        text-align: left; min-height: 36px;
    }
    .sa-ctx-item:hover { background: #f1f5f9; color: #0f172a; }

    @@media (max-width: 991.98px) {
        .sa-quick-nav         { padding: 6px 10px; }
        .sa-quick-nav-spacer  { height: 56px; }
    }
    @@media (max-width: 480px) {
        .sa-quick-nav-chip    { font-size: .78rem; padding: 10px 12px; min-height: 44px; }
    }

    /* ── Last-rate inline label under PC name ── */
    .sa-pc-rate-line {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.95rem; color: #6b7280; line-height: 1.25;
        white-space: nowrap;
    }
    .sa-pc-rate-line .sa-pc-rate-val { font-weight: 700; color: #1e3a5f; font-size: 1rem; }
    .sa-pc-rate-btn {
        display: inline-flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; padding: 0;
        background: transparent; border: 1px solid transparent; border-radius: 6px;
