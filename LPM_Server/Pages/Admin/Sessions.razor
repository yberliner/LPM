    // ── Quick-jump navigation ─────────────────────────────────────
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender)
            {
                // Inline <script> in a .razor file doesn't re-execute on client-side
                // navigation — define the helper via eval on first render instead.
                await JS.InvokeVoidAsync("eval", @"
                    window.lpmSessionsJumpTo = function(id) {
                        var el = document.getElementById(id);
                        if (!el) return;
                        var rect = el.getBoundingClientRect();
                        var targetY = rect.top + window.scrollY - 140;
                        window.scrollTo({ top: Math.max(0, targetY), behavior: 'smooth' });
                        el.classList.remove('sa-flash');
                        void el.offsetWidth;
                        el.classList.add('sa-flash');
                        setTimeout(function(){ el.classList.remove('sa-flash'); }, 1700);
                    };
                    window.lpmSessionsScrollSpy = function(cardIds) {
                        if (window.__lpmSessObserver) {
                            try { window.__lpmSessObserver.disconnect(); } catch(e) {}
                        }
                        if (!cardIds || cardIds.length === 0) return;
                        var chips = document.querySelectorAll('.sa-quick-nav-chip[data-target]');
                        var obs = new IntersectionObserver(function(entries) {
                            var crossed = entries.filter(function(e){ return e.isIntersecting; });
                            if (crossed.length === 0) return;
                            crossed.sort(function(a,b){ return a.boundingClientRect.top - b.boundingClientRect.top; });
                            var activeId = crossed[0].target.id;
                            chips.forEach(function(ch){
                                if (ch.getAttribute('data-target') === activeId)
                                    ch.classList.add('sa-quick-nav-chip-active');
                                else
                                    ch.classList.remove('sa-quick-nav-chip-active');
                            });
                        }, {
                            rootMargin: '-140px 0px -70% 0px',
                            threshold: 0
                        });
                        cardIds.forEach(function(id){
                            var el = document.getElementById(id);
                            if (el) obs.observe(el);
                        });
                        window.__lpmSessObserver = obs;
                    };
                ");
            }
            if (!_loading && (_groups.Count + _csGroups.Count) > 1)
            {
                var ids = _groups.Select(g => $"sa-aud-{g.AuditorId}")
                                 .Concat(_csGroups.Select(c => $"sa-cs-{c.CsId}"))
                                 .ToArray();
                await JS.InvokeVoidAsync("lpmSessionsScrollSpy", (object)ids);
            }
        }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException)   { }
    }

    private async Task JumpToAuditor(int auditorId)
    {
        _sessCollapsed = false;
        StateHasChanged();
        await Task.Yield();
        try { await JS.InvokeVoidAsync("lpmSessionsJumpTo", $"sa-aud-{auditorId}"); }
        catch (JSDisconnectedException) { }
        catch (TaskCanceledException)   { }
    }

