        padding: 2px 8px; white-space: nowrap;
        animation: sa-free-pulse 1.5s ease-in-out infinite;
    }
    @@keyframes sa-free-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(220,38,38,.3); }
        50%      { box-shadow: 0 0 0 4px rgba(220,38,38,.15); }
    }
</style>

@code {
    // ── Filter state ──────────────────────────────────────────────
    private bool    _includeApproved = false;
    private string  _fromDateStr = "";
    private string  _toDateStr   = "";
    private string? _filterError;

    // ── Sessions data ─────────────────────────────────────────────
    private List<AuditorSessionGroup>              _groups      = new();
    private Dictionary<(int aud, int pc), PcDefaults> _pcDefaults  = new();
    private Dictionary<int, RowEdit>               _rowEdits    = new();
    private Dictionary<int, string?>               _auditorAvatars = new();
    private Dictionary<int, List<LPM.Services.Wallet>> _pcWallets = new();
    // Top-row "apply to all" wallet selection per (auditor, PC) group
    private Dictionary<(int aud, int pc), int> _pcTopWallet   = new();
    // Top-row wallet selection per (CS, PC) group
    private Dictionary<(int cs,  int pc), int> _csTopWallet   = new();

    string PcWalletCurrency(int pcId)
    {
        // If any top-row selection exists for this PC, use that wallet's currency
        foreach (var kv in _pcTopWallet)
            if (kv.Key.pc == pcId)
            {
                var w = _pcWallets.GetValueOrDefault(pcId)?.FirstOrDefault(x => x.WalletId == kv.Value);
                if (w != null) return w.Currency;
            }
        foreach (var kv in _csTopWallet)
            if (kv.Key.pc == pcId)
            {
                var w = _pcWallets.GetValueOrDefault(pcId)?.FirstOrDefault(x => x.WalletId == kv.Value);
                if (w != null) return w.Currency;
            }
        return _pcCurrency.GetValueOrDefault(pcId, "ILS");
    }

    void OnTopWalletChanged(int auditorId, int pcId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        // No-op if already set to the same wallet (prevents spurious propagation on initial render)
        if (_pcTopWallet.TryGetValue((auditorId, pcId), out var existing) && existing == wid) return;
        _pcTopWallet[(auditorId, pcId)] = wid;
        // Apply to every session in this (auditor, PC) group — only update sessions that differ
        var audGroup = _groups.FirstOrDefault(g => g.AuditorId == auditorId);
        var pcGroup  = audGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup == null) return;
        for (int i = 0; i < pcGroup.Sessions.Count; i++)
        {
            var s = pcGroup.Sessions[i];
            if (s.WalletId == wid) continue;
            WalletSvc.SetSessionWallet(s.SessionId, wid);
            pcGroup.Sessions[i] = s with { WalletId = wid };
        }
    }

    void OnCsTopWalletChanged(int csId, int pcId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        if (_csTopWallet.TryGetValue((csId, pcId), out var existing) && existing == wid) return;
        _csTopWallet[(csId, pcId)] = wid;
        var csGroup = _csGroups.FirstOrDefault(g => g.CsId == csId);
        var pcGroup = csGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup == null) return;
        for (int i = 0; i < pcGroup.Reviews.Count; i++)
        {
            var rev = pcGroup.Reviews[i];
            if (rev.WalletId == wid) continue;
            WalletSvc.SetCsReviewWallet(rev.CsReviewId, wid);
            pcGroup.Reviews[i] = rev with { WalletId = wid };
        }
    }

    void OnSessionWalletChanged(int sessionId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        WalletSvc.SetSessionWallet(sessionId, wid);
        // Update local model so the dropdown reflects the new state
        foreach (var g in _groups)
        foreach (var pg in g.PcGroups)
        {
            var idx = pg.Sessions.FindIndex(s => s.SessionId == sessionId);
            if (idx >= 0)
            {
                pg.Sessions[idx] = pg.Sessions[idx] with { WalletId = wid };
                return;
            }
        }
    }

    void OnCsReviewWalletChanged(int csReviewId, string? val)
    {
        if (!int.TryParse(val, out var wid) || wid <= 0) return;
        WalletSvc.SetCsReviewWallet(csReviewId, wid);
        foreach (var g in _csGroups)
        foreach (var pg in g.PcGroups)
        {
            var idx = pg.Reviews.FindIndex(r => r.CsReviewId == csReviewId);
            if (idx >= 0)
            {
                pg.Reviews[idx] = pg.Reviews[idx] with { WalletId = wid };
                return;
            }
        }
    }

    // ── CS data ───────────────────────────────────────────────────
    private List<CsReviewerGroup>                  _csGroups    = new();
    private Dictionary<(int cs, int pc), double>    _csPcDefaults = new();   // default CS salary per CS+PC
    private Dictionary<int, double>                _csRowEdits  = new();    // CsReviewId → salary
    private Dictionary<int, double>                _csRateEdits = new();    // CsReviewId → charged rate (₪/hr, solo only)
    private Dictionary<int, string?>               _csAvatars   = new();

    // ── CS staff for reassignment ────────────────────────────────
    private List<(int PersonId, string FullName)> _csStaffList = new();

    // ── Inline editing state ──────────────────────────────────────
    private int? _editingSessionDateId;   // SessionId being date-edited
    private int? _editingCsDateId;        // CsReviewId being date-edited
    private int? _editingCsPersonId;      // CsReviewId being reassigned

    // ── UI state ──────────────────────────────────────────────────
    private bool _loading = true;
    private bool _busy;
    private string? _msg;
    private bool _msgIsError;
    private bool _sessCollapsed = false;
    private bool _csCollapsed   = false;
    private string _username = "";
    private int    _userId   = 0;

    private int _sessDraft    => _groups.Sum(g => g.PcGroups.Sum(pg => pg.Sessions.Count(s => s.VerifiedStatus != "Approved")));
    private int _sessApproved => _groups.Sum(g => g.PcGroups.Sum(pg => pg.Sessions.Count(s => s.VerifiedStatus == "Approved")));
    private int _csNotDone => _csGroups.Sum(g => g.PcGroups.Sum(pg => pg.Reviews.Count(r => r.CsStatus != "Approved")));
    private int _csDone    => _csGroups.Sum(g => g.PcGroups.Sum(pg => pg.Reviews.Count(r => r.CsStatus == "Approved")));

    class PcDefaults { public double ChargeRate { get; set; } public double Salary { get; set; } }
    class RowEdit     { public double ChargeRate { get; set; } public double Salary { get; set; } }

    private Dictionary<int, string> _pcCurrency = new(); // PcId → currency code
    static string CurrSym(string code) => code switch { "USD" => "$", "EUR" => "€", _ => "₪" };
    string PcCurrSym(int pcId) => CurrSym(PcWalletCurrency(pcId));

    // ── Lifecycle ─────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }
        _username = authState.User.Identity?.Name ?? "";
        _userId   = DashSvc.GetUserIdByUsername(_username) ?? 0;
        _csStaffList = DashSvc.GetCsStaffList(0);
        await LoadData();
    }

    // ── Filter actions ────────────────────────────────────────────
    private async Task SwitchToDraftOnly()
    {
        _includeApproved = false;
        _filterError = null;
        await LoadData();
    }

    private void SwitchToIncludeApproved()
    {
        if (_includeApproved) return;
        _includeApproved = true;
        if (string.IsNullOrEmpty(_fromDateStr))
            _fromDateStr = DateOnly.FromDateTime(DateTime.Today.AddDays(-28)).ToString("yyyy-MM-dd");
        if (string.IsNullOrEmpty(_toDateStr))
            _toDateStr = DateOnly.FromDateTime(DateTime.Today).ToString("yyyy-MM-dd");
    }

    private async Task ApplyApprovedFilter()
    {
        _filterError = null;
        if (!DateOnly.TryParse(_fromDateStr, out var from)) { _filterError = "Enter a valid From date."; return; }
        if (!DateOnly.TryParse(_toDateStr,   out var to))   { _filterError = "Enter a valid To date."; return; }
        if (from > to) { _filterError = "From date must be on or before To date."; return; }
        await LoadData();
    }

    // ── Data load ─────────────────────────────────────────────────
    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        await Task.Yield();

        DateOnly? from = null, to = null;
        if (_includeApproved && DateOnly.TryParse(_fromDateStr, out var f)) from = f;
        if (_includeApproved && DateOnly.TryParse(_toDateStr,   out var t)) to   = t;

        // ── Sessions ──
        _groups = DashSvc.GetSessionsGroupedByAuditorAndPc(_includeApproved, from, to);
        _pcDefaults.Clear();
        _rowEdits.Clear();
        _auditorAvatars.Clear();
        _pcCurrency.Clear();
        _pcWallets.Clear();
        _pcTopWallet.Clear();
        _csTopWallet.Clear();

        foreach (var group in _groups)
        {
            if (!_auditorAvatars.ContainsKey(group.AuditorId))
                _auditorAvatars[group.AuditorId] = UserDb.GetAvatarPath(group.AuditorName.Split(' ')[0].ToLower());

            foreach (var pcGroup in group.PcGroups)
            {
                if (!_pcCurrency.ContainsKey(pcGroup.PcId))
                    _pcCurrency[pcGroup.PcId] = DashSvc.GetLastPurchaseCurrency(pcGroup.PcId);
                if (!_pcWallets.ContainsKey(pcGroup.PcId))
                    _pcWallets[pcGroup.PcId] = WalletSvc.GetWalletsForPc(pcGroup.PcId, includeInactive: true);
                // Seed the top-row wallet selection from the current session wallet so currency icons
                // reflect the default without requiring an explicit admin pick.
                var seedWallet = pcGroup.Sessions.FirstOrDefault(s => s.WalletId.HasValue)?.WalletId
                               ?? _pcWallets[pcGroup.PcId].FirstOrDefault(w => w.IsActive)?.WalletId
                               ?? 0;
                if (seedWallet > 0)
                    _pcTopWallet[(group.AuditorId, pcGroup.PcId)] = seedWallet;
                var key = (group.AuditorId, pcGroup.PcId);
                var (defRate, defSalary) = DashSvc.GetLastApprovedDefaultsForPc(group.AuditorId, pcGroup.PcId);
                _pcDefaults[key] = new PcDefaults { ChargeRate = defRate / 100.0, Salary = defSalary / 100.0 };
                foreach (var s in pcGroup.Sessions)
                    _rowEdits[s.SessionId] = new RowEdit
                    {
                        ChargeRate = s.ChargedRateCentsPerHour  > 0 ? s.ChargedRateCentsPerHour  / 100.0 : defRate   / 100.0,
                        Salary     = s.AuditorSalaryCentsPerHour > 0 ? s.AuditorSalaryCentsPerHour / 100.0 : defSalary / 100.0
                    };
            }
        }

        // ── CS Reviews ──
        _csGroups = DashSvc.GetCsReviewsGroupedByCsAndPc(_includeApproved, from, to);
        _csPcDefaults.Clear();
        _csRowEdits.Clear();
        _csRateEdits.Clear();
        _csAvatars.Clear();

        foreach (var csGroup in _csGroups)
        {
            if (!_csAvatars.ContainsKey(csGroup.CsId))
                _csAvatars[csGroup.CsId] = UserDb.GetAvatarPath(csGroup.CsName.Split(' ')[0].ToLower());

            foreach (var pcGroup in csGroup.PcGroups)
            {
                if (!_pcCurrency.ContainsKey(pcGroup.PcId))
                    _pcCurrency[pcGroup.PcId] = DashSvc.GetLastPurchaseCurrency(pcGroup.PcId);
                if (!_pcWallets.ContainsKey(pcGroup.PcId))
                    _pcWallets[pcGroup.PcId] = WalletSvc.GetWalletsForPc(pcGroup.PcId, includeInactive: true);
                var csSeedWallet = pcGroup.Reviews.FirstOrDefault(r => r.WalletId.HasValue)?.WalletId
                                 ?? _pcWallets[pcGroup.PcId].FirstOrDefault(w => w.IsActive)?.WalletId
                                 ?? 0;
                if (csSeedWallet > 0)
                    _csTopWallet[(csGroup.CsId, pcGroup.PcId)] = csSeedWallet;
                var key = (csGroup.CsId, pcGroup.PcId);
                var defCsSalary = DashSvc.GetLastApprovedCsSalaryForPc(pcGroup.PcId);
                _csPcDefaults[key] = defCsSalary / 100.0;
                var defSoloRate = DashSvc.GetLastSoloCsRateForPc(pcGroup.PcId);
                foreach (var rev in pcGroup.Reviews)
                {
                    _csRowEdits[rev.CsReviewId] = rev.CsSalaryCentsPerHour > 0
                        ? rev.CsSalaryCentsPerHour / 100.0
                        : defCsSalary / 100.0;
                    if (rev.IsSolo)
                        _csRateEdits[rev.CsReviewId] = rev.ChargedCentsRatePerHour > 0
                            ? rev.ChargedCentsRatePerHour / 100.0
                            : defSoloRate / 100.0;
                }
            }
        }

        _loading = false;
    }

    // ── Session rate propagation (draft sessions only) ────────────
    private void PropagateRate(int auditorId, int pcId, double newRate, double newSalary)
    {
        var key = (auditorId, pcId);
        if (_pcDefaults.TryGetValue(key, out var pcDef)) { pcDef.ChargeRate = newRate; pcDef.Salary = newSalary; }
        var pcGroup = _groups.FirstOrDefault(g => g.AuditorId == auditorId)
                             ?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup is null) return;
        foreach (var s in pcGroup.Sessions)
        {
            if (s.VerifiedStatus == "Approved") continue;
            if (_rowEdits.TryGetValue(s.SessionId, out var edit)) { edit.ChargeRate = newRate; edit.Salary = newSalary; }
        }
    }

    // ── CS salary propagation (draft CS reviews only) ─────────────
    private void PropagateCSRate(int csId, int pcId, double newCsSalary)
    {
        _csPcDefaults[(csId, pcId)] = newCsSalary;
        var pcGroup = _csGroups.FirstOrDefault(g => g.CsId == csId)
                               ?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup is null) return;
        foreach (var rev in pcGroup.Reviews)
            if (rev.CsStatus != "Approved") _csRowEdits[rev.CsReviewId] = newCsSalary;
    }

    // ── Session submit ─────────────────────────────────────────────
    private void SubmitOne(int sessionId)
    {
        if (!_rowEdits.TryGetValue(sessionId, out var edit)) return;
        var s = _groups.SelectMany(g => g.PcGroups).SelectMany(p => p.Sessions)
                       .FirstOrDefault(x => x.SessionId == sessionId);
        Console.WriteLine($"[Sessions] Approved session {sessionId} — PC='{s?.PcName}' auditor='{s?.AuditorName}' date={s?.SessionDate} rate=₪{edit.ChargeRate}/hr auditorSalary=₪{edit.Salary}/hr by '{_username}'");
        _busy = true;
        int rateCents = (int)Math.Round(edit.ChargeRate * 100);
        int salCents  = (int)Math.Round(edit.Salary * 100);
        DashSvc.ApproveSession(sessionId, rateCents, salCents, _userId);
        _busy = false;
        ApplySessionApprovalInMemory(sessionId, rateCents, salCents);
        ShowMsg("Session saved.", false);
    }

    private void SubmitAllForPc(int auditorId, int pcId)
    {
        var audGroup = _groups.FirstOrDefault(g => g.AuditorId == auditorId);
        var pcGroup  = audGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup is null) return;

        // Force-update all row text boxes to match "Set all" defaults
        var defKey = (auditorId, pcId);
        if (_pcDefaults.TryGetValue(defKey, out var def))
        {
            foreach (var s in pcGroup.Sessions)
                if (_rowEdits.TryGetValue(s.SessionId, out var ed))
                    { ed.ChargeRate = def.ChargeRate; ed.Salary = def.Salary; }
        }

        Console.WriteLine($"[Sessions] Approve ALL sessions — auditor='{audGroup?.AuditorName}' (id={auditorId}) PC='{pcGroup.PcName}' (id={pcId}) by '{_username}'");
        _busy = true;
        int count = 0;
        string pcName = pcGroup.PcName;
        foreach (var s in pcGroup.Sessions.ToList())
        {
            if (!_rowEdits.TryGetValue(s.SessionId, out var edit)) continue;
            int rateCents = (int)Math.Round(edit.ChargeRate * 100);
            int salCents  = (int)Math.Round(edit.Salary * 100);
            Console.WriteLine($"[Sessions]   → session {s.SessionId} date={s.SessionDate} rate=₪{edit.ChargeRate}/hr auditorSalary=₪{edit.Salary}/hr");
            DashSvc.ApproveSession(s.SessionId, rateCents, salCents, _userId);
            ApplySessionApprovalInMemory(s.SessionId, rateCents, salCents);
            count++;
        }
        _busy = false;
        ShowMsg($"{count} session{(count != 1 ? "s" : "")} saved for {pcName}.", false);
    }

    // ── CS review submit ───────────────────────────────────────────
    private void SubmitOneCsReview(int csReviewId)
    {
        if (!_csRowEdits.TryGetValue(csReviewId, out var salary)) return;
        var rev = _csGroups.SelectMany(g => g.PcGroups).SelectMany(p => p.Reviews)
                           .FirstOrDefault(r => r.CsReviewId == csReviewId);
        int salaryCents = (int)Math.Round(salary * 100);
        int chargedRate = (int)Math.Round(_csRateEdits.GetValueOrDefault(csReviewId) * 100);
        Console.WriteLine($"[Sessions] Approved CS review {csReviewId} — PC='{rev?.PcName}' CS='{rev?.CsName}' sessionDate={rev?.SessionDate} csSalary=₪{salary}/hr chargedRate={chargedRate} by '{_username}'");
        _busy = true;
        DashSvc.ApproveCsReview(csReviewId, salaryCents, chargedRate);
        _busy = false;
        ApplyCsApprovalInMemory(csReviewId, salaryCents);
        ShowMsg("CS review saved.", false);
    }

    private void SubmitAllCsForPc(int csId, int pcId)
    {
        var csGroup = _csGroups.FirstOrDefault(g => g.CsId == csId);
        var pcGroup = csGroup?.PcGroups.FirstOrDefault(p => p.PcId == pcId);
        if (pcGroup is null) return;

        // Force-update all row text boxes to match "Set all" defaults
        var defKey = (csId, pcId);
        var defSal = _csPcDefaults.GetValueOrDefault(defKey);
        foreach (var rev in pcGroup.Reviews)
            _csRowEdits[rev.CsReviewId] = defSal;

        Console.WriteLine($"[Sessions] Approve ALL CS reviews — CS='{csGroup?.CsName}' (id={csId}) PC='{pcGroup.PcName}' (id={pcId}) by '{_username}'");
        _busy = true;
        int count = 0;
        string pcName = pcGroup.PcName;
        foreach (var rev in pcGroup.Reviews.ToList())
        {
            if (!_csRowEdits.TryGetValue(rev.CsReviewId, out var salary)) continue;
            int salaryCents = (int)Math.Round(salary * 100);
            int chargedRate = (int)Math.Round(_csRateEdits.GetValueOrDefault(rev.CsReviewId) * 100);
            Console.WriteLine($"[Sessions]   → CS review {rev.CsReviewId} sessionId={rev.SessionId} date={rev.SessionDate} csSalary=₪{salary}/hr chargedRate={chargedRate}");
            DashSvc.ApproveCsReview(rev.CsReviewId, salaryCents, chargedRate);
            ApplyCsApprovalInMemory(rev.CsReviewId, salaryCents);
            count++;
        }
        _busy = false;
        ShowMsg($"{count} CS review{(count != 1 ? "s" : "")} saved for {pcName}.", false);
    }

    // ── In-memory update helpers ───────────────────────────────────
    private void ApplySessionApprovalInMemory(int sessionId, int chargeRateCents, int salaryCents)
    {
        foreach (var group in _groups)
        {
            foreach (var pcGroup in group.PcGroups)
            {
                var idx = pcGroup.Sessions.FindIndex(s => s.SessionId == sessionId);
                if (idx < 0) continue;
                if (_includeApproved)
                    pcGroup.Sessions[idx] = pcGroup.Sessions[idx] with
                    {
                        VerifiedStatus           = "Approved",
                        ChargedRateCentsPerHour  = chargeRateCents,
                        AuditorSalaryCentsPerHour = salaryCents
                    };
                else
                    pcGroup.Sessions.RemoveAt(idx);
                goto done;
            }
        }
        done:
        if (!_includeApproved) PruneEmptySessionGroups();
    }

    private void ApplyCsApprovalInMemory(int csReviewId, int salaryCents)
    {
        foreach (var csGroup in _csGroups)
        {
            foreach (var pcGroup in csGroup.PcGroups)
            {
                var idx = pcGroup.Reviews.FindIndex(r => r.CsReviewId == csReviewId);
                if (idx < 0) continue;
                if (_includeApproved)
                    pcGroup.Reviews[idx] = pcGroup.Reviews[idx] with
                    {
                        CsStatus             = "Approved",
                        CsSalaryCentsPerHour = salaryCents
                    };
                else
                    pcGroup.Reviews.RemoveAt(idx);
                goto done;
            }
        }
        done:
        if (!_includeApproved) PruneEmptyCsGroups();
    }

    private void PruneEmptySessionGroups()
    {
        foreach (var g in _groups) g.PcGroups.RemoveAll(pg => pg.Sessions.Count == 0);
        _groups.RemoveAll(g => g.PcGroups.Count == 0);
    }

    private void PruneEmptyCsGroups()
    {
        foreach (var g in _csGroups) g.PcGroups.RemoveAll(pg => pg.Reviews.Count == 0);
        _csGroups.RemoveAll(g => g.PcGroups.Count == 0);
    }

    private void ShowMsg(string msg, bool isError) { _msg = msg; _msgIsError = isError; }

    private static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;

    private string CsStaffName(int csId) =>
        _csStaffList.FirstOrDefault(s => s.PersonId == csId).FullName ?? $"ID {csId}";

    // ── Inline edit: session date ─────────────────────────────────
    private async Task OnSessionDateChanged(int sessionId, string? newVal)
    {
        _editingSessionDateId = null;
        if (string.IsNullOrWhiteSpace(newVal) || !DateOnly.TryParse(newVal, out _)) return;
        DashSvc.UpdateSessionDate(sessionId, newVal);
        Console.WriteLine($"[Sessions] Changed session {sessionId} date to {newVal} by '{_username}'");
        ShowMsg("Session date updated.", false);
        await LoadData();
    }

    // ── Inline edit: CS review date (updates session date) ────────
    private async Task OnCsDateChanged(int csReviewId, int sessionId, string? newVal)
    {
        _editingCsDateId = null;
        if (string.IsNullOrWhiteSpace(newVal) || !DateOnly.TryParse(newVal, out _)) return;
        DashSvc.UpdateSessionDate(sessionId, newVal);
        Console.WriteLine($"[Sessions] Changed CS review {csReviewId} session {sessionId} date to {newVal} by '{_username}'");
        ShowMsg("Session date updated.", false);
        await LoadData();
    }

    // ── Inline edit: reassign CS person ───────────────────────────
    private async Task OnCsPersonChanged(int csReviewId, string? newVal)
    {
        _editingCsPersonId = null;
        if (!int.TryParse(newVal, out var newCsId) || newCsId <= 0) return;
        DashSvc.ReassignCsReview(csReviewId, newCsId);
        var name = CsStaffName(newCsId);
        Console.WriteLine($"[Sessions] Reassigned CS review {csReviewId} to {name} (PersonId={newCsId}) by '{_username}'");
        ShowMsg($"CS reassigned to {name}.", false);
        await LoadData();
    }
}
