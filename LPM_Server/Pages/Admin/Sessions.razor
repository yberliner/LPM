    // ── Data load ─────────────────────────────────────────────────
    private async Task LoadData(bool silent = false)
    {
        if (!silent) _loading = true;
        StateHasChanged();
        await Task.Yield();

        DateOnly? from = null, to = null;
        if (_includeApproved && DateOnly.TryParse(_fromDateStr, out var f)) from = f;
        if (_includeApproved && DateOnly.TryParse(_toDateStr,   out var t)) to   = t;

        // ── Sessions ──
        _groups = DashSvc.GetSessionsGroupedByAuditorAndPc(_includeApproved, from, to, OrgFilter);
        _pcDefaults.Clear();
        _rowEdits.Clear();
        _auditorAvatars.Clear();
        _pcCurrency.Clear();
        _pcWallets.Clear();
        _pcTopWallet.Clear();
        _csTopWallet.Clear();

        foreach (var group in _groups)
        {
            if (!_auditorAvatars.ContainsKey(group.AuditorId))
                _auditorAvatars[group.AuditorId] = UserDb.GetAvatarPath(group.AuditorName.Split(' ')[0].ToLower());

            foreach (var pcGroup in group.PcGroups)
            {
                if (!_pcCurrency.ContainsKey(pcGroup.PcId))
                    _pcCurrency[pcGroup.PcId] = DashSvc.GetLastPurchaseCurrency(pcGroup.PcId);
                if (!_pcWallets.ContainsKey(pcGroup.PcId))
                    _pcWallets[pcGroup.PcId] = WalletSvc.GetWalletsForPc(pcGroup.PcId, includeInactive: true);
                // Seed the top-row wallet selection from the current session wallet so currency icons
                // reflect the default without requiring an explicit admin pick.
                var seedWallet = pcGroup.Sessions.FirstOrDefault(s => s.WalletId.HasValue)?.WalletId
                               ?? _pcWallets[pcGroup.PcId].FirstOrDefault(w => w.IsActive)?.WalletId
                               ?? 0;
                if (seedWallet > 0)
                    _pcTopWallet[(group.AuditorId, pcGroup.PcId)] = seedWallet;
                var key = (group.AuditorId, pcGroup.PcId);
                var (defRate, defSalary) = DashSvc.GetLastApprovedDefaultsForPc(group.AuditorId, pcGroup.PcId);
                _pcDefaults[key] = new PcDefaults { ChargeRate = defRate / 100.0, Salary = defSalary / 100.0 };
                foreach (var s in pcGroup.Sessions)
                    _rowEdits[s.SessionId] = new RowEdit
                    {
                        ChargeRate = s.ChargedRateCentsPerHour  > 0 ? s.ChargedRateCentsPerHour  / 100.0 : defRate   / 100.0,
                        Salary     = s.AuditorSalaryCentsPerHour > 0 ? s.AuditorSalaryCentsPerHour / 100.0 : defSalary / 100.0
                    };
            }
        }

        // ── CS Reviews ──
        _csGroups = DashSvc.GetCsReviewsGroupedByCsAndPc(_includeApproved, from, to, OrgFilter);
        _csPcDefaults.Clear();
        _csRowEdits.Clear();
        _csRateEdits.Clear();
        _csAvatars.Clear();

        foreach (var csGroup in _csGroups)
        {
            if (!_csAvatars.ContainsKey(csGroup.CsId))
                _csAvatars[csGroup.CsId] = UserDb.GetAvatarPath(csGroup.CsName.Split(' ')[0].ToLower());

            foreach (var pcGroup in csGroup.PcGroups)
            {
                if (!_pcCurrency.ContainsKey(pcGroup.PcId))
                    _pcCurrency[pcGroup.PcId] = DashSvc.GetLastPurchaseCurrency(pcGroup.PcId);
                if (!_pcWallets.ContainsKey(pcGroup.PcId))
                    _pcWallets[pcGroup.PcId] = WalletSvc.GetWalletsForPc(pcGroup.PcId, includeInactive: true);
                var csSeedWallet = pcGroup.Reviews.FirstOrDefault(r => r.WalletId.HasValue)?.WalletId
                                 ?? _pcWallets[pcGroup.PcId].FirstOrDefault(w => w.IsActive)?.WalletId
                                 ?? 0;
                if (csSeedWallet > 0)
                    _csTopWallet[(csGroup.CsId, pcGroup.PcId)] = csSeedWallet;
                var key = (csGroup.CsId, pcGroup.PcId);
                var defCsSalary = DashSvc.GetLastApprovedCsSalaryForPc(pcGroup.PcId);
                _csPcDefaults[key] = defCsSalary / 100.0;
                var defSoloRate = DashSvc.GetLastSoloCsRateForPc(pcGroup.PcId);
                foreach (var rev in pcGroup.Reviews)
                {
                    _csRowEdits[rev.CsReviewId] = rev.CsSalaryCentsPerHour > 0
                        ? rev.CsSalaryCentsPerHour / 100.0
                        : defCsSalary / 100.0;
                    if (rev.IsSolo)
                        _csRateEdits[rev.CsReviewId] = rev.ChargedCentsRatePerHour > 0
                            ? rev.ChargedCentsRatePerHour / 100.0
                            : defSoloRate / 100.0;
                }
            }
        }

        // ── Last auditing purchase per PC (one batched query for the whole view) ──
        _pcLastPurchase.Clear();
        var allPcIds = _groups.SelectMany(g => g.PcGroups).Select(pg => pg.PcId)
            .Concat(_csGroups.SelectMany(g => g.PcGroups).Select(pg => pg.PcId))
            .Distinct().ToList();
        if (allPcIds.Count > 0)
            _pcLastPurchase = PcSvc.GetLastAuditingPurchasePerPc(allPcIds);

        // ── Rate-mismatch detection: per PC, find sessions whose ChargedRate differs from the
        // last-auditing-purchase rate. Only count sessions with ChargedRate > 0 (free / pending
        // sessions have rate 0 — that's "no rate yet", not a mismatch).
        _pcRateMismatch.Clear();
        foreach (var pg in _groups.SelectMany(g => g.PcGroups))
        {
            if (!_pcLastPurchase.TryGetValue(pg.PcId, out var lp)) continue;
            int lastRate = lp.RateCentsPerHour;
            var byRate = new Dictionary<int, RateBucket>();
            foreach (var s in pg.Sessions)
            {
                if (s.ChargedRateCentsPerHour <= 0) continue;     // skip pending / free
                // Tolerance: ±5 currency units (= 500 cents). Small differences are usually
                // rounding or trivial overrides — not worth flagging as a mismatch.
                if (Math.Abs(s.ChargedRateCentsPerHour - lastRate) <= 500) continue;
                if (!byRate.TryGetValue(s.ChargedRateCentsPerHour, out var bucket))
                    bucket = new RateBucket(s.ChargedRateCentsPerHour, 0, s.SessionDate);
                bucket = bucket with { Count = bucket.Count + 1,
                                       FirstDate = string.Compare(s.SessionDate, bucket.FirstDate, StringComparison.Ordinal) < 0
                                                   ? s.SessionDate : bucket.FirstDate };
                byRate[s.ChargedRateCentsPerHour] = bucket;
            }
            if (byRate.Count > 0)
                _pcRateMismatch[pg.PcId] = new RateMismatchInfo(
                    PcName: pg.PcName,
                    LastRateCents: lastRate,
                    Currency: lp.Currency,
                    MismatchBuckets: byRate.Values.OrderBy(b => b.RateCents).ToList());
        }

        _loading = false;
    }

    // ── Rate-mismatch state ─────────────────────────────────────────────────
    record RateBucket(int RateCents, int Count, string FirstDate);
    record RateMismatchInfo(string PcName, int LastRateCents, string Currency, List<RateBucket> MismatchBuckets);
    Dictionary<int, RateMismatchInfo> _pcRateMismatch = new();

