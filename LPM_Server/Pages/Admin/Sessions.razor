    // dd-M-yy format used in the Last-Purchase popup (no leading zero on month).
    private static string FormatDateShort(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd-M-yy") : dateStr;

    // cents-per-hour → whole-currency display, rounded half-away-from-zero so 68996 → 690 (not 689).
    // Plain integer division (cents / 100) silently truncates and was producing the off-by-one
    // for any rate whose fractional part was ≥ 0.50 (e.g. €689.96/hr was showing as 689).
    private static int RoundRateCents(int cents) =>
        (int)Math.Round(cents / 100.0, MidpointRounding.AwayFromZero);

