    /* Date input / Apply */
    .sa-date-input { font-size: 0.83rem; border-color: #ced4da; color: #212529; background-color: #fff; min-width: 130px; flex: 1 1 130px; max-width: 160px; min-height: 38px; touch-action: manipulation; }
    .sa-date-input:focus { border-color: #2d6a9f; box-shadow: none; }

    @@media (max-width: 480px) {
        .sa-page { padding-left: 10px !important; padding-right: 10px !important; }
        .sa-date-input { max-width: 100%; font-size: 1rem; }
        .sa-filter-card .card-body { padding: 10px 12px !important; }
        .sa-page .table { font-size: 0.78rem; }
    }
    .sa-btn-apply { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.8rem; font-weight: 600; }
    .sa-btn-apply:hover:not(:disabled) { background: #1e3a5f; color: #fff; }

    /* Cards */
    .sa-auditor-card { border-radius: 14px; overflow: hidden; }
    .sa-auditor-card:hover { box-shadow: 0 6px 28px rgba(30,58,95,.13) !important; transition: box-shadow .25s; }
    .sa-auditor-header  { background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%); }
    .sa-cs-card-header  { background: linear-gradient(135deg, #2a5fa8 0%, #4a90d9 100%); }

    /* Avatars */
    .sa-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.3); color: #fff; font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sa-avatar-img { width: 40px; height: 40px; border-radius: 50%; border: 2px solid rgba(255,255,255,.45); object-fit: cover; flex-shrink: 0; }

    /* PC sub-section */
    .sa-pc-divider { height: 7px; background: linear-gradient(90deg, #2d6a9f 0%, #dce3f0 100%); margin: 0; }
    .sa-pc-header  { background: #f4f7fc; color: #212529; min-height: 54px; }
    .sa-pc-dot     { width: 8px; height: 8px; border-radius: 50%; background: #2d6a9f; flex-shrink: 0; }
    .sa-pc-dot-cs  { background: #4a7fc1; }
    .sa-pc-name    { font-size: 0.9rem; color: #1e3a5f; }
    .sa-input-label{ font-size: 0.72rem; white-space: nowrap; }

    /* "Set all" inputs */
    .sa-rate-input .input-group-text { background: #fff; border-color: #ced4da; font-size: 0.75rem; color: #6c757d; white-space: nowrap; }
    .sa-rate-input .form-control { font-size: 0.85rem; border-color: #ced4da; color: #212529; background-color: #fff; }
    .sa-rate-input:focus-within .input-group-text,
    .sa-rate-input:focus-within .form-control { border-color: #2d6a9f; box-shadow: none; }

    /* Row-level inputs */
    .sa-row-input { font-size: 0.83rem; border-color: #dee2e6; border-radius: 6px; padding: 3px 8px; color: #212529; background-color: #fff; }
    .sa-row-input:focus { border-color: #2d6a9f; box-shadow: none; }

    /* Table headers */
    .sa-table { font-size: 0.85rem; }
    .sa-thead tr { background: #eef1f8; color: #212529; }
    .sa-thead th { font-size: 0.69rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #6c757d; padding-top: 7px; padding-bottom: 7px; border-bottom: 1px solid #dce3f0; border-top: none; }
    .sa-cs-thead tr { background: #e4ecf8; color: #212529; }
    .sa-cs-thead th { font-size: 0.69rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #4a7fc1; padding-top: 6px; padding-bottom: 6px; border-bottom: 1px solid #c7d7f0; border-top: none; }

    /* Row states */
    .sa-row-draft td     { border-bottom: 1px solid #f0f2f8; transition: background .12s; background: #f8f9fa; color: #212529; }
    .sa-row-draft:hover td  { background: #f5f7ff; }
    .sa-row-approved td  { border-bottom: 1px solid #bbf7d0; background: #f0fdf4; color: #212529; }
    .sa-row-approved:hover td { background: #dcfce7; }
    .sa-date { color: #1e3a5f; }

    /* Badges */
    .sa-badge-pending      { background: #fef3c7; color: #92400e; font-size: 0.68rem; }
    .sa-badge-approved-sm  { background: #d1fae5; color: #065f46; font-size: 0.68rem; }
    .sa-badge-free         { background: #ede9fe; color: #5b21b6; font-size: 0.68rem; }
    .sa-badge-status-draft    { background: #fef3c7; color: #92400e; font-size: 0.73rem; }
    .sa-badge-status-approved { background: #d1fae5; color: #065f46; font-size: 0.73rem; }

    /* Action buttons */
    .sa-btn-approve-all { background: rgba(255,255,255,.92); color: #1e3a5f; border: 1px solid rgba(45,106,159,.4); font-size: 0.78rem; border-radius: 7px; font-weight: 600; }
    .sa-btn-approve-all:hover:not(:disabled) { background: #fff; border-color: #2d6a9f; }
    .sa-btn-submit { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.78rem; padding: 3px 10px; font-weight: 600; }
    .sa-btn-submit:hover:not(:disabled) { background: #1e3a5f; color: #fff; }
    .sa-btn-update { background: transparent; color: #2d6a9f; border: 1px solid #2d6a9f; border-radius: 7px; font-size: 0.78rem; padding: 3px 10px; font-weight: 600; }
    .sa-btn-update:hover:not(:disabled) { background: #2d6a9f; color: #fff; }
    .sa-btn-cs-all { background: #4a7fc1; color: #fff; border: none; border-radius: 7px; font-size: 0.75rem; font-weight: 600; }
    .sa-btn-cs-all:hover:not(:disabled) { background: #1e3a5f; color: #fff; }

    /* Editable date — subtle hover cue */
    .sa-date-editable { cursor: pointer; border-bottom: 1px dashed transparent; transition: border-color .15s; }
    .sa-date-editable:hover { border-bottom-color: #2d6a9f; }

    /* Editable CS name — subtle hover cue */
    .sa-cs-name-editable { cursor: pointer; font-size: 0.8rem; color: #1e3a5f; border-bottom: 1px dashed transparent; transition: border-color .15s; display: inline-flex; align-items: center; gap: 4px; }
    .sa-cs-name-editable:hover { border-bottom-color: #4a7fc1; }

    /* Spinner */
    .sa-spin { display: inline-block; animation: sa-spin-anim 1s linear infinite; }
    @@keyframes sa-spin-anim { to { transform: rotate(360deg); } }

    /* Free solo CS badge */
    .sa-free-badge {
        display: inline-block;
        font-size: .68rem; font-weight: 700; letter-spacing: .03em;
        color: #dc2626; background: #fef2f2;
