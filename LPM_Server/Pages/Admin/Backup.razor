@page "/Admin/Backup"
@attribute [Authorize(Roles = "Admin,Customer")]
@using LPM.Services
@using Microsoft.AspNetCore.Authorization
@inject FolderService FolderSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<div class="bk-page p-3 p-md-4">

    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold" style="color:#e2e8f0;">System Backup</h4>
            <span class="text-muted" style="font-size:0.82rem;">Download a full backup of the database and all PC folders</span>
        </div>
    </div>

    @* ── Size Info Card ── *@
    <div class="card mb-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
        <div class="card-body">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">Database</div>
                    <div style="font-size:1.1rem; font-weight:600;">@FormatSize(_dbSize)</div>
                </div>
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">PC Folders</div>
                    <div style="font-size:1.1rem; font-weight:600;">@FormatSize(_pcSize)</div>
                </div>
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">Total Files</div>
                    <div style="font-size:1.1rem; font-weight:600;">@_totalFiles</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Warning Banner ── *@
    @if (_downloading)
    {
        <div class="bk-warning-banner">
            <div class="bk-warning-icon">
                <i class="ri-alarm-warning-fill"></i>
            </div>
            <div style="flex:1;">
                <div class="bk-warning-title">BACKUP IN PROGRESS</div>
                <div class="bk-warning-text">
                    You may switch to other tabs — the download continues in the background.
                    Do NOT close this tab, navigate away from this page, or let your computer sleep.
                </div>
                @* ── User Backup bar ── *@
                <div class="bk-phase-row mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @if (_userDone)
                        {   <i class="ri-checkbox-circle-fill" style="color:#22c55e;font-size:1rem;"></i> }
                        else if (_userActive)
                        {   <span class="spinner-border spinner-border-sm" style="color:#fbbf24;width:14px;height:14px;border-width:2px;"></span> }
                        else
                        {   <i class="ri-time-line" style="color:#475569;font-size:1rem;"></i> }
                        <span style="font-size:.8rem;font-weight:600;color:@(_userDone?"#22c55e":_userActive?"#fbbf24":"#64748b");">
                            User Backup (1/2)
                        </span>
                        <span class="ms-auto" style="font-size:.75rem;color:#94a3b8;">
                            @(_userTotal>0 ? $"{_userCurrent}/{_userTotal}" : (_userActive?"counting…":""))
                        </span>
                    </div>
                    <div class="progress" style="height:7px;background:#0f172a;border-radius:4px;">
                        <div class="progress-bar" style="width:@(_userTotal>0?(_userCurrent*100/_userTotal):0)%;
                             background:@(_userDone?"#22c55e":"#3b82f6");transition:width .3s ease;"></div>
                    </div>
                    @if (_userActive && !string.IsNullOrEmpty(_userFile))
                    {
                        <div style="font-size:.7rem;color:#64748b;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @_userFile
                        </div>
                    }
                </div>

                @* ── Server Backup bar ── *@
                <div class="bk-phase-row mt-2">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @if (_serverDone)
                        {   <i class="ri-checkbox-circle-fill" style="color:#22c55e;font-size:1rem;"></i> }
                        else if (_serverActive)
                        {   <span class="spinner-border spinner-border-sm" style="color:#fbbf24;width:14px;height:14px;border-width:2px;"></span> }
                        else
                        {   <i class="ri-time-line" style="color:#475569;font-size:1rem;"></i> }
                        <span style="font-size:.8rem;font-weight:600;color:@(_serverDone?"#22c55e":_serverActive?"#fbbf24":"#64748b");">
                            Server Backup (2/2)
                        </span>
                        <span class="ms-auto" style="font-size:.75rem;color:#94a3b8;">
                            @(_serverTotal>0 ? $"{_serverCurrent}/{_serverTotal}" : (_serverActive?"counting…":"Waiting…"))
                        </span>
                    </div>
                    <div class="progress" style="height:7px;background:#0f172a;border-radius:4px;opacity:@(_serverActive||_serverDone?"1":".35");">
                        <div class="progress-bar" style="width:@(_serverTotal>0?(_serverCurrent*100/_serverTotal):0)%;
                             background:@(_serverDone?"#22c55e":"#3b82f6");transition:width .3s ease;"></div>
                    </div>
                    @if (_serverActive && !string.IsNullOrEmpty(_serverFile))
                    {
                        <div style="font-size:.7rem;color:#64748b;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @_serverFile
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Blocked by another user banner ── *@
    @if (!string.IsNullOrEmpty(_blockedByUser) && !_downloading)
    {
        <div class="bk-blocked-banner mt-3">
            <div style="font-size:2.6rem; color:#f59e0b; flex-shrink:0; line-height:1;">
                <i class="ri-lock-fill"></i>
            </div>
            <div style="flex:1;">
                <div class="bk-blocked-title">BACKUP ALREADY IN PROGRESS</div>
                <div class="bk-blocked-text">
                    Started by: <strong style="color:#fde68a;">@_blockedByUser</strong>
                </div>
                <div class="bk-blocked-sub">Please wait until the current backup finishes before starting a new one.</div>
            </div>
        </div>
    }

    @* ── Action ── *@
    <div class="d-flex align-items-center gap-3 mt-3 flex-wrap">
        @if (!_downloading)
        {
            <button class="btn btn-primary btn-lg d-flex align-items-center gap-2 @(_shakeActive ? "bk-shake" : "")"
                    disabled="@(!string.IsNullOrEmpty(_blockedByUser))"
                    @onclick="ShowPasswordPrompt">
                <i class="ri-download-cloud-2-line" style="font-size:1.3rem;"></i>
                Start Backup
            </button>
        }
        else
        {
            <button class="btn btn-secondary btn-lg" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Backup in progress…
            </button>
            <button class="btn btn-outline-danger btn-lg d-flex align-items-center gap-2"
                    @onclick="CancelBackup">
                <i class="ri-close-circle-line"></i>
                Cancel
            </button>
        }
        @if (!string.IsNullOrEmpty(_refusedMessage))
        {
            <div class="bk-refused-msg d-flex align-items-center gap-2">
                <i class="ri-forbid-2-line"></i>
                @_refusedMessage
            </div>
        }
    </div>

    @* ── Integrity warning ── *@
    @if (!string.IsNullOrEmpty(_integrityWarning))
    {
        <div class="alert mt-3 d-flex align-items-start gap-3"
             style="max-width:700px; background:rgba(239,68,68,.15); border:2px solid #ef4444; border-radius:10px; color:#fca5a5;">
            <i class="ri-error-warning-fill" style="font-size:2rem; color:#ef4444; flex-shrink:0; margin-top:2px;"></i>
            <div>
                <div style="font-size:1rem; font-weight:700; color:#ef4444; letter-spacing:.04em;">
                    DATABASE INTEGRITY CHECK FAILED
                </div>
                <div style="font-size:.84rem; margin-top:4px;">
                    The live database appears to be corrupt. The backup was created anyway and includes all
                    auto-backups in the <strong>db-autobackups/</strong> folder — restore from the newest
                    healthy one there.
                </div>
                <div style="font-size:.76rem; color:#94a3b8; margin-top:6px; font-family:monospace;">@_integrityWarning</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3" style="max-width:600px;">@_error</div>
    }

    @* ── Password Modal ── *@
    @if (_showPasswordModal)
    {
        <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.6);" @onclick="() => _showPasswordModal = false">
            <div class="modal-dialog modal-sm modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                    <div class="modal-header py-2" style="border-color:#334155;">
                        <h6 class="modal-title"><i class="ri-lock-2-line me-2"></i>Confirm Identity</h6>
                        <button class="btn-close btn-close-white" @onclick="() => _showPasswordModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <p style="font-size:.82rem; color:#94a3b8;">Enter your password to start the backup download.</p>
                        <input type="password" class="form-control"
                               style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                               placeholder="Password"
                               autocomplete="new-password"
                               data-lpignore="true"
                               data-1p-ignore="true"
                               @bind="_backupPassword"
                               @bind:event="oninput"
                               @onkeydown="OnPasswordKeyDown" />
                        @if (!string.IsNullOrEmpty(_passwordError))
                        {
                            <div class="text-danger mt-2" style="font-size:.8rem;">@_passwordError</div>
                        }
                    </div>
                    <div class="modal-footer py-2" style="border-color:#334155;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showPasswordModal = false">Cancel</button>
                        <button class="btn btn-sm btn-primary" disabled="@_authBusy" @onclick="AuthAndStartBackup">
                            @if (_authBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Confirm
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_done)
    {
        <div class="alert alert-success mt-3 d-flex align-items-center gap-2" style="max-width:600px;">
            <i class="ri-check-double-line" style="font-size:1.2rem;"></i>
            Both backups complete. Check your browser downloads (2 files: User Backup + Server Backup).
        </div>
    }

    @if (_timedOutFiles.Count > 0)
    {
        <div class="alert mt-3" style="max-width:700px; background:rgba(251,191,36,.12); border:2px solid #fbbf24; border-radius:10px; color:#fde68a;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="ri-alarm-warning-line" style="font-size:1.2rem; color:#fbbf24;"></i>
                <strong style="color:#fbbf24;">@_timedOutFiles.Count file(s) skipped — could not be read within 60 seconds</strong>
            </div>
            <ul class="mb-0" style="font-size:.78rem; font-family:monospace; color:#94a3b8; padding-left:1.2rem;">
                @foreach (var f in _timedOutFiles)
                {
                    <li>@f</li>
                }
            </ul>
        </div>
    }
</div>

<style>
    .bk-page { max-width: 800px; }

    @@media (max-width: 480px) {
        .bk-page { padding-left: 10px !important; padding-right: 10px !important; }
        .bk-page .d-flex.gap-4 { gap: 16px !important; }
        .bk-warning-banner { gap: 10px; padding: 12px 14px; }
        .bk-warning-icon { font-size: 1.6rem; }
        .bk-warning-title { font-size: 0.9rem; }
        .bk-page .btn { min-height: 40px; touch-action: manipulation; }
    }

    .bk-warning-banner {
        display: flex; align-items: flex-start; gap: 16px;
        padding: 16px 20px;
        background: rgba(239, 68, 68, .12);
        border: 2px solid #ef4444;
        border-radius: 10px;
        animation: bk-pulse 1.5s ease-in-out infinite;
    }
    .bk-warning-icon {
        font-size: 2.2rem; color: #ef4444; margin-top: 2px;
        animation: bk-flash 1s ease-in-out infinite;
    }
    .bk-warning-title {
        font-size: 1rem; font-weight: 700; color: #ef4444;
        letter-spacing: .05em;
    }
    .bk-warning-text {
        font-size: .85rem; color: #fca5a5; margin-top: 4px;
    }

    @@keyframes bk-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,.3); }
        50% { box-shadow: 0 0 0 8px rgba(239,68,68,0), 0 0 20px rgba(239,68,68,.15); }
    }
    @@keyframes bk-flash {
        0%, 100% { opacity: 1; }
        50% { opacity: .3; }
    }

    .bk-blocked-banner {
        display: flex; align-items: flex-start; gap: 16px;
        padding: 20px 24px;
        background: rgba(245, 158, 11, .13);
        border: 2px solid #f59e0b;
        border-radius: 12px;
        max-width: 700px;
        animation: bk-blocked-pulse 2s ease-in-out infinite;
    }
    .bk-blocked-title {
        font-size: 1.05rem; font-weight: 800; color: #f59e0b;
        letter-spacing: .06em; margin-bottom: 4px;
    }
    .bk-blocked-text  { font-size: .92rem; color: #fcd34d; margin-bottom: 2px; }
    .bk-blocked-sub   { font-size: .82rem; color: #94a3b8; margin-top: 4px; }

    @@keyframes bk-blocked-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,.25); }
        50%       { box-shadow: 0 0 0 8px rgba(245,158,11,0), 0 0 24px rgba(245,158,11,.12); }
    }

    @@keyframes bk-shake {
        0%,100% { transform: translateX(0); }
        15%     { transform: translateX(-9px); }
        30%     { transform: translateX(9px); }
        45%     { transform: translateX(-7px); }
        60%     { transform: translateX(7px); }
        75%     { transform: translateX(-4px); }
        90%     { transform: translateX(4px); }
    }
    .bk-shake { animation: bk-shake 0.55s ease; }

    .bk-refused-msg {
        color: #ef4444; font-size: .85rem; font-weight: 600;
        animation: bk-refused-in .2s ease both;
    }
    @@keyframes bk-refused-in { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:none; } }

    @@media (max-width: 480px) {
        .bk-blocked-banner { padding: 14px 16px; gap: 12px; }
        .bk-blocked-title  { font-size: .9rem; }
    }
</style>

@code {
    long _dbSize;
    long _pcSize;
    int _totalFiles;
    bool _downloading;
    bool _done;
    string _error = "";
    System.Threading.Timer? _pollTimer;

    // Per-phase progress
    int    _userCurrent;  int    _userTotal;  string _userFile   = ""; bool _userActive;  bool _userDone;
    int    _serverCurrent; int   _serverTotal; string _serverFile = ""; bool _serverActive; bool _serverDone;

    string _integrityWarning = "";
    List<string> _timedOutFiles = new();

    // Concurrency guard
    string _blockedByUser = "";   // non-empty = another user's backup is running
    bool   _shakeActive;          // triggers CSS shake on the button
    string _refusedMessage = "";  // temporary inline refusal message

    // Password modal
    bool _showPasswordModal;
    string _backupPassword = "";
    string _passwordError = "";
    bool _authBusy;
    string _username = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.Identity?.Name ?? "";
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }

        // Check if another user's backup is already running
        if (BackupProgress.Running)
        {
            _blockedByUser = string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser;
            // Start polling so the banner clears automatically when the other backup finishes
            _pollTimer = new System.Threading.Timer(PollProgress, null, 1000, 1500);
        }

        var info = FolderSvc.GetBackupSizeInfo();
        _dbSize = info.DbSize;
        _pcSize = info.PcFoldersSize;
        _totalFiles = info.TotalFiles;
    }

    void ShowPasswordPrompt()
    {
        // Race condition: someone else started a backup after this page loaded
        if (BackupProgress.Running)
        {
            _blockedByUser = string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser;
            TriggerBlockedShake();
            return;
        }
        _backupPassword = "";
        _passwordError = "";
        _authBusy = false;
        _showPasswordModal = true;
    }

    async void TriggerBlockedShake()
    {
        _refusedMessage = $"Backup already in progress by {_blockedByUser} — cannot start a new one";
        _shakeActive = true;
        StateHasChanged();
        await Task.Delay(600);
        _shakeActive = false;
        StateHasChanged();
        await Task.Delay(3000);
        _refusedMessage = "";
        StateHasChanged();
    }

    async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AuthAndStartBackup();
    }

    async Task AuthAndStartBackup()
    {
        if (string.IsNullOrWhiteSpace(_backupPassword)) { _passwordError = "Password is required"; return; }
        _authBusy = true;
        _passwordError = "";
        StateHasChanged();

        try
        {
            var result = await JS.InvokeAsync<string>("lpmBackupAuth", _backupPassword);

            if (result == "LOCKED")
            {
                Console.WriteLine($"[Backup] Auth LOCKED (too many attempts) by '{_username}'");
                _passwordError = "Too many failed attempts. Locked for 15 minutes.";
                _authBusy = false;
                return;
            }

            if (string.IsNullOrEmpty(result) || result.StartsWith("FAIL:"))
            {
                var remaining = result != null && result.StartsWith("FAIL:")
                    ? result.Substring(5) : "?";
                Console.WriteLine($"[Backup] Auth FAILED ({remaining} attempts remaining) by '{_username}'");
                _passwordError = $"Incorrect password. {remaining} attempt(s) remaining.";
                _authBusy = false;
                return;
            }

            var token = result;

            _showPasswordModal = false;
            _backupPassword = "";

            // Pre-check integrity — show warning but always proceed
            _integrityWarning = "";
            var integrityJs = "(async function(){var r=await fetch('/api/backup-integrity');var j=await r.json();return j.ok?'ok':j.detail;})()";
            var integrityResult = await JS.InvokeAsync<string>("eval", integrityJs);
            if (integrityResult != "ok")
                _integrityWarning = integrityResult;
            StateHasChanged();

            await StartBackup(token);
        }
        catch
        {
            _passwordError = "Authentication failed";
            _authBusy = false;
        }
    }

    async Task StartBackup(string token)
    {
        Console.WriteLine($"[Backup] Backup started by '{_username}'");
        _downloading   = true;
        _done          = false;
        _error         = "";
        _timedOutFiles = new();
        _userCurrent   = 0; _userTotal   = 0; _userFile   = ""; _userActive   = false; _userDone   = false;
        _serverCurrent = 0; _serverTotal = 0; _serverFile = ""; _serverActive = false; _serverDone = false;
        BackupProgress.CurrentTempFile = null;
        BackupProgress.ActiveUser = _username;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("eval", "navigator.wakeLock?.request('screen').catch(()=>{})");
            _pollTimer?.Dispose();
            _pollTimer = new System.Threading.Timer(PollProgress, null, 500, 800);

            // Phase 1: User Backup
            _userActive = true;
            await TriggerAndWait(token, "/api/user-backup-download", "user");
            _userActive = false;
            if (!string.IsNullOrEmpty(_error) || BackupProgress.CancelRequested)
            {
                if (BackupProgress.CancelRequested) _error = "Backup was cancelled.";
                return;
            }
            _userCurrent = _userTotal; // snap to 100%
            _userDone = true;
            StateHasChanged();

            // Wait for the phase-1 zip to be fully downloaded and deleted from disk
            // before building phase 2 — prevents both ~60GB zips existing simultaneously.
            var waitMs = 0;
            while (BackupProgress.CurrentTempFile != null
                   && File.Exists(BackupProgress.CurrentTempFile)
                   && waitMs < 86_400_000) // cap at 24 hours
            {
                await Task.Delay(2000);
                waitMs += 2000;
            }

            // Phase 2: Server Backup
            _serverActive = true;
            await TriggerAndWait(token, "/api/server-backup-download", "server");
            _serverActive = false;
            if (!string.IsNullOrEmpty(_error) || BackupProgress.CancelRequested)
            {
                if (BackupProgress.CancelRequested) _error = "Backup was cancelled.";
                return;
            }
            _serverCurrent = _serverTotal; // snap to 100%
            _serverDone = true;

            Console.WriteLine($"[Backup] Both backups completed successfully by '{_username}'");
            _done = true;
        }
        catch (Exception ex)
        {
            _error = $"Backup failed: {ex.Message}";
        }
        finally
        {
            _userActive   = false;
            _serverActive = false;
            _pollTimer?.Dispose();
            _pollTimer = null;
            _downloading = false;
            BackupProgress.ActiveUser = "";
            _blockedByUser = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task TriggerAndWait(string token, string endpoint, string expectedPhase)
    {
        var dlName = expectedPhase == "user" ? "LPM-UserBackup.zip" : "LPM-ServerBackup.zip";
        await JS.InvokeVoidAsync("lpmTriggerDownload", endpoint + "?token=" + token, dlName);

        // Wait up to 8 seconds for the server to start this phase
        var startWait = 0;
        while (BackupProgress.Phase != expectedPhase && startWait < 8000)
        {
            await Task.Delay(500);
            startWait += 500;
        }
        if (BackupProgress.Phase != expectedPhase)
        {
            _error = $"Backup phase '{expectedPhase}' did not start — the download request may have failed.";
            return;
        }

        while (BackupProgress.Running)
            await Task.Delay(1000);

        if (!string.IsNullOrEmpty(BackupProgress.LastError))
            _error = $"Backup failed: {BackupProgress.LastError}";
    }

    void PollProgress(object? state)
    {
        var phase = BackupProgress.Phase;
        if (phase == "user")
        {
            _userCurrent = BackupProgress.Current;
            _userTotal   = BackupProgress.TotalFiles;
            _userFile    = BackupProgress.CurrentFile;
        }
        else if (phase == "server")
        {
            _serverCurrent = BackupProgress.Current;
            _serverTotal   = BackupProgress.TotalFiles;
            _serverFile    = BackupProgress.CurrentFile;
        }

        // Snapshot timed-out files list
        lock (BackupProgress.TimedOutFiles)
            _timedOutFiles = BackupProgress.TimedOutFiles.ToList();

        // Keep blocked-by-user banner in sync for the non-downloading observer
        if (!_downloading)
        {
            _blockedByUser = BackupProgress.Running
                ? (string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser)
                : "";
        }

        try { _ = InvokeAsync(StateHasChanged); } catch { /* circuit disposed or SignalR dropped */ }
    }

    void CancelBackup()
    {
        Console.WriteLine($"[Backup] Backup cancel requested by '{_username}'");
        BackupProgress.CancelRequested = true;
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
    }

    static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }
}
