@page "/Admin/Backup"
@attribute [Authorize(Roles = "Admin,Customer")]
@using LPM.Services
@using Microsoft.AspNetCore.Authorization
@inject FolderService FolderSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IDisposable

<div class="bk-page p-3 p-md-4">

    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold" style="color:#e2e8f0;">System Backup</h4>
            <span class="text-muted" style="font-size:0.82rem;">Download a full backup of the database and all PC folders</span>
        </div>
    </div>

    @* ── Size Info Card ── *@
    <div class="card mb-3" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
        <div class="card-body">
            <div class="d-flex align-items-center gap-4 flex-wrap">
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">Database</div>
                    <div style="font-size:1.1rem; font-weight:600;">@FormatSize(_dbSize)</div>
                </div>
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">PC Folders</div>
                    <div style="font-size:1.1rem; font-weight:600;">@FormatSize(_pcSize)</div>
                </div>
                <div>
                    <div style="font-size:.78rem; color:#94a3b8;">Total Files</div>
                    <div style="font-size:1.1rem; font-weight:600;">@_totalFiles</div>
                </div>
            </div>
        </div>
    </div>

    @* ── Warning Banner ── *@
    @if (_downloading)
    {
        <div class="bk-warning-banner">
            <div class="bk-warning-icon">
                <i class="ri-alarm-warning-fill"></i>
            </div>
            <div style="flex:1;">
                <div class="bk-warning-title">BACKUP IN PROGRESS</div>
                <div class="bk-warning-text">
                    You may switch to other tabs — the download continues in the background.
                    Do NOT close this tab, navigate away from this page, or let your computer sleep.
                </div>
                @* ── User Backup bar ── *@
                <div class="bk-phase-row mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @if (_userDone)
                        {   <i class="ri-checkbox-circle-fill" style="color:#22c55e;font-size:1rem;"></i> }
                        else if (_userActive)
                        {   <span class="spinner-border spinner-border-sm" style="color:#fbbf24;width:14px;height:14px;border-width:2px;"></span> }
                        else
                        {   <i class="ri-time-line" style="color:#475569;font-size:1rem;"></i> }
                        <span style="font-size:.8rem;font-weight:600;color:@(_userDone?"#22c55e":_userActive?"#fbbf24":"#64748b");">
                            User Backup (1/2)
                        </span>
                        <span class="ms-auto" style="font-size:.75rem;color:#94a3b8;">
                            @(_userTotal>0 ? $"{_userCurrent}/{_userTotal}" : (_userActive?"counting…":""))
                        </span>
                    </div>
                    <div class="progress" style="height:7px;background:#0f172a;border-radius:4px;">
                        <div class="progress-bar" style="width:@(_userTotal>0?(_userCurrent*100/_userTotal):0)%;
                             background:@(_userDone?"#22c55e":"#3b82f6");transition:width .3s ease;"></div>
                    </div>
                    @if (_userActive && !string.IsNullOrEmpty(_userFile))
                    {
                        <div style="font-size:.7rem;color:#64748b;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @_userFile
                        </div>
                    }
                </div>

                @* ── Server Backup bar ── *@
                <div class="bk-phase-row mt-2">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        @if (_serverDone)
                        {   <i class="ri-checkbox-circle-fill" style="color:#22c55e;font-size:1rem;"></i> }
                        else if (_serverActive)
                        {   <span class="spinner-border spinner-border-sm" style="color:#fbbf24;width:14px;height:14px;border-width:2px;"></span> }
                        else
                        {   <i class="ri-time-line" style="color:#475569;font-size:1rem;"></i> }
                        <span style="font-size:.8rem;font-weight:600;color:@(_serverDone?"#22c55e":_serverActive?"#fbbf24":"#64748b");">
                            Server Backup (2/2)
                        </span>
                        <span class="ms-auto" style="font-size:.75rem;color:#94a3b8;">
                            @(_serverTotal>0 ? $"{_serverCurrent}/{_serverTotal}" : (_serverActive?"counting…":"Waiting…"))
                        </span>
                    </div>
                    <div class="progress" style="height:7px;background:#0f172a;border-radius:4px;opacity:@(_serverActive||_serverDone?"1":".35");">
                        <div class="progress-bar" style="width:@(_serverTotal>0?(_serverCurrent*100/_serverTotal):0)%;
                             background:@(_serverDone?"#22c55e":"#3b82f6");transition:width .3s ease;"></div>
                    </div>
                    @if (_serverActive && !string.IsNullOrEmpty(_serverFile))
                    {
                        <div style="font-size:.7rem;color:#64748b;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @_serverFile
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Blocked by another user banner ── *@
    @if (!string.IsNullOrEmpty(_blockedByUser) && !_downloading)
    {
        <div class="bk-blocked-banner mt-3">
            <div style="font-size:2.6rem; color:#f59e0b; flex-shrink:0; line-height:1;">
                <i class="ri-lock-fill"></i>
            </div>
            <div style="flex:1;">
                <div class="bk-blocked-title">BACKUP ALREADY IN PROGRESS</div>
                <div class="bk-blocked-text">
                    Started by: <strong style="color:#fde68a;">@_blockedByUser</strong>
                </div>
                <div class="bk-blocked-sub">Please wait until the current backup finishes before starting a new one.</div>
            </div>
        </div>
    }

    @* ── Action ── *@
    <div class="d-flex align-items-center gap-3 mt-3 flex-wrap">
        @if (!_downloading && !_fbfDownloading)
        {
            <button class="btn btn-primary btn-lg d-flex align-items-center gap-2 @(_shakeActive ? "bk-shake" : "")"
                    disabled="@(!string.IsNullOrEmpty(_blockedByUser) || !_fbfSupported)"
                    @onclick="StartFolderBackup">
                <i class="ri-folder-download-line" style="font-size:1.3rem;"></i>
                Download to Folder
            </button>
            @if (!_fbfSupported)
            {
                <span style="font-size:.75rem;color:#94a3b8;">Folder download requires Chrome or Edge</span>
            }
        }
        else if (_fbfDownloading)
        {
            <button class="btn btn-secondary btn-lg" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Downloading files…
            </button>
            <button class="btn btn-outline-danger btn-lg d-flex align-items-center gap-2"
                    @onclick="CancelFolderBackup">
                <i class="ri-close-circle-line"></i>
                Cancel
            </button>
        }
        else
        {
            <button class="btn btn-secondary btn-lg" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Backup in progress…
            </button>
            <button class="btn btn-outline-danger btn-lg d-flex align-items-center gap-2"
                    @onclick="CancelBackup">
                <i class="ri-close-circle-line"></i>
                Cancel
            </button>
        }
        @if (!string.IsNullOrEmpty(_refusedMessage))
        {
            <div class="bk-refused-msg d-flex align-items-center gap-2">
                <i class="ri-forbid-2-line"></i>
                @_refusedMessage
            </div>
        }
    </div>

    @* ── File-by-file progress ── *@
    @if (_fbfDownloading)
    {
        <div class="bk-warning-banner mt-3">
            <div class="bk-warning-icon">
                <i class="ri-folder-download-line"></i>
            </div>
            <div style="flex:1;">
                <div class="bk-warning-title">DOWNLOADING FILES TO FOLDER</div>
                <div class="bk-warning-text">
                    Files are being saved directly to your chosen folder. You can leave this page open.
                </div>
                <div class="bk-phase-row mt-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span style="font-size:.8rem;font-weight:600;color:#fbbf24;">
                            Phase: @(_fbfPhase == "user" ? "User Backup" : "Server Backup")
                        </span>
                        <span class="ms-auto" style="font-size:.75rem;color:#94a3b8;">
                            @_fbfCurrent / @_fbfTotal
                            @if (_fbfSkipped > 0) { <text> (@_fbfSkipped skipped)</text> }
                            @if (_fbfErrors > 0) { <text> | <span style="color:#f87171;">@_fbfErrors errors</span></text> }
                        </span>
                    </div>
                    <div class="progress" style="height:7px;background:#0f172a;border-radius:4px;">
                        <div class="progress-bar" style="width:@(_fbfTotal > 0 ? (_fbfCurrent * 100 / _fbfTotal) : 0)%;
                             background:#3b82f6;transition:width .3s ease;"></div>
                    </div>
                    @if (!string.IsNullOrEmpty(_fbfCurrentFile))
                    {
                        <div style="font-size:.7rem;color:#64748b;margin-top:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                            @_fbfCurrentFile
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* ── Integrity warning ── *@
    @if (!string.IsNullOrEmpty(_integrityWarning))
    {
        <div class="alert mt-3 d-flex align-items-start gap-3"
             style="max-width:700px; background:rgba(239,68,68,.15); border:2px solid #ef4444; border-radius:10px; color:#fca5a5;">
            <i class="ri-error-warning-fill" style="font-size:2rem; color:#ef4444; flex-shrink:0; margin-top:2px;"></i>
            <div>
                <div style="font-size:1rem; font-weight:700; color:#ef4444; letter-spacing:.04em;">
                    DATABASE INTEGRITY CHECK FAILED
                </div>
                <div style="font-size:.84rem; margin-top:4px;">
                    The live database appears to be corrupt. The backup was created anyway and includes all
                    auto-backups in the <strong>db-autobackups/</strong> folder — restore from the newest
                    healthy one there.
                </div>
                <div style="font-size:.76rem; color:#94a3b8; margin-top:6px; font-family:monospace;">@_integrityWarning</div>
            </div>
        </div>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger mt-3" style="max-width:600px;">@_error</div>
    }

    @* ── Password Modal ── *@
    @if (_showPasswordModal)
    {
        <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.6);" @onclick="() => _showPasswordModal = false">
            <div class="modal-dialog modal-sm modal-dialog-centered" @onclick:stopPropagation="true">
                <div class="modal-content" style="background:#1e293b; color:#e2e8f0; border-color:#334155;">
                    <div class="modal-header py-2" style="border-color:#334155;">
                        <h6 class="modal-title"><i class="ri-lock-2-line me-2"></i>Confirm Identity</h6>
                        <button class="btn-close btn-close-white" @onclick="() => _showPasswordModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <p style="font-size:.82rem; color:#94a3b8;">Enter your password to start the backup download.</p>
                        <input type="password" class="form-control"
                               style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                               placeholder="Password"
                               autocomplete="new-password"
                               data-lpignore="true"
                               data-1p-ignore="true"
                               @bind="_backupPassword"
                               @bind:event="oninput"
                               @onkeydown="OnPasswordKeyDown" />
                        @if (!string.IsNullOrEmpty(_passwordError))
                        {
                            <div class="text-danger mt-2" style="font-size:.8rem;">@_passwordError</div>
                        }
                    </div>
                    <div class="modal-footer py-2" style="border-color:#334155;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showPasswordModal = false">@LS.T("common.cancel")</button>
                        <button class="btn btn-sm btn-primary" disabled="@_authBusy" @onclick="AuthAndStartBackup">
                            @if (_authBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-1"></span>
                            }
                            Confirm
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_done)
    {
        <div class="alert alert-success mt-3 d-flex align-items-center gap-2" style="max-width:600px;">
            <i class="ri-check-double-line" style="font-size:1.2rem;"></i>
            Both backups complete.
            @if (_fbfSkipped > 0 || _fbfErrors > 0)
            {
                <span>(@_fbfSkipped skipped, @_fbfErrors errors)</span>
            }
        </div>
    }

    @if (_timedOutFiles.Count > 0)
    {
        <div class="alert mt-3" style="max-width:700px; background:rgba(251,191,36,.12); border:2px solid #fbbf24; border-radius:10px; color:#fde68a;">
            <div class="d-flex align-items-center gap-2 mb-2">
                <i class="ri-alarm-warning-line" style="font-size:1.2rem; color:#fbbf24;"></i>
                <strong style="color:#fbbf24;">@_timedOutFiles.Count file(s) skipped — could not be read within 60 seconds</strong>
            </div>
            <ul class="mb-0" style="font-size:.78rem; font-family:monospace; color:#94a3b8; padding-left:1.2rem;">
                @foreach (var f in _timedOutFiles)
                {
                    <li>@f</li>
                }
            </ul>
        </div>
    }

    @* ── Backup Errors Table ── *@
    @if (_fbfHasStarted || _errors.Count > 0)
    {
        <div class="bk-err-card mt-3">
            <div class="bk-err-head">
                <div class="bk-err-title">
                    <i class="ri-error-warning-fill"></i>
                    Backup Errors (@_errors.Count)
                </div>
                <div class="bk-err-actions">
                    @if (!string.IsNullOrEmpty(_copyToast))
                    {
                        <span class="bk-copy-toast">@_copyToast</span>
                    }
                    <button class="btn btn-sm btn-outline-light bk-err-btn" @onclick="CopyErrorsTable"
                            disabled="@(_errors.Count == 0)" title="Copy as tab-separated text">
                        <i class="ri-clipboard-line me-1"></i>Copy
                    </button>
                    <button class="btn btn-sm btn-light bk-err-btn" @onclick="DownloadErrorsPdf"
                            disabled="@(_pdfBusy || _errors.Count == 0)">
                        @if (_pdfBusy)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="ri-file-pdf-2-line me-1"></i>
                        }
                        Download PDF
                    </button>
                </div>
            </div>
            <div class="bk-err-scroll">
                <table class="bk-err-table">
                    <thead>
                        <tr>
                            <th style="width:14%;">Type</th>
                            <th style="width:30%;">What &amp; Why</th>
                            <th style="width:34%;">Full Server Path</th>
                            <th style="width:12%;">PC Name</th>
                            <th style="width:10%;">When</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_errors.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="bk-err-empty">
                                    <i class="ri-checkbox-circle-line"></i>
                                    @(_fbfDownloading ? "No errors yet — backup in progress…" : "No errors recorded for this backup run.")
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var e in _errors)
                            {
                                var is404 = e.Type == "http_404";
                                <tr class="@(is404 ? "bk-err-row-404" : "bk-err-row-fail")">
                                    <td>
                                        <span class="bk-err-pill @(is404 ? "bk-pill-amber" : "bk-pill-red")">
                                            @(is404 ? "HTTP 404 — Not Found" : "Download Failed (3 attempts)")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="bk-err-expl">@ExplanationFor(e.Type)</div>
                                        @if (!string.IsNullOrEmpty(e.Detail))
                                        {
                                            <div class="bk-err-detail"><span class="bk-err-detail-k">Detail:</span> @e.Detail</div>
                                        }
                                    </td>
                                    <td class="bk-err-path">@e.FullPath</td>
                                    <td>
                                        @if (string.IsNullOrEmpty(e.PcName))
                                        {
                                            <span class="bk-err-dash">—</span>
                                        }
                                        else
                                        {
                                            @e.PcName
                                        }
                                    </td>
                                    <td class="bk-err-when">@e.When.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .bk-page { max-width: 800px; }

    @@media (max-width: 480px) {
        .bk-page { padding-left: 10px !important; padding-right: 10px !important; }
        .bk-page .d-flex.gap-4 { gap: 16px !important; }
        .bk-warning-banner { gap: 10px; padding: 12px 14px; }
        .bk-warning-icon { font-size: 1.6rem; }
        .bk-warning-title { font-size: 0.9rem; }
        .bk-page .btn { min-height: 40px; touch-action: manipulation; }
    }

    .bk-warning-banner {
        display: flex; align-items: flex-start; gap: 16px;
        padding: 16px 20px;
        background: rgba(239, 68, 68, .12);
        border: 2px solid #ef4444;
        border-radius: 10px;
        animation: bk-pulse 1.5s ease-in-out infinite;
    }
    .bk-warning-icon {
        font-size: 2.2rem; color: #ef4444; margin-top: 2px;
        animation: bk-flash 1s ease-in-out infinite;
    }
    .bk-warning-title {
        font-size: 1rem; font-weight: 700; color: #ef4444;
        letter-spacing: .05em;
    }
    .bk-warning-text {
        font-size: .85rem; color: #fca5a5; margin-top: 4px;
    }

    @@keyframes bk-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,.3); }
        50% { box-shadow: 0 0 0 8px rgba(239,68,68,0), 0 0 20px rgba(239,68,68,.15); }
    }
    @@keyframes bk-flash {
        0%, 100% { opacity: 1; }
        50% { opacity: .3; }
    }

    .bk-blocked-banner {
        display: flex; align-items: flex-start; gap: 16px;
        padding: 20px 24px;
        background: rgba(245, 158, 11, .13);
        border: 2px solid #f59e0b;
        border-radius: 12px;
        max-width: 700px;
        animation: bk-blocked-pulse 2s ease-in-out infinite;
    }
    .bk-blocked-title {
        font-size: 1.05rem; font-weight: 800; color: #f59e0b;
        letter-spacing: .06em; margin-bottom: 4px;
    }
    .bk-blocked-text  { font-size: .92rem; color: #fcd34d; margin-bottom: 2px; }
    .bk-blocked-sub   { font-size: .82rem; color: #94a3b8; margin-top: 4px; }

    @@keyframes bk-blocked-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,.25); }
        50%       { box-shadow: 0 0 0 8px rgba(245,158,11,0), 0 0 24px rgba(245,158,11,.12); }
    }

    @@keyframes bk-shake {
        0%,100% { transform: translateX(0); }
        15%     { transform: translateX(-9px); }
        30%     { transform: translateX(9px); }
        45%     { transform: translateX(-7px); }
        60%     { transform: translateX(7px); }
        75%     { transform: translateX(-4px); }
        90%     { transform: translateX(4px); }
    }
    .bk-shake { animation: bk-shake 0.55s ease; }

    .bk-refused-msg {
        color: #ef4444; font-size: .85rem; font-weight: 600;
        animation: bk-refused-in .2s ease both;
    }
    @@keyframes bk-refused-in { from { opacity:0; transform:translateY(-4px); } to { opacity:1; transform:none; } }

    @@media (max-width: 480px) {
        .bk-blocked-banner { padding: 14px 16px; gap: 12px; }
        .bk-blocked-title  { font-size: .9rem; }
    }

    /* ── Backup Errors Table ─────────────────────────────────── */
    .bk-err-card {
        background: #1e293b;
        border: 1px solid #334155;
        border-radius: 12px;
        max-width: 1200px;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(0,0,0,.35);
    }
    .bk-err-head {
        display: flex; align-items: center; gap: 12px;
        padding: 14px 18px;
        background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
        border-bottom: 1px solid #334155;
        flex-wrap: wrap;
    }
    .bk-err-title {
        font-size: 1.05rem; font-weight: 800; color: #fecaca;
        letter-spacing: .04em; flex: 1; min-width: 180px;
        display: flex; align-items: center; gap: 10px;
        text-shadow: 0 1px 2px rgba(0,0,0,.3);
    }
    .bk-err-title i { color: #fbbf24; font-size: 1.35rem; }
    .bk-err-actions { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .bk-err-btn { min-height: 32px; font-weight: 600; font-size: .82rem; }
    .bk-copy-toast {
        background: #16a34a; color: #fff; font-size: .72rem;
        padding: 4px 12px; border-radius: 20px; font-weight: 700;
        box-shadow: 0 2px 8px rgba(22,163,74,.4);
        animation: bk-copy-in .25s ease both;
    }
    @@keyframes bk-copy-in {
        from { opacity: 0; transform: scale(.7); }
        to   { opacity: 1; transform: scale(1); }
    }
    .bk-err-scroll {
        max-height: 420px; overflow: auto;
        background: #0f172a;
    }
    .bk-err-scroll::-webkit-scrollbar { width: 10px; height: 10px; }
    .bk-err-scroll::-webkit-scrollbar-track { background: #0f172a; }
    .bk-err-scroll::-webkit-scrollbar-thumb { background: #334155; border-radius: 6px; }
    .bk-err-scroll::-webkit-scrollbar-thumb:hover { background: #475569; }
    .bk-err-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .82rem;
        color: #e2e8f0;
    }
    .bk-err-table thead th {
        position: sticky; top: 0;
        background: #1e3a5f; color: #fff;
        font-weight: 700; text-align: left;
        padding: 11px 12px;
        font-size: .78rem;
        letter-spacing: .04em;
        text-transform: uppercase;
        border-bottom: 2px solid #0f172a;
        z-index: 2;
    }
    .bk-err-table tbody tr {
        border-bottom: 1px solid #1e293b;
        transition: background .15s ease;
    }
    .bk-err-table tbody tr:nth-child(even) { background: #17223a; }
    .bk-err-table tbody tr:hover { background: #273449; }
    .bk-err-table tbody td {
        padding: 11px 12px;
        vertical-align: top;
    }
    .bk-err-row-404 { border-left: 4px solid #f59e0b; }
    .bk-err-row-fail { border-left: 4px solid #ef4444; }
    .bk-err-pill {
        display: inline-block;
        padding: 5px 11px;
        border-radius: 16px;
        font-size: .72rem;
        font-weight: 800;
        letter-spacing: .02em;
        white-space: nowrap;
        box-shadow: 0 1px 4px rgba(0,0,0,.25);
