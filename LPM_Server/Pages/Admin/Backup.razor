</style>

@code {
    long _dbSize;
    long _pcSize;
    int _totalFiles;
    bool _downloading;
    bool _done;
    string _error = "";
    System.Threading.Timer? _pollTimer;

    // Per-phase progress
    int    _userCurrent;  int    _userTotal;  string _userFile   = ""; bool _userActive;  bool _userDone;
    int    _serverCurrent; int   _serverTotal; string _serverFile = ""; bool _serverActive; bool _serverDone;

    string _integrityWarning = "";
    List<string> _timedOutFiles = new();

    // Concurrency guard
    string _blockedByUser = "";   // non-empty = another user's backup is running
    bool   _shakeActive;          // triggers CSS shake on the button
    string _refusedMessage = "";  // temporary inline refusal message

    // File-by-file backup
    bool _fbfSupported;
    bool _fbfDownloading;
    string _fbfPhase = "";
    int _fbfCurrent, _fbfTotal, _fbfSkipped, _fbfErrors;
    string _fbfCurrentFile = "";

    // Per-file error log for the errors table
    record BackupError(string Type, string RelPath, string FullPath, string? PcName, DateTime When, string Detail);
    List<BackupError> _errors = new();
    string _copyToast = "";
    bool _pdfBusy;
    bool _fbfHasStarted;   // true once a file-by-file backup was started this session; keeps the table visible

    // Password modal
    bool _showPasswordModal;
    string _backupPassword = "";
    string _passwordError = "";
    bool _authBusy;
    string _username = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = authState.User.Identity?.Name ?? "";
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }

        // Check if another user's backup is already running
        if (BackupProgress.Running)
        {
            _blockedByUser = string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser;
            // Start polling so the banner clears automatically when the other backup finishes
            _pollTimer = new System.Threading.Timer(PollProgress, null, 1000, 1500);
        }

        var info = FolderSvc.GetBackupSizeInfo();
        _dbSize = info.DbSize;
        _pcSize = info.PcFoldersSize;
        _totalFiles = info.TotalFiles;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _fbfSupported = await JS.InvokeAsync<bool>("lpmFileBackup.isSupported");
            // Check if a file-by-file download is already running (circuit reconnect)
            if (_fbfSupported && await JS.InvokeAsync<bool>("lpmFileBackup.isRunning"))
            {
                _fbfDownloading = true;
                _fbfDotNetRef?.Dispose();
                _fbfDotNetRef = DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("lpmFileBackup.reconnectDotNetRef", _fbfDotNetRef);
            }
            StateHasChanged();
        }
    }

    void ShowPasswordPrompt()
    {
        // Race condition: someone else started a backup after this page loaded
        if (BackupProgress.Running)
        {
            _blockedByUser = string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser;
            TriggerBlockedShake();
            return;
        }
        _backupPassword = "";
        _passwordError = "";
        _authBusy = false;
        _showPasswordModal = true;
    }

    async void TriggerBlockedShake()
    {
        _refusedMessage = $"Backup already in progress by {_blockedByUser} — cannot start a new one";
        _shakeActive = true;
        StateHasChanged();
        await Task.Delay(600);
        _shakeActive = false;
        StateHasChanged();
        await Task.Delay(3000);
        _refusedMessage = "";
        StateHasChanged();
    }

    async Task OnPasswordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AuthAndStartBackup();
    }

    async Task AuthAndStartBackup()
    {
        if (string.IsNullOrWhiteSpace(_backupPassword)) { _passwordError = "Password is required"; return; }
        _authBusy = true;
        _passwordError = "";
        StateHasChanged();

        try
        {
            var result = await JS.InvokeAsync<string>("lpmBackupAuth", _backupPassword);

            if (result == "LOCKED")
            {
                Console.WriteLine($"[Backup] Auth LOCKED (too many attempts) by '{_username}'");
                _passwordError = "Too many failed attempts. Locked for 15 minutes.";
                _authBusy = false;
                return;
            }

            if (string.IsNullOrEmpty(result) || result.StartsWith("FAIL:"))
            {
                var remaining = result != null && result.StartsWith("FAIL:")
                    ? result.Substring(5) : "?";
                Console.WriteLine($"[Backup] Auth FAILED ({remaining} attempts remaining) by '{_username}'");
                _passwordError = $"Incorrect password. {remaining} attempt(s) remaining.";
                _authBusy = false;
                return;
            }

            var token = result;

            _showPasswordModal = false;
            _backupPassword = "";

            // Pre-check integrity — show warning but always proceed
            _integrityWarning = "";
            var integrityJs = "(async function(){var r=await fetch('/api/backup-integrity');var j=await r.json();return j.ok?'ok':j.detail;})()";
            var integrityResult = await JS.InvokeAsync<string>("eval", integrityJs);
            if (integrityResult != "ok")
                _integrityWarning = integrityResult;
            StateHasChanged();

            if (_fbfPendingStart)
            {
                _fbfPendingStart = false;
                await StartFolderBackupWithToken(token);
            }
            else
            {
                await StartBackup(token);
            }
        }
        catch
        {
            _passwordError = "Authentication failed";
            _authBusy = false;
        }
    }

    async Task StartBackup(string token)
    {
        Console.WriteLine($"[Backup] Backup started by '{_username}'");
        _downloading   = true;
        _done          = false;
        _error         = "";
        _timedOutFiles = new();
        _userCurrent   = 0; _userTotal   = 0; _userFile   = ""; _userActive   = false; _userDone   = false;
        _serverCurrent = 0; _serverTotal = 0; _serverFile = ""; _serverActive = false; _serverDone = false;
        BackupProgress.CurrentTempFile = null;
        BackupProgress.ActiveUser = _username;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("eval", "navigator.wakeLock?.request('screen').catch(()=>{})");
            _pollTimer?.Dispose();
            _pollTimer = new System.Threading.Timer(PollProgress, null, 500, 800);

            // Phase 1: User Backup
            _userActive = true;
            await TriggerAndWait(token, "/api/user-backup-download", "user");
            _userActive = false;
            if (!string.IsNullOrEmpty(_error) || BackupProgress.CancelRequested)
            {
                if (BackupProgress.CancelRequested) _error = "Backup was cancelled.";
                return;
            }
            _userCurrent = _userTotal; // snap to 100%
            _userDone = true;
            StateHasChanged();

            // Wait for the phase-1 zip to be fully downloaded and deleted from disk
            // before building phase 2 — prevents both ~60GB zips existing simultaneously.
            var waitMs = 0;
            while (BackupProgress.CurrentTempFile != null
                   && File.Exists(BackupProgress.CurrentTempFile)
                   && waitMs < 86_400_000) // cap at 24 hours
            {
                await Task.Delay(2000);
                waitMs += 2000;
            }

            // Phase 2: Server Backup
            _serverActive = true;
            await TriggerAndWait(token, "/api/server-backup-download", "server");
            _serverActive = false;
            if (!string.IsNullOrEmpty(_error) || BackupProgress.CancelRequested)
            {
                if (BackupProgress.CancelRequested) _error = "Backup was cancelled.";
                return;
            }
            _serverCurrent = _serverTotal; // snap to 100%
            _serverDone = true;

            Console.WriteLine($"[Backup] Both backups completed successfully by '{_username}'");
            _done = true;
        }
        catch (Exception ex)
        {
            _error = $"Backup failed: {ex.Message}";
        }
        finally
        {
            _userActive   = false;
            _serverActive = false;
            _pollTimer?.Dispose();
            _pollTimer = null;
            _downloading = false;
            BackupProgress.ActiveUser = "";
            _blockedByUser = "";
            await InvokeAsync(StateHasChanged);
        }
    }

    async Task TriggerAndWait(string token, string endpoint, string expectedPhase)
    {
        var dlName = expectedPhase == "user" ? "LPM-UserBackup.zip" : "LPM-ServerBackup.zip";
        await JS.InvokeVoidAsync("lpmTriggerDownload", endpoint + "?token=" + token, dlName);

        // Wait up to 8 seconds for the server to start this phase
        var startWait = 0;
        while (BackupProgress.Phase != expectedPhase && startWait < 8000)
        {
            await Task.Delay(500);
            startWait += 500;
        }
        if (BackupProgress.Phase != expectedPhase)
        {
            _error = $"Backup phase '{expectedPhase}' did not start — the download request may have failed.";
            return;
        }

        while (BackupProgress.Running)
            await Task.Delay(1000);

        if (!string.IsNullOrEmpty(BackupProgress.LastError))
            _error = $"Backup failed: {BackupProgress.LastError}";
    }

    void PollProgress(object? state)
    {
        var phase = BackupProgress.Phase;
        if (phase == "user")
        {
            _userCurrent = BackupProgress.Current;
            _userTotal   = BackupProgress.TotalFiles;
            _userFile    = BackupProgress.CurrentFile;
        }
        else if (phase == "server")
        {
            _serverCurrent = BackupProgress.Current;
            _serverTotal   = BackupProgress.TotalFiles;
            _serverFile    = BackupProgress.CurrentFile;
        }

        // Snapshot timed-out files list
        lock (BackupProgress.TimedOutFiles)
            _timedOutFiles = BackupProgress.TimedOutFiles.ToList();

        // Keep blocked-by-user banner in sync for the non-downloading observer
        if (!_downloading)
        {
            _blockedByUser = BackupProgress.Running
                ? (string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser)
                : "";
        }

        try { _ = InvokeAsync(StateHasChanged); } catch { /* circuit disposed or SignalR dropped */ }
    }

    void CancelBackup()
    {
        Console.WriteLine($"[Backup] Backup cancel requested by '{_username}'");
        BackupProgress.CancelRequested = true;
    }

    // ── File-by-file backup ──

    async Task StartFolderBackup()
    {
        if (BackupProgress.Running)
        {
            _blockedByUser = string.IsNullOrEmpty(BackupProgress.ActiveUser) ? "another user" : BackupProgress.ActiveUser;
            TriggerBlockedShake();
            return;
        }

        // Step 1: Pick directory FIRST (requires user gesture)
        try
        {
            var picked = await JS.InvokeAsync<bool>("lpmFileBackup.pickDirectory");
            if (!picked) return;
        }
        catch { return; } // user cancelled picker

        // Step 2: Show password modal — auth happens on confirm
        _backupPassword = "";
        _passwordError = "";
        _authBusy = false;
        _showPasswordModal = true;
        _fbfPendingStart = true;
        StateHasChanged();
    }

    DotNetObjectReference<Backup>? _fbfDotNetRef;
    bool _fbfPendingStart; // true = after auth, start folder backup instead of ZIP

    async Task StartFolderBackupWithToken(string token)
    {
        _fbfDownloading = true;
        _fbfPhase = "";
        _fbfCurrent = 0; _fbfTotal = 0; _fbfSkipped = 0; _fbfErrors = 0;
        _fbfCurrentFile = "";
        _errors = new();   // clear previous run's errors at start of a new backup
        _fbfHasStarted = true;
        _copyToast = "";
        _done = false;
        _error = "";
        StateHasChanged();

        Console.WriteLine($"[Backup] File-by-file backup started by '{_username}'");

        try
        {
            await JS.InvokeVoidAsync("eval", "navigator.wakeLock?.request('screen').catch(()=>{})");
            _fbfDotNetRef?.Dispose();
            _fbfDotNetRef = DotNetObjectReference.Create(this);
            // Fire-and-forget: JS calls OnBackupComplete when done (InvokeAsync would timeout on long backups)
            await JS.InvokeVoidAsync("lpmFileBackup.start", token, _fbfDotNetRef);
        }
        catch (Exception ex)
        {
            _error = $"Backup failed to start: {ex.Message}";
            _fbfDownloading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnBackupComplete(bool ok, string? error, int userTotal, int userSkipped, int userErrors, int serverTotal, int serverSkipped, int serverErrors)
    {
        _fbfDownloading = false;
        if (ok)
        {
            _done = true;
            Console.WriteLine($"[Backup] File-by-file COMPLETE by '{_username}' — User: {userTotal} files ({userSkipped} skipped, {userErrors} errors), Server: {serverTotal} files ({serverSkipped} skipped, {serverErrors} errors)");
        }
        else
        {
            _error = error ?? "Backup failed";
        }
        InvokeAsync(StateHasChanged);
    }

    void CancelFolderBackup()
    {
        Console.WriteLine($"[Backup] File-by-file cancel requested by '{_username}'");
        JS.InvokeVoidAsync("lpmFileBackup.cancel");
    }

    [JSInvokable]
    public void OnFileProgress(int current, int total, string path, int skipped, int errors, bool wasSkipped)
    {
        _fbfCurrent = current;
        _fbfTotal = total;
        _fbfCurrentFile = path;
        _fbfSkipped = skipped;
        _fbfErrors = errors;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnPhaseChanged(string phase)
    {
        _fbfPhase = phase;
        _fbfCurrent = 0;
        _fbfTotal = 0;
        _fbfSkipped = 0;
        _fbfErrors = 0;
        _fbfCurrentFile = "";
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnBackupError(string type, string relPath, string fullPath, string? pcName, string isoTime, string detail)
    {
        DateTime when;
        if (!DateTime.TryParse(isoTime, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.RoundtripKind, out when))
            when = DateTime.UtcNow;
        _errors.Add(new BackupError(
            Type: type ?? "",
            RelPath: relPath ?? "",
            FullPath: string.IsNullOrEmpty(fullPath) ? (relPath ?? "") : fullPath,
            PcName: string.IsNullOrWhiteSpace(pcName) ? null : pcName,
            When: when.ToLocalTime(),
            Detail: detail ?? ""));
        InvokeAsync(StateHasChanged);
    }

    static string ExplanationFor(string type) => type switch
    {
        "http_404"        => "The file was in the backup list but gone from the server when the download ran. Usually means it was deleted, renamed, or moved between building the manifest and fetching the file.",
        "download_failed" => "The fetch → blob → disk-write sequence failed 3 times in a row. Typical causes: non-404 HTTP error (500, 502), network drop, transfer corruption, disk full, or the target folder lost write permission.",
        _                 => "Unknown error type."
    };

    async Task CopyErrorsTable()
    {
        if (_errors.Count == 0) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Type\tWhat & Why\tDetail\tFull Server Path\tPC Name\tWhen");
        foreach (var e in _errors)
        {
            var typeLbl = e.Type == "http_404" ? "HTTP 404 — Not Found" : "Download Failed (3 attempts)";
            string Tsv(string s) => (s ?? "").Replace('\t', ' ').Replace("\r\n", " ").Replace('\n', ' ').Replace('\r', ' ');
            sb.Append(Tsv(typeLbl)).Append('\t')
              .Append(Tsv(ExplanationFor(e.Type))).Append('\t')
              .Append(Tsv(e.Detail)).Append('\t')
              .Append(Tsv(e.FullPath)).Append('\t')
              .Append(Tsv(e.PcName ?? "")).Append('\t')
              .Append(e.When.ToString("yyyy-MM-dd HH:mm:ss"))
              .AppendLine();
        }
        try
        {
            var ok = await JS.InvokeAsync<bool>("lpmCopyText", sb.ToString());
            _copyToast = ok ? "Copied!" : "Copy failed";
        }
        catch
        {
            _copyToast = "Copy failed";
        }
        StateHasChanged();
        _ = Task.Run(async () =>
        {
            try
            {
                await Task.Delay(1800);
                _copyToast = "";
                await InvokeAsync(StateHasChanged);
            }
            catch { /* circuit disposed — ignore */ }
        });
    }

    async Task DownloadErrorsPdf()
    {
        if (_errors.Count == 0 || _pdfBusy) return;
        _pdfBusy = true;
        StateHasChanged();
        try
        {
            var payload = new
            {
                userName = _username,
                errors = _errors.Select(e => new
                {
                    type     = e.Type,
                    relPath  = e.RelPath,
                    fullPath = e.FullPath,
                    pcName   = e.PcName,
                    detail   = e.Detail,
                    when     = e.When.ToUniversalTime().ToString("o")
                })
            };
            await JS.InvokeVoidAsync("lpmBackupErrorsPdf.download", payload);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Backup] PDF download failed: {ex.Message}");
            _error = $"PDF download failed: {ex.Message}";
        }
        finally
        {
            _pdfBusy = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _pollTimer?.Dispose();
        _fbfDotNetRef?.Dispose();
    }

    static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F2} GB";
    }
}
