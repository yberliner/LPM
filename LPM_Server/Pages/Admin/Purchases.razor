                            @if (!string.IsNullOrEmpty(sig))
                            {
                                <img src="@sig" style="max-width:32px;max-height:18px;border-radius:3px;border:1px solid #dee2e6;background:#fff;" alt="Sig" title="Buyer signature" />
                            }
                            else
                            {
                                <span class="badge" style="font-size:0.6rem;padding:2px 4px;background:#fef3c7;color:#92400e;" title="@LS.T("pcs.noSignature")">—</span>
                            }
                        </td>
                        <td class="text-center py-2">
                            @if (bankSt == "all")
                            {
                                <i class="ri-checkbox-circle-fill" style="font-size:1rem;color:#16a34a;" title="All received"></i>
                            }
                            else if (bankSt == "partial")
                            {
                                <i class="ri-indeterminate-circle-line" style="font-size:1rem;color:#d97706;" title="Partial"></i>
                            }
                            else
                            {
                                <span style="font-size:0.7rem;color:#9ca3af;">&mdash;</span>
                            }
                        </td>
                        <td class="text-center py-2">
                            @if (isDeleted)
                            {
                                <span class="badge pu-badge-deleted"><i class="ri-delete-bin-line me-1"></i>@LS.T("purchases.deleted")</span>
                            }
                            else if (isApproved)
                            {
                                <span class="badge pu-badge-approved"><i class="ri-check-line me-1"></i>@LS.T("purchases.approved")</span>
                            }
                            else
                            {
                                <span class="badge pu-badge-pending"><i class="ri-time-line me-1"></i>@LS.T("purchases.pending")</span>
                            }
                        </td>
                        <td class="pe-4 py-1 text-end">
                            <div class="d-flex gap-1 justify-content-end">
                                <button class="btn btn-sm pu-btn-view d-flex align-items-center gap-1"
                                        @onclick="() => ViewPurchase(pid)">
                                    <i class="ri-eye-line"></i>@LS.T("purchases.viewDetails")
                                </button>
                                @if (isDeleted)
                                {
                                    <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1"
                                            style="font-size:0.78rem;border-radius:7px;padding:3px 10px;font-weight:600;"
                                            @onclick="() => RestorePurchase(pid)" disabled="@_busy">
                                        <i class="ri-arrow-go-back-line"></i>@LS.T("purchases.restore")
                                    </button>
                                }
                                else if (!isApproved)
                                {
                                    <button class="btn btn-sm pu-btn-approve d-flex align-items-center gap-1"
                                            @onclick="() => ApprovePurchase(pid)" disabled="@_busy">
                                        <i class="ri-check-line"></i>@LS.T("purchases.approve")
                                    </button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    };

    static string FmtHM(double hours)
    {
        hours = Math.Abs(hours);
        int h = (int)hours;
        int m = (int)Math.Round((hours - h) * 60);
        if (m >= 60) { h++; m = 0; }
        return $"{h}:{m:D2}";
    }
}
