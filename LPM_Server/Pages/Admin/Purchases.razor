@page "/Admin/Purchases"
@attribute [Authorize(Roles = "Admin,Customer")]
@using LPM.Services
@using LPM.Auth
@using Microsoft.AspNetCore.Authorization
@inject PcService PcSvc
@inject UserDb UserDb
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="pu-page p-3 p-md-4">

    @* ── Page Header ── *@
    <div class="d-flex align-items-center mb-3 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold pu-title">@LS.T("purchases.title")</h4>
            <span class="text-muted" style="font-size:0.82rem;">@LS.T("purchases.subtitle")</span>
        </div>
        <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
            @if (_pendingCount > 0)
            {
                <span class="badge rounded-pill text-bg-warning px-3 py-2" style="font-size:0.77rem;">
                    <i class="ri-time-line me-1"></i>@_pendingCount @LS.T("purchases.pendingApproval")
                </span>
            }
            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    @onclick="LoadData" disabled="@_loading">
                <i class="ri-refresh-line @(_loading ? "pu-spin" : "")"></i> @LS.T("common.refresh")
            </button>
        </div>
    </div>

    @* ── Filter bar ── *@
    <div class="card border-0 shadow-sm mb-4 pu-filter-card">
        <div class="card-body py-3 px-4">
            <div class="d-flex align-items-center gap-3 flex-wrap">
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted fw-semibold" style="font-size:0.8rem;">@LS.T("purchases.show")</span>
                    <div class="btn-group pu-seg" role="group">
                        <button type="button"
                                class="btn btn-sm @(!_includeApproved ? "pu-seg-active" : "pu-seg-inactive")"
                                @onclick="SwitchToPendingOnly">
                            <i class="ri-time-line me-1"></i>@LS.T("purchases.pendingOnly")
                        </button>
                        <button type="button"
                                class="btn btn-sm @(_includeApproved ? "pu-seg-active" : "pu-seg-inactive")"
                                @onclick="SwitchToIncludeApproved">
                            <i class="ri-checkbox-circle-line me-1"></i>@LS.T("purchases.includeApproved")
                        </button>
                    </div>
                </div>

                @if (_includeApproved)
                {
                    <div class="pu-filter-divider d-none d-sm-block"></div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        @* Same period-navigation pattern as Salary.razor — Thursday→Wednesday window
                           anchored to a calendar month, with prev/next stepping ±1 month *@
                        <button class="pu-nav-btn" @onclick="PrevPeriod" disabled="@_loading" title="Previous period">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <span class="text-muted" style="font-size:0.8rem;">@LS.T("common.from")</span>
                        <input type="text" class="form-control form-control-sm pu-date-input"
                               placeholder="dd/mm/yy"
                               @bind="_fromDateStr" @bind:event="oninput" />
                        <span class="text-muted" style="font-size:0.8rem;">@LS.T("common.to")</span>
                        <input type="text" class="form-control form-control-sm pu-date-input"
                               placeholder="dd/mm/yy"
                               @bind="_toDateStr" @bind:event="oninput" />
                        <button class="pu-nav-btn" @onclick="NextPeriod"
                                disabled="@(_loading || IsCurrentPeriod)" title="Next period">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                        <button class="btn btn-sm pu-btn-apply d-flex align-items-center gap-1"
                                @onclick="ApplyFilter" disabled="@_loading">
                            <i class="ri-search-line"></i> @LS.T("common.apply")
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_filterError))
                    {
                        <span class="text-danger small d-flex align-items-center gap-1">
                            <i class="ri-error-warning-line"></i>@_filterError
                        </span>
                    }
                }

                <div class="pu-filter-divider d-none d-sm-block"></div>
                <div class="form-check form-switch d-flex align-items-center gap-1 mb-0">
                    <input class="form-check-input" type="checkbox" id="showDeleted"
                           checked="@_includeDeleted" @onchange="ToggleDeleted" />
                    <label class="form-check-label small text-muted" for="showDeleted" style="font-size:0.8rem;">
                        @LS.T("purchases.showDeleted")
                    </label>
                </div>

                @* Org filter — chip group, mirrors Statistics tab *@
                <div class="pu-filter-divider d-none d-sm-block"></div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="fw-semibold" style="font-size:0.8rem;color:#6b7280;">
                        <i class="ri-filter-3-line me-1"></i>Org:
                    </span>
                    <div class="btn-group" role="group" aria-label="Organization filter">
                        <button type="button"
                                class="btn btn-sm rounded-pill me-1 @(_selOrg == 0 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(0)" disabled="@_loading">All</button>
                        <button type="button"
                                class="btn btn-sm rounded-pill me-1 @(_selOrg == 1 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(1)" disabled="@_loading">Haifa</button>
                        <button type="button"
                                class="btn btn-sm rounded-pill @(_selOrg == 2 ? "btn-primary" : "btn-outline-primary")"
                                @onclick="() => SelectOrg(2)" disabled="@_loading">Riga</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <div class="text-muted">@LS.T("common.loading")</div>
        </div>
    }
    else
    {
        @* ── Auditing Purchases Table ── *@
        @if (_auditingPurchases.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header border-0 py-2 px-4 d-flex align-items-center"
                     style="background:linear-gradient(135deg,#15803d,#22c55e);border:none;cursor:pointer;"
                     @onclick="() => _auditingCollapsed = !_auditingCollapsed">
                    <i class="ri-arrow-down-s-line text-white pu-chevron @(_auditingCollapsed ? "pu-chevron-collapsed" : "") me-1"></i>
                    <span class="fw-semibold small text-white">
                        <i class="ri-timer-flash-line me-1"></i>@LS.T("purchases.auditingPurchases")
                    </span>
                    <span class="badge bg-white text-success ms-2">@_auditingPurchases.Count</span>
                </div>
                @if (!_auditingCollapsed)
                {
                    <div class="table-responsive">
                        @PurchaseTableBody(_auditingPurchases)
                    </div>
                }
            </div>
        }

        @* ── Course Purchases Table ── *@
        @if (_coursePurchases.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header border-0 py-2 px-4 d-flex align-items-center"
                     style="background:linear-gradient(135deg,#1e40af,#6366f1);border:none;cursor:pointer;"
                     @onclick="() => _courseCollapsed = !_courseCollapsed">
                    <i class="ri-arrow-down-s-line text-white pu-chevron @(_courseCollapsed ? "pu-chevron-collapsed" : "") me-1"></i>
                    <span class="fw-semibold small text-white">
                        <i class="ri-book-2-line me-1"></i>@LS.T("purchases.coursePurchases")
                    </span>
                    <span class="badge bg-white text-primary ms-2">@_coursePurchases.Count</span>
                </div>
                @if (!_courseCollapsed)
                {
                    <div class="table-responsive">
                        @PurchaseTableBody(_coursePurchases)
                    </div>
                }
            </div>
        }

        @* ── Book Purchases Table ── *@
        @if (_bookPurchases.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header border-0 py-2 px-4 d-flex align-items-center"
                     style="background:linear-gradient(135deg,#92400e,#d97706);border:none;cursor:pointer;"
                     @onclick="() => _bookCollapsed = !_bookCollapsed">
                    <i class="ri-arrow-down-s-line text-white pu-chevron @(_bookCollapsed ? "pu-chevron-collapsed" : "") me-1"></i>
                    <span class="fw-semibold small text-white">
                        <i class="ri-book-open-line me-1"></i>Book Purchases
                    </span>
                    <span class="badge bg-white ms-2" style="color:#92400e;">@_bookPurchases.Count</span>
                </div>
                @if (!_bookCollapsed)
                {
                    <div class="table-responsive">
                        @PurchaseTableBody(_bookPurchases)
                    </div>
                }
            </div>
        }

        @if (_auditingPurchases.Count == 0 && _coursePurchases.Count == 0 && _bookPurchases.Count == 0)
        {
            <div class="pu-empty-block mb-4">
                <i class="ri-check-double-line" style="font-size:1.8rem;color:#16a34a;"></i>
                <div class="fw-semibold mt-2">@LS.T("purchases.noPurchases")</div>
                <div class="small" style="color:#6b7280;">@(_includeApproved ? LS.T("purchases.noPurchases") : LS.T("purchases.allApproved"))</div>
            </div>
        }

        @* ── Total Summary card — per currency, with org breakdown + per-cell drilldown ── *@
        @if (_purchases.Count > 0)
        {
            var allBd = BuildAllOrgsBreakdown();
            var orgBds = BuildPerOrgBreakdowns();
            <div class="pu-summary" @onmouseleave="OnCellLeave">
                <div class="pu-summary-section">
                    <div class="pu-summary-title">
                        <i class="ri-money-dollar-circle-line me-1"></i>Total Summary — All Organizations
                    </div>
                    @if (allBd.Count == 0)
                    {
                        <div class="pu-summary-empty">No earnings in this view</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="pu-summary-table">
                                <thead>
                                    <tr>
                                        <th>Currency</th>
                                        <th class="text-end">Auditing</th>
                                        <th class="text-end">Courses</th>
                                        <th class="text-end">Books</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                @foreach (var kv in allBd)
                                {
                                    var capCurr = kv.Key;
                                    <tr>
                                        <td class="pu-summary-curr">@kv.Key</td>
                                        <td class="text-end pu-cell-hover"
                                            @onmouseenter='(e) => OnCellHover(e, null, "All Organizations", capCurr, "Auditing")'
                                            @onmouseleave="OnCellLeaveCell"
                                            @onclick='() => OnCellClick(null, "All Organizations", capCurr, "Auditing")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Auditing)</td>
                                        <td class="text-end pu-cell-hover"
                                            @onmouseenter='(e) => OnCellHover(e, null, "All Organizations", capCurr, "Courses")'
                                            @onmouseleave="OnCellLeaveCell"
                                            @onclick='() => OnCellClick(null, "All Organizations", capCurr, "Courses")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Courses)</td>
                                        <td class="text-end pu-cell-hover"
                                            @onmouseenter='(e) => OnCellHover(e, null, "All Organizations", capCurr, "Books")'
                                            @onmouseleave="OnCellLeaveCell"
                                            @onclick='() => OnCellClick(null, "All Organizations", capCurr, "Books")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Books)</td>
                                        <td class="text-end fw-bold pu-summary-total-cell pu-cell-hover"
                                            @onmouseenter='(e) => OnCellHover(e, null, "All Organizations", capCurr, "Total")'
                                            @onmouseleave="OnCellLeaveCell"
                                            @onclick='() => OnCellClick(null, "All Organizations", capCurr, "Total")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Total)</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* Per-cell card lives inside the section so cursor on it doesn't trigger mouseleave.
                       Two modes:
                         • Hover (transient): anchored next to the cursor, dismissed on outer mouseleave
                         • Pinned (clicked):  centered on screen with an X close button
                       In hover mode, top/left are clamped via CSS min() so the card never extends past
                       the viewport edges (fixes "card invisible when hovering bottom-row cells"). *@
                    @if (_hoverGroup != null)
                    {
                        double cellSum = 0;
                        foreach (var it in _hoverItems) cellSum += it.Amount;
                        var posStyle = _hoverPinned
                            ? "top:50%; left:50%; transform:translate(-50%,-50%) scale(1);"
                            : $"top:{_hoverY}px; left:{_hoverX}px;";
                        <div class="pu-cell-card is-active @(_hoverPinned ? "is-pinned" : "")" style="@posStyle">
                            <div class="pu-cell-head">
                                <span class="pu-cell-title-org">@_hoverOrgName</span>
                                <i class="ri-arrow-right-s-line pu-cell-arrow"></i>
                                <span class="pu-cell-title-cat">@_hoverCategory</span>
                                <span class="pu-cell-title-curr">@_hoverCurrency</span>
                                @if (_hoverPinned)
                                {
                                    <button type="button" class="pu-cell-close" @onclick="ClosePinned"
                                            aria-label="Close" title="Close">
                                        <i class="ri-close-line"></i>
                                    </button>
                                }
                            </div>
                            <div class="pu-cell-body">
                                @if (_hoverItems.Count == 0)
                                {
                                    <div class="pu-cell-empty"><i class="ri-inbox-line"></i> No items contribute to this cell.</div>
                                }
                                else
                                {
                                    int rowIdx = 0;
                                    @foreach (var item in _hoverItems)
                                    {
                                        var idx = rowIdx++;
                                        <div class="pu-cell-row pu-kind-@item.Kind.ToLower()" style="--row-i: @idx;">
                                            <div class="pu-cell-row-head">
                                                <i class="@PuKindIcon(item.Kind) pu-cell-row-icon"></i>
                                                <span class="pu-cell-row-kind">@item.Kind</span>
                                                <span class="pu-cell-row-date">@item.Date</span>
                                                <span class="pu-cell-row-pc">@item.PcName</span>
                                                <span class="pu-cell-row-amt">@PuCurrSym(item.Currency) @FmtAmt(item.Amount)</span>
                                            </div>
                                        </div>
                                    }
                                    <div class="pu-cell-foot">
                                        <span class="pu-cell-foot-sigma">Σ</span>
                                        <span class="pu-cell-foot-eq">=</span>
                                        <span class="pu-cell-foot-total">@PuCurrSym(_hoverCurrency!) @FmtAmt(cellSum)</span>
                                        <span class="pu-cell-foot-count">(@_hoverItems.Count item@(_hoverItems.Count == 1 ? "" : "s"))</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (orgBds.Count > 0)
                {
                    <div class="pu-summary-section">
                        <div class="pu-summary-title">
                            <i class="ri-building-line me-1"></i>By Organization
                        </div>
                        @foreach (var org in orgBds)
                        {
                            var capOrgId   = org.OrgId;
                            var capOrgName = org.OrgName;
                            <div class="pu-summary-org">
                                <div class="pu-summary-org-name">@org.OrgName</div>
                                <div class="table-responsive">
                                    <table class="pu-summary-table">
                                        <thead>
                                            <tr>
                                                <th>Currency</th>
                                                <th class="text-end">Auditing</th>
                                                <th class="text-end">Courses</th>
                                                <th class="text-end">Books</th>
                                                <th class="text-end">Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                        @foreach (var kv in org.ByCurrency)
                                        {
                                            var capCurr = kv.Key;
                                            <tr>
                                                <td class="pu-summary-curr">@kv.Key</td>
                                                <td class="text-end pu-cell-hover"
                                                    @onmouseenter='(e) => OnCellHover(e, capOrgId, capOrgName, capCurr, "Auditing")'
                                                    @onmouseleave="OnCellLeaveCell"
                                                    @onclick='() => OnCellClick(capOrgId, capOrgName, capCurr, "Auditing")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Auditing)</td>
                                                <td class="text-end pu-cell-hover"
                                                    @onmouseenter='(e) => OnCellHover(e, capOrgId, capOrgName, capCurr, "Courses")'
                                                    @onmouseleave="OnCellLeaveCell"
                                                    @onclick='() => OnCellClick(capOrgId, capOrgName, capCurr, "Courses")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Courses)</td>
                                                <td class="text-end pu-cell-hover"
                                                    @onmouseenter='(e) => OnCellHover(e, capOrgId, capOrgName, capCurr, "Books")'
                                                    @onmouseleave="OnCellLeaveCell"
                                                    @onclick='() => OnCellClick(capOrgId, capOrgName, capCurr, "Books")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Books)</td>
                                                <td class="text-end fw-bold pu-summary-total-cell pu-cell-hover"
                                                    @onmouseenter='(e) => OnCellHover(e, capOrgId, capOrgName, capCurr, "Total")'
                                                    @onmouseleave="OnCellLeaveCell"
                                                    @onclick='() => OnCellClick(capOrgId, capOrgName, capCurr, "Total")'>@PuCurrSym(kv.Key) @FmtAmt(kv.Value.Total)</td>
                                            </tr>
                                        }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@* ── Detail Modal ── *@
@if (_viewDetail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1050;">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-header py-2 px-3" style="background:#fff;border-color:#dee2e6;">
                    <h5 class="modal-title fw-bold mb-0" style="color:#212529;">
                        <i class="ri-shopping-cart-line me-2" style="color:#212529;"></i>@LS.T("purchases.purchaseDetail")
                    </h5>
                    <button type="button" class="btn-close" @onclick="() => _viewDetail = null"></button>
                </div>
                <div class="modal-body p-3" style="background:#fff;color:#212529;">
                    <div class="text-center mb-3">
                        <div style="font-size:1.6rem;font-weight:800;color:#1e3a5f;">@_viewDetail.PcName</div>
                        <div class="small" style="color:#6b7280;">@FormatDate(_viewDetail.PurchaseDate)</div>
                    </div>

                    @* Registrar / Referral (purchase-level) *@
                    <div class="d-flex gap-4 mb-3 small" style="color:#6b7280;">
                        @if (!string.IsNullOrWhiteSpace(_viewDetail.RegistrarName))
                        {
                            <span><i class="ri-user-line me-1"></i>@LS.T("courses.registrar"): <strong style="color:#212529;">@_viewDetail.RegistrarName</strong></span>
                        }
                        @if (!string.IsNullOrWhiteSpace(_viewDetail.ReferralName))
                        {
                            <span><i class="ri-user-received-line me-1"></i>@LS.T("courses.referral"): <strong style="color:#212529;">@_viewDetail.ReferralName</strong></span>
                        }
                    </div>

                    @if (_viewDetail.Items.Count > 0)
                    {
                      <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-3" style="--bs-table-bg:#fff;--bs-table-color:#212529;--bs-table-border-color:#dee2e6;">
                            <thead style="background:#f8f9fa;">
                                <tr>
                                    <th class="small" style="color:#212529;">@LS.T("pcs.type")</th>
                                    <th class="small text-center" style="color:#212529;">@LS.T("pcs.hrsVis")</th>
                                    <th class="small text-end" style="color:#212529;">@LS.T("pcs.amount")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _viewDetail.Items)
                                {
                                    <tr style="color:#212529;">
                                        <td class="small">
                                            @if (item.ItemType == "Course")
                                            {
                                                <span class="badge rounded-pill" style="background:#e0f2fe;color:#0369a1;font-size:.72rem;">
                                                    <i class="ri-book-2-line me-1"></i>@(item.CourseName ?? "Course")
                                                </span>
                                            }
                                            else if (item.ItemType == "Book")
                                            {
                                                <span class="badge rounded-pill" style="background:#fef3c7;color:#92400e;font-size:.72rem;">
                                                    <i class="ri-book-open-line me-1"></i>@(item.BookName ?? "Book")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge rounded-pill" style="background:#f0fdf4;color:#15803d;font-size:.72rem;">
                                                    <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditing")
                                                </span>
                                            }
                                        </td>
                                        <td class="small text-center fw-semibold" style="color:#212529;">
                                            @if (item.ItemType == "Course") { <span style="color:#34d399;">Course</span> }
                                            else if (item.ItemType == "Book") { <span style="color:#d97706;">Book</span> }
                                            else { @($"{(item.HoursBought < 0 ? "-" : "")}{FmtHM(item.HoursBought)}") }
                                        </td>
                                        <td class="small text-end" style="color:#212529;">@(item.AmountPaid > 0 ? $"{CurrSym(_viewDetail.Currency)}{(int)Math.Round(item.AmountPaid)}" : "\u2014")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot style="background:#f8f9fa;">
                                <tr style="color:#212529;">
                                    <td class="small fw-semibold" style="color:#212529;">@LS.T("stats.total")</td>
                                    <td class="small text-center fw-semibold" style="color:#212529;">
                                        @{ var hrs = _viewDetail.Items.Where(i => i.ItemType == "Auditing").Sum(i => i.HoursBought); }
                                        @(hrs != 0 ? $"{(hrs < 0 ? "-" : "")}{FmtHM(hrs)}" : "\u2014")
                                    </td>
                                    <td class="small text-end fw-semibold" style="color:#212529;">
                                        @{ var totalAmt = (int)Math.Round(_viewDetail.Items.Sum(i => i.AmountPaid)); }
                                        @(totalAmt > 0 ? $"{CurrSym(_viewDetail.Currency)}{totalAmt}" : "\u2014")
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                      </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:#6b7280;">@LS.T("purchases.noItems")</div>
                    }

                    @if (!string.IsNullOrEmpty(_viewDetail.Notes))
                    {
                        <div class="mb-3">
                            <label class="small fw-semibold mb-1" style="color:#212529;">@LS.T("pcs.notes")</label>
                            <div class="border rounded p-2 small" style="background:#f8f9fa;color:#212529;">@_viewDetail.Notes</div>
                        </div>
                    }

                    @* Payment Methods *@
                    @if (_viewDetail.PaymentMethods.Count > 0)
                    {
                        <div class="mb-3">
                            <label class="small fw-semibold mb-1" style="color:#212529;">@LS.T("purchases.paymentMethods")</label>
                          <div class="table-responsive">
                            <table class="table table-sm table-bordered mb-0" style="--bs-table-bg:#fff;--bs-table-color:#212529;--bs-table-border-color:#dee2e6;">
                                <thead style="background:#f8f9fa;">
                                    <tr>
                                        <th class="small" style="color:#212529;">@LS.T("purchases.methodType")</th>
                                        <th class="small text-end" style="color:#212529;">@LS.T("pcs.amount")</th>
                                        <th class="small" style="color:#212529;">@LS.T("purchases.paymentDate")</th>
                                        <th class="small text-center" style="color:#212529;">@LS.T("purchases.moneyInBank")</th>
                                        <th class="small" style="color:#212529;">@LS.T("purchases.moneyInBankDate")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var pm in _viewDetail.PaymentMethods)
                                    {
                                        <tr @key="pm.PaymentMethodId" style="color:#212529;@(pm.IsMoneyInBank ? "background:#f0fdf4;" : "")">
                                            <td class="small" style="color:#212529;">
                                                @{
                                                    var (dpmIcon, dpmLabel) = pm.MethodType switch
                                                    {
                                                        "CreditCard" => ("ri-bank-card-line", LS.T("purchases.creditCard")),
                                                        "Check" => ("ri-file-text-line", LS.T("purchases.check")),
                                                        "BankTransfer" => ("ri-exchange-line", LS.T("purchases.bankTransfer")),
                                                        "Credit" => ("ri-wallet-3-line", LS.T("purchases.credit")),
                                                        "Transfer" => ("ri-exchange-funds-line", LS.T("purchases.transfer")),
                                                        "ToBePaid" => ("ri-time-line", LS.T("purchases.toBePaid")),
                                                        _ => ("ri-money-dollar-circle-line", LS.T("purchases.cash"))
                                                    };
                                                }
                                                <i class="@dpmIcon me-1" style="color:#212529;"></i>@dpmLabel
                                            </td>
                                            <td class="small text-end fw-semibold" style="color:#212529;">@(pm.Amount > 0 ? $"{CurrSym(_viewDetail.Currency)}{pm.Amount}" : "\u2014")</td>
                                            <td class="small" style="color:#212529;">@(pm.PaymentDate != null ? FormatDate(pm.PaymentDate) : "\u2014")</td>
                                            <td class="text-center">
                                                @if (pm.MethodType == "ToBePaid" || pm.MethodType == "Credit" || pm.MethodType == "Transfer")
                                                {
                                                    <span class="badge" style="background:@(pm.MethodType == "Credit" ? "#dcfce7" : "#fef3c7");color:@(pm.MethodType == "Credit" ? "#166534" : "#92400e");font-size:.65rem;">N/A</span>
                                                }
                                                else
                                                {
                                                    <input type="checkbox" class="form-check-input"
                                                           checked="@pm.IsMoneyInBank"
                                                           @onchange="() => ToggleMoneyInBank(pm.PaymentMethodId, !pm.IsMoneyInBank)" />
                                                }
                                            </td>
                                            <td class="small" style="color:#6b7280;">@(pm.MoneyInBankDate != null ? FormatDate(pm.MoneyInBankDate) : "\u2014")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                          </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="small fw-semibold mb-1" style="color:#212529;">@LS.T("pcs.signature")</label>
                        @if (!string.IsNullOrEmpty(_viewDetail.SignatureData))
                        {
                            <div class="border rounded p-2 text-center" style="background:#f8f9fa;">
                                <img src="@_viewDetail.SignatureData" style="max-width:300px;max-height:120px;" alt="Signature" />
                            </div>
                        }
                        else
                        {
                            <div class="border rounded p-2 text-center" style="background:#fef3c7;color:#92400e;">
                                <i class="ri-edit-line me-1"></i>@LS.T("pcs.noSignature")
                            </div>
                        }
                    </div>

                    <div class="d-flex gap-3 small" style="color:#6b7280;">
                        @if (!string.IsNullOrEmpty(_viewDetail.CreatedByName))
                        {
                            <span><i class="ri-user-line me-1"></i>@LS.T("purchases.createdBy"): @_viewDetail.CreatedByName</span>
                        }
                        @if (!string.IsNullOrEmpty(_viewDetail.ApprovedByName))
                        {
                            <span><i class="ri-check-line me-1"></i>@LS.T("purchases.approvedBy"): @_viewDetail.ApprovedByName</span>
                        }
                    </div>
                </div>
                <div class="modal-footer py-2 px-3" style="background:#fff;border-color:#dee2e6;">
                    @if (_viewDetail.ApprovedStatus != "Approved")
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => { ApprovePurchase(_viewDetail.PurchaseId); _viewDetail = null; }">
                            <i class="ri-check-line me-1"></i>@LS.T("purchases.approve")
                        </button>
                    }
                    <button class="btn btn-sm btn-secondary" @onclick="() => _viewDetail = null">@LS.T("common.close")</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Toast ── *@
@if (!string.IsNullOrEmpty(_msg))
{
    <div class="position-fixed bottom-0 end-0 p-4" style="z-index:1200;">
        <div class="toast show align-items-center border-0 shadow-lg @(_msgIsError ? "text-bg-danger" : "text-bg-success")"
             role="alert" style="min-width:300px;border-radius:12px;">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2 fw-semibold">
                    <i class="@(_msgIsError ? "ri-error-warning-line" : "ri-checkbox-circle-line") fs-5"></i>
                    @_msg
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick='() => _msg = null'></button>
            </div>
        </div>
    </div>
}

<style>
