    .modal-content,
    .modal-content *:not(.badge):not(.btn):not(.btn-close) { color: #212529 !important; }
    .modal-content .table-light { background-color: #f8f9fa !important; }
    .modal-content .modal-header { background: #fff; border-color: #dee2e6; }
