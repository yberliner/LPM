    .pu-btn-view:hover { background: #2d6a9f; color: #fff; }
    .pu-btn-approve { background: #16a34a; color: #fff; border: none; border-radius: 7px; font-size: 0.78rem; padding: 3px 10px; font-weight: 600; white-space: nowrap; }
    .pu-btn-approve:hover:not(:disabled) { background: #15803d; color: #fff; }

    .pu-spin { display: inline-block; animation: pu-spin-anim 1s linear infinite; }
    @@keyframes pu-spin-anim { to { transform: rotate(360deg); } }

    .pu-flash td { animation: pu-flash-anim 1.2s ease-out; }
    @@keyframes pu-flash-anim {
        0%   { background: #fbbf24; transform: scale(1); }
        25%  { background: #34d399; }
