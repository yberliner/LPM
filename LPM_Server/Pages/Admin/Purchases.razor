    .modal-content .modal-footer { background: #fff; border-color: #dee2e6; }
    .modal-content .bg-light { background-color: #f8f9fa !important; }
    .modal-content .badge { color: inherit !important; }
    .modal-content .btn-close { color: initial !important; filter: none; }
</style>

@code {
    private bool    _includeApproved = false;
    private bool    _includeDeleted = false;
    private string  _fromDateStr = "";
    private string  _toDateStr   = "";
    private string? _filterError;

    private List<PurchaseListItem> _purchases = new();
    private List<PurchaseListItem> _auditingPurchases = new();
    private List<PurchaseListItem> _coursePurchases = new();
    private List<PurchaseListItem> _bookPurchases = new();

    private Dictionary<int, int>   _itemCounts = new();
    private Dictionary<int, string?> _signatures = new();
    private Dictionary<int, List<PurchasePaymentMethodInfo>> _paymentMethodsCache = new();
    private Dictionary<int, List<PurchaseItemInfo>> _itemsCache = new();
    private Dictionary<int, (string? Reg, string? Ref)> _regRefCache = new();
    private PurchaseDetail?        _viewDetail;

    private bool _loading = true;
    private bool _busy;
    private string? _msg;
    private bool _msgIsError;
    private bool _auditingCollapsed = false;
    private bool _courseCollapsed   = false;
    private bool _bookCollapsed    = false;

    static string CurrSym(string code) => code switch { "USD" => "$", "EUR" => "€", _ => "₪" };
    static string WltBg(string code)  => code switch { "USD" => "#e0f2fe", "EUR" => "#d1fae5", _ => "#dbeafe" };
    static string WltFg(string code)  => code switch { "USD" => "#0369a1", "EUR" => "#047857", _ => "#1e40af" };

    // ── Bottom-summary helpers ────────────────────────────────────────────────
    static string PuCurrSym(string code) => CurrSym(code);
    static string FmtAmt(double amt) => Math.Round(amt, MidpointRounding.AwayFromZero).ToString("N0");
    static string PuKindIcon(string kind) => kind switch
    {
        "Auditing" => "ri-timer-flash-line",
        "Courses"  => "ri-book-2-line",
        "Books"    => "ri-book-open-line",
        _          => "ri-circle-line",
    };

    record SumBucket(double Auditing, double Courses, double Books)
    {
        public double Total => Auditing + Courses + Books;
        public bool   HasAny => Auditing != 0 || Courses != 0 || Books != 0;
    }
    record OrgBreakdown(int OrgId, string OrgName, Dictionary<string, SumBucket> ByCurrency);

    /// <summary>Classify a purchase as Auditing / Courses / Books based on which list it landed in.
    /// Falls back to Auditing for anything not in the Course/Book buckets.</summary>
    string KindOf(PurchaseListItem p)
    {
        if (_coursePurchases.Contains(p)) return "Courses";
        if (_bookPurchases.Contains(p))   return "Books";
        return "Auditing";
    }

    Dictionary<string, SumBucket> BuildAllOrgsBreakdown()
    {
        var map = new Dictionary<string, SumBucket>();
        foreach (var p in _purchases.Where(x => !x.IsDeleted))
        {
            var k = KindOf(p);
            var existing = map.GetValueOrDefault(p.Currency, new SumBucket(0, 0, 0));
            map[p.Currency] = k switch
            {
                "Courses" => existing with { Courses  = existing.Courses  + p.TotalAmount },
                "Books"   => existing with { Books    = existing.Books    + p.TotalAmount },
                _         => existing with { Auditing = existing.Auditing + p.TotalAmount },
            };
        }
        return map.Where(kv => kv.Value.HasAny)
                  .OrderBy(kv => kv.Key)
                  .ToDictionary(kv => kv.Key, kv => kv.Value);
    }

    List<OrgBreakdown> BuildPerOrgBreakdowns()
    {
        var byOrg = _purchases.Where(x => !x.IsDeleted)
            .GroupBy(p => (p.OrgId, p.OrgName))
            .Select(g =>
            {
                var byCurr = new Dictionary<string, SumBucket>();
                foreach (var p in g)
                {
                    var k = KindOf(p);
                    var existing = byCurr.GetValueOrDefault(p.Currency, new SumBucket(0, 0, 0));
                    byCurr[p.Currency] = k switch
                    {
                        "Courses" => existing with { Courses  = existing.Courses  + p.TotalAmount },
                        "Books"   => existing with { Books    = existing.Books    + p.TotalAmount },
                        _         => existing with { Auditing = existing.Auditing + p.TotalAmount },
                    };
                }
                return new OrgBreakdown(g.Key.OrgId, g.Key.OrgName,
                    byCurr.Where(kv => kv.Value.HasAny).OrderBy(kv => kv.Key)
                          .ToDictionary(kv => kv.Key, kv => kv.Value));
            })
            .Where(o => o.ByCurrency.Count > 0)
            .OrderBy(o => o.OrgName == "Haifa" ? 0 : o.OrgName == "Riga" ? 1 : 2)
            .ThenBy(o => o.OrgName)
            .ToList();
        return byOrg;
    }

    // ── Per-cell hover state with debounce + DOM-nested card (Salary pattern) ──
    record HoverItem(string Date, string PcName, string Kind, double Amount, string Currency);

    int?    _hoverGroup;       // sentinel — non-null means a card is showing (we use 1)
    int?    _hoverOrgId;       // null = All orgs
    string? _hoverOrgName;
    string? _hoverCurrency;
    string? _hoverCategory;
    double  _hoverX, _hoverY;
    List<HoverItem> _hoverItems = new();
    bool    _hoverPinned;      // true after click — card centers on screen, stays until X clicked

    // Cached viewport dims used to flip the hover card horizontally when the cursor is near
    // the right edge — without this, the card overlaps the cell and you can't click it.
    int _viewportWidth  = 1920;
    int _viewportHeight = 1080;
    bool _viewportRead;

    int _hoverGen;
    const int HoverDwellMs = 100;
    const int CardWidth    = 420;
    const int CardMaxH     = 480;
    const int CursorOffset = 14;
    const int EdgeMargin   = 8;

    async Task OnCellHover(Microsoft.AspNetCore.Components.Web.MouseEventArgs e,
        int? orgId, string orgName, string currency, string category)
    {
        var myGen = ++_hoverGen;
        var clientX = e.ClientX;
        var clientY = e.ClientY;
        try { await Task.Delay(HoverDwellMs); }
        catch (TaskCanceledException) { return; }
        if (myGen != _hoverGen) return;     // a newer hover (or leave) came in — abort

        // Make sure we know the viewport size before computing card position.
        await EnsureViewportSize();
        var (px, py) = ComputeHoverPos(clientX, clientY);

        _hoverGroup    = 1;
        _hoverOrgId    = orgId;
        _hoverOrgName  = orgName;
        _hoverCurrency = currency;
        _hoverCategory = category;
        _hoverX        = px;
        _hoverY        = py;
        _hoverItems    = ComputeCellItems(orgId, currency, category);
        StateHasChanged();
    }

    /// <summary>Position the hover card to the right of the cursor when it fits, and FLIP to
    /// the left side when it doesn't (otherwise the card sits on top of the cell and you
    /// can't click it). Vertically: clamp so the card never extends below the viewport.</summary>
    (double X, double Y) ComputeHoverPos(double cursorX, double cursorY)
    {
        // Horizontal: try right of cursor; if it'd clip, flip to the left of cursor.
        double rightSide = cursorX + CursorOffset;
        double x = (rightSide + CardWidth + EdgeMargin <= _viewportWidth)
            ? rightSide
            : Math.Max(EdgeMargin, cursorX - CursorOffset - CardWidth);

        // Vertical: try below cursor; clamp so card never extends below viewport.
        double belowSide = cursorY + CursorOffset;
        double y = Math.Min(belowSide, Math.Max(EdgeMargin, _viewportHeight - CardMaxH - EdgeMargin));
        return (x, y);
    }

    async Task EnsureViewportSize()
    {
        if (_viewportRead) return;
        try
        {
            _viewportWidth  = await JS.InvokeAsync<int>("eval", "window.innerWidth");
            _viewportHeight = await JS.InvokeAsync<int>("eval", "window.innerHeight");
            _viewportRead = true;
        }
        catch { /* keep defaults — never let the reporter throw */ }
    }

    /// <summary>Cell-level mouseleave: aborts any in-flight dwell timer for this cell. Does NOT
    /// clear the visible card — that happens only when the cursor leaves the .pu-summary
    /// wrapper (so the user can move from a cell to the card without it disappearing).</summary>
    void OnCellLeaveCell() => _hoverGen++;

    void OnCellLeave()
    {
        _hoverGen++;
        if (_hoverPinned) return;     // pinned card stays open until X is clicked
        _hoverGroup = null;
        _hoverItems = new();
    }

    /// <summary>Click on a cell — pins the card centered on screen with an X close button.
    /// Bypasses the dwell debounce (clicks are intentional, no need to wait).</summary>
    void OnCellClick(int? orgId, string orgName, string currency, string category)
    {
        _hoverGen++;                  // abort any pending hover dwell
        _hoverGroup    = 1;
        _hoverOrgId    = orgId;
        _hoverOrgName  = orgName;
        _hoverCurrency = currency;
        _hoverCategory = category;
        _hoverItems    = ComputeCellItems(orgId, currency, category);
        _hoverPinned   = true;
    }

    void ClosePinned()
    {
        _hoverPinned = false;
        _hoverGroup  = null;
        _hoverItems  = new();
    }

    List<HoverItem> ComputeCellItems(int? orgFilter, string currency, string category)
    {
        bool wantAud = category == "Auditing" || category == "Total";
        bool wantCs  = category == "Courses"  || category == "Total";
        bool wantBk  = category == "Books"    || category == "Total";

        var list = new List<HoverItem>();
        foreach (var p in _purchases)
        {
            if (p.IsDeleted) continue;
            if (p.Currency != currency) continue;
            if (orgFilter.HasValue && p.OrgId != orgFilter.Value) continue;
            var k = KindOf(p);
            if (k == "Auditing" && !wantAud) continue;
            if (k == "Courses"  && !wantCs)  continue;
            if (k == "Books"    && !wantBk)  continue;
            list.Add(new HoverItem(p.PurchaseDate, p.PcName, k, p.TotalAmount, p.Currency));
        }
        return list.OrderBy(b => b.Date).ToList();
    }
    private int? _currentPersonId;
    private string _username = "";
    private string _sortCol = "date";
    private bool   _sortAsc = false;

    private int _pendingCount => _purchases.Count(p => p.ApprovedStatus != "Approved" && !p.IsDeleted);

    protected override async Task OnInitializedAsync()
    {
        if (await PermissionsLevels.RedirectIfRestricted(AuthStateProvider, Navigation)) return;
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }
        _username = authState.User.Identity?.Name ?? "";
        _currentPersonId = !string.IsNullOrEmpty(_username) ? PcSvc.GetPersonIdByUsername(_username) : null;
        await LoadData();
    }

    private async Task SwitchToPendingOnly()
    {
        _includeApproved = false;
        _filterError = null;
        await LoadData();
    }

    private void SwitchToIncludeApproved()
    {
        if (_includeApproved) return;
        _includeApproved = true;
        // Seed From/To with the current salary period (matches Salary.razor's behaviour).
        InitPeriod();
    }

    private async Task ApplyFilter()
    {
        _filterError = null;
        if (!TryParsePuDate(_fromDateStr, out var from)) { _filterError = "Enter a valid From date (dd/mm/yy)."; return; }
        if (!TryParsePuDate(_toDateStr,   out var to))   { _filterError = "Enter a valid To date (dd/mm/yy)."; return; }
        if (from > to) { _filterError = "From date must be on or before To date."; return; }
        await LoadData();
    }

    // ── Period navigation (mirrors Salary.razor's Thursday→Wednesday window) ──
    private int _periodYear;
    private int _periodMonth;

    /// <summary>For month M: From = Thursday of the week containing the first Wednesday of M;
    /// To = last Wednesday of M. Same algorithm as Salary.razor.</summary>
    (DateOnly From, DateOnly To) ComputePeriod(int year, int month)
    {
        var firstDay = new DateOnly(year, month, 1);
        var daysToWed = ((int)DayOfWeek.Wednesday - (int)firstDay.DayOfWeek + 7) % 7;
        var firstWed = firstDay.AddDays(daysToWed);
        var from = firstWed.AddDays(-6);

        var lastDay = new DateOnly(year, month, DateTime.DaysInMonth(year, month));
        var daysBackToWed = ((int)lastDay.DayOfWeek - (int)DayOfWeek.Wednesday + 7) % 7;
        var to = lastDay.AddDays(-daysBackToWed);

        return (from, to);
    }

    void InitPeriod()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var (year, month) = ResolveCurrentPeriodMonth(today);
        _periodYear = year;
        _periodMonth = month;
        ApplyPeriod();
    }

    (int Year, int Month) ResolveCurrentPeriodMonth(DateOnly today)
    {
        var year = today.Year;
        var month = today.Month;
        var lastDay = new DateOnly(year, month, DateTime.DaysInMonth(year, month));
        var daysBackToWed = ((int)lastDay.DayOfWeek - (int)DayOfWeek.Wednesday + 7) % 7;
        var lastWed = lastDay.AddDays(-daysBackToWed);
        if (today > lastWed)
        {
            month++;
            if (month > 12) { month = 1; year++; }
        }
        return (year, month);
    }

    void ApplyPeriod()
    {
        var (from, to) = ComputePeriod(_periodYear, _periodMonth);
        _fromDateStr = from.ToString("dd/MM/yy");
        _toDateStr   = to.ToString("dd/MM/yy");
    }

    async Task PrevPeriod()
    {
        _periodMonth--;
        if (_periodMonth < 1) { _periodMonth = 12; _periodYear--; }
        ApplyPeriod();
        await LoadData();
    }

    async Task NextPeriod()
    {
        if (IsCurrentPeriod) return;
        _periodMonth++;
        if (_periodMonth > 12) { _periodMonth = 1; _periodYear++; }
        ApplyPeriod();
        await LoadData();
    }

    bool IsCurrentPeriod
    {
        get
        {
            var (curYear, curMonth) = ResolveCurrentPeriodMonth(DateOnly.FromDateTime(DateTime.Today));
            return _periodYear == curYear && _periodMonth == curMonth;
        }
    }

    /// <summary>Parses a dd/MM/yy string. Falls back to plain TryParse for backwards compat
    /// (so existing yyyy-MM-dd entries still work if any are in localStorage / typed manually).</summary>
    static bool TryParsePuDate(string s, out DateOnly d)
    {
        if (DateOnly.TryParseExact(s, "dd/MM/yy", System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out d)) return true;
        return DateOnly.TryParse(s, out d);
    }

    // Organization filter — 0=All, 1=Haifa, 2=Riga (mirrors Statistics tab)
    private int  _selOrg;
    private int? OrgFilter => _selOrg == 0 ? (int?)null : _selOrg;

    private async Task SelectOrg(int org)
    {
        if (_selOrg == org) return;
        _selOrg = org;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        await Task.Yield();

        DateOnly? from = null, to = null;
        if (_includeApproved && TryParsePuDate(_fromDateStr, out var f)) from = f;
        if (_includeApproved && TryParsePuDate(_toDateStr,   out var t)) to   = t;

        _purchases = PcSvc.GetPurchases(_includeApproved, from, to, _includeDeleted, OrgFilter);

        _itemCounts.Clear();
        _signatures.Clear();
        _paymentMethodsCache.Clear();
        _itemsCache.Clear();
        _regRefCache.Clear();
        foreach (var p in _purchases)
        {
            var detail = PcSvc.GetPurchaseDetail(p.PurchaseId);
            _itemCounts[p.PurchaseId] = detail?.Items.Count ?? 0;
            _signatures[p.PurchaseId] = detail?.SignatureData;
            _paymentMethodsCache[p.PurchaseId] = detail?.PaymentMethods ?? new();
            _itemsCache[p.PurchaseId] = detail?.Items ?? new();
            _regRefCache[p.PurchaseId] = (detail?.RegistrarName, detail?.ReferralName);
        }

        SplitPurchases();
        _loading = false;
    }

    private void SplitPurchases()
    {
        _auditingPurchases = _purchases.Where(p =>
            _itemsCache.GetValueOrDefault(p.PurchaseId)?.Any(i => i.ItemType == "Auditing") == true).ToList();
        _coursePurchases = _purchases.Where(p =>
            _itemsCache.GetValueOrDefault(p.PurchaseId)?.Any(i => i.ItemType == "Course") == true).ToList();
        _bookPurchases = _purchases.Where(p =>
            _itemsCache.GetValueOrDefault(p.PurchaseId)?.Any(i => i.ItemType == "Book") == true).ToList();
    }

    private async Task ToggleDeleted()
    {
        _includeDeleted = !_includeDeleted;
        await LoadData();
    }

    private async Task RestorePurchase(int purchaseId)
    {
        Console.WriteLine($"[Purchases] Restored purchase {purchaseId} by '{_username}'");
        _busy = true;
        PcSvc.RestorePurchase(purchaseId);
        _busy = false;
        await LoadData();
        ShowMsg("Purchase restored.", false);
    }

    private void ApprovePurchase(int purchaseId)
    {
        if (!_currentPersonId.HasValue) return;
        Console.WriteLine($"[Purchases] Approved purchase {purchaseId} by '{_username}'");
        _busy = true;
        PcSvc.ApprovePurchase(purchaseId, _currentPersonId.Value);
        _busy = false;

        var idx = _purchases.FindIndex(p => p.PurchaseId == purchaseId);
        if (idx >= 0)
        {
            if (_includeApproved)
                _purchases[idx] = _purchases[idx] with { ApprovedStatus = "Approved" };
            else
                _purchases.RemoveAt(idx);
        }
        SplitPurchases();
        ShowMsg("Purchase approved.", false);
    }

    private void ViewPurchase(int purchaseId)
    {
        Console.WriteLine($"[Purchases] Viewed purchase {purchaseId} detail by '{_username}'");
        _viewDetail = PcSvc.GetPurchaseDetail(purchaseId);
    }

    private void OpenPurchaseInPcs(int pcId, int purchaseId)
    {
        Navigation.NavigateTo($"/PCs?pcId={pcId}&openPurchase={purchaseId}", forceLoad: false);
    }

    private int GetItemCount(int purchaseId) =>
        _itemCounts.GetValueOrDefault(purchaseId, 0);

    private string GetBankStatus(int purchaseId)
    {
        var pms = _paymentMethodsCache.GetValueOrDefault(purchaseId)?
            .Where(m => m.MethodType != "ToBePaid" && m.MethodType != "Credit" && m.MethodType != "Transfer").ToList();
        if (pms == null || pms.Count == 0) return "none";
        if (pms.All(m => m.IsMoneyInBank)) return "all";
        if (pms.Any(m => m.IsMoneyInBank)) return "partial";
        return "none";
    }

    private void ToggleMoneyInBank(int paymentMethodId, bool newValue)
    {
        Console.WriteLine($"[Purchases] Toggled money-in-bank for paymentMethod {paymentMethodId} to {newValue} by '{_username}'");
        PcSvc.SetMoneyInBank(paymentMethodId, newValue);
        if (_viewDetail != null)
        {
            var pid = _viewDetail.PurchaseId;
            _viewDetail = PcSvc.GetPurchaseDetail(pid);
            if (_viewDetail != null)
                _paymentMethodsCache[pid] = _viewDetail.PaymentMethods;
        }
    }

    private void ShowMsg(string msg, bool isError) { _msg = msg; _msgIsError = isError; }

    private static string FormatDate(string? dateStr) =>
        dateStr != null && DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr ?? "\u2014";

    void SetPurchaseSort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = col == "name"; }
    }

    string GetEffectiveDate(PurchaseListItem p)
    {
        var pms = _paymentMethodsCache.GetValueOrDefault(p.PurchaseId);
        if (pms != null && pms.Count > 0)
        {
            var dates = pms.Where(pm => !string.IsNullOrEmpty(pm.PaymentDate)).Select(pm => pm.PaymentDate!).ToList();
            if (dates.Count > 0) return dates.Min()!;
        }
        return p.PurchaseDate;
    }

    List<PurchaseListItem> SortedPurchases(List<PurchaseListItem> items)
    {
        IEnumerable<PurchaseListItem> q = items;
        q = (_sortCol, _sortAsc) switch
        {
            ("name",    true)  => q.OrderBy(p => p.PcName),
            ("name",    false) => q.OrderByDescending(p => p.PcName),
            ("date",    true)  => q.OrderBy(p => GetEffectiveDate(p)).ThenBy(p => p.PcName),
            ("date",    false) => q.OrderByDescending(p => GetEffectiveDate(p)).ThenBy(p => p.PcName),
            ("hours",   true)  => q.OrderBy(p => p.TotalHours).ThenBy(p => p.PcName),
            ("hours",   false) => q.OrderByDescending(p => p.TotalHours).ThenBy(p => p.PcName),
            ("amount",  true)  => q.OrderBy(p => p.TotalAmount).ThenBy(p => p.PcName),
            ("amount",  false) => q.OrderByDescending(p => p.TotalAmount).ThenBy(p => p.PcName),
            ("created", true)  => q.OrderBy(p => p.CreatedByName ?? "").ThenBy(p => p.PcName),
            ("created", false) => q.OrderByDescending(p => p.CreatedByName ?? "").ThenBy(p => p.PcName),
            ("status",  true)  => q.OrderBy(p => p.ApprovedStatus).ThenBy(p => p.PcName),
            ("status",  false) => q.OrderByDescending(p => p.ApprovedStatus).ThenBy(p => p.PcName),
            _                  => q.OrderByDescending(p => GetEffectiveDate(p))
        };
        return q.ToList();
    }

    RenderFragment SortHeader(string col, string label, string extraClass = "", string? widthPx = null) => __builder =>
    {
        var style = "cursor:pointer;user-select:none;" + (widthPx != null ? $"width:{widthPx};" : "");
        <th class="@extraClass" style="@style" @onclick="() => SetPurchaseSort(col)">
            @label
            @if (_sortCol == col)
            {
                <i class="ri-arrow-@(_sortAsc ? "up" : "down")-s-line ms-1" style="font-size:.7rem;"></i>
            }
        </th>
    };

