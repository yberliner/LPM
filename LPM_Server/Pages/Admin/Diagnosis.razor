    void OnUserSelected(ChangeEventArgs e)
    {
        int.TryParse(e.Value?.ToString(), out var uid);
        _selectedUserId = uid; _userMsg = ""; _newPassword = "";
        _userEditCols = []; _userEditVals = new();
        if (uid == 0) return;

        using var conn = new SqliteConnection(DbCs());
        conn.Open();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT * FROM core_users WHERE Id=@id";
        cmd.Parameters.AddWithValue("@id", uid);
        using var r = cmd.ExecuteReader();
        if (!r.Read()) return;
        for (int i = 0; i < r.FieldCount; i++)
        {
            var col = r.GetName(i);
            if (_hiddenCols.Contains(col)) continue;
            _userEditCols.Add(col);
            var val = r.IsDBNull(i) ? "" : r.GetValue(i).ToString() ?? "";
            _userEditVals[col] = MaskValue(col, val);
        }
    }

    async Task SaveUserFields()
    {
        if (_selectedUserId == 0) return;
        _userBusy = true; _userMsg = "";
        var editableCols = _userEditCols.Where(c => c != "Id" && !_maskCols.Contains(c)).ToList();
