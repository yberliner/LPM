        finally
        {
            _pcfdLoading = false;
        }
    }

    // ── Generic PC table discovery ─────────────────────────────────────────
    // Uses SQLite introspection (PRAGMA table_info / foreign_key_list) so any
    // new table added to the DB with PcId, PersonId, or a FK chain leading to
    // one of those is automatically included — no code change needed.

    /// <summary>
    /// BFS through the FK graph to build a WHERE-clause for every table whose
    /// rows can be filtered down to a single PC.
    /// Seed: tables with a direct PcId or PersonId column.
    /// Propagation: T has FK col → ParentTable.parentCol that is already seeded
    ///   → T filter = "col IN (SELECT parentCol FROM ParentTable WHERE parentFilter)"
    /// </summary>
    static Dictionary<string, string> BuildPcFilterMap(
        List<string> allTables,
        Dictionary<string, List<string>> tableColumns,
        Dictionary<string, List<(string FromCol, string ToTable, string ToCol)>> tableFks)
    {
        var map = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        foreach (var tbl in allTables)
        {
            if (!tableColumns.TryGetValue(tbl, out var cols)) continue;
            if (cols.Any(c => c.Equals("PcId", StringComparison.OrdinalIgnoreCase)))
                map[tbl] = "PcId = @pcid";
            else if (cols.Any(c => c.Equals("PersonId", StringComparison.OrdinalIgnoreCase)))
                map[tbl] = "PersonId = @pcid";
        }

        bool changed = true;
        while (changed)
        {
            changed = false;
            foreach (var tbl in allTables)
            {
                if (map.ContainsKey(tbl)) continue;
                if (!tableFks.TryGetValue(tbl, out var fks)) continue;
                foreach (var (fromCol, toTable, toCol) in fks)
                {
                    if (map.TryGetValue(toTable, out var parentFilter))
                    {
                        map[tbl] = $"{fromCol} IN (SELECT {toCol} FROM \"{toTable}\" WHERE {parentFilter})";
                        changed = true;
                        break;
                    }
                }
            }
        }

        return map;
    }

    /// <summary>
    /// Topological sort (Kahn's) so child tables come before their parents.
    /// Required because DELETE subqueries reference parent tables: deleting a
    /// parent first would make the subquery return nothing for the child.
    /// Edge A → B = "A has FK to B" = "delete A before B".
    /// </summary>
    static List<string> TopoSortForDeletion(
        List<string> tables,
        Dictionary<string, List<(string FromCol, string ToTable, string ToCol)>> tableFks)
    {
        var tableSet = new HashSet<string>(tables, StringComparer.OrdinalIgnoreCase);
        var inDegree = tables.ToDictionary(t => t, _ => 0, StringComparer.OrdinalIgnoreCase);
        var outEdges = tables.ToDictionary(t => t, _ => new List<string>(), StringComparer.OrdinalIgnoreCase);

        foreach (var tbl in tables)
        {
            if (!tableFks.TryGetValue(tbl, out var fks)) continue;
            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            foreach (var (_, toTable, _) in fks)
            {
                if (!tableSet.Contains(toTable)) continue;
                if (string.Equals(tbl, toTable, StringComparison.OrdinalIgnoreCase)) continue;
                if (!seen.Add(toTable)) continue;   // deduplicate multi-FK to same table
                outEdges[tbl].Add(toTable);
                inDegree[toTable]++;
            }
        }

        var queue  = new Queue<string>(tables.Where(t => inDegree[t] == 0).OrderBy(t => t));
        var result = new List<string>();
        while (queue.Count > 0)
        {
            var u = queue.Dequeue();
            result.Add(u);
            foreach (var v in outEdges[u].OrderBy(x => x))
                if (--inDegree[v] == 0) queue.Enqueue(v);
        }
        // Append any remaining (would only happen if there are cycles — shouldn't exist)
        result.AddRange(tables.Where(t => !result.Contains(t, StringComparer.OrdinalIgnoreCase)));
        return result;
    }

    static List<string> GetAllUserTables(SqliteConnection conn)
    {
        var list = new List<string>();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY name";
        using var r = cmd.ExecuteReader();
        while (r.Read()) list.Add(r.GetString(0));
        return list;
    }

    static List<string> GetTableColumns(SqliteConnection conn, string table)
    {
        var cols = new List<string>();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = $"PRAGMA table_info(\"{table}\")";
        using var r = cmd.ExecuteReader();
        while (r.Read()) cols.Add(r["name"].ToString()!);
        return cols;
    }

    static List<(string FromCol, string ToTable, string ToCol)> GetTableFks(SqliteConnection conn, string table)
    {
        var fks = new List<(string, string, string)>();
        using var cmd = conn.CreateCommand();
        cmd.CommandText = $"PRAGMA foreign_key_list(\"{table}\")";
        using var r = cmd.ExecuteReader();
        while (r.Read())
        {
            var from = r["from"].ToString() ?? "";
            var toT  = r["table"].ToString() ?? "";
            var to   = r["to"].ToString() ?? "";
            if (string.IsNullOrEmpty(to)) to = "rowid";
            if (!string.IsNullOrEmpty(from) && !string.IsNullOrEmpty(toT))
                fks.Add((from, toT, to));
        }
        return fks;
    }

    static string PcfdTableIcon(string name) => name switch
    {
        _ when name.StartsWith("core_", StringComparison.OrdinalIgnoreCase) => "ri-database-line",
        _ when name.StartsWith("sess_", StringComparison.OrdinalIgnoreCase) => "ri-calendar-event-line",
        _ when name.StartsWith("cs_",   StringComparison.OrdinalIgnoreCase) => "ri-shield-star-line",
        _ when name.StartsWith("fin_",  StringComparison.OrdinalIgnoreCase) => "ri-bank-card-line",
        _ when name.StartsWith("acad_", StringComparison.OrdinalIgnoreCase) => "ri-book-open-line",
        _ when name.StartsWith("sys_",  StringComparison.OrdinalIgnoreCase) => "ri-settings-3-line",
        _ => "ri-table-line"
    };

    (List<TableData> Tables, List<PcfdFolder> Folders) LoadPcFullData(int pcId)
    {
        var skipCols = new HashSet<string>(StringComparer.OrdinalIgnoreCase) { "PasswordHash" };

        using var conn = new SqliteConnection(DbCs());
        conn.Open();

        var allTables    = GetAllUserTables(conn);
        var tableColumns = allTables.ToDictionary(t => t, t => GetTableColumns(conn, t), StringComparer.OrdinalIgnoreCase);
        var tableFks     = allTables.ToDictionary(t => t, t => GetTableFks(conn, t),     StringComparer.OrdinalIgnoreCase);
        var filterMap    = BuildPcFilterMap(allTables, tableColumns, tableFks);

        var tables = new List<TableData>();
        foreach (var tbl in allTables)
        {
            if (!filterMap.TryGetValue(tbl, out var filter)) continue;
            var cols = new List<string>();
            var rows = new List<List<string>>();
            try
            {
                using var cmd = conn.CreateCommand();
                cmd.CommandText = $"SELECT * FROM \"{tbl}\" WHERE {filter}";
                cmd.Parameters.AddWithValue("@pcid", pcId);
                using var r = cmd.ExecuteReader();
                for (int i = 0; i < r.FieldCount; i++)
                    if (!skipCols.Contains(r.GetName(i))) cols.Add(r.GetName(i));
                while (r.Read())
                {
                    var row = new List<string>();
                    for (int i = 0; i < r.FieldCount; i++)
                        if (!skipCols.Contains(r.GetName(i)))
                        {
                            var val = r.IsDBNull(i) ? "" : r.GetValue(i).ToString() ?? "";
                            row.Add(MaskValue(r.GetName(i), val));
                        }
                    rows.Add(row);
                }
            }
            catch (Exception ex) { cols = [$"Error: {ex.Message}"]; }
            tables.Add(new TableData(tbl, PcfdTableIcon(tbl), cols, rows));
        }

        // Scan PC-Folders for any folder named "{pcId}-*"
        var folders = new List<PcfdFolder>();
        var basePath = FolderSvc.GetPcFoldersRoot();
        if (Directory.Exists(basePath))
        {
            var prefix = $"{pcId}-";
            foreach (var dir in Directory.GetDirectories(basePath)
                         .Where(d => Path.GetFileName(d).StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                         .OrderBy(d => d))
            {
                var files = Directory.EnumerateFiles(dir, "*", SearchOption.AllDirectories)
                    .Select(f => Path.GetRelativePath(dir, f).Replace('\\', '/'))
                    .OrderBy(f => f)
                    .ToList();
                folders.Add(new PcfdFolder(Path.GetFileName(dir), files));
            }
        }

        return (tables, folders);
    }

    async Task ExecuteDeletePc()
    {
        var pcId  = _pcfdPcId;
        var admin = AdminUser();
        _pcfdDeleteStep  = 3;
        _pcfdDeleteError = "";
        StateHasChanged();

        try
        {
            var (rows, files) = await Task.Run(() =>
            {
                Console.WriteLine($"[DeletePC] ====== START — Admin='{admin}' PcId={pcId} ======");
                int totalRows  = 0;
                int totalFiles = 0;

                using var conn = new SqliteConnection(DbCs());
                conn.Open();

                var allTables    = GetAllUserTables(conn);
                var tableColumns = allTables.ToDictionary(t => t, t => GetTableColumns(conn, t), StringComparer.OrdinalIgnoreCase);
                var tableFks     = allTables.ToDictionary(t => t, t => GetTableFks(conn, t),     StringComparer.OrdinalIgnoreCase);
                var filterMap    = BuildPcFilterMap(allTables, tableColumns, tableFks);
                var deleteOrder  = TopoSortForDeletion(filterMap.Keys.ToList(), tableFks);

                // PRAGMA foreign_keys must be set before the transaction begins.
                // We disable it to bypass cross-PC FK constraints (e.g. sess_sessions.AuditorId
                // referencing core_persons for sessions where this PC was the auditor of another PC).
                using (var p = conn.CreateCommand())
                { p.CommandText = "PRAGMA foreign_keys = OFF"; p.ExecuteNonQuery(); }

                using var tx  = conn.BeginTransaction();
                using var cmd = conn.CreateCommand();
                cmd.Transaction = tx;

                foreach (var tbl in deleteOrder)
                {
                    if (!filterMap.TryGetValue(tbl, out var filter)) continue;
                    try
                    {
                        cmd.CommandText = $"DELETE FROM \"{tbl}\" WHERE {filter}";
                        cmd.Parameters.Clear();
                        cmd.Parameters.AddWithValue("@pcid", pcId);
                        var n = cmd.ExecuteNonQuery();
                        if (n > 0)
                        {
                            totalRows += n;
                            Console.WriteLine($"[DeletePC]   {tbl}: {n} row(s) deleted");
                        }
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[DeletePC]   {tbl}: SKIPPED — {ex.Message}");
                    }
                }

                tx.Commit();

                using (var p = conn.CreateCommand())
                { p.CommandText = "PRAGMA foreign_keys = ON"; p.ExecuteNonQuery(); }

                Console.WriteLine($"[DeletePC] DB done — {totalRows} total rows deleted");

                // Delete PC folder(s) from disk
                var basePath = FolderSvc.GetPcFoldersRoot();
                if (Directory.Exists(basePath))
                {
                    var prefix = $"{pcId}-";
                    foreach (var dir in Directory.GetDirectories(basePath)
                                 .Where(d => Path.GetFileName(d).StartsWith(prefix, StringComparison.OrdinalIgnoreCase)))
                    {
                        var count = Directory.EnumerateFiles(dir, "*", SearchOption.AllDirectories).Count();
                        Directory.Delete(dir, recursive: true);
                        totalFiles += count;
                        Console.WriteLine($"[DeletePC]   Deleted folder: {dir} ({count} files)");
                    }
                }

                Console.WriteLine($"[DeletePC] ====== END — Admin='{admin}' PcId={pcId} rows={totalRows} files={totalFiles} ======");
                return (totalRows, totalFiles);
            });

            _pcfdDeletedRows  = rows;
            _pcfdDeletedFiles = files;
            _pcfdDeleteStep   = 4;
            _ = Task.Delay(3500).ContinueWith(_ => InvokeAsync(() =>
            {
                _pcfdDeleteStep = 0;
                _pcfdPcId       = 0;
                _pcfdTables     = [];
                _pcfdFolders    = [];
                LoadPcsRows();
                LoadLiveTables();
                StateHasChanged();
            }));
        }
        catch (Exception ex)
        {
            _pcfdDeleteError = $"Error: {ex.Message}";
            _pcfdDeleteStep  = 2;
            Console.WriteLine($"[DeletePC] FAILED — Admin='{admin}' PcId={pcId}: {ex.Message}");
        }
    }
}

