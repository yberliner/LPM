        {
            _cedbError = $"Failed: {ex.Message}";
            Console.WriteLine($"[Diagnosis] Admin '{admin}' Create Empty DB Copy failed: {ex}");
        }
        finally { _busy = false; LoadLiveTables(); }
    }

    void DoCreate()
    {
        var srcPath  = Config["Database:Path"] ?? "lifepower.db";
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        var dir      = Path.GetDirectoryName(Path.GetFullPath(srcPath)) ?? ".";
        var name     = Path.GetFileNameWithoutExtension(srcPath);
        var destPath = Path.Combine(dir, $"{name}_empty_{timestamp}.db");

        using var src = new SqliteConnection($"Data Source={srcPath}");
        src.Open();
        using var conn = new SqliteConnection($"Data Source={destPath};Pooling=False");
        conn.Open();
        src.BackupDatabase(conn);
        src.Close();
        Console.WriteLine($"[Diagnosis] Copied '{srcPath}' → '{destPath}'");

        using var cmd = conn.CreateCommand();
        cmd.CommandText = "PRAGMA foreign_keys = OFF"; cmd.ExecuteNonQuery();

        foreach (var table in new[]
        {
            "fin_payment_methods", "fin_purchase_items", "fin_purchases", "fin_payments",
            "acad_attendance", "acad_student_courses",
            "sess_folder_summary", "sess_misc_charges", "sess_sessions", "sess_auditors", "sess_meetings",
            "cs_work_log", "cs_reviews", "cs_case_supervisors",
            "sys_weekly_remarks", "sys_auditor_pc_permissions",
            "sys_staff_messages", "sys_staff_pc_list", "sys_trusted_devices",
            "core_user_roles", "core_users", "core_pcs", "core_persons",
        })
        {
            cmd.CommandText = $"DELETE FROM {table}"; cmd.Parameters.Clear();
            try { cmd.ExecuteNonQuery(); }
            catch (Exception ex) { Console.WriteLine($"[Diagnosis] Skipped '{table}': {ex.Message}"); }
        }

        cmd.CommandText = "DELETE FROM sqlite_sequence WHERE name IN " +
            "('core_persons','core_pcs','core_users','sess_sessions','cs_reviews'," +
            "'fin_purchases','fin_purchase_items','fin_payments','fin_payment_methods')";
        try { cmd.ExecuteNonQuery(); } catch { }

        cmd.CommandText = @"
            INSERT INTO core_persons (FirstName, LastName, Phone, Email, DateOfBirth, Gender, Org, Source, Notes, Nick)
            VALUES ('Admin', '', '', '', '', '', NULL, NULL, '', '')";
        cmd.Parameters.Clear(); cmd.ExecuteNonQuery();
        cmd.CommandText = "SELECT last_insert_rowid()";
        var personId = (long)cmd.ExecuteScalar()!;

        cmd.CommandText = "INSERT INTO core_pcs (PcId) VALUES (@pid)";
        cmd.Parameters.Clear(); cmd.Parameters.AddWithValue("@pid", personId);
        try { cmd.ExecuteNonQuery(); } catch { }

        var passwordHash = HashPassword("Admin1992");
        cmd.CommandText = @"
            INSERT INTO core_users
                (PersonId, Username, PasswordHash, StaffRole, UserType, GradeId, AllowAll,
                 IsActive, MustChangePassword, ContactConfirmed)
            VALUES (@pid, 'admin', @h, 'Auditor', 'Admin', NULL, 1, 1, 0, 1)";
        cmd.Parameters.Clear();
        cmd.Parameters.AddWithValue("@pid", personId);
        cmd.Parameters.AddWithValue("@h", passwordHash);
        cmd.ExecuteNonQuery();

        cmd.CommandText = "PRAGMA foreign_keys = ON"; cmd.Parameters.Clear(); cmd.ExecuteNonQuery();
        cmd.CommandText = "PRAGMA journal_mode=DELETE;"; cmd.ExecuteNonQuery();
        Console.WriteLine($"[Diagnosis] Seeded admin user. Empty DB ready at '{destPath}'");
        _resultPath = destPath;
    }

    static string HashPassword(string password)
    {
        const int iterations = 260000;
        byte[] salt = RandomNumberGenerator.GetBytes(16);
        using var kdf = new Rfc2898DeriveBytes(password, salt, iterations, HashAlgorithmName.SHA256);
        byte[] hash = kdf.GetBytes(32);
        return $"pbkdf2_sha256${iterations}${Convert.ToBase64String(salt)}${Convert.ToBase64String(hash)}";
    }
}

