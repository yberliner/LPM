            ("fin_purchase_items",  "ri-list-check",          "ORDER BY PurchaseItemId  DESC", null),
            ("fin_payments",        "ri-bank-card-line",      "ORDER BY PaymentId       DESC", null),
            ("fin_payment_methods", "ri-secure-payment-line", "ORDER BY PaymentMethodId DESC", null)));

        var tAcad = Task.Run(() => Group(
            ("acad_attendance",      "ri-check-double-line", "ORDER BY StudentId       DESC", null),
            ("acad_student_courses", "ri-book-open-line",    "ORDER BY StudentCourseId DESC", null)));

        Task.WaitAll(tCore, tSys, tLkp, tSess, tCs, tFin, tAcad);

        _coreTables  = tCore.Result;
        _sysTables   = tSys.Result;
        _lkpTables   = tLkp.Result;
        // Build PersonId → "FirstName LastName" lookup from core_persons
        var persons = tCore.Result.FirstOrDefault(t => t.Name == "core_persons");
        var personNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (persons != null)
        {
            int pidIdx  = persons.Columns.IndexOf("PersonId");
            int fnIdx   = persons.Columns.IndexOf("FirstName");
            int lnIdx   = persons.Columns.IndexOf("LastName");
            foreach (var r in persons.Rows)
            {
                var pid  = pidIdx >= 0 && pidIdx < r.Count ? r[pidIdx] : "";
                var fn   = fnIdx  >= 0 && fnIdx  < r.Count ? r[fnIdx]  : "";
                var ln   = lnIdx  >= 0 && lnIdx  < r.Count ? r[lnIdx]  : "";
                var name = $"{fn} {ln}".Trim();
                if (!string.IsNullOrEmpty(pid) && !string.IsNullOrEmpty(name))
                    personNames[pid] = name;
            }
        }

        _sessTables  = tSess.Result.Select(t =>
        {
            if (t.Name == "sess_sessions")
            {
                t = MoveColumnAfter(t, "Name", "SessionDate");
                t = AnnotateIdColumn(t, "PcId",      personNames);
                t = AnnotateIdColumn(t, "AuditorId", personNames);
                t = AppendTimeToDate(t, "SessionDate", "CreatedAt");
            }
            else if (t.Name == "sess_questions")
            {
                t = AnnotateIdColumn(t, "AskerId",    personNames);
                t = AnnotateIdColumn(t, "ReplierId",  personNames);
                t = AnnotateIdColumn(t, "ClosedById", personNames);
            }
            return t;
        }).ToList();
        _csTables    = tCs.Result;
        _finTables   = tFin.Result;
        _acadTables  = tAcad.Result;
    }

    // Appends the HH:mm time from a datetime column to a date-only column.
    static TableData AppendTimeToDate(TableData t, string dateCol, string timeSourceCol)
    {
        int dateIdx = t.Columns.IndexOf(dateCol);
        int timeIdx = t.Columns.IndexOf(timeSourceCol);
        if (dateIdx < 0 || timeIdx < 0) return t;
        var rows = t.Rows.Select(row =>
        {
            var r       = new List<string>(row);
            var dateVal = dateIdx < r.Count ? r[dateIdx] : "";
            var timeVal = timeIdx < r.Count ? r[timeIdx] : "";
            if (!string.IsNullOrEmpty(dateVal) && !string.IsNullOrEmpty(timeVal)
                && DateTime.TryParse(timeVal, out var dt))
            {
                r[dateIdx] = $"{dateVal} {dt:HH:mm}";
            }
            return r;
        }).ToList();
        return new TableData(t.Name, t.Icon, t.Columns, rows);
    }

    // Appends " (Name)" to every non-empty value in the given column using the provided id→name map.
    static TableData AnnotateIdColumn(TableData t, string col, Dictionary<string, string> names)
    {
        int idx = t.Columns.IndexOf(col);
        if (idx < 0) return t;
        var rows = t.Rows.Select(row =>
        {
            var r   = new List<string>(row);
            var val = idx < r.Count ? r[idx] : "";
            if (!string.IsNullOrEmpty(val) && names.TryGetValue(val, out var name))
                r[idx] = $"{val} ({name})";
            return r;
        }).ToList();
        return new TableData(t.Name, t.Icon, t.Columns, rows);
    }

    static TableData MoveColumnAfter(TableData t, string colToMove, string afterCol)
    {
        int fromIdx = t.Columns.IndexOf(colToMove);
        int afterIdx = t.Columns.IndexOf(afterCol);
        if (fromIdx < 0 || afterIdx < 0 || fromIdx == afterIdx + 1) return t;

        var cols = new List<string>(t.Columns);
        cols.RemoveAt(fromIdx);
        int insertAt = cols.IndexOf(afterCol) + 1;
        cols.Insert(insertAt, colToMove);

        var rows = t.Rows.Select(row =>
        {
            var r = new List<string>(row);
            var val = fromIdx < r.Count ? r[fromIdx] : "";
            r.RemoveAt(fromIdx);
            r.Insert(Math.Min(insertAt, r.Count), val);
            return r;
        }).ToList();

        return new TableData(t.Name, t.Icon, cols, rows);
    }

    static readonly HashSet<string> _maskCols =
        new(StringComparer.OrdinalIgnoreCase) { "TotpSecret" };

    static string MaskValue(string colName, string val) =>
        _maskCols.Contains(colName) && val.Length > 8 ? val[..8] + "...." : val;

    TableData Load(SqliteConnection conn, string table, string icon,
                   string orderBy = "", string[]? skipCols = null)
    {
        var skip = new HashSet<string>(skipCols ?? [], StringComparer.OrdinalIgnoreCase);
        var cols = new List<string>();
        var rows = new List<List<string>>();
        try
        {
            using var cmd = conn.CreateCommand();
            cmd.CommandText = $"SELECT * FROM {table} {orderBy}";
            using var r = cmd.ExecuteReader();
            for (int i = 0; i < r.FieldCount; i++)
                if (!skip.Contains(r.GetName(i))) cols.Add(r.GetName(i));
            while (r.Read())
            {
                var row = new List<string>();
                for (int i = 0; i < r.FieldCount; i++)
                    if (!skip.Contains(r.GetName(i)))
                    {
                        var val = r.IsDBNull(i) ? "" : r.GetValue(i).ToString() ?? "";
                        row.Add(MaskValue(r.GetName(i), val));
                    }
                rows.Add(row);
            }
        }
        catch (Exception ex) { cols = [$"Error: {ex.Message}"]; }
        return new TableData(table, icon, cols, rows);
    }

