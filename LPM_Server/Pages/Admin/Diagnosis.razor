        var targetUser   = _userList.FirstOrDefault(u => u.Id == _selectedUserId)?.Username ?? _selectedUserId.ToString();
        var admin        = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                var setClauses = editableCols.Select((c, i) => $"{c}=@p{i}");
                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                using var cmd = conn.CreateCommand();
                cmd.CommandText = $"UPDATE core_users SET {string.Join(", ", setClauses)} WHERE Id=@id";
                for (int i = 0; i < editableCols.Count; i++)
                    cmd.Parameters.AddWithValue($"@p{i}",
                        string.IsNullOrEmpty(editableVals[i]) ? DBNull.Value : (object)editableVals[i]);
                cmd.Parameters.AddWithValue("@id", _selectedUserId);
                cmd.ExecuteNonQuery();
                Console.WriteLine($"[Diagnosis] Admin '{admin}' updated core_users user '{targetUser}' (Id={_selectedUserId}): " +
                    string.Join(", ", editableCols.Select((c, i) => $"{c}='{editableVals[i]}'")));
