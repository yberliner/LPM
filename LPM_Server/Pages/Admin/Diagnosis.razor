        }
    }

    // ── Table loading ──────────────────────────────────────────────────────
    // Each group runs in its own Task with its own SQLite connection so all 7
    // groups are read in parallel (SQLite supports concurrent readers).
    void LoadLiveTables()
    {
        var cs = DbCs();

        // helper: open a fresh connection, load every item in the group, return the list
        List<TableData> Group(params (string t, string icon, string order, string[]? skip)[] items)
        {
            using var conn = new SqliteConnection(cs);
            conn.Open();
            var list = new List<TableData>(items.Length);
            foreach (var (t, icon, order, skip) in items)
                list.Add(Load(conn, t, icon, order, skip));
            return list;
        }

        var tCore = Task.Run(() => Group(
            ("core_users",   "ri-user-settings-line",  "ORDER BY Id",       new[]{"PasswordHash"}),
            ("core_persons", "ri-contacts-line",        "ORDER BY PersonId", null),
            ("core_pcs",     "ri-computer-line",        "ORDER BY PcId",     null)));

        var tSys = Task.Run(() => Group(
            ("sys_staff_pc_list",   "ri-shield-check-line",   "ORDER BY Id",        null),
            ("sys_staff_messages",  "ri-message-2-line",      "ORDER BY Id",        null),
            ("sys_weekly_remarks",  "ri-calendar-check-line", "ORDER BY Id",        null),
            ("sys_trusted_devices", "ri-device-line",         "ORDER BY CreatedAt", null),
            ("sys_shrunk_files",    "ri-file-reduce-line",    "ORDER BY Id DESC",   null),
            ("sys_activity_log",    "ri-history-line",        "ORDER BY Id DESC",   null)));

        var tLkp = Task.Run(() => Group(
            ("lkp_grades",           "ri-medal-line",     "ORDER BY SortOrder",       null),
            ("lkp_courses",          "ri-book-line",      "ORDER BY CourseId",         null),
            ("lkp_cs_status",        "ri-flag-line",      "ORDER BY SortOrder",        null),
            ("lkp_folder_items",     "ri-folder-line",    "ORDER BY Section, ItemId",  null),
            ("lkp_organizations",    "ri-building-line",  "ORDER BY OrgId",            null),
            ("lkp_referral_sources", "ri-link-m",         "ORDER BY ReferralId",       null),
            ("lkp_shortcuts",        "ri-keyboard-line",  "ORDER BY Id",               null),
            ("lkp_books",            "ri-book-open-line", "ORDER BY BookId",           null)));

        var tSess = Task.Run(() => Group(
            ("sess_sessions",       "ri-calendar-event-line", "ORDER BY SessionId       DESC", null),
            ("sess_misc_charges",   "ri-coins-line",          "ORDER BY MiscChargeId    DESC", null),
            ("sess_folder_summary", "ri-file-text-line",      "ORDER BY Id              DESC", null),
            ("sess_meetings",       "ri-time-line",           "ORDER BY MeetingId       DESC", null),
            ("sess_next_cs",        "ri-file-edit-line",      "ORDER BY Id              DESC", null),
            ("sess_completions",    "ri-trophy-line",         "ORDER BY Id              DESC", null),
            ("sess_questions",      "ri-question-line",       "ORDER BY SessionId       DESC", null)));

        var tCs = Task.Run(() => Group(
            ("cs_reviews",          "ri-shield-star-line", "ORDER BY CsReviewId      DESC", null),
            ("cs_work_log",         "ri-todo-line",        "ORDER BY CsWorkLogId     DESC", null),
