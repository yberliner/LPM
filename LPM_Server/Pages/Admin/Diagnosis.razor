    // ── Recent files methods ───────────────────────────────────────────────
    void LoadRecentFiles()
    {
        var basePath = Path.Combine(Directory.GetCurrentDirectory(), "PC-Folders");
        var cutoff   = DateTime.Now.AddDays(-_recentDays);
        _recentGroups = [];
        if (!Directory.Exists(basePath)) return;

        var groups = new Dictionary<string, List<RecentFile>>(StringComparer.OrdinalIgnoreCase);
        foreach (var file in Directory.EnumerateFiles(basePath, "*", SearchOption.AllDirectories))
        {
            // skip backup/temp dirs
            var rel = Path.GetRelativePath(basePath, file);
            var parts = rel.Split(Path.DirectorySeparatorChar);
            if (parts.Any(p => p.StartsWith("_", StringComparison.Ordinal))) continue;

            var modified = File.GetLastWriteTime(file);
            if (modified < cutoff) continue;

            var pcName  = parts[0];
            var relPath = string.Join("/", parts.Skip(1));
            if (!groups.ContainsKey(pcName)) groups[pcName] = [];
            groups[pcName].Add(new(file, relPath, modified, new FileInfo(file).Length));
        }

        _recentGroups = groups
            .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
            .Select(g => new PcRecentGroup(g.Key,
                g.Value.OrderByDescending(f => f.Modified).ToList()))
            .ToList();
    }

