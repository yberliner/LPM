    // ── Delete Session ─────────────────────────────────────────────────────
    void OpenDeleteSessionModal(string pkVal, TableData table, List<string> row)
    {
        _delSessInfo  = null;
        _delSessError = "";
        _delSessModal = true;

        if (!int.TryParse(pkVal, out var sessionId)) return;

        // Read PcId and Name from the row already loaded in memory
        int pcIdIdx   = table.Columns.IndexOf("PcId");
        int nameIdx   = table.Columns.IndexOf("Name");
        // Strip display annotation e.g. "94 (Yaniv Berliner)" → "94"
        var pcIdRaw = (row.ElementAtOrDefault(pcIdIdx) ?? "").Split(' ')[0];
        int pcId    = int.TryParse(pcIdRaw, out var p) ? p : 0;
        string sessName = nameIdx >= 0 ? (row.ElementAtOrDefault(nameIdx) ?? "") : "";

        Task.Run(() =>
        {
            var cs = DbCs();
            var fkTables = new List<DelSessFkTable>();

            // FK tables that reference sess_sessions.SessionId
            foreach (var (tbl, idCol) in new[]
            {
                ("cs_reviews",          "CsReviewId"),
                ("sess_folder_summary", "Id"),
                ("sess_next_cs",        "Id"),
                ("sess_questions",      "SessionId"),
            })
            {
                var cols = new List<string>();
                var rows = new List<List<string>>();
                try
                {
                    using var conn2 = new SqliteConnection(cs);
                    conn2.Open();
                    using var cmd2 = conn2.CreateCommand();
                    cmd2.CommandText = $"SELECT * FROM {tbl} WHERE SessionId = @sid";
                    cmd2.Parameters.AddWithValue("@sid", sessionId);
                    using var r = cmd2.ExecuteReader();
                    for (int i = 0; i < r.FieldCount; i++) cols.Add(r.GetName(i));
                    while (r.Read())
                    {
                        var rr = new List<string>();
                        for (int i = 0; i < r.FieldCount; i++)
                            rr.Add(r.IsDBNull(i) ? "" : r.GetValue(i)?.ToString() ?? "");
                        rows.Add(rr);
                    }
                }
                catch { }
                fkTables.Add(new DelSessFkTable(tbl, cols, rows));
            }

            // Find session files on disk
            var files = new List<string>();
            if (!string.IsNullOrWhiteSpace(sessName))
            {
                foreach (var finder in new Func<int, string?>[] {
                    id => FolderSvc.FindPcFolder(id),
                    id => FolderSvc.FindSoloPcFolder(id) })
                {
                    var folder = pcId > 0 ? finder(pcId) : null;
                    if (folder == null) continue;
                    var wsPath = Path.Combine(folder, "WorkSheets");
                    if (!Directory.Exists(wsPath)) continue;
                    var nameNoExt = Path.GetFileNameWithoutExtension(sessName);
                    foreach (var f in Directory.GetFiles(wsPath, "*.pdf"))
                    {
                        var fn = Path.GetFileNameWithoutExtension(f);
                        if (string.Equals(fn, nameNoExt, StringComparison.OrdinalIgnoreCase) ||
                            fn.StartsWith(nameNoExt + "_att_", StringComparison.OrdinalIgnoreCase))
                        {
                            files.Add(f);
                        }
                    }
                }
            }

            _delSessInfo = new DelSessInfo(sessionId, pcId, sessName, fkTables, files);
            InvokeAsync(StateHasChanged);
        });
    }

    async Task ExecuteDeleteSession()
    {
        if (_delSessInfo == null) return;
        _delSessBusy  = true;
        _delSessError = "";
        var info  = _delSessInfo;
        var admin = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                Console.WriteLine($"[DeleteSession] ====== START — Admin='{admin}' SessionId={info.SessionId} PcId={info.PcId} Name='{info.SessionName}' ======");

                // ── Backup files to _deleted_sessions before deleting ──────────
                var pcFoldersRoot  = FolderSvc.GetPcFoldersRoot();
                var backupRoot     = Path.Combine(pcFoldersRoot, "_deleted_sessions");
                var backupFolder   = Path.Combine(backupRoot,
                    $"{info.SessionId}_{DateTime.Now:yyyyMMdd_HHmmss}");

                // Purge backup subfolders older than 10 days
                if (Directory.Exists(backupRoot))
                {
                    foreach (var old in Directory.GetDirectories(backupRoot))
                    {
                        try
                        {
                            if (Directory.GetCreationTime(old) < DateTime.Now.AddDays(-10))
                            {
                                Directory.Delete(old, recursive: true);
                                Console.WriteLine($"[DeleteSession]   BACKUP PURGED (>10 days): {old}");
                            }
                        }
                        catch (Exception ex)
                        {
                            Console.WriteLine($"[DeleteSession]   BACKUP PURGE ERROR: {old} — {ex.Message}");
                        }
                    }
                }

                // Copy files to backup folder
                Console.WriteLine($"[DeleteSession] Files to backup+delete: {info.Files.Count}");
                if (info.Files.Count > 0)
                {
                    Directory.CreateDirectory(backupFolder);
                    Console.WriteLine($"[DeleteSession]   Backup folder: {backupFolder}");
                }
                foreach (var f in info.Files)
                {
                    try
                    {
                        var dest = Path.Combine(backupFolder, Path.GetFileName(f));
                        File.Copy(f, dest, overwrite: true);
                        Console.WriteLine($"[DeleteSession]   FILE BACKED UP: {f} → {dest}");
                        File.Delete(f);
                        Console.WriteLine($"[DeleteSession]   FILE DELETED: {f}");
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[DeleteSession]   FILE ERROR (skipped): {f} — {ex.Message}");
                    }
                }

                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                using var cmd = conn.CreateCommand();

                // Delete FK rows — log each row using the data already loaded in the modal
                foreach (var fkTbl in info.FkTables)
                {
                    Console.WriteLine($"[DeleteSession] Table {fkTbl.Table}: {fkTbl.Rows.Count} row(s) to delete");
                    foreach (var row in fkTbl.Rows)
                    {
                        var rowDesc = string.Join(", ", fkTbl.Cols.Zip(row, (c, v) => $"{c}={v}"));
                        Console.WriteLine($"[DeleteSession]   ROW: {rowDesc}");
                    }
                    cmd.CommandText = $"DELETE FROM {fkTbl.Table} WHERE SessionId = @sid";
                    cmd.Parameters.Clear();
                    cmd.Parameters.AddWithValue("@sid", info.SessionId);
                    var n = cmd.ExecuteNonQuery();
                    Console.WriteLine($"[DeleteSession]   → {n} row(s) deleted from {fkTbl.Table}");
                }

                // Delete the session itself last
                cmd.CommandText = "DELETE FROM sess_sessions WHERE SessionId = @sid";
                cmd.Parameters.Clear();
                cmd.Parameters.AddWithValue("@sid", info.SessionId);
                cmd.ExecuteNonQuery();
                Console.WriteLine($"[DeleteSession]   ROW: SessionId={info.SessionId}, PcId={info.PcId}, Name='{info.SessionName}'");
                Console.WriteLine($"[DeleteSession]   → 1 row deleted from sess_sessions");
                Console.WriteLine($"[DeleteSession] ====== END — Admin='{admin}' SessionId={info.SessionId} ======");
            });

            _delSessModal = false;
            _delSessInfo  = null;
            LoadLiveTables();
        }
        catch (Exception ex)
        {
            _delSessError = $"Error: {ex.Message}";
            Console.WriteLine($"[Diagnosis] Admin '{admin}' failed deleting session {info.SessionId}: {ex.Message}");
        }
        finally { _delSessBusy = false; }
    }

    // ── DB Integrity Check ─────────────────────────────────────────────────
    async Task RunIntegrityCheck()
    {
        _integrityChecking        = true;
        _integrityMsg             = "";
        _orphans                  = [];
        _pendingOrphanDelete      = [];
        _integrityProgressCurrent = 0;
        _integrityProgressTotal   = 0;
        _integrityProgressTable   = "";
        try
        {
            var cs   = DbCs();
            var list = new List<OrphanRow>();

            // Step 1: load table list + FK defs (fast, no UI update needed)
            List<string> tables;
            var fkMap = new Dictionary<string, List<(string FromCol, string ToTable, string ToCol)>>();
            await Task.Run(() =>
            {
                using var conn = new SqliteConnection(cs);
                conn.Open();
                tables = new List<string>();
                using (var cmd = conn.CreateCommand())
                {
                    cmd.CommandText = "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%' ORDER BY name";
                    using var r = cmd.ExecuteReader();
                    while (r.Read()) tables.Add(r.GetString(0));
                }
                foreach (var tbl in tables)
                {
                    var fks = new List<(string, string, string)>();
                    using var fkCmd = conn.CreateCommand();
                    fkCmd.CommandText = $"PRAGMA foreign_key_list(\"{tbl}\")";
                    using var fr = fkCmd.ExecuteReader();
                    while (fr.Read())
                    {
                        var from = fr["from"]?.ToString()  ?? "";
                        var toT  = fr["table"]?.ToString() ?? "";
                        var to   = fr["to"]?.ToString()    ?? "";
                        if (!string.IsNullOrEmpty(from) && !string.IsNullOrEmpty(toT))
                        {
                            if (string.IsNullOrEmpty(to)) to = "rowid";
                            fks.Add((from, toT, to));
                        }
                    }
                    if (fks.Count > 0) fkMap[tbl] = fks;
                }
            });

            // tables is assigned inside the lambda; capture it
            tables = fkMap.Keys
                .Concat(fkMap.Values.SelectMany(v => v.Select(x => x.ToTable)))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            // Re-fetch full table list for existence checks
            List<string> allTables = [];
            await Task.Run(() =>
            {
                using var conn = new SqliteConnection(cs);
                conn.Open();
                using var cmd = conn.CreateCommand();
                cmd.CommandText = "SELECT name FROM sqlite_master WHERE type='table' AND name NOT LIKE 'sqlite_%'";
                using var r = cmd.ExecuteReader();
                while (r.Read()) allTables.Add(r.GetString(0));
            });

            // Step 2: scan each table with FK defs, updating progress per table
            var tablesWithFks = fkMap.Keys.ToList();
            _integrityProgressTotal = tablesWithFks.Count;
            await InvokeAsync(StateHasChanged);

            foreach (var tbl in tablesWithFks)
            {
                _integrityProgressTable   = tbl;
                await InvokeAsync(StateHasChanged);

                var fks = fkMap[tbl];
                var tableOrphans = await Task.Run(() =>
                {
                    var found = new List<OrphanRow>();
                    using var conn = new SqliteConnection(cs);
                    conn.Open();
                    foreach (var (fromCol, toTable, toCol) in fks)
                    {
                        if (!allTables.Contains(toTable, StringComparer.OrdinalIgnoreCase)) continue;
                        var toColResolved = toCol == "rowid" ? "rowid" : toCol;
                        try
                        {
                            using var cmd = conn.CreateCommand();
                            cmd.CommandText = $@"
                                SELECT rowid, ""{fromCol}"" FROM ""{tbl}""
                                WHERE ""{fromCol}"" IS NOT NULL
                                  AND CAST(""{fromCol}"" AS TEXT) NOT IN
                                      (SELECT CAST(""{toColResolved}"" AS TEXT) FROM ""{toTable}"")";
                            using var or = cmd.ExecuteReader();
                            while (or.Read())
                            {
                                var rowId   = or.IsDBNull(0) ? 0L : or.GetInt64(0);
                                var fkValue = or.IsDBNull(1) ? "" : or.GetValue(1)?.ToString() ?? "";
                                found.Add(new OrphanRow(tbl, rowId, fromCol, fkValue, toTable, toColResolved));
                            }
                        }
                        catch { /* skip */ }
                    }
                    return found;
                });

                list.AddRange(tableOrphans);
                _integrityProgressCurrent++;
                await InvokeAsync(StateHasChanged);
            }

            _orphans = list;
            _integrityMsg = list.Count == 0
                ? "All FK references are valid — no orphans found."
                : $"Found {list.Count} orphan row{(list.Count != 1 ? "s" : "")} across {list.Select(o => o.Table).Distinct().Count()} table{(list.Select(o => o.Table).Distinct().Count() != 1 ? "s" : "")}.";
        }
        catch (Exception ex)
        {
            _integrityMsg = $"Error: {ex.Message}";
        }
        finally { _integrityChecking = false; }
    }

    static string FetchRowDesc(SqliteConnection conn, string table, long rowId)
    {
        using var cmd = conn.CreateCommand();
        cmd.CommandText = $"SELECT * FROM \"{table}\" WHERE rowid = @rid";
        cmd.Parameters.AddWithValue("@rid", rowId);
        using var r = cmd.ExecuteReader();
        if (!r.Read()) return $"rowid={rowId} (not found)";
        var parts = new List<string>();
        for (int i = 0; i < r.FieldCount; i++)
            parts.Add($"{r.GetName(i)}={( r.IsDBNull(i) ? "NULL" : r.GetValue(i))}");
        return string.Join(", ", parts);
    }

    async Task DeleteOrphan(OrphanRow orphan)
    {
        _pendingOrphanDelete.Remove((orphan.Table, orphan.RowId));
        var admin = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                var rowDesc = FetchRowDesc(conn, orphan.Table, orphan.RowId);
                using var cmd = conn.CreateCommand();
                cmd.CommandText = $"DELETE FROM \"{orphan.Table}\" WHERE rowid = @rid";
                cmd.Parameters.AddWithValue("@rid", orphan.RowId);
                cmd.ExecuteNonQuery();
                Console.WriteLine($"[Diagnosis] Admin '{admin}' deleted orphan from {orphan.Table}: {rowDesc}");
            });
            _orphans.Remove(orphan);
            _integrityMsg = _orphans.Count == 0
                ? "All orphans deleted."
                : $"{_orphans.Count} orphan row{(_orphans.Count != 1 ? "s" : "")} remaining.";
        }
        catch (Exception ex)
        {
            _integrityMsg = $"Error deleting orphan: {ex.Message}";
        }
    }

    async Task DeleteAllOrphans()
    {
        var toDelete = _orphans.ToList();
        var admin    = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                Console.WriteLine($"[Diagnosis] Admin '{admin}' deleting all {toDelete.Count} orphan(s)");
                using var cmd = conn.CreateCommand();
                foreach (var o in toDelete)
                {
                    var rowDesc = FetchRowDesc(conn, o.Table, o.RowId);
                    cmd.CommandText = $"DELETE FROM \"{o.Table}\" WHERE rowid = @rid";
                    cmd.Parameters.Clear();
                    cmd.Parameters.AddWithValue("@rid", o.RowId);
                    try
                    {
                        cmd.ExecuteNonQuery();
                        Console.WriteLine($"[Diagnosis] Admin '{admin}' deleted orphan from {o.Table}: {rowDesc}");
                    }
                    catch (Exception ex)
                    {
                        Console.WriteLine($"[Diagnosis] Warning: could not delete orphan from {o.Table} rowid={o.RowId}: {ex.Message}");
                    }
                }
            });
            _orphans             = [];
            _pendingOrphanDelete = [];
            _integrityMsg        = "All orphans deleted.";
        }
        catch (Exception ex)
        {
            _integrityMsg = $"Error: {ex.Message}";
        }
    }

    static string HashPassword(string password)
    {
        const int iterations = 260000;
        byte[] salt = RandomNumberGenerator.GetBytes(16);
        using var kdf = new Rfc2898DeriveBytes(password, salt, iterations, HashAlgorithmName.SHA256);
        byte[] hash = kdf.GetBytes(32);
        return $"pbkdf2_sha256${iterations}${Convert.ToBase64String(salt)}${Convert.ToBase64String(hash)}";
    }

