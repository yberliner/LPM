@page "/Admin/Diagnosis"
@attribute [Authorize(Roles = "Admin")]
@implements IDisposable
@using System.Security.Cryptography
@using System.Security.Claims
@using Microsoft.Data.Sqlite
@inject IConfiguration Config
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@inject LPM.Services.PdfShrinkService PdfShrinkSvc
@inject LPM.Services.FolderService FolderSvc
@inject LPM.Services.UserActivityService ActivitySvc
@inject IJSRuntime JS

<PageTitle>Diagnosis — LPM</PageTitle>

@if (_pageLoading)
{
    <div style="position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,.55);
                display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;
                backdrop-filter:blur(3px);">
        <div style="background:#1e293b;border-radius:16px;padding:32px 48px;
                    box-shadow:0 24px 64px rgba(0,0,0,.5);display:flex;flex-direction:column;
                    align-items:center;gap:14px;min-width:220px;">
            <div class="spinner-border" style="width:2.4rem;height:2.4rem;border-width:3px;color:#60a5fa;" role="status"></div>
            <div style="color:#e2e8f0;font-size:.95rem;font-weight:600;letter-spacing:.01em;">Loading Diagnosis…</div>
            <div style="color:#475569;font-size:.75rem;">Reading database tables</div>
        </div>
    </div>
}

<div class="diag-danger-banner">
    <i class="ri-error-warning-fill diag-danger-icon"></i>
    <div>
        <div class="diag-danger-title">⚠ Do not change anything in this page without contacting Yaniv first!</div>
        <div class="diag-danger-sub">Modifying data here directly affects the live server and database. Incorrect changes can cause data loss or system failures.</div>
    </div>
    <i class="ri-error-warning-fill diag-danger-icon"></i>
</div>

<div class="container-fluid py-4" style="max-width:960px;@(_pageLoading ? "pointer-events:none;filter:blur(2px);opacity:.4;" : "")">

    @* ── Tab Navigation ── *@
    <ul class="nav nav-tabs diag-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(_diagTab == "db" ? "active" : "")" @onclick='() => _diagTab = "db"' href="javascript:void(0)">
                <i class="ri-database-2-line me-1"></i>Database
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(_diagTab == "integrity" ? "active" : "")" @onclick='() => _diagTab = "integrity"' href="javascript:void(0)">
                <i class="ri-shield-check-line me-1"></i>DB Check Integrity
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(_diagTab == "pcfd" ? "active" : "")" @onclick='() => _diagTab = "pcfd"' href="javascript:void(0)">
                <i class="ri-user-search-line me-1"></i>PC Full Data
            </a>
        </li>
    </ul>

    @if (_diagTab == "db")
    {

    @* ── User Activity Monitor ── *@
    <div class="diag-activity-card mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2"
             style="cursor:pointer;user-select:none;" @onclick="() => _activityExpanded = !_activityExpanded">
            <div class="d-flex align-items-center gap-2">
                <i class="ri-group-line" style="font-size:1.2rem;color:#94a3b8;"></i>
                <span style="font-weight:700;font-size:1rem;color:#e2e8f0;">User Activity</span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
                @if (_activityUsers.Any(u => u.IsOnline))
                {
                    var onlineCount = _activityUsers.Count(u => u.IsOnline);
                    <div class="diag-unsafe-banner" @onclick:stopPropagation="true">
                        <i class="ri-alert-fill"></i>
                        @onlineCount user@(onlineCount == 1 ? "" : "s") currently active — do not update the server
                    </div>
                }
                else if (_activityUsers.Any())
                {
                    <div class="diag-safe-banner" @onclick:stopPropagation="true">
                        <i class="ri-checkbox-circle-fill"></i>
                        No active users — safe to update the server
                    </div>
                }
                <i class="@(_activityExpanded ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line")"
                   style="font-size:1.1rem;color:#64748b;"></i>
            </div>
        </div>

        @if (_activityExpanded)
        {
            <div class="mt-3">
                @if (!_activityUsers.Any())
                {
                    <div style="color:#475569;font-size:.85rem;padding:8px 0;">No activity recorded yet.</div>
                }
                else
                {
                    <table class="diag-act-table">
                        <thead>
                            <tr>
                                <th style="width:14px;"></th>
                                <th>User</th>
                                <th>Last Action</th>
                                <th style="width:110px;">When</th>
                                <th style="width:80px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var u in _activityUsers)
                            {
                                <tr>
                                    <td>
                                        <span class="@(u.IsOnline ? "diag-dot-online" : "diag-dot-offline")" title="@(u.IsOnline ? "Online" : "Offline")">●</span>
                                    </td>
                                    <td style="font-weight:600;color:#e2e8f0;">@u.Username</td>
                                    <td style="color:#94a3b8;font-size:.85rem;">@u.LastAction</td>
                                    <td style="color:#64748b;font-size:.82rem;white-space:nowrap;">
                                        @LPM.Services.UserActivityService.TimeAgo(u.LastActivityAt)
                                    </td>
                                    <td>
                                        <button class="btn btn-sm diag-history-btn"
                                                disabled="@_auditLoading"
                                                @onclick="() => OpenAuditModal(u.Username)"
                                                @onclick:stopPropagation="true">
                                            @if (_auditLoading && _auditUser == u.Username)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" style="width:.65rem;height:.65rem;border-width:2px;"></span>
                                            }
                                            else
                                            {
                                                <i class="ri-history-line me-1"></i>
                                            }
                                            History
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    </div>

    <div class="mb-3 mt-1 d-flex gap-2 flex-wrap">
        <a href="javascript:void(0)" class="diag-jump-link"
           @onclick='() => JS.InvokeVoidAsync("eval", "document.getElementById(\"sess_sessions\").scrollIntoView({behavior:\"smooth\"})")'><i class="ri-calendar-event-line me-1"></i>sess_sessions</a>
    </div>

    @* ── Audit History Modal ── *@
    @if (_showAuditModal)
    {
        <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.65);" @onclick="() => _showAuditModal = false">
            <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable" @onclick:stopPropagation="true">
                <div class="modal-content" style="background:#0f172a;border-color:#1e293b;color:#e2e8f0;max-height:80vh;">
                    <div class="modal-header py-2" style="border-color:#1e293b;">
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <h6 class="modal-title mb-0">
                                <i class="ri-history-line me-2" style="color:#60a5fa;"></i>
                                <strong>@_auditUser</strong> — Activity History
                            </h6>
                            <select class="form-select form-select-sm diag-days-select"
                                    value="@_auditDays"
                                    @onchange="OnAuditDaysChanged">
                                <option value="1">Today (1 day)</option>
                                <option value="7">Last 7 days</option>
                                <option value="30">Last 30 days</option>
                                <option value="0">All time</option>
                            </select>
                        </div>
                        <button class="btn-close btn-close-white ms-3" @onclick="() => _showAuditModal = false"></button>
                    </div>
                    <div class="modal-body" style="overflow-y:auto;">
                        @if (_auditLoading)
                        {
                            <div style="display:flex;align-items:center;justify-content:center;gap:10px;padding:32px 0;color:#64748b;">
                                <span class="spinner-border spinner-border-sm" style="width:1.1rem;height:1.1rem;border-width:2px;color:#60a5fa;"></span>
                                <span style="font-size:.85rem;">Loading history…</span>
                            </div>
                        }
                        else if (!_auditEntries.Any())
                        {
                            <div style="color:#475569;padding:16px 0;text-align:center;">No entries for this period.</div>
                        }
                        else
                        {
                            <table class="diag-audit-table">
                                <thead>
                                    <tr>
                                        <th style="width:20px;padding:3px 4px;"></th>
                                        @{ bool akind = _auditSortCol == "kind"; bool aact = _auditSortCol == "action"; bool atm = _auditSortCol == "time"; }
                                        <th class="diag-audit-th" @onclick='() => SetAuditSort("kind")'>
                                            Kind @if (akind) { <i class="@(_auditSortAsc ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line")" style="font-size:.75rem;"></i> }
                                        </th>
                                        <th class="diag-audit-th" @onclick='() => SetAuditSort("action")'>
                                            Action @if (aact) { <i class="@(_auditSortAsc ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line")" style="font-size:.75rem;"></i> }
                                        </th>
                                        <th class="diag-audit-th" style="white-space:nowrap;" @onclick='() => SetAuditSort("time")'>
                                            Date &amp; Time @if (atm) { <i class="@(_auditSortAsc ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line")" style="font-size:.75rem;"></i> }
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in SortedAuditEntries)
                                    {
                                        <tr class="diag-audit-tr-@entry.Kind">
                                            <td>
                                                @if (entry.Kind == "login")          { <i class="ri-login-box-line"></i> }
                                                else if (entry.Kind == "logout")     { <i class="ri-logout-box-r-line"></i> }
                                                else if (entry.Kind == "navigation") { <i class="ri-compass-3-line"></i> }
                                                else                                 { <i class="ri-cursor-line"></i> }
                                            </td>
                                            <td class="diag-audit-kind-cell">@entry.Kind</td>
                                            <td>@entry.Action</td>
                                            <td style="white-space:nowrap;">@LPM.Services.UserActivityService.FormatTimestamp(entry.ActivityAt)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            @if (_auditEntries.Count >= 500)
                            {
                                <div style="text-align:center;color:#475569;font-size:.78rem;padding:8px;">Showing latest 500 entries</div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <h4 class="fw-bold mb-1">Diagnosis</h4>
    <p class="text-muted mb-4" style="font-size:.85rem;">
        Creates a new copy of the current database with all data tables cleared and a single
        <strong>admin / Admin1992</strong> user seeded. The live database is never touched.
    </p>

    @if (!string.IsNullOrEmpty(_resultPath))
    {
        <div class="alert alert-success d-flex align-items-center gap-2">
            <i class="ri-checkbox-circle-line" style="font-size:1.3rem;"></i>
            <div>
                <strong>Done.</strong> File created:<br />
                <code style="font-size:.82rem; word-break:break-all;">@_resultPath</code>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_cedbError))
    {
        <div class="alert alert-danger">@_cedbError</div>
    }

    <div class="d-flex flex-wrap gap-3 mb-4">
        <button class="btn btn-danger d-flex align-items-center gap-2"
                disabled="@_busy" @onclick="CreateEmptyDbCopy">
            @if (_busy)
            {
                <span class="spinner-border spinner-border-sm"></span><span>Working…</span>
            }
            else
            {
                <i class="ri-database-2-line"></i><span>Create Empty DB Copy</span>
            }
        </button>

        <button class="btn btn-warning d-flex align-items-center gap-2"
                disabled="@_shrinkBusy" @onclick="RunShrinkPdf">
            @if (_shrinkBusy)
            {
                <span class="spinner-border spinner-border-sm"></span><span>Shrinking…</span>
            }
            else
            {
                <i class="ri-file-reduce-line"></i><span>Run Shrink PDF Service</span>
            }
        </button>
    </div>
    @if (!string.IsNullOrEmpty(_shrinkResult))
    {
        <div class="alert @(_shrinkResult.StartsWith("Error") ? "alert-danger" : "alert-success") mb-4">@_shrinkResult</div>
    }

    @* ── Test PDF File ─────────────────────────────────────────────────────── *@
    <div class="diag-editor-card mb-4">
        <div class="diag-editor-header">
            <i class="ri-file-search-line me-2"></i>Test PDF File
            <span class="diag-editor-sub">PdfSharp vs Ghostscript</span>
        </div>
        <div class="diag-editor-body">
            <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
                <InputFile id="pdf-diag-input" OnChange="OnPdfDiagFileSelected" accept=".pdf" style="display:none;" />
                <button class="btn btn-outline-primary d-flex align-items-center gap-2"
                        disabled="@_pdfDiagBusy"
                        @onclick='() => JS.InvokeVoidAsync("lpmClickById", "pdf-diag-input")'>
                    <i class="ri-upload-cloud-line"></i>Choose PDF…
                </button>
                @if (_pdfDiagBusy)
                {
                    <span class="spinner-border spinner-border-sm text-primary"></span>
                    <span class="text-muted" style="font-size:.85rem;">Analysing…</span>
                }
                @if (!string.IsNullOrEmpty(_pdfDiagFileName))
                {
                    <span style="font-size:.82rem;color:#64748b;">
                        <i class="ri-file-pdf-2-line me-1" style="color:#ef4444;"></i>@_pdfDiagFileName
                        (@FormatSize(_pdfDiagFileSize))
                    </span>
                }
            </div>

            @if (_pdfDiagResult != null)
            {
                var r = _pdfDiagResult;
                <div style="display:flex;flex-direction:column;gap:10px;">

                    @* Overall verdict *@
                    @if (r.CanOpenWithPdfSharp)
                    {
                        <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-0">
                            <i class="ri-checkbox-circle-fill" style="font-size:1.2rem;"></i>
                            <div>
                                <strong>PdfSharp can open this file.</strong>
                                @if (!r.GhostscriptNeeded)
                                {
                                    <span class="ms-1">Ghostscript will be <strong>skipped</strong> for this file — fast path.</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-0">
                            <i class="ri-error-warning-fill" style="font-size:1.2rem;"></i>
                            <div>
                                <strong>PdfSharp cannot open this file.</strong>
                                Ghostscript repair will be <strong>required</strong> (slow path).
                                <div style="font-size:.78rem;margin-top:3px;color:#7f1d1d;">Error: @r.PdfSharpError</div>
                            </div>
                        </div>
                    }

                    @* Detail grid *@
                    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:8px;">
                        <div class="diag-stat-box">
                            <div class="diag-stat-label">Pages</div>
                            <div class="diag-stat-value">@r.PageCount</div>
                        </div>
                        <div class="diag-stat-box">
                            <div class="diag-stat-label">Max size (pt)</div>
                            <div class="diag-stat-value">@r.MaxWidthPt.ToString("F0") × @r.MaxHeightPt.ToString("F0")</div>
                        </div>
                        <div class="diag-stat-box">
                            <div class="diag-stat-label">Pages uniform</div>
                            <div class="diag-stat-value" style="color:@(r.PagesUniform ? "#22c55e" : "#f59e0b");">
                                @(r.PagesUniform ? "Yes — no normalisation needed" : "No — will be normalised")
                            </div>
                        </div>
                        <div class="diag-stat-box">
                            <div class="diag-stat-label">Ghostscript available</div>
                            <div class="diag-stat-value" style="color:@(r.GhostscriptAvailable ? "#22c55e" : "#94a3b8");">
                                @(r.GhostscriptAvailable ? "Yes" : "Not installed")
                            </div>
                        </div>
                    </div>

                    @* Per-page sizes (only if non-uniform or <= 20 pages) *@
                    @if (!r.PagesUniform || r.PageCount <= 20)
                    {
                        <div>
                            <div class="diag-lbl mb-1">Page dimensions</div>
                            <div style="display:flex;flex-wrap:wrap;gap:5px;">
                                @foreach (var (pg, w, h) in r.PageSizes)
                                {
                                    bool differs = Math.Abs(w - r.MaxWidthPt) / r.MaxWidthPt > 0.05
                                               || Math.Abs(h - r.MaxHeightPt) / r.MaxHeightPt > 0.05;
                                    <span style="font-size:.72rem;padding:2px 7px;border-radius:4px;
                                                 background:@(differs ? "#7f1d1d" : "#1e293b");
                                                 color:@(differs ? "#fca5a5" : "#94a3b8");
                                                 border:1px solid @(differs ? "#ef4444" : "#334155");">
                                        p@pg: @w.ToString("F0")×@h.ToString("F0")
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @* ── User Editor ──────────────────────────────────────────────────────── *@
    <div class="diag-editor-card mb-4">
        <div class="diag-editor-header">
            <i class="ri-user-settings-line me-2"></i>Edit User
            <span class="diag-editor-sub">core_users</span>
        </div>
        <div class="diag-editor-body">
            <div class="row g-2 mb-3">
                <div class="col-12 col-sm-7 col-md-5">
                    <label class="diag-lbl">Select user</label>
                    <select class="form-select form-select-sm" @onchange="OnUserSelected" disabled="@_loadingUsers">
                        @if (_loadingUsers)
                        {
                            <option>Loading…</option>
                        }
                        else
                        {
                            <option value="0">— choose user —</option>
                            @foreach (var u in _userList)
                            {
                                <option value="@u.Id">@u.Id — @u.Username (@u.StaffRole / @u.UserType)</option>
                            }
                        }
                    </select>
                </div>
            </div>
            @if (_selectedUserId > 0 && _userEditCols.Count > 0)
            {
                <div class="row g-2 mb-3">
                    @foreach (var col in _userEditCols)
                    {
                        var cc = col;
                        bool ro = cc == "Id" || _maskCols.Contains(cc);
                        <div class="col-6 col-sm-4 col-md-3">
                            <label class="diag-lbl">@cc</label>
                            @if (ro)
                            {
                                <input type="text" class="form-control form-control-sm diag-input-ro" disabled value="@_userEditVals[cc]" />
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-sm" @bind="_userEditVals[cc]" @bind:event="oninput" />
                            }
                        </div>
                    }
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                    <button class="btn btn-primary btn-sm diag-action-btn" disabled="@_userBusy" @onclick="SaveUserFields">
                        @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-save-line me-1"></i> }
                        Save Fields
                    </button>
                    <button class="btn btn-outline-danger btn-sm diag-action-btn" disabled="@_userBusy" @onclick="ResetSecurityFlags">
                        @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-shield-keyhole-line me-1"></i> }
                        Re-verify User
                    </button>
                    <button class="btn btn-outline-warning btn-sm diag-action-btn" disabled="@_userBusy" @onclick="ResetTotpSecret">
                        @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-key-line me-1"></i> }
                        Reset TOTP Secret
                    </button>
                </div>
                <div class="border-top pt-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-sm-5 col-md-4">
                            <label class="diag-lbl">New password</label>
                            <input type="password" class="form-control form-control-sm" placeholder="Enter new password"
                                   @bind="_newPassword" @bind:event="oninput" />
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-warning btn-sm diag-action-btn"
                                    disabled="@(_userBusy || string.IsNullOrWhiteSpace(_newPassword))" @onclick="SaveUserPassword">
                                @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-key-2-line me-1"></i> }
                                Set Password
                            </button>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_userMsg))
                {
                    <div class="alert @(_userMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mt-3 mb-0 diag-feedback">@_userMsg</div>
                }
            }
        </div>
    </div>

    @* ── core_pcs Editor ──────────────────────────────────────────────────── *@
    <div class="diag-editor-card mb-4">
        <div class="diag-editor-header" style="cursor:pointer;user-select:none;" @onclick="() => _pcsExpanded = !_pcsExpanded">
            <i class="ri-computer-line me-2"></i>Edit PCs
            <span class="diag-editor-sub">core_pcs</span>
            <i class="@(_pcsExpanded ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line") ms-auto"></i>
        </div>
        @if (_pcsExpanded)
        {
        <div class="diag-editor-body">
            @if (!string.IsNullOrEmpty(_pcsMsg))
            {
                <div class="alert @(_pcsMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mb-3 diag-feedback">@_pcsMsg</div>
            }
            <div class="cedb-table-wrap mb-3">
                <table class="cedb-table">
                    <thead><tr><th></th><th>PcId</th><th>Name</th><th></th></tr></thead>
                    <tbody>
                        @if (_pcsRows.Count == 0)
                        {
                            <tr><td colspan="4" class="cedb-empty text-center py-2">No rows</td></tr>
                        }
                        @foreach (var row in _pcsRows)
                        {
                            var r = row;
                            bool pcsDelPending = _pendingDeletePcId == r.PcId;
                            <tr>
                                <td style="white-space:nowrap;">
                                    @if (pcsDelPending)
                                    {
                                        <button class="btn btn-danger btn-sm py-0 px-1 me-1" title="Confirm delete"
                                                disabled="@_pcsBusy" @onclick="() => DeletePcsRow(r.PcId)">
                                            <i class="ri-check-line"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                @onclick="() => _pendingDeletePcId = 0">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                disabled="@_pcsBusy"
                                                @onclick="() => { _pendingDeletePcId = r.PcId; _pcsMsg = string.Empty; }">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    }
                                </td>
                                <td><span style="color:#64748b;">@r.PcId</span></td>
                                <td>@r.PersonName</td>
                                <td class="text-end" style="white-space:nowrap;">
                                    @if (pcsDelPending)
                                    {
                                        <span class="me-1" style="font-size:.8rem;">Sure?</span>
                                        <button class="btn btn-danger btn-sm py-0 px-1 me-1" title="Confirm delete"
                                                disabled="@_pcsBusy" @onclick="() => DeletePcsRow(r.PcId)">
                                            <i class="ri-check-line"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                @onclick="() => _pendingDeletePcId = 0">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1" title="Edit"
                                                disabled="@_pcsBusy"
                                                @onclick="() => OpenPcsModal(r.PcId)">
                                            <i class="ri-pencil-line"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                disabled="@_pcsBusy"
                                                @onclick="() => { _pendingDeletePcId = r.PcId; _pcsMsg = string.Empty; }">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="diag-lbl">Add new PcId (= PersonId)</label>
                    <input type="number" class="form-control form-control-sm" style="width:130px;" placeholder="e.g. 5"
                           @bind="_newPcIdStr" @bind:event="oninput" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-success btn-sm diag-action-btn"
                            disabled="@(_pcsBusy || string.IsNullOrWhiteSpace(_newPcIdStr))" @onclick="AddPcsRow">
                        @if (_pcsBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-add-line me-1"></i> }
                        Add PC
                    </button>
                </div>
            </div>
        </div>
        }
    </div>

    @* ── core_* tables ── *@
    <div class="cedb-group-header mt-4">
        <i class="ri-user-line me-1"></i>core_* tables
        @if (_loadingTables) { <span class="spinner-border spinner-border-sm ms-2" style="color:#60a5fa;width:1rem;height:1rem;"></span> }
    </div>
    @if (_loadingTables)
    {
        <div class="cedb-section-loading">
            <span class="spinner-border spinner-border-sm me-2" style="color:#60a5fa;"></span>Loading tables…
        </div>
    }
    else
    {
        @foreach (var t in _coreTables)
        {
            @if (t.Name == "core_persons")
            {
                @EditableSection(new EditInfo(t, "PersonId"))
            }
            else
            {
                @TableSection(t)
            }
        }

        @* ── sys_* tables ── *@
        <div class="cedb-group-header mt-3"><i class="ri-settings-3-line me-1"></i>sys_* tables</div>
        @foreach (var t in _sysTables) { @TableSection(t) }

        @* ── lkp_* tables ── *@
        <div class="cedb-group-header mt-3"><i class="ri-price-tag-3-line me-1"></i>lkp_* tables</div>
        @foreach (var t in _lkpTables) { @TableSection(t) }
    }

    @* ── sess_* / cs_* / fin_* / acad_* tables ── *@
    @if (!_loadingTables)
    {
        @* ── sess_* tables (editable) ── *@
        <div class="cedb-group-header mt-3">
            <i class="ri-calendar-line me-1"></i>sess_* tables
            <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(editable)</span>
        </div>
        @foreach (var t in _sessTables)
        {
            var pk = t.Name switch
            {
                "sess_sessions"       => "SessionId",
                "sess_misc_charges"   => "MiscChargeId",
                "sess_folder_summary" => "Id",
                "sess_meetings"       => "MeetingId",
                _                     => "Id"
            };
            @if (t.Name == "sess_sessions") { <div id="sess_sessions"></div> }
            @EditableSection(new EditInfo(t, pk))
        }

        @* ── cs_* tables (editable) ── *@
        <div class="cedb-group-header mt-3">
            <i class="ri-user-star-line me-1"></i>cs_* tables
            <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(editable)</span>
        </div>
        @foreach (var t in _csTables)
        {
            var pk = t.Name switch
            {
                "cs_reviews"          => "CsReviewId",
                "cs_work_log"         => "CsWorkLogId",
                "cs_case_supervisors" => "CsId",
                _                     => "Id"
            };
            @EditableSection(new EditInfo(t, pk))
        }

        @* ── fin_* tables ── *@
        <div class="cedb-group-header mt-3">
            <i class="ri-money-dollar-circle-line me-1"></i>fin_* tables
        </div>
        @foreach (var t in _finTables) { @TableSection(t) }

        @* ── acad_* tables ── *@
        <div class="cedb-group-header mt-3">
            <i class="ri-graduation-cap-line me-1"></i>acad_* tables
        </div>
        @foreach (var t in _acadTables) { @TableSection(t) }
    }

    @* ── Recent PC-Folder Files (< 7 days) ────────────────────────────────── *@
    <div class="diag-editor-card mb-4 mt-4">
        <div class="diag-editor-header">
            <i class="ri-file-list-3-line me-2"></i>Recent Files — @(_recentLimit == 0 ? "All" : $"last {_recentLimit}")
            <span class="diag-editor-sub">PC-Folders</span>
            <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.75rem;"
                    @bind="_recentLimit" @bind:after="LoadRecentFiles">
                <option value="200">200</option>
                <option value="500">500</option>
                <option value="1000">1000</option>
                <option value="0">ALL</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm py-0" style="font-size:.72rem;"
                    @onclick="LoadRecentFiles">
                <i class="ri-refresh-line me-1"></i>Refresh
            </button>
        </div>
        <div class="diag-editor-body">
            @if (_loadingRecent)
            {
                <div class="cedb-section-loading">
                    <span class="spinner-border spinner-border-sm me-2" style="color:#60a5fa;"></span>Scanning files…
                </div>
            }
            else
            {
            @if (!string.IsNullOrEmpty(_recentMsg))
            {
                <div class="alert @(_recentMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mb-3 diag-feedback">@_recentMsg</div>
            }
            @if (_recentGroups.Count == 0)
            {
                <div class="cedb-empty">No files found.</div>
            }
            else
            {
                @foreach (var g in _recentGroups)
                {
                    var grp = g;
                    <div class="mb-3">
                        <div class="diag-lbl mb-1"><i class="ri-folder-3-line me-1"></i>@grp.PcName <span style="font-weight:400;color:#94a3b8;">(@grp.Files.Count file@(grp.Files.Count != 1 ? "s" : ""))</span></div>
                        <div class="cedb-table-wrap">
                            <table class="cedb-table">
                                <thead>
                                    <tr><th></th><th>File</th><th>Modified</th><th>Size</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in grp.Files)
                                    {
                                        var f = file;
                                        bool filePending = _pendingDeleteFile == f.FullPath;
                                        <tr class="@(filePending ? "table-danger" : "")">
                                            <td style="white-space:nowrap;">
                                                @if (filePending)
                                                {
                                                    <button class="btn btn-danger btn-sm py-0 px-1 me-1" @onclick="() => DeleteRecentFile(f.FullPath)">
                                                        <i class="ri-check-line"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => _pendingDeleteFile = null">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                                            title="Delete" @onclick="() => _pendingDeleteFile = f.FullPath">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                }
                                            </td>
                                            <td>@f.RelPath</td>
                                            <td style="white-space:nowrap;">@f.Modified.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td style="white-space:nowrap;">@FormatSize(f.Size)</td>
                                            <td class="text-end" style="white-space:nowrap;">
                                                @if (filePending)
                                                {
                                                    <span class="me-1" style="font-size:.65rem;color:#dc3545;vertical-align:middle;">Sure?</span>
                                                    <button class="btn btn-danger btn-sm py-0 px-1 me-1" @onclick="() => DeleteRecentFile(f.FullPath)">
                                                        <i class="ri-check-line"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => _pendingDeleteFile = null">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                                            title="Delete" @onclick="() => _pendingDeleteFile = f.FullPath">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
            } @* end else (_loadingRecent) *@
        </div>
    </div>

    } @* end _diagTab == "db" *@

    @* ── DB Check Integrity Tab ─────────────────────────────────────────── *@
    @if (_diagTab == "integrity")
    {
        <div class="diag-editor-card mb-4">
            <div class="diag-editor-header">
                <i class="ri-shield-check-line me-2"></i>DB Check Integrity
                <span class="diag-editor-sub">FK orphan detection</span>
                <button class="btn btn-outline-primary btn-sm ms-auto py-0 diag-action-btn"
                        disabled="@_integrityChecking" @onclick="RunIntegrityCheck">
                    @if (_integrityChecking)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    else
                    {
                        <i class="ri-scan-line me-1"></i>
                    }
                    Check DB
                </button>
            </div>
            <div class="diag-editor-body">
                @if (_integrityChecking)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1" style="font-size:.72rem;color:#64748b;">
                            <span>Scanning <code style="font-size:.7rem;">@_integrityProgressTable</code></span>
                            <span>@_integrityProgressCurrent / @_integrityProgressTotal tables</span>
                        </div>
                        <div class="progress" style="height:8px;border-radius:4px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width:@(_integrityProgressTotal > 0 ? $"{100 * _integrityProgressCurrent / _integrityProgressTotal}%" : "0%")">
                            </div>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(_integrityMsg))
                {
                    <div class="alert @(_orphans.Count == 0 ? "alert-success" : "alert-warning") py-1 px-3 mb-3 diag-feedback">@_integrityMsg</div>
                }
                @if (_orphans.Count > 0)
                {
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <span style="font-size:.78rem;font-weight:600;color:#b45309;">
                            @_orphans.Count orphan row@(_orphans.Count != 1 ? "s" : "") found
                        </span>
                        <button class="btn btn-danger btn-sm py-0" @onclick="DeleteAllOrphans">
                            <i class="ri-delete-bin-line me-1"></i>Delete All Orphans
                        </button>
                    </div>
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>
                                    <th>Table</th>
                                    <th>Row ID</th>
                                    <th>FK Column</th>
                                    <th>FK Value</th>
                                    <th>→ References</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var o in _orphans.ToList())
                                {
                                    var orphan = o;
                                    bool pending = _pendingOrphanDelete.Contains((orphan.Table, orphan.RowId));
                                    <tr class="@(pending ? "table-danger" : "")">
                                        <td><code style="font-size:.68rem;">@orphan.Table</code></td>
                                        <td style="color:#64748b;">@orphan.RowId</td>
                                        <td style="color:#0369a1;">@orphan.FkCol</td>
                                        <td style="color:#dc2626;font-weight:600;">@orphan.FkValue</td>
                                        <td style="color:#64748b;font-size:.68rem;"><code>@orphan.RefTable.@orphan.RefCol</code></td>
                                        <td class="text-end" style="white-space:nowrap;">
                                            @if (pending)
                                            {
                                                <span class="me-1" style="font-size:.65rem;color:#dc3545;vertical-align:middle;">Sure?</span>
                                                <button class="btn btn-danger btn-sm py-0 px-1 me-1" @onclick="() => DeleteOrphan(orphan)">
                                                    <i class="ri-check-line"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => _pendingOrphanDelete.Remove((orphan.Table, orphan.RowId))">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete orphan row"
                                                        @onclick="() => _pendingOrphanDelete.Add((orphan.Table, orphan.RowId))">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_integrityMsg))
                {
                    <div class="cedb-empty">No orphan rows found — database FK integrity is clean.</div>
                }
                else
                {
                    <div class="cedb-empty">Press "Check DB" to scan for orphan rows.</div>
                }
            </div>
        </div>
    }

    @* ── PC Full Data Tab ──────────────────────────────────────────────────── *@
    @if (_diagTab == "pcfd")
    {
        <style>
            @@keyframes pcfd-pulse {
                0%,100% { transform: scale(1);   opacity: 1; }
                50%      { transform: scale(1.18); opacity: .8; }
            }
            @@keyframes pcfd-done-in {
                from { opacity: 0; transform: scale(.82); }
                to   { opacity: 1; transform: scale(1); }
            }
            .pcfd-pulse-icon  { animation: pcfd-pulse 1.1s ease-in-out infinite; display:inline-block; }
            .pcfd-done-card   { animation: pcfd-done-in .55s cubic-bezier(.34,1.56,.64,1) both; }
            .pcfd-table-scroll{ max-height:280px; overflow-y:auto; }
            .pcfd-file-scroll { max-height:240px; overflow-y:auto; }
        </style>

        <div class="diag-editor-card mb-4">
            <div class="diag-editor-header">
                <i class="ri-user-search-line me-2"></i>PC Full Data
                <span class="diag-editor-sub">Select a PC to view all related DB rows and files</span>
            </div>
            <div class="diag-editor-body">
                <div class="row g-2 align-items-center mb-3">
                    <div class="col-12 col-sm-8 col-md-6">
                        <select class="form-select form-select-sm"
                                value="@_pcfdPcId"
                                @onchange="OnPcfdPcSelected">
                            <option value="0">— Choose a PC —</option>
                            @foreach (var pc in _pcsRows)
                            {
                                <option value="@pc.PcId">[@pc.PcId] @pc.PersonName</option>
                            }
                        </select>
                    </div>
                    @if (_pcfdPcId > 0 && !_pcfdLoading)
                    {
                        <div class="col-auto">
                            <button class="btn btn-danger btn-sm diag-action-btn"
                                    @onclick="StartPcfdDelete">
                                <i class="ri-delete-bin-2-line me-1"></i>Delete PC
                            </button>
                        </div>
                    }
                </div>

                @if (_pcfdLoading)
                {
                    <div class="d-flex align-items-center gap-2" style="color:#94a3b8;padding:16px 0;">
                        <span class="spinner-border spinner-border-sm" style="color:#60a5fa;"></span>
                        <span style="font-size:.85rem;">Loading PC data…</span>
                    </div>
                }
                else if (!string.IsNullOrEmpty(_pcfdError))
                {
                    <div class="alert alert-danger py-1 px-3 mb-0 diag-feedback">@_pcfdError</div>
                }
                else if (_pcfdPcId > 0)
                {
                    @* Summary bar *@
                    <div class="d-flex gap-3 flex-wrap mb-3" style="font-size:.8rem;color:#94a3b8;">
                        <span><i class="ri-table-line me-1"></i>@(_pcfdTables.Count(t => t.Rows.Count > 0)) tables with data</span>
                        <span><i class="ri-file-list-line me-1"></i>@(_pcfdFolders.Sum(f => f.Files.Count)) files in @_pcfdFolders.Count folder(s)</span>
                    </div>

                    @* DB Tables *@
                    @foreach (var t in _pcfdTables)
                    {
                        var tbl = t;
                        bool hasColl = _pcfdCollapsed.Contains(tbl.Name);
                        <div class="cedb-section mt-2">
                            <div class="cedb-section-title cedb-section-toggle"
                                 @onclick="() => { if (_pcfdCollapsed.Contains(tbl.Name)) _pcfdCollapsed.Remove(tbl.Name); else _pcfdCollapsed.Add(tbl.Name); }">
                                <i class="@tbl.Icon me-1"></i>@tbl.Name
                                <span class="cedb-count">@tbl.Rows.Count row@(tbl.Rows.Count != 1 ? "s" : "")</span>
                                <i class="ri-arrow-down-s-line cedb-chevron ms-auto @(hasColl ? "cedb-chevron-up" : "")"></i>
                            </div>
                            @if (!hasColl)
                            {
                                @if (tbl.Rows.Count == 0)
                                {
                                    <div class="cedb-empty">No rows</div>
                                }
                                else
                                {
                                    <div class="cedb-table-wrap pcfd-table-scroll">
                                        <table class="cedb-table">
                                            <thead><tr>@foreach (var col in tbl.Columns) { <th>@col</th> }</tr></thead>
                                            <tbody>
                                                @foreach (var row in tbl.Rows)
                                                {
                                                    <tr>@for (int i = 0; i < tbl.Columns.Count; i++) {
                                                        var v = i < row.Count ? row[i] : "";
                                                        <td>@v</td>
                                                    }</tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            }
                        </div>
                    }

                    @* PC Folder files *@
                    <div class="cedb-section mt-2">
                        <div class="cedb-section-title cedb-section-toggle"
                             @onclick='() => { if (_pcfdCollapsed.Contains("__files__")) _pcfdCollapsed.Remove("__files__"); else _pcfdCollapsed.Add("__files__"); }'>
                            <i class="ri-folder-open-line me-1"></i>PC Folder Files
                            <span class="cedb-count">@(_pcfdFolders.Sum(f => f.Files.Count)) file(s) in @_pcfdFolders.Count folder(s)</span>
                            <i class="ri-arrow-down-s-line cedb-chevron ms-auto @(_pcfdCollapsed.Contains("__files__") ? "cedb-chevron-up" : "")"></i>
                        </div>
                        @if (!_pcfdCollapsed.Contains("__files__"))
                        {
                            @if (!_pcfdFolders.Any())
                            {
                                <div class="cedb-empty">No PC folders found on disk</div>
                            }
                            else
                            {
                                @foreach (var folder in _pcfdFolders)
                                {
                                    var fld = folder;
                                    <div class="mb-2" style="padding:6px 10px;">
                                        <div style="font-size:.78rem;font-weight:700;color:#60a5fa;margin-bottom:4px;">
                                            <i class="ri-folder-line me-1"></i>@fld.FolderName
                                            <span style="font-weight:400;color:#64748b;margin-left:6px;">(@fld.Files.Count files)</span>
                                        </div>
                                        @if (fld.Files.Count == 0)
                                        {
                                            <div class="cedb-empty">Empty folder</div>
                                        }
                                        else
                                        {
                                            <div class="pcfd-file-scroll">
                                                <ul style="margin:0;padding-left:20px;list-style:none;">
                                                    @foreach (var f in fld.Files)
                                                    {
                                                        <li style="font-size:.75rem;color:#94a3b8;padding:1px 0;">
                                                            <i class="ri-file-line me-1" style="color:#475569;"></i>@f
                                                        </li>
                                                    }
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                        }
                    </div>
                }
            </div>
        </div>
    }

</div>

@* ── PC Full Data — Delete Confirmation Modal ─────────────────────────────── *@
@if (_pcfdDeleteStep > 0)
{
    <div style="position:fixed;inset:0;z-index:1060;background:rgba(0,0,0,.80);display:flex;align-items:center;justify-content:center;padding:16px;">

        @* Step 1: Are you sure? *@
        @if (_pcfdDeleteStep == 1)
        {
            <div style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:36px 40px;max-width:520px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.7);text-align:center;">
                <div class="pcfd-pulse-icon" style="font-size:4rem;color:#ef4444;margin-bottom:16px;">
                    <i class="ri-error-warning-fill"></i>
                </div>
                <div style="font-size:1.35rem;font-weight:800;color:#fca5a5;margin-bottom:10px;">
                    Delete PC — Are you sure?
                </div>
                <div style="font-size:.9rem;color:#fca5a5;margin-bottom:6px;font-weight:600;">
                    @(_pcsRows.FirstOrDefault(p => p.PcId == _pcfdPcId)?.PersonName ?? $"PC #{_pcfdPcId}")
                </div>
                <div style="font-size:.83rem;color:#ef4444;margin-bottom:20px;">
                    This will permanently and irreversibly delete
                    <strong>ALL</strong> database rows and <strong>ALL</strong> files
                    on disk associated with this PC.
                </div>
                <div style="font-size:.78rem;color:#b91c1c;background:#2a0a0a;border-radius:8px;padding:10px 14px;margin-bottom:24px;text-align:left;">
                    <div class="mb-1"><strong style="color:#fca5a5;">DB tables:</strong></div>
                    @foreach (var t in _pcfdTables.Where(t => t.Rows.Count > 0))
                    {
                        <div>· @t.Name — <strong>@t.Rows.Count</strong> row(s)</div>
                    }
                    <div class="mt-1"><strong style="color:#fca5a5;">Files:</strong> @(_pcfdFolders.Sum(f => f.Files.Count)) in @_pcfdFolders.Count folder(s)</div>
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-secondary btn-sm px-4" @onclick="() => _pcfdDeleteStep = 0">Cancel</button>
                    <button class="btn btn-danger btn-sm px-4" @onclick="() => _pcfdDeleteStep = 2">
                        Yes, delete everything →
                    </button>
                </div>
            </div>
        }

        @* Step 2: Type "delete" *@
        @if (_pcfdDeleteStep == 2)
        {
            <div style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:36px 40px;max-width:460px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.7);text-align:center;">
                <div style="font-size:3rem;color:#ef4444;margin-bottom:14px;">
                    <i class="ri-skull-2-line"></i>
                </div>
                <div style="font-size:1.1rem;font-weight:800;color:#fca5a5;margin-bottom:18px;">
                    Final confirmation required
                </div>
                <div style="font-size:.85rem;color:#f87171;margin-bottom:18px;">
                    Type <code style="background:#2a0a0a;padding:2px 6px;border-radius:4px;color:#fca5a5;font-weight:700;">delete</code> in the box below to confirm permanent deletion.
                </div>
                <input type="text"
                       class="form-control form-control-sm text-center mb-3"
                       style="background:#2a0a0a;border-color:@(_pcfdDeleteInput.Length > 0 && _pcfdDeleteInput != "delete" ? "#ef4444" : "#7f1d1d");color:#fca5a5;font-size:1rem;font-weight:700;letter-spacing:.08em;"
                       placeholder="type: delete"
                       @bind="_pcfdDeleteInput"
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_pcfdDeleteError))
                {
                    <div class="alert alert-danger py-1 px-2 mb-2 diag-feedback" style="font-size:.78rem;">@_pcfdDeleteError</div>
                }
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-secondary btn-sm px-4" @onclick="() => _pcfdDeleteStep = 0">Cancel</button>
                    <button class="btn btn-danger btn-sm px-4 diag-action-btn"
                            disabled="@(_pcfdDeleteInput != "delete")"
                            @onclick="ExecuteDeletePc">
                        <i class="ri-delete-bin-2-line me-1"></i>Execute Deletion
                    </button>
                </div>
            </div>
        }

        @* Step 3: Deleting *@
        @if (_pcfdDeleteStep == 3)
        {
            <div style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:48px 40px;max-width:400px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.7);text-align:center;">
                <div class="spinner-border" style="width:3rem;height:3rem;border-width:4px;color:#ef4444;margin-bottom:20px;" role="status"></div>
                <div style="font-size:1rem;font-weight:700;color:#fca5a5;">Deleting all PC data…</div>
                <div style="font-size:.78rem;color:#7f1d1d;margin-top:6px;">Please wait</div>
            </div>
        }

        @* Step 4: Done *@
        @if (_pcfdDeleteStep == 4)
        {
            <div class="pcfd-done-card" style="background:#031a0a;border:2px solid #14532d;border-radius:16px;padding:48px 40px;max-width:440px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.7);text-align:center;">
                <div style="font-size:4.5rem;color:#22c55e;margin-bottom:16px;">
                    <i class="ri-checkbox-circle-fill"></i>
                </div>
                <div style="font-size:1.2rem;font-weight:800;color:#86efac;margin-bottom:10px;">
                    PC data permanently deleted
                </div>
                <div style="font-size:.85rem;color:#4ade80;margin-bottom:6px;">
                    @_pcfdDeletedRows row(s) deleted from the database
                </div>
                <div style="font-size:.85rem;color:#4ade80;margin-bottom:24px;">
                    @_pcfdDeletedFiles file(s) deleted from disk
                </div>
                <div style="font-size:.72rem;color:#166534;">Closing automatically…</div>
            </div>
        }

    </div>
}

@* ── Delete Session Modal ─────────────────────────────────────────────────── *@
@if (_delSessModal)
{
    <div class="diag-modal-backdrop" @onclick="() => { if (!_delSessBusy) _delSessModal = false; }"></div>
    <div class="diag-modal" style="width:min(820px,96vw);">
        <div class="diag-modal-header">
            <span><i class="ri-delete-bin-2-line me-2" style="color:#ef4444;"></i>Delete Session #@(_delSessInfo?.SessionId)</span>
            <button class="btn-close btn-close-sm" disabled="@_delSessBusy" @onclick="() => _delSessModal = false"></button>
        </div>
        <div class="diag-modal-body">
            @if (_delSessInfo == null)
            {
                <div class="d-flex align-items-center gap-2"><span class="spinner-border spinner-border-sm"></span> Loading…</div>
            }
            else
            {
                @* FK Tables *@
                @foreach (var fkTbl in _delSessInfo.FkTables)
                {
                    var ft = fkTbl;
                    <div class="mb-3">
                        <div class="diag-lbl mb-1">
                            <i class="ri-table-line me-1"></i>@ft.Table
                            <span style="font-weight:400;color:#94a3b8;"> — @ft.Rows.Count row@(ft.Rows.Count != 1 ? "s" : "") to delete</span>
                        </div>
                        @if (ft.Rows.Count == 0)
                        {
                            <div class="cedb-empty">No rows</div>
                        }
                        else
                        {
                            <div class="cedb-table-wrap">
                                <table class="cedb-table">
                                    <thead><tr>@foreach (var c in ft.Cols) { <th>@c</th> }</tr></thead>
                                    <tbody>
                                        @foreach (var row in ft.Rows)
                                        {
                                            <tr>
                                                @foreach (var v in row)
                                                {
                                                    var display = v.Length > 80 ? v[..80] + "…" : v;
                                                    <td title="@v" style="max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#1e293b;">@display</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                }

                @* Files *@
                <div class="mb-3">
                    <div class="diag-lbl mb-1">
                        <i class="ri-file-list-3-line me-1"></i>WorkSheet files to delete
                        <span style="font-weight:400;color:#94a3b8;"> — @_delSessInfo.Files.Count file@(_delSessInfo.Files.Count != 1 ? "s" : "")</span>
                    </div>
                    @if (_delSessInfo.Files.Count == 0)
                    {
                        <div class="cedb-empty">No files found for this session</div>
                    }
                    else
                    {
                        <ul class="diag-delsess-files">
                            @foreach (var f in _delSessInfo.Files)
                            {
                                <li><i class="ri-file-pdf-line me-1" style="color:#ef4444;"></i>@Path.GetFileName(f)</li>
                            }
                        </ul>
                    }
                </div>

                @* Warning *@
                <div class="alert alert-danger py-2 px-3 mb-0" style="font-size:.82rem;">
                    <i class="ri-error-warning-line me-1"></i>
                    <strong>Irreversible.</strong> All listed rows and files will be permanently deleted. The sess_sessions row is deleted last.
                </div>

                @if (!string.IsNullOrEmpty(_delSessError))
                {
                    <div class="alert alert-danger py-1 px-3 mt-2 mb-0 diag-feedback">@_delSessError</div>
                }
            }
        </div>
        <div class="diag-modal-footer">
            <button class="btn btn-secondary btn-sm" disabled="@_delSessBusy" @onclick="() => _delSessModal = false">Cancel</button>
            <button class="btn btn-danger btn-sm diag-action-btn" disabled="@(_delSessBusy || _delSessInfo == null)"
                    @onclick="ExecuteDeleteSession">
                @if (_delSessBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                <i class="ri-delete-bin-2-line me-1"></i>Delete Session
            </button>
        </div>
    </div>
}

