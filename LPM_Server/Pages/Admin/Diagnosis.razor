@code {
    // ── Read-only table display ────────────────────────────────────────────
    record TableData(string Name, string Icon, List<string> Columns, List<List<string>> Rows);

    RenderFragment<TableData> TableSection => t =>
        @<div class="cedb-section mt-3">
            <div class="cedb-section-title cedb-section-toggle" @onclick="() => ToggleSection(t.Name)">
                <i class="@t.Icon me-1"></i>@t.Name
                <span class="cedb-count">@t.Rows.Count row@(t.Rows.Count != 1 ? "s" : "")</span>
                <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.72rem;"
                        @onclick:stopPropagation="true"
                        value="@(_tableLimit.TryGetValue(t.Name, out var tl) ? tl : 200)"
                        @onchange="e => { _tableLimit[t.Name] = int.Parse(e.Value!.ToString()!); }">
                    <option value="10">10</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                    <option value="0">All</option>
                </select>
                <i class="ri-arrow-down-s-line cedb-chevron @(_collapsed.Contains(t.Name) ? "cedb-chevron-up" : "")"></i>
            </div>
            @if (!_collapsed.Contains(t.Name))
            {
                @if (t.Rows.Count == 0)
                {
                    <div class="cedb-empty">No rows</div>
                }
                else
                {
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>@foreach (var col in t.Columns) { <th>@col</th> }</tr>
                            </thead>
                            <tbody>
                                @{ int tsLimit = _tableLimit.TryGetValue(t.Name, out var tsl) ? tsl : 200;
                                   var tsRows  = tsLimit > 0 ? t.Rows.Take(tsLimit) : t.Rows; }
                                @foreach (var row in tsRows)
                                {
                                    <tr>
                                        @for (int i = 0; i < t.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>;

    // ── Editable table display (sess_* / cs_* / core_persons) ────────────────
    record EditInfo(TableData Table, string PkCol);
    // sort state per table name: (column, ascending)
    Dictionary<string, (string Col, bool Asc)> _sortState = new();
    // row limit per table name: 0 = all, default 200
    Dictionary<string, int> _tableLimit = new();

    void SetSort(string tableName, string col)
    {
        if (_sortState.TryGetValue(tableName, out var cur) && cur.Col == col)
            _sortState[tableName] = (col, !cur.Asc);
        else
            _sortState[tableName] = (col, true);
    }

    IEnumerable<List<string>> SortedRows(TableData t)
    {
        IEnumerable<List<string>> rows = t.Rows;
        if (_sortState.TryGetValue(t.Name, out var s))
        {
            int idx = t.Columns.IndexOf(s.Col);
            if (idx >= 0)
                rows = s.Asc
                    ? rows.OrderBy(r => SortKey(r, idx))
                    : rows.OrderByDescending(r => SortKey(r, idx));
        }
        int limit = _tableLimit.TryGetValue(t.Name, out var lim) ? lim : 200;
        if (limit > 0) rows = rows.Take(limit);
        return rows;
    }

    static IComparable SortKey(List<string> row, int idx)
    {
        var v = idx < row.Count ? row[idx] : "";
        if (double.TryParse(v, out var d)) return d;
        return v;
    }

    RenderFragment<EditInfo> EditableSection => args =>
        @<div class="cedb-section mt-3">
            <div class="cedb-section-title cedb-section-toggle" @onclick="() => ToggleSection(args.Table.Name)">
                <i class="@args.Table.Icon me-1"></i>@args.Table.Name
                <span class="cedb-count">@args.Table.Rows.Count row@(args.Table.Rows.Count != 1 ? "s" : "")</span>
                <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.72rem;"
                        @onclick:stopPropagation="true"
                        value="@(_tableLimit.TryGetValue(args.Table.Name, out var curLim) ? curLim : 200)"
                        @onchange="e => { _tableLimit[args.Table.Name] = int.Parse(e.Value!.ToString()!); }">
                    <option value="10">10</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                    <option value="0">All</option>
                </select>
                <i class="ri-arrow-down-s-line cedb-chevron @(_collapsed.Contains(args.Table.Name) ? "cedb-chevron-up" : "")"></i>
            </div>
            @if (!_collapsed.Contains(args.Table.Name))
            {
                @if (args.Table.Rows.Count == 0)
                {
                    <div class="cedb-empty">No rows</div>
                }
                else
                {
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>
                                    <th style="width:@(args.Table.Name == "sess_sessions" ? "90px" : "60px");"></th>
                                    @foreach (var col in args.Table.Columns)
                                    {
                                        var c = col;
                                        bool isSort = _sortState.TryGetValue(args.Table.Name, out var ss) && ss.Col == c;
                                        <th style="cursor:pointer;user-select:none;" @onclick:stopPropagation="true"
                                            @onclick="() => SetSort(args.Table.Name, c)">
                                            @c
                                            @if (isSort)
                                            {
                                                <i class="@(ss.Asc ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line") ms-1" style="font-size:.8rem;"></i>
                                            }
                                        </th>
                                    }
                                    <th style="width:88px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in SortedRows(args.Table))
                                {
                                    var capturedRow = row;
                                    int pkIdx = args.Table.Columns.IndexOf(args.PkCol);
                                    string pkVal = pkIdx >= 0 && pkIdx < row.Count ? row[pkIdx] : "";
                                    bool isPending = _pendingDelete?.Table == args.Table.Name && _pendingDelete?.PkVal == pkVal;
                                    <tr class="@(isPending ? "table-danger" : "")">
                                        <td style="white-space:nowrap;">
                                            @if (args.Table.Name == "sess_sessions")
                                            {
                                                <button class="btn btn-sm py-0 px-1 diag-delsess-btn" title="Delete Session (cascade)"
                                                        @onclick="() => OpenDeleteSessionModal(pkVal, args.Table, capturedRow)">
                                                    <i class="ri-delete-bin-2-line"></i>
                                                </button>
                                            }
                                            else if (isPending)
                                            {
                                                <button class="btn btn-danger btn-sm py-0 px-1 me-1"
                                                        @onclick="() => DeleteRow(args.Table.Name, args.PkCol, pkVal)">
                                                    <i class="ri-check-line"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                        @onclick="() => _pendingDelete = null">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                        @onclick="() => _pendingDelete = (args.Table.Name, pkVal)">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            }
                                        </td>
                                        @for (int i = 0; i < args.Table.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            <td>@val</td>
                                        }
                                        <td class="text-end" style="white-space:nowrap;">
                                            @if (isPending)
                                            {
                                                <span class="me-1" style="font-size:.65rem;color:#dc3545;vertical-align:middle;">Sure?</span>
                                                <button class="btn btn-danger btn-sm py-0 px-1 me-1"
                                                        @onclick="() => DeleteRow(args.Table.Name, args.PkCol, pkVal)">
                                                    <i class="ri-check-line"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                        @onclick="() => _pendingDelete = null">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1" title="Edit"
                                                        @onclick="() => OpenEditModal(args.Table, args.PkCol, capturedRow)">
                                                    <i class="ri-pencil-line"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                        @onclick="() => _pendingDelete = (args.Table.Name, pkVal)">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>;

    // ── State ──────────────────────────────────────────────────────────────
    HashSet<string> _collapsed = [];
    void ToggleSection(string name) { if (!_collapsed.Remove(name)) _collapsed.Add(name); }

    bool   _pageLoading   = false;
    bool   _loadingTables = true;
    bool   _loadingRecent = true;
    bool   _loadingUsers  = true;
    readonly CancellationTokenSource _cts = new();

    bool   _busy;
    string _resultPath = "";
    string _cedbError  = "";

    bool   _shrinkBusy;
    string _shrinkResult = "";

    // PDF test
    bool   _pdfDiagBusy;
    string _pdfDiagFileName = "";
    long   _pdfDiagFileSize;
    LPM.Services.FolderService.PdfDiagResult? _pdfDiagResult;
    List<TableData> _coreTables = [];
    List<TableData> _sysTables  = [];
    List<TableData> _lkpTables  = [];
    List<TableData> _sessTables = [];
    List<TableData> _csTables   = [];
    List<TableData> _finTables  = [];
    List<TableData> _acadTables = [];

    // ── Tab ────────────────────────────────────────────────────────────────
    string _diagTab = "db";

    // ── Inline delete confirmation (sess_* / cs_* rows) ───────────────────
    (string Table, string PkVal)? _pendingDelete;

    // ── Delete Session modal ───────────────────────────────────────────────
    bool   _delSessModal = false;
    bool   _delSessBusy  = false;
    string _delSessError = "";
    record DelSessFkTable(string Table, List<string> Cols, List<List<string>> Rows);
    record DelSessInfo(int SessionId, int PcId, string SessionName,
        List<DelSessFkTable> FkTables, List<string> Files);
    DelSessInfo? _delSessInfo;

    // ── DB Integrity state ─────────────────────────────────────────────────
    record OrphanRow(string Table, long RowId, string FkCol, string FkValue, string RefTable, string RefCol);
    List<OrphanRow>          _orphans                  = [];
    bool                     _integrityChecking        = false;
    string                   _integrityMsg             = "";
    HashSet<(string, long)>  _pendingOrphanDelete      = [];
    int                      _integrityProgressCurrent = 0;
    int                      _integrityProgressTotal   = 0;
    string                   _integrityProgressTable   = "";

    // ── Edit modal ────────────────────────────────────────────────────────
    bool                       _editModalVisible;
    string                     _editModalTable  = "";
    string                     _editModalPkCol  = "";
    List<string>               _editModalCols   = [];
    Dictionary<string, string> _editModalVals   = new();
    string                     _editModalMsg    = "";
    bool                       _editModalOk;
    bool                       _editModalBusy;

    void OpenEditModal(TableData t, string pkCol, List<string> row)
    {
        _editModalTable = t.Name;
        _editModalPkCol = pkCol;
        _editModalCols  = t.Columns;
        _editModalVals  = new();
        for (int i = 0; i < t.Columns.Count; i++)
            _editModalVals[t.Columns[i]] = i < row.Count ? row[i] : "";
        _editModalMsg     = "";
        _editModalVisible = true;

        var rowDesc = string.Join(", ", t.Columns.Zip(row, (c, v) => $"{c}={v}"));
        Console.WriteLine($"[Diagnosis] Admin '{AdminUser()}' opened edit modal — {t.Name}: {rowDesc}");
    }

    void CloseEditModal() { _editModalVisible = false; _editModalMsg = ""; }

    async Task SaveEditModal()
    {
        _editModalBusy = true; _editModalMsg = "";
        var editableCols = _editModalCols.Where(c => c != _editModalPkCol).ToList();
        var editableVals = editableCols.Select(c => _editModalVals[c]).ToList();
        var pkVal        = _editModalVals.GetValueOrDefault(_editModalPkCol, "");
        var table        = _editModalTable;
        var pkCol        = _editModalPkCol;
        var admin        = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                var setClauses = editableCols.Select((c, i) => $"{c}=@p{i}");
                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                using var cmd = conn.CreateCommand();
                cmd.CommandText = $"UPDATE {table} SET {string.Join(", ", setClauses)} WHERE {pkCol}=@pk";
                for (int i = 0; i < editableCols.Count; i++)
                    cmd.Parameters.AddWithValue($"@p{i}",
                        string.IsNullOrEmpty(editableVals[i]) ? DBNull.Value : (object)editableVals[i]);
                cmd.Parameters.AddWithValue("@pk", long.TryParse(pkVal, out var pkLong1) ? (object)pkLong1 : pkVal);
                cmd.ExecuteNonQuery();

                Console.WriteLine($"[Diagnosis] Admin '{admin}' updated {table} {pkCol}={pkVal}: " +
                    string.Join(", ", editableCols.Select((c, i) => $"{c}='{editableVals[i]}'")));
            });
            _editModalMsg = "Saved."; _editModalOk = true;
            LoadLiveTables();
        }
        catch (Exception ex)
        {
            _editModalMsg = $"Error: {ex.Message}"; _editModalOk = false;
            Console.WriteLine($"[Diagnosis] Admin '{admin}' failed to update {table} {pkCol}={pkVal}: {ex.Message}");
        }
        finally { _editModalBusy = false; }
    }

    async Task DeleteRow(string tableName, string pkCol, string pkVal)
    {
        _pendingDelete = null;
        var admin = AdminUser();
        try
        {
            await Task.Run(() =>
            {
                using var conn = new SqliteConnection(DbCs());
                conn.Open();
                using var cmd = conn.CreateCommand();
                var pk = long.TryParse(pkVal, out var pkLong2) ? (object)pkLong2 : pkVal;

                // Fetch the row before deleting so we can log it fully
                cmd.CommandText = $"SELECT * FROM {tableName} WHERE {pkCol}=@pk";
                cmd.Parameters.AddWithValue("@pk", pk);
                var rowDesc = "";
                using (var r = cmd.ExecuteReader())
                {
                    if (r.Read())
                    {
                        var parts = new List<string>();
                        for (int i = 0; i < r.FieldCount; i++)
                            parts.Add($"{r.GetName(i)}={( r.IsDBNull(i) ? "NULL" : r.GetValue(i))}");
                        rowDesc = string.Join(", ", parts);
                    }
                }

                cmd.CommandText = $"DELETE FROM {tableName} WHERE {pkCol}=@pk";
                cmd.Parameters.Clear();
                cmd.Parameters.AddWithValue("@pk", pk);
                cmd.ExecuteNonQuery();
                Console.WriteLine($"[Diagnosis] Admin '{admin}' deleted row from {tableName}: {rowDesc}");
            });
            LoadLiveTables();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Diagnosis] Admin '{admin}' failed to delete from {tableName} {pkCol}={pkVal}: {ex.Message}");
        }
    }

