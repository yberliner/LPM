                    cmd.Parameters.AddWithValue($"@p{i}",
                        string.IsNullOrEmpty(editableVals[i]) ? DBNull.Value : (object)editableVals[i]);
                cmd.Parameters.AddWithValue("@id", _selectedUserId);
                cmd.ExecuteNonQuery();
                Console.WriteLine($"[Diagnosis] Admin '{admin}' updated core_users user '{targetUser}' (Id={_selectedUserId}): " +
