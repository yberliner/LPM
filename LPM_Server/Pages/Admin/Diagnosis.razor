@page "/Admin/Diagnosis"
@attribute [Authorize(Roles = "Admin")]
@using System.Security.Cryptography
@using System.Security.Claims
@using Microsoft.Data.Sqlite
@inject IConfiguration Config
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpCtx
@inject LPM.Services.PdfShrinkService PdfShrinkSvc

<PageTitle>Diagnosis — LPM</PageTitle>

<div class="container-fluid py-4" style="max-width:960px;">
    <h4 class="fw-bold mb-1">Diagnosis</h4>
    <p class="text-muted mb-4" style="font-size:.85rem;">
        Creates a new copy of the current database with all data tables cleared and a single
        <strong>admin / Admin1992</strong> user seeded. The live database is never touched.
    </p>

    @if (!string.IsNullOrEmpty(_resultPath))
    {
        <div class="alert alert-success d-flex align-items-center gap-2">
            <i class="ri-checkbox-circle-line" style="font-size:1.3rem;"></i>
            <div>
                <strong>Done.</strong> File created:<br />
                <code style="font-size:.82rem; word-break:break-all;">@_resultPath</code>
            </div>
        </div>
    }
    @if (!string.IsNullOrEmpty(_cedbError))
    {
        <div class="alert alert-danger">@_cedbError</div>
    }

    <div class="d-flex flex-wrap gap-3 mb-4">
        <button class="btn btn-danger d-flex align-items-center gap-2"
                disabled="@_busy" @onclick="CreateEmptyDbCopy">
            @if (_busy)
            {
                <span class="spinner-border spinner-border-sm"></span><span>Working…</span>
            }
            else
            {
                <i class="ri-database-2-line"></i><span>Create Empty DB Copy</span>
            }
        </button>

        <button class="btn btn-warning d-flex align-items-center gap-2"
                disabled="@_shrinkBusy" @onclick="RunShrinkPdf">
            @if (_shrinkBusy)
            {
                <span class="spinner-border spinner-border-sm"></span><span>Shrinking…</span>
            }
            else
            {
                <i class="ri-file-reduce-line"></i><span>Run Shrink PDF Service</span>
            }
        </button>
    </div>
    @if (!string.IsNullOrEmpty(_shrinkResult))
    {
        <div class="alert @(_shrinkResult.StartsWith("Error") ? "alert-danger" : "alert-success") mb-4">@_shrinkResult</div>
    }

    @* ── User Editor ──────────────────────────────────────────────────────── *@
    <div class="diag-editor-card mb-4">
        <div class="diag-editor-header">
            <i class="ri-user-settings-line me-2"></i>Edit User
            <span class="diag-editor-sub">core_users</span>
        </div>
        <div class="diag-editor-body">
            <div class="row g-2 mb-3">
                <div class="col-12 col-sm-7 col-md-5">
                    <label class="diag-lbl">Select user</label>
                    <select class="form-select form-select-sm" @onchange="OnUserSelected">
                        <option value="0">— choose user —</option>
                        @foreach (var u in _userList)
                        {
                            <option value="@u.Id">@u.Id — @u.Username (@u.StaffRole / @u.UserType)</option>
                        }
                    </select>
                </div>
            </div>
            @if (_selectedUserId > 0 && _userEditCols.Count > 0)
            {
                <div class="row g-2 mb-3">
                    @foreach (var col in _userEditCols)
                    {
                        var cc = col;
                        bool ro = cc == "Id";
                        <div class="col-6 col-sm-4 col-md-3">
                            <label class="diag-lbl">@cc</label>
                            @if (ro)
                            {
                                <input type="text" class="form-control form-control-sm diag-input-ro" disabled value="@_userEditVals[cc]" />
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-sm" @bind="_userEditVals[cc]" @bind:event="oninput" />
                            }
                        </div>
                    }
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
                    <button class="btn btn-primary btn-sm diag-action-btn" disabled="@_userBusy" @onclick="SaveUserFields">
                        @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-save-line me-1"></i> }
                        Save Fields
                    </button>
                </div>
                <div class="border-top pt-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-12 col-sm-5 col-md-4">
                            <label class="diag-lbl">New password</label>
                            <input type="password" class="form-control form-control-sm" placeholder="Enter new password"
                                   @bind="_newPassword" @bind:event="oninput" />
                        </div>
                        <div class="col-auto">
                            <button class="btn btn-warning btn-sm diag-action-btn"
                                    disabled="@(_userBusy || string.IsNullOrWhiteSpace(_newPassword))" @onclick="SaveUserPassword">
                                @if (_userBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-key-2-line me-1"></i> }
                                Set Password
                            </button>
                        </div>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_userMsg))
                {
                    <div class="alert @(_userMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mt-3 mb-0 diag-feedback">@_userMsg</div>
                }
            }
        </div>
    </div>

    @* ── core_pcs Editor ──────────────────────────────────────────────────── *@
    <div class="diag-editor-card mb-4">
        <div class="diag-editor-header">
            <i class="ri-computer-line me-2"></i>Edit PCs
            <span class="diag-editor-sub">core_pcs</span>
        </div>
        <div class="diag-editor-body">
            @if (!string.IsNullOrEmpty(_pcsMsg))
            {
                <div class="alert @(_pcsMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mb-3 diag-feedback">@_pcsMsg</div>
            }
            <div class="cedb-table-wrap mb-3">
                <table class="cedb-table">
                    <thead><tr><th>PcId</th><th>Name</th><th></th></tr></thead>
                    <tbody>
                        @if (_pcsRows.Count == 0)
                        {
                            <tr><td colspan="3" class="cedb-empty text-center py-2">No rows</td></tr>
                        }
                        @foreach (var row in _pcsRows)
                        {
                            var r = row;
                            bool pcsDelPending = _pendingDeletePcId == r.PcId;
                            <tr>
                                <td><span style="color:#64748b;">@r.PcId</span></td>
                                <td>@r.PersonName</td>
                                <td class="text-end" style="white-space:nowrap;">
                                    @if (pcsDelPending)
                                    {
                                        <span class="me-1" style="font-size:.8rem;">Sure?</span>
                                        <button class="btn btn-danger btn-sm py-0 px-1 me-1" title="Confirm delete"
                                                disabled="@_pcsBusy" @onclick="() => DeletePcsRow(r.PcId)">
                                            <i class="ri-check-line"></i>
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                @onclick="() => _pendingDeletePcId = 0">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1" title="Edit"
                                                disabled="@_pcsBusy"
                                                @onclick="() => OpenPcsModal(r.PcId)">
                                            <i class="ri-pencil-line"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                disabled="@_pcsBusy"
                                                @onclick="() => { _pendingDeletePcId = r.PcId; _pcsMsg = string.Empty; }">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="row g-2 align-items-end">
                <div class="col-auto">
                    <label class="diag-lbl">Add new PcId (= PersonId)</label>
                    <input type="number" class="form-control form-control-sm" style="width:130px;" placeholder="e.g. 5"
                           @bind="_newPcIdStr" @bind:event="oninput" />
                </div>
                <div class="col-auto">
                    <button class="btn btn-success btn-sm diag-action-btn"
                            disabled="@(_pcsBusy || string.IsNullOrWhiteSpace(_newPcIdStr))" @onclick="AddPcsRow">
                        @if (_pcsBusy) { <span class="spinner-border spinner-border-sm me-1"></span> } else { <i class="ri-add-line me-1"></i> }
                        Add PC
                    </button>
                </div>
            </div>
        </div>
    </div>

    @* ── core_* tables ── *@
    <div class="cedb-group-header mt-4"><i class="ri-user-line me-1"></i>core_* tables</div>
    @foreach (var t in _coreTables)
    {
        @if (t.Name == "core_persons")
        {
            @EditableSection(new EditInfo(t, "PersonId"))
        }
        else
        {
            @TableSection(t)
        }
    }

    @* ── sys_* tables ── *@
    <div class="cedb-group-header mt-3"><i class="ri-settings-3-line me-1"></i>sys_* tables</div>
    @foreach (var t in _sysTables) { @TableSection(t) }

    @* ── lkp_* tables ── *@
    <div class="cedb-group-header mt-3"><i class="ri-price-tag-3-line me-1"></i>lkp_* tables</div>
    @foreach (var t in _lkpTables) { @TableSection(t) }

    @* ── sess_* tables (editable) ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-calendar-line me-1"></i>sess_* tables
        <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(editable)</span>
    </div>
    @foreach (var t in _sessTables)
    {
        var pk = t.Name switch
        {
            "sess_sessions"       => "SessionId",
            "sess_misc_charges"   => "MiscChargeId",
            "sess_folder_summary" => "Id",
            "sess_meetings"       => "MeetingId",
            _                     => "Id"
        };
        @EditableSection(new EditInfo(t, pk))
    }

    @* ── cs_* tables (editable) ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-user-star-line me-1"></i>cs_* tables
        <span style="font-weight:400;font-size:.6rem;color:#94a3b8;text-transform:none;letter-spacing:0;">(editable)</span>
    </div>
    @foreach (var t in _csTables)
    {
        var pk = t.Name switch
        {
            "cs_reviews"          => "CsReviewId",
            "cs_work_log"         => "CsWorkLogId",
            "cs_case_supervisors" => "CsId",
            _                     => "Id"
        };
        @EditableSection(new EditInfo(t, pk))
    }

    @* ── fin_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-money-dollar-circle-line me-1"></i>fin_* tables
    </div>
    @foreach (var t in _finTables) { @TableSection(t) }

    @* ── acad_* tables ── *@
    <div class="cedb-group-header mt-3">
        <i class="ri-graduation-cap-line me-1"></i>acad_* tables
    </div>
    @foreach (var t in _acadTables) { @TableSection(t) }

    @* ── Recent PC-Folder Files (< 7 days) ────────────────────────────────── *@
    <div class="diag-editor-card mb-4 mt-4">
        <div class="diag-editor-header">
            <i class="ri-file-list-3-line me-2"></i>Recent Files — last @_recentDays day@(_recentDays != 1 ? "s" : "")
            <span class="diag-editor-sub">PC-Folders</span>
            <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.75rem;"
                    @bind="_recentDays" @bind:after="LoadRecentFiles">
                <option value="1">1 day</option>
                <option value="3">3 days</option>
                <option value="7">7 days</option>
                <option value="30">30 days</option>
            </select>
            <button class="btn btn-outline-secondary btn-sm py-0" style="font-size:.72rem;"
                    @onclick="LoadRecentFiles">
                <i class="ri-refresh-line me-1"></i>Refresh
            </button>
        </div>
        <div class="diag-editor-body">
            @if (!string.IsNullOrEmpty(_recentMsg))
            {
                <div class="alert @(_recentMsgOk ? "alert-success" : "alert-danger") py-1 px-3 mb-3 diag-feedback">@_recentMsg</div>
            }
            @if (_recentGroups.Count == 0)
            {
                <div class="cedb-empty">No files modified in the last @_recentDays day@(_recentDays != 1 ? "s" : "").</div>
            }
            else
            {
                @foreach (var g in _recentGroups)
                {
                    var grp = g;
                    <div class="mb-3">
                        <div class="diag-lbl mb-1"><i class="ri-folder-3-line me-1"></i>@grp.PcName <span style="font-weight:400;color:#94a3b8;">(@grp.Files.Count file@(grp.Files.Count != 1 ? "s" : ""))</span></div>
                        <div class="cedb-table-wrap">
                            <table class="cedb-table">
                                <thead>
                                    <tr><th>File</th><th>Modified</th><th>Size</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var file in grp.Files)
                                    {
                                        var f = file;
                                        bool filePending = _pendingDeleteFile == f.FullPath;
                                        <tr class="@(filePending ? "table-danger" : "")">
                                            <td>@f.RelPath</td>
                                            <td style="white-space:nowrap;">@f.Modified.ToString("yyyy-MM-dd HH:mm")</td>
                                            <td style="white-space:nowrap;">@FormatSize(f.Size)</td>
                                            <td class="text-end" style="white-space:nowrap;">
                                                @if (filePending)
                                                {
                                                    <span class="me-1" style="font-size:.65rem;color:#dc3545;vertical-align:middle;">Sure?</span>
                                                    <button class="btn btn-danger btn-sm py-0 px-1 me-1" @onclick="() => DeleteRecentFile(f.FullPath)">
                                                        <i class="ri-check-line"></i>
                                                    </button>
                                                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" @onclick="() => _pendingDeleteFile = null">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                                            title="Delete" @onclick="() => _pendingDeleteFile = f.FullPath">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@* ── Edit Row Modal ───────────────────────────────────────────────────────── *@
@if (_editModalVisible)
{
    <div class="diag-modal-backdrop" @onclick="CloseEditModal"></div>
    <div class="diag-modal">
        <div class="diag-modal-header">
            <span><i class="ri-pencil-line me-2"></i>Edit row — <code style="font-size:.8rem;">@_editModalTable</code></span>
            <button class="btn-close btn-close-sm" @onclick="CloseEditModal"></button>
        </div>
        <div class="diag-modal-body">
            <div class="row g-2">
                @foreach (var col in _editModalCols)
                {
                    var cc = col;
                    bool ro = cc == _editModalPkCol;
                    <div class="col-12 col-sm-6 col-md-4">
                        <label class="diag-lbl">@cc @(ro ? "(PK)" : "")</label>
                        @if (ro)
                        {
                            <input type="text" class="form-control form-control-sm diag-input-ro" disabled value="@_editModalVals[cc]" />
                        }
                        else
                        {
                            <input type="text" class="form-control form-control-sm" @bind="_editModalVals[cc]" @bind:event="oninput" />
                        }
                    </div>
                }
            </div>
            @if (!string.IsNullOrEmpty(_editModalMsg))
            {
                <div class="alert @(_editModalOk ? "alert-success" : "alert-danger") py-1 px-3 mt-3 mb-0 diag-feedback">@_editModalMsg</div>
            }
        </div>
        <div class="diag-modal-footer">
            <button class="btn btn-secondary btn-sm" @onclick="CloseEditModal">Cancel</button>
            <button class="btn btn-primary btn-sm diag-action-btn" disabled="@_editModalBusy" @onclick="SaveEditModal">
                @if (_editModalBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save
            </button>
        </div>
    </div>
}

@* ── core_pcs Edit Modal ───────────────────────────────────────────────────── *@
@if (_pcsModalVisible)
{
    <div class="diag-modal-backdrop" @onclick="ClosePcsModal"></div>
    <div class="diag-modal">
        <div class="diag-modal-header">
            <span><i class="ri-computer-line me-2"></i>Edit PC — <code style="font-size:.8rem;">core_pcs</code></span>
            <button class="btn-close btn-close-sm" @onclick="ClosePcsModal"></button>
        </div>
        <div class="diag-modal-body">
            <div class="row g-2">
                <div class="col-12 col-sm-6">
                    <label class="diag-lbl">PcId (current)</label>
                    <input type="text" class="form-control form-control-sm diag-input-ro" disabled value="@_pcsModalOldId" />
                </div>
                <div class="col-12 col-sm-6">
                    <label class="diag-lbl">PcId (new)</label>
                    <input type="number" class="form-control form-control-sm" @bind="_pcsModalNewStr" @bind:event="oninput" />
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_pcsModalMsg))
            {
                <div class="alert @(_pcsModalOk ? "alert-success" : "alert-danger") py-1 px-3 mt-3 mb-0 diag-feedback">@_pcsModalMsg</div>
            }
        </div>
        <div class="diag-modal-footer">
            <button class="btn btn-secondary btn-sm" @onclick="ClosePcsModal">Cancel</button>
            <button class="btn btn-primary btn-sm diag-action-btn" disabled="@_pcsModalBusy" @onclick="SavePcsModal">
                @if (_pcsModalBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                Save
            </button>
        </div>
    </div>
}

@code {
    // ── Read-only table display ────────────────────────────────────────────
    record TableData(string Name, string Icon, List<string> Columns, List<List<string>> Rows);

    RenderFragment<TableData> TableSection => t =>
        @<div class="cedb-section mt-3">
            <div class="cedb-section-title cedb-section-toggle" @onclick="() => ToggleSection(t.Name)">
                <i class="@t.Icon me-1"></i>@t.Name
                <span class="cedb-count">@t.Rows.Count row@(t.Rows.Count != 1 ? "s" : "")</span>
                <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.72rem;"
                        @onclick:stopPropagation="true"
                        value="@(_tableLimit.TryGetValue(t.Name, out var tl) ? tl : 200)"
                        @onchange="e => { _tableLimit[t.Name] = int.Parse(e.Value!.ToString()!); }">
                    <option value="10">10</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                    <option value="0">All</option>
                </select>
                <i class="ri-arrow-down-s-line cedb-chevron @(_collapsed.Contains(t.Name) ? "cedb-chevron-up" : "")"></i>
            </div>
            @if (!_collapsed.Contains(t.Name))
            {
                @if (t.Rows.Count == 0)
                {
                    <div class="cedb-empty">No rows</div>
                }
                else
                {
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>@foreach (var col in t.Columns) { <th>@col</th> }</tr>
                            </thead>
                            <tbody>
                                @{ int tsLimit = _tableLimit.TryGetValue(t.Name, out var tsl) ? tsl : 200;
                                   var tsRows  = tsLimit > 0 ? t.Rows.Take(tsLimit) : t.Rows; }
                                @foreach (var row in tsRows)
                                {
                                    <tr>
                                        @for (int i = 0; i < t.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            <td>@val</td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>;

    // ── Editable table display (sess_* / cs_* / core_persons) ────────────────
    record EditInfo(TableData Table, string PkCol);
    // sort state per table name: (column, ascending)
    Dictionary<string, (string Col, bool Asc)> _sortState = new();
    // row limit per table name: 0 = all, default 200
    Dictionary<string, int> _tableLimit = new();

    void SetSort(string tableName, string col)
    {
        if (_sortState.TryGetValue(tableName, out var cur) && cur.Col == col)
            _sortState[tableName] = (col, !cur.Asc);
        else
            _sortState[tableName] = (col, true);
    }

    IEnumerable<List<string>> SortedRows(TableData t)
    {
        IEnumerable<List<string>> rows = t.Rows;
        if (_sortState.TryGetValue(t.Name, out var s))
        {
            int idx = t.Columns.IndexOf(s.Col);
            if (idx >= 0)
                rows = s.Asc
                    ? rows.OrderBy(r => SortKey(r, idx))
                    : rows.OrderByDescending(r => SortKey(r, idx));
        }
        int limit = _tableLimit.TryGetValue(t.Name, out var lim) ? lim : 200;
        if (limit > 0) rows = rows.Take(limit);
        return rows;
    }

    static IComparable SortKey(List<string> row, int idx)
    {
        var v = idx < row.Count ? row[idx] : "";
        if (double.TryParse(v, out var d)) return d;
        return v;
    }

    RenderFragment<EditInfo> EditableSection => args =>
        @<div class="cedb-section mt-3">
            <div class="cedb-section-title cedb-section-toggle" @onclick="() => ToggleSection(args.Table.Name)">
                <i class="@args.Table.Icon me-1"></i>@args.Table.Name
                <span class="cedb-count">@args.Table.Rows.Count row@(args.Table.Rows.Count != 1 ? "s" : "")</span>
                <select class="form-select form-select-sm ms-auto me-2" style="width:auto;font-size:.72rem;"
                        @onclick:stopPropagation="true"
                        value="@(_tableLimit.TryGetValue(args.Table.Name, out var curLim) ? curLim : 200)"
                        @onchange="e => { _tableLimit[args.Table.Name] = int.Parse(e.Value!.ToString()!); }">
                    <option value="10">10</option>
                    <option value="100">100</option>
                    <option value="200">200</option>
                    <option value="500">500</option>
                    <option value="1000">1000</option>
                    <option value="0">All</option>
                </select>
                <i class="ri-arrow-down-s-line cedb-chevron @(_collapsed.Contains(args.Table.Name) ? "cedb-chevron-up" : "")"></i>
            </div>
            @if (!_collapsed.Contains(args.Table.Name))
            {
                @if (args.Table.Rows.Count == 0)
                {
                    <div class="cedb-empty">No rows</div>
                }
                else
                {
                    <div class="cedb-table-wrap">
                        <table class="cedb-table">
                            <thead>
                                <tr>
                                    @foreach (var col in args.Table.Columns)
                                    {
                                        var c = col;
                                        bool isSort = _sortState.TryGetValue(args.Table.Name, out var ss) && ss.Col == c;
                                        <th style="cursor:pointer;user-select:none;" @onclick:stopPropagation="true"
                                            @onclick="() => SetSort(args.Table.Name, c)">
                                            @c
                                            @if (isSort)
                                            {
                                                <i class="@(ss.Asc ? "ri-arrow-up-s-line" : "ri-arrow-down-s-line") ms-1" style="font-size:.8rem;"></i>
                                            }
                                        </th>
                                    }
                                    <th style="width:88px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in SortedRows(args.Table))
                                {
                                    var capturedRow = row;
                                    int pkIdx = args.Table.Columns.IndexOf(args.PkCol);
                                    string pkVal = pkIdx >= 0 && pkIdx < row.Count ? row[pkIdx] : "";
                                    bool isPending = _pendingDelete?.Table == args.Table.Name && _pendingDelete?.PkVal == pkVal;
                                    <tr class="@(isPending ? "table-danger" : "")">
                                        @for (int i = 0; i < args.Table.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            <td>@val</td>
                                        }
                                        <td class="text-end" style="white-space:nowrap;">
                                            @if (isPending)
                                            {
                                                <span class="me-1" style="font-size:.65rem;color:#dc3545;vertical-align:middle;">Sure?</span>
                                                <button class="btn btn-danger btn-sm py-0 px-1 me-1"
                                                        @onclick="() => DeleteRow(args.Table.Name, args.PkCol, pkVal)">
                                                    <i class="ri-check-line"></i>
                                                </button>
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1"
                                                        @onclick="() => _pendingDelete = null">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-outline-primary btn-sm py-0 px-1 me-1" title="Edit"
                                                        @onclick="() => OpenEditModal(args.Table, args.PkCol, capturedRow)">
                                                    <i class="ri-pencil-line"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                                        @onclick="() => _pendingDelete = (args.Table.Name, pkVal)">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>;

