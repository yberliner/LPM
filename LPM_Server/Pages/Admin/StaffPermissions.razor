@page "/Admin/StaffPermissions"
@attribute [Authorize(Roles = "Admin")]
@using LPM.Services
@using Microsoft.AspNetCore.Authorization
@inject DashboardService DashSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="sp-page p-3 p-md-4">

    @* ── Page Header ── *@
    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold sp-title">@LS.T("staffperm.title")</h4>
            <span class="text-muted" style="font-size:0.82rem;">@LS.T("staffperm.subtitle")</span>
        </div>
        <div class="ms-auto">
            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    @onclick="LoadData" disabled="@_loading">
                <i class="ri-refresh-line @(_loading ? "sp-spin" : "")"></i> @LS.T("common.refresh")
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <div class="text-muted">@LS.T("common.loading")</div>
        </div>
    }
    else
    {
        @* ══════════════════════════════════════════════════════════
           SECTION 1 — PENDING REQUESTS
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3">
            <i class="ri-shield-user-line me-2"></i>@LS.T("staffperm.pendingRequests")
            @if (_pending.Count > 0)
            {
                <span class="badge rounded-pill sp-badge-pending ms-2">@_pending.Count @LS.T("staffperm.pending")</span>
            }
        </div>

        @if (_pending.Count == 0)
        {
            <div class="sp-empty-block mb-5">
                <i class="ri-checkbox-circle-line text-success" style="font-size:1.8rem;"></i>
                <div class="fw-semibold mt-2" style="color:#1e3a5f;">@LS.T("staffperm.noPending")</div>
                <div class="small" style="color:#6b7280;">@LS.T("staffperm.allApproved")</div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-5 sp-card">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0 sp-table">
                        <thead>
                            <tr class="sp-thead">
                                <th class="ps-4">@LS.T("staffperm.auditor")</th>
                                <th>@LS.T("staffperm.pcPerson")</th>
                                <th class="text-center">@LS.T("staffperm.requested")</th>
                                <th class="pe-4 text-end" style="width:200px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in _pending)
                            {
                                <tr class="sp-row-pending">
                                    <td class="ps-4 py-2 fw-semibold">
                                        <div class="sp-avatar-inline">@(req.AuditorName.Length > 0 ? char.ToUpper(req.AuditorName[0]) : '?')</div>
                                        @req.AuditorName
                                    </td>
                                    <td class="py-2">
                                        <i class="ri-user-line me-1 text-muted"></i>@req.PcName
                                    </td>
                                    <td class="text-center py-2 text-muted" style="font-size:0.83rem;">@FormatDate(req.RequestedAt)</td>
                                    <td class="pe-4 py-1 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm sp-btn-approve d-flex align-items-center gap-1"
                                                    @onclick="() => Approve(req.Id)" disabled="@_busy">
                                                <i class="ri-check-line"></i>@LS.T("common.approve")
                                            </button>
                                            <button class="btn btn-sm sp-btn-reject d-flex align-items-center gap-1"
                                                    @onclick="() => Reject(req.Id)" disabled="@_busy">
                                                <i class="ri-close-line"></i>@LS.T("common.reject")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════════════════
           SECTION 2 — PERMISSION MATRIX
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3 sp-section-toggle mt-4"
             @onclick="() => _matrixSectionCollapsed = !_matrixSectionCollapsed">
            <i class="ri-arrow-down-s-line sp-section-chevron @(_matrixSectionCollapsed ? "sp-chevron-collapsed" : "") me-1"></i>
            <i class="ri-grid-line me-2"></i>Permission Matrix
            <span class="ms-2 text-muted" style="font-size:0.75rem;font-weight:400;text-transform:none;letter-spacing:0;">
                (@_allPcs.Count PCs · @_matrixAuditors.Count auditors)
            </span>
        </div>

        @if (!_matrixSectionCollapsed)
        {
            <div class="card border-0 shadow-sm sp-card mb-5">
                <div class="sp-matrix-wrap">
                    <table class="sp-matrix-table">
                        <thead>
                            <tr>
                                @* sticky PC name header *@
                                <th class="sp-mx-pc-col sp-mx-head-pc">PC</th>
                                @foreach (var aud in _matrixAuditors)
                                {
                                    <th class="sp-mx-aud-col">
                                        <div class="sp-mx-aud-label" title="@aud.AuditorName">
                                            @aud.AuditorName
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var pc in _allPcs)
                            {
                                <tr class="@(!pc.IsActive ? "sp-mx-row-inactive" : "")">
                                    <td class="sp-mx-pc-col sp-mx-pc-name @(_soloPcIds.Contains(pc.PcId) ? "sp-mx-solo-pc" : "")">
                                        @pc.FullName
                                        @if (_soloPcIds.Contains(pc.PcId))
                                        {
                                            <span class="sp-mx-solo-badge" title="Has solo auditor">S</span>
                                        }
                                        @if (!pc.IsActive)
                                        {
                                            <span class="sp-mx-inactive-badge">inactive</span>
                                        }
                                    </td>
                                    @foreach (var aud in _matrixAuditors)
                                    {
                                        var hasPerm = HasPermission(aud, pc.PcId);
                                        var cellKey = (aud.AuditorId, pc.PcId);
                                        var flashing = _flashingCells.Contains(cellKey);
                                        <td class="sp-mx-cell @(flashing ? "sp-mx-flash" : "")"
                                            @onclick="() => MatrixToggle(aud, pc.PcId, !hasPerm)"
                                            title="@aud.AuditorName — @pc.FullName">
                                            @if (aud.AllowAll)
                                            {
                                                <span class="sp-mx-allow-all" title="Allow All"></span>
                                            }
                                            else if (hasPerm)
                                            {
                                                <span class="sp-mx-check"></span>
                                            }
                                            else
                                            {
                                                <span class="sp-mx-empty"></span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="d-flex align-items-center gap-3 px-4 py-2 sp-mx-legend">
                    <span class="d-flex align-items-center gap-1"><span class="sp-mx-check sp-lg"></span> Has permission</span>
                    <span class="d-flex align-items-center gap-1"><span class="sp-mx-allow-all sp-lg"></span> Allow all</span>
                    <span class="d-flex align-items-center gap-1"><span class="sp-mx-empty sp-lg"></span> No permission</span>
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════════════════
           SECTION 3 — PER-AUDITOR PERMISSIONS (collapsible section)
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3 sp-section-toggle"
             @onclick="() => _auditorsSectionCollapsed = !_auditorsSectionCollapsed">
            <i class="ri-arrow-down-s-line sp-section-chevron @(_auditorsSectionCollapsed ? "sp-chevron-collapsed" : "") me-1"></i>
            <i class="ri-team-line me-2"></i>@LS.T("staffperm.auditorPermissions")
            <span class="ms-2 text-muted" style="font-size:0.75rem;font-weight:400;text-transform:none;letter-spacing:0;">
                (@_auditors.Count)
            </span>
        </div>

        @if (!_auditorsSectionCollapsed)
        {
            @foreach (var aud in _auditors)
            {
                var audCollapsed = _collapsedAuditors.Contains(aud.AuditorId);
                <div class="card border-0 shadow-sm mb-4 sp-card">
                    @* Card header *@
                    <div class="card-header d-flex align-items-center gap-3 py-3 px-4 border-0 sp-aud-header"
                         style="cursor:pointer;" @onclick="() => ToggleAuditorCollapse(aud.AuditorId)">
                        <i class="ri-arrow-down-s-line text-white sp-chevron @(audCollapsed ? "sp-chevron-collapsed" : "")"></i>
                        <div class="sp-avatar">@(aud.AuditorName.Length > 0 ? char.ToUpper(aud.AuditorName[0]) : '?')</div>
                        <div class="text-white lh-sm flex-grow-1">
                            <div class="fw-semibold" style="font-size:1rem;">@aud.AuditorName</div>
                            <div style="font-size:0.71rem;opacity:.72;">
                                @if (aud.AllowAll)
                                { <span>Allowed all PCs</span> }
                                else
                                { <span>@aud.ApprovedPcs.Count approved PC@(aud.ApprovedPcs.Count != 1 ? "s" : "")</span> }
                            </div>
                        </div>
                        @* Allow All toggle *@
                        <div class="d-flex align-items-center gap-2" @onclick:stopPropagation="true">
                            <span class="text-white-50" style="font-size:0.78rem;">@LS.T("staffperm.allowAll")</span>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input sp-switch" type="checkbox"
                                       checked="@aud.AllowAll"
                                       @onchange="e => ToggleAllowAll(aud.AuditorId, (bool)(e.Value ?? false))"
                                       disabled="@_busy" />
                            </div>
                        </div>
                    </div>

                    @* Approved PCs list *@
                    @if (!audCollapsed)
                    {
                    <div class="card-body p-0">
                        @if (aud.AllowAll)
                        {
                            <div class="px-4 py-3 text-muted fst-italic" style="font-size:0.87rem;">
                                <i class="ri-checkbox-circle-line text-success me-1"></i>
                                This auditor is allowed to add any PC without approval.
                            </div>
                        }
                        else if (aud.ApprovedPcs.Count == 0)
                        {
                            <div class="px-4 py-3 text-muted fst-italic" style="font-size:0.87rem;">
                                @LS.T("staffperm.noSpecificPCs")
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0 sp-table">
                                    <thead>
                                        <tr class="sp-sub-thead">
                                            <th class="ps-4">@LS.T("staffperm.pcPerson")</th>
                                            <th class="pe-4 text-end" style="width:80px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pc in aud.ApprovedPcs)
                                        {
                                            <tr class="sp-row-approved">
                                                <td class="ps-4 py-2">
                                                    <i class="ri-user-line me-1" style="color:#6b7280;"></i>@pc.PcName
                                                </td>
                                                <td class="pe-4 py-1 text-end">
                                                    <button class="btn btn-sm sp-btn-remove"
                                                            @onclick="() => RemovePermission(pc.Id)" disabled="@_busy"
                                                            title="Remove permission">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        @* Add PC row *@
                        @if (!aud.AllowAll)
                        {
                            <div class="d-flex align-items-center gap-2 px-4 py-3 sp-add-row">
                                <select class="form-select form-select-sm sp-pc-select"
                                        @bind="_addPcSelection[aud.AuditorId]">
                                    <option value="0">— select a PC to add —</option>
                                    @foreach (var pc in _allPcs.Where(p => !aud.ApprovedPcs.Any(ap => ap.PcId == p.PcId)))
                                    {
                                        <option value="@pc.PcId">@pc.FullName</option>
                                    }
                                </select>
                                <button class="btn btn-sm sp-btn-add d-flex align-items-center gap-1"
                                        @onclick="() => AddPermission(aud.AuditorId)" disabled="@_busy">
                                    <i class="ri-add-line"></i>@LS.T("common.add")
                                </button>
                            </div>
                        }
                    </div>
                    }
                </div>
            }
        }
    }

</div>

@* ── Toast ── *@
@if (!string.IsNullOrEmpty(_msg))
{
    <div class="position-fixed bottom-0 end-0 p-4" style="z-index:1200;">
        <div class="toast show align-items-center border-0 shadow-lg @(_msgIsError ? "text-bg-danger" : "text-bg-success")"
             role="alert" style="min-width:300px;border-radius:12px;">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2 fw-semibold">
                    <i class="@(_msgIsError ? "ri-error-warning-line" : "ri-checkbox-circle-line") fs-5"></i>
                    @_msg
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick='() => _msg = null'></button>
            </div>
        </div>
    </div>
}

<style>
    .sp-page  { max-width: 1400px; }
    .sp-title { color: var(--default-text-color); }

    /* Section labels */
    .sp-section-label { display: flex; align-items: center; font-size: 0.9rem; font-weight: 700; color: var(--default-text-color); text-transform: uppercase; letter-spacing: .08em; border-bottom: 2px solid #dce3f0; padding-bottom: 8px; }
    .sp-section-toggle { cursor: pointer; user-select: none; }
    .sp-section-toggle:hover { color: #2d6a9f; border-bottom-color: #2d6a9f; }
    .sp-section-chevron { font-size: 1.1rem; transition: transform .2s ease; flex-shrink: 0; }

    /* Empty block */
    .sp-empty-block { text-align: center; padding: 36px; background: #f8faff; border-radius: 12px; border: 1px dashed #c7d7f0; color: #212529; }

    /* Cards */
    .sp-card { border-radius: 14px; overflow: hidden; }
    .sp-card:hover { box-shadow: 0 6px 28px rgba(30,58,95,.13) !important; transition: box-shadow .25s; }
    .sp-aud-header { background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%); }

    /* Avatar */
    .sp-avatar { width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,.15); border: 2px solid rgba(255,255,255,.3); color: #fff; font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .sp-avatar-inline { display: inline-flex; width: 26px; height: 26px; border-radius: 50%; background: #2d6a9f; color: #fff; font-size: 0.75rem; font-weight: 700; align-items: center; justify-content: center; margin-right: 6px; flex-shrink: 0; }

    /* Switch */
    .sp-switch { width: 2.5em; height: 1.3em; cursor: pointer; }
    .sp-switch:checked { background-color: #4ade80; border-color: #4ade80; }

    /* Tables */
    .sp-table { font-size: 0.85rem; color: #212529; }
    .sp-table td, .sp-table th { color: #212529; }
    .sp-thead tr { background: #eef1f8; }
    .sp-thead th { font-size: 0.69rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: #6c757d !important; padding-top: 7px; padding-bottom: 7px; border-bottom: 1px solid #dce3f0; border-top: none; }
    .sp-sub-thead tr { background: #f4f7fc; }
    .sp-sub-thead th { font-size: 0.68rem; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: #8a99b0 !important; padding-top: 5px; padding-bottom: 5px; border-bottom: 1px solid #e8edf5; border-top: none; }

    /* Pending row */
    .sp-row-pending td { border-bottom: 1px solid #fde68a; background: #fffbeb; color: #212529 !important; }
    .sp-row-pending:hover td { background: #fef3c7; color: #212529 !important; }

    /* Approved PC row */
    .sp-row-approved td { background: #ffffff; color: #212529 !important; border-bottom: 1px solid #e8edf5; }
    .sp-row-approved:hover td { background: #f4f7fc; }
    .sp-badge-pending { background: #fef3c7; color: #92400e; font-size: 0.72rem; }

    /* Add row */
    .sp-add-row { background: #f8faff; border-top: 1px solid #e8edf5; flex-wrap: wrap; }
    .sp-pc-select { font-size: 0.83rem; flex: 1 1 200px; max-width: 320px; border-color: #ced4da; min-height: 38px; }
    .sp-pc-select:focus { border-color: #2d6a9f; box-shadow: none; }

    /* Buttons */
    .sp-btn-approve { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.78rem; font-weight: 600; touch-action: manipulation; min-height: 36px; }
    .sp-btn-approve:hover:not(:disabled) { background: #1e3a5f; color: #fff; }
    .sp-btn-reject  { background: transparent; color: #dc3545; border: 1px solid #dc3545; border-radius: 7px; font-size: 0.78rem; font-weight: 600; touch-action: manipulation; min-height: 36px; }
    .sp-btn-reject:hover:not(:disabled)  { background: #dc3545; color: #fff; }
    .sp-btn-remove  { background: transparent; color: #adb5bd; border: 1px solid #dee2e6; border-radius: 6px; font-size: 0.78rem; padding: 2px 7px; touch-action: manipulation; min-height: 34px; }
    .sp-btn-remove:hover:not(:disabled)  { background: #dc3545; color: #fff; border-color: #dc3545; }
    .sp-btn-add     { background: #2d6a9f; color: #fff; border: none; border-radius: 7px; font-size: 0.78rem; font-weight: 600; white-space: nowrap; touch-action: manipulation; min-height: 36px; }
    .sp-btn-add:hover:not(:disabled)     { background: #1e3a5f; color: #fff; }

    /* Collapse chevron */
    .sp-chevron { font-size: 1.2rem; transition: transform .25s ease; }
    .sp-chevron-collapsed { transform: rotate(-90deg); }

    /* Spinner */
    .sp-spin { display: inline-block; animation: sp-spin-anim 1s linear infinite; }
    @@keyframes sp-spin-anim { to { transform: rotate(360deg); } }

    /* ── MATRIX ── */
    .sp-matrix-wrap {
        overflow-x: scroll;
        overflow-y: auto;
        max-height: 70vh;
        scrollbar-width: thin;
        scrollbar-color: #94a3b8 #f1f5f9;
    }
    .sp-matrix-wrap::-webkit-scrollbar { width: 8px; height: 8px; }
    .sp-matrix-wrap::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
    .sp-matrix-wrap::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 4px; }
    .sp-matrix-wrap::-webkit-scrollbar-thumb:hover { background: #64748b; }
    .sp-matrix-wrap::-webkit-scrollbar-corner { background: #f1f5f9; }
    .sp-matrix-table {
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.8rem;
        table-layout: fixed;
        width: max-content;
    }

    /* Sticky header row */
    .sp-matrix-table thead tr {
        position: sticky;
        top: 0;
        z-index: 3;
        background: #eef1f8;
    }

    /* Sticky PC name column */
    .sp-mx-pc-col {
        position: sticky;
        left: 0;
        z-index: 2;
        width: 155px;
        min-width: 155px;
        max-width: 155px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .sp-mx-head-pc {
        background: #eef1f8;
        z-index: 4 !important;
        font-size: 0.69rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
        color: #6c757d;
        padding: 10px 14px;
        border-bottom: 2px solid #dce3f0;
        border-right: 2px solid #dce3f0;
    }
    .sp-mx-pc-name {
        background: #f8faff;
        padding: 5px 14px;
        font-size: 0.82rem;
        font-weight: 500;
        color: #1e3a5f;
        border-right: 2px solid #e0e8f4;
        border-bottom: 1px solid #e8edf5;
    }
    .sp-mx-row-inactive .sp-mx-pc-name {
        color: #9ca3af;
        font-weight: 400;
    }
    .sp-mx-solo-pc { color: #ea580c !important; font-weight: 600 !important; }
    .sp-mx-solo-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 14px; height: 14px; border-radius: 3px;
        background: #ea580c; color: #fff; font-size: 0.58rem; font-weight: 700;
        margin-left: 4px; vertical-align: middle; flex-shrink: 0;
    }
    .sp-mx-inactive-badge {
        display: inline-block;
        font-size: 0.62rem;
        background: #f3f4f6;
        color: #9ca3af;
        border: 1px solid #e5e7eb;
        border-radius: 4px;
        padding: 1px 5px;
        margin-left: 5px;
        vertical-align: middle;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    /* Auditor column headers — rotated diagonal text */
    .sp-mx-aud-col {
        min-width: 38px;
        max-width: 38px;
        width: 38px;
        padding: 0;
        vertical-align: bottom;
        text-align: center;
        border-bottom: 2px solid #dce3f0;
        border-right: 1px solid #e8edf5;
        height: 110px;
    }
    .sp-mx-aud-label {
        writing-mode: vertical-rl;
        transform: rotate(180deg);
        white-space: nowrap;
        font-size: 0.72rem;
        font-weight: 600;
        color: #374151;
        letter-spacing: .02em;
        padding: 8px 10px 6px;
        max-height: 100px;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Matrix cells */
    .sp-mx-cell {
        width: 38px;
        min-width: 38px;
        text-align: center;
        vertical-align: middle;
        padding: 6px 0;               /* 6px gives ~30px row height — more touch-friendly */
        cursor: pointer;
        border-bottom: 1px solid #e8edf5;
        border-right: 1px solid #e8edf5;
        transition: background 0.08s ease;
        user-select: none;
        touch-action: manipulation;   /* eliminates 300ms tap delay on iOS/Android */
        -webkit-tap-highlight-color: transparent;
    }
    .sp-mx-cell:hover { background: #dbeafe; }
    .sp-mx-row-inactive .sp-mx-cell { background: #fafafa; }
    .sp-mx-row-inactive .sp-mx-cell:hover { background: #f0f0f0; }

    /* Flash animation — very fast */
    @@keyframes sp-cell-flash {
        0%   { background: #bfdbfe; }
        50%  { background: #93c5fd; }
        100% { background: transparent; }
    }
    .sp-mx-flash { animation: sp-cell-flash 0.15s ease-out forwards; }

    /* Permission indicators */
    .sp-mx-check {
        display: inline-block;
        width: 18px; height: 18px;
        border-radius: 5px;
        background: #2d6a9f;
        position: relative;
    }
    .sp-mx-check::after {
        content: '';
        position: absolute;
        left: 5px; top: 2px;
        width: 5px; height: 9px;
        border: 2px solid #fff;
        border-top: none; border-left: none;
        transform: rotate(45deg);
    }
    .sp-mx-allow-all {
        display: inline-block;
        width: 18px; height: 18px;
        border-radius: 5px;
        background: #16a34a;
        position: relative;
    }
    .sp-mx-allow-all::after {
        content: '∞';
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        color: #fff;
        line-height: 1;
    }
    .sp-mx-empty {
        display: inline-block;
        width: 18px; height: 18px;
        border-radius: 5px;
        border: 1.5px solid #d1d5db;
        background: #fff;
    }

    /* Responsive — tablet ≤768px */
    @@media (max-width: 768px) {
        .sp-page { max-width: 100%; }
        .sp-mx-pc-col { width: 110px; min-width: 110px; max-width: 110px; font-size: 0.73rem; }
        .sp-mx-pc-name { padding: 4px 8px; }
        .sp-mx-aud-col { min-width: 34px; max-width: 34px; width: 34px; }
        .sp-mx-cell { min-width: 34px; width: 34px; }
        .sp-mx-check, .sp-mx-allow-all, .sp-mx-empty { width: 16px; height: 16px; }
        .sp-matrix-wrap { max-height: 55vh; }
        .sp-mx-aud-label { font-size: 0.65rem; padding: 6px 8px 4px; }
        .sp-aud-header { padding-left: 12px !important; padding-right: 12px !important; }
    }

    /* Responsive — mobile ≤480px */
    @@media (max-width: 480px) {
        .sp-page { padding: 12px !important; }

        /* Section label */
        .sp-section-label { font-size: 0.78rem; letter-spacing: .04em; }

        /* Auditor card header — let Allow-All toggle wrap to its own line */
        .sp-aud-header {
            flex-wrap: wrap !important;
            gap: 8px !important;
            padding: 10px 12px !important;
        }
        .sp-avatar { width: 34px; height: 34px; font-size: 0.95rem; }
        /* Allow-All block stretches to full width when wrapped */
        .sp-aud-header > div[onclick\:stoppropagation] {
            width: 100%;
            justify-content: flex-end;
            border-top: 1px solid rgba(255,255,255,.15);
            padding-top: 6px;
        }

        /* Add-PC row — stack select above button */
        .sp-add-row {
            flex-direction: column !important;
            align-items: stretch !important;
            padding: 10px 12px !important;
            gap: 8px !important;
        }
        .sp-pc-select { max-width: 100% !important; width: 100%; font-size: 1rem; min-height: 44px; }
        .sp-btn-add { width: 100%; justify-content: center; min-height: 40px; }

        /* Pending request buttons — stack them */
        .sp-btn-approve, .sp-btn-reject { font-size: 0.75rem; padding: 5px 10px; min-height: 36px; }

        /* Matrix */
        .sp-mx-pc-col { width: 90px; min-width: 90px; max-width: 90px; }
        .sp-mx-pc-name { font-size: 0.72rem; padding: 4px 6px; }
        .sp-matrix-wrap { max-height: 50vh; }
        .sp-mx-aud-col { min-width: 36px; max-width: 36px; width: 36px; height: 90px; }
        .sp-mx-cell { min-width: 36px; width: 36px; padding: 8px 0; }  /* taller touch targets */

        /* Toast full width on mobile */
        .toast { min-width: calc(100vw - 32px) !important; }
    }

    /* Legend */
    .sp-mx-legend {
        background: #f8faff;
        border-top: 1px solid #e8edf5;
        font-size: 0.75rem;
        color: #6b7280;
        flex-wrap: wrap;
    }
    .sp-mx-check.sp-lg, .sp-mx-allow-all.sp-lg, .sp-mx-empty.sp-lg {
        width: 14px; height: 14px;
    }
</style>

@code {
    private List<PermissionRequest> _pending   = new();
    private List<AuditorPermGroup>  _auditors  = new();
    private List<PcInfo>            _allPcs    = new();
    private List<AuditorPermGroup>  _matrixAuditors = new();
    private HashSet<int>            _soloPcIds = new();
    private Dictionary<int, int>    _addPcSelection = new();

    private bool    _loading = true;
    private bool    _busy;
    private string? _msg;
    private bool    _msgIsError;
    private HashSet<int> _collapsedAuditors = new();
    private bool    _auditorsSectionCollapsed = false;
    private bool    _matrixSectionCollapsed   = false;
    private string  _username = "";

    // Tracks cells currently showing the flash animation
    private HashSet<(int AuditorId, int PcId)> _flashingCells = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }
        _username = authState.User.Identity?.Name ?? "";
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        await Task.Yield();

        _pending  = DashSvc.GetPendingPermissionRequests();
        _auditors = DashSvc.GetAuditorPermGroups();
        _allPcs   = DashSvc.GetAllPcs().Where(p => p.WorkCapacity != "CSSolo").ToList();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == "Solo").Select(a => a.AuditorId).ToHashSet();

        foreach (var aud in _auditors)
            _addPcSelection.TryAdd(aud.AuditorId, 0);

        _loading = false;
    }

    private void Approve(int id)
    {
        var req = _pending.FirstOrDefault(r => r.Id == id);
        Console.WriteLine($"[StaffPermissions] Approved permission {id} for {req?.AuditorName} -> {req?.PcName} by '{_username}'");
        _busy = true;
        DashSvc.ApprovePermissionRequest(id);
        _busy = false;
        _pending.RemoveAll(r => r.Id == id);
        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
        ShowMsg("Permission approved.", false);
    }

    private void Reject(int id)
    {
        var req = _pending.FirstOrDefault(r => r.Id == id);
        Console.WriteLine($"[StaffPermissions] Rejected permission {id} for {req?.AuditorName} -> {req?.PcName} by '{_username}'");
        _busy = true;
        DashSvc.RejectPermissionRequest(id);
        _busy = false;
        _pending.RemoveAll(r => r.Id == id);
        ShowMsg("Request rejected and PC removed from dashboard.", false);
    }

    private void ToggleAuditorCollapse(int auditorId)
    {
        if (!_collapsedAuditors.Remove(auditorId))
            _collapsedAuditors.Add(auditorId);
    }

    private void ToggleAllowAll(int auditorId, bool allow)
    {
        Console.WriteLine($"[StaffPermissions] Set AllowAll={allow} for auditor {auditorId} by '{_username}'");
        _busy = true;
        DashSvc.SetAuditorAllowAll(auditorId, allow);
        _busy = false;
        var idx = _auditors.FindIndex(a => a.AuditorId == auditorId);
        if (idx >= 0)
            _auditors[idx] = _auditors[idx] with { AllowAll = allow };
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
    }

    private void AddPermission(int auditorId)
    {
        if (!_addPcSelection.TryGetValue(auditorId, out var pcId) || pcId == 0) return;
        var pc = _allPcs.FirstOrDefault(p => p.PcId == pcId);
        if (pc is null) return;

        Console.WriteLine($"[StaffPermissions] Added permission for auditor {auditorId} -> PC {pcId} ({pc.FullName}) by '{_username}'");
        _busy = true;
        DashSvc.AddApprovedPermission(auditorId, pcId);
        _busy = false;
        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
        _addPcSelection[auditorId] = 0;
        ShowMsg($"{pc.FullName} added.", false);
    }

    private void RemovePermission(int id)
    {
        Console.WriteLine($"[StaffPermissions] Deleted permission {id} by '{_username}'");
        _busy = true;
        DashSvc.RemovePermission(id);
        _busy = false;
        foreach (var aud in _auditors)
            aud.ApprovedPcs.RemoveAll(p => p.Id == id);
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
        ShowMsg("Permission removed.", false);
    }

    private bool HasPermission(AuditorPermGroup aud, int pcId)
        => aud.AllowAll || aud.ApprovedPcs.Any(p => p.PcId == pcId);

    private async Task MatrixToggle(AuditorPermGroup aud, int pcId, bool grant)
    {
        if (aud.AllowAll) return; // AllowAll cells are read-only

        var cellKey = (aud.AuditorId, pcId);
        // Trigger flash
        _flashingCells.Add(cellKey);
        StateHasChanged();
        _ = Task.Delay(150).ContinueWith(_ =>
        {
            _flashingCells.Remove(cellKey);
            InvokeAsync(StateHasChanged);
        });

        if (grant)
        {
            DashSvc.AddApprovedPermission(aud.AuditorId, pcId);
            _auditors = DashSvc.GetAuditorPermGroups();
        }
        else
        {
            var perm = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pcId);
            if (perm is not null)
            {
                DashSvc.RemovePermission(perm.Id);
                foreach (var a in _auditors)
                    a.ApprovedPcs.RemoveAll(p => p.PcId == pcId && a.AuditorId == aud.AuditorId);
            }
        }
        _matrixAuditors = _auditors.Where(a => a.StaffRole != "Solo").ToList();
    }

    private void ShowMsg(string msg, bool isError) { _msg = msg; _msgIsError = isError; }

    private static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;
}
