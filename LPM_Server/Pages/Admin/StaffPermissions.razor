    /* Responsive — tablet ≤768px */
    @@media (max-width: 768px) {
        .sp-page { max-width: 100%; }
        .sp-mx-pc-col { width: 110px; min-width: 110px; max-width: 110px; font-size: 0.73rem; }
        .sp-mx-pc-name { padding: 4px 8px; }
        .sp-mx-aud-col { min-width: 34px; max-width: 34px; width: 34px; }
        .sp-mx-cell { min-width: 34px; width: 34px; }
        .sp-mx-check, .sp-mx-allow-all, .sp-mx-empty { width: 16px; height: 16px; }
        .sp-matrix-wrap { max-height: 75vh; }
        .sp-mx-aud-label { font-size: 0.65rem; padding: 6px 8px 4px; }
        .sp-aud-header { padding-left: 12px !important; padding-right: 12px !important; }
