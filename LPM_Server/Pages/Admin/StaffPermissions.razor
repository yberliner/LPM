    @@media (max-width: 1200px) {
        .sp-matrix-with-legend { flex-direction: column; }
        .sp-legend-panel { flex: none; width: 100%; position: static; }
    }

    [data-theme-mode="dark"] .sp-legend-panel {
        background: linear-gradient(135deg, #1e293b, #0f172a);
        border-color: #334155;
        box-shadow: 0 4px 16px rgba(0,0,0,.3);
    }
    [data-theme-mode="dark"] .sp-legend-title { color: #e2e8f0; border-bottom-color: #334155; }
    [data-theme-mode="dark"] .sp-legend-section-title { color: #64748b; }
    [data-theme-mode="dark"] .sp-legend-text strong { color: #e2e8f0; }
    [data-theme-mode="dark"] .sp-legend-text span { color: #64748b; }
    [data-theme-mode="dark"] .sp-legend-item:hover { background: rgba(59,130,246,.12); }
    [data-theme-mode="dark"] .sp-legend-hint { border-top-color: #334155; color: #94a3b8; }

    .sp-mx-aud   { display:inline-flex; align-items:center; justify-content:center; width:22px; height:18px; background:#2d6a9f; color:#fff; border-radius:3px; font-size:.62rem; font-weight:700; }
    .sp-mx-cs    { display:inline-flex; align-items:center; justify-content:center; width:22px; height:18px; background:#198754; color:#fff; border-radius:3px; font-size:.62rem; font-weight:700; }
    .sp-mx-csr   { display:inline-flex; align-items:center; justify-content:center; width:26px; height:18px; background:#0d9488; color:#fff; border-radius:3px; font-size:.55rem; font-weight:700; }
    .sp-mx-css   { display:inline-flex; align-items:center; justify-content:center; width:26px; height:18px; background:#d97706; color:#fff; border-radius:3px; font-size:.55rem; font-weight:700; }
    .sp-mx-both  { display:inline-flex; align-items:center; justify-content:center; width:30px; height:18px; background:#7c3aed; color:#fff; border-radius:3px; font-size:.55rem; font-weight:700; }
    .sp-mx-bothr { display:inline-flex; align-items:center; justify-content:center; width:26px; height:18px; background:#6d28d9; color:#fff; border-radius:3px; font-size:.55rem; font-weight:700; }
    .sp-mx-boths { display:inline-flex; align-items:center; justify-content:center; width:26px; height:18px; background:#9333ea; color:#fff; border-radius:3px; font-size:.55rem; font-weight:700; }
    .sp-mx-aud.sp-lg, .sp-mx-cs.sp-lg, .sp-mx-csr.sp-lg, .sp-mx-css.sp-lg, .sp-mx-both.sp-lg, .sp-mx-bothr.sp-lg, .sp-mx-boths.sp-lg { width:34px; height:20px; font-size:.6rem; }
    .sp-mx-allow-all.sp-lg, .sp-mx-empty.sp-lg { width: 14px; height: 14px; }
    .sp-cap-select { width: auto; min-width: 90px; }
</style>

@code {
    private List<PermissionRequest>  _pending        = new();
    private List<AuditorPermGroup>   _auditors       = new();
    private List<PcInfo>             _allPcs         = new();
    private List<AuditorPermGroup>   _matrixAuditors = new();
    private HashSet<int>             _soloPcIds      = new();
    private Dictionary<int, int>     _addPcSelection = new();
    private Dictionary<int, string>  _addPcCapacity  = new();

    private bool    _loading = true;
    private bool    _busy;
    private string? _msg;
    private bool    _msgIsError;
    private HashSet<int> _collapsedAuditors = new();
    private bool    _auditorsSectionCollapsed = false;
    private bool    _matrixSectionCollapsed   = false;
    private string  _username = "";

    // Tracks cells currently showing the flash animation
    private HashSet<(int AuditorId, int PcId)> _flashingCells = new();
    private string _matrixFilter = "All";
    private bool   _hideFullCoverage;
    private string _pcSearchText = "";
    private HashSet<int>? _frozenPcIds;  // non-null when "Hide full coverage" is ON — freezes the visible row set

    // Right-click role picker context menu
    private record RoleCtxMenu(AuditorPermGroup Aud, int PcId, string AuditorName, string PcName, string? CurrentCap, bool IsCs, double X, double Y);
    private RoleCtxMenu? _ctxMenu;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!authState.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home", forceLoad: false);
            return;
        }
        _username = authState.User.Identity?.Name ?? "";
        await LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Attach the page-first wheel handler once the matrix container is in the DOM.
        // (Safe to call repeatedly — the JS side is idempotent.)
        if (!_loading && !_matrixSectionCollapsed)
        {
            try { await JS.InvokeVoidAsync("lpmAttachMatrixScroll", "sp-matrix-wrap"); }
            catch { /* JS not loaded yet or element missing — harmless */ }
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();
        await Task.Yield();

        _pending  = DashSvc.GetPendingPermissionRequests();
        _auditors = DashSvc.GetAuditorPermGroups();
        _allPcs   = DashSvc.GetAllPcs().OrderBy(p => p.FullName).ToList();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == StaffRoles.Solo).Select(a => a.AuditorId).ToHashSet();

        foreach (var aud in _auditors)
        {
            _addPcSelection.TryAdd(aud.AuditorId, 0);
            _addPcCapacity.TryAdd(aud.AuditorId, StaffRoles.Auditor);
        }

        _loading = false;
    }

    private void Approve(int id)
    {
        var req = _pending.FirstOrDefault(r => r.Id == id);
        Console.WriteLine($"[StaffPermissions] Approved permission {id} for {req?.AuditorName} -> {req?.PcName} by '{_username}'");
        _busy = true;
        DashSvc.ApprovePermissionRequest(id);
        _busy = false;
        _pending.RemoveAll(r => r.Id == id);
        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == StaffRoles.Solo).Select(a => a.AuditorId).ToHashSet();
        ShowMsg("Permission approved.", false);
    }

    private void Reject(int id)
    {
        var req = _pending.FirstOrDefault(r => r.Id == id);
        Console.WriteLine($"[StaffPermissions] Rejected permission {id} for {req?.AuditorName} -> {req?.PcName} by '{_username}'");
        _busy = true;
        DashSvc.RejectPermissionRequest(id);
        _busy = false;
        _pending.RemoveAll(r => r.Id == id);
        ShowMsg("Request rejected and PC removed from dashboard.", false);
    }

    private void ToggleAuditorCollapse(int auditorId)
    {
        if (!_collapsedAuditors.Remove(auditorId))
            _collapsedAuditors.Add(auditorId);
    }

    private void ToggleAllowAll(int auditorId, bool allow)
    {
        Console.WriteLine($"[StaffPermissions] Set AllowAll={allow} for auditor {auditorId} by '{_username}'");
        _busy = true;
        DashSvc.SetAuditorAllowAll(auditorId, allow);
        _busy = false;
        var idx = _auditors.FindIndex(a => a.AuditorId == auditorId);
        if (idx >= 0)
            _auditors[idx] = _auditors[idx] with { AllowAll = allow };
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
    }

    private void AddPermission(int auditorId)
    {
        if (!_addPcSelection.TryGetValue(auditorId, out var pcId) || pcId == 0) return;
        var pc = _allPcs.FirstOrDefault(p => p.PcId == pcId);
        if (pc is null) return;

        var capacity = _addPcCapacity.GetValueOrDefault(auditorId, StaffRoles.Auditor);
        Console.WriteLine($"[StaffPermissions] Added permission for auditor {auditorId} -> PC {pcId} ({pc.FullName}) as {capacity} by '{_username}'");
        _busy = true;
        DashSvc.AddApprovedPermission(auditorId, pcId, capacity);
        _busy = false;
        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == StaffRoles.Solo).Select(a => a.AuditorId).ToHashSet();
        _addPcSelection[auditorId] = 0;
        ShowMsg($"{pc.FullName} added as {capacity}.", false);
    }

    private void RemovePermission(int id)
    {
        Console.WriteLine($"[StaffPermissions] Deleted permission {id} by '{_username}'");
        _busy = true;
        DashSvc.RemovePermission(id);
        _busy = false;
        foreach (var aud in _auditors)
            aud.ApprovedPcs.RemoveAll(p => p.Id == id);
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        ShowMsg("Permission removed.", false);
    }

    private bool HasPermission(AuditorPermGroup aud, int pcId)
        => aud.ApprovedPcs.Any(p => p.PcId == pcId);

    private void MatrixToggle(AuditorPermGroup aud, int pcId)
    {

        var cellKey = (aud.AuditorId, pcId);
        _flashingCells.Add(cellKey);
        StateHasChanged();
        _ = Task.Delay(150).ContinueWith(_ => { _flashingCells.Remove(cellKey); InvokeAsync(StateHasChanged); });

        var pcName = _allPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        var existing = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pcId);
        var isCs = StaffRoles.IsCS(aud.StaffRole);
        // Click cycle for CS staff: Auditor → CS → CSReview → CSSolo → AuditorAndCS → AuditorAndCSReview → AuditorAndCSSolo → Remove
        // Click cycle for non-CS staff: Auditor → Remove
        string? nextCap = (existing?.WorkCapacity, isCs) switch
        {
            (null, _)                              => StaffRoles.Auditor,
            (StaffRoles.Auditor, true)             => StaffRoles.CS,
            (StaffRoles.CS, true)                  => StaffRoles.CSReview,
            (StaffRoles.CSReview, true)            => StaffRoles.CSSolo,
            (StaffRoles.CSSolo, true)              => StaffRoles.AuditorAndCS,
            (StaffRoles.AuditorAndCS, true)        => StaffRoles.AuditorAndCSReview,
            (StaffRoles.AuditorAndCSReview, true)  => StaffRoles.AuditorAndCSSolo,
            _                                      => null, // remove
        };

        if (existing is null)
        {
            Console.WriteLine($"[StaffPermissions] MatrixToggle: granted {nextCap} — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
            DashSvc.AddApprovedPermission(aud.AuditorId, pcId, nextCap!);
        }
        else if (nextCap != null)
        {
            Console.WriteLine($"[StaffPermissions] MatrixToggle: {existing.WorkCapacity}→{nextCap} — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
            DashSvc.AddApprovedPermission(aud.AuditorId, pcId, nextCap);
        }
        else
        {
            Console.WriteLine($"[StaffPermissions] MatrixToggle: removed '{existing.WorkCapacity}' — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
            DashSvc.RemovePermission(existing.Id);
        }
        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == StaffRoles.Solo).Select(a => a.AuditorId).ToHashSet();
    }

    // ── Capacity display helpers ──
    static string CapLabel(string cap) => cap switch
    {
        StaffRoles.Auditor            => "A",
        StaffRoles.CS                 => "CS",
        StaffRoles.CSReview           => "CSR",
        StaffRoles.CSSolo             => "CSS",
        StaffRoles.AuditorAndCS       => "A+CS",
        StaffRoles.AuditorAndCSReview => "A+R",
        StaffRoles.AuditorAndCSSolo   => "A+S",
        _ => "?"
    };

    string CellTooltip(AuditorPermGroup aud, int pcId, bool hasPerm)
    {
        var pcName = _allPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        if (!hasPerm) return $"{aud.AuditorName} — {pcName}";
        var cap = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pcId)?.WorkCapacity ?? StaffRoles.Auditor;
        return $"{aud.AuditorName} — {pcName} [{CapTooltip(cap)}]";
    }

    static string CapTooltip(string cap) => cap switch
    {
        StaffRoles.Auditor            => "Auditor",
        StaffRoles.CS                 => "CS (all sessions)",
        StaffRoles.CSReview           => "CS Review (non-solo only)",
        StaffRoles.CSSolo             => "CS Solo (solo only)",
        StaffRoles.AuditorAndCS       => "Auditor + CS (all sessions)",
        StaffRoles.AuditorAndCSReview => "Auditor + CS Review (non-solo only)",
        StaffRoles.AuditorAndCSSolo   => "Auditor + CS Solo (solo only)",
        _ => cap
    };

    static string CapCssClass(string cap) => cap switch
    {
        StaffRoles.Auditor            => "sp-mx-aud",
        StaffRoles.CS                 => "sp-mx-cs",
        StaffRoles.CSReview           => "sp-mx-csr",
        StaffRoles.CSSolo             => "sp-mx-css",
        StaffRoles.AuditorAndCS       => "sp-mx-both",
        StaffRoles.AuditorAndCSReview => "sp-mx-bothr",
        StaffRoles.AuditorAndCSSolo   => "sp-mx-boths",
        _ => "sp-mx-aud"
    };

    // ── Filter helpers ──
    private bool PcHasAuditor(int pcId)
        => _matrixAuditors.Any(a => a.ApprovedPcs.Any(p => p.PcId == pcId && StaffRoles.IsAuditorCapacity(p.WorkCapacity)));

    private bool PcHasCs(int pcId)
        => _matrixAuditors.Any(a => a.ApprovedPcs.Any(p => p.PcId == pcId && StaffRoles.IsCsCapacity(p.WorkCapacity)));

    private bool IsFullCoverage(int pcId) => PcHasAuditor(pcId) && PcHasCs(pcId);

    private List<PcInfo> GetFilteredPcs()
    {
        IEnumerable<PcInfo> list;

        if (_frozenPcIds != null)
        {
            // Freeze mode: show exactly the rows that were visible when "Hide full coverage" was turned on,
            // regardless of whether they've since become fully covered.
            var frozen = _frozenPcIds;
            list = _allPcs.Where(pc => frozen.Contains(pc.PcId));
        }
        else
        {
            list = _matrixFilter switch
            {
                "Unassigned" => _allPcs.Where(pc => !PcHasAuditor(pc.PcId) && !PcHasCs(pc.PcId)),
                "Partial"    => _allPcs.Where(pc => PcHasAuditor(pc.PcId) != PcHasCs(pc.PcId)),
                "Solo"       => _allPcs.Where(pc => _soloPcIds.Contains(pc.PcId)),
                _            => _allPcs.AsEnumerable()
            };
        }

        if (!string.IsNullOrWhiteSpace(_pcSearchText))
        {
            var q = _pcSearchText.Trim();
            list = list.Where(pc => pc.FullName.Contains(q, StringComparison.OrdinalIgnoreCase));
        }

        return list.ToList();
    }

    private void OpenRoleMenu(MouseEventArgs e, AuditorPermGroup aud, int pcId)
    {
        var pcName  = _allPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        var current = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pcId)?.WorkCapacity;
        var isCs    = StaffRoles.IsCS(aud.StaffRole);
        _ctxMenu = new RoleCtxMenu(aud, pcId, aud.AuditorName, pcName, current, isCs, e.ClientX, e.ClientY);
    }

    private void CloseRoleMenu() => _ctxMenu = null;

    private void ApplyRole(string? cap)
    {
        if (_ctxMenu == null) return;
        var aud = _ctxMenu.Aud;
        var pcId = _ctxMenu.PcId;
        var pcName = _ctxMenu.PcName;
        var existing = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pcId);

        if (cap == null)
        {
            // Remove
            if (existing != null)
            {
                Console.WriteLine($"[StaffPermissions] Context menu: removed '{existing.WorkCapacity}' — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
                DashSvc.RemovePermission(existing.Id);
            }
        }
        else
        {
            if (existing == null)
            {
                Console.WriteLine($"[StaffPermissions] Context menu: granted {cap} — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
                DashSvc.AddApprovedPermission(aud.AuditorId, pcId, cap);
            }
            else if (existing.WorkCapacity != cap)
            {
                Console.WriteLine($"[StaffPermissions] Context menu: {existing.WorkCapacity}→{cap} — auditor='{aud.AuditorName}' (id={aud.AuditorId}) PC='{pcName}' (id={pcId}) by '{_username}'");
                DashSvc.AddApprovedPermission(aud.AuditorId, pcId, cap);
            }
        }

        var cellKey = (aud.AuditorId, pcId);
        _flashingCells.Add(cellKey);
        _ = Task.Delay(150).ContinueWith(_ => { _flashingCells.Remove(cellKey); InvokeAsync(StateHasChanged); });

        _auditors = DashSvc.GetAuditorPermGroups();
        _matrixAuditors = _auditors.Where(a => a.StaffRole != StaffRoles.Solo).ToList();
        _soloPcIds = _auditors.Where(a => a.StaffRole == StaffRoles.Solo).Select(a => a.AuditorId).ToHashSet();

        _ctxMenu = null;
    }

    private void OnHideFullCoverageChanged(ChangeEventArgs e)
    {
        _hideFullCoverage = (bool)(e.Value ?? false);
        if (_hideFullCoverage)
        {
            // Snapshot the currently visible (non-full-coverage) PCs and freeze the row set.
            var current = _matrixFilter switch
            {
                "Unassigned" => _allPcs.Where(pc => !PcHasAuditor(pc.PcId) && !PcHasCs(pc.PcId)),
                "Partial"    => _allPcs.Where(pc => PcHasAuditor(pc.PcId) != PcHasCs(pc.PcId)),
                "Solo"       => _allPcs.Where(pc => _soloPcIds.Contains(pc.PcId)),
                _            => _allPcs.AsEnumerable()
            };
            _frozenPcIds = current.Where(pc => !IsFullCoverage(pc.PcId)).Select(pc => pc.PcId).ToHashSet();
        }
        else
        {
            _frozenPcIds = null;
        }
    }

    private int CountByFilter(string filter) => filter switch
    {
        "Unassigned" => _allPcs.Count(pc => !PcHasAuditor(pc.PcId) && !PcHasCs(pc.PcId)),
        "Partial"    => _allPcs.Count(pc => PcHasAuditor(pc.PcId) != PcHasCs(pc.PcId)),
        "Solo"       => _allPcs.Count(pc => _soloPcIds.Contains(pc.PcId)),
        _            => _allPcs.Count
    };

    private void ShowMsg(string msg, bool isError) { _msg = msg; _msgIsError = isError; }

    private static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;
}
