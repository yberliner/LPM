    /* Responsive — mobile ≤480px */
    @@media (max-width: 480px) {
        .sp-page { padding: 12px !important; }

        /* Section label */
        .sp-section-label { font-size: 0.78rem; letter-spacing: .04em; }

        /* Auditor card header — let Allow-All toggle wrap to its own line */
        .sp-aud-header {
            flex-wrap: wrap !important;
            gap: 8px !important;
            padding: 10px 12px !important;
        }
        .sp-avatar { width: 34px; height: 34px; font-size: 0.95rem; }
        /* Allow-All block stretches to full width when wrapped */
        .sp-aud-header > div[onclick\:stoppropagation] {
            width: 100%;
            justify-content: flex-end;
            border-top: 1px solid rgba(255,255,255,.15);
            padding-top: 6px;
        }

        /* Add-PC row — stack select above button */
        .sp-add-row {
            flex-direction: column !important;
            align-items: stretch !important;
            padding: 10px 12px !important;
            gap: 8px !important;
        }
        .sp-pc-select { max-width: 100% !important; width: 100%; font-size: 1rem; min-height: 44px; }
        .sp-btn-add { width: 100%; justify-content: center; min-height: 40px; }

        /* Pending request buttons — stack them */
        .sp-btn-approve, .sp-btn-reject { font-size: 0.75rem; padding: 5px 10px; min-height: 36px; }

        /* Matrix */
        .sp-mx-pc-col { width: 90px; min-width: 90px; max-width: 90px; }
        .sp-mx-pc-name { font-size: 0.72rem; padding: 4px 6px; }
        .sp-matrix-wrap { max-height: 65vh; }
        .sp-mx-aud-col { min-width: 36px; max-width: 36px; width: 36px; height: 90px; }
        .sp-mx-cell { min-width: 36px; width: 36px; padding: 8px 0; }  /* taller touch targets */

        /* Toast full width on mobile */
        .toast { min-width: calc(100vw - 32px) !important; }
    }

    /* ── FILTER BAR ── */
    .sp-filter-bar {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 5px 6px;
        background: linear-gradient(135deg, rgba(238,241,248,0.9) 0%, rgba(224,232,244,0.9) 100%);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 14px;
        border: 1px solid rgba(209,213,219,0.5);
        box-shadow: 0 1px 8px rgba(30,58,95,0.06);
        flex-wrap: wrap;
    }
    .sp-filter-btn {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 14px;
        border: 1px solid transparent;
        border-radius: 10px;
        background: transparent;
        color: #6b7280;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
        white-space: nowrap;
        touch-action: manipulation;
        min-height: 36px;
        position: relative;
        overflow: hidden;
    }
    .sp-filter-btn::before {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        opacity: 0;
        transition: opacity 0.28s;
        background: radial-gradient(circle at center, rgba(45,106,159,0.12) 0%, transparent 70%);
    }
    .sp-filter-btn:hover:not(.sp-filter-active)::before { opacity: 1; }
    .sp-filter-btn:hover:not(.sp-filter-active) {
        color: #1e3a5f;
        border-color: rgba(45,106,159,0.18);
    }
    .sp-filter-btn.sp-filter-active {
        background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%);
        color: #fff;
        box-shadow: 0 3px 14px rgba(30,58,95,0.3), inset 0 1px 0 rgba(255,255,255,0.15);
        transform: translateY(-1px);
    }
    .sp-filter-btn.sp-filter-active:hover {
        box-shadow: 0 5px 20px rgba(30,58,95,0.4), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .sp-filter-btn i { font-size: 0.92rem; transition: transform 0.2s; }
    .sp-filter-btn:hover i { transform: scale(1.15); }
    .sp-filter-count {
        display: inline-flex;
        align-items: center;
