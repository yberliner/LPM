    /* Matrix cells */
    .sp-mx-cell {
        width: 38px;
        min-width: 38px;
        text-align: center;
        vertical-align: middle;
        padding: 6px 0;               /* 6px gives ~30px row height — more touch-friendly */
        cursor: pointer;
        border-bottom: 1px solid #e8edf5;
        border-right: 1px solid #e8edf5;
        transition: background 0.08s ease;
        user-select: none;
        touch-action: manipulation;   /* eliminates 300ms tap delay on iOS/Android */
        -webkit-tap-highlight-color: transparent;
    }
    .sp-mx-cell:hover { background: #dbeafe; }
    .sp-mx-row-inactive .sp-mx-cell { background: #fafafa; }
    .sp-mx-row-inactive .sp-mx-cell:hover { background: #f0f0f0; }

    /* Flash animation — very fast */
    @@keyframes sp-cell-flash {
        0%   { background: #bfdbfe; }
        50%  { background: #93c5fd; }
        100% { background: transparent; }
    }
    .sp-mx-flash { animation: sp-cell-flash 0.15s ease-out forwards; }

    /* Permission indicators */
    .sp-mx-check {
        display: inline-block;
        width: 18px; height: 18px;
        border-radius: 5px;
        background: #2d6a9f;
        position: relative;
    }
    .sp-mx-check::after {
        content: '';
        position: absolute;
        left: 5px; top: 2px;
        width: 5px; height: 9px;
        border: 2px solid #fff;
        border-top: none; border-left: none;
