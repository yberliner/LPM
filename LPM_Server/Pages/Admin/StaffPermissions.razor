        box-shadow: 0 3px 14px rgba(234,88,12,0.35), inset 0 1px 0 rgba(255,255,255,0.18);
    }
    .sp-filter-btn-solo.sp-filter-active:hover {
        box-shadow: 0 5px 20px rgba(234,88,12,0.45), inset 0 1px 0 rgba(255,255,255,0.18);
    }
    .sp-filter-btn-solo:hover:not(.sp-filter-active) {
        color: #ea580c;
        border-color: rgba(234,88,12,0.18);
    }
    .sp-filter-btn-solo::before {
        background: radial-gradient(circle at center, rgba(234,88,12,0.1) 0%, transparent 70%);
    }

    /* Solo row highlight in matrix */
    .sp-mx-row-solo .sp-mx-pc-name {
        background: #fff7ed !important;
        border-right-color: #fed7aa !important;
    }
    .sp-mx-row-solo td.sp-mx-cell {
        background: rgba(254,215,170,0.15);
    }
    .sp-mx-row-solo td.sp-mx-cell:hover {
