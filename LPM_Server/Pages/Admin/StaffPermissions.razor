@page "/Admin/StaffPermissions"
@attribute [Authorize(Roles = "Admin")]
@using LPM.Services
@using Microsoft.AspNetCore.Authorization
@inject DashboardService DashSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="sp-page p-3 p-md-4">

    @* ── Page Header ── *@
    <div class="d-flex align-items-center mb-4 gap-3 flex-wrap">
        <div>
            <h4 class="mb-0 fw-bold sp-title">@LS.T("staffperm.title")</h4>
            <span class="text-muted" style="font-size:0.82rem;">@LS.T("staffperm.subtitle")</span>
        </div>
        <div class="ms-auto">
            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                    @onclick="LoadData" disabled="@_loading">
                <i class="ri-refresh-line @(_loading ? "sp-spin" : "")"></i> @LS.T("common.refresh")
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary mb-3" style="width:2.5rem;height:2.5rem;" role="status"></div>
            <div class="text-muted">@LS.T("common.loading")</div>
        </div>
    }
    else
    {
        @* ══════════════════════════════════════════════════════════
           SECTION 1 — PENDING REQUESTS
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3">
            <i class="ri-shield-user-line me-2"></i>@LS.T("staffperm.pendingRequests")
            @if (_pending.Count > 0)
            {
                <span class="badge rounded-pill sp-badge-pending ms-2">@_pending.Count @LS.T("staffperm.pending")</span>
            }
        </div>

        @if (_pending.Count == 0)
        {
            <div class="sp-empty-block mb-5">
                <i class="ri-checkbox-circle-line text-success" style="font-size:1.8rem;"></i>
                <div class="fw-semibold mt-2" style="color:#1e3a5f;">@LS.T("staffperm.noPending")</div>
                <div class="small" style="color:#6b7280;">@LS.T("staffperm.allApproved")</div>
            </div>
        }
        else
        {
            <div class="card border-0 shadow-sm mb-5 sp-card">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0 sp-table">
                        <thead>
                            <tr class="sp-thead">
                                <th class="ps-4">@LS.T("staffperm.auditor")</th>
                                <th>@LS.T("staffperm.pcPerson")</th>
                                <th class="text-center">@LS.T("staffperm.requested")</th>
                                <th class="pe-4 text-end" style="width:200px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in _pending)
                            {
                                <tr class="sp-row-pending">
                                    <td class="ps-4 py-2 fw-semibold">
                                        <div class="sp-avatar-inline">@(req.AuditorName.Length > 0 ? char.ToUpper(req.AuditorName[0]) : '?')</div>
                                        @req.AuditorName
                                    </td>
                                    <td class="py-2">
                                        <i class="ri-user-line me-1 text-muted"></i>@req.PcName
                                    </td>
                                    <td class="text-center py-2 text-muted" style="font-size:0.83rem;">@FormatDate(req.RequestedAt)</td>
                                    <td class="pe-4 py-1 text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm sp-btn-approve d-flex align-items-center gap-1"
                                                    @onclick="() => Approve(req.Id)" disabled="@_busy">
                                                <i class="ri-check-line"></i>@LS.T("common.approve")
                                            </button>
                                            <button class="btn btn-sm sp-btn-reject d-flex align-items-center gap-1"
                                                    @onclick="() => Reject(req.Id)" disabled="@_busy">
                                                <i class="ri-close-line"></i>@LS.T("common.reject")
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* ══════════════════════════════════════════════════════════
           SECTION 2 — PERMISSION MATRIX
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3 sp-section-toggle mt-4"
             @onclick="() => _matrixSectionCollapsed = !_matrixSectionCollapsed">
            <i class="ri-arrow-down-s-line sp-section-chevron @(_matrixSectionCollapsed ? "sp-chevron-collapsed" : "") me-1"></i>
            <i class="ri-grid-line me-2"></i>Permission Matrix
            <span class="ms-2 text-muted" style="font-size:0.75rem;font-weight:400;text-transform:none;letter-spacing:0;">
                (@_allPcs.Count PCs · @_matrixAuditors.Count auditors)
            </span>
        </div>

        @if (!_matrixSectionCollapsed)
        {
            var filteredPcs = GetFilteredPcs();

            <div class="sp-filter-bar mb-3">
                <button type="button" class="sp-filter-btn @(_matrixFilter == "All" ? "sp-filter-active" : "")"
                        @onclick='() => _matrixFilter = "All"'>
                    <i class="ri-apps-2-line"></i>
                    <span class="d-none d-sm-inline">All PCs</span>
                    <span class="sp-filter-count">@_allPcs.Count</span>
                </button>
                <button type="button" class="sp-filter-btn @(_matrixFilter == "Unassigned" ? "sp-filter-active" : "")"
                        @onclick='() => _matrixFilter = "Unassigned"'>
                    <i class="ri-user-unfollow-line"></i>
                    <span class="d-none d-sm-inline">Unassigned</span>
                    <span class="sp-filter-count">@CountByFilter("Unassigned")</span>
                </button>
                <button type="button" class="sp-filter-btn @(_matrixFilter == "Partial" ? "sp-filter-active" : "")"
                        @onclick='() => _matrixFilter = "Partial"'>
                    <i class="ri-user-received-2-line"></i>
                    <span class="d-none d-sm-inline">Partial Coverage</span>
                    <span class="sp-filter-count">@CountByFilter("Partial")</span>
                </button>
                <button type="button" class="sp-filter-btn sp-filter-btn-solo @(_matrixFilter == "Solo" ? "sp-filter-active" : "")"
                        @onclick='() => _matrixFilter = "Solo"'>
                    <i class="ri-user-star-line"></i>
                    <span class="d-none d-sm-inline">Solo</span>
                    <span class="sp-filter-count">@CountByFilter("Solo")</span>
                </button>
                <label class="form-check form-check-inline ms-3 mb-0" style="cursor:pointer;font-size:.82rem;">
                    <input class="form-check-input" type="checkbox" checked="@_hideFullCoverage"
                           @onchange="OnHideFullCoverageChanged" />
                    <span class="text-muted">Hide full coverage (A+CS)</span>
                </label>
            </div>

            @* ── PC search (separate row) ── *@
            <div class="sp-pc-search-row d-flex align-items-center gap-2 mb-3">
                <div class="position-relative flex-grow-1">
                    <i class="ri-search-line position-absolute"
                       style="left:14px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:1.05rem;"></i>
                    <input type="text" class="form-control sp-pc-search-input"
                           placeholder="Search PC name..."
                           value="@_pcSearchText"
                           @oninput="e => _pcSearchText = e.Value?.ToString() ?? string.Empty" />
                </div>
                <button type="button" class="btn btn-danger sp-pc-search-clear"
                        disabled="@string.IsNullOrEmpty(_pcSearchText)"
                        @onclick='() => _pcSearchText = ""'>
                    <i class="ri-close-circle-line me-1"></i>Clear
                </button>
            </div>

            <div class="sp-matrix-with-legend">
            <div class="card border-0 shadow-sm sp-card mb-5">
                <div class="sp-matrix-wrap" id="sp-matrix-wrap">
                    <table class="sp-matrix-table">
                        <thead>
                            <tr>
                                @* sticky PC name header *@
                                <th class="sp-mx-pc-col sp-mx-head-pc">PC</th>
                                @foreach (var aud in _matrixAuditors)
                                {
                                    <th class="sp-mx-aud-col @(aud.AllowAll ? "sp-mx-aud-col-priv" : "")">
                                        <div class="sp-mx-aud-label @(aud.AllowAll ? "sp-mx-aud-label-priv" : "")"
                                             title="@(aud.AuditorName + (aud.AllowAll ? " — Privileged (AllowAll)" : ""))">
                                            @aud.AuditorName
                                            @if (aud.AllowAll) { <span class="sp-mx-priv-dot">⚡</span> }
                                        </div>
                                    </th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (filteredPcs.Count == 0)
                            {
                                <tr>
                                    <td colspan="@(1 + _matrixAuditors.Count)" class="text-center py-5" style="color:#9ca3af;">
                                        <div><i class="ri-filter-off-line" style="font-size:2.2rem;opacity:.45;"></i></div>
                                        <div class="mt-2 fw-semibold" style="font-size:.85rem;">No PCs match this filter</div>
                                    </td>
                                </tr>
                            }
                            @foreach (var pc in filteredPcs)
                            {
                                <tr class="@(!pc.IsActive ? "sp-mx-row-inactive" : "") @(_soloPcIds.Contains(pc.PcId) ? "sp-mx-row-solo" : "")">
                                    <td class="sp-mx-pc-col sp-mx-pc-name @(_soloPcIds.Contains(pc.PcId) ? "sp-mx-solo-pc" : "")">
                                        @pc.FullName
                                        @if (_soloPcIds.Contains(pc.PcId))
                                        {
                                            <span class="sp-mx-solo-badge" title="Has solo auditor">S</span>
                                        }
                                        @if (!pc.IsActive)
                                        {
                                            <span class="sp-mx-inactive-badge">inactive</span>
                                        }
                                    </td>
                                    @foreach (var aud in _matrixAuditors)
                                    {
                                        var hasPerm = HasPermission(aud, pc.PcId);
                                        var cellKey = (aud.AuditorId, pc.PcId);
                                        var flashing = _flashingCells.Contains(cellKey);
                                        <td class="sp-mx-cell @(flashing ? "sp-mx-flash" : "") @(aud.AllowAll ? "sp-mx-cell-priv" : "")"
                                            @onclick="() => MatrixToggle(aud, pc.PcId)"
                                            @oncontextmenu="e => OpenRoleMenu(e, aud, pc.PcId)"
                                            @oncontextmenu:preventDefault="true"
                                            title="@CellTooltip(aud, pc.PcId, hasPerm)">
                                            @if (hasPerm)
                                            {
                                                var cap = aud.ApprovedPcs.FirstOrDefault(p => p.PcId == pc.PcId)?.WorkCapacity ?? StaffRoles.Auditor;
                                                <span class="@CapCssClass(cap)">@CapLabel(cap)</span>
                                            }
                                            else
                                            {
                                                <span class="sp-mx-empty"></span>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @* ── Legend Panel (right side) ── *@
            <div class="sp-legend-panel">
                <div class="sp-legend-title">
                    <i class="ri-map-2-line"></i> Permission Guide
                </div>
                <div class="sp-legend-section">
                    <div class="sp-legend-section-title">Auditor Roles</div>
                    <div class="sp-legend-item" title="Auditor only — conducts auditing sessions for this PC">
                        <span class="sp-mx-aud sp-lg">A</span>
                        <div class="sp-legend-text">
                            <strong>Auditor</strong>
                            <span>Conducts auditing sessions</span>
                        </div>
                    </div>
                </div>
                <div class="sp-legend-section">
                    <div class="sp-legend-section-title">CS Roles</div>
                    <div class="sp-legend-item" title="Case Supervisor for all session types (solo + non-solo)">
                        <span class="sp-mx-cs sp-lg">CS</span>
                        <div class="sp-legend-text">
                            <strong>CS (All)</strong>
                            <span>Supervises all sessions</span>
                        </div>
                    </div>
                    <div class="sp-legend-item" title="Case Supervisor for non-solo (audited) sessions only">
                        <span class="sp-mx-csr sp-lg">CSR</span>
                        <div class="sp-legend-text">
                            <strong>CS Review</strong>
                            <span>Non-solo sessions only</span>
                        </div>
                    </div>
                    <div class="sp-legend-item" title="Case Supervisor for solo sessions only">
                        <span class="sp-mx-css sp-lg">CSS</span>
                        <div class="sp-legend-text">
                            <strong>CS Solo</strong>
                            <span>Solo sessions only</span>
                        </div>
                    </div>
                </div>
                <div class="sp-legend-section">
                    <div class="sp-legend-section-title">Combined Roles</div>
                    <div class="sp-legend-item" title="Both auditor and case supervisor for all session types">
                        <span class="sp-mx-both sp-lg">A+CS</span>
                        <div class="sp-legend-text">
                            <strong>Auditor + CS</strong>
                            <span>Both roles, all sessions</span>
                        </div>
                    </div>
                    <div class="sp-legend-item" title="Auditor + case supervisor for non-solo sessions only">
                        <span class="sp-mx-bothr sp-lg">A+R</span>
                        <div class="sp-legend-text">
                            <strong>Auditor + CS Review</strong>
                            <span>Both roles, non-solo only</span>
                        </div>
                    </div>
                    <div class="sp-legend-item" title="Auditor + case supervisor for solo sessions only">
                        <span class="sp-mx-boths sp-lg">A+S</span>
                        <div class="sp-legend-text">
                            <strong>Auditor + CS Solo</strong>
                            <span>Both roles, solo only</span>
                        </div>
                    </div>
                </div>
                <div class="sp-legend-section">
                    <div class="sp-legend-section-title">Other</div>
                    <div class="sp-legend-item" title="No permission assigned — click to grant">
                        <span class="sp-mx-empty sp-lg"></span>
                        <div class="sp-legend-text">
                            <strong>No Permission</strong>
                            <span>Click cell to assign</span>
                        </div>
                    </div>
                    <div class="sp-legend-item" title="Privileged users can open any PC folder regardless of assignments">
                        <span class="sp-privileged-badge">✦</span>
                        <div class="sp-legend-text">
                            <strong>Privileged</strong>
                            <span>Unrestricted folder access</span>
                        </div>
                    </div>
                </div>
                <div class="sp-legend-hint">
                    <i class="ri-cursor-line"></i> Click a cell to cycle through roles
                </div>
            </div>
        </div>
        }

        @* ══════════════════════════════════════════════════════════
           SECTION 3 — PER-AUDITOR PERMISSIONS (collapsible section)
           ══════════════════════════════════════════════════════════ *@
        <div class="sp-section-label mb-3 sp-section-toggle"
             @onclick="() => _auditorsSectionCollapsed = !_auditorsSectionCollapsed">
            <i class="ri-arrow-down-s-line sp-section-chevron @(_auditorsSectionCollapsed ? "sp-chevron-collapsed" : "") me-1"></i>
            <i class="ri-team-line me-2"></i>@LS.T("staffperm.auditorPermissions")
            <span class="ms-2 text-muted" style="font-size:0.75rem;font-weight:400;text-transform:none;letter-spacing:0;">
                (@_auditors.Count)
            </span>
        </div>

        @if (!_auditorsSectionCollapsed)
        {
            @foreach (var aud in _auditors.Where(a => a.StaffRole != StaffRoles.Solo))
            {
                var audCollapsed = _collapsedAuditors.Contains(aud.AuditorId);
                <div class="card border-0 shadow-sm mb-4 sp-card">
                    @* Card header *@
                    <div class="card-header d-flex align-items-center gap-3 py-3 px-4 border-0 sp-aud-header"
                         style="cursor:pointer;" @onclick="() => ToggleAuditorCollapse(aud.AuditorId)">
                        <i class="ri-arrow-down-s-line text-white sp-chevron @(audCollapsed ? "sp-chevron-collapsed" : "")"></i>
                        <div class="sp-avatar">@(aud.AuditorName.Length > 0 ? char.ToUpper(aud.AuditorName[0]) : '?')</div>
                        <div class="text-white lh-sm flex-grow-1">
                            <div class="fw-semibold d-flex align-items-center gap-2" style="font-size:1rem;">
                                @aud.AuditorName
                                @if (aud.AllowAll)
                                {
                                    <span class="sp-privileged-badge">✦ Privileged</span>
                                }
                            </div>
                            <div style="font-size:0.71rem;opacity:.72;">
                                @aud.ApprovedPcs.Count approved PC@(aud.ApprovedPcs.Count != 1 ? "s" : "")
                                @if (aud.AllowAll) { <span class="ms-1 opacity-75">· auto-approves new PCs</span> }
                            </div>
                        </div>
                        @* Allow All toggle *@
                        <div class="d-flex align-items-center gap-2" @onclick:stopPropagation="true">
                            <span class="text-white-50" style="font-size:0.78rem;">@LS.T("staffperm.allowAll")</span>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input sp-switch" type="checkbox"
                                       checked="@aud.AllowAll"
                                       @onchange="e => ToggleAllowAll(aud.AuditorId, (bool)(e.Value ?? false))"
                                       disabled="@_busy" />
                            </div>
                        </div>
                    </div>

                    @* Approved PCs list *@
                    @if (!audCollapsed)
                    {
                    <div class="card-body p-0">
                        @if (aud.AllowAll)
                        {
                            <div class="px-4 py-2 sp-allowall-info">
                                <i class="ri-flashlight-line me-1"></i>
                                <strong>Privileged user</strong> — can open any PC folder without approval.
                                PCs listed below control which PCs appear in their dashboard tables.
                            </div>
                        }
                        @if (aud.ApprovedPcs.Count == 0)
                        {
                            <div class="px-4 py-3 text-muted fst-italic" style="font-size:0.87rem;">
                                @LS.T("staffperm.noSpecificPCs")
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm align-middle mb-0 sp-table">
                                    <thead>
                                        <tr class="sp-sub-thead">
                                            <th class="ps-4">@LS.T("staffperm.pcPerson")</th>
                                            <th class="pe-4 text-end" style="width:80px;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var pc in aud.ApprovedPcs)
                                        {
                                            <tr class="sp-row-approved">
                                                <td class="ps-4 py-2">
                                                    <i class="ri-user-line me-1" style="color:#6b7280;"></i>@pc.PcName
                                                </td>
                                                <td class="pe-4 py-1 text-end">
                                                    <button class="btn btn-sm sp-btn-remove"
                                                            @onclick="() => RemovePermission(pc.Id)" disabled="@_busy"
                                                            title="Remove permission">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        @* Add PC row *@
                        <div class="d-flex align-items-center gap-2 px-4 py-3 sp-add-row flex-wrap">
                            <select class="form-select form-select-sm sp-pc-select"
                                    @bind="_addPcSelection[aud.AuditorId]">
                                <option value="0">— select a PC to add —</option>
                                @foreach (var pc in _allPcs.Where(p => !aud.ApprovedPcs.Any(ap => ap.PcId == p.PcId)))
                                {
                                    <option value="@pc.PcId">@pc.FullName</option>
                                }
                            </select>
                            <select class="form-select form-select-sm sp-cap-select"
                                    @bind="_addPcCapacity[aud.AuditorId]">
                                <option value="Auditor">Auditor</option>
                                @if (StaffRoles.IsCS(aud.StaffRole))
                                {
                                    <option value="CS">CS</option>
                                }
                            </select>
                            <button class="btn btn-sm sp-btn-add d-flex align-items-center gap-1"
                                    @onclick="() => AddPermission(aud.AuditorId)" disabled="@_busy">
                                <i class="ri-add-line"></i>@LS.T("common.add")
                            </button>
                        </div>
                    </div>
                    }
                </div>
            }
        }
    }

</div>

@* ── Role Picker Context Menu ── *@
@if (_ctxMenu != null)
{
    <div class="sp-ctx-backdrop" @onclick="CloseRoleMenu"
         @oncontextmenu:preventDefault="true" @oncontextmenu:stopPropagation="true"></div>
    <div class="sp-ctx-menu" style="@($"top:{_ctxMenu.Y}px; left:{_ctxMenu.X}px;")"
         @onclick:stopPropagation="true" @oncontextmenu:preventDefault="true">
        <div class="sp-ctx-head">
            <div class="sp-ctx-head-title">@_ctxMenu.AuditorName</div>
            <div class="sp-ctx-head-sub">@_ctxMenu.PcName</div>
        </div>
        @{
            var isCs = _ctxMenu.IsCs;
            var cur  = _ctxMenu.CurrentCap;
        }
        <button class="sp-ctx-item @(cur == StaffRoles.Auditor ? "sp-ctx-active" : "")"
                @onclick="() => ApplyRole(StaffRoles.Auditor)">
            <span class="sp-mx-aud sp-ctx-badge">A</span>
            <span>Auditor</span>
        </button>
        @if (isCs)
        {
            <button class="sp-ctx-item @(cur == StaffRoles.CS ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.CS)">
                <span class="sp-mx-cs sp-ctx-badge">CS</span>
                <span>CS (all sessions)</span>
            </button>
            <button class="sp-ctx-item @(cur == StaffRoles.CSReview ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.CSReview)">
                <span class="sp-mx-csr sp-ctx-badge">CS-R</span>
                <span>CS Review (non-solo)</span>
            </button>
            <button class="sp-ctx-item @(cur == StaffRoles.CSSolo ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.CSSolo)">
                <span class="sp-mx-css sp-ctx-badge">CS-S</span>
                <span>CS Solo (solo only)</span>
            </button>
            <div class="sp-ctx-divider"></div>
            <button class="sp-ctx-item @(cur == StaffRoles.AuditorAndCS ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.AuditorAndCS)">
                <span class="sp-mx-ac sp-ctx-badge">A+CS</span>
                <span>Auditor + CS</span>
            </button>
            <button class="sp-ctx-item @(cur == StaffRoles.AuditorAndCSReview ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.AuditorAndCSReview)">
                <span class="sp-mx-acr sp-ctx-badge">A+CS-R</span>
                <span>Auditor + CS Review</span>
            </button>
            <button class="sp-ctx-item @(cur == StaffRoles.AuditorAndCSSolo ? "sp-ctx-active" : "")"
                    @onclick="() => ApplyRole(StaffRoles.AuditorAndCSSolo)">
                <span class="sp-mx-acs sp-ctx-badge">A+CS-S</span>
                <span>Auditor + CS Solo</span>
            </button>
        }
        @if (cur != null)
        {
            <div class="sp-ctx-divider"></div>
            <button class="sp-ctx-item sp-ctx-remove" @onclick="() => ApplyRole(null)">
                <i class="ri-delete-bin-line"></i>
                <span>Remove permission</span>
            </button>
        }
    </div>
}

@* ── Toast ── *@
@if (!string.IsNullOrEmpty(_msg))
{
    <div class="position-fixed bottom-0 end-0 p-4" style="z-index:1200;">
        <div class="toast show align-items-center border-0 shadow-lg @(_msgIsError ? "text-bg-danger" : "text-bg-success")"
             role="alert" style="min-width:300px;border-radius:12px;">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2 fw-semibold">
                    <i class="@(_msgIsError ? "ri-error-warning-line" : "ri-checkbox-circle-line") fs-5"></i>
                    @_msg
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto"
                        @onclick='() => _msg = null'></button>
            </div>
        </div>
    </div>
}

