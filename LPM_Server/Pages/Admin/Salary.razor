@page "/Admin/Salary"
@using LPM.Services
@inject DashboardService DashSvc
@inject LPM.Services.CourseService CourseSvc
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Salary Report</PageTitle>

<div class="sal-page">

    @* ── Header ── *@
    <div class="sal-header">
        <div class="sal-header-left">
            <i class="ri-money-dollar-circle-line sal-header-icon"></i>
            <div>
                <div class="sal-header-title">Salary Report</div>
                <div class="sal-header-sub">Staff earnings by sessions, CS reviews &amp; commissions</div>
            </div>
        </div>
        <div class="sal-controls">
            <button class="sal-nav-btn" @onclick="PrevPeriod" title="Previous period">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <div class="sal-control-group">
                <label class="sal-label">From</label>
                <input type="text" class="sal-date-input" placeholder="dd/mm/yy"
                       @bind="_fromStr" @bind:event="oninput" />
            </div>
            <div class="sal-control-group">
                <label class="sal-label">To</label>
                <input type="text" class="sal-date-input" placeholder="dd/mm/yy"
                       @bind="_toStr" @bind:event="oninput" />
            </div>
            <button class="sal-nav-btn" @onclick="NextPeriod" disabled="@IsCurrentPeriod" title="Next period">
                <i class="ri-arrow-right-s-line"></i>
            </button>
            <button class="sal-calc-btn" @onclick="Calculate" disabled="@_loading">
                @if (_loading)
                {
                    <span class="sal-spinner"></span>
                }
                else
                {
                    <i class="ri-bar-chart-2-line me-1"></i>
                }
                Calculate
            </button>
        </div>
    </div>

    @* ── Financial Config ── *@
    <div class="card shadow-sm mb-4 mx-3 mx-md-4 mt-3" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#fff8e1;color:#212529;border-radius:12px 12px 0 0;border-bottom:1px solid #ffe082;cursor:pointer;"
             @onclick="() => _showFinConfig = !_showFinConfig">
            <span class="fw-semibold small" style="color:#f57f17;">
                <i class="ri-settings-3-line me-1"></i>@LS.T("courses.financialConfig")
            </span>
            <span class="d-flex align-items-center gap-2">
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showFinConfig ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showFinConfig)
        {
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3 small" style="width:50%;">Setting</th>
                        <th class="small">Value</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.vatPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgVatPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.ccCommissionPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCcCommissionPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.reserveDeductPct")</td>
                        <td><input type="number" step="0.01" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgReserveDeductPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.instructorOtPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgInstructorOtPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.csOtPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCsOtPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle" colspan="2">
                            <div class="fw-medium mb-2">@LS.T("courses.academyInstructors")</div>
                            @if (_cfgInstructors.Count > 0)
                            {
                                <div class="d-none d-sm-flex gap-2 mb-1 sal-instr-header">
                                    <div style="flex:1;min-width:140px;">Instructor</div>
                                    <div style="width:80px;">% Start</div>
                                    <div style="width:80px;">% Finish</div>
                                    <div style="width:36px;"></div>
                                </div>
                            }
                            @for (int idx = 0; idx < _cfgInstructors.Count; idx++)
                            {
                                var i = idx;
                                var entry = _cfgInstructors[i];
                                <div class="d-flex gap-2 align-items-center flex-wrap mb-2">
                                    <select class="form-select form-select-sm" style="flex:1;min-width:140px;"
                                            value="@entry.PersonId"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _cfgInstructors[i].PersonId = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var u in _coreUsers)
                                        {
                                            <option value="@u.Id">@u.FullName</option>
                                        }
                                    </select>
                                    <input type="number" step="0.1" min="0" max="100"
                                           class="form-control form-control-sm" style="width:80px;"
                                           placeholder="Start"
                                           @bind="entry.StartPct" />
                                    <input type="number" step="0.1" min="0" max="100"
                                           class="form-control form-control-sm" style="width:80px;"
                                           placeholder="Finish"
                                           @bind="entry.FinishPct" />
                                    <button class="btn btn-sm btn-outline-danger d-flex align-items-center justify-content-center"
                                            style="width:36px;height:36px;padding:0;"
                                            @onclick="() => RemoveInstructor(i)" title="Remove">
                                        <i class="ri-close-line"></i>
                                    </button>
                                </div>
                            }
                            @if (_cfgInstructors.Count < 4)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="AddInstructor">
                                    <i class="ri-add-line me-1"></i>Add Instructor
                                </button>
                            }
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr style="background:#fffde7;">
                        <td class="ps-3 py-2">
                            @if (!string.IsNullOrEmpty(_cfgMsg))
                            {
                                <span class="small @(_cfgIsError ? "text-danger" : "text-success")">@_cfgMsg</span>
                            }
                        </td>
                        <td class="py-2">
                            <button class="btn btn-sm btn-warning" @onclick="SaveFinancialConfig">
                                <i class="ri-save-line me-1"></i>@LS.T("common.save")
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
          </div>
        </div>
        }
    </div>

    @* ── Error ── *@
    @if (_error != null)
    {
        <div class="alert alert-danger mx-4 mt-3">@_error</div>
    }

    @* ── Results ── *@
    @if (_groups != null)
    {
        <div class="@(_recalculating ? "sal-recalculating" : "")">
        @if (_groups.Count == 0)
        {
            <div class="sal-empty">
                <i class="ri-inbox-line" style="font-size:2rem;color:#94a3b8;"></i>
                <div class="mt-2" style="color:#64748b;">No salary data found for this period.</div>
            </div>
        }
        else
        {
            @* Grand total banner *@
            <div class="sal-grand-total">
                <i class="ri-trophy-line me-2"></i>
                Grand Total — @_groups.Count staff member@(_groups.Count != 1 ? "s" : ""):
                <span class="sal-grand-amount">₪ @FormatShekel(_groups.Sum(g => g.TotalCents))</span>
            </div>

            @foreach (var group in _groups)
            {
                var hasSessions = group.Sessions.Count > 0;
                var hasCsRows   = group.CsReviews.Count > 0;
                var hasComm     = group.Commissions.Count > 0;

                <div class="sal-user-card">
                    @* Card header (clickable to collapse) *@
                    <div class="sal-user-header" style="cursor:pointer;" @onclick="() => ToggleCollapse(group.FullName)">
                        <i class="ri-arrow-down-s-line sal-chevron @(_collapsed.Contains(group.FullName) ? "sal-chevron-collapsed" : "")"></i>
                        <div class="sal-user-avatar">@(group.FullName.Length > 0 ? char.ToUpper(group.FullName[0]) : '?')</div>
                        <div class="sal-user-info">
                            <div class="sal-user-name">@group.FullName</div>
                            <div class="sal-user-sub">
                                @if (hasSessions) { <span>@group.Sessions.Count session@(group.Sessions.Count != 1 ? "s" : "")</span> }
                                @if (hasSessions && (hasCsRows || hasComm)) { <span class="sal-dot">·</span> }
                                @if (hasCsRows)   { <span>@group.CsReviews.Count CS review@(group.CsReviews.Count != 1 ? "s" : "")</span> }
                                @if (hasCsRows && hasComm) { <span class="sal-dot">·</span> }
                                @if (hasComm)     { <span>@group.Commissions.Count commission@(group.Commissions.Count != 1 ? "s" : "")</span> }
                            </div>
                        </div>
                        @{
                            var totByCurr = group.TotalsByCurrency();
                            var commTotal = group.Commissions.Sum(c => c.AmountCents);
                            // Commissions assumed ILS — add to ILS bucket
                            if (commTotal > 0) totByCurr["ILS"] = totByCurr.GetValueOrDefault("ILS") + commTotal;
                        }
                        <span class="sal-header-total">
                            @if (totByCurr.Count == 0)
                            {
                                <span>@SalCurrSym("ILS") 0</span>
                            }
                            else
                            {
                                foreach (var t in totByCurr.OrderBy(t => t.Key))
                                {
                                    <span style="margin-left:8px;">@SalCurrSym(t.Key) @FormatShekel(t.Value)</span>
                                }
                            }
                        </span>
                    </div>

                    @if (!_collapsed.Contains(group.FullName))
                    {
                    @* Sessions table *@
                    @if (hasSessions)
                    {
                        @foreach (var sessCurr in group.Sessions.GroupBy(s => s.Currency).OrderBy(g => g.Key))
                        {
                            var sessCurrTotal = sessCurr.Where(s => s.IsApproved && !s.IsFree).Sum(s => s.PaymentCents);
                            <div class="sal-section-label">
                                <i class="ri-stethoscope-line me-1"></i>Sessions — @sessCurr.Key @SalCurrSym(sessCurr.Key)
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm mb-0 sal-table sal-table-fixed">
                                    <colgroup>
                                        <col style="width:9%;" /><col style="width:15%;" /><col style="width:9%;" /><col />
                                        <col style="width:10%;" /><col style="width:11%;" />
                                        <col style="width:13%;" /><col style="width:10%;" />
                                    </colgroup>
                                    <thead>
                                        <tr class="sal-thead">
                                            <th>Date</th>
                                            <th>Name</th>
                                            <th>ID</th>
                                            <th>PC</th>
                                            <th class="text-center">Duration</th>
                                            <th class="text-end">Rate /hr</th>
                                            <th class="text-end">Payment</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var s in sessCurr)
                                        {
                                            <tr class="@(s.IsApproved ? "" : "sal-row-pending")" style="@(s.IsFree ? "opacity:.7;" : "")">
                                                <td class="sal-date">@FormatDate(s.Date)</td>
                                                <td class="sal-name">@s.Name</td>
                                                <td class="sal-id">
                                                    <span class="sal-id-sess" title="Session ID">sess #@s.SessionId</span>
                                                </td>
                                                <td class="sal-pc @(_soloPcIds.Contains(s.PcId) ? "sal-pc-solo" : "")">
                                                    @s.PcName
                                                    @if (s.IsFree) { <span class="sal-free-tag">Free</span> }
                                                </td>
                                                <td class="text-center"><span class="sal-dur-badge">@FmtDur(s.DurationSec)</span></td>
                                                <td class="text-end sal-rate">@if (s.IsFree) { <span style="color:#dc2626;font-weight:600;">@SalCurrSym(s.Currency) 0</span> } else if (s.IsApproved) { @($"{SalCurrSym(s.Currency)} {s.RateCentsPerHour / 100}") } else { <span class="sal-pending-dash">—</span> }</td>
                                                <td class="text-end sal-payment">@if (s.IsFree) { <span style="color:#dc2626;font-weight:600;">@SalCurrSym(s.Currency) 0</span> } else if (s.IsApproved) { @($"{SalCurrSym(s.Currency)} {FormatShekel(s.PaymentCents)}") } else { <span class="sal-pending-dash">—</span> }</td>
                                                <td class="text-center">@if (s.IsFree) { <span class="sal-free-tag">Free session</span> } else if (s.IsApproved) { <span class="sal-badge-approved">Approved</span> } else { <span class="sal-badge-pending">Pending</span> }</td>
                                            </tr>
                                        }
                                        <tr class="sal-subtotal-row">
                                            <td colspan="6" class="text-end fw-bold">Subtotal</td>
                                            <td class="text-end fw-bold sal-payment">@SalCurrSym(sessCurr.Key) @FormatShekel(sessCurrTotal)</td>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                    }

                    @* CS Reviews table *@
                    @if (hasCsRows)
                    {
                        @foreach (var csCurr in group.CsReviews.GroupBy(c => c.Currency).OrderBy(g => g.Key))
                        {
                            var csCurrTotal = csCurr.Where(c => c.IsApproved && !c.IsFree).Sum(c => c.PaymentCents);
                            <div class="sal-section-label sal-section-label-mt">
                                <i class="ri-user-star-line me-1"></i>CS Reviews — @csCurr.Key @SalCurrSym(csCurr.Key)
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm mb-0 sal-table sal-table-fixed">
                                    <colgroup>
                                        <col style="width:8%;" /><col style="width:15%;" /><col style="width:15%;" /><col />
                                        <col style="width:10%;" /><col style="width:11%;" />
                                        <col style="width:13%;" /><col style="width:10%;" />
                                    </colgroup>
                                    <thead>
                                        <tr class="sal-thead">
                                            <th>Date</th>
                                            <th>Name</th>
                                            <th>ID</th>
                                            <th>PC</th>
                                            <th class="text-center">Duration</th>
                                            <th class="text-end">Rate /hr</th>
                                            <th class="text-end">Payment</th>
                                            <th class="text-center">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var c in csCurr)
                                        {
                                            <tr class="@(c.IsApproved ? "" : "sal-row-pending")" style="@(c.IsFree ? "opacity:.7;" : "")">
                                                <td class="sal-date">@FormatDate(c.Date)</td>
                                                <td class="sal-name">@c.Name</td>
                                                <td class="sal-id">
                                                    <span class="sal-id-cs" title="CS Review ID">cs #@c.CsReviewId</span>
                                                    <span class="sal-id-sess" title="Session ID">sess #@c.SessionId</span>
                                                </td>
                                                <td class="sal-pc @(_soloPcIds.Contains(c.PcId) ? "sal-pc-solo" : "")">
                                                    @c.PcName@(c.IsSolo ? " (solo)" : "")
                                                    @if (c.IsFree) { <span class="sal-free-tag">Free</span> }
                                                </td>
                                                <td class="text-center"><span class="sal-dur-badge">@FmtDur(c.DurationSec)</span></td>
                                                <td class="text-end sal-rate">@if (c.IsFree) { <span style="color:#dc2626;font-weight:600;">@SalCurrSym(c.Currency) 0</span> } else if (c.IsApproved) { @($"{SalCurrSym(c.Currency)} {c.RateCentsPerHour / 100}") } else { <span class="sal-pending-dash">—</span> }</td>
                                                <td class="text-end sal-payment">@if (c.IsFree) { <span style="color:#dc2626;font-weight:600;">@SalCurrSym(c.Currency) 0</span> } else if (c.IsApproved) { @($"{SalCurrSym(c.Currency)} {FormatShekel(c.PaymentCents)}") } else { <span class="sal-pending-dash">—</span> }</td>
                                                <td class="text-center">@if (c.IsFree) { <span class="sal-free-tag">Free session</span> } else if (c.IsApproved) { <span class="sal-badge-approved">Approved</span> } else { <span class="sal-badge-pending">Pending</span> }</td>
                                            </tr>
                                        }
                                        <tr class="sal-subtotal-row">
                                            <td colspan="6" class="text-end fw-bold">Subtotal</td>
                                            <td class="text-end fw-bold sal-payment">@SalCurrSym(csCurr.Key) @FormatShekel(csCurrTotal)</td>
                                            <td></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        }
                    }

                    @* Commission Earnings table *@
                    @if (hasComm)
                    {
                        <div class="sal-section-label @((hasSessions || hasCsRows) ? "sal-section-label-mt" : "")">
                            <i class="ri-percent-line me-1"></i>Commission Earnings
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 sal-table sal-table-fixed">
                                <colgroup>
                                    <col style="width:10%;" /><col /><col style="width:11%;" />
                                    <col style="width:12%;" /><col style="width:14%;" /><col style="width:11%;" />
                                </colgroup>
                                <thead>
                                    <tr class="sal-thead">
                                        <th></th>
                                        <th>PC</th>
                                        <th>Role</th>
                                        <th>Category</th>
                                        <th class="text-end">Payment ₪</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var cm in group.Commissions)
                                    {
                                        <tr @onmouseenter="() => _hoverComm = cm" @onmouseleave="() => { if (_hoverComm == cm) _hoverComm = null; }">
                                            <td class="text-center" style="padding:4px 2px;">
                                                <button class="sal-detail-btn" @onclick="() => ShowDetail(cm)" title="View calculation">
                                                    <i class="ri-information-line"></i>
                                                </button>
                                            </td>
                                            <td class="sal-pc">@cm.PcName</td>
                                            <td><span class="sal-role-badge sal-role-@cm.Role.Replace(" ", "").Replace(".", "").ToLower()">@cm.Role</span></td>
                                            <td class="small text-muted">@cm.Category</td>
                                            <td class="text-end sal-payment">₪ @FormatShekel(cm.AmountCents)</td>
                                            <td></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* Total row — aligned under Payment column via same colgroup *@
                    <div class="table-responsive">
                        <table class="sal-table sal-table-fixed sal-total-table">
                            <colgroup>
                                <col style="width:10%;" /><col /><col style="width:11%;" />
                                <col style="width:12%;" /><col style="width:14%;" /><col style="width:11%;" />
                            </colgroup>
                            <tbody>
                                <tr class="sal-total-row" style="cursor:default;"
                                    @onmouseenter="() => _hoverGroup = group"
                                    @onmouseleave="() => { if (_hoverGroup == group) _hoverGroup = null; }">
                                    <td colspan="4" class="text-end sal-total-label">
                                        <i class="ri-money-dollar-circle-line me-1"></i>Total Salary
                                    </td>
                                    <td class="text-end sal-total-amount">₪ @FormatShekel(group.TotalCents)</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    } @* end collapse *@
                </div>
            }
        }
        </div>
    }

    @* ── Unassigned Referrals ── *@
    @if (_unassigned.Count > 0)
    {
        <div class="sal-unassigned-card">
            <div class="sal-unassigned-header">
                <i class="ri-error-warning-line me-2"></i>Unassigned Referral Commissions
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0 sal-table">
                    <thead>
                        <tr class="sal-thead">
                            <th>PC</th>
                            <th>Category</th>
                            <th class="text-end">Amount ₪</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in _unassigned)
                        {
                            <tr>
                                <td class="sal-pc">@u.PcName</td>
                                <td class="small text-muted">@u.Category</td>
                                <td class="text-end sal-payment">₪ @FormatShekel(u.AmountCents)</td>
                                <td class="small">@u.Notes</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr style="background:#fff3e0;">
                            <td colspan="2" class="text-end fw-semibold small">Total Unassigned</td>
                            <td class="text-end fw-bold sal-payment">₪ @FormatShekel(_unassigned.Sum(u => u.AmountCents))</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }

    @* ── Commission Detail Modal ── *@
    @if (_detailRow != null)
    {
        var d = _detailRow.Detail;
        <div class="sal-modal-overlay" @onclick="CloseDetail">
            <div class="sal-modal-box" @onclick:stopPropagation="true">
                <div class="sal-modal-header">
                    <span><i class="ri-file-list-3-line me-2"></i>Commission Calculation Detail</span>
                    <button class="sal-modal-close" @onclick="CloseDetail"><i class="ri-close-line"></i></button>
                </div>
                <div class="sal-modal-body">
                    <div class="sal-detail-section sal-detail-purchase">
                        <div class="sal-detail-title"><i class="ri-shopping-bag-line me-1"></i>Purchase</div>
                        <div class="sal-detail-grid">
                            <span class="sal-detail-label">Purchase #</span><span>@d.PurchaseId</span>
                            <span class="sal-detail-label">Date</span><span>@FormatDate(d.PurchaseDate)</span>
                            <span class="sal-detail-label">PC</span><span>@_detailRow.PcName</span>
                            <span class="sal-detail-label">Completion</span>
                            @if (d.ItemType != "Course")
                            {
                                <span style="color:#94a3b8;">—</span>
                            }
                            else if (d.CourseFinishDate != null)
                            {
                                <span><span class="sal-badge-approved">Completed</span> @FormatDate(d.CourseFinishDate)</span>
                            }
                            else
                            {
                                <span><span class="sal-badge-pending">In Progress</span></span>
                            }
                        </div>
                    </div>
                    <div class="sal-detail-section sal-detail-payment">
                        <div class="sal-detail-title"><i class="ri-bank-card-line me-1"></i>Payment</div>
                        <div class="sal-detail-grid">
                            <span class="sal-detail-label">Method</span><span>@d.PaymentMethod</span>
                            <span class="sal-detail-label">Amount</span><span class="fw-semibold">₪ @d.PaymentGross.ToString("N0")</span>
                            <span class="sal-detail-label">Payment Date</span><span>@FormatDate(d.PaymentDate)</span>
                        </div>
                    </div>
                    <div class="sal-detail-section sal-detail-split">
                        <div class="sal-detail-title"><i class="ri-pie-chart-line me-1"></i>Purchased Item</div>
                        <div class="sal-detail-grid">
                            <span class="sal-detail-label">Item</span><span>@d.ItemName (@d.ItemType)</span>
                            <span class="sal-detail-label">Item Price</span><span>₪ @d.ItemPrice.ToString("N0")</span>
                            <span class="sal-detail-label">Purchase Total</span><span>₪ @d.TotalPurchasePrice.ToString("N0")</span>
                            <span class="sal-detail-label">This Item's Share</span><span class="fw-semibold">₪ @d.ItemShare.ToString("N2")</span>
                        </div>
                    </div>
                    <div class="sal-detail-section sal-detail-deduction">
                        <div class="sal-detail-title"><i class="ri-calculator-line me-1"></i>Deduction Chain</div>
                        <table class="table table-sm mb-0 sal-deduction-table">
                            <tr><td>Gross (allocated share)</td><td class="text-end fw-semibold">₪ @d.ItemShare.ToString("N2")</td></tr>
                            <tr><td>&minus; VAT (@((decimal)_cfgVatPct)%)</td><td class="text-end" style="color:#dc2626 !important;">&minus;₪ @d.VatAmount.ToString("N2")</td></tr>
                            <tr><td>&minus; CC Commission @(d.PaymentMethod == "CreditCard" ? $"({(decimal)_cfgCcCommissionPct}%)" : "(n/a)")</td><td class="text-end" style="color:#dc2626 !important;">&minus;₪ @d.CcAmount.ToString("N2")</td></tr>
                            @if (d.BookPrice > 0)
                            {
                                <tr><td>&minus; Book Price</td><td class="text-end" style="color:#dc2626 !important;">&minus;₪ @d.BookPrice.ToString("N2")</td></tr>
                            }
                            <tr style="border-top:2px solid #cbd5e1;"><td>Net After Deductions</td><td class="text-end fw-semibold">₪ @d.NetAfterDeductions.ToString("N2")</td></tr>
                            <tr><td>&minus; Reserve (@((decimal)_cfgReserveDeductPct)%)</td><td class="text-end" style="color:#dc2626 !important;">&minus;₪ @d.ReserveAmount.ToString("N2")</td></tr>
                            <tr style="background:#d1fae5 !important;border-top:2px solid #059669;">
                                <td class="fw-bold" style="color:#059669 !important;">Net Base</td>
                                <td class="text-end fw-bold" style="color:#059669 !important;">₪ @d.NetBase.ToString("N2")</td>
                            </tr>
                        </table>
                    </div>
                    <div class="sal-detail-section sal-detail-result">
                        <div class="sal-detail-title"><i class="ri-money-dollar-circle-line me-1"></i>Commission</div>
                        <div class="sal-detail-grid">
                            <span class="sal-detail-label">Role</span>
                            <span><span class="sal-role-badge sal-role-@_detailRow.Role.Replace(" ", "").Replace(".", "").ToLower()">@_detailRow.Role</span></span>
                            <span class="sal-detail-label">Why</span>
                            <span>@GetRoleExplanation(_detailRow.Role, _detailRow.PcName)</span>
                            <span class="sal-detail-label">Category</span>
                            <span>@_detailRow.Category</span>
                            <span class="sal-detail-label">Commission %</span><span class="fw-semibold">@d.CommissionPct%</span>
                            <span class="sal-detail-label">Net Base</span><span>₪ @d.NetBase.ToString("N2")</span>
                            <span class="sal-detail-label">Amount</span>
                            <span class="fw-bold" style="color:#059669 !important;font-size:1.1rem;">₪ @FormatShekel(_detailRow.AmountCents)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Floating Hover Card ── *@
    @if (_hoverComm != null)
    {
        var hd = _hoverComm.Detail;
        <div class="sal-hover-card">
            <div class="sal-hc-header">
                <span class="sal-role-badge sal-role-@_hoverComm.Role.Replace(" ", "").Replace(".", "").ToLower()">@_hoverComm.Role</span>
                <span class="sal-hc-cat">@_hoverComm.Category</span>
            </div>
            <div class="sal-hc-why">@GetRoleExplanation(_hoverComm.Role, _hoverComm.PcName)</div>

            <div class="sal-hc-section">
                <div class="sal-hc-row"><span class="sal-hc-lbl">Purchase</span><span>#@hd.PurchaseId · @FormatDate(hd.PurchaseDate)</span></div>
                <div class="sal-hc-row"><span class="sal-hc-lbl">Payment</span><span>@hd.PaymentMethod ₪@hd.PaymentGross.ToString("N0") · @FormatDate(hd.PaymentDate)</span></div>
                <div class="sal-hc-row"><span class="sal-hc-lbl">Item</span><span>@hd.ItemName (@hd.ItemType)</span></div>
                @if (hd.TotalPurchasePrice != hd.ItemPrice)
                {
                    <div class="sal-hc-row"><span class="sal-hc-lbl">Item Share</span><span>₪@hd.ItemPrice.ToString("N0") / ₪@hd.TotalPurchasePrice.ToString("N0") → <strong>₪@hd.ItemShare.ToString("N2")</strong></span></div>
                }
            </div>

            <div class="sal-hc-chain">
                <span>₪@hd.ItemShare.ToString("N2")</span>
                <span class="sal-hc-arr">→</span>
                <span class="sal-hc-ded">−VAT ₪@hd.VatAmount.ToString("N2")</span>
                @if (hd.CcAmount > 0) { <span class="sal-hc-ded">−CC ₪@hd.CcAmount.ToString("N2")</span> }
                @if (hd.BookPrice > 0) { <span class="sal-hc-ded">−Book ₪@hd.BookPrice.ToString("N2")</span> }
                <span class="sal-hc-ded">−Res ₪@hd.ReserveAmount.ToString("N2")</span>
                <span class="sal-hc-arr">→</span>
                <span class="sal-hc-net">₪@hd.NetBase.ToString("N2")</span>
            </div>

            <div class="sal-hc-result">
                ₪@hd.NetBase.ToString("N2") × @hd.CommissionPct% = <strong>₪@FormatShekel(_hoverComm.AmountCents)</strong>
            </div>

            @if (hd.ItemType == "Course")
            {
                <div class="sal-hc-status">
                    @if (hd.CourseFinishDate != null)
                    { <span class="sal-badge-approved" style="font-size:.65rem;">Completed @FormatDate(hd.CourseFinishDate)</span> }
                    else
                    { <span class="sal-badge-pending" style="font-size:.65rem;">In Progress</span> }
                </div>
            }
        </div>
    }

    @* ── Floating Total Breakdown Card ── *@
    @if (_hoverGroup != null)
    {
        var g = _hoverGroup;
        var sessTotal = g.Sessions.Where(s => s.IsApproved).Sum(s => s.PaymentCents);
        var csTotal   = g.CsReviews.Where(c => c.IsApproved).Sum(c => c.PaymentCents);
        var commTotal = g.Commissions.Sum(c => c.AmountCents);
        <div class="sal-hover-card">
            <div class="sal-hc-header">
                <span style="font-weight:700;color:#fff;font-size:.9rem;">@g.FullName — Total Breakdown</span>
            </div>

            @if (g.Sessions.Count > 0)
            {
                <div class="sal-hc-section" style="margin-top:8px;">
                    <div class="sal-hc-row" style="margin-bottom:4px;">
                        <span class="sal-hc-lbl" style="font-weight:700;color:#94a3b8;">Sessions</span>
                        <span></span>
                    </div>
                    @foreach (var s in g.Sessions.Where(s => s.IsApproved))
                    {
                        <div class="sal-hc-row">
                            <span>@s.PcName · @FmtDur(s.DurationSec)</span>
                            <span>₪@FormatShekel(s.PaymentCents)</span>
                        </div>
                    }
                    @{ var pendingSess = g.Sessions.Count(s => !s.IsApproved); }
                    @if (pendingSess > 0)
                    {
                        <div class="sal-hc-row"><span style="color:#64748b;">+@pendingSess pending</span><span style="color:#64748b;">—</span></div>
                    }
                    <div class="sal-hc-row" style="border-top:1px solid rgba(255,255,255,.1);padding-top:4px;margin-top:4px;">
                        <span style="font-weight:600;">Sessions subtotal</span>
                        <span style="font-weight:700;color:#4ade80;">₪@FormatShekel(sessTotal)</span>
                    </div>
                </div>
            }

            @if (g.CsReviews.Count > 0)
            {
                <div class="sal-hc-section" style="margin-top:8px;">
                    <div class="sal-hc-row" style="margin-bottom:4px;">
                        <span class="sal-hc-lbl" style="font-weight:700;color:#94a3b8;">CS Reviews</span>
                        <span></span>
                    </div>
                    @foreach (var c in g.CsReviews.Where(c => c.IsApproved || c.IsFree))
                    {
                        <div class="sal-hc-row" style="@(c.IsFree ? "opacity:.6;" : "")">
                            <span>@c.PcName · @FmtDur(c.DurationSec)@(c.IsFree ? " (Free)" : "")</span>
                            <span>₪@(c.IsFree ? "0" : FormatShekel(c.PaymentCents))</span>
                        </div>
                    }
                    @{ var pendingCs = g.CsReviews.Count(c => !c.IsApproved); }
                    @if (pendingCs > 0)
                    {
                        <div class="sal-hc-row"><span style="color:#64748b;">+@pendingCs pending</span><span style="color:#64748b;">—</span></div>
                    }
                    <div class="sal-hc-row" style="border-top:1px solid rgba(255,255,255,.1);padding-top:4px;margin-top:4px;">
                        <span style="font-weight:600;">CS subtotal</span>
                        <span style="font-weight:700;color:#4ade80;">₪@FormatShekel(csTotal)</span>
                    </div>
                </div>
            }

            @if (g.Commissions.Count > 0)
            {
                <div class="sal-hc-section" style="margin-top:8px;">
                    <div class="sal-hc-row" style="margin-bottom:4px;">
                        <span class="sal-hc-lbl" style="font-weight:700;color:#94a3b8;">Commissions</span>
                        <span></span>
                    </div>
                    @foreach (var cm in g.Commissions)
                    {
                        <div class="sal-hc-row">
                            <span>@cm.PcName · @cm.Role</span>
                            <span>₪@FormatShekel(cm.AmountCents)</span>
                        </div>
                    }
                    <div class="sal-hc-row" style="border-top:1px solid rgba(255,255,255,.1);padding-top:4px;margin-top:4px;">
                        <span style="font-weight:600;">Commissions subtotal</span>
                        <span style="font-weight:700;color:#4ade80;">₪@FormatShekel(commTotal)</span>
                    </div>
                </div>
            }

            <div class="sal-hc-result" style="margin-top:10px;padding-top:10px;border-top:2px solid rgba(74,222,128,.3);font-size:.95rem;">
                @if (sessTotal > 0) { <span>₪@FormatShekel(sessTotal)</span> }
                @if (sessTotal > 0 && (csTotal > 0 || commTotal > 0)) { <span> + </span> }
                @if (csTotal > 0) { <span>₪@FormatShekel(csTotal)</span> }
                @if (csTotal > 0 && commTotal > 0) { <span> + </span> }
                @if (commTotal > 0) { <span>₪@FormatShekel(commTotal)</span> }
                <span> = </span><strong>₪@FormatShekel(g.TotalCents)</strong>
            </div>
        </div>
    }

</div>

@code {
    string  _fromStr = "";
    string  _toStr   = "";
    bool    _loading;
    bool    _recalculating;
    string? _error;
    List<UserSalaryGroup>? _groups;
    List<UnassignedReferralRow> _unassigned = new();
    HashSet<int> _soloPcIds = new();
    int _periodYear;
    int _periodMonth;
    HashSet<string> _collapsed = new();

    // ── Commission Detail modal + hover ──
    CommissionRow? _detailRow;
    CommissionRow? _hoverComm;
    UserSalaryGroup? _hoverGroup;
    void ShowDetail(CommissionRow row) => _detailRow = row;
    void CloseDetail() => _detailRow = null;

    static string GetRoleExplanation(string role, string pcName) => role switch
    {
        "Registrar"      => $"Registered the purchase for {pcName}",
        "Referral"       => $"Referred {pcName} to the center",
        "Acad. Start"    => $"Academy instructor — start commission on {pcName}'s course",
        "Acad. Finish"   => $"Academy instructor — completion commission on {pcName}'s course",
        "OT Instructor"  => $"One-on-one instructor for {pcName}'s course",
        "OT CS"          => $"Case supervisor for {pcName}'s course",
        _                => role
    };

    // ── Financial Config state ──
    bool _showFinConfig = false;
    double _cfgVatPct;
    double _cfgCcCommissionPct;
    double _cfgAuditRegistrarPct;
    double _cfgCourseRegistrarPct;
    double _cfgAuditReferralPct;
    double _cfgCourseReferralPct;
    double _cfgReserveDeductPct;
    double _cfgInstructorOtPct;
    double _cfgCsOtPct;
    List<InstructorEntry> _cfgInstructors = new();
    List<(int Id, string FullName)> _coreUsers = [];
    string _cfgMsg = "";
    bool   _cfgIsError;

    class InstructorEntry
    {
        public int PersonId { get; set; }
        public double StartPct { get; set; }
        public double FinishPct { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!auth.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home");
            return;
        }
        LoadFinancialConfig();
        InitPeriod();
        await Calculate();
    }

    (DateOnly From, DateOnly To) ComputePeriod(int year, int month)
    {
        var first = new DateOnly(year, month, 1);
        var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
        var from = first.AddDays(daysToThu);

        var lastDay = new DateOnly(year, month, DateTime.DaysInMonth(year, month));
        DateOnly to;
        if (lastDay.DayOfWeek == DayOfWeek.Wednesday)
            to = lastDay;
        else
        {
            var nextMonth = lastDay.AddDays(1);
            var daysToWed = ((int)DayOfWeek.Wednesday - (int)nextMonth.DayOfWeek + 7) % 7;
            to = nextMonth.AddDays(daysToWed);
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        if (to > today) to = today;

        return (from, to);
    }

    void InitPeriod()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var year = today.Year;
        var month = today.Month;

        var first = new DateOnly(year, month, 1);
        var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
        if (today < first.AddDays(daysToThu))
        {
            month--;
            if (month < 1) { month = 12; year--; }
        }
        _periodYear = year;
        _periodMonth = month;
        ApplyPeriod();
    }

    void ApplyPeriod()
    {
        var (from, to) = ComputePeriod(_periodYear, _periodMonth);
        _fromStr = from.ToString("dd/MM/yy");
        _toStr = to.ToString("dd/MM/yy");
    }

    async Task PrevPeriod()
    {
        _periodMonth--;
        if (_periodMonth < 1) { _periodMonth = 12; _periodYear--; }
        ApplyPeriod();
        await Calculate();
    }

    async Task NextPeriod()
    {
        if (IsCurrentPeriod) return;
        _periodMonth++;
        if (_periodMonth > 12) { _periodMonth = 1; _periodYear++; }
        ApplyPeriod();
        await Calculate();
    }

    bool IsCurrentPeriod
    {
        get
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            var first = new DateOnly(today.Year, today.Month, 1);
            var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
            int curMonth = today.Month, curYear = today.Year;
            if (today < first.AddDays(daysToThu))
            { curMonth--; if (curMonth < 1) { curMonth = 12; curYear--; } }
            return _periodYear == curYear && _periodMonth == curMonth;
        }
    }

    void ToggleCollapse(string name)
    {
        if (!_collapsed.Remove(name)) _collapsed.Add(name);
    }

    async Task Calculate()
    {
        _error = null;
        if (!DateOnly.TryParseExact(_fromStr, new[] { "dd/MM/yy", "dd/MM/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var from))
            { _error = "Invalid From date — use dd/mm/yy."; return; }
        if (!DateOnly.TryParseExact(_toStr, new[] { "dd/MM/yy", "dd/MM/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var to))
            { _error = "Invalid To date — use dd/mm/yy."; return; }
        if (from > to) { _error = "From date must be on or before To date."; return; }

        _loading       = true;
        _recalculating = _groups != null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var report = DashSvc.GetSalaryReport(from, to);
            _groups = report.Groups;
            _unassigned = report.UnassignedReferrals;
            _soloPcIds = DashSvc.GetSoloPcIds();
        }
        catch (Exception ex)
        {
            _error = $"Error loading data: {ex.Message}";
        }
        finally
        {
            _loading       = false;
            _recalculating = false;
            StateHasChanged();
        }
    }

    void LoadFinancialConfig()
    {
        _coreUsers = CourseSvc.GetCoreUsers();
        var cfg = CourseSvc.GetFinancialConfig();
        _cfgVatPct             = cfg.VatPct;
        _cfgCcCommissionPct    = cfg.CcCommissionPct;
        _cfgAuditRegistrarPct  = cfg.AuditRegistrarPct;
        _cfgCourseRegistrarPct = cfg.CourseRegistrarPct;
        _cfgAuditReferralPct   = cfg.AuditReferralPct;
        _cfgCourseReferralPct  = cfg.CourseReferralPct;
        _cfgReserveDeductPct   = cfg.ReserveDeductPct;
        _cfgInstructorOtPct    = cfg.InstructorOtPct;
        _cfgCsOtPct            = cfg.CsOtPct;
        _cfgMsg = "";

        _cfgInstructors = InstructorConfig.ParseList(cfg.AcademyInstructorIds)
            .Take(4)
            .Select(ic => new InstructorEntry { PersonId = ic.PersonId, StartPct = ic.StartCommPct, FinishPct = ic.FinishCommPct })
            .ToList();
    }

    void SaveFinancialConfig()
    {
        var configs = _cfgInstructors
            .Where(e => e.PersonId > 0)
            .Select(e => new InstructorConfig(e.PersonId, e.StartPct, e.FinishPct));
        var serialized = InstructorConfig.SerializeList(configs);
        CourseSvc.UpdateFinancialConfig(
            _cfgVatPct, _cfgCcCommissionPct,
            _cfgAuditRegistrarPct, _cfgCourseRegistrarPct,
            _cfgAuditReferralPct, _cfgCourseReferralPct,
            _cfgReserveDeductPct, serialized,
            _cfgInstructorOtPct, _cfgCsOtPct);
        _cfgMsg = LS.T("courses.configSaved");
        _cfgIsError = false;
    }

    void AddInstructor()
    {
        if (_cfgInstructors.Count < 4)
            _cfgInstructors.Add(new InstructorEntry());
    }

    void RemoveInstructor(int idx)
    {
        if (idx >= 0 && idx < _cfgInstructors.Count)
            _cfgInstructors.RemoveAt(idx);
    }

    static string FormatDate(string d) =>
        DateOnly.TryParse(d, out var dt) ? dt.ToString("dd/MM/yy") : d;

    static string FmtDur(int sec)
    {
        var m = sec / 60;
        return m >= 60 ? $"{m / 60}h {m % 60:D2}m" : $"{m}m";
    }

    static string SalCurrSym(string code) => code switch { "USD" => "$", "EUR" => "€", _ => "₪" };

    static string FormatShekel(long cents)
    {
        var whole = cents / 100;
        var frac  = Math.Abs(cents % 100);
        return frac == 0 ? $"{whole:N0}" : $"{whole:N0}.{frac:D2}";
    }
}

<style>
    /* ── Page layout ── */
    .sal-page { padding: 0 0 40px; }

    /* ── Header ── */
    .sal-header {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
        padding: 20px 28px 16px;
        border-bottom: 1px solid rgba(100,116,139,.12);
    }
    .sal-header-left   { display: flex; align-items: center; gap: 14px; }
    .sal-header-icon   { font-size: 2rem; background: linear-gradient(135deg,#10b981,#059669); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .sal-header-title  { font-size: 1.25rem; font-weight: 700; color: var(--custom-black); }
    .sal-header-sub    { font-size: .78rem; color: #64748b; }

    /* ── Controls ── */
    .sal-controls      { display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap; }
    .sal-control-group { display: flex; flex-direction: column; gap: 4px; }
    .sal-label         { font-size: .72rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .4px; }
    .sal-date-input    {
        border: 1.5px solid rgba(100,116,139,.25); border-radius: 8px;
        padding: 6px 10px; font-size: 16px; color: var(--custom-black);
        background: var(--custom-white); outline: none; min-height: 44px; width: 100%;
    }
    .sal-date-input:focus { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,.12); }
    .sal-nav-btn {
        background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25);
        color: #fff; border-radius: 8px; width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 1.1rem; transition: background .15s;
        flex-shrink: 0;
    }
    .sal-nav-btn:hover:not(:disabled) { background: rgba(255,255,255,.3); }
    .sal-nav-btn:disabled { opacity: .3; cursor: default; }
    .sal-chevron { transition: transform .2s; font-size: 1.1rem; margin-right: 4px; flex-shrink: 0; }
    .sal-chevron-collapsed { transform: rotate(-90deg); }
    .sal-header-total {
        margin-left: auto; font-size: .85rem; font-weight: 700;
        color: #10b981; white-space: nowrap;
    }
    .sal-calc-btn {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 20px; border: none; border-radius: 9px; min-height: 44px;
        background: linear-gradient(135deg,#10b981,#059669); color: #fff;
        font-weight: 700; font-size: .88rem; cursor: pointer;
        box-shadow: 0 3px 10px rgba(16,185,129,.3);
        transition: transform .15s, box-shadow .15s;
    }
    .sal-calc-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 5px 14px rgba(16,185,129,.4); }
    .sal-calc-btn:disabled { opacity: .6; cursor: not-allowed; }
    .sal-spinner {
        width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.4);
        border-top-color: #fff; border-radius: 50%;
        animation: sal-spin .7s linear infinite; display: inline-block;
    }
    @@keyframes sal-spin { to { transform: rotate(360deg); } }

    /* ── Grand total ── */
    .sal-grand-total {
        margin: 20px 28px 4px;
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        background: linear-gradient(135deg,#1e293b,#334155);
