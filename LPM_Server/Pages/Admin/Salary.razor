@page "/Admin/Salary"
@using LPM.Services
@inject DashboardService DashSvc
@inject LPM.Services.CourseService CourseSvc
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Salary Report</PageTitle>

<div class="sal-page">

    @* ── Header ── *@
    <div class="sal-header">
        <div class="sal-header-left">
            <i class="ri-money-dollar-circle-line sal-header-icon"></i>
            <div>
                <div class="sal-header-title">Salary Report</div>
                <div class="sal-header-sub">Staff earnings by sessions &amp; CS reviews</div>
            </div>
        </div>
        <div class="sal-controls">
            <button class="sal-nav-btn" @onclick="PrevPeriod" title="Previous period">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <div class="sal-control-group">
                <label class="sal-label">From</label>
                <input type="text" class="sal-date-input" placeholder="dd/mm/yy"
                       @bind="_fromStr" @bind:event="oninput" />
            </div>
            <div class="sal-control-group">
                <label class="sal-label">To</label>
                <input type="text" class="sal-date-input" placeholder="dd/mm/yy"
                       @bind="_toStr" @bind:event="oninput" />
            </div>
            <button class="sal-nav-btn" @onclick="NextPeriod" disabled="@IsCurrentPeriod" title="Next period">
                <i class="ri-arrow-right-s-line"></i>
            </button>
            <button class="sal-calc-btn" @onclick="Calculate" disabled="@_loading">
                @if (_loading)
                {
                    <span class="sal-spinner"></span>
                }
                else
                {
                    <i class="ri-bar-chart-2-line me-1"></i>
                }
                Calculate
            </button>
        </div>
    </div>

    @* ── Financial Config ── *@
    <div class="card shadow-sm mb-4 mx-3 mx-md-4 mt-3" style="border-radius:12px;border:none;">
        <div class="card-header py-2 px-3 d-flex align-items-center justify-content-between"
             style="background:#fff8e1;color:#212529;border-radius:12px 12px 0 0;border-bottom:1px solid #ffe082;cursor:pointer;"
             @onclick="() => _showFinConfig = !_showFinConfig">
            <span class="fw-semibold small" style="color:#f57f17;">
                <i class="ri-settings-3-line me-1"></i>@LS.T("courses.financialConfig")
            </span>
            <span class="d-flex align-items-center gap-2">
                <i class="ri-arrow-down-s-line" style="transition:transform .2s;@(_showFinConfig ? "" : "transform:rotate(-90deg);")"></i>
            </span>
        </div>
        @if (_showFinConfig)
        {
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3 small" style="width:50%;">Setting</th>
                        <th class="small">Value</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.vatPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgVatPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.ccCommissionPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCcCommissionPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseRegistrarPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseRegistrarPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.auditReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgAuditReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.courseReferralPct")</td>
                        <td><input type="number" step="0.1" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgCourseReferralPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle">@LS.T("courses.reserveDeductPct")</td>
                        <td><input type="number" step="0.01" class="form-control form-control-sm" style="max-width:120px;" @bind="_cfgReserveDeductPct" /></td>
                    </tr>
                    <tr>
                        <td class="ps-3 align-middle" colspan="2">
                            <div class="fw-medium mb-1">@LS.T("courses.academyInstructors")</div>
                            <div class="d-flex gap-2 flex-wrap">
                                @for (int idx = 0; idx < 4; idx++)
                                {
                                    var i = idx;
                                    <select class="form-select form-select-sm" style="max-width:160px;"
                                            value="@_cfgInstructors[i]"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _cfgInstructors[i] = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var u in _coreUsers)
                                        {
                                            <option value="@u.Id">@u.FullName</option>
                                        }
                                    </select>
                                }
                            </div>
                        </td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr style="background:#fffde7;">
                        <td class="ps-3 py-2">
                            @if (!string.IsNullOrEmpty(_cfgMsg))
                            {
                                <span class="small @(_cfgIsError ? "text-danger" : "text-success")">@_cfgMsg</span>
                            }
                        </td>
                        <td class="py-2">
                            <button class="btn btn-sm btn-warning" @onclick="SaveFinancialConfig">
                                <i class="ri-save-line me-1"></i>@LS.T("common.save")
                            </button>
                        </td>
                    </tr>
                </tfoot>
            </table>
          </div>
        </div>
        }
    </div>

    @* ── Error ── *@
    @if (_error != null)
    {
        <div class="alert alert-danger mx-4 mt-3">@_error</div>
    }

    @* ── Results ── *@
    @if (_groups != null)
    {
        <div class="@(_recalculating ? "sal-recalculating" : "")">
        @if (_groups.Count == 0)
        {
            <div class="sal-empty">
                <i class="ri-inbox-line" style="font-size:2rem;color:#94a3b8;"></i>
                <div class="mt-2" style="color:#64748b;">No salary data found for this period.</div>
            </div>
        }
        else
        {
            @* Grand total banner *@
            <div class="sal-grand-total">
                <i class="ri-trophy-line me-2"></i>
                Grand Total — @_groups.Count staff member@(_groups.Count != 1 ? "s" : ""):
                <span class="sal-grand-amount">₪ @FormatShekel(_groups.Sum(g => g.TotalCents))</span>
            </div>

            @foreach (var group in _groups)
            {
                var hasSessions = group.Sessions.Count > 0;
                var hasCsRows   = group.CsReviews.Count > 0;

                <div class="sal-user-card">
                    @* Card header (clickable to collapse) *@
                    <div class="sal-user-header" style="cursor:pointer;" @onclick="() => ToggleCollapse(group.FullName)">
                        <i class="ri-arrow-down-s-line sal-chevron @(_collapsed.Contains(group.FullName) ? "sal-chevron-collapsed" : "")"></i>
                        <div class="sal-user-avatar">@(group.FullName.Length > 0 ? char.ToUpper(group.FullName[0]) : '?')</div>
                        <div class="sal-user-info">
                            <div class="sal-user-name">@group.FullName</div>
                            <div class="sal-user-sub">
                                @if (hasSessions) { <span>@group.Sessions.Count session@(group.Sessions.Count != 1 ? "s" : "")</span> }
                                @if (hasSessions && hasCsRows) { <span class="sal-dot">·</span> }
                                @if (hasCsRows)   { <span>@group.CsReviews.Count CS review@(group.CsReviews.Count != 1 ? "s" : "")</span> }
                            </div>
                        </div>
                        <span class="sal-header-total">₪ @FormatShekel(group.TotalCents)</span>
                    </div>

                    @if (!_collapsed.Contains(group.FullName))
                    {
                    @* Sessions table *@
                    @if (hasSessions)
                    {
                        <div class="sal-section-label"><i class="ri-stethoscope-line me-1"></i>Sessions</div>
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 sal-table sal-table-fixed">
                                <colgroup>
                                    <col style="width:10%;" /><col /><col style="width:11%;" />
                                    <col style="width:12%;" /><col style="width:14%;" /><col style="width:11%;" />
                                </colgroup>
                                <thead>
                                    <tr class="sal-thead">
                                        <th>Date</th>
                                        <th>PC</th>
                                        <th class="text-center">Duration</th>
                                        <th class="text-end">Rate ₪/hr</th>
                                        <th class="text-end">Payment ₪</th>
                                        <th class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in group.Sessions)
                                    {
                                        <tr class="@(s.IsApproved ? "" : "sal-row-pending")">
                                            <td class="sal-date">@FormatDate(s.Date)</td>
                                            <td class="sal-pc">@s.PcName</td>
                                            <td class="text-center"><span class="sal-dur-badge">@FmtDur(s.DurationSec)</span></td>
                                            <td class="text-end sal-rate">@if (s.IsApproved) { @($"₪ {s.RateCentsPerHour / 100}") } else { <span class="sal-pending-dash">—</span> }</td>
                                            <td class="text-end sal-payment">@if (s.IsApproved) { @($"₪ {FormatShekel(s.PaymentCents)}") } else { <span class="sal-pending-dash">—</span> }</td>
                                            <td class="text-center">@if (s.IsApproved) { <span class="sal-badge-approved">Approved</span> } else { <span class="sal-badge-pending">Pending</span> }</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* CS Reviews table *@
                    @if (hasCsRows)
                    {
                        <div class="sal-section-label @(hasSessions ? "sal-section-label-mt" : "")">
                            <i class="ri-user-star-line me-1"></i>CS Reviews
                        </div>
                        <div class="table-responsive">
                            <table class="table table-sm mb-0 sal-table sal-table-fixed">
                                <colgroup>
                                    <col style="width:10%;" /><col /><col style="width:11%;" />
                                    <col style="width:12%;" /><col style="width:14%;" /><col style="width:11%;" />
                                </colgroup>
                                <thead>
                                    <tr class="sal-thead">
                                        <th>Date</th>
                                        <th>PC</th>
                                        <th class="text-center">Duration</th>
                                        <th class="text-end">Rate ₪/hr</th>
                                        <th class="text-end">Payment ₪</th>
                                        <th class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in group.CsReviews)
                                    {
                                        <tr class="@(c.IsApproved ? "" : "sal-row-pending")">
                                            <td class="sal-date">@FormatDate(c.Date)</td>
                                            <td class="sal-pc">@c.PcName</td>
                                            <td class="text-center"><span class="sal-dur-badge">@FmtDur(c.DurationSec)</span></td>
                                            <td class="text-end sal-rate">@if (c.IsApproved) { @($"₪ {c.RateCentsPerHour / 100}") } else { <span class="sal-pending-dash">—</span> }</td>
                                            <td class="text-end sal-payment">@if (c.IsApproved) { @($"₪ {FormatShekel(c.PaymentCents)}") } else { <span class="sal-pending-dash">—</span> }</td>
                                            <td class="text-center">@if (c.IsApproved) { <span class="sal-badge-approved">Approved</span> } else { <span class="sal-badge-pending">Pending</span> }</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* Total row — aligned under Payment column via same colgroup *@
                    <div class="table-responsive">
                        <table class="sal-table sal-table-fixed sal-total-table">
                            <colgroup>
                                <col style="width:10%;" /><col /><col style="width:11%;" />
                                <col style="width:12%;" /><col style="width:14%;" /><col style="width:11%;" />
                            </colgroup>
                            <tbody>
                                <tr class="sal-total-row">
                                    <td colspan="4" class="text-end sal-total-label">
                                        <i class="ri-money-dollar-circle-line me-1"></i>Total Salary
                                    </td>
                                    <td class="text-end sal-total-amount">₪ @FormatShekel(group.TotalCents)</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    } @* end collapse *@
                </div>
            }
        }
        </div>
    }

</div>

@code {
    string  _fromStr = "";
    string  _toStr   = "";
    bool    _loading;
    bool    _recalculating;
    string? _error;
    List<UserSalaryGroup>? _groups;
    int _periodYear;
    int _periodMonth;
    HashSet<string> _collapsed = new();

    // ── Financial Config state ──
    bool _showFinConfig = false;
    double _cfgVatPct;
    double _cfgCcCommissionPct;
    double _cfgAuditRegistrarPct;
    double _cfgCourseRegistrarPct;
    double _cfgAuditReferralPct;
    double _cfgCourseReferralPct;
    double _cfgReserveDeductPct;
    int[] _cfgInstructors = new int[4];
    List<(int Id, string FullName)> _coreUsers = [];
    string _cfgMsg = "";
    bool   _cfgIsError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!auth.User.IsInRole("Admin"))
        {
            Navigation.NavigateTo("/Home");
            return;
        }
        LoadFinancialConfig();
        InitPeriod();
        await Calculate();
    }

    (DateOnly From, DateOnly To) ComputePeriod(int year, int month)
    {
        var first = new DateOnly(year, month, 1);
        var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
        var from = first.AddDays(daysToThu);

        var lastDay = new DateOnly(year, month, DateTime.DaysInMonth(year, month));
        DateOnly to;
        if (lastDay.DayOfWeek == DayOfWeek.Wednesday)
            to = lastDay;
        else
        {
            var nextMonth = lastDay.AddDays(1);
            var daysToWed = ((int)DayOfWeek.Wednesday - (int)nextMonth.DayOfWeek + 7) % 7;
            to = nextMonth.AddDays(daysToWed);
        }

        var today = DateOnly.FromDateTime(DateTime.Today);
        if (to > today) to = today;

        return (from, to);
    }

    void InitPeriod()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        var year = today.Year;
        var month = today.Month;

        var first = new DateOnly(year, month, 1);
        var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
        if (today < first.AddDays(daysToThu))
        {
            month--;
            if (month < 1) { month = 12; year--; }
        }
        _periodYear = year;
        _periodMonth = month;
        ApplyPeriod();
    }

    void ApplyPeriod()
    {
        var (from, to) = ComputePeriod(_periodYear, _periodMonth);
        _fromStr = from.ToString("dd/MM/yy");
        _toStr = to.ToString("dd/MM/yy");
    }

    async Task PrevPeriod()
    {
        _periodMonth--;
        if (_periodMonth < 1) { _periodMonth = 12; _periodYear--; }
        ApplyPeriod();
        await Calculate();
    }

    async Task NextPeriod()
    {
        if (IsCurrentPeriod) return;
        _periodMonth++;
        if (_periodMonth > 12) { _periodMonth = 1; _periodYear++; }
        ApplyPeriod();
        await Calculate();
    }

    bool IsCurrentPeriod
    {
        get
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            var first = new DateOnly(today.Year, today.Month, 1);
            var daysToThu = ((int)DayOfWeek.Thursday - (int)first.DayOfWeek + 7) % 7;
            int curMonth = today.Month, curYear = today.Year;
            if (today < first.AddDays(daysToThu))
            { curMonth--; if (curMonth < 1) { curMonth = 12; curYear--; } }
            return _periodYear == curYear && _periodMonth == curMonth;
        }
    }

    void ToggleCollapse(string name)
    {
        if (!_collapsed.Remove(name)) _collapsed.Add(name);
    }

    async Task Calculate()
    {
        _error = null;
        if (!DateOnly.TryParseExact(_fromStr, new[] { "dd/MM/yy", "dd/MM/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var from))
            { _error = "Invalid From date — use dd/mm/yy."; return; }
        if (!DateOnly.TryParseExact(_toStr, new[] { "dd/MM/yy", "dd/MM/yyyy" }, null, System.Globalization.DateTimeStyles.None, out var to))
            { _error = "Invalid To date — use dd/mm/yy."; return; }
        if (from > to) { _error = "From date must be on or before To date."; return; }

        _loading       = true;
        _recalculating = _groups != null;
        StateHasChanged();
        await Task.Yield();

        try
        {
            _groups = DashSvc.GetSalaryReport(from, to);
        }
        catch (Exception ex)
        {
            _error = $"Error loading data: {ex.Message}";
        }
        finally
        {
            _loading       = false;
            _recalculating = false;
            StateHasChanged();
        }
    }

    void LoadFinancialConfig()
    {
        _coreUsers = CourseSvc.GetCoreUsers();
        var cfg = CourseSvc.GetFinancialConfig();
        _cfgVatPct             = cfg.VatPct;
        _cfgCcCommissionPct    = cfg.CcCommissionPct;
        _cfgAuditRegistrarPct  = cfg.AuditRegistrarPct;
        _cfgCourseRegistrarPct = cfg.CourseRegistrarPct;
        _cfgAuditReferralPct   = cfg.AuditReferralPct;
        _cfgCourseReferralPct  = cfg.CourseReferralPct;
        _cfgReserveDeductPct   = cfg.ReserveDeductPct;
        _cfgMsg = "";

        _cfgInstructors = new int[4];
        var ids = cfg.AcademyInstructorIds
            .Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries)
            .Where(s => int.TryParse(s, out _))
            .Select(int.Parse)
            .ToArray();
        for (int i = 0; i < Math.Min(ids.Length, 4); i++)
            _cfgInstructors[i] = ids[i];
    }

    void SaveFinancialConfig()
    {
        var cleanIds = string.Join(",", _cfgInstructors.Where(id => id > 0));
        CourseSvc.UpdateFinancialConfig(
            _cfgVatPct, _cfgCcCommissionPct,
            _cfgAuditRegistrarPct, _cfgCourseRegistrarPct,
            _cfgAuditReferralPct, _cfgCourseReferralPct,
            _cfgReserveDeductPct, cleanIds);
        _cfgMsg = LS.T("courses.configSaved");
        _cfgIsError = false;
    }

    static string FormatDate(string d) =>
        DateOnly.TryParse(d, out var dt) ? dt.ToString("dd/MM/yy") : d;

    static string FmtDur(int sec)
    {
        var m = sec / 60;
        return m >= 60 ? $"{m / 60}h {m % 60:D2}m" : $"{m}m";
    }

    static string FormatShekel(long cents)
    {
        var whole = cents / 100;
        var frac  = Math.Abs(cents % 100);
        return frac == 0 ? $"{whole:N0}" : $"{whole:N0}.{frac:D2}";
    }
}

<style>
    /* ── Page layout ── */
    .sal-page { padding: 0 0 40px; }

    /* ── Header ── */
    .sal-header {
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
        padding: 20px 28px 16px;
        border-bottom: 1px solid rgba(100,116,139,.12);
    }
    .sal-header-left   { display: flex; align-items: center; gap: 14px; }
    .sal-header-icon   { font-size: 2rem; background: linear-gradient(135deg,#10b981,#059669); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .sal-header-title  { font-size: 1.25rem; font-weight: 700; color: var(--custom-black); }
    .sal-header-sub    { font-size: .78rem; color: #64748b; }

    /* ── Controls ── */
    .sal-controls      { display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap; }
    .sal-control-group { display: flex; flex-direction: column; gap: 4px; }
    .sal-label         { font-size: .72rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .4px; }
    .sal-date-input    {
        border: 1.5px solid rgba(100,116,139,.25); border-radius: 8px;
        padding: 6px 10px; font-size: 16px; color: var(--custom-black);
        background: var(--custom-white); outline: none; min-height: 44px; width: 100%;
    }
    .sal-date-input:focus { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,.12); }
    .sal-nav-btn {
        background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25);
        color: #fff; border-radius: 8px; width: 34px; height: 34px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 1.1rem; transition: background .15s;
        flex-shrink: 0;
    }
    .sal-nav-btn:hover:not(:disabled) { background: rgba(255,255,255,.3); }
    .sal-nav-btn:disabled { opacity: .3; cursor: default; }
    .sal-chevron { transition: transform .2s; font-size: 1.1rem; margin-right: 4px; flex-shrink: 0; }
    .sal-chevron-collapsed { transform: rotate(-90deg); }
    .sal-header-total {
        margin-left: auto; font-size: .85rem; font-weight: 700;
        color: #10b981; white-space: nowrap;
    }
    .sal-calc-btn {
        display: flex; align-items: center; gap: 6px;
        padding: 8px 20px; border: none; border-radius: 9px; min-height: 44px;
        background: linear-gradient(135deg,#10b981,#059669); color: #fff;
        font-weight: 700; font-size: .88rem; cursor: pointer;
        box-shadow: 0 3px 10px rgba(16,185,129,.3);
        transition: transform .15s, box-shadow .15s;
    }
    .sal-calc-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 5px 14px rgba(16,185,129,.4); }
    .sal-calc-btn:disabled { opacity: .6; cursor: not-allowed; }
    .sal-spinner {
        width: 16px; height: 16px; border: 2px solid rgba(255,255,255,.4);
        border-top-color: #fff; border-radius: 50%;
        animation: sal-spin .7s linear infinite; display: inline-block;
    }
    @@keyframes sal-spin { to { transform: rotate(360deg); } }

    /* ── Grand total ── */
    .sal-grand-total {
        margin: 20px 28px 4px;
        display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
        background: linear-gradient(135deg,#1e293b,#334155);
        color: #e2e8f0; border-radius: 12px; padding: 14px 20px;
        font-size: .9rem; font-weight: 600;
        animation: sal-fade-in .4s ease;
    }
    .sal-grand-amount { font-size: 1.2rem; font-weight: 800; color: #4ade80; margin-left: 6px; }

    /* ── User card ── */
    .sal-user-card {
        margin: 20px 28px 0;
        border-radius: 14px; overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,.07);
        border: 1px solid rgba(100,116,139,.1);
        animation: sal-fade-in .35s ease;
    }
