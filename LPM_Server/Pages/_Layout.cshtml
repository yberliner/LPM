@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@inject StateService stateService
@using System.Text.Json;
@{
    var appState = stateService.GetAppState();
    var cookieTheme = Context.Request.Cookies["lpm-theme"];
    var effectiveTheme = (cookieTheme == "light" || cookieTheme == "dark") ? cookieTheme : appState?.ColorTheme;
}

<!DOCTYPE html>
<html lang="en" data-toggled="close"
