        <script>
            window.pcfSaveAnnotatedPdf = async function(pcId, filePath, pagesJson) {
                const pages = JSON.parse(pagesJson);
                // Convert page images to blobs, build a multi-page PDF via canvas→PNG→fetch to server
                // For now: flatten each page (PDF + annotations) into images, send to server to rebuild PDF
                const formData = new FormData();
                for (let i = 0; i < pages.length; i++) {
                    const resp = await fetch(pages[i].dataUrl);
                    const blob = await resp.blob();
                    formData.append('page_' + i, blob, 'page_' + i + '.png');
                }
                formData.append('pageCount', pages.length.toString());
                formData.append('widths', JSON.stringify(pages.map(p => p.width)));
                formData.append('heights', JSON.stringify(pages.map(p => p.height)));

                const saveResp = await fetch('/api/pc-file-save-annotated?pcId=' + pcId + '&path=' + encodeURIComponent(filePath), {
                    method: 'POST',
                    body: formData
                });
                if (!saveResp.ok) throw new Error('Save failed: ' + saveResp.status);
            };

            window.pcfOpenTab = function(url) {
                window.open(url, '_blank');
            };

            // ── Ctrl+key shortcuts: insert text at cursor ──
            window._lpmShortcuts = {};
            window._lpmReservedKeys = ['c','v','z','x','a','s','p','f','r','t','w','n','l'];
            window.lpmLoadShortcuts = function(shortcuts) {
                window._lpmShortcuts = shortcuts || {};
            };
            document.addEventListener('keydown', function(e) {
                if (!(e.ctrlKey || e.metaKey) || e.altKey || e.shiftKey) return;
                var key = e.key.toLowerCase();
                if (window._lpmReservedKeys.indexOf(key) >= 0) return;
                var text = window._lpmShortcuts[key];
                if (!text) return;
                var el = document.activeElement;
                if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable)) {
                    e.preventDefault();
                    if (el.isContentEditable) {
                        document.execCommand('insertText', false, text);
                    } else {
                        var start = el.selectionStart;
                        var end = el.selectionEnd;
                        var val = el.value;
                        el.value = val.substring(0, start) + text + val.substring(end);
                        el.selectionStart = el.selectionEnd = start + text.length;
                        el.dispatchEvent(new Event('input', { bubbles: true }));
                        el.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                }
            });

            // Fullscreen toggle
            window.openFullscreen = function() {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch(function() {});
                    document.querySelector('.full-screen-open')?.classList.add('d-none');
                    document.querySelector('.full-screen-close')?.classList.remove('d-none');
                } else {
                    document.exitFullscreen().catch(function() {});
                    document.querySelector('.full-screen-open')?.classList.remove('d-none');
                    document.querySelector('.full-screen-close')?.classList.add('d-none');
                }
            };
            document.addEventListener('fullscreenchange', function() {
                if (!document.fullscreenElement) {
                    document.querySelector('.full-screen-open')?.classList.remove('d-none');
                    document.querySelector('.full-screen-close')?.classList.add('d-none');
                }
            });

            // Cross-tab CS-done listener for Dashboard refresh
            window.lpmInitCsListener = function(dotNetRef) {
                try {
                    var ch = new BroadcastChannel('lpm-cs-done');
                    ch.onmessage = function() { dotNetRef.invokeMethodAsync('OnCsDoneFromTab'); };
                    window._lpmCsCh = ch;
                } catch(e) {}
                document.addEventListener('visibilitychange', function() {
                    if (!document.hidden) dotNetRef.invokeMethodAsync('OnTabFocused');
                });
            };
        </script>
