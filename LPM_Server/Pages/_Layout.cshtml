        <script>
          window.downloadFile = (fileName, base64Data) => {
            // Never throw back into Blazor circuit
            try {
              const bytes = Uint8Array.from(atob(base64Data), c => c.charCodeAt(0));
              const blob = new Blob([bytes], { type: "application/pdf" });
              const url = URL.createObjectURL(blob);

              const a = document.createElement("a");
              a.href = url;
              a.download = fileName;

              // Do NOT append to body; just click it
              a.click();

              // Cleanup (no removeChild)
              setTimeout(() => {
                try { URL.revokeObjectURL(url); } catch { }
                try { a.remove(); } catch { }
              }, 0);
            } catch (e) {
              console.error("downloadFile failed:", e);
            }
          };
        </script>

        <script>
          window._pdfCanvasCache = {};
          window._pdfDataCache = {};

          window.cacheAllPdfData = (dataMap) => {
            for (const [key, b64] of Object.entries(dataMap))
              window._pdfDataCache[key] = b64;
          };

          window.showStatPdf = async (containerId, key) => {
            try {
              const container = document.getElementById(containerId);
              if (!container) return;
              if (window._pdfCanvasCache[key]) {
                container.innerHTML = '';
                window._pdfCanvasCache[key].forEach(c => container.appendChild(c));
                return;
              }
              container.innerHTML = '';
              const b64 = window._pdfDataCache[key];
              if (!b64) return;
              const pdfjsLib = window['pdfjs-dist/build/pdf'];
              if (!pdfjsLib) { container.innerHTML = '<div style="color:#ef4444;padding:20px;">PDF.js not loaded</div>'; return; }
              const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
              const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
              const canvases = [];
              for (let i = 1; i <= pdf.numPages; i++) {
                const page = await pdf.getPage(i);
                const rawScale = (container.clientWidth - 24) / page.getViewport({ scale: 1 }).width;
                const viewport = page.getViewport({ scale: Math.min(Math.max(rawScale, 0.8), 1.5) });
                const canvas = document.createElement('canvas');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                canvas.style.display = 'block';
                canvas.style.margin = '0 auto 8px auto';
                canvas.style.boxShadow = '0 2px 12px rgba(0,0,0,.18)';
                canvas.style.borderRadius = '3px';
                container.appendChild(canvas);
                await page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport }).promise;
                canvases.push(canvas);
              }
              window._pdfCanvasCache[key] = canvases;
            } catch(e) { console.error('showStatPdf failed:', e); }
          };

          window.preRenderAllStatPdfs = async (keys) => {
            for (const key of keys) {
              if (window._pdfCanvasCache[key]) continue;
              const b64 = window._pdfDataCache[key];
              if (!b64) continue;
              try {
                const pdfjsLib = window['pdfjs-dist/build/pdf'];
                if (!pdfjsLib) continue;
                const bytes = Uint8Array.from(atob(b64), c => c.charCodeAt(0));
                const pdf = await pdfjsLib.getDocument({ data: bytes }).promise;
                const canvases = [];
                for (let i = 1; i <= pdf.numPages; i++) {
                  const page = await pdf.getPage(i);
                  const viewport = page.getViewport({ scale: 1.2 });
                  const canvas = document.createElement('canvas');
                  canvas.width = viewport.width;
                  canvas.height = viewport.height;
                  canvas.style.display = 'block';
                  canvas.style.margin = '0 auto 8px auto';
                  canvas.style.boxShadow = '0 2px 12px rgba(0,0,0,.18)';
                  canvas.style.borderRadius = '3px';
                  await page.render({ canvasContext: canvas.getContext('2d'), viewport: viewport }).promise;
                  canvases.push(canvas);
                }
                window._pdfCanvasCache[key] = canvases;
              } catch(e) { console.error('preRender failed for', key, e); }
            }
          };

          window.clearPdfCache = () => { window._pdfCanvasCache = {}; window._pdfDataCache = {}; };
        </script>

        <!-- PDF.js for PC Folder viewer -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
        <script>
            if (window['pdfjs-dist/build/pdf']) {
                window['pdfjs-dist/build/pdf'].GlobalWorkerOptions.workerSrc =
                    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
            }
        </script>
        <script src="js/pcf-viewer.js?v=38"></script>
        <script>
            window.pcfSaveAnnotatedPdf = async function(pcId, filePath, pagesJson) {
                const pages = JSON.parse(pagesJson);
                // Convert page images to blobs, build a multi-page PDF via canvas→PNG→fetch to server
                // For now: flatten each page (PDF + annotations) into images, send to server to rebuild PDF
                const formData = new FormData();
                for (let i = 0; i < pages.length; i++) {
                    const resp = await fetch(pages[i].dataUrl);
                    const blob = await resp.blob();
                    formData.append('page_' + i, blob, 'page_' + i + '.png');
                }
                formData.append('pageCount', pages.length.toString());
                formData.append('widths', JSON.stringify(pages.map(p => p.width)));
                formData.append('heights', JSON.stringify(pages.map(p => p.height)));

                const saveResp = await fetch('/api/pc-file-save-annotated?pcId=' + pcId + '&path=' + encodeURIComponent(filePath), {
                    method: 'POST',
                    body: formData
                });
                if (!saveResp.ok) throw new Error('Save failed: ' + saveResp.status);
            };

            window.pcfOpenTab = function(url) {
                window.open(url, '_blank');
            };

            // ── Ctrl+key shortcuts: insert text at cursor ──
            window._lpmShortcuts = {};
            window._lpmReservedKeys = ['c','v','z','x','a','s','p','f','r','t','w','n','l'];
            window.lpmLoadShortcuts = function(shortcuts) {
                window._lpmShortcuts = shortcuts || {};
            };
            document.addEventListener('keydown', function(e) {
                if (!(e.ctrlKey || e.metaKey) || e.altKey || e.shiftKey) return;
                var key = e.key.toLowerCase();
                if (window._lpmReservedKeys.indexOf(key) >= 0) return;
                var text = window._lpmShortcuts[key];
                if (!text) return;
                var el = document.activeElement;
                if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable)) {
                    e.preventDefault();
                    if (el.isContentEditable) {
                        document.execCommand('insertText', false, text);
                    } else {
                        var start = el.selectionStart;
                        var end = el.selectionEnd;
                        var val = el.value;
                        el.value = val.substring(0, start) + text + val.substring(end);
                        el.selectionStart = el.selectionEnd = start + text.length;
                        el.dispatchEvent(new Event('input', { bubbles: true }));
                        el.dispatchEvent(new Event('change', { bubbles: true }));
                    }
                }
            });

            // Fullscreen toggle
            window.openFullscreen = function() {
                if (!document.fullscreenElement) {
                    document.documentElement.requestFullscreen().catch(function() {});
                    document.querySelector('.full-screen-open')?.classList.add('d-none');
                    document.querySelector('.full-screen-close')?.classList.remove('d-none');
                } else {
                    document.exitFullscreen().catch(function() {});
                    document.querySelector('.full-screen-open')?.classList.remove('d-none');
                    document.querySelector('.full-screen-close')?.classList.add('d-none');
                }
            };
            document.addEventListener('fullscreenchange', function() {
                if (!document.fullscreenElement) {
                    document.querySelector('.full-screen-open')?.classList.remove('d-none');
                    document.querySelector('.full-screen-close')?.classList.add('d-none');
                }
            });

            // Cross-tab CS-done listener for Dashboard refresh
            window.lpmInitCsListener = function(dotNetRef) {
                try {
                    var ch = new BroadcastChannel('lpm-cs-done');
                    ch.onmessage = function() { dotNetRef.invokeMethodAsync('OnCsDoneFromTab'); };
                    window._lpmCsCh = ch;
                } catch(e) {}
                document.addEventListener('visibilitychange', function() {
                    if (!document.hidden) dotNetRef.invokeMethodAsync('OnTabFocused');
                });
            };
        </script>
        <script src="js/folder-import.js"></script>
        <script>
        // ── LPM Voice Commands (PCFolder) — loaded inline for reliability ──────
        // Full implementation is in voice-commands.js; this is the inline copy.
        // If already defined (e.g. by dynamic loader), skip.
        if (!window.lpmVoice) { var s = document.createElement('script'); s.src='/js/voice-commands.js'; document.head.appendChild(s); }
        </script>

