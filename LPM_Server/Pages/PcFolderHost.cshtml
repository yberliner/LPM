@page "/PcFolder/{pcId:int}"
@using Microsoft.AspNetCore.Components.Web
@namespace LPM.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = "_PcFolderLayout";

    if (User.Identity?.IsAuthenticated != true)
    {
        ViewContext.HttpContext.Response.Redirect("/login");
        return;
    }

    var pcId = int.Parse(RouteData.Values["pcId"]!.ToString()!);
}

<component type="typeof(PcFolder)" render-mode="Server"
           param-PcId="pcId" />
