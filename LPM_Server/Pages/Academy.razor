                var name = rawName.Replace("\\", "\\\\").Replace("'", "\\'");
                var org  = students[j].Org.Replace("\\", "\\\\").Replace("'", "\\'");
                msb.Append($"['{name}',{students[j].VisitCount},'{org}']");
            }
            msb.Append(']');
        }
        msb.Append(']');
        var mdata = msb.ToString();

        var mfn =
            "function(opts){" +
            "var d=" + mdata + ";" +
            "var idx=opts.dataPointIndex;" +
            "var total=0;for(var s=0;s<opts.series.length;s++){total+=(opts.series[s][idx]||0);}" +
            "var labels=['Don/Default','Friend','Social','Haifa','Other'];" +
            "var colors=['#16a34a','#f59e0b','#3b82f6','#7c3aed','#94a3b8'];" +
            "var st=d[idx]||[];" +
            "var r='<div style=\"padding:10px 14px;min-width:210px;font-family:inherit;background:#fff;" +
                    "border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.14)\">';" +
            "r+='<div style=\"font-weight:700;font-size:.93rem;color:#312e81;" +
                    "border-bottom:1px solid #c7d2fe;padding-bottom:5px;margin-bottom:8px\">Visit Count: '+total+'</div>';" +
            "for(var i=0;i<labels.length;i++){" +
            "var cnt=opts.series[i]?opts.series[i][idx]||0:0;" +
            "if(cnt>0){r+='<div style=\"display:flex;align-items:center;gap:6px;padding:2px 0\">'+" +
            "'<span style=\"width:9px;height:9px;border-radius:50%;background:'+colors[i]+';display:inline-block;\"></span>'+" +
            "'<span style=\"font-size:.8rem;color:#374151\">'+labels[i]+': <b>'+cnt+'</b></span></div>';}}" +
            "if(st.length){" +
            "r+='<div style=\"font-size:.7rem;color:#888;text-transform:uppercase;" +
                    "letter-spacing:.7px;margin:8px 0 5px\">Top Students</div>';" +
            "var maxShow=20;for(var i=0;i<Math.min(st.length,maxShow);i++){" +
            "var orgLabel=st[i][2]?(' <span style=\"font-size:.7rem;padding:1px 5px;border-radius:8px;" +
                    "background:#e0e7ff;color:#4338ca;font-weight:600;\">'+st[i][2]+'</span>'):'';"+
            "r+='<div style=\"display:flex;justify-content:space-between;align-items:center;gap:12px;padding:3px 6px;" +
                    "border-radius:4px;background:'+(i%2===0?'#eef2ff':'transparent')+'\">';" +
            "r+='<span style=\"color:#212529;font-size:.82rem\">'+st[i][0]+orgLabel+'</span>';" +
            "r+='<span style=\"color:#4338ca;font-weight:700;font-size:.82rem\">'+st[i][1]+'</span>';" +
            "r+='</div>';" +
            "}" +
            "if(st.length>maxShow){r+='<div style=\"text-align:center;padding:6px 0 2px;color:#888;" +
                    "font-size:.78rem;font-style:italic;border-top:1px dashed #e0e0e0;margin-top:4px\">" +
                    "+'+(st.length-maxShow)+' more students\u2026</div>';}" +
            "}" +
            "r+='</div>';" +
            "return r;}";

        _monthChartOptions.Tooltip = new Tooltip { Custom = mfn };
    }

    void SelectDay(int idx)
    {
        _selDay     = idx;
        _searchText = "";
        LoadVisits();
    }

    void OnSearchInput(ChangeEventArgs e) =>
        _searchText = e.Value?.ToString() ?? "";

    // No-course warning state
    bool _showNoCourseWarning;
    PersonItem? _pendingVisitPerson;

    // Animation state
    int? _lastAddedPersonId;
    int? _clickedPersonId;
    int? _tappedVisitId;

    async void OnPersonClick(PersonItem p)
    {
        // Trigger click animation on the person row
        _clickedPersonId = p.PersonId;
        StateHasChanged();

        var hasCourse = !string.IsNullOrEmpty(_personOpenCourses.GetValueOrDefault(p.PersonId, ""));
        if (!hasCourse)
        {
            _pendingVisitPerson = p;
            _showNoCourseWarning = true;
            return;
        }
        AddVisit(p);

        // Clear animation states after animations complete
        await Task.Delay(700);
        _clickedPersonId = null;
        _lastAddedPersonId = null;
        StateHasChanged();
    }

    async void ConfirmAddWithoutCourse()
    {
        _showNoCourseWarning = false;
        if (_pendingVisitPerson != null)
            AddVisit(_pendingVisitPerson);
        _pendingVisitPerson = null;
        StateHasChanged();

        await Task.Delay(700);
        _lastAddedPersonId = null;
        StateHasChanged();
    }

    void CancelNoCourseWarning()
    {
        _showNoCourseWarning = false;
        _pendingVisitPerson = null;
    }

    void AddVisit(PersonItem p)
    {
        _lastAddedPersonId = p.PersonId;
        AcademySvc.AddVisit(p.PersonId, SelectedDate);
        _dayCounts[_selDay] = AcademySvc.GetVisitsForDay(SelectedDate).Count;
        LoadVisits();
        RefreshChart();
    }

    void DoRemoveVisit(int visitId)
    {
        AcademySvc.RemoveVisit(visitId);
        _dayCounts[_selDay] = AcademySvc.GetVisitsForDay(SelectedDate).Count;
        LoadVisits();
        RefreshChart();
    }

    async void DoCycleVisits(int visitId)
    {
        _tappedVisitId = visitId;
        StateHasChanged();

        AcademySvc.CycleVisitsPerDay(visitId);
        LoadVisits();
        RefreshChart();

        await Task.Delay(500);
        _tappedVisitId = null;
        StateHasChanged();
    }

    /// Returns the list of week-start Thursdays whose month matches the given weekStart's month.
    static List<DateOnly> GetMonthWeeks(DateOnly weekStart)
    {
        var month = weekStart.Month;
        var year  = weekStart.Year;
        // Find first Thursday in this month
        var d = new DateOnly(year, month, 1);
        while (d.DayOfWeek != DayOfWeek.Thursday) d = d.AddDays(1);
        var weeks = new List<DateOnly>();
        while (d.Month == month)
        {
            weeks.Add(d);
            d = d.AddDays(7);
        }
        return weeks;
    }

    void LoadMonthStudents()
    {
        var weeks = GetMonthWeeks(_weekStart);
        _monthWeekCount = weeks.Count;
        if (weeks.Count == 0) { _monthStudents = []; return; }
        _monthStart = weeks[0];
        _monthEnd   = weeks[^1].AddDays(6);
        _monthLabel = _monthStart.ToString("MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture);
        _monthStudents = AcademySvc.GetStudentVisitsForDateRange(_monthStart, _monthEnd);
    }

    async Task PrintWeek()
    {
        var students = AcademySvc.GetStudentVisitsForWeek(_weekStart);
        var (byRef, byOrg) = AcademySvc.GetWeeklyStudentBreakdown(_weekStart);
        var personIds = students.Select(s => s.PersonId);
        var courses = CourseSvc.GetOpenCoursesForPersons(personIds);
        var pdfBytes = PdfService.GenerateAcademyWeekPdf(_weekStart, students, byRef, byOrg, courses, _monthStudents, _monthLabel, _monthWeekCount, _monthStart, _monthEnd, weeklyTotals: _weeklyTotals);
        var fileName = $"Academy_{_weekStart:yyyy_MM_dd}.pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(pdfBytes));
    }

    // ── Course modal ──────────────────────────────────────────────────────────

    void OpenCourseModal(int personId, string personName)
    {
        _courseMgmtPersonId   = personId;
        _courseMgmtPersonName = personName;
        _enrollError          = "";
        _finishingCourseId    = null;
        _newEnrollCourseId    = 0;
        _newEnrollDate        = DateTime.Today;
        _finishDate           = DateTime.Today;
        _allCourses           = CourseSvc.GetAllCourses();
        _personCourseList     = CourseSvc.GetStudentCourses(personId);
    }

    void CloseCourseModal() => _courseMgmtPersonId = null;

    void AddStudentCourse()
    {
        if (_newEnrollCourseId <= 0) { _enrollError = "Select a course."; return; }
        _enrollError = "";
        CourseSvc.AddStudentCourse(_courseMgmtPersonId!.Value, _newEnrollCourseId,
            _newEnrollDate.ToString("yyyy-MM-dd"));
        _newEnrollCourseId = 0;
        _personCourseList  = CourseSvc.GetStudentCourses(_courseMgmtPersonId.Value);
        ReloadOpenCourses();
    }

    void StartFinish(int studentCourseId)
    {
        _finishingCourseId = studentCourseId;
        _finishDate = DateTime.Today;
    }

    void ConfirmFinish(int studentCourseId)
    {
        CourseSvc.FinishStudentCourse(studentCourseId, _finishDate.ToString("yyyy-MM-dd"));
        _finishingCourseId = null;
        _personCourseList  = CourseSvc.GetStudentCourses(_courseMgmtPersonId!.Value);
        ReloadOpenCourses();
    }

    void DeleteStudentCourse(int studentCourseId)
    {
        CourseSvc.DeleteStudentCourse(studentCourseId);
        _personCourseList = CourseSvc.GetStudentCourses(_courseMgmtPersonId!.Value);
        ReloadOpenCourses();
    }

    void ReloadOpenCourses()
    {
        var allIds = _allPersons.Select(p => p.PersonId);
        _personOpenCourses = CourseSvc.GetOpenCoursesForPersons(allIds);
    }
