@* ── Course Management Modal ── *@
@if (_courseMgmtPersonId.HasValue)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45);"
         @onclick="CloseCourseModal">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;"
             @onclick:stopPropagation="true">
            <div class="modal-content shadow" style="border-radius:14px;border:none;background:#fff;color:#212529;">

                <div class="modal-header py-2 px-3"
                     style="background:linear-gradient(135deg,#4c1d95,#7c3aed);border-radius:14px 14px 0 0;border:none;">
                    <div>
                        <h6 class="modal-title mb-0 text-white fw-bold">
                            <i class="ri-book-2-line me-2 opacity-75"></i>@_courseMgmtPersonName
                        </h6>
                        <div class="text-white opacity-75" style="font-size:.75rem;">Course Management</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseCourseModal"></button>
                </div>

                <div class="modal-body px-3 py-3">

                    @* ── Active courses ── *@
                    @{
                        var activeCourses = _personCourseList.Where(c => c.DateFinished == null).ToList();
                        var doneCourses   = _personCourseList.Where(c => c.DateFinished != null).ToList();
                    }

                    @if (activeCourses.Count > 0)
                    {
                        <div class="fw-semibold mb-2" style="font-size:.83rem;color:#a78bfa;">
                            <i class="ri-book-open-line me-1"></i>Active Courses
                        </div>
                        @foreach (var sc in activeCourses)
                        {
                            var visitsSince = CourseSvc.GetVisitCountSince(_courseMgmtPersonId!.Value, sc.DateStarted);
                            <div class="d-flex align-items-center gap-2 mb-2 p-2 rounded"
                                 style="background:#f5f3ff;border:1px solid #ddd6fe;color:#212529;">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="font-size:.86rem;color:#4c1d95;">@sc.CourseName</div>
                                    <div style="font-size:.75rem;color:#6b7280;">
                                        Started: @sc.DateStarted &nbsp;·&nbsp;
                                        <span style="color:#059669;font-weight:600;">@visitsSince visit@(visitsSince == 1 ? "" : "s") since start</span>
                                    </div>
                                </div>
                                @if (_finishingCourseId == sc.StudentCourseId)
                                {
                                    <div class="d-flex align-items-center gap-1 flex-wrap">
                                        <input type="date" class="form-control form-control-sm" style="max-width:145px;"
                                               @bind="_finishDate" />
                                        <button class="btn btn-sm btn-success py-0 px-2"
                                                @onclick="() => ConfirmFinish(sc.StudentCourseId)">✓</button>
                                        <button class="btn btn-sm btn-link py-0" style="color:#6b7280;"
                                                @onclick="() => _finishingCourseId = null">✕</button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:.76rem;"
                                            @onclick="() => StartFinish(sc.StudentCourseId)">
                                        <i class="ri-check-line me-1"></i>Finish
                                    </button>
                                    <button class="btn btn-sm btn-link text-danger py-0 px-1"
                                            @onclick="() => DeleteStudentCourse(sc.StudentCourseId)">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="small mb-3" style="color:#6b7280;">
                            <i class="ri-information-line me-1"></i>No active courses.
                        </div>
                    }

                    @* ── Add new course ── *@
                    <div class="border-top pt-3 mt-2">
                        <div class="fw-semibold mb-2" style="font-size:.83rem;color:#1e3a5f;">
                            <i class="ri-add-circle-line me-1"></i>Enroll in Course
                        </div>
                        <div class="d-flex gap-2 flex-wrap">
                            <select class="form-select form-select-sm" style="max-width:200px;" @bind="_newEnrollCourseId">
                                <option value="0">— select course —</option>
                                @foreach (var c in _allCourses)
                                {
                                    <option value="@c.CourseId">@c.Name</option>
                                }
                            </select>
                            <input type="date" class="form-control form-control-sm" style="max-width:145px;"
                                   @bind="_newEnrollDate" />
                            <button class="btn btn-sm btn-primary"
                                    @onclick="AddStudentCourse"
                                    disabled="@(_newEnrollCourseId <= 0)">
                                <i class="ri-save-line me-1"></i>Enroll
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_enrollError))
                        {
                            <div class="alert alert-danger py-1 px-2 mt-2 small mb-0">@_enrollError</div>
                        }
                    </div>

                    @* ── Past courses ── *@
                    @if (doneCourses.Count > 0)
                    {
                        <div class="border-top pt-3 mt-2">
                            <div class="fw-semibold mb-2" style="font-size:.83rem;color:#1e3a5f; opacity:.7;">
                                <i class="ri-history-line me-1"></i>Completed
                            </div>
                            @foreach (var sc in doneCourses)
                            {
                                <div class="d-flex align-items-center gap-2 mb-1 px-2 py-1 rounded"
                                     style="background:#f9fafb;border:1px solid #e5e7eb;color:#212529;">
                                    <div class="flex-grow-1">
                                        <span class="fw-medium" style="font-size:.83rem;color:#374151;">@sc.CourseName</span>
                                        <span class="text-muted ms-2" style="font-size:.73rem;">@sc.DateStarted → @sc.DateFinished</span>
                                    </div>
                                    <button class="btn btn-sm btn-link text-danger py-0 px-1"
                                            @onclick="() => DeleteStudentCourse(sc.StudentCourseId)">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }

                </div>

                <div class="modal-footer py-2 px-3" style="border-top:1px solid #ede9fe;">
                    <button class="btn btn-sm btn-link text-muted" @onclick="CloseCourseModal">@LS.T("common.close")</button>
                </div>

            </div>
        </div>
    </div>
}

<style>
    /* ── Responsive two-panel layout ── */
    .acad-right-panel { width: 290px; min-width: 220px; flex-shrink: 0; }
    @@media (max-width: 768px) {
        .acad-main-layout { flex-direction: column; }
        .acad-right-panel { width: 100% !important; min-width: 0 !important; }
        .acad-visit-card .card-body { overflow-x: hidden; }
    }

    /* ── Persons scrollbar ── */
    .acad-persons-scroll { scrollbar-width: thin; scrollbar-color: #c4c4c4 transparent; }
    .acad-persons-scroll::-webkit-scrollbar { width: 6px; }
    .acad-persons-scroll::-webkit-scrollbar-thumb { background: #c4c4c4; border-radius: 3px; }
    .acad-persons-scroll::-webkit-scrollbar-track { background: transparent; }

    /* ── Nav bar ── */
    .acad-nav-bar {
        display: flex; align-items: center; flex-wrap: wrap; gap: 10px;
        padding: 10px 16px 10px;
        background: linear-gradient(135deg, #065f46 0%, #059669 60%, #10b981 100%);
        color: #fff;
    }
    .acad-nav-week { font-weight: 600; font-size: .93rem; }
    .acad-nav-btn {
        background: rgba(255,255,255,.18); color: #fff; border: 1px solid rgba(255,255,255,.25);
        border-radius: 20px; font-size: .82rem; padding: 4px 12px;
        transition: background .18s;
    }
    .acad-nav-btn:hover:not(:disabled) { background: rgba(255,255,255,.3); color: #fff; }
    .acad-nav-btn:disabled { opacity: .4; }
    .acad-add-btn {
        background: rgba(255,255,255,.95); color: #065f46; border: none;
        border-radius: 20px; font-size: .82rem; font-weight: 600; padding: 5px 14px;
        box-shadow: 0 2px 10px rgba(0,0,0,.12);
    }
    .acad-add-btn:hover { background: #fff; color: #047857; }
    .acad-print-btn {
        background: transparent; color: rgba(255,255,255,.85); border: 1px solid rgba(255,255,255,.3);
        border-radius: 20px; font-size: .82rem; padding: 4px 12px;
    }
    .acad-print-btn:hover { background: rgba(255,255,255,.15); color: #fff; }

    /* ── Day pills ── */
    .acad-day-bar { display: flex; flex-wrap: wrap; gap: 8px; padding-top: 12px; }
    .acad-day-pill {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 13px; border-radius: 20px; border: 1px solid #d1fae5;
        background: #f0fdf4; color: #374151;
        font-size: .8rem; font-weight: 500; cursor: pointer;
        transition: background .15s, border-color .15s, box-shadow .15s;
    }
    .acad-day-pill:hover:not(.acad-day-future):not(.acad-day-active) {
        background: #dcfce7; border-color: #6ee7b7;
    }
    .acad-day-active {
        background: linear-gradient(135deg, #059669, #10b981) !important;
        border-color: transparent !important; color: #fff !important;
        box-shadow: 0 3px 12px rgba(5,150,105,.35);
    }
    .acad-day-future { opacity: .4; cursor: default; }
    .acad-day-label { font-size: .8rem; }
    .acad-day-badge {
        background: rgba(255,255,255,.35); color: #fff;
        font-size: .7rem; font-weight: 700;
        border-radius: 10px; padding: 0 6px; min-width: 18px; text-align: center;
    }
    .acad-day-pill:not(.acad-day-active) .acad-day-badge {
        background: #059669; color: #fff;
    }

    /* ── Visit card ── */
    .acad-visit-header {
        display: flex; align-items: center; justify-content: space-between;
        background: linear-gradient(135deg, #065f46, #10b981);
        color: #fff; border-radius: 14px 14px 0 0; padding: 10px 16px; border: none;
    }
    .acad-visit-chip {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 10px 5px 8px; border-radius: 20px;
        font-size: .82rem; font-weight: 600;
        border-width: 1px; border-style: solid;
        box-shadow: 0 1px 4px rgba(0,0,0,.1);
        transition: transform .15s, box-shadow .15s;
        max-width: 100%; flex-wrap: wrap;
    }
    .acad-visit-chip:hover { transform: translateY(-1px); box-shadow: 0 3px 10px rgba(0,0,0,.15); }
    .acad-chip-remove {
        background: none; border: none; padding: 0; margin-left: 2px;
        opacity: .6; line-height: 1; cursor: pointer; font-size: .9rem;
        display: flex; align-items: center;
        transition: opacity .15s;
        flex-shrink: 0;
    }
    .acad-chip-remove:hover { opacity: 1; }
    .acad-vpd-badge {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 18px; height: 18px; border-radius: 50%;
        background: rgba(0,0,0,.2); color: #fff; font-size: .7rem; font-weight: 800;
        line-height: 1; flex-shrink: 0;
    }

    /* ── Persons panel ── */
    .acad-persons-card { background: #fff !important; }
    .acad-persons-card .card-body { background: #fff; }
    .acad-persons-header {
        display: flex; align-items: center; gap: 6px;
        background: #f8fafc; border-bottom: 1px solid #e2e8f0;
        border-radius: 14px 14px 0 0; padding: 9px 12px;
        color: #374151; border: none;
    }
    .acad-person-row {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 8px; border-radius: 8px; margin-bottom: 2px;
        color: #1f2937;
        transition: background .12s;
    }
    .acad-person-available { cursor: pointer; }
    .acad-person-available:hover { background: #f0fdf4; color: #1f2937; }
    .acad-person-available:hover .acad-add-icon { color: #16a34a; }
    .acad-person-visited { cursor: default; opacity: .65; }
    .acad-person-no-course { cursor: pointer; opacity: .7; background: #fef3c7; }
    .acad-person-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .acad-add-icon { color: #9ca3af; transition: color .15s; }

    /* ── Legend dot ── */
    .acad-legend-dot {
        width: 9px; height: 9px; border-radius: 50%; flex-shrink: 0; display: inline-block;
    }

    /* ── Chart header ── */
    .acad-chart-header {
        display: flex; align-items: center; justify-content: space-between;
        background: linear-gradient(135deg, #065f46, #10b981);
        color: #fff; padding: 10px 16px; border: none;
        border-radius: 14px 14px 0 0;
    }
    /* Allow tooltip to escape the chart card */
    .apexcharts-tooltip { z-index: 9999 !important; }

    @@media print {
        .acad-nav-bar { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
    }

    /* Force dark text inside white-bg course modal */
    .modal-content .form-select,
    .modal-content .form-control { color: #212529 !important; background-color: #fff !important; border-color: #dee2e6 !important; }

    /* ── Click animation on person row ── */
    .acad-person-clicked {
        animation: personClickPulse .55s cubic-bezier(.4,0,.2,1);
        pointer-events: none;
    }
    @@keyframes personClickPulse {
        0%   { transform: scale(1); background: transparent; }
        15%  { transform: scale(.96); background: #d1fae5; box-shadow: inset 0 0 0 2px #34d399; }
        40%  { transform: scale(1.02); background: #a7f3d0; }
        60%  { transform: scale(.99); background: #d1fae5; }
        100% { transform: scale(1); background: transparent; box-shadow: none; }
    }

    /* ── Pop-in animation for newly added visit chip ── */
    .acad-chip-enter {
        animation: chipPopIn .5s cubic-bezier(.34,1.56,.64,1);
    }
    @@keyframes chipPopIn {
        0%   { opacity: 0; transform: scale(.3) translateY(12px); }
        50%  { opacity: 1; transform: scale(1.08) translateY(-2px); }
        70%  { transform: scale(.97) translateY(1px); }
        100% { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* Subtle glow on the newly added chip */
    .acad-chip-enter {
        box-shadow: 0 0 0 3px rgba(16,185,129,.35), 0 4px 15px rgba(16,185,129,.25);
    }

    /* ── Tap animation on visit chip (cycle visits) ── */
    .acad-chip-tapped {
        animation: chipTapBounce .45s cubic-bezier(.4,0,.2,1);
    }
    @@keyframes chipTapBounce {
        0%   { transform: scale(1); }
        20%  { transform: scale(.92); filter: brightness(1.15); }
        50%  { transform: scale(1.06); }
        70%  { transform: scale(.98); }
        100% { transform: scale(1); filter: brightness(1); }
    }
</style>

@* ── No active course warning popup ── *@
@if (_showNoCourseWarning && _pendingVisitPerson != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
