                                 Items="@_monthlyTotals"
                                 Name="Don / Default"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(m => m.MonthLabel)"
                                 YValue="@(m => (decimal)m.DonCount)" />
                <ApexPointSeries TItem="MonthVisitCount"
                                 Items="@_monthlyTotals"
                                 Name="Friend"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(m => m.MonthLabel)"
                                 YValue="@(m => (decimal)m.FriendCount)" />
                <ApexPointSeries TItem="MonthVisitCount"
                                 Items="@_monthlyTotals"
                                 Name="Social Network"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(m => m.MonthLabel)"
                                 YValue="@(m => (decimal)m.SocialCount)" />
                <ApexPointSeries TItem="MonthVisitCount"
                                 Items="@_monthlyTotals"
                                 Name="Haifa"
                                 SeriesType="SeriesType.Bar"
                                 XValue="@(m => m.MonthLabel)"
                                 YValue="@(m => (decimal)m.HaifaCount)" />
                <ApexPointSeries TItem="MonthVisitCount"
                                 Items="@_monthlyTotals"
