@page "/Academy"
@attribute [Authorize]
@inject LPM.Services.AcademyService AcademySvc
@inject LPM.Services.CourseService CourseSvc
@inject PdfService PdfService
@inject IJSRuntime JS
@using LPM.Services
@using Microsoft.AspNetCore.Authorization
@using System.Globalization
@using ApexCharts

@* ── Week navigation bar ── *@
<div class="acad-nav-bar">
    <div class="d-flex align-items-center gap-2 flex-shrink-0">
        <button class="btn btn-sm acad-nav-btn" @onclick="PrevWeek">
            <i class="ri-arrow-left-s-line"></i> @LS.T("common.prev")
        </button>
        <span class="acad-nav-week">
            <i class="ri-calendar-2-line me-1 opacity-75"></i>
            @DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
        </span>
        <button class="btn btn-sm acad-nav-btn" @onclick="NextWeek"
                disabled="@(_weekStart >= DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today)))">
            Next <i class="ri-arrow-right-s-line"></i>
        </button>
    </div>
    <div class="d-flex gap-2 ms-auto">
        <button class="btn btn-sm acad-print-btn" @onclick="PrintWeek">
            <i class="ri-printer-line me-1"></i>@LS.T("common.print")
        </button>
    </div>
</div>

@* ── Day pill tabs ── *@
<div class="acad-day-bar px-3 mb-3">
    @for (int i = 0; i < 7; i++)
    {
        var idx      = i;
        var day      = _weekStart.AddDays(idx);
        var isFuture = day > DateOnly.FromDateTime(DateTime.Today);
        var isSel    = idx == _selDay;
        var cnt      = _dayCounts.GetValueOrDefault(idx, 0);

        <button class="acad-day-pill @(isSel ? "acad-day-active" : "") @(isFuture ? "acad-day-future" : "")"
                @onclick="() => SelectDay(idx)" disabled="@isFuture">
            <span class="acad-day-label">@DayLabel(day)</span>
            @if (cnt > 0)
            {
                <span class="acad-day-badge">@cnt</span>
            }
        </button>
    }
</div>

@* ── Main content: visits + person list ── *@
<div class="d-flex gap-3 px-3 mb-3 acad-main-layout" style="align-items:flex-start;">

    @* ── Today's visit list ── *@
    <div class="card flex-grow-1 shadow-sm acad-visit-card" style="min-width:0;border-radius:14px;border:none;">
        <div class="card-header acad-visit-header">
            <div class="d-flex align-items-center gap-2">
                <i class="ri-user-heart-line"></i>
                <strong style="font-size:.9rem;">@LS.T("academy.visits") — @DayLabel(_weekStart.AddDays(_selDay))</strong>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill px-2" style="background:rgba(255,255,255,.25);font-size:.78rem;">
                    @_visits.Count
                </span>
                @* Referral legend *@
                <div class="d-flex align-items-center gap-2 ms-2" style="font-size:.72rem;">
                    <span class="acad-legend-dot" style="background:#16a34a;"></span><span class="opacity-80">@LS.T("academy.don")</span>
                    <span class="acad-legend-dot" style="background:#f59e0b;"></span><span class="opacity-80">@LS.T("academy.friend")</span>
                    <span class="acad-legend-dot" style="background:#3b82f6;"></span><span class="opacity-80">@LS.T("academy.social")</span>
                    <span class="acad-legend-dot" style="background:#94a3b8;"></span><span class="opacity-80">@LS.T("academy.other")</span>
                </div>
            </div>
        </div>
        <div class="card-body py-3 px-3">
            @if (_visits.Count == 0)
            {
                <div class="text-center py-4 text-muted">
                    <i class="ri-user-search-line d-block mb-2 opacity-30" style="font-size:2.2rem;"></i>
                    <span class="small">No visits recorded for this day yet.</span>
                </div>
            }
            else
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var v in _visits)
                    {
                        var (chipBg, chipBorder, chipColor) = ReferralChipStyle(v.Source);
                        var vid = v.VisitId;
                        <span class="acad-visit-chip @(v.PersonId == _lastAddedPersonId ? "acad-chip-enter" : "") @(v.VisitId == _tappedVisitId ? "acad-chip-tapped" : "")" style="background:@chipBg;border-color:@chipBorder;color:@chipColor;cursor:pointer;"
                              @onclick="() => DoCycleVisits(vid)">
                            <span class="acad-vpd-badge" title="Visits today (click to cycle)">@v.VisitsPerDay</span>
                            <i class="ri-user-smile-line" style="font-size:.82rem;opacity:.7;"></i>
                            @v.FullName@if (!string.IsNullOrEmpty(v.Nick)) { <text> </text><span style="font-size:.7rem;opacity:.75;">(@v.Nick)</span> }
                            @if (!string.IsNullOrEmpty(v.Org))
                            {
                                <span style="font-size:.68rem;padding:1px 5px;border-radius:8px;
                                             background:rgba(0,0,0,.1);opacity:.85;font-weight:700;">
                                    @v.Org
                                </span>
                            }
                            @{
                                var openCourse = _personOpenCourses.GetValueOrDefault(v.PersonId, "");
                            }
                            @if (!string.IsNullOrEmpty(openCourse))
                            {
                                <span style="font-size:.67rem;padding:1px 6px;border-radius:8px;
                                             background:rgba(124,58,237,.18);color:#5b21b6;font-weight:700;flex-shrink:0;">
                                    <i class="ri-book-2-line" style="font-size:.65rem;"></i> @openCourse
                                </span>
                            }
                            <button class="acad-chip-remove" title="Manage courses" style="color:@chipColor;opacity:.7;"
                                    @onclick="() => OpenCourseModal(v.PersonId, v.FullName)" @onclick:stopPropagation="true">
                                <i class="ri-book-line"></i>
                            </button>
                            <button class="acad-chip-remove" title="Remove" style="color:@chipColor;"
                                    @onclick="() => DoRemoveVisit(v.VisitId)" @onclick:stopPropagation="true">
                                <i class="ri-close-fill"></i>
                            </button>
                        </span>
                    }
                </div>
            }
        </div>
    </div>

    @* ── All persons panel ── *@
    <div class="card shadow-sm acad-persons-card acad-right-panel" style="border-radius:14px;border:none;">
        <div class="card-header acad-persons-header">
            <i class="ri-contacts-book-2-line me-1"></i>
            <strong style="font-size:.88rem;">All Persons</strong>
        </div>
        <div class="card-body py-2 px-2">
            <div class="input-group input-group-sm mb-2">
                <span class="input-group-text bg-white border-end-0" style="border-color:#e2e8f0;">
                    <i class="ri-search-2-line text-muted" style="font-size:.85rem;"></i>
                </span>
                <input class="form-control border-start-0" style="border-color:#e2e8f0;font-size:.84rem;"
                       placeholder="Filter persons..."
                       value="@_searchText"
                       @oninput="OnSearchInput" />
            </div>
            <div class="acad-persons-scroll" style="max-height:260px; overflow-y:scroll;">
                @foreach (var p in FilteredPersons)
                {
                    var visited = AlreadyVisited(p.PersonId);
                    var pCourse = _personOpenCourses.GetValueOrDefault(p.PersonId, "");
                    var hasActiveCourse = !string.IsNullOrEmpty(pCourse);
                    <div class="acad-person-row @(visited ? "acad-person-visited" : hasActiveCourse ? "acad-person-available" : "acad-person-no-course") @(p.PersonId == _clickedPersonId ? "acad-person-clicked" : "")"
                         @onclick="() => { if (!visited) OnPersonClick(p); }">
                        <div class="acad-person-dot" style="background:@(hasActiveCourse ? ReferralDotColor(p.Source) : "#d1d5db");"></div>
                        <div class="overflow-hidden flex-grow-1" style="min-width:0;">
                            <div style="font-size:.83rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;@(hasActiveCourse ? "" : "color:#9ca3af;")">@p.FullName@if (!string.IsNullOrEmpty(p.Nick)) { <span style="font-size:.68rem;color:#6b7280;opacity:.85;"> (@p.Nick)</span> }</div>
                            @if (hasActiveCourse)
                            {
                                <div style="font-size:.67rem;color:#a78bfa;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    <i class="ri-book-2-line"></i> @pCourse
                                </div>
                            }
                            else
                            {
                                <div style="font-size:.67rem;color:#d97706;font-weight:600;">
                                    <i class="ri-alert-line"></i> @LS.T("academy.noActiveCourse")
                                </div>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(p.Org))
                        {
                            <span style="font-size:.67rem;padding:1px 5px;border-radius:8px;
                                         background:#e0e7ff;color:#4338ca;font-weight:600;flex-shrink:0;">
                                @p.Org
                            </span>
                        }
                        @if (visited)
                        {
                            <i class="ri-check-double-line ms-auto" style="font-size:.88rem;color:#4ade80;flex-shrink:0;"></i>
                        }
                        else
                        {
                            <i class="ri-add-circle-line ms-auto acad-add-icon" style="font-size:.88rem;flex-shrink:0;"></i>
                        }
                    </div>
                }
                @if (!FilteredPersons.Any())
                {
                    <div class="text-muted small text-center py-3">No persons found.</div>
                }
            </div>
        </div>
    </div>

</div>

@* ── Weekly student breakdown summary ── *@
@if (_weekByReferral.Count > 0 || _weekByOrg.Count > 0)
{
    <div class="mx-3 mb-3">
        <div class="card shadow-sm" style="border-radius:12px;border:none;background:#f8fffe;">
            <div class="card-body py-2 px-3" style="color:#212529;">
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <span class="small fw-semibold" style="color:#065f46;white-space:nowrap;">
                        <i class="ri-bar-chart-2-line me-1"></i>Week summary:
                    </span>

                    @* ── Referral breakdown ── *@
                    @if (_weekByReferral.Count > 0)
                    {
                        <span class="small fw-semibold ms-1" style="color:#6b7280;">By referral —</span>
                        @foreach (var kv in _weekByReferral.OrderByDescending(x => x.Value))
                        {
                            var dotCol = ReferralDotColor(kv.Key == "Don" ? "Don" : kv.Key);
                            <span class="d-inline-flex align-items-center gap-1"
                                  style="font-size:.8rem;font-weight:600;color:#1f2937;">
                                <span style="width:8px;height:8px;border-radius:50%;background:@dotCol;display:inline-block;flex-shrink:0;"></span>
                                @kv.Key: <strong>@kv.Value</strong>
                            </span>
                        }
                    }

                    @* ── Org breakdown ── *@
                    @if (_weekByOrg.Count > 0)
                    {
                        <span class="vr mx-1"></span>
                        <span class="small fw-semibold" style="color:#6b7280;">By org —</span>
                        @foreach (var kv in _weekByOrg.OrderByDescending(x => x.Value))
                        {
                            <span class="d-inline-flex align-items-center gap-1"
                                  style="font-size:.8rem;font-weight:600;color:#1f2937;">
                                <i class="ri-building-2-line" style="font-size:.75rem;color:#059669;"></i>
                                @kv.Key: <strong>@kv.Value</strong>
                            </span>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Inline weekly student table ── *@
@if (_weekStudents.Count > 0)
{
    <div class="card mx-3 mb-3 shadow-sm" style="border-radius:14px;border:none;">
        <div class="card-header acad-chart-header" style="border-radius:14px 14px 0 0;cursor:pointer;"
             @onclick="() => _weekTableExpanded = !_weekTableExpanded">
            <div class="d-flex align-items-center gap-2">
                <i class="@(_weekTableExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")" style="font-size:1.1rem;"></i>
                <strong style="font-size:.9rem;">Weekly Student List — @DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))</strong>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.25);font-size:.78rem;">
                    @_weekStudents.Count students
                </span>
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.15);font-size:.75rem;">
                    @_weekStudents.Sum(s => s.VisitCount) visits
                </span>
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.3);font-size:.75rem;">
                    @_weekStudents.Sum(s => s.TotalSessions) total visits
                </span>
            </div>
        </div>
        @if (_weekTableExpanded)
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3 small" style="width:32px;">#</th>
                                <th class="small">Student</th>
                                <th class="small" style="width:60px;">Org</th>
                                <th class="small" style="width:120px;">Referral</th>
                                <th class="small" style="width:130px;">Active Course</th>
                                <th class="small text-center" style="width:50px;">Visits</th>
                                <th class="small text-center" style="width:80px;">Total Visits</th>
                                <th style="width:36px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rowNum = 0; }
                            @foreach (var s in _weekStudents)
                            {
                                rowNum++;
                                var (bg, _, col) = ReferralChipStyle(s.Source);
                                var dotColor     = ReferralDotColor(s.Source);
                                var refLabel     = string.IsNullOrEmpty(s.Source) ? "Don" : s.Source;
                                var courseStr    = _personOpenCourses.GetValueOrDefault(s.PersonId, "");
                                <tr style="background:@(rowNum % 2 == 0 ? "#fafafa" : "#fff");">
                                    <td class="ps-3 small text-muted align-middle">@rowNum</td>
                                    <td class="align-middle">
                                        <span class="fw-medium" style="font-size:.86rem;">@s.FullName@if (!string.IsNullOrEmpty(s.Nick)) { <span style="font-size:.72rem;color:#6b7280;"> (@s.Nick)</span> }</span>
                                    </td>
                                    <td class="align-middle">
                                        @if (!string.IsNullOrEmpty(s.Org))
                                        {
                                            <span class="badge rounded-pill" style="background:#e0e7ff;color:#4338ca;font-size:.72rem;">@s.Org</span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <span class="d-inline-flex align-items-center gap-1" style="font-size:.8rem;font-weight:600;">
                                            <span style="width:7px;height:7px;border-radius:50%;background:@dotColor;display:inline-block;flex-shrink:0;"></span>
                                            @refLabel
                                        </span>
                                    </td>
                                    <td class="align-middle">
                                        @if (!string.IsNullOrEmpty(courseStr))
                                        {
                                            <span class="badge rounded-pill" style="background:#ede9fe;color:#7c3aed;font-size:.72rem;">
                                                <i class="ri-book-2-line me-1"></i>@courseStr
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="fw-bold" style="color:#059669;font-size:.9rem;">@s.VisitCount</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <span class="fw-bold" style="color:#d97706;font-size:.9rem;">@s.TotalSessions</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <button class="btn btn-link btn-sm py-0 px-1" title="Manage courses"
                                                style="color:#7c3aed;font-size:.85rem;"
                                                @onclick="() => OpenCourseModal(s.PersonId, s.FullName)">
                                            <i class="ri-book-line"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@* ── Monthly student table (collapsible) ── *@
@if (_monthStudents.Count > 0)
{
    <div class="card mx-3 mb-3 shadow-sm" style="border-radius:14px;border:none;">
        <div class="card-header acad-chart-header" style="border-radius:14px 14px 0 0;cursor:pointer;background:linear-gradient(135deg,#4338ca 0%,#6366f1 100%);"
             @onclick="() => _monthTableExpanded = !_monthTableExpanded">
            <div class="d-flex align-items-center gap-2">
                <i class="@(_monthTableExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")" style="font-size:1.1rem;"></i>
                <strong style="font-size:.9rem;">Monthly Student List — @_monthLabel (@DayLabel(_monthStart) – @DayLabel(_monthEnd))</strong>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.2);font-size:.75rem;">
                    @_monthWeekCount weeks
                </span>
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.25);font-size:.78rem;">
                    @_monthStudents.Count students
                </span>
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.15);font-size:.75rem;">
                    @_monthStudents.Sum(s => s.VisitCount) visits
                </span>
                <span class="badge rounded-pill" style="background:rgba(255,255,255,.3);font-size:.75rem;">
                    @_monthStudents.Sum(s => s.TotalSessions) total visits
                </span>
            </div>
        </div>
        @if (_monthTableExpanded)
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3 small" style="width:32px;">#</th>
                                <th class="small">Student</th>
                                <th class="small" style="width:60px;">Org</th>
                                <th class="small" style="width:120px;">Referral</th>
                                <th class="small" style="width:130px;">Active Course</th>
                                <th class="small text-center" style="width:50px;">Visits</th>
                                <th class="small text-center" style="width:80px;">Total Visits</th>
                                <th style="width:36px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ int mRowNum = 0; }
                            @foreach (var s in _monthStudents)
                            {
                                mRowNum++;
                                var dotColor  = ReferralDotColor(s.Source);
                                var refLabel  = string.IsNullOrEmpty(s.Source) ? "Don" : s.Source;
                                var courseStr = _personOpenCourses.GetValueOrDefault(s.PersonId, "");
                                <tr style="background:@(mRowNum % 2 == 0 ? "#f5f3ff" : "#fff");">
                                    <td class="ps-3 small text-muted align-middle">@mRowNum</td>
                                    <td class="align-middle">
                                        <span class="fw-medium" style="font-size:.86rem;">@s.FullName@if (!string.IsNullOrEmpty(s.Nick)) { <span style="font-size:.72rem;color:#6b7280;"> (@s.Nick)</span> }</span>
                                    </td>
                                    <td class="align-middle">
                                        @if (!string.IsNullOrEmpty(s.Org))
                                        {
                                            <span class="badge rounded-pill" style="background:#e0e7ff;color:#4338ca;font-size:.72rem;">@s.Org</span>
                                        }
                                    </td>
                                    <td class="align-middle">
                                        <span class="d-inline-flex align-items-center gap-1" style="font-size:.8rem;font-weight:600;">
                                            <span style="width:7px;height:7px;border-radius:50%;background:@dotColor;display:inline-block;flex-shrink:0;"></span>
