    static string ReferralDotColor(string referral) => referral switch
    {
        "Friend"          => "#f59e0b",
        "Social Network"  => "#3b82f6",
        "Haifa"           => "#7c3aed",
        "Other"           => "#94a3b8",
        _                 => "#16a34a",  // Don / default
    };

    protected override void OnInitialized()
    {
        _allPersons = AcademySvc.GetAllPersons();
        _allCourses = CourseSvc.GetAllCourses();
        _weekStart  = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));

        var today = DateOnly.FromDateTime(DateTime.Today);
        _selDay = 0;
        for (int i = 6; i >= 0; i--)
        {
            if (_weekStart.AddDays(i) <= today)
            { _selDay = i; break; }
        }

        LoadWeek();
    }

    void PrevWeek() { _weekStart = _weekStart.AddDays(-7); LoadWeek(); }

    void NextWeek()
    {
        var maxWeek = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));
        if (_weekStart >= maxWeek) return;
        var next = _weekStart.AddDays(7);
        _weekStart = next > maxWeek ? maxWeek : next;
        var today = DateOnly.FromDateTime(DateTime.Today);
        for (int i = 6; i >= 0; i--)
            if (_weekStart.AddDays(i) <= today) { _selDay = i; break; }
        _searchText = "";
        LoadWeek();
    }

    void LoadWeek()
    {
        LoadDayCounts();
        LoadVisits();
        RefreshChart();
    }

    void LoadDayCounts()
    {
        _dayCounts = [];
        for (int i = 0; i < 7; i++)
            _dayCounts[i] = AcademySvc.GetVisitsForDay(_weekStart.AddDays(i)).Count;
    }

    void LoadVisits() => _visits = AcademySvc.GetVisitsForDay(SelectedDate);

    void RefreshChart()
    {
        var latestWeekStart = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));
        _weeklyTotals  = AcademySvc.GetWeeklyVisitCounts(latestWeekStart, 20);
        _monthlyTotals = AcademySvc.GetMonthlyVisitCounts(latestWeekStart, 12);
        _weekStudents  = AcademySvc.GetStudentVisitsForWeek(_weekStart);
        (_weekByReferral, _weekByOrg) = AcademySvc.GetWeeklyStudentBreakdown(_weekStart);
        LoadMonthStudents();

        // Batch-load open courses for all persons
        var allIds = _allPersons.Select(p => p.PersonId);
        _personOpenCourses = CourseSvc.GetOpenCoursesForPersons(allIds);

        UpdateChartTooltip();
        _chartKey++;
        _monthChartKey++;
    }

    void UpdateChartTooltip()
    {
        // Build a JS array of per-week student data: [ [[name,count,org], ...], ... ]
        var sb = new System.Text.StringBuilder("[");
        for (int i = 0; i < _weeklyTotals.Count; i++)
        {
            if (i > 0) sb.Append(',');
            sb.Append('[');
            var students = _weeklyTotals[i].TopStudents;
            for (int j = 0; j < students.Count; j++)
            {
                if (j > 0) sb.Append(',');
                var rawName = students[j].FullName;
                if (!string.IsNullOrEmpty(students[j].Nick)) rawName += $" ({students[j].Nick})";
                var name = rawName.Replace("\\", "\\\\").Replace("'", "\\'");
                var org  = students[j].Org.Replace("\\", "\\\\").Replace("'", "\\'");
                sb.Append($"['{name}',{students[j].VisitCount},'{org}']");
            }
            sb.Append(']');
        }
        sb.Append(']');
        var data = sb.ToString();

        var fn =
            "function(opts){" +
            "var d=" + data + ";" +
            "var idx=opts.dataPointIndex;" +
            // sum all series for total
            "var total=0;for(var s=0;s<opts.series.length;s++){total+=(opts.series[s][idx]||0);}" +
            "var labels=['Don/Default','Friend','Social','Haifa','Other'];" +
            "var colors=['#16a34a','#f59e0b','#3b82f6','#7c3aed','#94a3b8'];" +
            "var st=d[idx]||[];" +
            "var r='<div style=\"padding:10px 14px;min-width:210px;font-family:inherit;background:#fff;" +
                    "border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.14)\">';" +
            "r+='<div style=\"font-weight:700;font-size:.93rem;color:#1b5e20;" +
                    "border-bottom:1px solid #c8e6c9;padding-bottom:5px;margin-bottom:8px\">Visit Count: '+total+'</div>';" +
            // referral breakdown
            "for(var i=0;i<labels.length;i++){" +
            "var cnt=opts.series[i]?opts.series[i][idx]||0:0;" +
            "if(cnt>0){r+='<div style=\"display:flex;align-items:center;gap:6px;padding:2px 0\">'+" +
            "'<span style=\"width:9px;height:9px;border-radius:50%;background:'+colors[i]+';display:inline-block;\"></span>'+" +
            "'<span style=\"font-size:.8rem;color:#374151\">'+labels[i]+': <b>'+cnt+'</b></span></div>';}}" +
            // student names
            "if(st.length){" +
            "r+='<div style=\"font-size:.7rem;color:#888;text-transform:uppercase;" +
                    "letter-spacing:.7px;margin:8px 0 5px\">Top Students</div>';" +
            "var maxShow=20;for(var i=0;i<Math.min(st.length,maxShow);i++){" +
            "var orgLabel=st[i][2]?(' <span style=\"font-size:.7rem;padding:1px 5px;border-radius:8px;" +
                    "background:#e0e7ff;color:#4338ca;font-weight:600;\">'+st[i][2]+'</span>'):'';"+
            "r+='<div style=\"display:flex;justify-content:space-between;align-items:center;gap:12px;padding:3px 6px;" +
                    "border-radius:4px;background:'+(i%2===0?'#f1f8f1':'transparent')+'\">';" +
            "r+='<span style=\"color:#212529;font-size:.82rem\">'+st[i][0]+orgLabel+'</span>';" +
            "r+='<span style=\"color:#2e7d32;font-weight:700;font-size:.82rem\">'+st[i][1]+'</span>';" +
            "r+='</div>';" +
            "}" +
            "if(st.length>maxShow){r+='<div style=\"text-align:center;padding:6px 0 2px;color:#888;" +
                    "font-size:.78rem;font-style:italic;border-top:1px dashed #e0e0e0;margin-top:4px\">" +
                    "+'+(st.length-maxShow)+' more students\u2026</div>';}" +
            "}" +
            "r+='</div>';" +
            "return r;}";

        _chartOptions.Tooltip = new Tooltip { Custom = fn };

        // Monthly tooltip — same format
        var msb = new System.Text.StringBuilder("[");
        for (int i = 0; i < _monthlyTotals.Count; i++)
        {
            if (i > 0) msb.Append(',');
            msb.Append('[');
            var students = _monthlyTotals[i].TopStudents;
            for (int j = 0; j < students.Count; j++)
            {
                if (j > 0) msb.Append(',');
