                             Name="Social Network"
                             SeriesType="SeriesType.Bar"
                             XValue="@(w => w.WeekLabel)"
                             YValue="@(w => (decimal)w.SocialCount)" />
            <ApexPointSeries TItem="WeekVisitCount"
                             Items="@_weeklyTotals"
                             Name="Haifa"
                             SeriesType="SeriesType.Bar"
                             XValue="@(w => w.WeekLabel)"
                             YValue="@(w => (decimal)w.HaifaCount)" />
            <ApexPointSeries TItem="WeekVisitCount"
                             Items="@_weeklyTotals"
