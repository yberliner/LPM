            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-error-warning-line text-warning" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("academy.noActiveCourseTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">
                        <strong>@_pendingVisitPerson.FullName</strong> @LS.T("academy.noActiveCourseMsg")
                    </div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="CancelNoCourseWarning">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-warning px-3" @onclick="ConfirmAddWithoutCourse">
                            <i class="ri-check-line me-1"></i>@LS.T("academy.addAnyway")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {

    DateOnly                _weekStart;
    int                     _selDay;
    Dictionary<int, int>    _dayCounts       = [];
    List<PersonItem>        _allPersons      = [];
    List<VisitRecord>       _visits          = [];
    List<WeekVisitCount>    _weeklyTotals    = [];
    List<MonthVisitCount>   _monthlyTotals   = [];
    int                     _chartKey;
    int                     _monthChartKey;
    string                  _searchText      = "";
    Dictionary<string, int> _weekByReferral  = [];
    Dictionary<string, int> _weekByOrg       = [];
    bool _weekTableExpanded = true;
    bool _monthTableExpanded = true;
    int _monthWeekCount;
    DateOnly _monthStart;
    DateOnly _monthEnd;
    string _monthLabel = "";

    List<(int PersonId, string FullName, int VisitCount, int TotalSessions, string Source, string Org, string Nick)> _weekStudents = [];
    List<(int PersonId, string FullName, int VisitCount, int TotalSessions, string Source, string Org, string Nick)> _monthStudents = [];
    Dictionary<int, string> _personOpenCourses = [];
    List<CourseItem>        _allCourses        = [];

    // Course management modal state
    int?   _courseMgmtPersonId;
    string _courseMgmtPersonName  = "";
    List<StudentCourseItem> _personCourseList = [];
    int    _newEnrollCourseId;
    DateTime _newEnrollDate = DateTime.Today;
    string _enrollError = "";
    int?   _finishingCourseId;
    DateTime _finishDate = DateTime.Today;


    ApexChartOptions<WeekVisitCount> _chartOptions = new()
    {
        Chart       = new Chart
        {
            Toolbar  = new Toolbar { Show = false },
            Background = "transparent",
            Stacked  = true,
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { ColumnWidth = "65%", BorderRadius = 0 } },
        Colors      = new List<string> { "#16a34a", "#f59e0b", "#3b82f6", "#7c3aed", "#94a3b8" },
        Xaxis       = new XAxis { Labels = new XAxisLabels { Rotate = -45, Style = new AxisLabelStyle { FontSize = "11px" } } },
        Grid        = new Grid { BorderColor = "#e0e0e0" },
        Legend      = new Legend { Show = false },
    };

    ApexChartOptions<MonthVisitCount> _monthChartOptions = new()
    {
        Chart       = new Chart
        {
            Toolbar  = new Toolbar { Show = false },
            Background = "transparent",
            Stacked  = true,
        },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { ColumnWidth = "65%", BorderRadius = 0 } },
        Colors      = new List<string> { "#16a34a", "#f59e0b", "#3b82f6", "#7c3aed", "#94a3b8" },
        Xaxis       = new XAxis { Labels = new XAxisLabels { Rotate = -45, Style = new AxisLabelStyle { FontSize = "11px" } } },
        Grid        = new Grid { BorderColor = "#e0e0e0" },
        Legend      = new Legend { Show = false },
    };

    DateOnly SelectedDate => _weekStart.AddDays(_selDay);

    static string DayLabel(DateOnly d) =>
        d.ToString("ddd dd/MM", CultureInfo.InvariantCulture);

    IEnumerable<PersonItem> FilteredPersons => string.IsNullOrWhiteSpace(_searchText)
        ? _allPersons
        : _allPersons.Where(p => p.FullName.Contains(_searchText, StringComparison.OrdinalIgnoreCase));

    bool AlreadyVisited(int personId) => _visits.Any(v => v.PersonId == personId);

    // Referral → chip background, border, text color
    static (string bg, string border, string color) ReferralChipStyle(string referral) => referral switch
    {
        "Friend"          => ("linear-gradient(135deg,#fef3c7,#fde68a)", "#fcd34d", "#78350f"),
        "Social Network"  => ("linear-gradient(135deg,#dbeafe,#bfdbfe)", "#93c5fd", "#1e3a8a"),
        "Haifa"           => ("linear-gradient(135deg,#f5f3ff,#ede9fe)", "#c4b5fd", "#4c1d95"),
        "Other"           => ("linear-gradient(135deg,#f3f4f6,#e5e7eb)", "#d1d5db", "#374151"),
        _                 => ("linear-gradient(135deg,#d1fae5,#a7f3d0)", "#6ee7b7", "#064e3b"),  // Don / default
    };

