                                    <td class="text-center align-middle">
                                        <span class="fw-bold" style="color:#d97706;font-size:.9rem;">@s.TotalSessions</span>
                                    </td>
                                    <td class="text-center align-middle">
                                        <button class="btn btn-link btn-sm py-0 px-1" title="Manage courses"
                                                style="color:#7c3aed;font-size:.85rem;"
                                                @onclick="() => OpenCourseModal(s.PersonId, s.FullName)">
                                            <i class="ri-book-line"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@* ── Statistics chart card ── *@
<div class="card mx-3 mb-3 shadow-sm" style="border-radius:14px;border:none;overflow:visible;">
    <div class="card-header acad-chart-header">
        <div class="d-flex align-items-center gap-2">
            <i class="ri-bar-chart-box-fill" style="font-size:1.1rem;"></i>
            <strong style="font-size:.9rem;">@LS.T("academy.weeklyVisitTotals")</strong>
        </div>
        <div class="d-flex align-items-center gap-3" style="font-size:.75rem;">
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:2px;background:#16a34a;display:inline-block;"></span>
                <span class="opacity-80">@LS.T("academy.don")</span>
            </span>
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:2px;background:#f59e0b;display:inline-block;"></span>
                <span class="opacity-80">@LS.T("academy.friend")</span>
            </span>
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:2px;background:#3b82f6;display:inline-block;"></span>
                <span class="opacity-80">@LS.T("academy.social")</span>
            </span>
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:2px;background:#7c3aed;display:inline-block;"></span>
                <span class="opacity-80">Haifa</span>
            </span>
            <span class="d-flex align-items-center gap-1">
                <span style="width:10px;height:10px;border-radius:2px;background:#94a3b8;display:inline-block;"></span>
                <span class="opacity-80">@LS.T("academy.other")</span>
            </span>
            <span style="font-size:.78rem;opacity:.8;">
                @LS.T("home.total"): @_weeklyTotals.Sum(w => w.TotalVisits) @LS.T("academy.visits").ToLower()
            </span>
        </div>
    </div>
    <div class="card-body py-1 px-2">
        <ApexChart TItem="WeekVisitCount"
                   Options="@_chartOptions"
                   Height="220"
                   @key="_chartKey">
            <ApexPointSeries TItem="WeekVisitCount"
                             Items="@_weeklyTotals"
                             Name="Don / Default"
                             SeriesType="SeriesType.Bar"
                             XValue="@(w => w.WeekLabel)"
                             YValue="@(w => (decimal)w.DonCount)" />
            <ApexPointSeries TItem="WeekVisitCount"
                             Items="@_weeklyTotals"
                             Name="Friend"
                             SeriesType="SeriesType.Bar"
                             XValue="@(w => w.WeekLabel)"
                             YValue="@(w => (decimal)w.FriendCount)" />
            <ApexPointSeries TItem="WeekVisitCount"
