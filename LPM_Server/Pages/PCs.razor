    // 10.5 → "10:30", 2.75 → "2:45" (always positive, sign handled separately)
    static string FormatHoursMinutes(double hours)
    {
        hours = Math.Abs(hours);
        int h = (int)hours;
        int m = (int)Math.Round((hours - h) * 60);
        if (m >= 60) { h++; m = 0; }
        return $"{h}:{m:D2}";
    }

