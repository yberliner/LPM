    // ── Course Completions Report ──────────────────────────────────────────────

    bool _showCoursesReportModal;
    DateTime _courseReportFrom = DateTime.Today.AddYears(-1);
    DateTime _courseReportTo   = DateTime.Today;
    List<CourseReportGroup>? _courseReportGroups;

    record CourseReportCourse(string CourseName, string DateStarted, string DateFinished);
    record SessCompletionItem(string? CompleteDate, string? FinishedGrade, string? AuditorName);
    record CourseReportGroup(string PcName, List<CourseReportCourse> Courses, List<SessCompletionItem> Completions);

    void OpenCoursesReportModal()
    {
        _courseReportGroups = null;
        _showCoursesReportModal = true;
        RunCoursesReport();
    }

    void GenerateCourseReportTestData()
    {
        if (_allCourses.Count == 0) return;
        var rng        = Random.Shared;
        var rangeStart = _courseReportFrom;
        var rangeEnd   = _courseReportTo;
        var spanDays   = Math.Max(1, (int)(rangeEnd - rangeStart).TotalDays);
        string[] testGrades = ["Grade 0", "Grade 1", "Grade 2", "Grade 3", "Grade 4", "ARC straightwire", "Objectives"];

        _courseReportGroups = _allPcsEx
            .Select(pc =>
            {
                int courseCount = rng.Next(0, 5); // 0–4
                int compCount   = rng.Next(0, 4); // 0–3
                if (courseCount == 0 && compCount == 0) return null;

                var courses = Enumerable.Range(0, courseCount)
                    .Select(_ =>
                    {
                        var course     = _allCourses[rng.Next(_allCourses.Count)];
                        var finishedAt = rangeStart.AddDays(rng.Next(0, spanDays));
                        var startedAt  = finishedAt.AddDays(-rng.Next(30, 180));
                        return new CourseReportCourse(
                            course.Name,
                            startedAt.ToString("yyyy-MM-dd"),
                            finishedAt.ToString("yyyy-MM-dd"));
                    }).ToList();

                var completions = Enumerable.Range(0, compCount)
                    .Select(_ => new SessCompletionItem(
                        rangeStart.AddDays(rng.Next(0, spanDays)).ToString("yyyy-MM-dd"),
                        testGrades[rng.Next(testGrades.Length)],
                        null))
                    .ToList();

                return new CourseReportGroup(pc.FullName, courses, completions);
            })
            .Where(g => g != null)
            .Cast<CourseReportGroup>()
            .OrderBy(g => g.PcName)
            .ToList();
    }

    void RunCoursesReport()
    {
        var from    = _courseReportFrom.ToString("yyyy-MM-dd");
        var to      = _courseReportTo.ToString("yyyy-MM-dd");
        var fromDo  = DateOnly.FromDateTime(_courseReportFrom);
        var toDo    = DateOnly.FromDateTime(_courseReportTo);

        var allEnrollments = CourseSvc.GetCourseEnrollmentReport();
        var courseGroups = allEnrollments
            .Where(e => e.DateFinished != null && string.Compare(e.DateFinished, from) >= 0 && string.Compare(e.DateFinished, to) <= 0)
            .GroupBy(e => e.PCFullName)
            .ToDictionary(g => g.Key, g => g.OrderBy(e => e.DateFinished)
                 .Select(e => new CourseReportCourse(e.CourseName, e.DateStarted, e.DateFinished!))
                 .ToList());

        var sessCompletions = CompletionSvc.GetAllForRange(fromDo, toDo);
        var sessGroups = sessCompletions
            .GroupBy(c => c.PcName)
            .ToDictionary(g => g.Key, g => g.Select(c => new SessCompletionItem(c.CompleteDate, c.FinishedGrade, c.AuditorName)).ToList());

        var allPcNames = courseGroups.Keys.Union(sessGroups.Keys).OrderBy(n => n);
        _courseReportGroups = allPcNames
            .Select(name => new CourseReportGroup(
                name,
                courseGroups.TryGetValue(name, out var courses) ? courses : [],
                sessGroups.TryGetValue(name, out var comps) ? comps : []))
            .ToList();
    }

