@page "/PCs"
@attribute [Authorize(Roles = "Admin,Customer")]
@inject LPM.Services.PcService PcSvc
@inject LPM.Services.CourseService CourseSvc
@inject LPM.Services.DashboardService DashSvc
@inject LPM.Services.WalletService WalletSvc
@inject LPM.Auth.UserDb UserDb
@inject LPM.Services.SmsService SmsSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject LPM.Services.CompletionService CompletionSvc
@inject LPM.Services.FolderService FolderSvc
@inject LPM.Services.SessionManagerLauncher SmLauncher
@inject PdfService PdfSvc
@inject LPM.Services.SessionManagerLauncher SmLauncher
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using LPM.Services
@implements IDisposable

<div class="pc-page-container">

    @* ── Toolbar ── *@
    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap pc-toolbar">
        <div class="pc-search-wrap">
            <input class="form-control form-control-sm pc-search-input" placeholder="@LS.T("common.search")"
                   @bind="_search" @bind:event="oninput" />
            @if (!string.IsNullOrEmpty(_search))
            {
                <button type="button" class="pc-search-clear"
                        title="Clear search"
                        @onclick="() => _search = string.Empty">
                    <i class="ri-close-line"></i>
                </button>
            }
        </div>
        <button class="pc-report-btn" @onclick="OpenCoursesReportModal" title="@LS.T("pcs.courseCompletionsReport")">
            <i class="ri-graduation-cap-line"></i><span class="pc-btn-label">@LS.T("pcs.completions")</span>
        </button>
        <button class="pc-report-btn" @onclick="OpenPendingCoursesModal" title="@LS.T("pcs.pendingCourses")">
            <i class="ri-hourglass-line"></i><span class="pc-btn-label">@LS.T("pcs.pendingCourses")</span>
        </button>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="filterHasSessions"
                   @bind="_filterHasSessions" style="cursor:pointer;" />
            <label class="form-check-label small fw-semibold" for="filterHasSessions" style="cursor:pointer;color:#6366f1;">
                <i class="ri-archive-line me-1" style="font-size:.8rem;"></i>@LS.T("pcs.auditedOnly")
            </label>
        </div>
        <button class="pc-report-btn" @onclick="PrintPcTable" title="@LS.T("common.printPDF")">
            <i class="ri-printer-line"></i>
        </button>
        <button class="pc-report-btn" @onclick="() => _showColumnGuide = true" title="@LS.T("pcs.columnGuide")">
            <i class="ri-question-line"></i>
        </button>
        <span class="badge bg-primary-transparent text-primary" style="font-size:.72rem;">
            @FilteredPcsEx.Count() PCs
        </span>
        <div class="ms-auto d-flex gap-2 align-items-center">
            <button class="pc-sms-btn @(!_selPcId.HasValue ? "pc-action-disabled" : "")"
                    @onclick="OpenSmsModal"
                    disabled="@(!_selPcId.HasValue)"
                    title="@(_selPcId.HasValue ? "Send SMS to this PC" : "Select a PC first")">
                <i class="ri-send-plane-fill"></i><span class="pc-btn-label">SMS</span>
            </button>
            <button class="pc-purchase-btn @(!_selPcId.HasValue ? "pc-action-disabled" : "")"
                    @onclick="OpenPurchaseModal"
                    disabled="@(!_selPcId.HasValue)"
                    title="@(_selPcId.HasValue ? "" : "Select a PC first")">
                <i class="ri-shopping-cart-line"></i><span class="pc-btn-label">@LS.T("pcs.newPurchase")</span>
            </button>
        </div>
    </div>

    @* ── Org pill bar ── *@
    <div class="pc-org-bar">
        <button class="pc-org-pill @(_filterOrgId == null ? "active" : "")"
                @onclick="() => SetOrgFilter(null)">
            All <span class="pc-org-count">@_allPcsEx.Count</span>
        </button>
        @foreach (var org in _organizations)
        {
            var oid = org.Id;
            <button class="pc-org-pill @(_filterOrgId == oid ? "active" : "") @(_dragPcId != null && _dragOverOrgId == oid ? "drag-over" : "")"
                    @onclick="() => SetOrgFilter(oid)"
                    ondragover="event.preventDefault();"
                    @ondragenter="() => OnDragEnterOrg(oid)"
                    @ondrop="() => OnDropOnOrg(oid)"
                    @ondrop:preventDefault>
                @org.Name <span class="pc-org-count">@_allPcsEx.Count(p => p.OrgId == oid)</span>
            </button>
        }
        <button class="pc-org-pill pc-org-pill-ungrouped @(_filterOrgId == 0 ? "active" : "") @(_dragPcId != null && _dragOverOrgId == 0 ? "drag-over" : "")"
                @onclick="() => SetOrgFilter(0)"
                ondragover="event.preventDefault();"
                @ondragenter="() => OnDragEnterOrg(0)"
                @ondrop="() => OnDropOnOrg(0)"
                @ondrop:preventDefault>
            <i class="ri-inbox-unarchive-line"></i> Ungrouped <span class="pc-org-count">@_allPcsEx.Count(p => p.OrgId == 0)</span>
        </button>
    </div>

    @* ── PC Table (full width) ── *@
    <div class="overflow-x-auto pc-table-wrapper @(_selPcId.HasValue ? "pc-table-drawer-open" : "")">
        @if (!FilteredPcsEx.Any())
        {
            <div class="text-muted small text-center mt-4">@LS.T("pcs.noPcsFound")</div>
        }
        else
        {
        <table id="pc-list-table" class="table table-sm table-hover mb-0 pc-list-table">
            <colgroup>
                <col class="pc-col-name" />
                <col style="width:72px;" />
                <col style="width:110px;" />
                <col style="width:85px;" />
                <col style="width:60px;" />
                <col style="width:65px;" />
                <col style="width:65px;" />
                <col style="width:55px;" />
                <col style="width:65px;" />
                <col />
                <col style="width:66px;" />
            </colgroup>
            <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                <tr>
                    <th class="small ps-2 pc-th-sort @SortClass("name")" @onclick='() => ToggleSort("name")'>@LS.T("pcs.pcName")</th>
                    <th class="small text-center pc-th-sort @SortClass("org")" @onclick='() => ToggleSort("org")'>Org</th>
                    <th class="small text-center">Wallet</th>
                    <th class="small text-center pc-th-sort @SortClass("balance")" @onclick='() => ToggleSort("balance")'>@LS.T("pcs.balance")</th>
                    <th class="small text-center pc-th-sort pc-th-wrap @SortClass("hoursLeft")" @onclick='() => ToggleSort("hoursLeft")'>@LS.T("pcs.hoursLeft")</th>
                    <th class="small text-center pc-th-sort pc-th-wrap @SortClass("totalTime")" @onclick='() => ToggleSort("totalTime")'>@LS.T("pcs.totalSessionTime")</th>
                    <th class="small text-center pc-th-sort @SortClass("sessions")" @onclick='() => ToggleSort("sessions")'>@LS.T("pcs.auditorSessions")</th>
                    <th class="small text-center pc-th-sort pc-th-wrap @SortClass("visits")" @onclick='() => ToggleSort("visits")'>@LS.T("pcs.totalVisits")</th>
                    <th class="small text-center pc-th-sort pc-th-wrap @SortClass("purchased")" @onclick='() => ToggleSort("purchased")'>@LS.T("pcs.hoursPurchased")</th>
                    <th class="small pc-th-sort @SortClass("auditor")" @onclick='() => ToggleSort("auditor")'>Auditor</th>
                    <th class="small text-center" style="width:66px;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pc in FilteredPcsEx)
                {
                    var wallets = _pcWalletBalances.GetValueOrDefault(pc.PcId) ?? new();
                    if (wallets.Count == 0)
                    {
                        // Safety: render a minimal row if a PC has no wallet yet
                        <tr>
                            <td class="small ps-2">@pc.FullName</td>
                            <td class="small text-center">
                                @if (!string.IsNullOrEmpty(pc.OrgName))
                                {
                                    <span class="badge rounded-pill"
                                          style="background:@OrgBadgeBg(pc.OrgName);color:@OrgBadgeFg(pc.OrgName);font-size:.7rem;">@pc.OrgName</span>
                                }
                            </td>
                            <td class="small text-muted text-center" colspan="7">
                                <i class="ri-wallet-3-line me-1"></i>No wallet
                            </td>
                            <td class="small"></td>
                            <td class="small text-center">
                                <button class="btn btn-sm btn-link p-0" title="Add wallet"
                                        @onclick="() => OpenAddWallet(pc.PcId, pc.FullName)"
                                        @onclick:stopPropagation="true">
                                    <i class="ri-add-circle-line" style="color:#0891b2;font-size:1.15rem;"></i>
                                </button>
                            </td>
                        </tr>
                        continue;
                    }

                    for (int i = 0; i < wallets.Count; i++)
                    {
                        var w = wallets[i];
                        var isFirst = (i == 0);
                        var rowSel  = _selPcId == pc.PcId;
                        <tr class="@(rowSel ? "table-primary" : "") @(_dragPcId == pc.PcId ? "pc-row-dragging" : "") @(isFirst ? "" : "pc-wallet-row-sub")"
                            style="cursor:pointer;"
                            draggable="@isFirst"
                            @ondragstart="() => OnDragStart(pc.PcId)"
                            @ondragend="OnDragEnd"
                            @oncontextmenu="(e) => OpenPcCtxMenu(e, pc.PcId, pc.OrgId)"
                            @oncontextmenu:preventDefault
                            @onclick="() => SelectPc(pc.PcId)">

                            @{
                                var hasMixed = _mixedRates.ContainsKey(pc.PcId);
                                _sessionMixedRates.TryGetValue(pc.PcId, out var srmEntries);
                                var hasSrm   = isFirst && srmEntries != null && srmEntries.Count > 0;
                                string nameTextStyle =
                                    _soloPcIds.Contains(pc.PcId) && isFirst ? "color:#ea580c;font-weight:600;"
                                    : hasMixed && hasSrm && isFirst ? "color:#9a3412;font-weight:700;"
                                    : hasMixed && isFirst ? "color:#b45309;font-weight:600;"
                                    : hasSrm && isFirst   ? "color:#c2410c;font-weight:700;"
                                    : "";
                            }
                            <td class="small ps-2 @(hasMixed ? "pc-mixed-rate" : "") @(hasSrm ? "pc-srm-cell" : "")"
                                tabindex="@(hasSrm ? "0" : null)"
                                style="@(isFirst ? "" : "border-top:none; color:#94a3b8;") @nameTextStyle">
                                @if (isFirst)
                                {
                                    <span class="text-truncate d-inline-block" style="max-width:100%;vertical-align:middle;">@pc.FullName@if (_soloPcIds.Contains(pc.PcId)) { <span style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:3px;background:#ea580c;color:#fff;font-size:.58rem;font-weight:700;margin-left:3px;vertical-align:middle;">S</span> }@if (!string.IsNullOrEmpty(pc.Nick)) { <span class="text-muted" style="font-size:.7rem;"> (@pc.Nick)</span> }@if (hasSrm) { <i class="ri-pulse-line ms-1" style="color:#ea580c;font-size:.72rem;vertical-align:middle;animation:srmPulse 2s ease-in-out infinite;" title="Multiple session rates in last 30 days"></i> }</span>

                                    @if (hasSrm)
                                    {
                                        var entries = srmEntries!;
                                        var colorMap = BuildSessionRateColorMap(entries);
                                        var distinctRateCount = colorMap.Count;
                                        var rateBreakdown = entries
                                            .GroupBy(e => $"{e.Currency}:{e.RateCentsPerHour}")
                                            .OrderBy(g => g.First().Currency).ThenBy(g => g.First().RateCentsPerHour)
                                            .Select(g => new { g.First().Currency, g.First().RateCentsPerHour, Count = g.Count() })
                                            .ToList();
                                        <div class="pc-srm-panel" @onclick:stopPropagation="true">
                                            <div class="pc-srm-glow"></div>
                                            <div class="pc-srm-header">
                                                <i class="ri-pulse-line me-1" style="color:#fb923c;"></i>
                                                <span>Session rates &mdash; last 30 days</span>
                                                <span class="pc-srm-count-badge">@distinctRateCount rates</span>
                                            </div>
                                            <div class="pc-srm-list">
                                                @{ var rowIdx = 0; }
                                                @foreach (var s in entries)
                                                {
                                                    var rowColor = SrmColor(colorMap, s);
                                                    var totalSec = s.LengthSec + s.AdminSec;
                                                    var sid = s.SessionId;
                                                    var delay = $"{rowIdx * 40}ms";
                                                    rowIdx++;
                                                    <div class="pc-srm-row" style="--row-color:@rowColor; animation-delay:@delay;"
                                                         @onclick="() => OpenSessionFromHover(sid)" @onclick:stopPropagation="true">
                                                        <div class="pc-srm-row-rail"></div>
                                                        <div class="pc-srm-row-main">
                                                            <div class="pc-srm-row-top">
                                                                <span class="pc-srm-row-date">@FormatDate(s.Date)</span>
                                                                <span class="pc-srm-row-dur">@FormatHM(totalSec)</span>
                                                            </div>
                                                            <div class="pc-srm-row-aud">@s.AuditorName</div>
                                                        </div>
                                                        <span class="pc-srm-rate-badge" style="background:@rowColor;">
                                                            @CurrSym(s.Currency)@FormatRatePerHour(s.RateCentsPerHour)<span class="pc-srm-per-hr">/hr</span>
                                                        </span>
                                                        <i class="ri-external-link-line pc-srm-row-arrow"></i>
                                                    </div>
                                                }
                                            </div>
                                            <div class="pc-srm-footer">
                                                @foreach (var b in rateBreakdown)
                                                {
                                                    var c = colorMap.TryGetValue($"{b.Currency}:{b.RateCentsPerHour}", out var cc) ? cc : "#64748b";
                                                    <span class="pc-srm-chip" style="background:@c;">
                                                        @CurrSym(b.Currency)@FormatRatePerHour(b.RateCentsPerHour)<span style="opacity:.85;">/hr</span> &times; @b.Count
                                                    </span>
                                                }
                                            </div>
                                            <div class="pc-srm-footer-hint">Click a row to open in Session Manager</div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span style="opacity:.35; font-size:.72rem; padding-left:8px;">↳</span>
                                }
                            </td>

                            @* Org (per-PC, first row only) *@
                            <td class="small text-center" style="@(isFirst ? "" : "border-top:none;")">
                                @if (isFirst && !string.IsNullOrEmpty(pc.OrgName))
                                {
                                    <span class="badge rounded-pill"
                                          style="background:@OrgBadgeBg(pc.OrgName);color:@OrgBadgeFg(pc.OrgName);font-size:.7rem;">@pc.OrgName</span>
                                }
                            </td>

                            @* Wallet badge *@
                            <td class="small text-center" style="@(isFirst ? "" : "border-top:none;")">
                                @{
                                    var walletTitle = w.IsActive ? w.Name : w.Name + " (inactive)";
                                }
                                <span class="pc-wallet-badge @(w.IsActive ? "" : "pc-wallet-inactive")"
                                      style="background:@WalletBgColor(w.Currency); color:@WalletFgColor(w.Currency);"
                                      title="@walletTitle">
                                    <span class="pc-wallet-sym">@WalletSym(w.Currency)</span>
                                    <span class="pc-wallet-name">@w.Name</span>
                                </span>
                            </td>

                            @* Balance (per wallet) *@
                            <td class="small text-center fw-semibold"
                                style="@(isFirst ? "" : "border-top:none;") color:@(w.RemainingCents >= 0 ? "#22c55e" : "#ef4444");">
                                @($"{WalletSym(w.Currency)}{(w.RemainingCents / 100.0):N0}")
                            </td>

                            @* Hours Left (per wallet) *@
                            <td class="small text-center fw-semibold"
                                style="@(isFirst ? "" : "border-top:none;") color:@(w.RemainingHours >= 0 ? "#4ade80" : "#f87171");">
                                @if (w.EffectiveRateCentsPerHour > 0)
                                {
                                    @HrsLabel((long)(w.RemainingHours * 3600))
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>

                            @* Total session time (per wallet) *@
                            <td class="small text-center text-muted" style="@(isFirst ? "" : "border-top:none;")">
                                @HrsLabel((long)(w.UsedSessionHours * 3600))
                            </td>

                            @* Auditor sessions — per-PC, shown only on first row *@
                            <td class="small text-center text-muted" style="@(isFirst ? "" : "border-top:none;")">
                                @(isFirst ? pc.AuditorSessions.ToString() : "")
                            </td>
                            @* Academy visits — per-PC, shown only on first row *@
                            <td class="small text-center text-muted" style="@(isFirst ? "" : "border-top:none;")">
                                @(isFirst ? pc.AcademyVisits.ToString() : "")
                            </td>
                            @* Hours Purchased (per wallet) *@
                            <td class="small text-center @(w.PurchasedHours < 0 ? "" : "text-muted")"
                                style="@(isFirst ? "" : "border-top:none;") @(w.PurchasedHours < 0 ? "color:#f87171;font-weight:600;" : "")">
                                @(w.PurchasedHours < 0 ? "-" : "")@FormatHoursMinutes(w.PurchasedHours)
                            </td>
                            @* Auditor — per-PC, shown only on first row *@
                            <td class="small text-muted text-truncate" style="@(isFirst ? "" : "border-top:none;") max-width:120px;">
                                @(isFirst ? (string.IsNullOrEmpty(pc.Auditor) ? "\u2014" : pc.Auditor) : "")
                            </td>
                            @* Actions *@
                            <td class="small text-center" style="@(isFirst ? "" : "border-top:none;") padding:0;">
                                <div class="d-inline-flex align-items-center gap-1">
                                    <button class="btn btn-link btn-sm p-0"
                                            title="Edit wallet"
                                            @onclick="() => OpenEditWallet(pc.PcId, pc.FullName, w.WalletId)"
                                            @onclick:stopPropagation="true">
                                        <i class="ri-edit-line" style="font-size:.95rem;color:#64748b;"></i>
                                    </button>
                                    <button class="btn btn-link btn-sm p-0"
                                            title="Transfer balance"
                                            @onclick="() => OpenTransferWallet(w.WalletId)"
                                            @onclick:stopPropagation="true">
                                        <i class="ri-exchange-funds-line" style="font-size:.95rem;color:#7c3aed;"></i>
                                    </button>
                                    @if (isFirst)
                                    {
                                        <button class="btn btn-link btn-sm p-0"
                                                title="Add wallet"
                                                @onclick="() => OpenAddWallet(pc.PcId, pc.FullName)"
                                                @onclick:stopPropagation="true">
                                            <i class="ri-add-circle-line" style="font-size:1rem;color:#0891b2;"></i>
                                        </button>
                                        <button class="btn btn-link btn-sm p-0 bal-detail-btn"
                                                title="@LS.T("pcs.balanceDetails")"
                                                @onclick="() => OpenBalanceModal(pc.PcId, pc.FullName)"
                                                @onclick:stopPropagation="true">
                                            <i class="ri-file-list-3-line" style="font-size:.95rem;color:#6366f1;"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        }
    </div>

    @* ── PC right-click context menu ── *@
    @if (_showPcCtxMenu)
    {
        <div class="pc-ctx-backdrop" @onclick="ClosePcCtxMenu"></div>
        <div class="pc-ctx-menu" style="top:@(_pcCtxY)px;left:@(_pcCtxX)px;">
            <div class="pc-ctx-title"><i class="ri-arrow-right-up-line"></i> Move to</div>
            @foreach (var org in _organizations)
            {
                var oid = org.Id;
                <button class="pc-ctx-item @(_ctxMenuPcOrgId == oid ? "pc-ctx-current" : "")"
                        @onclick="() => MovePcViaCtx(oid)">
                    @if (_ctxMenuPcOrgId == oid) { <i class="ri-check-line pc-ctx-check"></i> }
                    @org.Name
                </button>
            }
            <div class="pc-ctx-divider"></div>
            <button class="pc-ctx-item @(_ctxMenuPcOrgId == 0 ? "pc-ctx-current" : "")"
                    @onclick="() => MovePcViaCtx(0)">
                @if (_ctxMenuPcOrgId == 0) { <i class="ri-check-line pc-ctx-check"></i> }
                <i class="ri-inbox-unarchive-line"></i> Ungrouped
            </button>
        </div>
    }

    @* ── Detail panel (replaces table when a PC is selected) ── *@
    <div class="pc-drawer @(_selPcId.HasValue && _detail != null ? "pc-drawer-open" : "")">

    @* Handle bar + close *@
    <div class="pc-drawer-handle-bar">
        <div class="pc-drawer-handle"></div>
        <button class="pc-drawer-close" @onclick="CloseDrawer" title="Close">
            <i class="ri-close-line"></i>
        </button>
    </div>

    @if (_selPcId.HasValue && _detail != null)
    {
        @* Compact PC header *@
        <div class="pc-drawer-header">
            <div class="pc-header-avatar">
                @(_detail.FirstName.Length > 0 ? _detail.FirstName[0].ToString().ToUpper() : "?")
            </div>
            <div class="pc-header-info">
                <div class="pc-header-name-row">
                    <span class="pc-header-name">@_detail.FullName</span>
                    <button class="pc-edit-btn" @onclick="OpenEditModal">
                        <i class="ri-edit-line"></i>@LS.T("common.edit")
                    </button>
                    @if (!string.IsNullOrEmpty(_detail.Nick))
                    {
                        <span class="pc-header-tag pc-tag-id"><i class="ri-hashtag"></i>@_detail.Nick</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Org))
                    {
                        <span class="pc-header-tag pc-tag-org"><i class="ri-building-line"></i>@_detail.Org</span>
                    }
                    <button class="pc-solo-btn @(_isSolo ? "pc-solo-btn-active" : "")"
                            @onclick="AskToggleSolo"
                            title="@(_isSolo ? "Revoke solo auditor access" : "Grant solo auditor access")">
                        <i class="ri-user-star-line"></i>Solo Access
                    </button>
                    @if (_isAdmin)
                    {
                        <div class="pc-reset-budget-wrap">
                            <button class="pc-reset-budget-btn" @onclick="OpenResetBudgetModal">
                                <i class="ri-restart-line"></i>Reset Budget
                            </button>
                            <div class="pc-reset-tooltip">
                                <div class="pc-reset-tooltip-title"><i class="ri-information-line"></i> What does Reset Budget do?</div>
                                <p>Sets a <strong>cutoff date</strong> — all balance calculations will only include purchases and sessions <strong>from that date forward</strong>.</p>
                                <p>Previous financial history is completely ignored for balance, hours left, and cost calculations.</p>
                                <div class="pc-reset-tooltip-example">
                                    <strong>Example:</strong> A PC was paying in <span style="color:#ef4444;">EUR</span> and now switches to <span style="color:#22c55e;">ILS</span>. Reset the budget to start fresh with the new currency.
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="pc-header-meta" style="font-size:.72rem; color:#64748b; gap:10px;">
                    <span><i class="ri-hashtag" style="margin-right:2px;"></i>ID: @_detail.PcId</span>
                    @if (!string.IsNullOrEmpty(_detail.CreatedAt))
                    {
                        <span><i class="ri-calendar-event-line" style="margin-right:2px;"></i>Added: @FormatCreatedAt(_detail.CreatedAt)</span>
                    }
                    <span><i class="ri-user-add-line" style="margin-right:2px;"></i>By: @(string.IsNullOrEmpty(_detail.CreatedByName) ? "Import" : _detail.CreatedByName)</span>
                </div>
                <div class="pc-header-meta">
                    <span class="pc-auditor-label"><i class="ri-shield-user-line"></i>Auditor: <strong>@_pcAuditorLabel</strong></span>
                    @if (!string.IsNullOrEmpty(_detail.Phone))
                    {
                        <span><i class="ri-phone-line"></i>@_detail.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Email))
                    {
                        <span><i class="ri-mail-line"></i>@_detail.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.DateOfBirth))
                    {
                        <span><i class="ri-cake-line"></i>@_detail.DateOfBirth</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Gender))
                    {
                        <span>@_detail.Gender</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Source))
                    {
                        <span><i class="ri-user-received-line"></i>@_detail.Source</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_detail.Notes))
                {
                    <div class="pc-header-notes">@_detail.Notes</div>
                }
            </div>
        </div>

        @* ── Scrollable content ── *@
        <div class="pc-drawer-body">

            @* ── Courses ── *@
            <div class="card shadow-sm mb-3 pc-card-courses" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#6d28d9,#a855f7);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-book-open-line me-1"></i>@LS.T("pcs.courses")
                    </span>
                    @if (AllCoursesSorted.Count > 0)
                    {
                        <span class="badge bg-white text-primary">@AllCoursesSorted.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (AllCoursesSorted.Count > 0)
                    {
                      <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0" style="table-layout:auto;">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3 align-middle" style="white-space:nowrap;">@LS.T("pcs.course")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.dateStarted")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.dateFinished")</th>
                                    <th class="small text-center align-middle d-none d-md-table-cell" style="white-space:nowrap;">Instructor</th>
                                    <th class="small text-center align-middle d-none d-md-table-cell" style="white-space:nowrap;">CS</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">Amount</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("common.status")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.action")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.editPurchase")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sc in AllCoursesSorted)
                                {
                                    bool isActive = sc.DateFinished == null;
                                    bool isOT = CourseTypes.IsAdvanced(sc.CourseType);
                                    var hasPurchase = _coursePurchaseMap.TryGetValue(sc.CourseId, out var coursePurchaseId);
                                    var activeColor = isOT ? "#0d9488" : "#6d28d9";
                                    <tr style="@(!isActive ? "opacity:.65;" : "")"
                                        title="@(isOT && isActive ? $"Instructor: {sc.InstructorName ?? "None"} | CS: {sc.CsName ?? "None"}" : "")">
                                        <td class="small ps-3 fw-semibold align-middle" style="color:@(isActive ? activeColor : "#6b7280");">
                                            <span class="badge rounded-pill me-1" style="@(isOT ? "background:#ccfbf1;color:#0d9488;" : "background:#ede9fe;color:#7c3aed;")font-size:.6rem;vertical-align:middle;">@sc.CourseType</span>@sc.CourseName
                                            @if (isOT && isActive)
                                            {
                                                <div class="d-md-none" style="font-size:.7rem;color:#6b7280;margin-top:2px;">
                                                    <i class="ri-user-line"></i> @(sc.InstructorName ?? "None") · <i class="ri-shield-user-line"></i> @(sc.CsName ?? "None")
                                                </div>
                                            }
                                        </td>
                                        <td class="small text-center align-middle">
                                            @if (_editDateScId == sc.StudentCourseId)
                                            {
                                                <input type="text" class="form-control form-control-sm text-center" style="max-width:90px;font-size:.78rem;margin:0 auto;"
                                                       placeholder="dd/mm/yy"
                                                       value="@FormatDate(sc.DateStarted)"
                                                       @onchange="e => SaveDateStarted(sc.StudentCourseId, e.Value?.ToString())"
                                                       @onblur="() => _editDateScId = null" />
                                            }
                                            else
                                            {
                                                <span style="cursor:pointer;" title="Click to edit"
                                                      @onclick="() => _editDateScId = sc.StudentCourseId">@FormatDate(sc.DateStarted)</span>
                                            }
                                        </td>
                                        <td class="small text-center align-middle">@(sc.DateFinished != null ? FormatDate(sc.DateFinished) : "\u2014")</td>
                                        <td class="small text-center align-middle d-none d-md-table-cell">
                                            @if (isOT && isActive)
                                            {
                                                <select class="form-select form-select-sm py-0" style="font-size:.75rem;min-width:100px;"
                                                        value="@(sc.InstructorId?.ToString() ?? "0")"
                                                        @onchange="(e) => OnInstructorChanged(sc, e)">
                                                    <option value="0">None</option>
                                                    @foreach (var u in _instructorList)
                                                    {
                                                        <option value="@u.Id">@u.FullName</option>
                                                    }
                                                </select>
                                            }
                                            else if (isOT)
                                            {
                                                <span class="text-muted" style="font-size:.75rem;">@(sc.InstructorName ?? "—")</span>
                                            }
                                        </td>
                                        <td class="small text-center align-middle d-none d-md-table-cell">
                                            @if (isOT && isActive)
                                            {
                                                <select class="form-select form-select-sm py-0" style="font-size:.75rem;min-width:100px;"
                                                        value="@(sc.CsId?.ToString() ?? "0")"
                                                        @onchange="(e) => OnCsChanged(sc, e)">
                                                    <option value="0">None</option>
                                                    @foreach (var u in _csList)
                                                    {
                                                        <option value="@u.Id">@u.FullName</option>
                                                    }
                                                </select>
                                            }
                                            else if (isOT)
                                            {
                                                <span class="text-muted" style="font-size:.75rem;">@(sc.CsName ?? "—")</span>
                                            }
                                        </td>
                                        <td class="small text-center align-middle">@(_courseAmountMap.TryGetValue(sc.CourseId, out var cAmt) && cAmt > 0 ? $"{CurrSym(_courseCurrencyMap.GetValueOrDefault(sc.CourseId, "ILS"))}{(int)Math.Round(cAmt)}" : "\u2014")</td>
                                        <td class="small text-center align-middle">
                                            @if (_coursePurchaseStatusMap.TryGetValue(sc.CourseId, out var cStatus))
                                            {
                                                var (csCls, csLbl) = cStatus switch {
                                                    "Approved" => ("bg-success-transparent text-success", LS.T("sessions.approved")),
                                                    "Pending"  => ("bg-warning-transparent text-warning", LS.T("purchases.pending")),
                                                    _          => ("bg-secondary-transparent text-secondary", cStatus)
                                                };
                                                <span class="badge @csCls">@csLbl</span>
                                            }
                                            else
                                            {
                                                <span>\u2014</span>
                                            }
                                        </td>
                                        <td class="small text-center align-middle">
                                            @if (isActive)
                                            {
                                                <button class="btn btn-sm btn-outline-success py-0 px-2"
                                                        @onclick="() => AskFinishCourse(sc.StudentCourseId, sc.CourseName)">
                                                    <i class="ri-check-line me-1"></i>@LS.T("pcs.markDone")
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm border-0 py-0 px-2"
                                                        style="background:#d1fae5;color:#065f46;font-size:.7rem;"
                                                        @onclick="() => AskReopenCourse(sc.StudentCourseId, sc.CourseName)">
                                                    <i class="ri-check-double-line me-1"></i>@LS.T("pcs.done")
                                                </button>
                                            }
                                        </td>
                                        <td class="text-center align-middle">
                                            @if (hasPurchase)
                                            {
                                                <button class="btn btn-link btn-sm py-0 px-0"
                                                        title="@LS.T("pcs.editPurchase")"
                                                        @onclick="() => OpenEditPurchase(coursePurchaseId)">
                                                    <i class="ri-receipt-line" style="font-size:0.9rem;color:#6366f1;"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                      </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noCourses")</div>
                    }
                </div>
            </div>

            @* ── Auditing Purchases ── *@
            <div class="card shadow-sm pc-card-auditing" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#1e3a5f,#3b82f6);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditingPurchases")
                    </span>
                    @if (_auditingPurchases.Count > 0)
                    {
                        <span class="badge bg-white text-primary">@_auditingPurchases.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_auditingPurchases.Count > 0)
                    {
                      <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">@LS.T("pcs.date")</th>
                                    <th class="small text-center">@LS.T("pcs.hoursBought")</th>
                                    <th class="small text-center">Amount</th>
                                    <th class="small text-center">@LS.T("common.status")</th>
                                    <th class="small text-center" style="white-space:nowrap;">@LS.T("pcs.editPurchase")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ap in _auditingPurchases)
                                {
                                    <tr>
                                        <td class="small ps-3">@FormatDate(ap.Date)</td>
                                        <td class="small text-center fw-semibold">@(ap.HoursBought < 0 ? "-" : "")@FormatHoursMinutes(ap.HoursBought)</td>
                                        <td class="small text-center">@(ap.Amount != 0 ? $"{CurrSym(ap.Currency)}{(int)Math.Round(ap.Amount)}" : "\u2014")</td>
                                        <td class="small text-center">
                                            @{
                                                var (apCls, apLbl) = ap.Status switch {
                                                    "Approved" => ("bg-success-transparent text-success", LS.T("sessions.approved")),
                                                    "Pending"  => ("bg-warning-transparent text-warning", LS.T("purchases.pending")),
                                                    _          => ("bg-secondary-transparent text-secondary", ap.Status)
                                                };
                                            }
                                            <span class="badge @apCls">@apLbl</span>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-link btn-sm py-0 px-0"
                                                    title="@LS.T("pcs.editPurchase")"
                                                    @onclick="() => OpenEditPurchase(ap.PurchaseId)">
                                                <i class="ri-receipt-line" style="font-size:0.9rem;color:#2d6a9f;"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td class="small ps-3 fw-semibold">@LS.T("pcs.total")</td>
                                    @{ var apTotal = _auditingPurchases.Sum(a => a.HoursBought); }
                                    <td class="small text-center fw-semibold">@(apTotal < 0 ? "-" : "")@FormatHoursMinutes(apTotal)</td>
                                    <td class="small text-center fw-semibold">
                                        @{
                                            var auditGroups = _auditingPurchases.Where(a => a.Amount != 0)
                                                .GroupBy(a => a.Currency)
                                                .Select(g => $"{CurrSym(g.Key)}{(int)Math.Round(g.Sum(a => a.Amount))}")
                                                .ToList();
                                        }
                                        @(auditGroups.Count > 0 ? string.Join(" + ", auditGroups) : "\u2014")
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                      </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noAuditingPurchases")</div>
                    }
                </div>
            </div>

            @* ── PC Completions (sess_completions) ── *@
            @if (_pcCompletions.Count > 0)
            {
            <div class="card shadow-sm mt-3" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#14532d,#22c55e);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-trophy-line me-1"></i>@LS.T("pcs.completions")
                    </span>
                    <span class="badge bg-white text-success">@_pcCompletions.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">@LS.T("pcs.completeDate")</th>
                                    <th class="small text-center">@LS.T("pcs.grade")</th>
                                    <th class="small text-center">@LS.T("pcs.auditor")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in _pcCompletions)
                                {
                                    <tr>
                                        <td class="small ps-3">@(c.CompleteDate ?? "—")</td>
                                        <td class="small text-center fw-semibold" style="color:#15803d;">@(c.FinishedGrade ?? "—")</td>
                                        <td class="small text-center">@(c.AuditorName ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            }

            @* ── Change History ── *@
            <div class="card shadow-sm mt-3" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#475569,#64748b);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-history-line me-1"></i>Change History
                    </span>
                    @if (_pcHistory.Count > 0)
                    {
                        <span class="badge bg-white text-secondary">@_pcHistory.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_pcHistory.Count > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0" style="font-size:.78rem;">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-3">Action</th>
                                        <th>Details</th>
                                        <th>By</th>
                                        <th>Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var h in _pcHistory)
                                    {
                                        <tr>
                                            <td class="ps-3">
                                                <span class="badge @(h.Action == "Created" ? "bg-success" : "bg-info text-dark")" style="font-size:.7rem;">@h.Action</span>
                                            </td>
                                            <td style="color:#64748b; max-width:250px; white-space:normal;">@(h.Details ?? "")</td>
                                            <td class="fw-semibold">@h.ChangedBy</td>
                                            <td class="text-muted" style="white-space:nowrap;">@FormatCreatedAt(h.ChangedAt)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">No change history recorded</div>
                    }
                </div>
            </div>

        </div>
    }
    </div>

</div>

@* ── Course Completions Report Modal ── *@
@if (_showCoursesReportModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1050;">
        <div class="modal-dialog" style="max-width:95vw;width:95vw;margin:2vh auto;">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;border:none;max-height:94vh;overflow:hidden;display:flex;flex-direction:column;">

                @* ── Fixed: Title bar ── *@
                <div style="background:linear-gradient(135deg,#1e3a5f,#3b82f6);border-radius:14px 14px 0 0;padding:12px 18px;display:flex;align-items:center;gap:12px;flex-shrink:0;">
                    <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:#fff;flex-shrink:0;">
                        <i class="ri-bar-chart-grouped-line"></i>
                    </div>
                    <div style="flex:1;">
                        <div style="font-size:1.05rem;font-weight:700;color:#fff;line-height:1.2;">@LS.T("pcs.courseCompletionsReport")</div>
                        <div style="font-size:.73rem;color:rgba(255,255,255,.7);">@LS.T("pcs.courseCompletionsSub")</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showCoursesReportModal = false" style="opacity:.8;"></button>
                </div>

                @* ── Fixed: Date filter bar ── *@
                <div style="padding:10px 18px;background:#f8faff;border-bottom:1px solid #e0e7ff;flex-shrink:0;display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:.72rem;font-weight:600;color:#374151;margin-bottom:3px;">From</div>
                        <input type="date" class="form-control form-control-sm"
                               style="max-width:155px;color:#212529;background:#fff;border-color:#dee2e6;"
                               value="@_courseReportFrom.ToString("yyyy-MM-dd")"
                               @onchange="e => _courseReportFrom = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _courseReportFrom" />
                    </div>
                    <div>
                        <div style="font-size:.72rem;font-weight:600;color:#374151;margin-bottom:3px;">To</div>
                        <input type="date" class="form-control form-control-sm"
                               style="max-width:155px;color:#212529;background:#fff;border-color:#dee2e6;"
                               value="@_courseReportTo.ToString("yyyy-MM-dd")"
                               @onchange="e => _courseReportTo = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _courseReportTo" />
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="RunCoursesReport">
                        <i class="ri-search-line me-1"></i>Apply
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="GenerateCourseReportTestData"
                            style="font-size:.7rem;padding:3px 8px;opacity:.6;" title="Fill with random test data">
                        test
                    </button>
                    @if (_courseReportGroups != null)
                    {
                        <span style="font-size:.76rem;background:#dbeafe;color:#1e40af;border-radius:6px;padding:4px 12px;font-weight:700;">
                            @_courseReportGroups.Count PCs · @_courseReportGroups.Sum(g => g.Courses.Count) courses · @_courseReportGroups.Sum(g => g.Completions.Count) completions
                        </span>
                    }
                </div>

                @* ── Scrollable: Table area ── *@
                <div style="flex:1;min-height:0;overflow-y:auto;overflow-x:auto;background:#fff;border-radius:0 0 14px 14px;">
                    @if (_courseReportGroups == null)
                    {
                        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;color:#94a3b8;font-size:.9rem;">
                            <i class="ri-calendar-search-line" style="font-size:2.5rem;margin-bottom:8px;opacity:.4;"></i>
                            @LS.T("pcs.selectDateRange")
                        </div>
                    }
                    else if (_courseReportGroups.Count == 0)
                    {
                        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;color:#94a3b8;font-size:.9rem;">
                            <i class="ri-inbox-line" style="font-size:2.5rem;margin-bottom:8px;opacity:.4;"></i>
                            @LS.T("pcs.noCompletionsInPeriod")
                        </div>
                    }
                    else
                    {
                        <table style="width:100%;border-collapse:collapse;color:#212529;font-size:.84rem;">
                            <thead>
                                <tr style="position:sticky;top:0;z-index:2;">
                                    <th style="width:240px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;white-space:nowrap;">PC Name</th>
                                    <th style="padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;">Course / Grade</th>
                                    <th style="width:120px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;text-align:center;white-space:nowrap;">Started</th>
                                    <th style="width:120px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;text-align:center;white-space:nowrap;">Date</th>
                                    <th style="width:140px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;white-space:nowrap;">Auditor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var grp in _courseReportGroups)
                                {
                                    @* PC group header row *@
                                    <tr style="background:#eff6ff;">
                                        <td colspan="5" style="padding:8px 14px;font-size:.83rem;font-weight:700;color:#1e3a5f;border-top:2px solid #bfdbfe;border-bottom:1px solid #dbeafe;">
                                            <i class="ri-user-3-line me-1" style="opacity:.7;"></i>@grp.PcName
                                            @if (grp.Courses.Count > 0)
                                            {
                                                <span style="display:inline-block;margin-left:8px;background:#1e3a5f;color:#fff;border-radius:20px;padding:1px 9px;font-size:.67rem;font-weight:700;vertical-align:middle;">
                                                    @grp.Courses.Count courses
                                                </span>
                                            }
                                            @if (grp.Completions.Count > 0)
                                            {
                                                <span style="display:inline-block;margin-left:6px;background:#14532d;color:#fff;border-radius:20px;padding:1px 9px;font-size:.67rem;font-weight:700;vertical-align:middle;">
                                                    @grp.Completions.Count completions
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    @* Course rows *@
                                    @foreach (var c in grp.Courses)
                                    {
                                        <tr style="background:#fff;border-bottom:1px solid #f1f5f9;">
                                            <td style="padding:6px 14px 6px 30px;color:#94a3b8;font-size:.75rem;">
                                                <i class="ri-corner-down-right-line"></i>
                                            </td>
                                            <td style="padding:6px 14px;font-weight:600;color:#6d28d9;">
                                                <span style="font-size:.68rem;background:#ede9fe;color:#6d28d9;border-radius:4px;padding:1px 6px;margin-right:6px;font-weight:700;">Course</span>@c.CourseName
                                            </td>
                                            <td style="padding:6px 14px;text-align:center;color:#64748b;">@FormatDate(c.DateStarted)</td>
                                            <td style="padding:6px 14px;text-align:center;color:#059669;font-weight:700;">
                                                <i class="ri-check-line me-1" style="font-size:.8rem;"></i>@FormatDate(c.DateFinished!)
                                            </td>
                                            <td style="padding:6px 14px;color:#94a3b8;">—</td>
                                        </tr>
                                    }
                                    @* Completion rows *@
                                    @foreach (var sc in grp.Completions)
                                    {
                                        <tr style="background:#f0fdf4;border-bottom:1px solid #dcfce7;">
                                            <td style="padding:6px 14px 6px 30px;color:#94a3b8;font-size:.75rem;">
                                                <i class="ri-corner-down-right-line"></i>
                                            </td>
                                            <td style="padding:6px 14px;font-weight:600;color:#15803d;">
                                                <span style="font-size:.68rem;background:#dcfce7;color:#15803d;border-radius:4px;padding:1px 6px;margin-right:6px;font-weight:700;">Completion</span>@(sc.FinishedGrade ?? "—")
                                            </td>
                                            <td style="padding:6px 14px;text-align:center;color:#94a3b8;">—</td>
                                            <td style="padding:6px 14px;text-align:center;color:#15803d;font-weight:700;">
                                                <i class="ri-trophy-line me-1" style="font-size:.8rem;"></i>@(sc.CompleteDate ?? "—")
                                            </td>
                                            <td style="padding:6px 14px;color:#374151;font-size:.82rem;">@(sc.AuditorName ?? "—")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>


            </div>
        </div>
    </div>
}

@* ── Purchase Modal ── *@
@if (_showPurchaseModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1050;">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-header py-2 px-3 d-flex align-items-center" style="border-color:#dee2e6;">
                    <h5 class="modal-title fw-bold mb-0" style="color:#212529;">
                        <i class="ri-shopping-cart-line me-2"></i>@(_editingPurchaseId.HasValue ? LS.T("pcs.editPurchase") : LS.T("pcs.purchase"))
                    </h5>
                    @if (_editingPurchaseId.HasValue)
                    {
                        <span class="badge bg-warning text-dark ms-2" style="font-size:.7rem;">@LS.T("purchases.statusResetWarning")</span>
                    }
                    <div class="ms-auto d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="PrintPurchase">
                            <i class="ri-printer-line me-1"></i>@LS.T("common.print")
                        </button>
                        <button type="button" class="btn-close" @onclick="ClosePurchaseModal"></button>
                    </div>
                </div>
                <div class="modal-body p-3">
                    @* PC Name big *@
                    <div class="text-center mb-3">
                        <div style="font-size:1.6rem;font-weight:800;color:#1e3a5f;">@_detail.FullName</div>
                    </div>

                        @* ═══ Wallet picker (only when PC has 2+ wallets) ═══ *@
                        @if (_purchaseWalletOptions.Count > 1)
                        {
                            <div class="purchase-section mb-3" style="border-left:3px solid @WalletFgColor(_purchaseCurrency);">
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                    <i class="ri-wallet-3-fill" style="font-size:1.3rem; color:@WalletFgColor(_purchaseCurrency);"></i>
                                    <span class="purchase-section-title mb-0">Wallet</span>
                                    <select class="form-select form-select-sm ms-2" style="min-width:260px; font-size:.9rem; font-weight:600; flex:0 1 auto;"
                                            value="@_purchaseWalletId"
                                            @onchange="OnPurchaseWalletChanged">
                                        @foreach (var w in _purchaseWalletOptions)
                                        {
                                            <option value="@w.WalletId">@w.Name — @w.Currency @WalletSym(w.Currency)@(w.IsActive ? "" : " (inactive)")</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        }
                        else if (_purchaseWalletOptions.Count == 0)
                        {
                            <div class="alert alert-danger py-2 mb-3" style="font-size:.82rem;">
                                <i class="ri-error-warning-line me-1"></i>This PC has no wallet — add one first on the PCs page.
                            </div>
                        }

                        @* ═══ SECTION 1: Purchase Items ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #3b82f6;">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="purchase-section-title">
                                    <i class="ri-shopping-bag-line" style="color:#3b82f6;"></i>@LS.T("pcs.purchaseItems")
                                </span>
                                <button class="btn btn-sm btn-outline-primary py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPurchaseItem" disabled="@(!CanAddMoreItems())">
                                    <i class="ri-add-line me-1"></i>@LS.T("pcs.addItem")
                                </button>
                            </div>

                            @for (int idx = 0; idx < _purchaseItems.Count; idx++)
                            {
                                var i = idx;
                                var item = _purchaseItems[i];
                                var valid = IsItemValid(item);
                                <div class="card mb-2 purchase-item-card @(!valid ? "purchase-item-invalid" : "purchase-item-valid")">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <div class="d-flex gap-2 align-items-center">
                                                <span class="item-number-badge">@(i + 1)</span>
                                                @{ var capturedIdx = i; }
                                                <button class="btn btn-sm @(item.ItemType == "Auditing" ? "btn-primary" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Auditing")'>
                                                    <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditing")
                                                </button>
                                                <button class="btn btn-sm @(item.ItemType == "Course" ? "btn-info text-white" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Course")'>
                                                    <i class="ri-book-2-line me-1"></i>@LS.T("pcs.course")
                                                </button>
                                                <button class="btn btn-sm @(item.ItemType == "Book" ? "btn-success" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Book")'>
                                                    <i class="ri-book-open-line me-1"></i>Book
                                                </button>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!valid)
                                                {
                                                    <span class="item-incomplete-hint">
                                                        <i class="ri-error-warning-line"></i>
                                                        @(item.ItemType == "Auditing" ? LS.T("pcs.enterHours") : item.ItemType == "Course" ? LS.T("pcs.pickCourse") : "Pick a book")
                                                    </span>
                                                }
                                                @if (_purchaseItems.Count > 1)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemovePurchaseItem(i)">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                        <div class="row g-2 align-items-end">
                                            @if (item.ItemType == "Auditing")
                                            {
                                                var curItem = item;
                                                var hValid = int.TryParse(item.HoursH, out var _hv) && _hv > 0 || (int.TryParse(item.HoursM, out var _mv2) && _mv2 > 0);
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.hoursBought")</label>
                                                    <div class="d-flex align-items-center gap-1">
                                                        <input type="number" class="form-control form-control-sm aud-hm-input @(hValid ? "field-valid" : "field-invalid")"
                                                               value="@item.HoursH" min="0" style="width:70px;font-size:16px;" placeholder="H"
                                                               onfocus="this.select()"
                                                               @oninput="@(e => { curItem.HoursH = e.Value?.ToString() ?? ""; curItem.Sec = "00"; RecalcAuditing(curItem); })" />
                                                        <span class="fw-bold" style="font-size:1.1rem;color:#64748b;">:</span>
                                                        <input type="number" class="form-control form-control-sm aud-hm-input @(hValid ? "field-valid" : "field-invalid")"
                                                               value="@item.HoursM" min="0" max="59" style="width:60px;font-size:16px;" placeholder="M"
                                                               onfocus="this.select()"
                                                               @oninput="@(e => { var s = e.Value?.ToString() ?? ""; if (int.TryParse(s, out var mv) && mv > 59) s = "59"; curItem.HoursM = s; curItem.Sec = "00"; RecalcAuditing(curItem); })" />
                                                        <span class="aud-sec-dot">·</span>
                                                        <div class="aud-sec-wrap" title="Auto-set by Calc from @CurrSym(_purchaseCurrency) button — edit Hours/Minutes instead">
                                                            <input type="text" class="form-control form-control-sm aud-sec-input" tabindex="-1"
                                                                   value="@item.Sec" readonly />
                                                            <span class="aud-sec-tag"><i class="ri-lock-line"></i>sec</span>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.ratePerHour") (@CurrSym(_purchaseCurrency))</label>
                                                    <input type="number" class="form-control form-control-sm @(item.RatePerHour <= 0 ? "field-invalid" : "field-valid")"
                                                           value="@item.RatePerHour" min="0" style="max-width:90px;font-size:16px;" placeholder="0"
                                                           onfocus="this.select()"
                                                           @oninput="@(e => { curItem.RatePerHour = int.TryParse(e.Value?.ToString(), out var v) ? v : 0; RecalcAuditing(curItem); })" />
                                                </div>
                                                <div class="col-auto d-flex align-items-end position-relative" style="min-height:38px;">
                                                    @{
                                                        var totalPay = item.AmountPaid;
                                                        var totalColor = totalPay >= 0 ? "#16a34a" : "#dc2626";
                                                    }
                                                    <span class="fw-bold" style="font-size:.9rem;color:@totalColor;">
                                                        = @CurrSym(_purchaseCurrency)@FmtAmt(totalPay)
                                                    </span>
                                                    <button type="button" class="rev-calc-btn ms-2 @(item.RatePerHour <= 0 ? "rev-calc-disabled" : "")"
                                                            title="@(item.RatePerHour <= 0 ? "Set rate first" : "Enter total amount — we'll calc the time")"
                                                            @onclick="@(() => OpenReverseCalc(i))">
                                                        <span class="rev-calc-shimmer"></span>
                                                        <span class="rev-calc-icon"><i class="ri-exchange-dollar-line"></i></span>
                                                        <span class="rev-calc-label">Calc from @CurrSym(_purchaseCurrency)</span>
                                                        <span class="rev-calc-tooltip" aria-hidden="true">
                                                            <span class="rev-calc-demo">
                                                                <span class="rev-calc-demo-amt">@CurrSym(_purchaseCurrency)2000</span>
                                                                <span class="rev-calc-demo-arrow">→</span>
                                                                <span class="rev-calc-demo-time">10:00:00</span>
                                                            </span>
                                                            <span class="rev-calc-tooltip-sub">Type an amount, we set the time</span>
                                                        </span>
                                                    </button>
                                                    @if (_reverseCalcItemIdx == i)
                                                    {
                                                        <div class="rev-calc-popover" @onclick:stopPropagation="true">
                                                            <div class="rev-calc-pop-title">Total amount (@CurrSym(_purchaseCurrency))</div>
                                                            <input type="number" class="form-control form-control-sm rev-calc-input"
                                                                   value="@_reverseCalcAmount" placeholder="e.g. 2000" autofocus min="0"
                                                                   @onchange="OnReverseCalcAmountChange"
                                                                   @onkeydown="OnReverseCalcKeyDown" />
                                                            <div class="rev-calc-pop-actions">
                                                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="CloseReverseCalc">Cancel</button>
                                                                <button type="button" class="btn btn-sm btn-primary" @onclick="ApplyReverseCalc">Apply</button>
                                                            </div>
                                                            <div class="rev-calc-pop-hint">Time may round to the nearest second. The amount stays exactly as you entered.</div>
                                                        </div>
                                                    }
                                                </div>
                                                <div class="col-12 mt-1">
                                                    <label class="form-check form-check-inline aud-neg-check @(item.IsNegativeHours ? "aud-neg-active" : "")" style="cursor:pointer;">
                                                        <input class="form-check-input" type="checkbox" checked="@item.IsNegativeHours"
                                                               @onchange="@(e => { curItem.IsNegativeHours = (bool)(e.Value ?? false); RecalcAuditing(curItem); })" />
                                                        <span class="form-check-label small">@LS.T("pcs.negativeAdjust")</span>
                                                    </label>
                                                </div>
                                            }
                                            else if (item.ItemType == "Course")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.course")</label>
                                                    <select class="form-select form-select-sm @(item.CourseId <= 0 ? "field-invalid" : "field-valid")" style="max-width:200px;"
                                                            value="@item.CourseId"
                                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) { item.CourseId = v; AutoFillCoursePrice(item); } }">
                                                        <option value="0">— @LS.T("pcs.selectCourse") —</option>
                                                        @foreach (var c in _allCourses)
                                                        {
                                                            <option value="@c.CourseId">@c.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            else if (item.ItemType == "Book")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">Book</label>
                                                    <select class="form-select form-select-sm @(item.BookId <= 0 ? "field-invalid" : "field-valid")" style="max-width:200px;"
                                                            value="@item.BookId"
                                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) { item.BookId = v; AutoFillBookPrice(item); } }">
                                                        <option value="0">— select book —</option>
                                                        @foreach (var b in _allBooks)
                                                        {
                                                            <option value="@b.BookId">@b.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            @if (item.ItemType != "Auditing")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">Amount (@CurrSym(_purchaseCurrency))</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@((int)Math.Round(item.AmountPaid))" min="0" style="max-width:105px;" placeholder="0"
                                                           @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.AmountPaid = v; }" />
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                            @* Items summary *@
                            @if (_purchaseItems.Count > 0)
                            {
                                var totalItemAmount = _purchaseItems.Sum(x => x.AmountPaid);
                                var totalHours = _purchaseItems.Where(x => x.ItemType == "Auditing").Sum(x => x.HoursBought);
                                var courseCount = _purchaseItems.Count(x => x.ItemType == "Course" && x.CourseId > 0);
                                var bookCount = _purchaseItems.Count(x => x.ItemType == "Book" && x.BookId > 0);
                                <div class="items-summary">
                                    @if (totalHours != 0)
                                    {
                                        <span><i class="ri-timer-flash-line"></i> @(totalHours < 0 ? "-" : "")@FormatHoursMinutes(totalHours) @LS.T("pcs.hours")</span>
                                    }
                                    @if (courseCount > 0)
                                    {
                                        <span><i class="ri-book-2-line"></i> @courseCount @LS.T("pcs.courses")</span>
                                    }
                                    @if (bookCount > 0)
                                    {
                                        <span><i class="ri-book-open-line"></i> @bookCount Books</span>
                                    }
                                    <span class="ms-auto fw-semibold">@LS.T("pcs.total"): @CurrSym(_purchaseCurrency)@FmtAmt(totalItemAmount)</span>
                                </div>
                            }
                        </div>

                        @* ═══ SECTION 2: Payment Methods ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #10b981;">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="purchase-section-title">
                                    <i class="ri-bank-card-line" style="color:#10b981;"></i>@LS.T("purchases.paymentMethods")
                                </span>
                                <button class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPaymentMethod" disabled="@(!CanAddMorePayments())">
                                    <i class="ri-add-line me-1"></i>@LS.T("purchases.addPaymentMethod")
                                </button>
                            </div>
                            @for (int pmIdx = 0; pmIdx < _purchasePaymentMethods.Count; pmIdx++)
                            {
                                var pi2 = pmIdx;
                                var pm = _purchasePaymentMethods[pi2];
                                <div class="d-flex gap-2 align-items-end mb-2 p-2 border rounded flex-wrap" style="background:#f8fafc;border-radius:10px !important;">
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.methodType")</label>
                                        <select class="form-select form-select-sm" style="max-width:140px;font-size:.8rem;"
                                                value="@pm.MethodType"
                                                @onchange='e => { pm.MethodType = e.Value?.ToString() ?? "Cash"; if (pm.MethodType != "CreditCard") pm.Installments = 1; if (pm.MethodType == "ToBePaid") pm.PaymentDate = null; }'>
                                            <option value="Cash">@LS.T("purchases.cash")</option>
                                            <option value="CreditCard">@LS.T("purchases.creditCard")</option>
                                            <option value="Check">@LS.T("purchases.check")</option>
                                            <option value="BankTransfer">@LS.T("purchases.bankTransfer")</option>
                                            <option value="Credit">@LS.T("purchases.credit")</option>
                                            <option value="ToBePaid">@LS.T("purchases.toBePaid")</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">Amount (@CurrSym(_purchaseCurrency))</label>
                                        <input type="number" class="form-control form-control-sm @(pm.Amount == 0 ? "field-invalid" : "field-valid")"
                                               style="max-width:100px;font-size:.8rem;"
                                               value="@pm.Amount" placeholder="0"
                                               onfocus="this.select()"
                                               @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) pm.Amount = v; }" />
                                    </div>
                                    @if (pm.MethodType != "ToBePaid")
                                    {
                                        <div>
                                            <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.paymentDate")</label>
                                            <input type="text" class="form-control form-control-sm" style="max-width:140px;font-size:.8rem;"
                                                   placeholder="dd/mm/yy"
                                                   value="@(pm.PaymentDate?.ToString("dd/MM/yy") ?? "")"
                                                   @onchange="e => pm.PaymentDate = ParseDateInput(e.Value?.ToString())" />
                                        </div>
                                    }
                                    @if (pm.MethodType == "CreditCard")
                                    {
                                        <div>
                                            <label class="form-label small mb-0" style="font-size:.72rem;">Payments</label>
                                            <input type="number" class="form-control form-control-sm" style="max-width:70px;font-size:.8rem;"
                                                   min="1" max="24" value="@pm.Installments"
                                                   @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v) && v >= 1 && v <= 24) pm.Installments = v; }" />
                                        </div>
                                    }
                                    @if (_purchasePaymentMethods.Count > 1)
                                    {
                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => _purchasePaymentMethods.RemoveAt(pi2)">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                </div>
                            }
                            @{
                                var itemsTotalRaw = _purchaseItems.Sum(i => i.AmountPaid);
                                var itemsTotal = (int)Math.Round(itemsTotalRaw);
                                var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
                                var pmBalance = itemsTotal - pmTotal;
                            }
                            @if (pmTotal != 0 || itemsTotal != 0)
                            {
                                <div class="payment-summary mt-2">
                                    <span>@LS.T("purchases.paid"): @CurrSym(_purchaseCurrency)@pmTotal / @CurrSym(_purchaseCurrency)@FmtAmt(itemsTotalRaw)</span>
                                    @if (pmBalance != 0)
                                    {
                                        var underpaid = itemsTotal == 0 ? pmBalance > 0 : Math.Sign(pmBalance) == Math.Sign(itemsTotal);
                                        <span class="@(underpaid ? "text-danger" : "text-warning") fw-semibold">
                                            <i class="ri-error-warning-line"></i>
                                            @(underpaid ? LS.T("purchases.underpaid") : LS.T("purchases.overpaid")): @CurrSym(_purchaseCurrency)@Math.Abs(pmBalance)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-semibold">
                                            <i class="ri-check-line"></i> @LS.T("purchases.balanced")
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        @* ═══ SECTION 3: Details ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #8b5cf6;">
                            <span class="purchase-section-title mb-2 d-block">
                                <i class="ri-file-info-line" style="color:#8b5cf6;"></i>@LS.T("pcs.purchaseDetails")
                            </span>

                            @* Date + Registrar + Referral in one row *@
                            <div class="d-flex gap-3 flex-wrap mb-3">
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.date")</label>
                                    <input type="text" class="form-control form-control-sm" style="max-width:150px;"
                                           placeholder="dd/mm/yy"
                                           value="@(_purchaseDate.ToString("dd/MM/yy"))"
                                           @onchange="e => { var d = ParseDateInput(e.Value?.ToString()); if (d.HasValue) _purchaseDate = d.Value; }" />
                                </div>
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("courses.registrar")</label>
                                    <select class="form-select form-select-sm" style="max-width:170px;"
                                            value="@_purchaseRegistrarId"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _purchaseRegistrarId = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var s in _staff)
                                        {
                                            <option value="@s.PersonId">@s.FullName</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("courses.referral")</label>
                                    <select class="form-select form-select-sm" style="max-width:170px;"
                                            value="@_purchaseReferralId"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _purchaseReferralId = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        <option value="-1">— @LS.T("common.other") —</option>
                                        @foreach (var p in _allPersons)
                                        {
                                            <option value="@p.PersonId">@p.FullName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            @* Notes *@
                            <div class="mb-3">
                                <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.notes")</label>
                                <textarea class="form-control form-control-sm" rows="2" @bind="_purchaseNotes"
                                          placeholder="@LS.T("members.optional")" style="border-radius:8px;"></textarea>
                            </div>

                            @* Signature *@
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <label class="form-label small mb-0" style="color:#212529;font-size:.72rem;">
                                        @LS.T("pcs.signature")
                                        @if (!_skipSignature) { <span style="color:#dc3545;font-size:1rem;">*</span> }
                                        <input class="form-check-input ms-2" type="checkbox" id="skipSig"
                                               style="vertical-align:middle;"
                                               checked="@_skipSignature" @onchange="ToggleSkipSignature" />
                                        <span style="font-size:0.72rem;color:#6b7280;vertical-align:middle;margin-left:3px;">@LS.T("pcs.noSignature")</span>
                                    </label>
                                    @if (!_skipSignature)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:0.7rem;"
                                                @onclick="ClearSignature">
                                            @LS.T("pcs.clearSignature")
                                        </button>
                                    }
                                </div>
                                @if (!_skipSignature)
                                {
                                    <div style="border:2px solid #dee2e6;border-radius:8px;background:#fafafa;position:relative;">
                                        <canvas id="signatureCanvas" style="width:100%;height:120px;cursor:crosshair;display:block;"></canvas>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-3 small" style="border:2px dashed #dee2e6;border-radius:8px;background:#f9fafb;color:#9ca3af;">
                                        <i class="ri-edit-line me-1"></i>@LS.T("pcs.noSignatureNote")
                                    </div>
                                }
                            </div>
                        </div>
                </div>
                <div class="modal-footer py-2 px-3 flex-wrap">
                    @if (!string.IsNullOrEmpty(_purchaseError))
                    {
                        <div class="alert alert-danger py-1 px-2 mb-0 small flex-grow-1">@_purchaseError</div>
                    }
                    @if (!_skipSignature && !_hasSigned)
                    {
                        <div class="signature-reminder flex-grow-1">
                            <i class="ri-pen-nib-line"></i> @LS.T("pcs.signatureReminder")
                        </div>
                    }
                    <button class="btn btn-danger btn-sm me-auto delpurch-trigger"
                            @onclick="OpenDeletePurchaseConfirm"
                            disabled="@(!_editingPurchaseId.HasValue)"
                            title="@(_editingPurchaseId.HasValue ? LS.T("pcs.delete.title") : LS.T("pcs.delete.newDisabled"))">
                        <i class="ri-delete-bin-2-line me-1"></i>@LS.T("common.delete")
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="ClosePurchaseModal">@LS.T("common.cancel")</button>
                    @{
                        var canSave = HasValidPurchaseItems() && IsPaymentBalanced();
                        var saveReasons = canSave ? new List<string>() : GetSaveBlockReasons();
                    }
                    <div class="save-btn-wrap">
                        <button class="btn btn-primary btn-sm @(!canSave ? "save-btn-disabled" : "")" @onclick="SavePurchase"
                                disabled="@(!canSave)">
                            <i class="ri-save-line me-1"></i>@LS.T("common.save")
                        </button>
                        @if (!canSave && saveReasons.Any())
                        {
                            <div class="save-block-tooltip">
                                <div class="save-block-header">
                                    <i class="ri-lock-line"></i> Cannot save yet
                                </div>
                                @foreach (var reason in saveReasons)
                                {
                                    <div class="save-block-reason">
                                        <i class="ri-close-circle-line"></i>
                                        <span>@reason</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Delete Purchase Confirmation (hard delete) ────────────────────────── *@
@if (_delPurchStep > 0)
{
    <style>
        @@keyframes delpurch-pulse   { 0%,100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.18); opacity: .78; } }
        @@keyframes delpurch-shake   { 0%,100% { transform: translateX(0); } 20% { transform: translateX(-6px); } 40% { transform: translateX(6px); } 60% { transform: translateX(-4px); } 80% { transform: translateX(4px); } }
        @@keyframes delpurch-done    { from { opacity: 0; transform: scale(.6) rotate(-8deg); } 60% { opacity: 1; transform: scale(1.12) rotate(3deg); } to { opacity: 1; transform: scale(1) rotate(0); } }
        @@keyframes delpurch-ring    { from { transform: scale(.4); opacity: .85; } to { transform: scale(2.6); opacity: 0; } }
        @@keyframes delpurch-flash   { 0% { background: rgba(239,68,68,0); } 30% { background: rgba(239,68,68,.55); } 100% { background: rgba(239,68,68,0); } }
        @@keyframes delpurch-fall    { 0% { transform: translateY(-20px) rotate(0); opacity: 0; } 15% { opacity: 1; } 100% { transform: translateY(320px) rotate(540deg); opacity: 0; } }
        .delpurch-pulse     { animation: delpurch-pulse 1.1s ease-in-out infinite; display: inline-block; }
        .delpurch-shake     { animation: delpurch-shake .6s ease-in-out both; }
        .delpurch-done-card { animation: delpurch-done .65s cubic-bezier(.34,1.56,.64,1) both; position: relative; overflow: hidden; }
        .delpurch-flash-ov  { position: absolute; inset: 0; pointer-events: none; animation: delpurch-flash .9s ease-out .05s both; border-radius: inherit; }
        .delpurch-ring      { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; pointer-events: none; }
        .delpurch-ring::before, .delpurch-ring::after {
            content: ""; position: absolute; width: 160px; height: 160px; border-radius: 50%;
            border: 3px solid #22c55e; animation: delpurch-ring 1.2s ease-out both;
        }
        .delpurch-ring::after { animation-delay: .25s; border-color: #4ade80; }
        .delpurch-shard      {
            position: absolute; top: 0; width: 7px; height: 14px; border-radius: 2px;
            animation: delpurch-fall 1.4s cubic-bezier(.55,.05,.7,.35) forwards;
        }
        .delpurch-fk-table   { width: 100%; border-collapse: collapse; font-size: .72rem; }
        .delpurch-fk-table th { background: #7f1d1d; color: #fecaca; text-align: left; padding: 4px 8px; font-weight: 600; white-space: nowrap; }
        .delpurch-fk-table td { background: #2a0a0a; color: #fecaca; padding: 4px 8px; border-top: 1px solid #450a0a; max-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .delpurch-fk-wrap    { overflow-x: auto; max-height: 180px; overflow-y: auto; border: 1px solid #7f1d1d; border-radius: 6px; }
        .delpurch-empty      { font-size: .75rem; color: #991b1b; font-style: italic; padding: 4px 8px; }
        @@media (max-width: 768px) {
            .delpurch-card  { padding: 24px 18px !important; max-width: 94vw !important; }
            .delpurch-title { font-size: 1.15rem !important; }
            .delpurch-fk-table th, .delpurch-fk-table td { font-size: .68rem; padding: 3px 6px; }
        }
    </style>

    <div style="position:fixed;inset:0;z-index:10200;background:rgba(0,0,0,.82);display:flex;align-items:center;justify-content:center;padding:16px;overflow-y:auto;">

        @* ── Step 1: preview + "are you sure?" ── *@
        @if (_delPurchStep == 1)
        {
            <div class="delpurch-card" style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:32px 36px;max-width:760px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.75);color:#fecaca;">
                <div class="text-center mb-3">
                    <div class="delpurch-pulse" style="font-size:3.6rem;color:#ef4444;line-height:1;">
                        <i class="ri-error-warning-fill"></i>
                    </div>
                    <div class="delpurch-title" style="font-size:1.35rem;font-weight:800;color:#fca5a5;margin-top:10px;">
                        @LS.T("pcs.delete.title") #@(_delPurchInfo?.PrimaryPurchaseId)
                    </div>
                    <div style="font-size:.85rem;color:#ef4444;margin-top:6px;">
                        @LS.T("pcs.delete.warning")
                    </div>
                </div>

                @if (_delPurchInfo == null)
                {
                    <div class="d-flex align-items-center justify-content-center gap-2 py-3">
                        <span class="spinner-border spinner-border-sm" style="color:#ef4444;"></span>
                        <span style="font-size:.85rem;">@LS.T("pcs.delete.loading")</span>
                    </div>
                }
                else
                {
                    <div style="background:#2a0a0a;border-radius:8px;padding:14px 16px;margin-bottom:16px;">
                        <div style="font-size:.8rem;font-weight:700;color:#fca5a5;margin-bottom:8px;">
                            <i class="ri-list-check-2 me-1"></i>@LS.T("pcs.delete.affectedRows") (@_delPurchInfo.TotalRowCount)
                        </div>

                        @* Purchase rows (primary + paired transfer) *@
                        <div class="mb-2">
                            <div style="font-size:.75rem;font-weight:600;color:#fca5a5;margin-bottom:4px;">
                                <i class="ri-shopping-cart-line me-1"></i>fin_purchases
                                <span style="font-weight:400;color:#f87171;"> — @_delPurchInfo.Purchases.Count @LS.T("pcs.delete.rows")</span>
                            </div>
                            <div class="delpurch-fk-wrap">
                                <table class="delpurch-fk-table">
                                    @if (_delPurchInfo.Purchases.Count > 0)
                                    {
                                        <thead><tr>@foreach (var c in _delPurchInfo.Purchases[0].Cols) { <th>@c</th> }</tr></thead>
                                        <tbody>
                                            @foreach (var p in _delPurchInfo.Purchases)
                                            {
                                                <tr>@foreach (var v in p.Values) { var disp = v.Length > 60 ? v[..60] + "…" : v; <td title="@v">@disp</td> }</tr>
                                            }
                                        </tbody>
                                    }
                                </table>
                            </div>
                        </div>

                        @* FK tables *@
                        @foreach (var fk in _delPurchInfo.FkTables)
                        {
                            <div class="mb-2">
                                <div style="font-size:.75rem;font-weight:600;color:#fca5a5;margin-bottom:4px;">
                                    <i class="ri-table-line me-1"></i>@fk.Table
                                    <span style="font-weight:400;color:#f87171;"> — @fk.Rows.Count @LS.T("pcs.delete.rows")</span>
                                </div>
                                @if (fk.Rows.Count == 0)
                                {
                                    <div class="delpurch-empty">@LS.T("pcs.delete.noRows")</div>
                                }
                                else
                                {
                                    <div class="delpurch-fk-wrap">
                                        <table class="delpurch-fk-table">
                                            <thead><tr>@foreach (var c in fk.Cols) { <th>@c</th> }</tr></thead>
                                            <tbody>
                                                @foreach (var row in fk.Rows)
                                                {
                                                    <tr>@foreach (var v in row) { var disp = v.Length > 60 ? v[..60] + "…" : v; <td title="@v">@disp</td> }</tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        }

                        @* Enrollments (derived) *@
                        <div class="mb-0">
                            <div style="font-size:.75rem;font-weight:600;color:#fca5a5;margin-bottom:4px;">
                                <i class="ri-graduation-cap-line me-1"></i>@_delPurchInfo.Enrollments.Table
                                <span style="font-weight:400;color:#f87171;"> — @_delPurchInfo.Enrollments.Rows.Count @LS.T("pcs.delete.rows")</span>
                            </div>
                            @if (_delPurchInfo.Enrollments.Rows.Count == 0)
                            {
                                <div class="delpurch-empty">@LS.T("pcs.delete.noRows")</div>
                            }
                            else
                            {
                                <div class="delpurch-fk-wrap">
                                    <table class="delpurch-fk-table">
                                        <thead><tr>@foreach (var c in _delPurchInfo.Enrollments.Cols) { <th>@c</th> }</tr></thead>
                                        <tbody>
                                            @foreach (var row in _delPurchInfo.Enrollments.Rows)
                                            {
                                                <tr>@foreach (var v in row) { var disp = v.Length > 60 ? v[..60] + "…" : v; <td title="@v">@disp</td> }</tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                }

                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <button class="btn btn-secondary btn-sm px-4" @onclick="CancelDeletePurchase">@LS.T("common.cancel")</button>
                    <button class="btn btn-danger btn-sm px-4" disabled="@(_delPurchInfo == null)" @onclick="() => _delPurchStep = 2">
                        @LS.T("pcs.delete.yesContinue") <i class="ri-arrow-right-line ms-1"></i>
                    </button>
                </div>
            </div>
        }

        @* ── Step 2: type "delete" ── *@
        @if (_delPurchStep == 2)
        {
            <div class="delpurch-card" style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:36px 40px;max-width:460px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.75);text-align:center;color:#fecaca;">
                <div style="font-size:3rem;color:#ef4444;margin-bottom:14px;">
                    <i class="ri-skull-2-line"></i>
                </div>
                <div style="font-size:1.1rem;font-weight:800;color:#fca5a5;margin-bottom:16px;">
                    @LS.T("pcs.delete.finalConfirm")
                </div>
                <div style="font-size:.85rem;color:#f87171;margin-bottom:18px;">
                    @LS.T("pcs.delete.typeHint") <code style="background:#2a0a0a;padding:2px 8px;border-radius:4px;color:#fca5a5;font-weight:700;">delete</code>
                </div>
                <input type="text"
                       class="form-control text-center mb-3 @(_delPurchInput.Length > 0 && _delPurchInput != "delete" ? "delpurch-shake" : "")"
                       style="background:#2a0a0a;border:2px solid @(_delPurchInput.Length > 0 && _delPurchInput != "delete" ? "#ef4444" : "#7f1d1d");color:#fca5a5;font-size:1.05rem;font-weight:700;letter-spacing:.12em;min-height:44px;"
                       placeholder="@LS.T("pcs.delete.inputPlaceholder")"
                       @bind="_delPurchInput"
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(_delPurchError))
                {
                    <div class="alert alert-danger py-1 px-2 mb-2" style="font-size:.78rem;">@_delPurchError</div>
                }
                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <button class="btn btn-secondary btn-sm px-4" disabled="@_delPurchBusy" @onclick="() => _delPurchStep = 1">@LS.T("common.back")</button>
                    <button class="btn btn-danger btn-sm px-4"
                            disabled="@(_delPurchInput != "delete" || _delPurchBusy)"
                            @onclick="ExecuteHardDeletePurchase">
                        <i class="ri-delete-bin-2-line me-1"></i>@LS.T("pcs.delete.executeBtn")
                    </button>
                </div>
            </div>
        }

        @* ── Step 3: deleting ── *@
        @if (_delPurchStep == 3)
        {
            <div class="delpurch-card" style="background:#1a0505;border:2px solid #7f1d1d;border-radius:16px;padding:48px 40px;max-width:400px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.75);text-align:center;color:#fecaca;">
                <div class="spinner-border" style="width:3.2rem;height:3.2rem;border-width:4px;color:#ef4444;margin-bottom:20px;" role="status"></div>
                <div style="font-size:1rem;font-weight:700;color:#fca5a5;">@LS.T("pcs.delete.deleting")</div>
                <div style="font-size:.78rem;color:#991b1b;margin-top:6px;">@LS.T("pcs.delete.pleaseWait")</div>
            </div>
        }

        @* ── Step 4: SUCCESS — amazing animation ── *@
        @if (_delPurchStep == 4)
        {
            <div class="delpurch-card delpurch-done-card" style="background:linear-gradient(135deg,#031a0a 0%,#052e16 100%);border:2px solid #14532d;border-radius:16px;padding:52px 44px;max-width:460px;width:100%;box-shadow:0 30px 80px rgba(0,0,0,.75);text-align:center;color:#bbf7d0;">
                <div class="delpurch-flash-ov"></div>
                <div class="delpurch-ring"></div>
                @* confetti shards *@
                <div class="delpurch-shard" style="left:12%;background:#22c55e;animation-delay:.05s;"></div>
                <div class="delpurch-shard" style="left:26%;background:#4ade80;animation-delay:.18s;"></div>
                <div class="delpurch-shard" style="left:42%;background:#86efac;animation-delay:.3s;"></div>
                <div class="delpurch-shard" style="left:58%;background:#22c55e;animation-delay:.12s;"></div>
                <div class="delpurch-shard" style="left:74%;background:#4ade80;animation-delay:.24s;"></div>
                <div class="delpurch-shard" style="left:88%;background:#86efac;animation-delay:.08s;"></div>

                <div style="position:relative;font-size:5rem;color:#22c55e;margin-bottom:18px;line-height:1;">
                    <i class="ri-checkbox-circle-fill"></i>
                </div>
                <div style="position:relative;font-size:1.35rem;font-weight:800;color:#86efac;margin-bottom:10px;letter-spacing:.02em;">
                    @LS.T("pcs.delete.successTitle")
                </div>
                <div style="position:relative;font-size:.9rem;color:#4ade80;margin-bottom:6px;">
                    @_delPurchRowsDeleted @LS.T("pcs.delete.rowsDeleted")
                </div>
                <div style="position:relative;font-size:.72rem;color:#166534;margin-top:12px;">@LS.T("pcs.delete.closing")</div>
            </div>
        }
    </div>
}

@* ── Purchase Success Toast ── *@
@* ── Currency mismatch warning popup ── *@
@if (_showCurrencyWarning)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.6);z-index:10100;">
        <div class="modal-dialog modal-dialog-centered modal-sm" @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#1e293b;color:#e2e8f0;border:2px solid #f59e0b;">
                <div class="modal-header py-2" style="background:#92400e;border-bottom:none;">
                    <h5 class="modal-title text-white d-flex align-items-center gap-2" style="font-size:.95rem;">
                        <i class="ri-error-warning-fill" style="font-size:1.3rem;color:#fbbf24;"></i> Currency Mismatch
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CancelCurrencyChange"></button>
                </div>
                <div class="modal-body" style="font-size:.85rem;line-height:1.6;">
                    <p>This PC already has auditing purchases in <strong style="color:#fbbf24;">@_currencyWarningExisting</strong>.</p>
                    <p>Switching to <strong style="color:#fbbf24;">@_currencyWarningNew</strong> will cause <strong>mixed currencies</strong> which means:</p>
                    <ul style="padding-left:18px;margin:8px 0;">
                        <li>Balance calculation will be <strong>inaccurate</strong> (amounts in different currencies will be mixed)</li>
                        <li>Hours remaining cannot be calculated correctly</li>
                        <li>Balance and hours columns will show a <span style="color:#f59e0b;">⚠ warning</span> instead of values</li>
                    </ul>
                    <p class="mb-0" style="color:#94a3b8;">To fix this later, edit the purchase and change it back to a single currency.</p>
                </div>
                <div class="modal-footer py-2" style="border-top:1px solid #334155;">
                    <button class="btn btn-sm btn-outline-light" @onclick="CancelCurrencyChange">Cancel</button>
                    <button class="btn btn-sm btn-warning fw-semibold" @onclick="ConfirmCurrencyChange">
                        <i class="ri-error-warning-line me-1"></i>Change to @_currencyWarningNew anyway
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showPurchaseSuccess)
{
    <div class="pcs-success-overlay">
        <div class="pcs-success-card">
            <i class="ri-checkbox-circle-fill pcs-success-icon"></i>
            @((MarkupString)_purchaseSuccessHtml)
        </div>
    </div>
}

@* ── Delete Purchase Confirmation ── *@
@if (_confirmDeletePurchaseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-error-warning-line text-danger" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmDeleteTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmDeleteMsg")</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmDeletePurchaseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-danger px-3" @onclick="ConfirmDeletePurchase">
                            <i class="ri-delete-bin-line me-1"></i>@LS.T("common.delete")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Solo Access Confirm Modal ── *@
@if (_showSoloConfirm && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-body p-4 text-center">
                    @if (_soloConfirmEnable)
                    {
                        <div class="pc-solo-confirm-icon" style="background:linear-gradient(135deg,#ea580c,#f97316);">
                            <i class="ri-user-star-line"></i>
                        </div>
                        <div class="fw-bold mt-3 mb-1" style="font-size:1rem;">Grant Solo Access?</div>
                        <div class="small mb-1" style="color:#374151;">
                            A login account will be created for <strong>@_detail.FullName</strong>.
                        </div>
                        <div class="small mb-3" style="color:#6b7280;">
                            Username: <code>@_soloConfirmUsername</code><br/>
                            Password: <code>@((_detail.FirstName.Trim().Length > 0 ? char.ToUpper(_detail.FirstName.Trim()[0]) + _detail.FirstName.Trim()[1..].ToLower() : "User") + "1992")</code>
                        </div>
                    }
                    else
                    {
                        <div class="pc-solo-confirm-icon" style="background:linear-gradient(135deg,#dc2626,#ef4444);">
                            <i class="ri-user-unfollow-line"></i>
                        </div>
                        <div class="fw-bold mt-3 mb-1" style="font-size:1rem;">Revoke Solo Access?</div>
                        <div class="small mb-3" style="color:#6b7280;">
                            <strong>@_detail.FullName</strong>'s solo auditor account will be deactivated.
                            They will no longer be able to log in.
                        </div>
                    }
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _showSoloConfirm = false">
                            Cancel
                        </button>
                        <button class="btn btn-sm px-3 @(_soloConfirmEnable ? "btn-warning" : "btn-danger")"
                                @onclick="ConfirmToggleSolo">
                            <i class="@(_soloConfirmEnable ? "ri-user-star-line" : "ri-user-unfollow-line") me-1"></i>
                            @(_soloConfirmEnable ? "Grant Access" : "Revoke Access")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

