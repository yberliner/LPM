@* ── Reset Budget Modal ── *@
@if (_showResetModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;" @onclick="() => { if (!_resetSuccess && !_resetDeleted) _showResetModal = false; }">
        <div class="modal-dialog modal-dialog-centered" style="max-width:500px;" @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#1e293b;border:1px solid #334155;border-radius:12px;overflow:hidden;">

                @if (_resetSuccess)
                {
                    <div class="reset-success-overlay">
                        <div class="reset-success-icon">
                            <i class="ri-checkbox-circle-fill"></i>
                        </div>
                        <div class="reset-success-title">Budget Reset!</div>
                        <div class="reset-success-sub">Balance recalculated from @_resetDate.ToString("dd/MM/yyyy") forward</div>
                    </div>
                }
                else if (_resetDeleted)
                {
                    <div class="reset-success-overlay">
                        <div class="reset-success-icon" style="background:linear-gradient(135deg,#ef4444,#b91c1c);">
                            <i class="ri-delete-bin-line"></i>
                        </div>
                        <div class="reset-success-title" style="color:#ef4444;">Reset Removed!</div>
                        <div class="reset-success-sub">Balance now includes all historical transactions again</div>
                    </div>
                }
                else if (_resetConfirmDelete)
                {
                    <div class="modal-header" style="border-bottom:1px solid #334155;padding:16px 20px;">
                        <h6 class="modal-title" style="color:#ef4444;font-weight:700;"><i class="ri-error-warning-line me-2"></i>Delete Budget Reset</h6>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => { _resetConfirmDelete = false; }"></button>
                    </div>
                    <div class="modal-body" style="padding:24px;">
                        <div style="text-align:center;margin-bottom:20px;">
                            <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#ef4444,#b91c1c);
                                        display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;">
                                <i class="ri-delete-bin-line" style="font-size:1.8rem;color:#fff;"></i>
                            </div>
                            <div style="color:#e2e8f0;font-weight:700;font-size:1.05rem;">Are you sure?</div>
                        </div>
                        <div style="background:#1c0a0a;border:1px solid #ef4444;border-radius:8px;padding:14px;margin-bottom:16px;font-size:.85rem;color:#fca5a5;">
                            <p style="margin:0 0 8px;"><strong>You are about to delete the budget reset from @_resetDeleteDate.</strong></p>
                            <p style="margin:0 0 6px;"><i class="ri-arrow-right-s-line"></i> All historical purchases and sessions will be included in balance calculations again.</p>
                            <p style="margin:0 0 6px;"><i class="ri-arrow-right-s-line"></i> The balance, hours left, and cost will change immediately.</p>
                            <p style="margin:0;"><i class="ri-arrow-right-s-line"></i> If this PC had mixed currencies before the reset, the "Mix" warning may reappear.</p>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top:1px solid #334155;padding:12px 20px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => { _resetConfirmDelete = false; }">Cancel</button>
                        <button class="btn btn-sm btn-danger" style="font-weight:600;" @onclick="ExecuteDeleteReset">
                            <i class="ri-delete-bin-line me-1"></i>Yes, Delete Reset
                        </button>
                    </div>
                }
                else
                {
                    <div class="modal-header" style="border-bottom:1px solid #334155;padding:16px 20px;">
                        <h6 class="modal-title" style="color:#f59e0b;font-weight:700;"><i class="ri-restart-line me-2"></i>Reset Budget</h6>
                        <button type="button" class="btn-close btn-close-white" @onclick="() => _showResetModal = false"></button>
                    </div>
                    <div class="modal-body" style="padding:20px;max-height:65vh;overflow-y:auto;">
                        <p style="color:#94a3b8;font-size:.88rem;margin-bottom:16px;">
                            All balance calculations for <strong style="color:#e2e8f0;">@_detail.FullName</strong> will only include
                            transactions from the selected date forward.
                        </p>

                        @* ── History ── *@
                        @if (_resetHistory.Count > 0)
                        {
                            <div style="margin-bottom:16px;">
                                <div style="color:#64748b;font-size:.78rem;font-weight:600;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">
                                    <i class="ri-history-line me-1"></i>Previous Resets
                                </div>
                                <div style="background:#0f172a;border-radius:8px;border:1px solid #1e293b;overflow:hidden;">
                                    <table class="table table-sm mb-0" style="font-size:.8rem;">
                                        <thead>
                                            <tr style="background:#1a2332;">
                                                <th style="color:#64748b;font-weight:600;padding:6px 10px;">Date</th>
                                                <th style="color:#64748b;font-weight:600;padding:6px 10px;">By</th>
                                                <th style="color:#64748b;font-weight:600;padding:6px 10px;">Notes</th>
                                                <th style="color:#64748b;font-weight:600;padding:6px 10px;">Created</th>
                                                <th style="width:36px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var h in _resetHistory)
                                            {
                                                var hId = h.Id;
                                                var hDate = h.ResetDate;
                                                var hActive = h.IsActive;
                                                <tr style="border-top:1px solid #1e293b;@(!hActive ? "opacity:.4;" : "")">
                                                    <td style="color:@(hActive ? "#f59e0b" : "#64748b");padding:5px 10px;font-weight:600;@(!hActive ? "text-decoration:line-through;" : "")">@h.ResetDate</td>
                                                    <td style="color:#94a3b8;padding:5px 10px;">@h.CreatedBy</td>
                                                    <td style="color:#94a3b8;padding:5px 10px;max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@h.Notes">@(h.Notes ?? "—")</td>
                                                    <td style="color:#475569;padding:5px 10px;white-space:nowrap;">@h.CreatedAt</td>
                                                    <td style="padding:3px 6px;">
                                                        @if (hActive)
                                                        {
                                                            <button class="btn btn-sm" style="padding:2px 5px;color:#ef4444;font-size:.75rem;"
                                                                    title="Deactivate this reset"
                                                                    @onclick="() => AskDeleteReset(hId, hDate)">
                                                                <i class="ri-delete-bin-line"></i>
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <span style="font-size:.68rem;color:#475569;" title="Deactivated">removed</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }

                        @* ── New reset form ── *@
                        <div style="background:#0f172a;border-radius:8px;border:1px solid #334155;padding:14px;">
                            <div style="color:#e2e8f0;font-size:.82rem;font-weight:600;margin-bottom:10px;">
                                <i class="ri-add-line me-1" style="color:#f59e0b;"></i>New Reset
                            </div>
                            <div class="mb-3">
                                <label class="form-label" style="color:#94a3b8;font-size:.82rem;">Reset Date</label>
                                <input type="date" class="form-control form-control-sm"
                                       style="background:#1e293b;color:#e2e8f0;border-color:#475569;"
                                       @bind="_resetDate" />
                            </div>
                            <div>
                                <label class="form-label" style="color:#94a3b8;font-size:.82rem;">Notes (reason for reset)</label>
                                <textarea class="form-control form-control-sm" rows="2"
                                          style="background:#1e293b;color:#e2e8f0;border-color:#475569;"
                                          placeholder="e.g. Switched from EUR to ILS"
                                          @bind="_resetNotes"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top:1px solid #334155;padding:12px 20px;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showResetModal = false">Cancel</button>
                        <button class="btn btn-sm btn-warning" style="font-weight:600;" @onclick="ConfirmResetBudget">
                            <i class="ri-restart-line me-1"></i>Reset Budget
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ── SMS Compose Modal ── *@
@if (_showSmsModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
            <div class="modal-content sms-modal-content">

                @* Header *@
                <div class="sms-modal-header">
                    <div class="sms-modal-icon">
                        <i class="ri-message-2-fill"></i>
                    </div>
                    <div>
                        <div class="sms-modal-title">Send SMS</div>
                        <div class="sms-modal-subtitle">Compose a message to send via SMS</div>
                    </div>
                    <button class="btn-close ms-auto" @onclick="CloseSmsModal" style="filter:invert(1);opacity:.6;"></button>
                </div>

                <div class="modal-body p-4">

                    @* Recipient card *@
                    <div class="sms-recipient-card mb-3">
                        <div class="sms-recipient-avatar">
                            @(_detail.FirstName.Length > 0 ? _detail.FirstName[0].ToString().ToUpper() : "?")
                        </div>
                        <div class="sms-recipient-info">
                            <div class="sms-recipient-name">@_detail.FullName</div>
                            @if (!string.IsNullOrWhiteSpace(_smsPhone))
                            {
                                <div class="sms-recipient-phone">
                                    <i class="ri-phone-fill me-1"></i>@_smsPhone
                                </div>
                            }
                            else
                            {
                                <div class="sms-no-phone">
                                    <i class="ri-error-warning-line me-1"></i>No phone number on record
                                </div>
                            }
                        </div>
                    </div>

                    @* Message textarea *@
                    @if (!string.IsNullOrWhiteSpace(_smsPhone))
                    {
                        <div class="mb-2">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <label class="form-label fw-semibold small mb-0" style="color:#374151;">
                                    <i class="ri-chat-3-line me-1"></i>Message
                                </label>
                                <button class="sms-dir-toggle" @onclick="() => _smsRtl = !_smsRtl"
                                        title="Toggle text direction">
                                    @if (_smsRtl)
                                    {
                                        <i class="ri-text-direction-r"></i><span>RTL</span>
                                    }
                                    else
                                    {
                                        <i class="ri-text-direction-l"></i><span>LTR</span>
                                    }
                                </button>
                            </div>
                            <textarea class="form-control sms-textarea"
                                      rows="4"
                                      maxlength="320"
                                      placeholder="@(_smsRtl ? "כתוב את ההודעה כאן…" : "Type your SMS message here…")"
                                      dir="@(_smsRtl ? "rtl" : "ltr")"
                                      @bind="_smsMessage"
                                      @bind:event="oninput"></textarea>
                            <div class="d-flex justify-content-end mt-1">
                                <span class="sms-char-count @(_smsMessage.Length > 160 ? "sms-char-warn" : "")">
                                    @_smsMessage.Length / 160
                                    @if (_smsMessage.Length > 160) { <span> (2 SMS)</span> }
                                </span>
                            </div>
                        </div>
                    }

                </div>

                <div class="modal-footer sms-modal-footer">
                    <button class="btn btn-secondary btn-sm px-4" @onclick="CloseSmsModal">@LS.T("common.cancel")</button>
                    @if (!string.IsNullOrWhiteSpace(_smsPhone))
                    {
                        <button class="pc-sms-send-btn"
                                @onclick="SendSmsFromModal"
                                disabled="@(string.IsNullOrWhiteSpace(_smsMessage) || _smsSending)">
                            @if (_smsSending)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Sending…</span>
                            }
                            else
                            {
                                <i class="ri-send-plane-fill me-1"></i>
                                <span>Send SMS</span>
                            }
                        </button>
                    }
                </div>

            </div>
        </div>
    </div>
}

@* ── SMS Success Overlay ── *@
@if (_smsSuccess)
{
    <div class="sms-success-overlay" @onclick="DismissSmsSuccess">
        <div class="sms-success-card" @onclick:stopPropagation="true">
            <div class="sms-success-burst">
                <svg class="sms-checkmark" viewBox="0 0 52 52">
                    <circle class="sms-checkmark-circle" cx="26" cy="26" r="25" fill="none" />
                    <path class="sms-checkmark-path" fill="none" d="M14 27 l8 8 l16-16" />
