                                            <th class="text-center">@LS.T("pcs.totalVisits")</th>
                                            <th>@LS.T("pcs.instructor")</th>
                                            <th>@LS.T("pcs.cs")</th>
                                            <th class="text-center">@LS.T("pcs.action")</th>
                                        </tr>
                                    </thead>
