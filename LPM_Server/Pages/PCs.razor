@page "/PCs"
@attribute [Authorize]
@inject LPM.Services.PcService PcSvc
@inject LPM.Services.CourseService CourseSvc
@inject LPM.Services.DashboardService DashSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using LPM.Services

<div class="d-flex gap-3" style="height:calc(100vh - 130px); overflow:hidden;">

    @* ── LEFT PANEL: PC Table ── *@
    <div class="d-flex flex-column" style="width:340px;min-width:340px;">
        <div class="d-flex gap-1 mb-2">
            <input class="form-control form-control-sm" placeholder="@LS.T("common.search")"
                   @bind="_search" @bind:event="oninput" />
            <button class="btn btn-sm btn-success text-nowrap" @onclick="() => _addModal.Show()">
                <i class="ri-user-add-line me-1"></i>@LS.T("pcs.newPc")
            </button>
        </div>
        <div class="overflow-y-auto flex-grow-1">
            @if (!FilteredPcsEx.Any())
            {
                <div class="text-muted small text-center mt-4">@LS.T("pcs.noPcsFound")</div>
            }
            else
            {
                <table class="table table-sm table-hover mb-0 pc-list-table">
                    <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                        <tr>
                            <th class="small ps-2 pc-th-sort @SortClass("name")" @onclick='() => ToggleSort("name")'>@LS.T("pcs.pcName")</th>
                            <th class="small text-center pc-th-sort @SortClass("hoursLeft")" style="width:70px;" @onclick='() => ToggleSort("hoursLeft")'>@LS.T("pcs.hoursLeft")</th>
                            <th class="small text-center pc-th-sort @SortClass("totalTime")" style="width:70px;" @onclick='() => ToggleSort("totalTime")'>@LS.T("pcs.totalSessionTime")</th>
                            <th class="small text-center pc-th-sort @SortClass("visits")" style="width:55px;" @onclick='() => ToggleSort("visits")'>@LS.T("pcs.totalVisits")</th>
                            <th class="small text-center pc-th-sort @SortClass("purchased")" style="width:55px;" @onclick='() => ToggleSort("purchased")'>@LS.T("pcs.hoursPurchased")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var pc in FilteredPcsEx)
                        {
                            <tr class="@(_selPcId == pc.PcId ? "table-primary" : "")"
                                style="cursor:pointer;"
                                @onclick="() => SelectPc(pc.PcId)">
                                <td class="small ps-2 text-truncate" style="max-width:120px;">@pc.FullName</td>
                                <td class="small text-center fw-semibold"
                                    style="color:@(pc.RemainSec >= 0 ? "#4ade80" : "#f87171");">
                                    @HrsLabel(pc.RemainSec)
                                </td>
                                <td class="small text-center text-muted">@HrsLabel(pc.TotalSessionSec)</td>
                                <td class="small text-center text-muted">@pc.AcademyVisits</td>
                                <td class="small text-center text-muted">@(pc.HoursPurchased)h</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* ── RIGHT PANEL ── *@
    <div class="flex-grow-1 overflow-y-auto">

        @if (_selPcId.HasValue && _detail != null)
        {
            @* ── PC DETAIL ── *@

            @* Header card *@
            <div class="card shadow-sm mb-3">
                <div class="card-body py-2 px-3">
                    <div class="d-flex align-items-start gap-3">
                        <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold flex-shrink-0"
                             style="width:48px;height:48px;background:#3949ab;font-size:1.3rem;">
                            @(_detail.FirstName.Length > 0 ? _detail.FirstName[0].ToString().ToUpper() : "?")
                        </div>
                        @if (_editMode)
                        {
                            <div class="row g-2 flex-grow-1">
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("members.firstName")</label>
                                    <input class="form-control form-control-sm" @bind="_editFirstName" style="width:130px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("members.lastName")</label>
                                    <input class="form-control form-control-sm" @bind="_editLastName" style="width:130px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("members.phone")</label>
                                    <input class="form-control form-control-sm" @bind="_editPhone" style="width:130px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("pcs.email")</label>
                                    <input class="form-control form-control-sm" @bind="_editEmail" style="width:190px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("pcs.dateOfBirth")</label>
                                    <input type="date" class="form-control form-control-sm" @bind="_editDob" style="width:150px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("pcs.sex")</label>
                                    <select class="form-select form-select-sm" @bind="_editSex" style="width:110px;">
                                        <option value="">—</option>
                                        <option value="Male">@LS.T("pcs.male")</option>
                                        <option value="Female">@LS.T("pcs.female")</option>
                                        <option value="Other">@LS.T("pcs.other")</option>
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("members.externalId")</label>
                                    <input class="form-control form-control-sm" @bind="_editExternalId" style="width:120px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("pcs.startDate")</label>
                                    <input type="date" class="form-control form-control-sm" @bind="_editStartDate" style="width:150px;" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-0">@LS.T("pcs.origin")</label>
                                    <select class="form-select form-select-sm" @bind="_editOrigin" style="width:140px;">
                                        <option value="">— @LS.T("pcs.selectOrigin") —</option>
                                        <option value="Haifa">Haifa</option>
                                        <option value="Riga">Riga</option>
                                        <option value="from Abroad">@LS.T("pcs.fromAbroad")</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label class="form-label small mb-0">@LS.T("pcs.notes")</label>
                                    <textarea class="form-control form-control-sm" rows="2" @bind="_editNotes"></textarea>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center gap-2 flex-wrap mb-1">
                                    <span class="fs-5 fw-semibold" style="color:var(--default-text-color);">@_detail.FullName</span>
                                    @if (!string.IsNullOrEmpty(_detail.ExternalId))
                                    {
                                        <span class="badge bg-secondary-transparent text-secondary">
                                            <i class="ri-hashtag me-1"></i>@_detail.ExternalId
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(_detail.StartDate))
                                    {
                                        <span class="text-muted small">
                                            <i class="ri-calendar-line me-1"></i>@LS.T("pcs.since") @_detail.StartDate
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(_detail.Origin))
                                    {
                                        <span class="badge rounded-pill" style="background:#ede9fe;color:#6d28d9;font-size:.73rem;">
                                            <i class="ri-map-pin-line me-1"></i>@_detail.Origin
                                        </span>
                                    }
                                </div>
                                <div class="d-flex gap-3 flex-wrap">
                                    @if (!string.IsNullOrEmpty(_detail.Phone))
                                    {
                                        <span class="text-muted small">
                                            <i class="ri-phone-line me-1"></i>@_detail.Phone
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(_detail.Email))
                                    {
                                        <span class="text-muted small">
                                            <i class="ri-mail-line me-1"></i>@_detail.Email
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(_detail.DateOfBirth))
                                    {
                                        <span class="text-muted small">
                                            <i class="ri-cake-line me-1"></i>@LS.T("pcs.dob") @_detail.DateOfBirth
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(_detail.Sex))
                                    {
                                        <span class="text-muted small">@_detail.Sex</span>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(_detail.Notes))
                                {
                                    <div class="text-muted small mt-1 fst-italic">@_detail.Notes</div>
                                }
                            </div>
                        }
                        <div class="ms-auto d-flex gap-2 flex-shrink-0">
                            @if (_editMode)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="SaveEdit">
                                    <i class="ri-save-line me-1"></i>@LS.T("common.save")
                                </button>
                                <button class="btn btn-sm btn-link text-muted" @onclick="() => _editMode = false">@LS.T("common.cancel")</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="StartEdit">
                                    <i class="ri-edit-line me-1"></i>@LS.T("common.edit")
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* Stats row *@
            @if (_stats != null)
            {
                long remainSec = (long)_stats.TotalHoursPurchased * 3600 - _stats.UsedSec;
                <div class="row g-2 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="pc-stat-card" style="background:linear-gradient(135deg,#1e40af,#6366f1);">
                            <div class="pc-stat-icon"><i class="ri-calendar-check-line"></i></div>
                            <div class="pc-stat-value">@_stats.TotalSessions</div>
                            <div class="pc-stat-label">@LS.T("auditors.totalSessions")</div>
                            @if (_stats.FreeSessions > 0)
                            {
                                <div class="pc-stat-sub">@_stats.FreeSessions @LS.T("pcs.free")</div>
                            }
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="pc-stat-card" style="background:linear-gradient(135deg,#0d9488,#22c55e);">
                            <div class="pc-stat-icon"><i class="ri-timer-flash-line"></i></div>
                            <div class="pc-stat-value">@Hmm((int)_stats.UsedSec)</div>
                            <div class="pc-stat-label">@LS.T("pcs.hoursUsed")</div>
                            <div class="pc-stat-sub">@LS.T("pcs.billedSessions")</div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="pc-stat-card" style="background:linear-gradient(135deg,#d97706,#f59e0b);">
                            <div class="pc-stat-icon"><i class="ri-bank-card-2-line"></i></div>
                            <div class="pc-stat-value">@_stats.TotalHoursPurchased<span style="font-size:1rem;font-weight:500;">h</span></div>
                            <div class="pc-stat-label">@LS.T("pcs.hoursPurchased")</div>
                            @if (_stats.TotalAmountPaid > 0)
                            {
                                <div class="pc-stat-sub">@("\u20AA")@_stats.TotalAmountPaid @LS.T("pcs.paid")</div>
                            }
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="pc-stat-card" style="background:@(remainSec >= 0 ? "linear-gradient(135deg,#065f46,#16a34a)" : "linear-gradient(135deg,#9f1239,#ef4444)");">
                            <div class="pc-stat-icon">
                                <i class="@(remainSec >= 0 ? "ri-time-line" : "ri-alarm-warning-line")"></i>
                            </div>
                            <div class="pc-stat-value">@HmmSigned(remainSec)</div>
                            <div class="pc-stat-label">@LS.T("pcs.hoursRemaining")</div>
                            @if (_stats.LastSessionDate != null)
                            {
                                <div class="pc-stat-sub">@LS.T("pcs.last"): @_stats.LastSessionDate</div>
                            }
                        </div>
                    </div>
                </div>
            }

            @* Combined Purchases & Payments card *@
            <div class="card shadow-sm mb-3 purchases-card">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#1e3a5f,#2d6a9f);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-shopping-cart-line me-1"></i>@LS.T("pcs.payments")
                    </span>
                    <div class="d-flex align-items-center gap-2">
                        @if (_pcPurchases != null)
                        {
                            var unapproved = _pcPurchases.Count(p => p.ApprovedStatus != "Approved");
                            @if (unapproved > 0)
                            {
                                <span class="badge rounded-pill bg-warning text-dark fw-bold" style="font-size:.7rem;">
                                    @unapproved @LS.T("purchases.pending")
                                </span>
                            }
                        }
                        <button class="btn btn-sm btn-outline-light py-0 px-2" style="font-size:0.75rem;"
                                @onclick="OpenPurchaseModal">
                            <i class="ri-add-line me-1"></i>@LS.T("pcs.purchase")
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (_pcPurchases?.Count > 0)
                    {
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">@LS.T("pcs.date")</th>
                                    <th class="small text-center">@LS.T("purchases.totalHours")</th>
                                    <th class="small text-end">@LS.T("purchases.totalAmount")</th>
                                    <th class="small">@LS.T("pcs.notes")</th>
                                    <th class="small">@LS.T("purchases.createdBy")</th>
                                    <th class="small text-center">@LS.T("common.status")</th>
                                    <th style="width:70px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var pp in _pcPurchases)
                                {
                                    var isApproved = pp.ApprovedStatus == "Approved";
                                    var isDraft = pp.ApprovedStatus == "Draft";
                                    var rowBg = isApproved ? "#f0fdf4" : isDraft ? "#f8f9fa" : "#fffbeb";
                                    <tr style="background:@rowBg;color:#212529;">
                                        <td class="small ps-3">@FormatDate(pp.PurchaseDate)</td>
                                        <td class="small text-center fw-semibold">@(pp.TotalHours > 0 ? $"{pp.TotalHours}h" : "\u2014")</td>
                                        <td class="small text-end fw-semibold">@(pp.TotalAmount > 0 ? $"\u20AA{pp.TotalAmount}" : "\u2014")</td>
                                        <td class="small" style="color:#6b7280;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@pp.Notes">@(pp.Notes ?? "\u2014")</td>
                                        <td class="small" style="color:#6b7280;">@pp.CreatedByName</td>
                                        <td class="small text-center">
                                            @if (isApproved)
                                            {
                                                <span class="badge" style="background:#d1fae5;color:#065f46;font-size:.72rem;">
                                                    <i class="ri-check-line me-1"></i>@LS.T("purchases.approved")
                                                </span>
                                            }
                                            else if (isDraft)
                                            {
                                                <span class="badge" style="background:#e2e8f0;color:#475569;font-size:.72rem;">
                                                    <i class="ri-draft-line me-1"></i>@LS.T("pcs.draft")
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background:#fef3c7;color:#92400e;font-size:.72rem;">
                                                    <i class="ri-time-line me-1"></i>@LS.T("purchases.pending")
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="d-flex gap-1 justify-content-center">
                                                <button class="btn btn-link btn-sm text-primary py-0 px-0"
                                                        title="@LS.T("pcs.editPurchase")"
                                                        @onclick="() => OpenEditPurchase(pp.PurchaseId)">
                                                    <i class="ri-pencil-line" style="font-size:0.85rem;"></i>
                                                </button>
                                                <button class="btn btn-link btn-sm text-danger py-0 px-0"
                                                        title="@LS.T("common.delete")"
                                                        @onclick="() => _confirmDeletePurchaseId = pp.PurchaseId">
                                                    <i class="ri-delete-bin-line" style="font-size:0.85rem;"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td class="small ps-3 fw-semibold">@LS.T("stats.total")</td>
                                    <td class="small text-center fw-semibold">
                                        @{ var totalPurchaseHrs = _pcPurchases.Sum(p => p.TotalHours); }
                                        @(totalPurchaseHrs > 0 ? $"{totalPurchaseHrs}h" : "\u2014")
                                    </td>
                                    <td class="small text-end fw-semibold">
                                        @{ var totalPurchaseAmt = _pcPurchases.Sum(p => p.TotalAmount); }
                                        @(totalPurchaseAmt > 0 ? $"\u20AA{totalPurchaseAmt}" : "\u2014")
                                    </td>
                                    <td colspan="4"></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noPayments")</div>
                    }
                </div>
            </div>

            @* Session history card *@
            <div class="card shadow-sm">
                <div class="card-header d-flex align-items-center justify-content-between py-2">
                    <span class="fw-semibold small"><i class="ri-time-line me-1"></i>@LS.T("pcs.sessionHistory")</span>
                    @if (_sessions?.Count > 0)
                    {
                        <span class="badge bg-primary-transparent text-primary">@_sessions.Count @LS.T("pcs.sessions")</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_sessions?.Count > 0)
                    {
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">@LS.T("pcs.date")</th>
                                    <th class="small">@LS.T("pcs.auditor")</th>
                                    <th class="small text-center">@LS.T("pcs.duration")</th>
                                    <th class="small text-center">@LS.T("pcs.admin")</th>
                                    <th class="small text-center">@LS.T("pcs.type")</th>
                                    <th class="small text-center">@LS.T("common.status")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _sessions)
                                {
                                    <tr>
                                        <td class="small ps-3">@s.Date</td>
                                        <td class="small">@s.AuditorName</td>
                                        <td class="small text-center">@Hmm(s.LengthSec)</td>
                                        <td class="small text-center" style="color:var(--default-text-color);opacity:.6;">
                                            @(s.AdminSec > 0 ? Hmm(s.AdminSec) : "\u2014")
                                        </td>
                                        <td class="small text-center">
                                            @if (s.IsFree)
                                            {
                                                <span class="badge bg-warning-transparent text-warning">@LS.T("pcs.free")</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success-transparent text-success">@LS.T("pcs.billed")</span>
                                            }
                                        </td>
                                        <td class="small text-center">
                                            @{
                                                var (cls, lbl) = s.VerifiedStatus switch {
                                                    "Approved" => ("bg-success-transparent text-success", LS.T("sessions.approved")),
                                                    "Draft"    => ("bg-secondary-transparent text-secondary", LS.T("sessions.draft")),
                                                    _          => ("bg-warning-transparent text-warning", s.VerifiedStatus)
                                                };
                                            }
                                            <span class="badge @cls">@lbl</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="2" class="small ps-3 fw-semibold">@LS.T("pcs.totalBilled")</td>
                                    <td class="small text-center fw-semibold">
                                        @Hmm(_sessions.Where(s => !s.IsFree).Sum(s => s.LengthSec))
                                    </td>
                                    <td class="small text-center fw-semibold" style="color:#6b7280;">
                                        @{ var adminTot = _sessions.Where(s => !s.IsFree).Sum(s => s.AdminSec); }
                                        @(adminTot > 0 ? Hmm(adminTot) : "\u2014")
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noSessions")</div>
                    }
                </div>
            </div>

        }
        else
        {
            <div class="d-flex flex-column align-items-center justify-content-center"
                 style="height:60vh;color:var(--default-text-color);opacity:.5;">
                <i class="ri-contacts-book-2-line" style="font-size:3.5rem;opacity:0.2;"></i>
                <p class="mt-2 small">@LS.T("pcs.selectPrompt")</p>
            </div>
        }

    </div>
</div>

@* ── Purchase Modal ── *@
@if (_showPurchaseModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1050;">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-header py-2 px-3 d-flex align-items-center" style="border-color:#dee2e6;">
                    <h5 class="modal-title fw-bold mb-0" style="color:#212529;">
                        <i class="ri-shopping-cart-line me-2"></i>@(_editingPurchaseId.HasValue ? LS.T("pcs.editPurchase") : LS.T("pcs.purchase"))
                    </h5>
                    @if (_editingPurchaseId.HasValue)
                    {
                        <span class="badge bg-warning text-dark ms-2" style="font-size:.7rem;">@LS.T("purchases.statusResetWarning")</span>
                    }
                    <div class="ms-auto d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="PrintPurchase">
                            <i class="ri-printer-line me-1"></i>@LS.T("common.print")
                        </button>
                        <button type="button" class="btn-close" @onclick="ClosePurchaseModal"></button>
                    </div>
                </div>
                <div class="modal-body p-3">
                    @* PC Name big *@
                    <div class="text-center mb-3">
                        <div style="font-size:1.6rem;font-weight:800;color:#1e3a5f;">@_detail.FullName</div>
                    </div>

                        @* Purchase items *@
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold small">@LS.T("pcs.purchaseItems")</span>
                                <button class="btn btn-sm btn-outline-primary py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPurchaseItem">
                                    @LS.T("pcs.addItem")
                                </button>
                            </div>

                            @for (int idx = 0; idx < _purchaseItems.Count; idx++)
                            {
                                var i = idx;
                                var item = _purchaseItems[i];
                                <div class="card border mb-2">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <div class="d-flex gap-2">
                                                @{ var capturedIdx = i; }
                                                <button class="btn btn-sm @(item.ItemType == "Auditing" ? "btn-primary" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Auditing")'>
                                                    <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditing")
                                                </button>
                                                <button class="btn btn-sm @(item.ItemType == "Course" ? "btn-info text-white" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Course")'>
                                                    <i class="ri-book-2-line me-1"></i>@LS.T("pcs.course")
                                                </button>
                                            </div>
                                            @if (_purchaseItems.Count > 1)
                                            {
                                                <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemovePurchaseItem(i)">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            }
                                        </div>
                                        <div class="row g-2 align-items-end">
                                            @if (item.ItemType == "Auditing")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.hoursBought")</label>
                                                    <input type="number" class="form-control form-control-sm"
                                                           value="@item.HoursBought" min="0" style="width:95px;" placeholder="0"
                                                           @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.HoursBought = v; }" />
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.course")</label>
                                                    <select class="form-select form-select-sm" style="width:200px;"
                                                            value="@item.CourseId"
                                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.CourseId = v; }">
                                                        <option value="0">— @LS.T("pcs.selectCourse") —</option>
                                                        @foreach (var c in _allCourses)
                                                        {
                                                            <option value="@c.CourseId">@c.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            <div class="col-auto">
                                                <label class="form-label small mb-0">@LS.T("pcs.amountIls")</label>
                                                <input type="number" class="form-control form-control-sm"
                                                       value="@item.AmountPaid" min="0" style="width:105px;" placeholder="0"
                                                       @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.AmountPaid = v; }" />
                                            </div>
                                            <div class="col-auto">
                                                <label class="form-label small mb-0">@LS.T("courses.registrar")</label>
                                                <select class="form-select form-select-sm" style="width:160px;"
                                                        value="@item.RegistrarId"
                                                        @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.RegistrarId = v; }">
                                                    <option value="0">— @LS.T("common.none") —</option>
                                                    @foreach (var s in _staff)
                                                    {
                                                        <option value="@s.PersonId">@s.FullName</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-auto">
                                                <label class="form-label small mb-0">@LS.T("courses.referral")</label>
                                                <select class="form-select form-select-sm" style="width:160px;"
                                                        value="@item.ReferralId"
                                                        @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.ReferralId = v; }">
                                                    <option value="0">— @LS.T("common.none") —</option>
                                                    @foreach (var p in _allPersons)
                                                    {
                                                        <option value="@p.PersonId">@p.FullName</option>
                                                    }
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        @* Payment Methods *@
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold small">@LS.T("purchases.paymentMethods")</span>
                                <button class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPaymentMethod">
                                    @LS.T("purchases.addPaymentMethod")
                                </button>
                            </div>
                            @for (int pmIdx = 0; pmIdx < _purchasePaymentMethods.Count; pmIdx++)
                            {
                                var pi2 = pmIdx;
                                var pm = _purchasePaymentMethods[pi2];
                                <div class="d-flex gap-2 align-items-end mb-2 p-2 border rounded" style="background:#f8fafc;">
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.methodType")</label>
                                        <select class="form-select form-select-sm" style="width:140px;font-size:.8rem;"
                                                value="@pm.MethodType"
                                                @onchange='e => pm.MethodType = e.Value?.ToString() ?? "Cash"'>
                                            <option value="Cash">@LS.T("purchases.cash")</option>
                                            <option value="CreditCard">@LS.T("purchases.creditCard")</option>
                                            <option value="Check">@LS.T("purchases.check")</option>
                                            <option value="BankTransfer">@LS.T("purchases.bankTransfer")</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.amount")</label>
                                        <input type="number" class="form-control form-control-sm" style="width:100px;font-size:.8rem;"
                                               value="@pm.Amount" min="0" placeholder="0"
                                               @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) pm.Amount = v; }" />
                                    </div>
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.paymentDate")</label>
                                        <input type="date" class="form-control form-control-sm" style="width:140px;font-size:.8rem;"
                                               value="@(pm.PaymentDate?.ToString("yyyy-MM-dd"))"
                                               @onchange="e => pm.PaymentDate = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null" />
                                    </div>
                                    @if (_purchasePaymentMethods.Count > 1)
                                    {
                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => _purchasePaymentMethods.RemoveAt(pi2)">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                </div>
                            }
                            @{
                                var itemsTotal = _purchaseItems.Sum(i => i.AmountPaid);
                                var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
                            }
                            @if (pmTotal > 0 && pmTotal != itemsTotal)
                            {
                                <div class="small text-warning d-flex align-items-center gap-1 mt-1">
                                    <i class="ri-error-warning-line"></i>@LS.T("purchases.amountMismatch")
                                    <span class="fw-semibold">(\u20AA@pmTotal / \u20AA@itemsTotal)</span>
                                </div>
                            }
                        </div>

                        @* Notes (below all items) *@
                        <div class="mb-3">
                            <label class="form-label small fw-semibold mb-1">@LS.T("pcs.notes")</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_purchaseNotes"
                                      placeholder="@LS.T("members.optional")"></textarea>
                        </div>

                        @* Date *@
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div>
                                <label class="form-label small fw-semibold mb-0">@LS.T("pcs.date")</label>
                                <input type="date" class="form-control form-control-sm" @bind="_purchaseDate" style="width:160px;" />
                            </div>
                        </div>

                        @* Signature *@
                        <div class="mb-3">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <label class="form-label small fw-semibold mb-0">
                                    @LS.T("pcs.signature") <span style="color:#dc3545;font-size:1rem;">*</span>
                                </label>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:0.7rem;"
                                        @onclick="ClearSignature">
                                    @LS.T("pcs.clearSignature")
                                </button>
                            </div>
                            <div style="border:2px solid #dee2e6;border-radius:8px;background:#fafafa;position:relative;">
                                <canvas id="signatureCanvas" style="width:100%;height:120px;cursor:crosshair;display:block;"></canvas>
                            </div>
                        </div>
                </div>
                <div class="modal-footer py-2 px-3">
                    @if (!string.IsNullOrEmpty(_purchaseError))
                    {
                        <div class="alert alert-danger py-1 px-2 mb-0 small flex-grow-1">@_purchaseError</div>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="ClosePurchaseModal">@LS.T("common.cancel")</button>
                    <button class="btn btn-primary btn-sm" @onclick="SavePurchase"
                            disabled="@(!HasValidPurchaseItems())">
                        <i class="ri-save-line me-1"></i>@LS.T("common.save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<SpkNewPersonModal @ref="_addModal" Title="@LS.T("pcs.addNewPc")" ShowPcOriginField="true"
                   ExistingFullNames="@(new HashSet<string>(_allPcsEx.Select(p => p.FullName), StringComparer.OrdinalIgnoreCase))"
                   OnSaved="SaveNewPc" />

@* ── Delete Purchase Confirmation ── *@
@if (_confirmDeletePurchaseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-error-warning-line text-danger" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmDeleteTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmDeleteMsg")</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmDeletePurchaseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-danger px-3" @onclick="ConfirmDeletePurchase">
                            <i class="ri-delete-bin-line me-1"></i>@LS.T("common.delete")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .pc-stat-card {
        border-radius: 14px; padding: 16px 12px; text-align: center; color: #fff;
        position: relative; overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,.15);
        transition: transform .18s, box-shadow .18s;
    }
    .pc-stat-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.22); }
    .pc-stat-card::before {
        content:''; position:absolute; top:-28px; right:-28px;
        width:80px; height:80px; border-radius:50%; background:rgba(255,255,255,.1);
    }
    .pc-stat-icon  { font-size:1.4rem; opacity:.75; margin-bottom:4px; }
    .pc-stat-value { font-size:1.7rem; font-weight:800; line-height:1.1; position:relative; }
    .pc-stat-label { font-size:.7rem; opacity:.82; margin-top:4px; letter-spacing:.03em; text-transform:uppercase; }
    .pc-stat-sub   { font-size:.7rem; opacity:.68; margin-top:2px; }

    .pc-list-table th { font-size:0.7rem; font-weight:700; letter-spacing:.03em; text-transform:uppercase; white-space:nowrap; }
    .pc-list-table td { vertical-align:middle; }
    .pc-th-sort { cursor:pointer; user-select:none; position:relative; padding-right:16px !important; }
    .pc-th-sort::after { content:''; display:inline-block; width:0; height:0; border-left:4px solid transparent;
                         border-right:4px solid transparent; margin-left:4px; vertical-align:middle; opacity:0.3;
                         border-bottom:4px solid currentColor; }
    .pc-th-sort.sort-asc::after { border-bottom:4px solid currentColor; border-top:none; opacity:0.8; }
    .pc-th-sort.sort-desc::after { border-bottom:none; border-top:4px solid currentColor; opacity:0.8; }

    .purchases-card { border: none; border-radius: 14px; overflow: hidden; }

    /* Force readable colors inside tables with hardcoded light-background rows */
    .purchases-card .table,
    .purchases-card .table td,
    .purchases-card .table th { color: #212529 !important; }
    .purchases-card .table tr { --bs-table-bg: transparent; }
    .purchases-card .table td,
    .purchases-card .table th { background-color: inherit !important; --bs-table-bg-type: transparent; }
    .purchases-card .table-light { background-color: #f8f9fa !important; color: #212529 !important; }
    .purchases-card .table-light th,
    .purchases-card .table-light td { color: #212529 !important; background-color: #f8f9fa !important; }

    /* Force dark text inside white-bg modals (purchase modal, delete confirm) */
    .modal-content .form-label { color: #212529 !important; }
    .modal-content .form-control,
    .modal-content .form-select { color: #212529 !important; background-color: #fff !important; border-color: #dee2e6 !important; }
    .modal-content .form-control::placeholder { color: #6c757d !important; }
    .modal-content .fw-semibold { color: #212529; }
    .modal-content .btn-close { filter: none; }
    .modal-content .modal-footer { border-color: #dee2e6; color: #212529; }
    .modal-content .card { background: #fff; color: #212529; }
    .modal-content .card-body { color: #212529; }
</style>

@code {
    List<PcListItemEx> _allPcsEx    = [];
    int?               _selPcId;
    string             _search      = "";

    // Sort state
    string _sortCol  = "hoursLeft";
    bool   _sortAsc  = true;

    PcDetailInfo?       _detail;
    PcStats?            _stats;
    List<PcSessionInfo>? _sessions;

    // Add PC modal
    SpkNewPersonModal _addModal = default!;

    // Edit mode
    bool      _editMode;
    string    _editFirstName = "", _editLastName = "", _editExternalId = "";
    string    _editPhone = "", _editEmail = "", _editNotes = "", _editSex = "", _editOrigin = "";
    DateTime? _editDob;
    DateTime? _editStartDate;

    // Purchase modal
    bool     _showPurchaseModal;
    DateTime _purchaseDate = DateTime.Today;
    string   _purchaseNotes = "";
    string   _purchaseError = "";
    List<PurchaseItemModel> _purchaseItems = new();
    List<PaymentMethodModel> _purchasePaymentMethods = new();
    int? _editingPurchaseId;
    int? _confirmDeletePurchaseId;
    string _origPurchaseSnapshot = "";

    List<CourseItem>             _allCourses  = [];
    List<(int PersonId, string FullName)> _staff      = [];
    List<(int PersonId, string FullName)> _allPersons = [];
    int? _currentPersonId;

    // All purchases for this PC (not just pending)
    List<PurchaseListItem>? _pcPurchases;

    class PurchaseItemModel
    {
        public string ItemType { get; set; } = "Auditing";
        public int CourseId { get; set; }
        public int HoursBought { get; set; }
        public int AmountPaid { get; set; }
        public int RegistrarId { get; set; }
        public int ReferralId { get; set; }
    }

    class PaymentMethodModel
    {
        public string MethodType { get; set; } = "Cash";
        public int Amount { get; set; }
        public DateTime? PaymentDate { get; set; } = DateTime.Today;
    }

    IEnumerable<PcListItemEx> FilteredPcsEx
    {
        get
        {
            var list = string.IsNullOrWhiteSpace(_search)
                ? _allPcsEx.AsEnumerable()
                : _allPcsEx.Where(p =>
                    p.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    p.ExternalId.Contains(_search, StringComparison.OrdinalIgnoreCase));

            list = (_sortCol, _sortAsc) switch
            {
                ("name", true)       => list.OrderBy(p => p.FullName),
                ("name", false)      => list.OrderByDescending(p => p.FullName),
                ("hoursLeft", true)  => list.OrderBy(p => p.RemainSec),
                ("hoursLeft", false) => list.OrderByDescending(p => p.RemainSec),
                ("totalTime", true)  => list.OrderBy(p => p.TotalSessionSec),
                ("totalTime", false) => list.OrderByDescending(p => p.TotalSessionSec),
                ("visits", true)     => list.OrderBy(p => p.AcademyVisits),
                ("visits", false)    => list.OrderByDescending(p => p.AcademyVisits),
                ("purchased", true)  => list.OrderBy(p => p.HoursPurchased),
                ("purchased", false) => list.OrderByDescending(p => p.HoursPurchased),
                _ => list.OrderBy(p => p.RemainSec)
            };

            return list;
        }
    }

    async Task ToggleSort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = true; }
        await JS.InvokeVoidAsync("localStorage.setItem", "pcs_sortCol", _sortCol);
        await JS.InvokeVoidAsync("localStorage.setItem", "pcs_sortAsc", _sortAsc.ToString());
    }

    string SortClass(string col) =>
        _sortCol != col ? "" : _sortAsc ? "sort-asc" : "sort-desc";

    bool _sortLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var col = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortCol");
            var asc = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortAsc");
            if (!string.IsNullOrEmpty(col)) _sortCol = col;
            if (!string.IsNullOrEmpty(asc)) _sortAsc = asc == "True";
            _sortLoaded = true;
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _allPcsEx   = PcSvc.GetAllPcsExtended();
        _allCourses = CourseSvc.GetAllCourses();
        _staff      = PcSvc.GetStaff();
        _allPersons = PcSvc.GetAllPersons();

        var auth = await AuthState.GetAuthenticationStateAsync();
        var username = auth.User.Identity?.Name;
        _currentPersonId = username != null ? PcSvc.GetPersonIdByUsername(username) : null;
    }

    void SelectPc(int pcId)
    {
        _selPcId  = pcId;
        _editMode = false;
        LoadDetail();
    }

    void LoadDetail()
    {
        if (!_selPcId.HasValue) return;
        _detail            = PcSvc.GetPcDetail(_selPcId.Value);
        _stats             = PcSvc.GetPcStats(_selPcId.Value);
        _sessions          = PcSvc.GetPcSessions(_selPcId.Value);
        _pcPurchases       = PcSvc.GetAllPurchasesForPc(_selPcId.Value);
    }

    void SaveNewPc((string fn, string ln, string phone, string email, string dob, string sex,
                    string org, string referral, string origin, int courseId) d)
    {
        var newId = PcSvc.AddPcWithPerson(d.fn, d.ln, d.phone, d.email, d.dob, d.sex, d.origin);
        _allPcsEx = PcSvc.GetAllPcsExtended();
        SelectPc(newId);
    }

    void StartEdit()
    {
        if (_detail == null) return;
        _editMode       = true;
        _editFirstName  = _detail.FirstName;
        _editLastName   = _detail.LastName;
        _editExternalId = _detail.ExternalId;
        _editPhone      = _detail.Phone;
        _editEmail      = _detail.Email;
        _editDob        = string.IsNullOrEmpty(_detail.DateOfBirth) ? null
                          : DateTime.TryParse(_detail.DateOfBirth, out var dob) ? dob : null;
        _editSex        = _detail.Sex;
        _editNotes      = _detail.Notes;
        _editOrigin     = _detail.Origin;
        _editStartDate  = string.IsNullOrEmpty(_detail.StartDate) ? null
                          : DateTime.TryParse(_detail.StartDate, out var d) ? d : null;
    }

    void SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(_editFirstName)) return;
        PcSvc.UpdatePcDetail(_selPcId!.Value,
            _editFirstName, _editLastName, _editExternalId,
            _editPhone, _editEmail,
            _editStartDate?.ToString("yyyy-MM-dd") ?? "", _editNotes,
            _editDob?.ToString("yyyy-MM-dd") ?? "", _editSex, _editOrigin);
        _editMode = false;
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    // ── Purchase modal ──────────────────────────────────────────────

    string GetPurchaseSnapshot()
    {
        var items = string.Join("|", _purchaseItems.Select(i => $"{i.ItemType},{i.CourseId},{i.HoursBought},{i.AmountPaid},{i.RegistrarId},{i.ReferralId}"));
        var pms = string.Join("|", _purchasePaymentMethods.Select(m => $"{m.MethodType},{m.Amount},{m.PaymentDate?.ToString("yyyy-MM-dd")}"));
        return $"{_purchaseDate:yyyy-MM-dd}~{_purchaseNotes}~{items}~{pms}";
    }

    async Task OpenPurchaseModal()
    {
        _showPurchaseModal = true;
        _editingPurchaseId = null;
        _purchaseDate      = DateTime.Today;
        _purchaseNotes     = "";
        _purchaseError     = "";
        _allCourses        = CourseSvc.GetAllCourses();
        _purchaseItems     = new List<PurchaseItemModel>
        {
            new PurchaseItemModel { RegistrarId = _currentPersonId ?? 0 }
        };
        _purchasePaymentMethods = new List<PaymentMethodModel>
        {
            new PaymentMethodModel()
        };
        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("SignaturePad.init", "signatureCanvas", null);
        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task OpenEditPurchase(int purchaseId)
    {
        var detail = PcSvc.GetPurchaseDetail(purchaseId);
        if (detail == null) return;

        _showPurchaseModal = true;
        _editingPurchaseId = purchaseId;
        _purchaseError     = "";
        _allCourses        = CourseSvc.GetAllCourses();

        _purchaseDate = DateTime.TryParse(detail.PurchaseDate, out var dt) ? dt : DateTime.Today;
        _purchaseNotes = detail.Notes ?? "";

        _purchaseItems = detail.Items.Select(it => new PurchaseItemModel
        {
            ItemType    = it.ItemType,
            CourseId    = it.CourseId ?? 0,
            HoursBought = it.HoursBought,
            AmountPaid  = it.AmountPaid,
            RegistrarId = it.RegistrarId ?? 0,
            ReferralId  = it.ReferralId ?? 0
        }).ToList();
        if (_purchaseItems.Count == 0)
            _purchaseItems.Add(new PurchaseItemModel { RegistrarId = _currentPersonId ?? 0 });

        _purchasePaymentMethods = detail.PaymentMethods.Select(pm => new PaymentMethodModel
        {
            MethodType  = pm.MethodType,
            Amount      = pm.Amount,
            PaymentDate = DateTime.TryParse(pm.PaymentDate, out var pdt) ? pdt : null
        }).ToList();
        if (_purchasePaymentMethods.Count == 0)
            _purchasePaymentMethods.Add(new PaymentMethodModel());

        StateHasChanged();
        await Task.Delay(100);
        await JS.InvokeVoidAsync("SignaturePad.init", "signatureCanvas", null);

        // Draw existing signature if present
        if (!string.IsNullOrEmpty(detail.SignatureData))
            await JS.InvokeVoidAsync("SignaturePad.drawImage", "signatureCanvas", detail.SignatureData);

        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task ClosePurchaseModal()
    {
        _showPurchaseModal = false;
        await JS.InvokeVoidAsync("SignaturePad.dispose", "signatureCanvas");
    }

    void AddPurchaseItem()
    {
        _purchaseItems.Add(new PurchaseItemModel { RegistrarId = _currentPersonId ?? 0 });
    }

    void AddPaymentMethod()
    {
        _purchasePaymentMethods.Add(new PaymentMethodModel());
    }

    void RemovePurchaseItem(int idx)
    {
        if (_purchaseItems.Count > 1)
            _purchaseItems.RemoveAt(idx);
    }

    void SetItemType(int idx, string type)
    {
        _purchaseItems[idx].ItemType = type;
        if (type == "Course") _purchaseItems[idx].HoursBought = 0;
    }

    bool HasValidPurchaseItems()
    {
        return _purchaseItems.Any(item =>
            (item.ItemType == "Auditing" && (item.HoursBought > 0 || item.AmountPaid > 0)) ||
            (item.ItemType == "Course" && item.CourseId > 0 && item.AmountPaid > 0));
    }

    async Task SavePurchase()
    {
        _purchaseError = "";

        // Validate items
        foreach (var item in _purchaseItems)
        {
            if (item.ItemType == "Course" && item.CourseId <= 0)
            { _purchaseError = LS.T("pcs.errorSelectCourse"); return; }
            if (item.ItemType == "Auditing" && item.HoursBought <= 0 && item.AmountPaid <= 0)
            { _purchaseError = LS.T("pcs.errorEnterHoursOrAmount"); return; }
            if (item.ItemType == "Course" && item.AmountPaid <= 0)
            { _purchaseError = LS.T("pcs.errorEnterAmount"); return; }
        }

        // Get signature — required
        string? sigData = await JS.InvokeAsync<string?>("SignaturePad.getDataUrl", "signatureCanvas");
        if (string.IsNullOrEmpty(sigData))
        { _purchaseError = LS.T("pcs.signatureRequired"); return; }

        var items = _purchaseItems.Select(pi => (
            itemType:    pi.ItemType,
            courseId:    pi.ItemType == "Course" ? (int?)pi.CourseId : null,
            hoursBought: pi.ItemType == "Auditing" ? pi.HoursBought : 0,
            amountPaid:  pi.AmountPaid,
            registrarId: pi.RegistrarId > 0 ? (int?)pi.RegistrarId : null,
            referralId:  pi.ReferralId > 0 ? (int?)pi.ReferralId : null
        )).ToList();

        var pmList = _purchasePaymentMethods
            .Where(m => m.Amount > 0)
            .Select(m => (m.MethodType, m.Amount, paymentDate: m.PaymentDate?.ToString("yyyy-MM-dd")))
            .ToList();

        if (_editingPurchaseId.HasValue)
        {
            // Check if anything changed
            if (GetPurchaseSnapshot() == _origPurchaseSnapshot)
            {
                _purchaseError = LS.T("purchases.nothingChanged");
                return;
            }
            PcSvc.UpdatePurchase(_editingPurchaseId.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                items, pmList);
        }
        else
        {
            PcSvc.CreatePurchase(
                _selPcId!.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                sigData,
                _currentPersonId,
                items, pmList);

            // Send automatic message to admins about the purchase
            if (_currentPersonId.HasValue && _detail != null)
            {
                var totalAmt = items.Sum(i => i.amountPaid);
                var totalHrs = items.Where(i => i.itemType == "Auditing").Sum(i => i.hoursBought);
                var msg = $"Automatic msg: New purchase for {_detail.FullName}";
                if (totalHrs > 0) msg += $" — {totalHrs}h";
                if (totalAmt > 0) msg += $" — \u20AA{totalAmt}";
                DashSvc.SendAutoMessageToAdmins(_currentPersonId.Value, msg);
            }
        }

        await ClosePurchaseModal();
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    async Task ClearSignature()
    {
        await JS.InvokeVoidAsync("SignaturePad.clear", "signatureCanvas");
    }

    async Task PrintPurchase()
    {
        string? sigData = await JS.InvokeAsync<string?>("SignaturePad.getDataUrl", "signatureCanvas");

        var printItems = _purchaseItems.Select(pi => new
        {
            itemType = pi.ItemType,
            courseName = pi.ItemType == "Course" && pi.CourseId > 0
                ? _allCourses.FirstOrDefault(c => c.CourseId == pi.CourseId)?.Name ?? "Course"
                : "",
            hoursBought = pi.HoursBought,
            amountPaid = pi.AmountPaid,
            registrarName = pi.RegistrarId > 0
                ? _staff.FirstOrDefault(s => s.PersonId == pi.RegistrarId).FullName ?? ""
                : "",
            referralName = pi.ReferralId > 0
                ? _allPersons.FirstOrDefault(p => p.PersonId == pi.ReferralId).FullName ?? ""
                : ""
        }).ToArray();

        await JS.InvokeVoidAsync("PrintPurchase.printReceipt",
            _detail!.FullName,
            _purchaseDate.ToString("dd/MM/yyyy"),
            printItems,
            string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
            sigData);
    }

    void ConfirmDeletePurchase()
    {
        if (!_confirmDeletePurchaseId.HasValue) return;
        PcSvc.DeletePurchase(_confirmDeletePurchaseId.Value);
        _confirmDeletePurchaseId = null;
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    // Decimal hours label for PC list (e.g. "3:48" / "-1:25")
    static string HrsLabel(long secs)
    {
        var sign = secs < 0 ? "-" : "";
        var abs  = Math.Abs(secs);
        var h    = abs / 3600;
        var m    = (abs % 3600) / 60;
        return $"{sign}{h}:{m:D2}";
    }

    // H:MM from seconds — integer arithmetic, always exact
    static string Hmm(int secs)
    {
        int s = Math.Abs(secs);
        return $"{s / 3600}:{(s % 3600) / 60:00}";
    }
    static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;

    // H:MM for a signed long (e.g. hours remaining can be negative)
    static string HmmSigned(long secs)
    {
        long s = Math.Abs(secs);
        string t = $"{s / 3600}:{(s % 3600) / 60:00}";
        return secs < 0 ? $"-{t}" : t;
    }
}
