    /* Reset Budget button + tooltip */
    .pc-reset-budget-wrap {
        position: relative; display: inline-block;
    }
    .pc-reset-budget-btn {
        display: inline-flex; align-items: center; gap: 3px;
        border: 1.5px solid #f59e0b; background: transparent;
        color: #f59e0b; font-size: .75rem; font-weight: 500;
        cursor: pointer; padding: 4px 10px; border-radius: 6px;
        transition: all .18s ease;
        min-height: 32px;
    }
    .pc-reset-budget-btn i { font-size: .85rem; }
    .pc-reset-budget-btn:hover {
        background: #f59e0b; color: #000; box-shadow: 0 0 12px rgba(245,158,11,.35);
    }
    .pc-reset-tooltip {
        display: none; position: absolute; left: 50%; top: calc(100% + 10px);
        transform: translateX(-50%); z-index: 1100;
        width: 320px; padding: 16px; border-radius: 10px;
        background: #1e293b; border: 1.5px solid #f59e0b;
        box-shadow: 0 8px 32px rgba(0,0,0,.45);
        color: #cbd5e1; font-size: .82rem; line-height: 1.45;
        opacity: 0;
        animation: resetTooltipIn .25s ease forwards;
    }
    .pc-reset-budget-wrap:hover .pc-reset-tooltip {
        display: block;
    }
    .pc-reset-tooltip-title {
        color: #f59e0b; font-weight: 700; font-size: .88rem; margin-bottom: 8px;
    }
    .pc-reset-tooltip p { margin: 0 0 8px 0; }
    .pc-reset-tooltip-example {
        background: #0f172a; border-radius: 6px; padding: 8px 10px;
        border-left: 3px solid #f59e0b; font-size: .8rem;
    }
    @@keyframes resetTooltipIn {
        from { opacity: 0; transform: translateX(-50%) translateY(6px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }

    /* Reset success animation */
    .reset-success-overlay {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 48px 24px; text-align: center;
        animation: resetSuccessFadeIn .4s ease;
    }
    .reset-success-icon {
        width: 80px; height: 80px; border-radius: 50%;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        display: flex; align-items: center; justify-content: center;
        margin-bottom: 18px;
        animation: resetSuccessPop .5s cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 0 0 0 rgba(245,158,11,.4);
        animation: resetSuccessPop .5s cubic-bezier(.34,1.56,.64,1), resetSuccessGlow 1.2s ease-in-out .4s infinite alternate;
    }
    .reset-success-icon i {
        font-size: 2.4rem; color: #000;
    }
    .reset-success-title {
        color: #f59e0b; font-size: 1.4rem; font-weight: 800; letter-spacing: .03em;
        margin-bottom: 6px;
        animation: resetSuccessSlideUp .5s ease .15s both;
    }
    .reset-success-sub {
        color: #94a3b8; font-size: .88rem;
        animation: resetSuccessSlideUp .5s ease .3s both;
    }
    @@keyframes resetSuccessFadeIn {
        from { opacity: 0; } to { opacity: 1; }
    }
    @@keyframes resetSuccessPop {
        0%   { transform: scale(0); }
        100% { transform: scale(1); }
    }
    @@keyframes resetSuccessGlow {
        from { box-shadow: 0 0 0 0 rgba(245,158,11,.4); }
        to   { box-shadow: 0 0 24px 8px rgba(245,158,11,.2); }
    }
    @@keyframes resetSuccessSlideUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* Solo confirm modal icon */
    .pc-solo-confirm-icon {
        width: 52px; height: 52px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto; font-size: 1.5rem; color: #fff;
        box-shadow: 0 4px 14px rgba(234,88,12,.3);
    }

    /* ── Purchase button ── */
    .pc-purchase-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: #1e293b; color: #fff; border: none; border-radius: 10px;
        padding: 7px 16px; font-size: 0.82rem; font-weight: 600;
        cursor: pointer; position: relative; z-index: 0; overflow: visible;
        transition: transform .2s ease;
    }
    .pc-purchase-btn::before {
        content: '';
        position: absolute; inset: -1.5px; border-radius: 12px;
        background: linear-gradient(270deg, #6366f1, #3b82f6, #06b6d4, #6366f1);
        background-size: 300% 300%;
        animation: pcPurchaseGlow 6s ease infinite;
        z-index: -1; opacity: .6;
    }
    .pc-purchase-btn::after {
        content: '';
        position: absolute; inset: 0; border-radius: 10px;
        background: #1e293b; z-index: -1;
    }
    .pc-purchase-btn i {
        display: inline-block;
        animation: pcCartNudge 3s ease-in-out infinite;
    }
    .pc-purchase-btn:hover { transform: translateY(-1px); }
    .pc-purchase-btn:hover::before { opacity: 1; }
    @@keyframes pcPurchaseGlow {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    @@keyframes pcCartNudge {
        0%, 85%, 100% { transform: translateX(0) rotate(0); }
        88%  { transform: translateX(-2px) rotate(-4deg); }
        91%  { transform: translateX(2px) rotate(4deg); }
        94%  { transform: translateX(-1px) rotate(-2deg); }
        97%  { transform: translateX(0) rotate(0); }
    }

    /* ── Left panel table ── */
    .pc-list-table th { font-size:0.7rem; font-weight:700; letter-spacing:.03em; text-transform:uppercase; white-space:nowrap; }
    .pc-list-table td { vertical-align:middle; }
    .pc-th-sort { cursor:pointer; user-select:none; position:relative; padding-right:16px !important; }
    /* Allow specific narrow headers to wrap onto 2 lines instead of forcing nowrap */
    .pc-list-table th.pc-th-wrap,
    .pc-list-table thead th.pc-th-wrap { white-space: normal !important; line-height: 1.15; word-break: normal; }
    .pc-th-sort::after { content:''; display:inline-block; width:0; height:0; border-left:4px solid transparent;
                         border-right:4px solid transparent; margin-left:4px; vertical-align:middle; opacity:0.3;
                         border-bottom:4px solid currentColor; }
    .pc-th-sort.sort-asc::after { border-bottom:4px solid currentColor; border-top:none; opacity:0.8; }
    .pc-th-sort.sort-desc::after { border-bottom:none; border-top:4px solid currentColor; opacity:0.8; }

    .purchases-card { border: none; border-radius: 14px; overflow: hidden; }

    /* Force readable colors inside tables with hardcoded light-background rows */
