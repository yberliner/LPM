    async Task OpenEditPurchase(int purchaseId)
    {
        var detail = PcSvc.GetPurchaseDetail(purchaseId);
        if (detail == null) return;

        _showPurchaseModal = true;
        _editingPurchaseId = purchaseId;
        _purchaseError     = "";
        _skipSignature     = string.IsNullOrEmpty(detail.SignatureData);
        _hasSigned         = !string.IsNullOrEmpty(detail.SignatureData);
        _allCourses        = CourseSvc.GetAllCourses();
        _allBooks          = CourseSvc.GetAllBooks();

        _purchaseDate = DateTime.TryParse(detail.PurchaseDate, out var dt) ? dt : DateTime.Today;
        _purchaseNotes = detail.Notes ?? "";
        _purchaseCurrency = detail.Currency;

        _purchaseRegistrarId = detail.RegistrarId ?? 0;
        _purchaseReferralId  = detail.ReferralId ?? 0;
        _purchaseItems = detail.Items.Select(it =>
        {
            var m = new PurchaseItemModel
            {
                ItemType    = it.ItemType,
                CourseId    = it.CourseId ?? 0,
                BookId      = it.BookId ?? 0,
                HoursBought = it.HoursBought,
                AmountPaid  = it.AmountPaid
            };
            if (it.ItemType == "Auditing")
            {
                double absHrs = Math.Abs(it.HoursBought);
                int wh = (int)absHrs;
                int wm = (int)Math.Round((absHrs - wh) * 60);
                if (wm >= 60) { wh++; wm = 0; }
                m.HoursH = wh.ToString();
                m.HoursM = wm.ToString("D2");
                m.IsNegativeHours = it.HoursBought < 0;
                m.RatePerHour = it.HoursBought != 0 ? (int)Math.Abs(it.AmountPaid / it.HoursBought) : 0;
            }
            return m;
        }).ToList();
        if (_purchaseItems.Count == 0)
            _purchaseItems.Add(new PurchaseItemModel());

        // Merge installment rows back: group CreditCard rows with Installments > 1 by contiguous monthly dates
        var rawPms = detail.PaymentMethods.ToList();
        var mergedPms = new List<PaymentMethodModel>();
        var used = new HashSet<int>();
        for (int pi = 0; pi < rawPms.Count; pi++)
        {
            if (used.Contains(pi)) continue;
            var pm = rawPms[pi];
            if (pm.MethodType == "CreditCard" && pm.Installments > 1)
            {
                // Find all consecutive CC rows with same Installments value
                var group = new List<PurchasePaymentMethodInfo> { pm };
                used.Add(pi);
                for (int pj = pi + 1; pj < rawPms.Count; pj++)
                {
                    if (used.Contains(pj)) continue;
                    var next = rawPms[pj];
                    if (next.MethodType == "CreditCard" && next.Installments == pm.Installments)
                    { group.Add(next); used.Add(pj); }
                    else break;
                }
                var totalAmt = group.Sum(g => g.Amount);
                var earliest = group.Min(g => g.PaymentDate);
                mergedPms.Add(new PaymentMethodModel
                {
                    MethodType = "CreditCard", Amount = totalAmt, Installments = pm.Installments,
                    PaymentDate = DateTime.TryParse(earliest, out var epdt) ? epdt : null
                });
            }
            else
            {
                used.Add(pi);
                mergedPms.Add(new PaymentMethodModel
                {
                    MethodType = pm.MethodType, Amount = pm.Amount, Installments = pm.Installments,
                    PaymentDate = DateTime.TryParse(pm.PaymentDate, out var pdt) ? pdt : null
                });
            }
        }
        _purchasePaymentMethods = mergedPms;
        if (_purchasePaymentMethods.Count == 0)
            _purchasePaymentMethods.Add(new PaymentMethodModel());

        StateHasChanged();
        await Task.Delay(100);
        if (!_skipSignature)
        {
            await InitSignaturePad();
            if (!string.IsNullOrEmpty(detail.SignatureData))
                await JS.InvokeVoidAsync("SignaturePad.drawImage", "signatureCanvas", detail.SignatureData);
        }

        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

