    // Decimal hours label for PC list (e.g. "3:48" / "-1:25")
    static string HrsLabel(long secs)
    {
        var sign = secs < 0 ? "-" : "";
        var abs  = Math.Abs(secs);
        var h    = abs / 3600;
        var m    = (abs % 3600) / 60;
        return $"{sign}{h}:{m:D2}";
    }

    // H:MM from seconds — integer arithmetic, always exact
    static string Hmm(int secs)
    {
        int s = Math.Abs(secs);
        return $"{s / 3600}:{(s % 3600) / 60:00}";
    }
    // Rounded: 30+ leftover seconds → +1 minute
    static string HmmRound(int secs)
    {
        int s = Math.Abs(secs);
        int totalMin = s / 60 + (s % 60 >= 30 ? 1 : 0);
        return $"{totalMin / 60}:{totalMin % 60:00}";
    }
    // Exact with seconds for tooltip
    static string Hmmss(int secs)
    {
        int s = Math.Abs(secs);
        return $"{s / 3600}:{(s % 3600) / 60:00}:{s % 60:00}";
    }
    static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;

    static string FormatCreatedAt(string createdAt) =>
        DateTime.TryParse(createdAt, out var dt) ? dt.ToString("dd/MM/yy") : createdAt;

    static readonly string[] _dateFmts = { "dd/MM/yy", "d/M/yy", "dd/MM/yyyy", "d/M/yyyy", "yyyy-MM-dd" };
    static DateTime? ParseDateInput(string? val)
    {
        if (string.IsNullOrWhiteSpace(val)) return null;
        return DateTime.TryParseExact(val, _dateFmts,
            System.Globalization.CultureInfo.InvariantCulture,
            System.Globalization.DateTimeStyles.None, out var d) ? d : null;
    }

