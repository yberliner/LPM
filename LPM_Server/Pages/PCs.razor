    /// Formats an amount: whole numbers as "42", fractional as "42<small>.50</small>"
    static MarkupString FmtAmt(double amount)
    {
        var abs = Math.Abs(amount);
        var whole = (int)abs;
        var frac = abs - whole;
        var sign = amount < 0 ? "-" : "";
        if (frac < 0.005)
            return new MarkupString($"{sign}{whole}");
        return new MarkupString($"{sign}{whole}<span style=\"font-size:.72em;opacity:.7;\">.{(int)Math.Round(frac * 100):D2}</span>");
    }

    /// Plain-text version for use in string interpolation (success toasts, logs)
    static string FmtAmtText(double amount)
    {
        var abs = Math.Abs(amount);
        var whole = (int)abs;
        var frac = abs - whole;
        var sign = amount < 0 ? "-" : "";
        if (frac < 0.005) return $"{sign}{whole}";
        return $"{sign}{whole}.{(int)Math.Round(frac * 100):D2}";
    }

    IEnumerable<PcListItemEx> FilteredPcsEx
    {
        get
        {
            var list = string.IsNullOrWhiteSpace(_search)
                ? _allPcsEx.AsEnumerable()
                : _allPcsEx.Where(p =>
                    p.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    p.Nick.Contains(_search, StringComparison.OrdinalIgnoreCase));

            if (_filterHasSessions)
                list = list.Where(p => p.TotalSessions > 0);

            if (_filterOrgId.HasValue)
            {
                var fid = _filterOrgId.Value;
                list = fid == 0
                    ? list.Where(p => p.OrgId == 0)
                    : list.Where(p => p.OrgId == fid);
            }

            list = (_sortCol, _sortAsc) switch
            {
                ("name", true)       => list.OrderBy(p => p.FullName),
                ("name", false)      => list.OrderByDescending(p => p.FullName),
                ("balance", true)    => list.OrderBy(p => _balances.TryGetValue(p.PcId, out var b) ? b.BalanceNis : 0m),
                ("balance", false)   => list.OrderByDescending(p => _balances.TryGetValue(p.PcId, out var b) ? b.BalanceNis : 0m),
                ("hoursLeft", true)  => list.OrderBy(p => _balances.TryGetValue(p.PcId, out var b) ? b.HoursLeft : 0),
                ("hoursLeft", false) => list.OrderByDescending(p => _balances.TryGetValue(p.PcId, out var b) ? b.HoursLeft : 0),
                ("totalTime", true)  => list.OrderBy(p => p.TotalSessionSec),
                ("totalTime", false) => list.OrderByDescending(p => p.TotalSessionSec),
                ("sessions", true)   => list.OrderBy(p => p.AuditorSessions),
                ("sessions", false)  => list.OrderByDescending(p => p.AuditorSessions),
                ("visits", true)     => list.OrderBy(p => p.AcademyVisits),
                ("visits", false)    => list.OrderByDescending(p => p.AcademyVisits),
                ("purchased", true)  => list.OrderBy(p => p.HoursPurchased),
                ("purchased", false) => list.OrderByDescending(p => p.HoursPurchased),
                ("auditor", true)    => list.OrderBy(p => p.Auditor),
                ("auditor", false)   => list.OrderByDescending(p => p.Auditor),
                ("org", true)        => list.OrderBy(p => string.IsNullOrEmpty(p.OrgName) ? "\uFFFF" : p.OrgName),
                ("org", false)       => list.OrderByDescending(p => string.IsNullOrEmpty(p.OrgName) ? "" : p.OrgName),
                _ => list.OrderBy(p => _balances.TryGetValue(p.PcId, out var b) ? b.HoursLeft : 0)
            };

            return list;
        }
    }

