    void SetItemType(int idx, string type)
    {
        var item = _purchaseItems[idx];
        var prev = item.ItemType;
        item.ItemType = type;
        if (type != "Course") item.CourseId = 0;
        if (type != "Book") item.BookId = 0;
        if (type == "Auditing" && item.RatePerHour == 0)
        {
            int defRate = _selPcId.HasValue && _balances.TryGetValue(_selPcId.Value, out var b) ? b.PurchaseRateCents / 100 : 0;
            item.RatePerHour = defRate;
        }
        if (prev != type) item.AmountPaid = 0;
        if (type == "Auditing" && prev != "Auditing") RecalcAuditing(item);
    }

    void AutoFillBookPrice(PurchaseItemModel item)
    {
        if (item.AmountPaid != 0) return;
        var book = _allBooks.FirstOrDefault(b => b.BookId == item.BookId);
        if (book != null) item.AmountPaid = book.Price;
    }

    void AutoFillCoursePrice(PurchaseItemModel item)
    {
        if (item.AmountPaid != 0) return;
        var course = _allCourses.FirstOrDefault(c => c.CourseId == item.CourseId);
        if (course != null && course.Price > 0) item.AmountPaid = course.Price;
    }

    bool HasValidPurchaseItems()
    {
        return _purchaseItems.Any(IsItemValid);
    }

    bool IsItemValid(PurchaseItemModel item)
    {
        return (item.ItemType == "Auditing" && (int.TryParse(item.HoursH, out var _h) && _h > 0 || int.TryParse(item.HoursM, out var _m) && _m > 0) && item.RatePerHour > 0) ||
               (item.ItemType == "Course" && item.CourseId > 0) ||
               (item.ItemType == "Book" && item.BookId > 0);
    }

    bool CanAddMoreItems()
    {
        // Only allow adding a new item if the last one is valid
        return _purchaseItems.Count == 0 || IsItemValid(_purchaseItems[^1]);
    }

    bool CanAddMorePayments()
    {
        // Only allow adding a new payment if the last one has an amount
        return _purchasePaymentMethods.Count == 0 || _purchasePaymentMethods[^1].Amount != 0;
    }

    bool IsPaymentBalanced()
    {
        var itemsTotal = (int)Math.Round(_purchaseItems.Sum(x => x.AmountPaid));
        var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
        return pmTotal == itemsTotal;
    }

    List<string> GetSaveBlockReasons()
    {
        var reasons = new List<string>();
        // Check items validity
        if (!_purchaseItems.Any())
            reasons.Add("No items added");
        else
        {
            for (int i = 0; i < _purchaseItems.Count; i++)
            {
                var item = _purchaseItems[i];
                var num = i + 1;
                if (item.ItemType == "Auditing")
                {
                    bool hasH = int.TryParse(item.HoursH, out var h) && h > 0;
                    bool hasM = int.TryParse(item.HoursM, out var m) && m > 0;
                    if (!hasH && !hasM)
                        reasons.Add($"Item #{num}: enter hours or minutes");
                    if (item.RatePerHour <= 0)
                        reasons.Add($"Item #{num}: enter rate per hour");
                }
                else if (item.ItemType == "Course" && item.CourseId <= 0)
                    reasons.Add($"Item #{num}: select a course");
                else if (item.ItemType == "Book" && item.BookId <= 0)
                    reasons.Add($"Item #{num}: select a book");
            }
            if (!HasValidPurchaseItems())
                if (!reasons.Any()) reasons.Add("No valid items");
        }
        // Check payment balance
        var itemsTotalRaw = _purchaseItems.Sum(x => x.AmountPaid);
        var itemsTotal = (int)Math.Round(itemsTotalRaw);
        var itemsTotalStr = FmtAmtText(itemsTotalRaw);
        var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
        if (pmTotal != itemsTotal)
        {
            var diff = itemsTotal - pmTotal;
            if (pmTotal == 0)
                reasons.Add($"No payments entered (need {CurrSym(_purchaseCurrency)}{itemsTotalStr})");
            else
            {
                var underpaid = itemsTotal == 0 ? diff > 0 : Math.Sign(diff) == Math.Sign(itemsTotal);
                var label = underpaid ? "Underpaid" : "Overpaid";
                reasons.Add($"{label} by {CurrSym(_purchaseCurrency)}{Math.Abs(diff)} ({CurrSym(_purchaseCurrency)}{pmTotal} of {CurrSym(_purchaseCurrency)}{itemsTotalStr})");
            }
        }
        return reasons;
    }

    async Task SavePurchase()
    {
        _purchaseError = "";

        // Validate items
        foreach (var item in _purchaseItems)
        {
            if (item.ItemType == "Course" && item.CourseId <= 0)
            { _purchaseError = LS.T("pcs.errorSelectCourse"); return; }
            if (item.ItemType == "Auditing" && (!(int.TryParse(item.HoursH, out var _sh) && _sh > 0 || int.TryParse(item.HoursM, out var _sm) && _sm > 0) || item.RatePerHour <= 0))
            { _purchaseError = LS.T("pcs.errorEnterHoursOrAmount"); return; }
            if (item.ItemType == "Book" && item.BookId <= 0)
            { _purchaseError = "Please select a book"; return; }
        }
        // Validate credit card installments have a date
        foreach (var pm in _purchasePaymentMethods)
        {
            if (pm.MethodType == "CreditCard" && pm.Installments > 1 && pm.PaymentDate == null)
            { _purchaseError = "Credit card installments require a start date"; return; }
        }

        // Get signature — required unless skipped
        string? sigData = _skipSignature ? null
            : await JS.InvokeAsync<string?>("SignaturePad.getDataUrl", "signatureCanvas");
        if (!_skipSignature && string.IsNullOrEmpty(sigData))
        { _purchaseError = LS.T("pcs.signatureRequired"); return; }

        var items = _purchaseItems.Select(pi => (
            itemType:    pi.ItemType,
            courseId:    pi.ItemType == "Course" ? (int?)pi.CourseId : null,
            bookId:     pi.ItemType == "Book" ? (int?)pi.BookId : null,
            hoursBought: pi.ItemType == "Auditing" ? pi.HoursBought : 0.0,
            amountPaid:  pi.AmountPaid
        )).ToList();

        int? regId = _purchaseRegistrarId > 0 ? _purchaseRegistrarId : null;
        int? refId = _purchaseReferralId != 0 ? _purchaseReferralId : null;

        var pmList = _purchasePaymentMethods
            .Where(m => m.Amount != 0)
            .Select(m => (m.MethodType, m.Amount, paymentDate: m.PaymentDate?.ToString("yyyy-MM-dd"), m.Installments))
            .ToList();

        if (_editingPurchaseId.HasValue)
        {
            // Check if anything changed
            if (GetPurchaseSnapshot() == _origPurchaseSnapshot)
            {
                _purchaseError = LS.T("purchases.nothingChanged");
                return;
            }
            var itemsLog = string.Join("; ", items.Select(x => x.itemType == "Course" ? $"Course(id={x.courseId}) {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}" : x.itemType == "Book" ? $"Book(id={x.bookId}) {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}" : $"Auditing {x.hoursBought}h {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}"));
            var pmLog    = string.Join("; ", pmList.Select(m => $"{m.MethodType} {CurrSym(_purchaseCurrency)}{m.Amount} on {m.paymentDate}"));
            Console.WriteLine($"[PCs] Updated purchase {_editingPurchaseId.Value} for PC {_selPcId} date={_purchaseDate:yyyy-MM-dd} items=[{itemsLog}] payments=[{pmLog}] reg={regId} ref={refId} notes='{_purchaseNotes}' by '{_username}'");
            PcSvc.UpdatePurchase(_editingPurchaseId.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                items, pmList, regId, refId, _purchaseCurrency,
                walletId: _purchaseWalletId > 0 ? _purchaseWalletId : null);
        }
        else
        {
            var itemsLog = string.Join("; ", items.Select(x => x.itemType == "Course" ? $"Course(id={x.courseId}) {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}" : x.itemType == "Book" ? $"Book(id={x.bookId}) {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}" : $"Auditing {x.hoursBought}h {CurrSym(_purchaseCurrency)}{(int)Math.Round(x.amountPaid)}"));
            var pmLog    = string.Join("; ", pmList.Select(m => $"{m.MethodType} {CurrSym(_purchaseCurrency)}{m.Amount} on {m.paymentDate}"));
            Console.WriteLine($"[PCs] Created purchase for PC {_selPcId!.Value} date={_purchaseDate:yyyy-MM-dd} items=[{itemsLog}] payments=[{pmLog}] reg={regId} ref={refId} notes='{_purchaseNotes}' by '{_username}'");
            PcSvc.CreatePurchase(
                _selPcId!.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                sigData,
                _currentPersonId,
                items, pmList, regId, refId, _purchaseCurrency,
                walletId: _purchaseWalletId > 0 ? _purchaseWalletId : null);

            // Send automatic message to admins about the purchase
            if (_currentPersonId.HasValue && _detail != null)
            {
                var totalAmt = (int)Math.Round(items.Sum(i => i.amountPaid));
                var totalHrs = items.Where(i => i.itemType == "Auditing").Sum(i => i.hoursBought);
                var msg = $"Automatic msg: New purchase for {_detail.FullName}";
                if (totalHrs != 0) msg += $" — {FormatHoursMinutes(totalHrs)}h";
                if (totalAmt > 0) msg += $" — {CurrSym(_purchaseCurrency)}{totalAmt}";
                DashSvc.SendAutoMessageToAdmins(_currentPersonId.Value, msg);
            }
        }

        // Build success summary before closing
        static string Enc(string? s) => System.Net.WebUtility.HtmlEncode(s ?? "");
        var successPcName = Enc(_detail?.FullName);
        var successItems = new List<string>();
        foreach (var pi in _purchaseItems)
        {
            if (pi.ItemType == "Auditing" && pi.HoursBought != 0)
                successItems.Add(Enc($"{(pi.IsNegativeHours ? "-" : "")}{FormatHoursMinutes(pi.HoursBought)} Auditing — {CurrSym(_purchaseCurrency)}{FmtAmtText(pi.AmountPaid)}"));
            else if (pi.ItemType == "Course" && pi.CourseId > 0)
                successItems.Add(Enc($"Course — {CurrSym(_purchaseCurrency)}{FmtAmtText(pi.AmountPaid)}"));
            else if (pi.ItemType == "Book" && pi.BookId > 0)
                successItems.Add(Enc($"Book — {CurrSym(_purchaseCurrency)}{FmtAmtText(pi.AmountPaid)}"));
        }
        var successTotal = Enc(FmtAmtText(_purchaseItems.Sum(x => x.AmountPaid)));
        var isEdit = _editingPurchaseId.HasValue;
        _purchaseSuccessHtml = $"<div class='pcs-success-name'>{successPcName}</div>"
            + string.Join("", successItems.Select(s => $"<div class='pcs-success-item'>{s}</div>"))
            + $"<div class='pcs-success-total'>Total: {Enc(CurrSym(_purchaseCurrency))}{successTotal}</div>"
            + $"<div class='pcs-success-badge'>{(isEdit ? "Updated" : "Created")}</div>";

        await ClosePurchaseModal();

        // Refresh data immediately so the UI shows updated values behind the toast
        _allPcsEx = PcSvc.GetAllPcsExtended();
        _balances = PcSvc.GetAllPcBalances();
        LoadWalletBalancesForAll();
        _mixedCurrencyPcs = PcSvc.GetPcsWithMixedCurrencies();
        _mixedRates = PcSvc.GetPcsWithMixedRates();
        _sessionMixedRates = PcSvc.GetPcsWithMixedSessionRatesIn30Days();
        LoadDetail();

        _showPurchaseSuccess = true;
        StateHasChanged();
        await Task.Delay(3500);
