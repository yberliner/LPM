                                                <td class="text-center">
                                                    @if (isActive)
                                                    {
                                                        <button class="btn btn-sm btn-outline-success py-0 px-2"
                                                                @onclick="() => AskFinishCourse(e.StudentCourseId, e.CourseName)">
                                                            <i class="ri-check-line me-1"></i>@LS.T("pcs.markDone")
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm border-0 py-0 px-2"
                                                                style="background:#d1fae5;color:#065f46;font-size:.7rem;"
                                                                @onclick="() => AskReopenCourse(e.StudentCourseId, e.CourseName)">
                                                            <i class="ri-check-double-line me-1"></i>@LS.T("pcs.done")
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            }
                        </details>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Finish Course Confirmation ── *@
@if (_confirmFinishCourseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-check-double-line text-success" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmFinishCourseTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmFinishCourseMsg", _confirmFinishCourseName)</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmFinishCourseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-success px-3" @onclick="ConfirmFinishCourse">
                            <i class="ri-check-line me-1"></i>@LS.T("pcs.markDone")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (_confirmReopenCourseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-arrow-go-back-line text-warning" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmReopenCourseTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmReopenCourseMsg", _confirmReopenCourseName)</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmReopenCourseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-warning px-3" @onclick="ConfirmReopenCourse">
                            <i class="ri-arrow-go-back-line me-1"></i>@LS.T("pcs.reopen")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Balance Explanation Modal ── *@
@if (_showBalanceModal && _balanceExplanation != null)
{
    var ex = _balanceExplanation;
    var balCurr = ex.Purchases.FirstOrDefault()?.Currency ?? "ILS";
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060;" @onclick="CloseBalanceModal">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content bal-modal">
                @* Header *@
                <div class="bal-modal-header">
                    <div class="bal-modal-icon"><i class="ri-calculator-line"></i></div>
                    <div style="flex:1;min-width:0;">
                        <div class="bal-modal-title">@LS.T("pcs.balanceBreakdown")</div>
                        <div class="bal-modal-subtitle">@_balancePcName</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseBalanceModal"></button>
                </div>

                <div class="modal-body p-0" style="max-height:70vh;overflow-y:auto;">
                    @{ var balResetDate = ex.ResetDate; }
                    @if (balResetDate != null)
                    {
                        <div style="background:linear-gradient(135deg,#7c2d12,#1e293b);border-bottom:3px solid #f59e0b;padding:18px 24px;display:flex;align-items:center;gap:16px;">
                            <i class="ri-restart-line" style="color:#f59e0b;font-size:2.4rem;flex-shrink:0;"></i>
                            <div style="flex:1;">
                                <div style="color:#fbbf24;font-weight:800;font-size:1.25rem;letter-spacing:.3px;">
                                    Budget Reset: @FormatDate(balResetDate)
                                </div>
                                <div style="color:#e2e8f0;font-size:.85rem;margin-top:3px;">
                                    Balance calculated from this date forward.
                                    <span style="color:#94a3b8;">Earlier sessions shown faded below.</span>
                                </div>
                            </div>
                        </div>
                    }
                    @* ── Purchases (grouped per wallet) ── *@
                    <div class="bal-section bal-sec-purchased">
                        <div class="bal-sec-title"><i class="ri-shopping-cart-2-line"></i> @LS.T("pcs.auditingPurchases")</div>
                        @if (ex.Purchases.Any())
                        {
                            @foreach (var wGrp in ex.Purchases.GroupBy(p => (p.WalletId, p.WalletName, p.Currency))
                                                  .OrderBy(g => g.Key.WalletId ?? int.MaxValue))
                            {
                                var walletLabel = wGrp.Key.WalletName ?? "(no wallet)";
                                var wGrpCurr    = wGrp.Key.Currency;
                                var wGrpTotal   = wGrp.Sum(p => p.AmountNis);
                                <div class="px-3 py-1 d-flex align-items-center gap-2" style="background:#ecfdf5;border-top:1px solid #d1fae5;">
                                    <span style="display:inline-flex; align-items:center; gap:5px; padding:2px 8px; border-radius:999px; font-size:0.72rem; font-weight:700; background:#dbeafe; color:#1e40af;">
                                        <span style="font-weight:900; font-size:0.9rem;">@CurrSym(wGrpCurr)</span>
                                        @walletLabel
                                        <span style="opacity:.7; font-weight:500;">(@wGrpCurr)</span>
                                    </span>
                                </div>
                                <table class="table table-sm mb-0">
                                    <thead><tr>
                                        <th class="small" style="color:#166534;">@LS.T("pcs.date")</th>
                                        <th class="small text-center" style="color:#166534;">@LS.T("pcs.hours")</th>
                                        <th class="small text-end" style="color:#166534;">@LS.T("pcs.amount")</th>
                                    </tr></thead>
                                    <tbody>
                                        @foreach (var p in wGrp)
                                        {
                                            <tr>
                                                <td class="small">@FormatDate(p.Date)</td>
                                                <td class="small text-center">@(p.Hours < 0 ? "-" : "")@FormatHoursMinutes(p.Hours)</td>
                                                <td class="small text-end fw-semibold" style="color:@(p.AmountNis >= 0 ? "#16a34a" : "#dc2626");">@CurrSym(p.Currency)@(p.AmountNis.ToString("N0"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr style="background:#dcfce7;">
                                            <td class="small fw-bold" style="color:#166534;" colspan="2">Subtotal</td>
                                            <td class="small fw-bold text-end" style="color:#166534;">
                                                @($"{CurrSym(wGrpCurr)}{wGrpTotal:N0}")
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            }
                        }
                        else
                        {
                            <div class="small text-muted px-3 py-2">@LS.T("pcs.noAuditingPurchases")</div>
                        }
                    </div>

                    @* ── Per-wallet balance grid ── *@
                    @{ var walletBals = _pcWalletBalances.GetValueOrDefault(_balancePcId) ?? new(); }
                    @if (walletBals.Count > 0)
                    {
                        <div class="bal-section">
                            <div class="bal-sec-title"><i class="ri-wallet-3-line"></i> Per-wallet balance</div>
                            <table class="table table-sm mb-0">
                                <thead><tr>
                                    <th class="small">Wallet</th>
                                    <th class="small text-end">Purchased</th>
                                    <th class="small text-end">Used (sessions)</th>
                                    <th class="small text-end">Remaining</th>
                                    <th class="small text-end">Rate /hr</th>
                                    <th class="small text-end">Hours left</th>
                                </tr></thead>
                                <tbody>
                                    @foreach (var wb in walletBals)
                                    {
                                        <tr>
                                            <td class="small">
                                                <span style="display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:999px; font-size:0.72rem; font-weight:700; background:#dbeafe; color:#1e40af;">
                                                    <span style="font-weight:900;">@CurrSym(wb.Currency)</span>
                                                    @wb.Name
                                                    <span style="opacity:.7; font-weight:500;">(@wb.Currency)</span>
                                                </span>
                                            </td>
                                            <td class="small text-end">@CurrSym(wb.Currency)@((wb.PurchasedCents / 100.0).ToString("N0"))</td>
                                            <td class="small text-end text-muted">@CurrSym(wb.Currency)@(((wb.UsedSessionCents + wb.UsedCsReviewCents) / 100.0).ToString("N0"))</td>
                                            <td class="small text-end fw-bold" style="color:@(wb.RemainingCents >= 0 ? "#16a34a" : "#dc2626");">@CurrSym(wb.Currency)@((wb.RemainingCents / 100.0).ToString("N0"))</td>
                                            <td class="small text-end">@(wb.EffectiveRateCentsPerHour > 0 ? $"{CurrSym(wb.Currency)}{wb.EffectiveRateCentsPerHour / 100}" : "—")</td>
                                            <td class="small text-end">@(wb.EffectiveRateCentsPerHour > 0 ? HrsLabel((long)(wb.RemainingHours * 3600)) : "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* ── Used Money ── *@
                    <div class="bal-section bal-sec-used">
                        <div class="bal-sec-title"><i class="ri-time-line"></i> @LS.T("pcs.usedMoney") <span class="badge bg-secondary ms-1">@(ex.BillableSessionCount + ex.SoloReviewCount) @LS.T("pcs.sessions")</span></div>
                        <div class="d-flex justify-content-between align-items-center px-3 py-2">
                            <span class="small" style="color:#991b1b;">@LS.T("pcs.totalSessionCost")</span>
                            <span class="fw-bold" style="color:#dc2626;">-@CurrSym(balCurr)@(ex.TotalUsedNis.ToString("N2"))</span>
                        </div>
                    </div>

                    @* ── Balance Result ── *@
                    <div class="bal-result-card">
                        <div class="bal-result-label">@LS.T("pcs.balance")</div>
                        <div class="bal-result-value" style="color:@(ex.BalanceNis >= 0 ? "#16a34a" : "#dc2626");">
                            @CurrSym(balCurr)@(ex.BalanceNis.ToString("N2"))
                        </div>
                    </div>

                    @* ── Hours Calculation ── *@
                    <div class="bal-section bal-sec-hours">
                        <div class="bal-sec-title"><i class="ri-hourglass-line"></i> @LS.T("pcs.hoursRemaining")</div>
                        <div class="bal-formula px-3 py-2">
                            <span class="bal-formula-item">@CurrSym(balCurr)@(ex.BalanceNis.ToString("N2"))</span>
                            <span class="bal-formula-op">&divide;</span>
                            <span class="bal-formula-item">@CurrSym(balCurr)@(ex.EffectiveRateCents / 100)/hr</span>
                            <span class="bal-formula-op">=</span>
                            <span class="bal-formula-result">@(ex.EffectiveRateCents > 0 ? $"{(ex.HoursLeft < 0 ? "-" : "")}{FormatHoursMinutes(ex.HoursLeft)}" : "\u2014")</span>
                        </div>
                        <div class="px-3 pb-2 small">
                            <span style="color:#475569;">@LS.T("pcs.rateUsed"): <strong>@CurrSym(balCurr)@(ex.EffectiveRateCents / 100)/hr</strong></span>
                            <span class="text-muted ms-1">(@ex.RateSource)</span>
                            @if (ex.PurchaseRateCents > 0 && ex.EffectiveRateCents != ex.PurchaseRateCents)
                            {
                                <div class="mt-1">
                                    <span class="badge bal-badge-warn">
                                        <i class="ri-alert-line"></i>
                                        @LS.T("pcs.purchaseRate"): @CurrSym(balCurr)@(ex.PurchaseRateCents / 100)/hr
                                    </span>
                                </div>
                            }
                        </div>
                    </div>

                    @* ── Session Details Toggle ── *@
                    <div class="d-flex align-items-center justify-content-center gap-3 py-3">
                        <button class="btn bal-sessions-btn" @onclick="ToggleSessionDetails">
                            <i class="@(_balShowSessions ? "ri-arrow-up-s-line" : "ri-list-check")"></i>
                            @(_balShowSessions ? LS.T("pcs.hideSessions") : LS.T("pcs.showAllSessions"))
                        </button>
                        @if (_balShowSessions)
                        {
                            <label class="form-check form-check-inline mb-0" style="cursor:pointer;font-size:.78rem;">
                                <input class="form-check-input" type="checkbox" checked="@_balHideImported"
                                       @onchange="e => _balHideImported = (bool)(e.Value ?? false)" />
                                <span class="text-muted">Hide imported</span>
                            </label>
                        }
                    </div>

                    @* ── Session Detail Table ── *@
                    @if (_balShowSessions && _balSessionDetails != null)
                    {
                        <div class="bal-sessions-detail" style="animation:balSlideIn .3s ease;">
                            <table class="table table-sm mb-0">
                                <thead class="table-light" style="position:sticky;top:0;">
                                    <tr>
                                        <th class="small text-center">#</th>
                                        <th class="small">@LS.T("pcs.date")</th>
                                        <th class="small">@LS.T("pcs.auditor")</th>
                                        <th class="small">Wallet</th>
                                        <th class="small text-center">@LS.T("pcs.duration")</th>
                                        <th class="small text-center">@LS.T("pcs.admin")</th>
                                        <th class="small text-center">@LS.T("pcs.rateLabel")</th>
                                        <th class="small text-center">@LS.T("pcs.source")</th>
                                        <th class="small text-center">Imported</th>
                                        <th class="small text-end">@LS.T("pcs.cost")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int rowIdx = 0; var filteredSessions = _balHideImported ? _balSessionDetails.Where(s => !s.IsImported) : _balSessionDetails; }
                                    @foreach (var s in filteredSessions)
                                    {
                                        var baseBg = rowIdx++ % 2 == 0 ? "#fafafa" : "#fff";
                                        var rowBg  = s.IsBeforeReset ? "#f1f5f9" : baseBg;
                                        var rowStyle = $"background:{rowBg};" + (s.IsBeforeReset ? "opacity:.45;filter:grayscale(.6);" : "") + "cursor:pointer;";
                                        <tr style="@rowStyle" title="@(s.IsBeforeReset ? "Before budget reset — not counted in current balance · Click to open in Session Manager" : "Click to open in Session Manager")"
                                            @onclick="() => OpenSessionFromBalance(s.SessionId)">
                                            <td class="small text-center text-muted">@s.SessionId</td>
                                            <td class="small">@FormatDate(s.Date)</td>
                                            <td class="small">@s.AuditorName</td>
                                            <td class="small">
                                                @if (s.WalletId.HasValue)
                                                {
                                                    <span class="badge" style="background:@WltBg(s.Currency); color:@WltFg(s.Currency); font-weight:600; white-space:nowrap;">
                                                        @CurrSym(s.Currency) @(s.WalletName ?? "—") (@s.Currency)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="small text-center" title="@Hmmss(s.LengthSec)">@HmmRound(s.LengthSec)</td>
                                            <td class="small text-center" title="@Hmmss(s.AdminSec)">@HmmRound(s.AdminSec)</td>
                                            <td class="small text-center">@CurrSym(s.Currency)@(s.RateCentsUsed / 100)</td>
                                            <td class="small text-center"><span class="badge @RateBadgeClass(s.RateSource)">@s.RateSource</span></td>
                                            <td class="small text-center">
                                                @if (s.IsBeforeReset)
                                                {
                                                    <span class="badge" style="background:#fef3c7;color:#92400e;font-size:.62rem;" title="Before budget reset">pre</span>
                                                }
                                                else if (s.IsImported)
                                                {
                                                    <i class="ri-download-cloud-line" style="color:#6366f1;" title="Imported session"></i>
                                                }
                                            </td>
                                            <td class="small text-end fw-semibold" style="color:#dc2626;">@CurrSym(s.Currency)@(s.CostNis.ToString("N2"))</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @* ── Solo CS Review Detail Table ── *@
                    @if (_balShowSessions && _balSoloDetails != null && _balSoloDetails.Count > 0)
                    {
                        <div class="bal-sessions-detail" style="animation:balSlideIn .3s ease; margin-top:8px;">
                            <div class="px-3 py-2 fw-semibold small" style="color:#7c3aed; border-bottom:1px solid #ede9fe;">
                                <i class="ri-user-line me-1"></i> Solo CS Reviews
                                <span class="badge ms-1" style="background:#7c3aed;">@_balSoloDetails.Count</span>
                            </div>
                            <table class="table table-sm mb-0">
                                <thead class="table-light" style="position:sticky;top:0;">
                                    <tr>
                                        <th class="small text-center">#</th>
                                        <th class="small">@LS.T("pcs.date")</th>
                                        <th class="small">Wallet</th>
                                        <th class="small text-center">@LS.T("pcs.duration")</th>
                                        <th class="small text-center">@LS.T("pcs.rateLabel")</th>
                                        <th class="small text-center">Imported</th>
                                        <th class="small text-end">@LS.T("pcs.cost")</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int soloIdx = 0; var filteredSolo = _balHideImported ? _balSoloDetails.Where(sr => !sr.IsImported) : _balSoloDetails; }
                                    @foreach (var sr in filteredSolo)
                                    {
                                        var baseSoloBg = soloIdx++ % 2 == 0 ? "#f5f3ff" : "#ede9fe";
                                        var soloBg = sr.IsBeforeReset ? "#e2e8f0" : baseSoloBg;
                                        var soloOpacity = sr.IsBeforeReset ? "opacity:.45;filter:grayscale(.6);" : (sr.IsFree ? "opacity:.7;" : "");
                                        <tr style="background:@soloBg;@(soloOpacity)cursor:pointer;"
                                            title="@(sr.IsBeforeReset ? "Before budget reset — not counted in current balance · Click to open in Session Manager" : "Click to open in Session Manager")"
                                            @onclick="() => OpenSessionFromBalance(sr.SessionId)">
                                            <td class="small text-center text-muted">@sr.SessionId</td>
                                            <td class="small">@FormatDate(sr.Date)</td>
                                            <td class="small">
                                                @if (sr.WalletId.HasValue)
                                                {
                                                    <span class="badge" style="background:@WltBg(sr.Currency); color:@WltFg(sr.Currency); font-weight:600; white-space:nowrap;">
                                                        @CurrSym(sr.Currency) @(sr.WalletName ?? "—") (@sr.Currency)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td class="small text-center" title="@Hmmss(sr.ReviewLengthSec)">@HmmRound(sr.ReviewLengthSec)</td>
                                            <td class="small text-center">@CurrSym(sr.Currency)@(sr.RateCents / 100)</td>
                                            <td class="small text-center">
                                                @if (sr.IsBeforeReset)
                                                {
                                                    <span class="badge" style="background:#fef3c7;color:#92400e;font-size:.62rem;" title="Before budget reset">pre</span>
                                                }
                                                else if (sr.IsImported)
                                                {
                                                    <i class="ri-download-cloud-line" style="color:#6366f1;" title="Imported session"></i>
                                                }
                                            </td>
                                            <td class="small text-end fw-semibold" style="color:@(sr.IsFree ? "#10b981" : "#7c3aed");">
                                                @if (sr.IsFree)
                                                {
                                                    <span class="badge" style="background:#d1fae5;color:#065f46;font-size:.65rem;">Free</span>
                                                }
                                                else
                                                {
                                                    @($"{CurrSym(sr.Currency)}{sr.CostNis:N2}")
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Column Guide Modal ── *@
@if (_showColumnGuide)
{
    <div class="cg-overlay" @onclick="() => _showColumnGuide = false">
        <div class="cg-box" @onclick:stopPropagation="true">
            <div class="cg-hdr">
                <span><i class="ri-book-open-line me-2"></i>Column Guide</span>
                <button class="cg-close" @onclick="() => _showColumnGuide = false"><i class="ri-close-line"></i></button>
            </div>
            <div class="cg-body">
                <div class="cg-sec cg-sec-name">
                    <div class="cg-title"><i class="ri-user-3-line me-1"></i>PC Name</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Full name of the PC (client)</span>
                        <span class="cg-lbl">Solo PCs</span><span>Shown in <strong style="color:#ea580c !important;">orange</strong> with an <strong>S</strong> badge — they work independently without an auditor</span>
                        <span class="cg-lbl">Nickname</span><span>Appears in parentheses when set</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-balance">
                    <div class="cg-title"><i class="ri-money-dollar-circle-line me-1"></i>Balance (₪)</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Formula</span><span><strong>Total Purchased ₪ &minus; Total Used ₪</strong></span>
                        <span class="cg-lbl">Purchased</span><span>Sum of all AmountPaid from auditing purchases</span>
                        <span class="cg-lbl">Used (Sessions)</span><span>For each non-solo, non-free session: Rate &times; (Length + Admin) &divide; 3600. Rate falls back to previous session rate, then purchase rate</span>
                        <span class="cg-lbl">Used (Solo CS)</span><span>For each solo CS review with rate &gt; 0 and Notes = <strong>"Bill"</strong>: <strong>Rate &times; ReviewLength &divide; 3600</strong>. Rate = 0 means not yet billable (set in Sessions page).<br/>
                            Reviews marked <strong style="color:#10b981 !important;">"Free"</strong> or with no notes (old data) are <strong>not charged</strong> — cost = 0</span>
                        <span class="cg-lbl">Color</span><span><strong style="color:#16a34a !important;">Green</strong> = positive &nbsp; <strong style="color:#dc2626 !important;">Red</strong> = owes money</span>
                    </div>
                    <div class="cg-example">
                        <strong>Example:</strong> Purchased ₪5,000. Sessions cost ₪3,200. Solo CS reviews cost ₪400.<br/>
                        ₪5,000 &minus; ₪3,200 &minus; ₪400 = <strong style="color:#16a34a !important;">₪1,400</strong>
                    </div>
                </div>
                <div class="cg-sec cg-sec-hours">
                    <div class="cg-title"><i class="ri-hourglass-line me-1"></i>Hours Left</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Formula</span><span><strong>Balance ₪ &divide; Effective Rate (₪/hr)</strong></span>
                        <span class="cg-lbl">Effective Rate</span><span>Rate from the last session with ChargedRate &gt; 0. If none, falls back to last purchase rate (AmountPaid &divide; HoursBought)</span>
                        <span class="cg-lbl">Rate Mismatch</span><span>If session rate &ne; purchase rate, a <strong style="color:#92400e !important;">warning</strong> appears — hover to see both rates</span>
                    </div>
                    <div class="cg-example">
                        <strong>Example:</strong> Balance = ₪1,400. Last session rate = ₪200/hr.<br/>
                        ₪1,400 &divide; ₪200/hr = <strong style="color:#1e40af !important;">7:00</strong>
                    </div>
                </div>
                <div class="cg-sec cg-sec-time">
                    <div class="cg-title"><i class="ri-time-line me-1"></i>Total Sessions Time</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Sum of LengthSeconds from all non-free sessions with an auditor, as H:MM</span>
                        <span class="cg-lbl">Excludes</span><span>Solo sessions (AuditorId = NULL) are <strong>not</strong> included</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-sess">
                    <div class="cg-title"><i class="ri-hashtag me-1"></i># Sessions</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Count of non-free sessions with an auditor</span>
                        <span class="cg-lbl">Excludes</span><span>Solo sessions (AuditorId = NULL) are <strong>not</strong> counted</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-acad">
                    <div class="cg-title"><i class="ri-book-2-line me-1"></i>Acad Visits</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Total academy attendance records for this PC</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-purch">
                    <div class="cg-title"><i class="ri-shopping-cart-2-line me-1"></i>Hours Purchased</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Sum of HoursBought from all auditing purchases (non-deleted)</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-aud">
                    <div class="cg-title"><i class="ri-user-star-line me-1"></i>Auditor</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Shows</span><span>Auditor from the most recent session. Shows "—" if none</span>
                    </div>
                </div>
                <div class="cg-sec cg-sec-detail">
                    <div class="cg-title"><i class="ri-calculator-line me-1"></i>Balance Details (₪ icon)</div>
                    <div class="cg-grid">
                        <span class="cg-lbl">Purchases</span><span>Each purchase with date, hours, and amount</span>
                        <span class="cg-lbl">Used Money</span><span>Total cost: regular sessions + solo CS reviews marked "Bill" (reviews marked "Free" or with no notes are excluded)</span>
                        <span class="cg-lbl">Balance</span><span>Purchased minus used</span>
                        <span class="cg-lbl">Hours Left</span><span>Balance &divide; effective rate</span>
                        <span class="cg-lbl">Session Details</span><span>Per-session cost, rate used, and rate source</span>
                        <span class="cg-lbl">Solo Reviews</span><span>Shown separately in purple — date, duration, rate, cost. Reviews marked "Free" appear with a green <strong style="color:#065f46 !important;">Free</strong> badge and cost = 0. Only "Bill" reviews are charged.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ── Page container ── */
    .pc-page-container { display: flex; flex-direction: column; height: calc(100vh - 60px); min-height: 0; }
    .pc-table-wrapper { overflow-y: auto; flex: 1; min-height: 0; }
    .pc-table-drawer-open { display: none; }

    /* ── Bottom Drawer ── */
    .pc-drawer {
        display: none; flex-direction: column;
        background: var(--custom-white, #fff);
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        border: 1px solid rgba(0,0,0,.06);
        overflow: hidden; flex: 1; min-height: 0;
    }
    .pc-drawer-open { display: flex; }
    .pc-drawer-open + .pc-nothing { display: none; } /* placeholder */
