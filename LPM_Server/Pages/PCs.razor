    /* ── Purchase modal sections ── */
    .purchase-section {
        background: #f9fafb;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 14px;
    }
    .purchase-section-title {
        font-size: 0.82rem;
        font-weight: 700;
        color: #374151;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .purchase-section-title i { font-size: 1rem; }

    /* ── Item card validation states ── */
    .purchase-item-card { border-radius: 10px; transition: all 0.25s ease; }

    /* ── Purchase success toast ── */
    .pcs-success-overlay {
        position: fixed; inset: 0; z-index: 1060;
        display: flex; align-items: center; justify-content: center;
        background: rgba(0,0,0,.35); backdrop-filter: blur(3px);
        animation: pcsSuccessFadeIn .3s ease, pcsSuccessFadeOut .8s ease 2.7s forwards;
    }
    .pcs-success-card {
        background: #fff; border-radius: 18px; padding: 28px 36px;
        box-shadow: 0 12px 48px rgba(0,0,0,.2);
        text-align: center; min-width: 260px; max-width: 400px;
        animation: pcsSuccessScale .4s cubic-bezier(.34,1.56,.64,1);
    }
    .pcs-success-icon { font-size: 2.8rem; color: #22c55e; display: block; margin-bottom: 10px; }
    .pcs-success-name { font-size: 1.2rem; font-weight: 800; color: #1e293b; margin-bottom: 8px; }
    .pcs-success-item { font-size: .82rem; color: #475569; padding: 2px 0; }
    .pcs-success-total { font-size: 1rem; font-weight: 700; color: #1e40af; margin-top: 10px; }
    .pcs-success-badge {
        display: inline-block; margin-top: 10px;
        background: #dcfce7; color: #166534; font-size: .72rem; font-weight: 600;
        padding: 3px 12px; border-radius: 12px;
    }
    @@keyframes pcsSuccessFadeIn { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes pcsSuccessFadeOut { from { opacity: 1; } to { opacity: 0; } }
    @@keyframes pcsSuccessScale { from { transform: scale(.7); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .purchase-item-valid { border: 1px solid #d1d5db; }
    .purchase-item-invalid { border: 1.5px solid #f87171 !important; background: #fef2f2; }

    .item-number-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 50%;
        background: #e0e7ff; color: #3b5998; font-size: 0.72rem; font-weight: 700;
    }
    .purchase-item-invalid .item-number-badge { background: #fee2e2; color: #dc2626; }

    .item-incomplete-hint {
        font-size: 0.7rem; color: #ef4444; display: inline-flex; align-items: center; gap: 3px;
        animation: hint-pulse 2s ease-in-out infinite;
    }
    @@keyframes hint-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Field-level validation */
    .field-invalid { border-color: #f87171 !important; background-color: #fff5f5 !important; }
    .field-valid { border-color: #86efac !important; }

    /* Items summary bar */
    .items-summary {
        display: flex; align-items: center; gap: 12px;
        padding: 6px 12px; border-radius: 8px;
        background: #eff6ff; font-size: 0.78rem; color: #1e40af;
    }
    .items-summary i { font-size: 0.85rem; }

    /* Signature reminder in footer */
    .signature-reminder {
        font-size: 0.75rem; color: #b45309;
        background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px;
        padding: 4px 10px; display: inline-flex; align-items: center; gap: 5px;
        animation: hint-pulse 2s ease-in-out infinite;
    }

    /* ── Save button disabled tooltip ── */
    .save-btn-wrap {
        position: relative;
        display: inline-block;
    }
    .save-btn-disabled {
        opacity: 0.55 !important;
        cursor: not-allowed !important;
        animation: saveBtnPulse 2.5s ease-in-out infinite;
    }
    @@keyframes saveBtnPulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(59,130,246,0); }
        50% { box-shadow: 0 0 0 6px rgba(59,130,246,0.15); }
    }
    .save-block-tooltip {
        display: none;
        position: absolute;
        bottom: calc(100% + 10px);
        right: 0;
        min-width: 270px;
        max-width: 340px;
        background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        color: #e2e8f0;
        border-radius: 12px;
        padding: 0;
        box-shadow: 0 8px 32px rgba(0,0,0,.35), 0 0 0 1px rgba(255,255,255,.06);
        z-index: 1100;
        overflow: hidden;
        animation: saveTooltipIn .35s cubic-bezier(.34,1.56,.64,1);
    }
    .save-btn-wrap:hover .save-block-tooltip,
    .save-btn-wrap:focus-within .save-block-tooltip {
        display: block;
    }
    .save-block-tooltip::after {
        content: '';
        position: absolute;
        bottom: -6px;
        right: 22px;
        width: 12px;
        height: 12px;
        background: #0f172a;
        transform: rotate(45deg);
        border-radius: 0 0 3px 0;
    }
    .save-block-header {
        display: flex;
        align-items: center;
        gap: 7px;
        padding: 10px 14px;
        font-weight: 700;
        font-size: .82rem;
        color: #fbbf24;
        background: rgba(251,191,36,.08);
        border-bottom: 1px solid rgba(255,255,255,.06);
    }
    .save-block-header i {
        font-size: 1rem;
        animation: lockShake 2s ease-in-out infinite;
    }
    @@keyframes lockShake {
        0%, 85%, 100% { transform: rotate(0); }
        88% { transform: rotate(-8deg); }
        92% { transform: rotate(8deg); }
        96% { transform: rotate(-4deg); }
    }
    .save-block-reason {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 7px 14px;
        font-size: .78rem;
        line-height: 1.35;
        border-bottom: 1px solid rgba(255,255,255,.04);
        animation: reasonSlideIn .4s ease both;
    }
    .save-block-reason:last-child { border-bottom: none; }
    .save-block-reason:nth-child(2) { animation-delay: .05s; }
    .save-block-reason:nth-child(3) { animation-delay: .1s; }
    .save-block-reason:nth-child(4) { animation-delay: .15s; }
    .save-block-reason:nth-child(5) { animation-delay: .2s; }
    .save-block-reason i {
        color: #f87171;
        font-size: .85rem;
        flex-shrink: 0;
        margin-top: 1px;
        animation: reasonIconPop .3s cubic-bezier(.34,1.56,.64,1) both;
    }
    .save-block-reason:nth-child(2) i { animation-delay: .1s; }
    .save-block-reason:nth-child(3) i { animation-delay: .15s; }
    .save-block-reason:nth-child(4) i { animation-delay: .2s; }
    .save-block-reason:nth-child(5) i { animation-delay: .25s; }
    @@keyframes saveTooltipIn {
        from { opacity: 0; transform: translateY(6px) scale(.95); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    @@keyframes reasonSlideIn {
        from { opacity: 0; transform: translateX(10px); }
        to   { opacity: 1; transform: translateX(0); }
    }
    @@keyframes reasonIconPop {
        from { transform: scale(0); }
        to   { transform: scale(1); }
    }

    /* Payment summary bar */
    .payment-summary {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px 12px; border-radius: 8px;
        background: #f0fdf4; font-size: 0.78rem; color: #166534;
    }

    /* Force dark text inside white-bg modals (purchase modal, delete confirm) */
    .modal-content:not(.cg-modal) .form-label { color: #212529 !important; }
    .modal-content:not(.cg-modal) .form-control,
    .modal-content:not(.cg-modal) .form-select { color: #212529 !important; background-color: #fff !important; border-color: #dee2e6 !important; }
    .modal-content:not(.cg-modal) .form-control::placeholder { color: #6c757d !important; }
    .modal-content:not(.cg-modal) .fw-semibold { color: #212529; }
    .modal-content:not(.cg-modal) .btn-close { filter: none; }
    .modal-content:not(.cg-modal) .modal-footer { border-color: #dee2e6; color: #212529; }
    .modal-content:not(.cg-modal) .card { background: #fff; color: #212529; }
    .modal-content:not(.cg-modal) .card-body { color: #212529; }

    /* ── Resizable columns (JS-driven — see lpmInitColResize) ── */
    .pc-list-table { min-width: 100%; }
    .pc-col-name { min-width: 100px; }
    /* th position:relative set by JS; overflow-x auto on the wrapper allows horizontal scroll */
    .pc-list-table thead th { white-space: nowrap; }

    /* ── Send SMS button ── */
    .pc-sms-btn {
        display: inline-flex; align-items: center; gap: 5px;
        background: rgba(99,102,241,.1);
        color: #6366f1;
        border: 1.5px solid rgba(99,102,241,.35);
        border-radius: 20px;
        padding: 4px 12px; font-size: 0.75rem; font-weight: 700;
        cursor: pointer; transition: all .18s ease;
        letter-spacing: .03em; text-transform: uppercase;
        min-height: 30px; touch-action: manipulation;
        backdrop-filter: blur(4px);
    }
    .pc-sms-btn:hover {
        background: #6366f1; color: #fff;
        border-color: #6366f1;
        box-shadow: 0 4px 14px rgba(99,102,241,.4);
        transform: translateY(-1px);
    }
    .pc-sms-btn:active { transform: translateY(0); box-shadow: none; }
    .pc-sms-btn i { font-size: .85rem; }
    .pc-sms-btn:hover i { animation: smsPlaneLaunch .5s ease; }
    @@keyframes smsPlaneLaunch {
        0%   { transform: translate(0,0) rotate(0); opacity: 1; }
        50%  { transform: translate(6px,-6px) rotate(10deg); opacity: .7; }
        100% { transform: translate(0,0) rotate(0); opacity: 1; }
    }

    /* ── SMS Modal ── */
    .sms-modal-content {
        border: none; border-radius: 20px;
        background: #fff; color: #1e293b;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        overflow: hidden;
    }
    .sms-modal-header {
        display: flex; align-items: center; gap: 14px;
        padding: 20px 22px 16px;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
    }
    .sms-modal-icon {
        width: 44px; height: 44px; flex-shrink: 0; border-radius: 12px;
        background: rgba(255,255,255,.2); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
    }
    .sms-modal-title { font-size: 1.1rem; font-weight: 700; color: #fff; line-height: 1.2; }
    .sms-modal-subtitle { font-size: .75rem; color: rgba(255,255,255,.75); }

    .sms-recipient-card {
        display: flex; align-items: center; gap: 14px;
        background: #f8faff; border: 1.5px solid #e0e7ff;
        border-radius: 14px; padding: 14px 16px;
    }
    .sms-recipient-avatar {
        width: 46px; height: 46px; flex-shrink: 0; border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #0ea5e9);
        color: #fff; font-size: 1.2rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 3px 10px rgba(99,102,241,.3);
    }
    .sms-recipient-info { flex: 1; min-width: 0; }
    .sms-recipient-name { font-size: 1rem; font-weight: 700; color: #1e293b; }
    .sms-recipient-phone { font-size: .82rem; color: #6366f1; font-weight: 500; margin-top: 3px; }
    .sms-no-phone {
        font-size: .82rem; color: #ef4444; font-weight: 500; margin-top: 3px;
        background: #fef2f2; border-radius: 6px; padding: 4px 8px; display: inline-flex; align-items: center;
    }

    .sms-textarea {
        border: 1.5px solid #e0e7ff; border-radius: 12px;
        font-size: .9rem; resize: vertical; min-height: 110px;
        font-size: 16px; /* prevent iOS auto-zoom */
        transition: border-color .2s;
    }
    .sms-textarea:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); }

    .sms-char-count { font-size: .72rem; color: #94a3b8; }
    .sms-char-warn { color: #f59e0b; font-weight: 600; }

    .sms-dir-toggle {
        display: inline-flex; align-items: center; gap: 4px;
        background: #f1f5f9; border: 1px solid #e2e8f0;
        color: #64748b; font-size: .7rem; font-weight: 700;
        padding: 3px 9px; border-radius: 20px; cursor: pointer;
        transition: all .15s ease; letter-spacing: .04em;
        text-transform: uppercase;
    }
    .sms-dir-toggle:hover { background: #6366f1; color: #fff; border-color: #6366f1; }
    .sms-dir-toggle i { font-size: .85rem; }

    .sms-modal-footer {
        background: #f8faff; border-top: 1px solid #e0e7ff;
        padding: 14px 22px; display: flex; justify-content: flex-end; gap: 10px;
    }

    .pc-sms-send-btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
        color: #fff; border: none; border-radius: 10px;
        padding: 9px 22px; font-size: .88rem; font-weight: 700;
        cursor: pointer; transition: all .2s ease; min-height: 44px;
        box-shadow: 0 3px 12px rgba(99,102,241,.3);
    }
    .pc-sms-send-btn:disabled { opacity: .55; cursor: not-allowed; transform: none; box-shadow: none; }
    .pc-sms-send-btn:not(:disabled):hover { transform: translateY(-1px); box-shadow: 0 5px 18px rgba(99,102,241,.45); }

    /* ── SMS Success Overlay ── */
    .sms-success-overlay {
        position: fixed; inset: 0; z-index: 2000;
        background: rgba(0,0,0,.6); backdrop-filter: blur(6px);
        display: flex; align-items: center; justify-content: center;
        animation: smsOverlayIn .3s ease;
        cursor: pointer;
    }
    @@keyframes smsOverlayIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    .sms-success-card {
        background: #fff; border-radius: 24px;
        padding: 40px 48px; text-align: center;
        box-shadow: 0 30px 80px rgba(0,0,0,.35);
        animation: smsCardIn .4s cubic-bezier(.34,1.56,.64,1);
        min-width: 280px; max-width: 360px;
        cursor: default;
    }
    @@keyframes smsCardIn {
        from { transform: scale(.7) translateY(30px); opacity: 0; }
        to   { transform: scale(1) translateY(0);     opacity: 1; }
    }
    .sms-success-burst {
        position: relative; display: inline-block; margin-bottom: 16px;
    }
    .sms-checkmark {
        width: 72px; height: 72px;
        display: block; margin: 0 auto;
        filter: drop-shadow(0 4px 16px rgba(16,185,129,.4));
    }
    .sms-checkmark-circle {
        stroke: #10b981; stroke-width: 2; stroke-dasharray: 166; stroke-dashoffset: 166;
        animation: smsCircleDraw .6s ease forwards;
    }
    .sms-checkmark-path {
        stroke: #10b981; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
        stroke-dasharray: 48; stroke-dashoffset: 48;
        animation: smsCheckDraw .4s .5s ease forwards;
    }
    @@keyframes smsCircleDraw { to { stroke-dashoffset: 0; } }
    @@keyframes smsCheckDraw  { to { stroke-dashoffset: 0; } }

    .sms-success-title {
        font-size: 1.6rem; font-weight: 800;
        background: linear-gradient(135deg, #10b981, #0ea5e9);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
        animation: smsTitlePop .4s .8s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-pc {
        font-size: 1.05rem; font-weight: 700; color: #1e293b;
        margin-bottom: 4px;
        animation: smsTitlePop .4s .9s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-phone {
        font-size: .9rem; color: #6366f1; font-weight: 600;
        animation: smsTitlePop .4s 1s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-hint {
        margin-top: 18px; font-size: .72rem; color: #94a3b8;
        animation: smsTitlePop .4s 1.1s ease both;
    }
    @@keyframes smsTitlePop {
        from { opacity: 0; transform: translateY(10px) scale(.95); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Tablet / Mobile responsive ── */
    @@media (max-width: 768px) {
        .pc-sms-btn, .pc-purchase-btn { font-size: .78rem; padding: 6px 12px; }
        .sms-success-card { padding: 32px 24px; min-width: 240px; }
        .sms-success-title { font-size: 1.3rem; }
    }
    @@media (max-width: 480px) {
        .sms-modal-content { border-radius: 16px; }
        .sms-modal-header { padding: 16px; }
        .sms-recipient-card { padding: 12px; }
        .sms-checkmark { width: 60px; height: 60px; }
        .sms-success-title { font-size: 1.2rem; }
    }

    /* ── Auditing H:M inputs — hide spin arrows ── */
    .aud-hm-input::-webkit-inner-spin-button,
    .aud-hm-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    .aud-hm-input { -moz-appearance: textfield; }

    /* ── Auditing negative adjustment checkbox ── */
    .aud-neg-check { font-size: .78rem; color: #6b7280; transition: all .15s ease; }
    .aud-neg-active { color: #dc2626; font-weight: 600; }
    .aud-neg-active .form-check-input { background-color: #dc2626; border-color: #dc2626; }

    /* ── Seconds chip (read-only, derived from Calc from ₪) ── */
    .aud-sec-dot {
        color: #cbd5e1;
        font-size: 1.1rem;
        margin: 0 2px;
        user-select: none;
        line-height: 1;
        opacity: .55;
    }
    .aud-sec-wrap {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 1px;
        padding: 2px 3px;
        background: #eef2ff;
        border: 1px dashed #c7d2fe;
        border-radius: 6px;
        cursor: help;
        transition: background .15s ease;
        width: 34px;
        flex: 0 0 auto;
    }
    .aud-sec-wrap:hover { background: #e0e7ff; }
    .aud-sec-input {
        background: transparent !important;
        color: #4f46e5 !important;
        border: none !important;
        box-shadow: none !important;
        font-family: ui-monospace, "Courier New", monospace !important;
        font-size: 12px !important;
        font-weight: 700 !important;
        line-height: 1 !important;
        display: block !important;
        width: 26px !important;
        min-width: 0 !important;
        max-width: 26px !important;
        padding: 1px 0 !important;
        height: auto !important;
        text-align: center;
        letter-spacing: .5px;
        cursor: not-allowed !important;
        font-variant-numeric: tabular-nums;
        flex: 0 0 auto !important;
    }
    .aud-sec-input:focus { box-shadow: none !important; }
    .aud-sec-tag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 1px;
        font-size: 8px;
        font-weight: 700;
        color: #6366f1;
        letter-spacing: .4px;
        text-transform: uppercase;
        line-height: 1;
        white-space: nowrap;
        user-select: none;
    }
    .aud-sec-tag i { font-size: 8px; }

    /* ── Reverse-calc button + animation ── */
    .rev-calc-btn {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 4px 10px;
        font-size: .72rem;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, #6366f1 0%, #14b8a6 100%);
        border: none;
        border-radius: 999px;
        cursor: pointer;
        overflow: visible;
        box-shadow: 0 2px 6px rgba(99,102,241,.25);
        animation: revCalcBreath 3s ease-in-out infinite;
        transition: transform .15s ease, box-shadow .15s ease;
    }
    .rev-calc-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(99,102,241,.4);
    }
    .rev-calc-btn:active { transform: translateY(0) scale(.97); }
    .rev-calc-btn.rev-calc-disabled {
        background: #cbd5e1;
        color: #64748b;
        cursor: not-allowed;
        animation: none;
        box-shadow: none;
        pointer-events: none;
    }
    .rev-calc-icon { display: inline-flex; font-size: .85rem; }
    .rev-calc-label { font-size: .7rem; letter-spacing: .2px; }
    .rev-calc-shimmer {
        position: absolute;
        inset: 0;
        overflow: hidden;
        border-radius: 999px;
        pointer-events: none;
    }
    .rev-calc-shimmer::before {
        content: "";
        position: absolute;
        top: 0; left: -60%;
        width: 40%; height: 100%;
        background: linear-gradient(115deg, transparent 20%, rgba(255,255,255,.45) 50%, transparent 80%);
        animation: revCalcShimmer 6s ease-in-out infinite;
    }
    @@keyframes revCalcBreath {
        0%, 100% { box-shadow: 0 2px 6px rgba(99,102,241,.25); }
        50%      { box-shadow: 0 2px 14px rgba(20,184,166,.55); }
    }
    @@keyframes revCalcShimmer {
        0%   { left: -60%; }
        60%  { left: 120%; }
        100% { left: 120%; }
    }

    /* ── Reverse-calc hover tooltip (mini demo) ── */
    .rev-calc-tooltip {
        position: absolute;
        bottom: calc(100% + 8px);
        left: 50%;
        transform: translateX(-50%) translateY(4px);
        background: #0f172a;
        color: #e2e8f0;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: .7rem;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity .18s ease, transform .18s ease;
        box-shadow: 0 8px 24px rgba(15,23,42,.35);
        z-index: 1080;
    }
    .rev-calc-tooltip::after {
        content: "";
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: #0f172a;
    }
    .rev-calc-btn:hover .rev-calc-tooltip {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }
    .rev-calc-demo {
        display: flex;
        align-items: center;
        gap: 6px;
        justify-content: center;
        font-weight: 700;
    }
    .rev-calc-demo-amt {
        color: #fbbf24;
        animation: revDemoAmt 3s ease-in-out infinite;
    }
    .rev-calc-demo-arrow {
        color: #a78bfa;
        animation: revDemoArrow 3s ease-in-out infinite;
    }
    .rev-calc-demo-time {
        color: #34d399;
        font-variant-numeric: tabular-nums;
        animation: revDemoTime 3s ease-in-out infinite;
    }
    .rev-calc-tooltip-sub {
        display: block;
        font-size: .62rem;
        color: #94a3b8;
        font-weight: 400;
        margin-top: 3px;
        text-align: center;
    }
    @@keyframes revDemoAmt {
        0%, 20%  { opacity: 1; transform: translateX(0); }
        45%, 55% { opacity: .3; transform: translateX(-4px); }
        80%,100% { opacity: 1; transform: translateX(0); }
    }
    @@keyframes revDemoArrow {
        0%, 30%  { opacity: .4; }
        50%      { opacity: 1; }
        70%,100% { opacity: .4; }
    }
    @@keyframes revDemoTime {
        0%, 35%  { opacity: .3; transform: translateX(4px); }
        55%, 80% { opacity: 1; transform: translateX(0); }
        100%     { opacity: .3; transform: translateX(4px); }
    }

    /* ── Reverse-calc popover ── */
    .rev-calc-popover {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        min-width: 210px;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px;
        box-shadow: 0 12px 32px rgba(15,23,42,.18);
        z-index: 1090;
        animation: revCalcPopIn .18s cubic-bezier(.34,1.56,.64,1);
    }
    .rev-calc-pop-title { font-size: .72rem; font-weight: 600; color: #475569; margin-bottom: 4px; }
    .rev-calc-input { font-size: 16px !important; }
    .rev-calc-pop-actions { display: flex; gap: 6px; justify-content: flex-end; margin-top: 8px; }
    .rev-calc-pop-hint { margin-top: 6px; font-size: .62rem; color: #94a3b8; line-height: 1.3; }
    @@keyframes revCalcPopIn {
        from { opacity: 0; transform: translateY(-6px) scale(.96); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    @@media (prefers-reduced-motion: reduce) {
        .rev-calc-btn { animation: none; }
        .rev-calc-shimmer { display: none; }
        .rev-calc-demo-amt, .rev-calc-demo-arrow, .rev-calc-demo-time { animation: none; }
        .rev-calc-popover { animation: none; }
    }

    /* ── Balance columns ── */
    .bal-rate-mismatch {
        position: relative;
        cursor: help;
        background: #fef3c7 !important;
    }
    .bal-rate-tip {
        display: none;
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #1e293b;
        color: #fff;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: .72rem;
        white-space: nowrap;
        z-index: 10;
        pointer-events: none;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
    }
    .bal-rate-tip::after {
        content: '';
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-top-color: #1e293b;
    }
    .bal-rate-mismatch:hover .bal-rate-tip,
    .bal-rate-mismatch:focus .bal-rate-tip {
        display: block;
        animation: balTipIn .2s ease;
    }
    @@keyframes balTipIn {
        from { opacity: 0; transform: translateX(-50%) translateY(4px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    /* ── Mixed-rate highlight on PC name ── */
    .pc-mixed-rate {
        position: relative;
        cursor: help;
        background: #fef9c3 !important;
        overflow: visible !important;
    }

    /* ── Session-mixed-rate (last 30 days) ── peach + diagonal-gradient when combined ── */
    .pc-srm-cell {
        position: relative;
        cursor: pointer;
        background: #fed7aa !important;
        overflow: visible !important;
        outline: none;
    }
    .pc-srm-cell:focus-visible { box-shadow: inset 0 0 0 2px #c2410c; }
    .pc-mixed-rate.pc-srm-cell {
        background: linear-gradient(135deg, #fef9c3 0%, #fef9c3 50%, #fed7aa 50%, #fed7aa 100%) !important;
    }

    @@keyframes srmPulse {
        0%, 100% { transform: scale(1);    opacity: .85; }
        50%      { transform: scale(1.25); opacity: 1;   }
    }

    /* ── The "WOW" hover panel ── */
    .pc-srm-panel {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        z-index: 50;
        width: 360px;
        max-width: calc(100vw - 32px);
        background: rgba(15, 23, 42, 0.97);
        color: #f1f5f9;
        border: 1px solid rgba(148, 163, 184, 0.18);
        border-radius: 14px;
        padding: 12px 12px 10px;
        box-shadow: 0 18px 60px rgba(0, 0, 0, 0.55), 0 0 0 1px rgba(255, 255, 255, 0.04);
        opacity: 0;
        transform: translateY(8px) scale(0.985);
        transition: opacity 0.18s ease, transform 0.22s cubic-bezier(.175,.885,.32,1.275);
        pointer-events: none;
        cursor: default;
        backdrop-filter: blur(6px);
        -webkit-backdrop-filter: blur(6px);
    }
    .pc-srm-panel::before {
        content: '';
        position: absolute;
        top: -7px; left: 18px;
        width: 14px; height: 14px;
        background: rgba(15, 23, 42, 0.97);
        border-top: 1px solid rgba(148, 163, 184, 0.18);
        border-left: 1px solid rgba(148, 163, 184, 0.18);
        transform: rotate(45deg);
    }
    .pc-srm-cell:hover .pc-srm-panel,
    .pc-srm-cell:focus-within .pc-srm-panel {
        opacity: 1;
        transform: translateY(0) scale(1);
        pointer-events: auto;
    }
    .pc-srm-glow {
        position: absolute; inset: -1px;
        border-radius: 14px;
        pointer-events: none;
        background: radial-gradient(120% 60% at 0% 0%, rgba(251,146,60,0.25), transparent 60%),
                    radial-gradient(80% 50% at 100% 100%, rgba(59,130,246,0.18), transparent 65%);
        opacity: 0; transition: opacity .25s ease;
    }
    .pc-srm-cell:hover .pc-srm-glow,
    .pc-srm-cell:focus-within .pc-srm-glow { opacity: 1; }

    .pc-srm-header {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.78rem; font-weight: 700; letter-spacing: 0.01em;
        color: #f8fafc; padding: 2px 4px 8px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.12);
        margin-bottom: 6px;
    }
    .pc-srm-header > span:first-of-type { flex: 1; }
    .pc-srm-count-badge {
        font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em;
        background: linear-gradient(135deg, #fb923c, #ef4444);
        color: #fff; border-radius: 999px;
        padding: 2px 8px;
        box-shadow: 0 2px 8px rgba(239, 68, 68, 0.35);
    }

    .pc-srm-list {
        display: flex; flex-direction: column; gap: 4px;
        max-height: 280px;
        overflow-y: auto;
        padding: 2px 2px 4px;
        margin: 0 -2px;
    }
    .pc-srm-list::-webkit-scrollbar { width: 6px; }
    .pc-srm-list::-webkit-scrollbar-thumb { background: rgba(148,163,184,0.25); border-radius: 3px; }

    .pc-srm-row {
        position: relative;
        display: flex; align-items: center; gap: 10px;
        padding: 7px 8px 7px 10px;
        border-radius: 9px;
        background: rgba(30, 41, 59, 0.55);
        border: 1px solid transparent;
        cursor: pointer;
        opacity: 0; transform: translateX(-12px);
        animation: srmRowIn 0.32s cubic-bezier(.175,.885,.32,1.275) forwards;
        transition: background 0.15s ease, border-color 0.15s ease, transform 0.12s ease;
        overflow: hidden;
    }
    @@keyframes srmRowIn { to { opacity: 1; transform: translateX(0); } }

    .pc-srm-row:hover {
        background: rgba(30, 41, 59, 0.85);
        border-color: var(--row-color, #64748b);
        transform: translateX(2px);
    }
    .pc-srm-row:active { transform: translateX(2px) scale(0.985); }

    .pc-srm-row-rail {
        flex-shrink: 0;
        width: 4px; height: 38px;
        border-radius: 2px;
        background: var(--row-color, #64748b);
        box-shadow: 0 0 8px var(--row-color, transparent);
    }
    .pc-srm-row-main { flex: 1; min-width: 0; }
    .pc-srm-row-top {
        display: flex; align-items: baseline; gap: 8px;
        font-size: 0.82rem; line-height: 1.15; color: #f1f5f9;
    }
    .pc-srm-row-date { font-weight: 700; }
    .pc-srm-row-dur  { font-size: 0.74rem; color: #94a3b8; font-weight: 500; }
    .pc-srm-row-aud {
        font-size: 0.72rem; color: #cbd5e1; margin-top: 2px;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .pc-srm-rate-badge {
        flex-shrink: 0;
        display: inline-flex; align-items: center;
        font-size: 0.78rem; font-weight: 800; color: #fff;
        padding: 4px 9px; border-radius: 999px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.08) inset;
        letter-spacing: 0.01em;
    }
    .pc-srm-per-hr { font-weight: 600; opacity: 0.85; margin-left: 1px; }

    .pc-srm-row-arrow {
        flex-shrink: 0;
        font-size: 0.82rem; color: #64748b;
        transition: transform 0.18s ease, color 0.18s ease;
    }
    .pc-srm-row:hover .pc-srm-row-arrow {
        color: var(--row-color, #f1f5f9);
        transform: translateX(2px);
    }

    .pc-srm-footer {
        display: flex; flex-wrap: wrap; gap: 4px;
        margin-top: 8px; padding-top: 8px;
        border-top: 1px solid rgba(148, 163, 184, 0.12);
    }
    .pc-srm-chip {
        font-size: 0.66rem; font-weight: 700; letter-spacing: 0.01em;
        color: #fff; padding: 2px 8px; border-radius: 999px;
        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.25);
    }
    .pc-srm-footer-hint {
        margin-top: 6px; padding: 0 4px;
        font-size: 0.65rem; color: #64748b; font-style: italic; text-align: right;
    }

    @@media (max-width: 768px) {
        .pc-srm-panel { width: 320px; left: -8px; }
    }
    @@media (max-width: 480px) {
        .pc-srm-panel { width: calc(100vw - 24px); left: -8px; max-height: 70vh; }
        .pc-srm-list  { max-height: 50vh; }
    }
    .pc-mixed-tip {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        background: #1e293b;
        color: #fff;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: .72rem;
        white-space: nowrap;
        z-index: 10;
        pointer-events: none;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
    }
    .pc-mixed-tip::after {
        content: '';
        position: absolute;
        bottom: 100%;
        left: 20px;
        border: 5px solid transparent;
        border-bottom-color: #1e293b;
    }
    .pc-mixed-rate:hover .pc-mixed-tip,
    .pc-mixed-rate:focus .pc-mixed-tip {
        display: block;
        animation: balTipIn .2s ease;
    }

    /* ── Mixed-currency warning on balance/hours cells ── */
    .pc-mixed-curr {
        position: relative;
        cursor: help;
        background: #fef3c7 !important;
    }
    .pc-mixed-curr-tip {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background: #1e293b;
        color: #fff;
        padding: 8px 12px;
        border-radius: 8px;
        font-size: .72rem;
        white-space: nowrap;
        z-index: 10;
        pointer-events: none;
        box-shadow: 0 4px 12px rgba(0,0,0,.2);
    }
    .pc-mixed-curr-tip::after {
        content: '';
        position: absolute;
        bottom: 100%;
        left: 50%;
        transform: translateX(-50%);
        border: 5px solid transparent;
        border-bottom-color: #1e293b;
    }
    .pc-mixed-curr:hover .pc-mixed-curr-tip,
    .pc-mixed-curr:focus .pc-mixed-curr-tip {
        display: block;
        animation: balTipIn .2s ease;
    }

    .bal-detail-btn { line-height: 1; min-height: 32px; min-width: 32px; }
    .bal-detail-btn:hover i { color: #4f46e5 !important; transform: scale(1.15); transition: all .15s ease; }

    /* ── Balance Explanation Modal ── */
    .bal-modal { border: none; border-radius: 20px; overflow: hidden; background: #fff; color: #212529; }
    .bal-modal-header {
        display: flex; align-items: center; gap: 14px;
        padding: 20px 24px 16px;
        background: linear-gradient(135deg, #1e40af, #6366f1);
    }
    .bal-modal-icon {
        width: 48px; height: 48px; border-radius: 14px; flex-shrink: 0;
        background: rgba(255,255,255,.18); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem; color: #fff;
    }
    .bal-modal-title { font-size: 1.1rem; font-weight: 700; color: #fff; }
    .bal-modal-subtitle { font-size: .82rem; color: rgba(255,255,255,.7); }

    .bal-section { margin: 0; border-bottom: 1px solid #f1f5f9; }
    .bal-sec-title {
        display: flex; align-items: center; gap: 8px;
        font-size: .82rem; font-weight: 700;
        padding: 12px 16px 8px;
    }
    .bal-sec-title i { font-size: 1.1rem; }
    .bal-sec-purchased { background: #f0fdf4; }
    .bal-sec-purchased .bal-sec-title { color: #166534; }
    .bal-sec-purchased .table { --bs-table-bg: transparent; }
    .bal-sec-purchased .table td, .bal-sec-purchased .table th { background: transparent !important; color: #212529 !important; border-color: #bbf7d0; }

    .bal-sec-used { background: #fef2f2; }
    .bal-sec-used .bal-sec-title { color: #991b1b; }

    .bal-sec-hours { background: #eff6ff; }
    .bal-sec-hours .bal-sec-title { color: #1e40af; }

    .bal-result-card {
        text-align: center; padding: 20px 16px;
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        border-bottom: 1px solid #e2e8f0;
    }
    .bal-result-label { font-size: .82rem; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
    .bal-result-value { font-size: 2rem; font-weight: 800; }

    .bal-formula {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
        font-size: .9rem;
    }
    .bal-formula-item {
        background: #fff; border: 1px solid #bfdbfe; border-radius: 8px;
        padding: 4px 10px; font-weight: 600; color: #1e40af;
    }
    .bal-formula-op { font-size: 1.1rem; font-weight: 700; color: #94a3b8; }
    .bal-formula-result {
        background: #dbeafe; border-radius: 8px;
        padding: 4px 12px; font-weight: 800; color: #1e3a8a; font-size: 1rem;
    }

    .bal-badge-warn {
        background: #fef3c7; color: #92400e; font-size: .72rem;
        display: inline-flex; align-items: center; gap: 4px;
    }
    .bal-badge-own { background: #dcfce7; color: #166534; }
    .bal-badge-fallback { background: #dbeafe; color: #1e40af; }
    .bal-badge-purchase { background: #fef3c7; color: #92400e; }

    .bal-sessions-btn {
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: #fff; border: none; border-radius: 10px;
        padding: 8px 20px; font-size: .82rem; font-weight: 600;
        display: inline-flex; align-items: center; gap: 6px;
        transition: all .2s ease; min-height: 44px;
    }
    .bal-sessions-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 14px rgba(99,102,241,.4); color: #fff; }
    .bal-sessions-btn:active { transform: translateY(0); }

    .bal-sessions-detail {
        max-height: 400px; overflow-y: auto;
        border-top: 2px solid #e2e8f0;
    }
    .bal-sessions-detail .table { --bs-table-bg: transparent; }
    .bal-sessions-detail .table td, .bal-sessions-detail .table th { color: #212529 !important; background: transparent !important; }
    .bal-sessions-detail .table thead.table-light th { background: #f1f5f9 !important; color: #374151 !important; }

    @@keyframes balSlideIn {
        from { opacity: 0; max-height: 0; }
        to   { opacity: 1; max-height: 400px; }
    }

    /* ── Balance modal responsive ── */
    @@media (max-width: 768px) {
        .bal-modal-header { padding: 16px; }
        .bal-result-value { font-size: 1.6rem; }
        .bal-formula { font-size: .8rem; }
    }
    @@media (max-width: 480px) {
        .bal-modal { border-radius: 16px; }
        .bal-modal-icon { width: 40px; height: 40px; font-size: 1.2rem; }
        .bal-sessions-detail { max-height: 300px; }
    }

    /* ── Column Guide Modal (same pattern as Salary detail modal) ── */
    .cg-overlay {
        position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 9999;
        display: flex; align-items: center; justify-content: center;
    }
    .cg-box {
        background: #fff !important; border-radius: 16px; width: 560px; max-width: 94vw;
        max-height: 90vh; overflow-y: auto;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
    }
    .cg-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; background: linear-gradient(135deg,#4f46e5,#6366f1);
        color: #fff !important; font-weight: 700; font-size: .95rem;
        border-radius: 16px 16px 0 0; position: sticky; top: 0; z-index: 1;
    }
    .cg-close {
        background: rgba(255,255,255,.2); border: none; color: #fff !important; border-radius: 8px;
        width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 1.1rem;
    }
    .cg-close:hover { background: rgba(255,255,255,.35); }
    .cg-body { padding: 20px; color: #1e293b !important; }
    .cg-body * { color: inherit; }
    .cg-sec { margin-bottom: 16px; border-radius: 8px; padding: 12px 14px; }
    .cg-title {
        font-size: .72rem !important; font-weight: 700 !important; text-transform: uppercase;
        letter-spacing: .5px; margin-bottom: 8px;
        padding-bottom: 4px; border-bottom: 1px solid rgba(100,116,139,.12);
    }
    .cg-grid {
        display: grid; grid-template-columns: 120px 1fr; gap: 6px 12px; font-size: .85rem;
    }
    .cg-lbl { color: #475569 !important; font-size: .82rem; }
    .cg-example {
        margin-top: 10px; padding: 8px 12px; border-radius: 6px;
        background: #f0fdf4 !important; border: 1px solid #bbf7d0;
        font-size: .84rem; color: #1e293b !important;
    }

    /* Section colors (same approach as sal-detail-purchase etc.) */
    .cg-sec-name    { background: #eef2ff !important; border-left: 4px solid #6366f1; }
    .cg-sec-name .cg-title { color: #4338ca !important; }
    .cg-sec-name .cg-lbl { color: #475569 !important; }

    .cg-sec-balance { background: #f0fdf4 !important; border-left: 4px solid #22c55e; }
    .cg-sec-balance .cg-title { color: #166534 !important; }
    .cg-sec-balance .cg-lbl { color: #475569 !important; }

    .cg-sec-hours   { background: #eff6ff !important; border-left: 4px solid #3b82f6; }
    .cg-sec-hours .cg-title { color: #1e40af !important; }
    .cg-sec-hours .cg-lbl { color: #475569 !important; }

    .cg-sec-time    { background: #fff7ed !important; border-left: 4px solid #f97316; }
    .cg-sec-time .cg-title { color: #9a3412 !important; }
    .cg-sec-time .cg-lbl { color: #475569 !important; }

    .cg-sec-sess    { background: #faf5ff !important; border-left: 4px solid #a855f7; }
    .cg-sec-sess .cg-title { color: #7e22ce !important; }
    .cg-sec-sess .cg-lbl { color: #475569 !important; }

    .cg-sec-acad    { background: #f0fdfa !important; border-left: 4px solid #14b8a6; }
    .cg-sec-acad .cg-title { color: #0f766e !important; }
    .cg-sec-acad .cg-lbl { color: #475569 !important; }

    .cg-sec-purch   { background: #fefce8 !important; border-left: 4px solid #eab308; }
    .cg-sec-purch .cg-title { color: #a16207 !important; }
    .cg-sec-purch .cg-lbl { color: #475569 !important; }

    .cg-sec-aud     { background: #fff1f2 !important; border-left: 4px solid #f43f5e; }
    .cg-sec-aud .cg-title { color: #be123c !important; }
    .cg-sec-aud .cg-lbl { color: #475569 !important; }

    .cg-sec-detail  { background: #f5f3ff !important; border-left: 4px solid #8b5cf6; }
    .cg-sec-detail .cg-title { color: #6d28d9 !important; }
    .cg-sec-detail .cg-lbl { color: #475569 !important; }

    @@media (max-width: 480px) {
        .cg-grid { grid-template-columns: 100px 1fr; font-size: .82rem; }
    }

    /* ── Org pill bar ── */
    .pc-org-bar {
        display: flex; gap: 6px; padding: 6px 8px;
        background: linear-gradient(135deg, #f8fafc, #f1f5f9);
        border-radius: 14px; margin-bottom: 8px;
        overflow-x: auto; flex-shrink: 0;
        border: 1px solid rgba(0,0,0,.05);
        scrollbar-width: thin;
    }
    .pc-org-pill {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 7px 16px; border: 2px solid transparent;
        border-radius: 10px; background: transparent;
        color: #64748b; font-size: .8rem; font-weight: 600;
        cursor: pointer; white-space: nowrap;
        transition: all .2s cubic-bezier(.4,0,.2,1);
        min-height: 38px; position: relative;
        user-select: none;
    }
    .pc-org-pill:hover {
        background: #e2e8f0; color: #334155;
        transform: translateY(-1px);
    }
    .pc-org-pill.active {
        background: linear-gradient(135deg, #6366f1, #818cf8);
        color: #fff;
        box-shadow: 0 3px 12px rgba(99,102,241,.35);
        border-color: transparent;
        transform: translateY(-1px);
    }
    .pc-org-pill.active:hover {
        background: linear-gradient(135deg, #4f46e5, #6366f1);
        box-shadow: 0 4px 16px rgba(99,102,241,.45);
    }
    .pc-org-pill.drag-over {
        border-color: #6366f1;
        background: #eef2ff;
        box-shadow: 0 0 0 3px rgba(99,102,241,.2), 0 4px 14px rgba(99,102,241,.25);
        transform: translateY(-2px) scale(1.03);
        color: #4338ca;
    }
    .pc-org-pill.active.drag-over {
        box-shadow: 0 0 0 3px rgba(99,102,241,.3), 0 6px 20px rgba(99,102,241,.4);
        transform: translateY(-2px) scale(1.05);
    }
    .pc-org-count {
        display: inline-flex; align-items: center; justify-content: center;
        min-width: 22px; height: 20px; padding: 0 6px;
        border-radius: 10px; font-size: .68rem; font-weight: 700;
    }
    .pc-org-pill:not(.active) .pc-org-count {
        background: #e2e8f0; color: #475569;
    }
    .pc-org-pill.active .pc-org-count {
        background: rgba(255,255,255,.25); color: #fff;
    }
    .pc-org-pill-ungrouped { color: #94a3b8; }
    .pc-org-pill-ungrouped i { font-size: .9rem; }

    /* Dragging row */
    .pc-row-dragging { opacity: .45; }

    /* ── PC context menu ── */
    .pc-ctx-backdrop {
        position: fixed; inset: 0; z-index: 1050; background: transparent;
    }
    .pc-ctx-menu {
        position: fixed; z-index: 1051;
        background: #fff; border-radius: 12px;
        box-shadow: 0 8px 32px rgba(0,0,0,.15), 0 2px 8px rgba(0,0,0,.08);
        border: 1px solid rgba(0,0,0,.08);
        min-width: 180px; padding: 6px;
        animation: pcCtxIn .15s ease;
    }
    @@keyframes pcCtxIn {
        from { opacity: 0; transform: scale(.95) translateY(-4px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }
    .pc-ctx-title {
        padding: 6px 10px 4px; font-size: .7rem; font-weight: 700;
        color: #94a3b8; text-transform: uppercase; letter-spacing: .04em;
        display: flex; align-items: center; gap: 4px;
    }
    .pc-ctx-title i { font-size: .8rem; }
    .pc-ctx-divider {
        height: 1px; background: #e2e8f0; margin: 4px 8px;
    }
    .pc-ctx-item {
        display: flex; align-items: center; gap: 8px;
        width: 100%; padding: 8px 12px; border: none;
        background: transparent; color: #334155;
