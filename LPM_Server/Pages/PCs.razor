@page "/PCs"
@attribute [Authorize(Roles = "Admin,Customer")]
@inject LPM.Services.PcService PcSvc
@inject LPM.Services.CourseService CourseSvc
@inject LPM.Services.DashboardService DashSvc
@inject LPM.Auth.UserDb UserDb
@inject LPM.Services.SmsService SmsSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject LPM.Services.CompletionService CompletionSvc
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using LPM.Services
@implements IDisposable

<div class="pc-page-container">

    @* ── Toolbar ── *@
    <div class="d-flex align-items-center gap-2 mb-2 flex-wrap pc-toolbar">
        <input class="form-control form-control-sm" style="max-width:220px;" placeholder="@LS.T("common.search")"
               @bind="_search" @bind:event="oninput" />
        <button class="pc-report-btn" @onclick="OpenCoursesReportModal" title="Course Completions Report">
            <i class="ri-graduation-cap-line"></i><span class="pc-btn-label">Completions</span>
        </button>
        <div class="form-check form-switch mb-0">
            <input class="form-check-input" type="checkbox" id="filterHasSessions"
                   @bind="_filterHasSessions" style="cursor:pointer;" />
            <label class="form-check-label small fw-semibold" for="filterHasSessions" style="cursor:pointer;color:#6366f1;">
                <i class="ri-archive-line me-1" style="font-size:.8rem;"></i>Audited Only
            </label>
        </div>
        <span class="badge bg-primary-transparent text-primary" style="font-size:.72rem;">
            @FilteredPcsEx.Count() PCs
        </span>
        <div class="ms-auto d-flex gap-2 align-items-center">
            <button class="pc-sms-btn @(!_selPcId.HasValue ? "pc-action-disabled" : "")"
                    @onclick="OpenSmsModal"
                    disabled="@(!_selPcId.HasValue)"
                    title="@(_selPcId.HasValue ? "Send SMS to this PC" : "Select a PC first")">
                <i class="ri-send-plane-fill"></i><span class="pc-btn-label">SMS</span>
            </button>
            <button class="pc-purchase-btn @(!_selPcId.HasValue ? "pc-action-disabled" : "")"
                    @onclick="OpenPurchaseModal"
                    disabled="@(!_selPcId.HasValue)"
                    title="@(_selPcId.HasValue ? "" : "Select a PC first")">
                <i class="ri-shopping-cart-line"></i><span class="pc-btn-label">@LS.T("pcs.newPurchase")</span>
            </button>
        </div>
    </div>

    @* ── PC Table (full width) ── *@
    <div class="overflow-x-auto pc-table-wrapper @(_selPcId.HasValue ? "pc-table-drawer-open" : "")">
        @if (!FilteredPcsEx.Any())
        {
            <div class="text-muted small text-center mt-4">@LS.T("pcs.noPcsFound")</div>
        }
        else
        {
        <table id="pc-list-table" class="table table-sm table-hover mb-0 pc-list-table">
            <colgroup>
                <col class="pc-col-name" />
                <col style="width:80px;" />
                <col style="width:80px;" />
                <col style="width:70px;" />
                <col style="width:70px;" />
            </colgroup>
            <thead class="table-light" style="position:sticky;top:0;z-index:1;">
                <tr>
                    <th class="small ps-2 pc-th-sort @SortClass("name")" @onclick='() => ToggleSort("name")'>@LS.T("pcs.pcName")</th>
                    <th class="small text-center pc-th-sort @SortClass("hoursLeft")" @onclick='() => ToggleSort("hoursLeft")'>@LS.T("pcs.hoursLeft")</th>
                    <th class="small text-center pc-th-sort @SortClass("totalTime")" @onclick='() => ToggleSort("totalTime")'>@LS.T("pcs.totalSessionTime")</th>
                    <th class="small text-center pc-th-sort @SortClass("visits")" @onclick='() => ToggleSort("visits")'>@LS.T("pcs.totalVisits")</th>
                    <th class="small text-center pc-th-sort @SortClass("purchased")" @onclick='() => ToggleSort("purchased")'>@LS.T("pcs.hoursPurchased")</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pc in FilteredPcsEx)
                {
                    <tr class="@(_selPcId == pc.PcId ? "table-primary" : "")"
                        style="cursor:pointer;"
                        @onclick="() => SelectPc(pc.PcId)">
                        <td class="small ps-2 text-truncate" style="@(_soloPcIds.Contains(pc.PcId) ? "color:#ea580c;font-weight:600;" : "")">@pc.FullName@if (_soloPcIds.Contains(pc.PcId)) { <span style="display:inline-flex;align-items:center;justify-content:center;width:13px;height:13px;border-radius:3px;background:#ea580c;color:#fff;font-size:.58rem;font-weight:700;margin-left:3px;vertical-align:middle;">S</span> }@if (!string.IsNullOrEmpty(pc.Nick)) { <span class="text-muted" style="font-size:.7rem;"> (@pc.Nick)</span> }</td>
                        <td class="small text-center fw-semibold"
                            style="color:@(pc.RemainSec >= 0 ? "#4ade80" : "#f87171");">
                            @HrsLabel(pc.RemainSec)
                        </td>
                        <td class="small text-center text-muted">@HrsLabel(pc.TotalSessionSec)</td>
                        <td class="small text-center text-muted">@pc.AcademyVisits</td>
                        <td class="small text-center text-muted">@(pc.HoursPurchased)h</td>
                    </tr>
                }
            </tbody>
        </table>
        }
    </div>

    @* ── Detail panel (replaces table when a PC is selected) ── *@
    <div class="pc-drawer @(_selPcId.HasValue && _detail != null ? "pc-drawer-open" : "")">

    @* Handle bar + close *@
    <div class="pc-drawer-handle-bar">
        <div class="pc-drawer-handle"></div>
        <button class="pc-drawer-close" @onclick="CloseDrawer" title="Close">
            <i class="ri-close-line"></i>
        </button>
    </div>

    @if (_selPcId.HasValue && _detail != null)
    {
        @* Compact PC header *@
        <div class="pc-drawer-header">
            <div class="pc-header-avatar">
                @(_detail.FirstName.Length > 0 ? _detail.FirstName[0].ToString().ToUpper() : "?")
            </div>
            <div class="pc-header-info">
                <div class="pc-header-name-row">
                    <span class="pc-header-name">@_detail.FullName</span>
                    <button class="pc-edit-btn" @onclick="OpenEditModal">
                        <i class="ri-edit-line"></i>@LS.T("common.edit")
                    </button>
                    @if (!string.IsNullOrEmpty(_detail.Nick))
                    {
                        <span class="pc-header-tag pc-tag-id"><i class="ri-hashtag"></i>@_detail.Nick</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Org))
                    {
                        <span class="pc-header-tag pc-tag-org"><i class="ri-building-line"></i>@_detail.Org</span>
                    }
                    <button class="pc-solo-btn @(_isSolo ? "pc-solo-btn-active" : "")"
                            @onclick="AskToggleSolo"
                            title="@(_isSolo ? "Revoke solo auditor access" : "Grant solo auditor access")">
                        <i class="ri-user-star-line"></i>Solo Access
                    </button>
                </div>
                <div class="pc-header-meta">
                    <span class="pc-auditor-label"><i class="ri-shield-user-line"></i>Auditor: <strong>@_pcAuditorLabel</strong></span>
                    @if (!string.IsNullOrEmpty(_detail.Phone))
                    {
                        <span><i class="ri-phone-line"></i>@_detail.Phone</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Email))
                    {
                        <span><i class="ri-mail-line"></i>@_detail.Email</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.DateOfBirth))
                    {
                        <span><i class="ri-cake-line"></i>@_detail.DateOfBirth</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Gender))
                    {
                        <span>@_detail.Gender</span>
                    }
                    @if (!string.IsNullOrEmpty(_detail.Source))
                    {
                        <span><i class="ri-user-received-line"></i>@_detail.Source</span>
                    }
                </div>
                @if (!string.IsNullOrEmpty(_detail.Notes))
                {
                    <div class="pc-header-notes">@_detail.Notes</div>
                }
            </div>
        </div>

        @* ── Scrollable content ── *@
        <div class="pc-drawer-body">

            @* ── Courses ── *@
            <div class="card shadow-sm mb-3 pc-card-courses" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#6d28d9,#a855f7);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-book-open-line me-1"></i>@LS.T("pcs.courses")
                    </span>
                    @if (AllCoursesSorted.Count > 0)
                    {
                        <span class="badge bg-white text-primary">@AllCoursesSorted.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (AllCoursesSorted.Count > 0)
                    {
                      <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0" style="table-layout:auto;">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3 align-middle" style="white-space:nowrap;">@LS.T("pcs.course")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.dateStarted")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.dateFinished")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.amountIls")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("common.status")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.action")</th>
                                    <th class="small text-center align-middle" style="white-space:nowrap;">@LS.T("pcs.editPurchase")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sc in AllCoursesSorted)
                                {
                                    bool isActive = sc.DateFinished == null;
                                    var hasPurchase = _coursePurchaseMap.TryGetValue(sc.CourseId, out var coursePurchaseId);
                                    <tr style="@(!isActive ? "opacity:.65;" : "")">
                                        <td class="small ps-3 fw-semibold align-middle" style="color:@(isActive ? "#6d28d9" : "#6b7280");">@sc.CourseName</td>
                                        <td class="small text-center align-middle">@sc.DateStarted</td>
                                        <td class="small text-center align-middle">@(sc.DateFinished ?? "\u2014")</td>
                                        <td class="small text-center align-middle">@(_courseAmountMap.TryGetValue(sc.CourseId, out var cAmt) && cAmt > 0 ? $"\u20AA{cAmt}" : "\u2014")</td>
                                        <td class="small text-center align-middle">
                                            @if (_coursePurchaseStatusMap.TryGetValue(sc.CourseId, out var cStatus))
                                            {
                                                var (csCls, csLbl) = cStatus switch {
                                                    "Approved" => ("bg-success-transparent text-success", LS.T("sessions.approved")),
                                                    "Pending"  => ("bg-warning-transparent text-warning", LS.T("purchases.pending")),
                                                    _          => ("bg-secondary-transparent text-secondary", cStatus)
                                                };
                                                <span class="badge @csCls">@csLbl</span>
                                            }
                                            else
                                            {
                                                <span>\u2014</span>
                                            }
                                        </td>
                                        <td class="small text-center align-middle">
                                            @if (isActive)
                                            {
                                                <button class="btn btn-sm btn-outline-success py-0 px-2"
                                                        @onclick="() => AskFinishCourse(sc.StudentCourseId, sc.CourseName)">
                                                    <i class="ri-check-line me-1"></i>@LS.T("pcs.markDone")
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background:#d1fae5;color:#065f46;font-size:.7rem;">
                                                    <i class="ri-check-double-line me-1"></i>@LS.T("pcs.done")
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center align-middle">
                                            @if (hasPurchase)
                                            {
                                                <button class="btn btn-link btn-sm py-0 px-0"
                                                        title="@LS.T("pcs.editPurchase")"
                                                        @onclick="() => OpenEditPurchase(coursePurchaseId)">
                                                    <i class="ri-receipt-line" style="font-size:0.9rem;color:#6366f1;"></i>
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                      </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noCourses")</div>
                    }
                </div>
            </div>

            @* ── Auditing Purchases ── *@
            <div class="card shadow-sm pc-card-auditing" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#1e3a5f,#3b82f6);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditingPurchases")
                    </span>
                    @if (_auditingPurchases.Count > 0)
                    {
                        <span class="badge bg-white text-primary">@_auditingPurchases.Count</span>
                    }
                </div>
                <div class="card-body p-0">
                    @if (_auditingPurchases.Count > 0)
                    {
                      <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">@LS.T("pcs.date")</th>
                                    <th class="small text-center">@LS.T("pcs.hoursBought")</th>
                                    <th class="small text-center">@LS.T("pcs.amountIls")</th>
                                    <th class="small text-center">@LS.T("common.status")</th>
                                    <th class="small text-center" style="white-space:nowrap;">@LS.T("pcs.editPurchase")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ap in _auditingPurchases)
                                {
                                    <tr>
                                        <td class="small ps-3">@ap.Date</td>
                                        <td class="small text-center fw-semibold">@(ap.HoursBought)h</td>
                                        <td class="small text-center">@(ap.Amount > 0 ? $"\u20AA{ap.Amount}" : "\u2014")</td>
                                        <td class="small text-center">
                                            @{
                                                var (apCls, apLbl) = ap.Status switch {
                                                    "Approved" => ("bg-success-transparent text-success", LS.T("sessions.approved")),
                                                    "Pending"  => ("bg-warning-transparent text-warning", LS.T("purchases.pending")),
                                                    _          => ("bg-secondary-transparent text-secondary", ap.Status)
                                                };
                                            }
                                            <span class="badge @apCls">@apLbl</span>
                                        </td>
                                        <td class="text-center">
                                            <button class="btn btn-link btn-sm py-0 px-0"
                                                    title="@LS.T("pcs.editPurchase")"
                                                    @onclick="() => OpenEditPurchase(ap.PurchaseId)">
                                                <i class="ri-receipt-line" style="font-size:0.9rem;color:#2d6a9f;"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td class="small ps-3 fw-semibold">@LS.T("pcs.total")</td>
                                    <td class="small text-center fw-semibold">@(_auditingPurchases.Sum(a => a.HoursBought))h</td>
                                    <td class="small text-center fw-semibold">
                                        @{ var auditTotal = _auditingPurchases.Sum(a => a.Amount); }
                                        @(auditTotal > 0 ? $"\u20AA{auditTotal}" : "\u2014")
                                    </td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                      </div>
                    }
                    else
                    {
                        <div class="small text-center py-3" style="color:var(--default-text-color);opacity:.6;">@LS.T("pcs.noAuditingPurchases")</div>
                    }
                </div>
            </div>

            @* ── PC Completions (sess_completions) ── *@
            @if (_pcCompletions.Count > 0)
            {
            <div class="card shadow-sm mt-3" style="border:none;border-radius:14px;overflow:hidden;">
                <div class="card-header d-flex align-items-center justify-content-between py-2"
                     style="background:linear-gradient(135deg,#14532d,#22c55e);border:none;">
                    <span class="fw-semibold small text-white">
                        <i class="ri-trophy-line me-1"></i>Completions
                    </span>
                    <span class="badge bg-white text-success">@_pcCompletions.Count</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small ps-3">Complete Date</th>
                                    <th class="small text-center">Grade</th>
                                    <th class="small text-center">Auditor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in _pcCompletions)
                                {
                                    <tr>
                                        <td class="small ps-3">@(c.CompleteDate ?? "—")</td>
                                        <td class="small text-center fw-semibold" style="color:#15803d;">@(c.FinishedGrade ?? "—")</td>
                                        <td class="small text-center">@(c.AuditorName ?? "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            }

        </div>
    }
    </div>

</div>

@* ── Course Completions Report Modal ── *@
@if (_showCoursesReportModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1050;">
        <div class="modal-dialog" style="max-width:95vw;width:95vw;margin:2vh auto;">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;border:none;max-height:94vh;overflow:hidden;display:flex;flex-direction:column;">

                @* ── Fixed: Title bar ── *@
                <div style="background:linear-gradient(135deg,#1e3a5f,#3b82f6);border-radius:14px 14px 0 0;padding:12px 18px;display:flex;align-items:center;gap:12px;flex-shrink:0;">
                    <div style="width:38px;height:38px;border-radius:10px;background:rgba(255,255,255,.18);display:flex;align-items:center;justify-content:center;font-size:1.2rem;color:#fff;flex-shrink:0;">
                        <i class="ri-bar-chart-grouped-line"></i>
                    </div>
                    <div style="flex:1;">
                        <div style="font-size:1.05rem;font-weight:700;color:#fff;line-height:1.2;">Course Completions Report</div>
                        <div style="font-size:.73rem;color:rgba(255,255,255,.7);">Courses finished within the selected period, grouped by PC</div>
                    </div>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showCoursesReportModal = false" style="opacity:.8;"></button>
                </div>

                @* ── Fixed: Date filter bar ── *@
                <div style="padding:10px 18px;background:#f8faff;border-bottom:1px solid #e0e7ff;flex-shrink:0;display:flex;align-items:flex-end;gap:12px;flex-wrap:wrap;">
                    <div>
                        <div style="font-size:.72rem;font-weight:600;color:#374151;margin-bottom:3px;">From</div>
                        <input type="date" class="form-control form-control-sm"
                               style="max-width:155px;color:#212529;background:#fff;border-color:#dee2e6;"
                               value="@_courseReportFrom.ToString("yyyy-MM-dd")"
                               @onchange="e => _courseReportFrom = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _courseReportFrom" />
                    </div>
                    <div>
                        <div style="font-size:.72rem;font-weight:600;color:#374151;margin-bottom:3px;">To</div>
                        <input type="date" class="form-control form-control-sm"
                               style="max-width:155px;color:#212529;background:#fff;border-color:#dee2e6;"
                               value="@_courseReportTo.ToString("yyyy-MM-dd")"
                               @onchange="e => _courseReportTo = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : _courseReportTo" />
                    </div>
                    <button class="btn btn-primary btn-sm" @onclick="RunCoursesReport">
                        <i class="ri-search-line me-1"></i>Apply
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="GenerateCourseReportTestData"
                            style="font-size:.7rem;padding:3px 8px;opacity:.6;" title="Fill with random test data">
                        test
                    </button>
                    @if (_courseReportGroups != null)
                    {
                        <span style="font-size:.76rem;background:#dbeafe;color:#1e40af;border-radius:6px;padding:4px 12px;font-weight:700;">
                            @_courseReportGroups.Count PCs · @_courseReportGroups.Sum(g => g.Courses.Count) courses · @_courseReportGroups.Sum(g => g.Completions.Count) completions
                        </span>
                    }
                </div>

                @* ── Scrollable: Table area ── *@
                <div style="flex:1;min-height:0;overflow-y:auto;overflow-x:auto;background:#fff;border-radius:0 0 14px 14px;">
                    @if (_courseReportGroups == null)
                    {
                        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;color:#94a3b8;font-size:.9rem;">
                            <i class="ri-calendar-search-line" style="font-size:2.5rem;margin-bottom:8px;opacity:.4;"></i>
                            Select a date range and press Apply.
                        </div>
                    }
                    else if (_courseReportGroups.Count == 0)
                    {
                        <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;color:#94a3b8;font-size:.9rem;">
                            <i class="ri-inbox-line" style="font-size:2.5rem;margin-bottom:8px;opacity:.4;"></i>
                            No course completions found in this period.
                        </div>
                    }
                    else
                    {
                        <table style="width:100%;border-collapse:collapse;color:#212529;font-size:.84rem;">
                            <thead>
                                <tr style="position:sticky;top:0;z-index:2;">
                                    <th style="width:240px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;white-space:nowrap;">PC Name</th>
                                    <th style="padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;">Course / Grade</th>
                                    <th style="width:120px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;text-align:center;white-space:nowrap;">Started</th>
                                    <th style="width:120px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;text-align:center;white-space:nowrap;">Date</th>
                                    <th style="width:140px;padding:8px 14px;background:#f1f5f9;color:#475569;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.04em;border-bottom:2px solid #e2e8f0;white-space:nowrap;">Auditor</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var grp in _courseReportGroups)
                                {
                                    @* PC group header row *@
                                    <tr style="background:#eff6ff;">
                                        <td colspan="5" style="padding:8px 14px;font-size:.83rem;font-weight:700;color:#1e3a5f;border-top:2px solid #bfdbfe;border-bottom:1px solid #dbeafe;">
                                            <i class="ri-user-3-line me-1" style="opacity:.7;"></i>@grp.PcName
                                            @if (grp.Courses.Count > 0)
                                            {
                                                <span style="display:inline-block;margin-left:8px;background:#1e3a5f;color:#fff;border-radius:20px;padding:1px 9px;font-size:.67rem;font-weight:700;vertical-align:middle;">
                                                    @grp.Courses.Count courses
                                                </span>
                                            }
                                            @if (grp.Completions.Count > 0)
                                            {
                                                <span style="display:inline-block;margin-left:6px;background:#14532d;color:#fff;border-radius:20px;padding:1px 9px;font-size:.67rem;font-weight:700;vertical-align:middle;">
                                                    @grp.Completions.Count completions
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    @* Course rows *@
                                    @foreach (var c in grp.Courses)
                                    {
                                        <tr style="background:#fff;border-bottom:1px solid #f1f5f9;">
                                            <td style="padding:6px 14px 6px 30px;color:#94a3b8;font-size:.75rem;">
                                                <i class="ri-corner-down-right-line"></i>
                                            </td>
                                            <td style="padding:6px 14px;font-weight:600;color:#6d28d9;">
                                                <span style="font-size:.68rem;background:#ede9fe;color:#6d28d9;border-radius:4px;padding:1px 6px;margin-right:6px;font-weight:700;">Course</span>@c.CourseName
                                            </td>
                                            <td style="padding:6px 14px;text-align:center;color:#64748b;">@FormatDate(c.DateStarted)</td>
                                            <td style="padding:6px 14px;text-align:center;color:#059669;font-weight:700;">
                                                <i class="ri-check-line me-1" style="font-size:.8rem;"></i>@FormatDate(c.DateFinished!)
                                            </td>
                                            <td style="padding:6px 14px;color:#94a3b8;">—</td>
                                        </tr>
                                    }
                                    @* Completion rows *@
                                    @foreach (var sc in grp.Completions)
                                    {
                                        <tr style="background:#f0fdf4;border-bottom:1px solid #dcfce7;">
                                            <td style="padding:6px 14px 6px 30px;color:#94a3b8;font-size:.75rem;">
                                                <i class="ri-corner-down-right-line"></i>
                                            </td>
                                            <td style="padding:6px 14px;font-weight:600;color:#15803d;">
                                                <span style="font-size:.68rem;background:#dcfce7;color:#15803d;border-radius:4px;padding:1px 6px;margin-right:6px;font-weight:700;">Completion</span>@(sc.FinishedGrade ?? "—")
                                            </td>
                                            <td style="padding:6px 14px;text-align:center;color:#94a3b8;">—</td>
                                            <td style="padding:6px 14px;text-align:center;color:#15803d;font-weight:700;">
                                                <i class="ri-trophy-line me-1" style="font-size:.8rem;"></i>@(sc.CompleteDate ?? "—")
                                            </td>
                                            <td style="padding:6px 14px;color:#374151;font-size:.82rem;">@(sc.AuditorName ?? "—")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    }
                </div>


            </div>
        </div>
    </div>
}

@* ── Purchase Modal ── *@
@if (_showPurchaseModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1050;">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-header py-2 px-3 d-flex align-items-center" style="border-color:#dee2e6;">
                    <h5 class="modal-title fw-bold mb-0" style="color:#212529;">
                        <i class="ri-shopping-cart-line me-2"></i>@(_editingPurchaseId.HasValue ? LS.T("pcs.editPurchase") : LS.T("pcs.purchase"))
                    </h5>
                    @if (_editingPurchaseId.HasValue)
                    {
                        <span class="badge bg-warning text-dark ms-2" style="font-size:.7rem;">@LS.T("purchases.statusResetWarning")</span>
                    }
                    <div class="ms-auto d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="PrintPurchase">
                            <i class="ri-printer-line me-1"></i>@LS.T("common.print")
                        </button>
                        <button type="button" class="btn-close" @onclick="ClosePurchaseModal"></button>
                    </div>
                </div>
                <div class="modal-body p-3">
                    @* PC Name big *@
                    <div class="text-center mb-3">
                        <div style="font-size:1.6rem;font-weight:800;color:#1e3a5f;">@_detail.FullName</div>
                    </div>

                        @* ═══ SECTION 1: Purchase Items ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #3b82f6;">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="purchase-section-title">
                                    <i class="ri-shopping-bag-line" style="color:#3b82f6;"></i>@LS.T("pcs.purchaseItems")
                                </span>
                                <button class="btn btn-sm btn-outline-primary py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPurchaseItem" disabled="@(!CanAddMoreItems())">
                                    <i class="ri-add-line me-1"></i>@LS.T("pcs.addItem")
                                </button>
                            </div>

                            @for (int idx = 0; idx < _purchaseItems.Count; idx++)
                            {
                                var i = idx;
                                var item = _purchaseItems[i];
                                var valid = IsItemValid(item);
                                <div class="card mb-2 purchase-item-card @(!valid ? "purchase-item-invalid" : "purchase-item-valid")">
                                    <div class="card-body py-2 px-3">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <div class="d-flex gap-2 align-items-center">
                                                <span class="item-number-badge">@(i + 1)</span>
                                                @{ var capturedIdx = i; }
                                                <button class="btn btn-sm @(item.ItemType == "Auditing" ? "btn-primary" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Auditing")'>
                                                    <i class="ri-timer-flash-line me-1"></i>@LS.T("pcs.auditing")
                                                </button>
                                                <button class="btn btn-sm @(item.ItemType == "Course" ? "btn-info text-white" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Course")'>
                                                    <i class="ri-book-2-line me-1"></i>@LS.T("pcs.course")
                                                </button>
                                                <button class="btn btn-sm @(item.ItemType == "Book" ? "btn-success" : "btn-outline-secondary")"
                                                        @onclick='() => SetItemType(capturedIdx, "Book")'>
                                                    <i class="ri-book-open-line me-1"></i>Book
                                                </button>
                                            </div>
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!valid)
                                                {
                                                    <span class="item-incomplete-hint">
                                                        <i class="ri-error-warning-line"></i>
                                                        @(item.ItemType == "Auditing" ? LS.T("pcs.enterHours") : item.ItemType == "Course" ? LS.T("pcs.pickCourse") : "Pick a book")
                                                    </span>
                                                }
                                                @if (_purchaseItems.Count > 1)
                                                {
                                                    <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemovePurchaseItem(i)">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                        <div class="row g-2 align-items-end">
                                            @if (item.ItemType == "Auditing")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.hoursBought")</label>
                                                    <input type="number" class="form-control form-control-sm @(item.HoursBought <= 0 ? "field-invalid" : "field-valid")"
                                                           value="@item.HoursBought" min="0" style="max-width:95px;" placeholder="0"
                                                           @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.HoursBought = v; }" />
                                                </div>
                                            }
                                            else if (item.ItemType == "Course")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">@LS.T("pcs.course")</label>
                                                    <select class="form-select form-select-sm @(item.CourseId <= 0 ? "field-invalid" : "field-valid")" style="max-width:200px;"
                                                            value="@item.CourseId"
                                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.CourseId = v; }">
                                                        <option value="0">— @LS.T("pcs.selectCourse") —</option>
                                                        @foreach (var c in _allCourses)
                                                        {
                                                            <option value="@c.CourseId">@c.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            else if (item.ItemType == "Book")
                                            {
                                                <div class="col-auto">
                                                    <label class="form-label small mb-0">Book</label>
                                                    <select class="form-select form-select-sm @(item.BookId <= 0 ? "field-invalid" : "field-valid")" style="max-width:200px;"
                                                            value="@item.BookId"
                                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) { item.BookId = v; AutoFillBookPrice(item); } }">
                                                        <option value="0">— select book —</option>
                                                        @foreach (var b in _allBooks)
                                                        {
                                                            <option value="@b.BookId">@b.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            <div class="col-auto">
                                                <label class="form-label small mb-0">@LS.T("pcs.amountIls")</label>
                                                <input type="number" class="form-control form-control-sm"
                                                       value="@item.AmountPaid" min="0" style="max-width:105px;" placeholder="0"
                                                       @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) item.AmountPaid = v; }" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            @* Items summary *@
                            @if (_purchaseItems.Count > 0)
                            {
                                var totalItemAmount = _purchaseItems.Sum(x => x.AmountPaid);
                                var totalHours = _purchaseItems.Where(x => x.ItemType == "Auditing").Sum(x => x.HoursBought);
                                var courseCount = _purchaseItems.Count(x => x.ItemType == "Course" && x.CourseId > 0);
                                var bookCount = _purchaseItems.Count(x => x.ItemType == "Book" && x.BookId > 0);
                                <div class="items-summary">
                                    @if (totalHours > 0)
                                    {
                                        <span><i class="ri-timer-flash-line"></i> @totalHours @LS.T("pcs.hours")</span>
                                    }
                                    @if (courseCount > 0)
                                    {
                                        <span><i class="ri-book-2-line"></i> @courseCount @LS.T("pcs.courses")</span>
                                    }
                                    @if (bookCount > 0)
                                    {
                                        <span><i class="ri-book-open-line"></i> @bookCount Books</span>
                                    }
                                    <span class="ms-auto fw-semibold">@LS.T("pcs.total"): &#8362;@totalItemAmount</span>
                                </div>
                            }
                        </div>

                        @* ═══ SECTION 2: Payment Methods ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #10b981;">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="purchase-section-title">
                                    <i class="ri-bank-card-line" style="color:#10b981;"></i>@LS.T("purchases.paymentMethods")
                                </span>
                                <button class="btn btn-sm btn-outline-success py-0 px-2" style="font-size:0.75rem;"
                                        @onclick="AddPaymentMethod" disabled="@(!CanAddMorePayments())">
                                    <i class="ri-add-line me-1"></i>@LS.T("purchases.addPaymentMethod")
                                </button>
                            </div>
                            @for (int pmIdx = 0; pmIdx < _purchasePaymentMethods.Count; pmIdx++)
                            {
                                var pi2 = pmIdx;
                                var pm = _purchasePaymentMethods[pi2];
                                <div class="d-flex gap-2 align-items-end mb-2 p-2 border rounded flex-wrap" style="background:#f8fafc;border-radius:10px !important;">
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.methodType")</label>
                                        <select class="form-select form-select-sm" style="max-width:140px;font-size:.8rem;"
                                                value="@pm.MethodType"
                                                @onchange='e => pm.MethodType = e.Value?.ToString() ?? "Cash"'>
                                            <option value="Cash">@LS.T("purchases.cash")</option>
                                            <option value="CreditCard">@LS.T("purchases.creditCard")</option>
                                            <option value="Check">@LS.T("purchases.check")</option>
                                            <option value="BankTransfer">@LS.T("purchases.bankTransfer")</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.amount")</label>
                                        <input type="number" class="form-control form-control-sm @(pm.Amount <= 0 ? "field-invalid" : "field-valid")"
                                               style="max-width:100px;font-size:.8rem;"
                                               value="@pm.Amount" min="0" placeholder="0"
                                               @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) pm.Amount = v; }" />
                                    </div>
                                    <div>
                                        <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("purchases.paymentDate")</label>
                                        <input type="date" class="form-control form-control-sm" style="max-width:140px;font-size:.8rem;"
                                               value="@(pm.PaymentDate?.ToString("yyyy-MM-dd"))"
                                               @onchange="e => pm.PaymentDate = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : null" />
                                    </div>
                                    @if (_purchasePaymentMethods.Count > 1)
                                    {
                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => _purchasePaymentMethods.RemoveAt(pi2)">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                </div>
                            }
                            @{
                                var itemsTotal = _purchaseItems.Sum(i => i.AmountPaid);
                                var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
                                var pmBalance = itemsTotal - pmTotal;
                            }
                            @if (pmTotal > 0 || itemsTotal > 0)
                            {
                                <div class="payment-summary mt-2">
                                    <span>@LS.T("purchases.paid"): &#8362;@pmTotal / &#8362;@itemsTotal</span>
                                    @if (pmBalance != 0)
                                    {
                                        <span class="@(pmBalance > 0 ? "text-danger" : "text-warning") fw-semibold">
                                            <i class="ri-error-warning-line"></i>
                                            @(pmBalance > 0 ? LS.T("purchases.underpaid") : LS.T("purchases.overpaid")): &#8362;@Math.Abs(pmBalance)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-success fw-semibold">
                                            <i class="ri-check-line"></i> @LS.T("purchases.balanced")
                                        </span>
                                    }
                                </div>
                            }
                        </div>

                        @* ═══ SECTION 3: Details ═══ *@
                        <div class="purchase-section" style="border-left:3px solid #8b5cf6;">
                            <span class="purchase-section-title mb-2 d-block">
                                <i class="ri-file-info-line" style="color:#8b5cf6;"></i>@LS.T("pcs.purchaseDetails")
                            </span>

                            @* Date + Registrar + Referral in one row *@
                            <div class="d-flex gap-3 flex-wrap mb-3">
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.date")</label>
                                    <input type="date" class="form-control form-control-sm" @bind="_purchaseDate" style="max-width:150px;" />
                                </div>
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("courses.registrar")</label>
                                    <select class="form-select form-select-sm" style="max-width:170px;"
                                            value="@_purchaseRegistrarId"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _purchaseRegistrarId = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var s in _staff)
                                        {
                                            <option value="@s.PersonId">@s.FullName</option>
                                        }
                                    </select>
                                </div>
                                <div>
                                    <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("courses.referral")</label>
                                    <select class="form-select form-select-sm" style="max-width:170px;"
                                            value="@_purchaseReferralId"
                                            @onchange="e => { if (int.TryParse(e.Value?.ToString(), out var v)) _purchaseReferralId = v; }">
                                        <option value="0">— @LS.T("common.none") —</option>
                                        @foreach (var p in _allPersons)
                                        {
                                            <option value="@p.PersonId">@p.FullName</option>
                                        }
                                    </select>
                                </div>
                            </div>

                            @* Notes *@
                            <div class="mb-3">
                                <label class="form-label small mb-0" style="font-size:.72rem;">@LS.T("pcs.notes")</label>
                                <textarea class="form-control form-control-sm" rows="2" @bind="_purchaseNotes"
                                          placeholder="@LS.T("members.optional")" style="border-radius:8px;"></textarea>
                            </div>

                            @* Signature *@
                            <div>
                                <div class="d-flex align-items-center justify-content-between mb-1">
                                    <label class="form-label small mb-0" style="color:#212529;font-size:.72rem;">
                                        @LS.T("pcs.signature")
                                        @if (!_skipSignature) { <span style="color:#dc3545;font-size:1rem;">*</span> }
                                        <input class="form-check-input ms-2" type="checkbox" id="skipSig"
                                               style="vertical-align:middle;"
                                               checked="@_skipSignature" @onchange="ToggleSkipSignature" />
                                        <span style="font-size:0.72rem;color:#6b7280;vertical-align:middle;margin-left:3px;">@LS.T("pcs.noSignature")</span>
                                    </label>
                                    @if (!_skipSignature)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:0.7rem;"
                                                @onclick="ClearSignature">
                                            @LS.T("pcs.clearSignature")
                                        </button>
                                    }
                                </div>
                                @if (!_skipSignature)
                                {
                                    <div style="border:2px solid #dee2e6;border-radius:8px;background:#fafafa;position:relative;">
                                        <canvas id="signatureCanvas" style="width:100%;height:120px;cursor:crosshair;display:block;"></canvas>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-3 small" style="border:2px dashed #dee2e6;border-radius:8px;background:#f9fafb;color:#9ca3af;">
                                        <i class="ri-edit-line me-1"></i>@LS.T("pcs.noSignatureNote")
                                    </div>
                                }
                            </div>
                        </div>
                </div>
                <div class="modal-footer py-2 px-3 flex-wrap">
                    @if (!string.IsNullOrEmpty(_purchaseError))
                    {
                        <div class="alert alert-danger py-1 px-2 mb-0 small flex-grow-1">@_purchaseError</div>
                    }
                    @if (!_skipSignature && !_hasSigned)
                    {
                        <div class="signature-reminder flex-grow-1">
                            <i class="ri-pen-nib-line"></i> @LS.T("pcs.signatureReminder")
                        </div>
                    }
                    <button class="btn btn-secondary btn-sm" @onclick="ClosePurchaseModal">@LS.T("common.cancel")</button>
                    @{
                        var canSave = HasValidPurchaseItems() && IsPaymentBalanced();
                    }
                    <button class="btn btn-primary btn-sm" @onclick="SavePurchase"
                            disabled="@(!canSave)">
                        <i class="ri-save-line me-1"></i>@LS.T("common.save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@* ── Delete Purchase Confirmation ── *@
@if (_confirmDeletePurchaseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-error-warning-line text-danger" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmDeleteTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmDeleteMsg")</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmDeletePurchaseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-danger px-3" @onclick="ConfirmDeletePurchase">
                            <i class="ri-delete-bin-line me-1"></i>@LS.T("common.delete")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Solo Access Confirm Modal ── *@
@if (_showSoloConfirm && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-body p-4 text-center">
                    @if (_soloConfirmEnable)
                    {
                        <div class="pc-solo-confirm-icon" style="background:linear-gradient(135deg,#ea580c,#f97316);">
                            <i class="ri-user-star-line"></i>
                        </div>
                        <div class="fw-bold mt-3 mb-1" style="font-size:1rem;">Grant Solo Access?</div>
                        <div class="small mb-1" style="color:#374151;">
                            A login account will be created for <strong>@_detail.FullName</strong>.
                        </div>
                        <div class="small mb-3" style="color:#6b7280;">
                            Username: <code>@_soloConfirmUsername</code><br/>
                            Password: <code>@((_detail.FirstName.Trim().Length > 0 ? char.ToUpper(_detail.FirstName.Trim()[0]) + _detail.FirstName.Trim()[1..].ToLower() : "User") + "1992")</code>
                        </div>
                    }
                    else
                    {
                        <div class="pc-solo-confirm-icon" style="background:linear-gradient(135deg,#dc2626,#ef4444);">
                            <i class="ri-user-unfollow-line"></i>
                        </div>
                        <div class="fw-bold mt-3 mb-1" style="font-size:1rem;">Revoke Solo Access?</div>
                        <div class="small mb-3" style="color:#6b7280;">
                            <strong>@_detail.FullName</strong>'s solo auditor account will be deactivated.
                            They will no longer be able to log in.
                        </div>
                    }
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _showSoloConfirm = false">
                            Cancel
                        </button>
                        <button class="btn btn-sm px-3 @(_soloConfirmEnable ? "btn-warning" : "btn-danger")"
                                @onclick="ConfirmToggleSolo">
                            <i class="@(_soloConfirmEnable ? "ri-user-star-line" : "ri-user-unfollow-line") me-1"></i>
                            @(_soloConfirmEnable ? "Grant Access" : "Revoke Access")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<SpkNewPersonModal @ref="_editModal" Title="@LS.T("common.edit")" RequireAllFields="true" ExistingFullNames="_existingPcNames" OnSaved="SaveEditFromModal" />

@* ── Solo Access — Admin Only Notice ── *@
@if (_showSoloAdminOnly)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;"
         @onclick="() => _showSoloAdminOnly = false">
        <div class="modal-dialog modal-sm modal-dialog-centered" @onclick:stopPropagation="true">
            <div class="modal-content" style="border-radius:14px;background:#fff;color:#212529;">
                <div class="modal-body p-4 text-center">
                    <div style="display:inline-flex;align-items:center;justify-content:center;
                                width:52px;height:52px;border-radius:50%;
                                background:linear-gradient(135deg,#6366f1,#818cf8);margin-bottom:12px;">
                        <i class="ri-shield-keyhole-line" style="font-size:1.5rem;color:#fff;"></i>
                    </div>
                    <div class="fw-bold mb-2" style="font-size:1rem;">Admin Only</div>
                    <div class="small mb-3" style="color:#4b5563;">
                        Only an <strong>Admin</strong> can grant or revoke Solo Access for a PC.
                    </div>
                    <button class="btn btn-sm btn-primary px-4"
                            @onclick="() => _showSoloAdminOnly = false">OK</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── SMS Compose Modal ── *@
@if (_showSmsModal && _detail != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.55);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:460px;">
            <div class="modal-content sms-modal-content">

                @* Header *@
                <div class="sms-modal-header">
                    <div class="sms-modal-icon">
                        <i class="ri-message-2-fill"></i>
                    </div>
                    <div>
                        <div class="sms-modal-title">Send SMS</div>
                        <div class="sms-modal-subtitle">Compose a message to send via SMS</div>
                    </div>
                    <button class="btn-close ms-auto" @onclick="CloseSmsModal" style="filter:invert(1);opacity:.6;"></button>
                </div>

                <div class="modal-body p-4">

                    @* Recipient card *@
                    <div class="sms-recipient-card mb-3">
                        <div class="sms-recipient-avatar">
                            @(_detail.FirstName.Length > 0 ? _detail.FirstName[0].ToString().ToUpper() : "?")
                        </div>
                        <div class="sms-recipient-info">
                            <div class="sms-recipient-name">@_detail.FullName</div>
                            @if (!string.IsNullOrWhiteSpace(_smsPhone))
                            {
                                <div class="sms-recipient-phone">
                                    <i class="ri-phone-fill me-1"></i>@_smsPhone
                                </div>
                            }
                            else
                            {
                                <div class="sms-no-phone">
                                    <i class="ri-error-warning-line me-1"></i>No phone number on record
                                </div>
                            }
                        </div>
                    </div>

                    @* Message textarea *@
                    @if (!string.IsNullOrWhiteSpace(_smsPhone))
                    {
                        <div class="mb-2">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <label class="form-label fw-semibold small mb-0" style="color:#374151;">
                                    <i class="ri-chat-3-line me-1"></i>Message
                                </label>
                                <button class="sms-dir-toggle" @onclick="() => _smsRtl = !_smsRtl"
                                        title="Toggle text direction">
                                    @if (_smsRtl)
                                    {
                                        <i class="ri-text-direction-r"></i><span>RTL</span>
                                    }
                                    else
                                    {
                                        <i class="ri-text-direction-l"></i><span>LTR</span>
                                    }
                                </button>
                            </div>
                            <textarea class="form-control sms-textarea"
                                      rows="4"
                                      maxlength="320"
                                      placeholder="@(_smsRtl ? "כתוב את ההודעה כאן…" : "Type your SMS message here…")"
                                      dir="@(_smsRtl ? "rtl" : "ltr")"
                                      @bind="_smsMessage"
                                      @bind:event="oninput"></textarea>
                            <div class="d-flex justify-content-end mt-1">
                                <span class="sms-char-count @(_smsMessage.Length > 160 ? "sms-char-warn" : "")">
                                    @_smsMessage.Length / 160
                                    @if (_smsMessage.Length > 160) { <span> (2 SMS)</span> }
                                </span>
                            </div>
                        </div>
                    }

                </div>

                <div class="modal-footer sms-modal-footer">
                    <button class="btn btn-secondary btn-sm px-4" @onclick="CloseSmsModal">Cancel</button>
                    @if (!string.IsNullOrWhiteSpace(_smsPhone))
                    {
                        <button class="pc-sms-send-btn"
                                @onclick="SendSmsFromModal"
                                disabled="@(string.IsNullOrWhiteSpace(_smsMessage) || _smsSending)">
                            @if (_smsSending)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                                <span>Sending…</span>
                            }
                            else
                            {
                                <i class="ri-send-plane-fill me-1"></i>
                                <span>Send SMS</span>
                            }
                        </button>
                    }
                </div>

            </div>
        </div>
    </div>
}

@* ── SMS Success Overlay ── *@
@if (_smsSuccess)
{
    <div class="sms-success-overlay" @onclick="DismissSmsSuccess">
        <div class="sms-success-card" @onclick:stopPropagation="true">
            <div class="sms-success-burst">
                <svg class="sms-checkmark" viewBox="0 0 52 52">
                    <circle class="sms-checkmark-circle" cx="26" cy="26" r="25" fill="none" />
                    <path class="sms-checkmark-path" fill="none" d="M14 27 l8 8 l16-16" />
                </svg>
            </div>
            <div class="sms-success-title">SMS Sent!</div>
            <div class="sms-success-pc">@_smsSuccessPcName</div>
            <div class="sms-success-phone">
                <i class="ri-phone-fill me-1"></i>@_smsSuccessPhone
            </div>
            <div class="sms-success-hint">Click anywhere to dismiss</div>
        </div>
    </div>
}

@* ── Finish Course Confirmation ── *@
@if (_confirmFinishCourseId.HasValue)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-sm modal-dialog-centered">
            <div class="modal-content" style="border-radius:12px;background:#fff;color:#212529;">
                <div class="modal-body text-center p-4">
                    <i class="ri-check-double-line text-success" style="font-size:2.5rem;"></i>
                    <div class="fw-bold mt-2 mb-1">@LS.T("pcs.confirmFinishCourseTitle")</div>
                    <div class="small mb-3" style="color:#6b7280;">@LS.T("pcs.confirmFinishCourseMsg", _confirmFinishCourseName)</div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-sm btn-secondary px-3" @onclick="() => _confirmFinishCourseId = null">
                            @LS.T("common.cancel")
                        </button>
                        <button class="btn btn-sm btn-success px-3" @onclick="ConfirmFinishCourse">
                            <i class="ri-check-line me-1"></i>@LS.T("pcs.markDone")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ── Page container ── */
    .pc-page-container { display: flex; flex-direction: column; height: calc(100vh - 60px); min-height: 0; }
    .pc-table-wrapper { overflow-y: auto; flex: 1; min-height: 0; }
    .pc-table-drawer-open { display: none; }

    /* ── Bottom Drawer ── */
    .pc-drawer {
        display: none; flex-direction: column;
        background: var(--custom-white, #fff);
        border-radius: 12px;
        box-shadow: 0 1px 6px rgba(0,0,0,.08);
        border: 1px solid rgba(0,0,0,.06);
        overflow: hidden; flex: 1; min-height: 0;
    }
    .pc-drawer-open { display: flex; }
    .pc-drawer-open + .pc-nothing { display: none; } /* placeholder */
    .pc-table-drawer-open { display: none; }


    /* Drag handle bar */
    .pc-drawer-handle-bar {
        display: flex; align-items: center; justify-content: center;
        padding: 8px 14px 4px;
        flex-shrink: 0; position: relative;
    }
    .pc-drawer-handle {
        width: 40px; height: 4px; border-radius: 2px;
        background: rgba(0,0,0,.15);
    }
    .pc-drawer-close {
        position: absolute; right: 12px; top: 6px;
        display: flex; align-items: center; justify-content: center;
        width: 32px; height: 32px; border-radius: 50%;
        border: none; background: rgba(0,0,0,.06);
        color: var(--default-text-color, #374151);
        font-size: 1.1rem; cursor: pointer;
        transition: background .15s ease;
        min-height: 44px; min-width: 44px;
    }
    .pc-drawer-close:hover { background: rgba(0,0,0,.12); }

    /* Drawer compact header */
    .pc-drawer-header {
        display: flex; align-items: flex-start; gap: 12px;
        padding: 6px 16px 10px;
        border-bottom: 1px solid rgba(0,0,0,.07);
        flex-shrink: 0;
    }

    /* Scrollable content inside drawer */
    .pc-drawer-body {
        overflow-y: auto; flex: 1; padding: 12px 16px 16px;
    }

    @@media (max-width: 768px) {
    }

    @@media (max-width: 480px) {
        .pc-header-avatar { width: 42px; height: 42px; font-size: 1.1rem; border-radius: 10px; }
        .pc-header-name { font-size: 1rem; }
        .pc-solo-btn { font-size: 0.72rem; padding: 4px 8px; }
        .pc-btn-label { display: none; }
    }

    /* ── Header card ── */
    .pc-header-card {
        background: var(--custom-white, #fff);
        border-radius: 16px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.06);
        overflow: hidden;
    }
    .pc-header-top {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 18px;
    }
    .pc-header-avatar {
        width: 50px; height: 50px; border-radius: 14px; flex-shrink: 0;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: #fff; font-size: 1.3rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 12px rgba(99,102,241,.3);
    }
    .pc-header-info { flex: 1; min-width: 0; }
    .pc-header-name-row {
        display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .pc-header-name {
        font-size: 1.15rem; font-weight: 700;
        color: var(--default-text-color, #1e293b);
    }
    .pc-header-tag {
        display: inline-flex; align-items: center; gap: 3px;
        font-size: .7rem; font-weight: 600; padding: 2px 8px;
        border-radius: 6px;
    }
    .pc-header-tag i { font-size: .72rem; }
    .pc-tag-id  { background: #f1f5f9; color: #64748b; }
    .pc-tag-org { background: #ede9fe; color: #6d28d9; }
    .pc-header-meta {
        display: flex; gap: 12px; flex-wrap: wrap;
        margin-top: 4px; font-size: .78rem; color: #64748b;
    }
    .pc-header-meta i { margin-right: 3px; font-size: .8rem; }
    .pc-header-notes {
        margin-top: 4px; font-size: .78rem; color: #94a3b8;
        font-style: italic;
    }
    .pc-header-actions {
        display: flex; align-items: center; gap: 8px; flex-shrink: 0;
    }
    .pc-edit-btn {
        display: inline-flex; align-items: center; gap: 3px;
        border: none; background: transparent;
        color: #94a3b8; font-size: .75rem; font-weight: 500;
        cursor: pointer; padding: 2px 6px; border-radius: 6px;
        transition: all .15s ease;
    }
    .pc-edit-btn i { font-size: .8rem; }
    .pc-edit-btn:hover {
        background: #f1f5f9; color: #6366f1;
    }

    /* Solo access toggle button */
    .pc-solo-btn {
        display: inline-flex; align-items: center; gap: 3px;
        border: 1.5px solid #d1d5db; background: transparent;
        color: #9ca3af; font-size: .75rem; font-weight: 500;
        cursor: pointer; padding: 4px 10px; border-radius: 6px;
        transition: all .18s ease;
        min-height: 32px;
        touch-action: manipulation;
        -webkit-tap-highlight-color: transparent;
        animation: soloIdlePulse 3.5s ease-in-out infinite;
    }
    .pc-solo-btn i { font-size: .85rem; }
    .pc-solo-btn:hover {
        border-color: #ea580c; color: #ea580c; background: #fff7ed;
        animation: none;
    }
    .pc-solo-btn-active {
        border-color: #ea580c; background: #fff7ed; color: #ea580c; font-weight: 600;
        animation: soloActivePulse 3s ease-in-out infinite;
    }
    .pc-solo-btn-active:hover { background: #ffedd5; animation: none; }
    @@keyframes soloIdlePulse {
        0%, 70%, 100% { box-shadow: 0 0 0 0 rgba(156,163,175,0); border-color: #d1d5db; }
        35%            { box-shadow: 0 0 0 3px rgba(156,163,175,0.18); border-color: #9ca3af; }
    }
    @@keyframes soloActivePulse {
        0%, 70%, 100% { box-shadow: 0 0 0 0 rgba(234,88,12,0); }
        35%            { box-shadow: 0 0 0 3px rgba(234,88,12,0.18); }
    }

    /* Solo confirm modal icon */
    .pc-solo-confirm-icon {
        width: 52px; height: 52px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto; font-size: 1.5rem; color: #fff;
        box-shadow: 0 4px 14px rgba(234,88,12,.3);
    }

    /* ── Purchase button ── */
    .pc-purchase-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: #1e293b; color: #fff; border: none; border-radius: 10px;
        padding: 7px 16px; font-size: 0.82rem; font-weight: 600;
        cursor: pointer; position: relative; z-index: 0; overflow: visible;
        transition: transform .2s ease;
    }
    .pc-purchase-btn::before {
        content: '';
        position: absolute; inset: -1.5px; border-radius: 12px;
        background: linear-gradient(270deg, #6366f1, #3b82f6, #06b6d4, #6366f1);
        background-size: 300% 300%;
        animation: pcPurchaseGlow 6s ease infinite;
        z-index: -1; opacity: .6;
    }
    .pc-purchase-btn::after {
        content: '';
        position: absolute; inset: 0; border-radius: 10px;
        background: #1e293b; z-index: -1;
    }
    .pc-purchase-btn i {
        display: inline-block;
        animation: pcCartNudge 3s ease-in-out infinite;
    }
    .pc-purchase-btn:hover { transform: translateY(-1px); }
    .pc-purchase-btn:hover::before { opacity: 1; }
    @@keyframes pcPurchaseGlow {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    @@keyframes pcCartNudge {
        0%, 85%, 100% { transform: translateX(0) rotate(0); }
        88%  { transform: translateX(-2px) rotate(-4deg); }
        91%  { transform: translateX(2px) rotate(4deg); }
        94%  { transform: translateX(-1px) rotate(-2deg); }
        97%  { transform: translateX(0) rotate(0); }
    }

    /* ── Left panel table ── */
    .pc-list-table th { font-size:0.7rem; font-weight:700; letter-spacing:.03em; text-transform:uppercase; white-space:nowrap; }
    .pc-list-table td { vertical-align:middle; }
    .pc-th-sort { cursor:pointer; user-select:none; position:relative; padding-right:16px !important; }
    .pc-th-sort::after { content:''; display:inline-block; width:0; height:0; border-left:4px solid transparent;
                         border-right:4px solid transparent; margin-left:4px; vertical-align:middle; opacity:0.3;
                         border-bottom:4px solid currentColor; }
    .pc-th-sort.sort-asc::after { border-bottom:4px solid currentColor; border-top:none; opacity:0.8; }
    .pc-th-sort.sort-desc::after { border-bottom:none; border-top:4px solid currentColor; opacity:0.8; }

    .purchases-card { border: none; border-radius: 14px; overflow: hidden; }

    /* Force readable colors inside tables with hardcoded light-background rows */
    .purchases-card .table,
    .purchases-card .table td,
    .purchases-card .table th { color: #212529 !important; }
    .purchases-card .table tr { --bs-table-bg: transparent; }
    .purchases-card .table td,
    .purchases-card .table th { background-color: inherit !important; --bs-table-bg-type: transparent; }
    .purchases-card .table-light { background-color: #f8f9fa !important; color: #212529 !important; }
    .purchases-card .table-light th,
    .purchases-card .table-light td { color: #212529 !important; background-color: #f8f9fa !important; }

    /* ── Courses vs Auditing table tints ── */
    .pc-card-courses .table tbody tr { background: #faf5ff; }
    .pc-card-courses .table tbody tr:hover { background: #f3e8ff !important; }
    .pc-card-courses .table thead.table-light th { background: #f3e8ff !important; color: #581c87 !important; }

    .pc-card-auditing .table tbody tr { background: #f0f7ff; }
    .pc-card-auditing .table tbody tr:hover { background: #e0efff !important; }
    .pc-card-auditing .table thead.table-light th { background: #dbeafe !important; color: #1e3a5f !important; }
    .pc-card-auditing .table tfoot.table-light td { background: #dbeafe !important; color: #1e3a5f !important; }

    /* ── Disabled state for SMS / Purchase when no PC selected ── */
    .pc-action-disabled {
        opacity: 0.38 !important;
        cursor: not-allowed !important;
        filter: grayscale(60%);
        pointer-events: none;
    }

    /* ── Completions Report modal — force light theme ── */
    .cr-modal-body { background: #fff !important; color: #212529 !important; }
    .cr-modal-body .form-label { color: #374151 !important; }
    .cr-modal-body .form-control { color: #212529 !important; background: #fff !important; border-color: #dee2e6 !important; }
    .cr-modal-body .text-muted { color: #6c757d !important; }
    .cr-modal-body .badge { color: inherit; }

    /* ── Completions report button ── */
    .pc-report-btn {
        display: inline-flex; align-items: center; gap: 6px;
        background: linear-gradient(135deg, #6d28d9, #a855f7);
        color: #fff; border: none; border-radius: 20px;
        padding: 5px 14px; font-size: 0.76rem; font-weight: 700;
        cursor: pointer; transition: all .2s ease;
        min-height: 32px; touch-action: manipulation;
        box-shadow: 0 2px 8px rgba(109,40,217,.35);
        letter-spacing: .02em;
    }
    .pc-report-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 14px rgba(109,40,217,.5);
        background: linear-gradient(135deg, #7c3aed, #c026d3);
    }
    .pc-report-btn:active { transform: translateY(0); }
    .pc-report-btn i { font-size: 1rem; }

    /* ── Course Completions Report table ── */
    .cr-table { border-collapse: separate; border-spacing: 0; }
    .cr-table, .cr-table td, .cr-table th { color: #212529 !important; }
    .cr-table thead.table-light th { background: #f8f9fa !important; color: #374151 !important; }
    .cr-pc-row { background: #eff6ff !important; }
    .cr-pc-cell {
        padding: 7px 10px !important;
        font-size: .82rem; font-weight: 700; color: #1e3a5f !important;
        border-top: 2px solid #bfdbfe !important;
    }
    .cr-course-row td { padding-top: 5px !important; padding-bottom: 5px !important; background: #fff !important; }
    .cr-course-row:last-child td { border-bottom: 1px solid #e2e8f0; }

    /* ── Purchase modal sections ── */
    .purchase-section {
        background: #f9fafb;
        border-radius: 12px;
        padding: 14px 16px;
        margin-bottom: 14px;
    }
    .purchase-section-title {
        font-size: 0.82rem;
        font-weight: 700;
        color: #374151;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
    .purchase-section-title i { font-size: 1rem; }

    /* ── Item card validation states ── */
    .purchase-item-card { border-radius: 10px; transition: all 0.25s ease; }
    .purchase-item-valid { border: 1px solid #d1d5db; }
    .purchase-item-invalid { border: 1.5px solid #f87171 !important; background: #fef2f2; }

    .item-number-badge {
        display: inline-flex; align-items: center; justify-content: center;
        width: 22px; height: 22px; border-radius: 50%;
        background: #e0e7ff; color: #3b5998; font-size: 0.72rem; font-weight: 700;
    }
    .purchase-item-invalid .item-number-badge { background: #fee2e2; color: #dc2626; }

    .item-incomplete-hint {
        font-size: 0.7rem; color: #ef4444; display: inline-flex; align-items: center; gap: 3px;
        animation: hint-pulse 2s ease-in-out infinite;
    }
    @@keyframes hint-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    /* Field-level validation */
    .field-invalid { border-color: #f87171 !important; background-color: #fff5f5 !important; }
    .field-valid { border-color: #86efac !important; }

    /* Items summary bar */
    .items-summary {
        display: flex; align-items: center; gap: 12px;
        padding: 6px 12px; border-radius: 8px;
        background: #eff6ff; font-size: 0.78rem; color: #1e40af;
    }
    .items-summary i { font-size: 0.85rem; }

    /* Signature reminder in footer */
    .signature-reminder {
        font-size: 0.75rem; color: #b45309;
        background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px;
        padding: 4px 10px; display: inline-flex; align-items: center; gap: 5px;
        animation: hint-pulse 2s ease-in-out infinite;
    }

    /* Payment summary bar */
    .payment-summary {
        display: flex; align-items: center; justify-content: space-between;
        padding: 6px 12px; border-radius: 8px;
        background: #f0fdf4; font-size: 0.78rem; color: #166534;
    }

    /* Force dark text inside white-bg modals (purchase modal, delete confirm) */
    .modal-content .form-label { color: #212529 !important; }
    .modal-content .form-control,
    .modal-content .form-select { color: #212529 !important; background-color: #fff !important; border-color: #dee2e6 !important; }
    .modal-content .form-control::placeholder { color: #6c757d !important; }
    .modal-content .fw-semibold { color: #212529; }
    .modal-content .btn-close { filter: none; }
    .modal-content .modal-footer { border-color: #dee2e6; color: #212529; }
    .modal-content .card { background: #fff; color: #212529; }
    .modal-content .card-body { color: #212529; }

    /* ── Resizable columns (JS-driven — see lpmInitColResize) ── */
    .pc-list-table { min-width: 100%; }
    .pc-col-name { min-width: 100px; }
    /* th position:relative set by JS; overflow-x auto on the wrapper allows horizontal scroll */
    .pc-list-table thead th { white-space: nowrap; }

    /* ── Send SMS button ── */
    .pc-sms-btn {
        display: inline-flex; align-items: center; gap: 5px;
        background: rgba(99,102,241,.1);
        color: #6366f1;
        border: 1.5px solid rgba(99,102,241,.35);
        border-radius: 20px;
        padding: 4px 12px; font-size: 0.75rem; font-weight: 700;
        cursor: pointer; transition: all .18s ease;
        letter-spacing: .03em; text-transform: uppercase;
        min-height: 30px; touch-action: manipulation;
        backdrop-filter: blur(4px);
    }
    .pc-sms-btn:hover {
        background: #6366f1; color: #fff;
        border-color: #6366f1;
        box-shadow: 0 4px 14px rgba(99,102,241,.4);
        transform: translateY(-1px);
    }
    .pc-sms-btn:active { transform: translateY(0); box-shadow: none; }
    .pc-sms-btn i { font-size: .85rem; }
    .pc-sms-btn:hover i { animation: smsPlaneLaunch .5s ease; }
    @@keyframes smsPlaneLaunch {
        0%   { transform: translate(0,0) rotate(0); opacity: 1; }
        50%  { transform: translate(6px,-6px) rotate(10deg); opacity: .7; }
        100% { transform: translate(0,0) rotate(0); opacity: 1; }
    }

    /* ── SMS Modal ── */
    .sms-modal-content {
        border: none; border-radius: 20px;
        background: #fff; color: #1e293b;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        overflow: hidden;
    }
    .sms-modal-header {
        display: flex; align-items: center; gap: 14px;
        padding: 20px 22px 16px;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
    }
    .sms-modal-icon {
        width: 44px; height: 44px; flex-shrink: 0; border-radius: 12px;
        background: rgba(255,255,255,.2); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
    }
    .sms-modal-title { font-size: 1.1rem; font-weight: 700; color: #fff; line-height: 1.2; }
    .sms-modal-subtitle { font-size: .75rem; color: rgba(255,255,255,.75); }

    .sms-recipient-card {
        display: flex; align-items: center; gap: 14px;
        background: #f8faff; border: 1.5px solid #e0e7ff;
        border-radius: 14px; padding: 14px 16px;
    }
    .sms-recipient-avatar {
        width: 46px; height: 46px; flex-shrink: 0; border-radius: 12px;
        background: linear-gradient(135deg, #6366f1, #0ea5e9);
        color: #fff; font-size: 1.2rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 3px 10px rgba(99,102,241,.3);
    }
    .sms-recipient-info { flex: 1; min-width: 0; }
    .sms-recipient-name { font-size: 1rem; font-weight: 700; color: #1e293b; }
    .sms-recipient-phone { font-size: .82rem; color: #6366f1; font-weight: 500; margin-top: 3px; }
    .sms-no-phone {
        font-size: .82rem; color: #ef4444; font-weight: 500; margin-top: 3px;
        background: #fef2f2; border-radius: 6px; padding: 4px 8px; display: inline-flex; align-items: center;
    }

    .sms-textarea {
        border: 1.5px solid #e0e7ff; border-radius: 12px;
        font-size: .9rem; resize: vertical; min-height: 110px;
        font-size: 16px; /* prevent iOS auto-zoom */
        transition: border-color .2s;
    }
    .sms-textarea:focus { border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12); }

    .sms-char-count { font-size: .72rem; color: #94a3b8; }
    .sms-char-warn { color: #f59e0b; font-weight: 600; }

    .sms-dir-toggle {
        display: inline-flex; align-items: center; gap: 4px;
        background: #f1f5f9; border: 1px solid #e2e8f0;
        color: #64748b; font-size: .7rem; font-weight: 700;
        padding: 3px 9px; border-radius: 20px; cursor: pointer;
        transition: all .15s ease; letter-spacing: .04em;
        text-transform: uppercase;
    }
    .sms-dir-toggle:hover { background: #6366f1; color: #fff; border-color: #6366f1; }
    .sms-dir-toggle i { font-size: .85rem; }

    .sms-modal-footer {
        background: #f8faff; border-top: 1px solid #e0e7ff;
        padding: 14px 22px; display: flex; justify-content: flex-end; gap: 10px;
    }

    .pc-sms-send-btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px;
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
        color: #fff; border: none; border-radius: 10px;
        padding: 9px 22px; font-size: .88rem; font-weight: 700;
        cursor: pointer; transition: all .2s ease; min-height: 44px;
        box-shadow: 0 3px 12px rgba(99,102,241,.3);
    }
    .pc-sms-send-btn:disabled { opacity: .55; cursor: not-allowed; transform: none; box-shadow: none; }
    .pc-sms-send-btn:not(:disabled):hover { transform: translateY(-1px); box-shadow: 0 5px 18px rgba(99,102,241,.45); }

    /* ── SMS Success Overlay ── */
    .sms-success-overlay {
        position: fixed; inset: 0; z-index: 2000;
        background: rgba(0,0,0,.6); backdrop-filter: blur(6px);
        display: flex; align-items: center; justify-content: center;
        animation: smsOverlayIn .3s ease;
        cursor: pointer;
    }
    @@keyframes smsOverlayIn {
        from { opacity: 0; }
        to   { opacity: 1; }
    }
    .sms-success-card {
        background: #fff; border-radius: 24px;
        padding: 40px 48px; text-align: center;
        box-shadow: 0 30px 80px rgba(0,0,0,.35);
        animation: smsCardIn .4s cubic-bezier(.34,1.56,.64,1);
        min-width: 280px; max-width: 360px;
        cursor: default;
    }
    @@keyframes smsCardIn {
        from { transform: scale(.7) translateY(30px); opacity: 0; }
        to   { transform: scale(1) translateY(0);     opacity: 1; }
    }
    .sms-success-burst {
        position: relative; display: inline-block; margin-bottom: 16px;
    }
    .sms-checkmark {
        width: 72px; height: 72px;
        display: block; margin: 0 auto;
        filter: drop-shadow(0 4px 16px rgba(16,185,129,.4));
    }
    .sms-checkmark-circle {
        stroke: #10b981; stroke-width: 2; stroke-dasharray: 166; stroke-dashoffset: 166;
        animation: smsCircleDraw .6s ease forwards;
    }
    .sms-checkmark-path {
        stroke: #10b981; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
        stroke-dasharray: 48; stroke-dashoffset: 48;
        animation: smsCheckDraw .4s .5s ease forwards;
    }
    @@keyframes smsCircleDraw { to { stroke-dashoffset: 0; } }
    @@keyframes smsCheckDraw  { to { stroke-dashoffset: 0; } }

    .sms-success-title {
        font-size: 1.6rem; font-weight: 800;
        background: linear-gradient(135deg, #10b981, #0ea5e9);
        -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 8px;
        animation: smsTitlePop .4s .8s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-pc {
        font-size: 1.05rem; font-weight: 700; color: #1e293b;
        margin-bottom: 4px;
        animation: smsTitlePop .4s .9s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-phone {
        font-size: .9rem; color: #6366f1; font-weight: 600;
        animation: smsTitlePop .4s 1s cubic-bezier(.34,1.56,.64,1) both;
    }
    .sms-success-hint {
        margin-top: 18px; font-size: .72rem; color: #94a3b8;
        animation: smsTitlePop .4s 1.1s ease both;
    }
    @@keyframes smsTitlePop {
        from { opacity: 0; transform: translateY(10px) scale(.95); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }

    /* ── Tablet / Mobile responsive ── */
    @@media (max-width: 768px) {
        .pc-sms-btn, .pc-purchase-btn { font-size: .78rem; padding: 6px 12px; }
        .sms-success-card { padding: 32px 24px; min-width: 240px; }
        .sms-success-title { font-size: 1.3rem; }
    }
    @@media (max-width: 480px) {
        .sms-modal-content { border-radius: 16px; }
        .sms-modal-header { padding: 16px; }
        .sms-recipient-card { padding: 12px; }
        .sms-checkmark { width: 60px; height: 60px; }
        .sms-success-title { font-size: 1.2rem; }
    }
</style>

@code {
    List<PcListItemEx> _allPcsEx    = [];
    HashSet<int>       _soloPcIds   = new();
    int?               _selPcId;
    bool               _isSolo;
    string             _search      = "";
    bool               _filterHasSessions = false;

    // SMS state
    bool   _showSmsModal      = false;
    bool   _smsSending        = false;
    bool   _smsSuccess        = false;
    bool   _smsRtl            = true;   // default RTL (Hebrew)
    string _smsPhone          = "";
    string _smsMessage        = "";
    string _smsSuccessPcName  = "";
    string _smsSuccessPhone   = "";

    // Solo toggle confirm
    bool   _showSoloConfirm;
    bool   _soloConfirmEnable; // true = enabling, false = disabling
    string _soloConfirmUsername = "";
    bool   _showSoloAdminOnly;  // non-admin clicked Solo Access button
    bool   _isAdmin;

    // Sort state
    string _sortCol  = "hoursLeft";
    bool   _sortAsc  = true;

    PcDetailInfo?       _detail;
    string              _pcAuditorLabel = "";

    // Courses
    List<StudentCourseItem>? _activeCourses;
    List<StudentCourseItem>? _finishedCourses;
    List<StudentCourseItem> AllCoursesSorted =>
        (_activeCourses ?? new()).Concat(_finishedCourses ?? new())
        .OrderByDescending(c => c.DateStarted).ToList();
    int? _confirmFinishCourseId;
    string _confirmFinishCourseName = "";

    // Edit modal
    SpkNewPersonModal _editModal = null!;
    HashSet<string> _existingPcNames = new();

    // Purchase modal
    bool     _showPurchaseModal;
    DateTime _purchaseDate = DateTime.Today;
    string   _purchaseNotes = "";
    string   _purchaseError = "";
    List<PurchaseItemModel> _purchaseItems = new();
    List<PaymentMethodModel> _purchasePaymentMethods = new();
    int? _editingPurchaseId;
    int? _confirmDeletePurchaseId;
    string _origPurchaseSnapshot = "";
    bool   _skipSignature;
    bool   _hasSigned;
    DotNetObjectReference<PCs>? _sigRef;

    List<CourseItem>             _allCourses  = [];
    List<BookItem>               _allBooks    = [];
    List<(int PersonId, string FullName)> _staff      = [];
    List<(int PersonId, string FullName)> _allPersons = [];
    int? _currentPersonId;
    string _username = "";

    // All purchases for this PC (not just pending)
    List<PurchaseListItem>? _pcPurchases;
    Dictionary<int, int> _coursePurchaseMap = new(); // CourseId → PurchaseId
    Dictionary<int, string> _coursePurchaseStatusMap = new(); // CourseId → ApprovedStatus
    Dictionary<int, int> _courseAmountMap = new(); // CourseId → AmountPaid
    int? _latestAuditingPurchaseId;

    // Auditing purchases display
    List<AuditingPurchaseDisplay> _auditingPurchases = new();
    record AuditingPurchaseDisplay(int PurchaseId, string Date, int HoursBought, int Amount, string Status);
    List<CompletionService.PcCompletionDetail> _pcCompletions = [];

    class PurchaseItemModel
    {
        public string ItemType { get; set; } = "Auditing";
        public int CourseId { get; set; }
        public int BookId { get; set; }
        public int HoursBought { get; set; }
        public int AmountPaid { get; set; }
    }

    // Purchase-level registrar/referral
    int _purchaseRegistrarId;
    int _purchaseReferralId;

    class PaymentMethodModel
    {
        public string MethodType { get; set; } = "Cash";
        public int Amount { get; set; }
        public DateTime? PaymentDate { get; set; } = DateTime.Today;
    }

    IEnumerable<PcListItemEx> FilteredPcsEx
    {
        get
        {
            var list = string.IsNullOrWhiteSpace(_search)
                ? _allPcsEx.AsEnumerable()
                : _allPcsEx.Where(p =>
                    p.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                    p.Nick.Contains(_search, StringComparison.OrdinalIgnoreCase));

            if (_filterHasSessions)
                list = list.Where(p => p.TotalSessions > 0);

            list = (_sortCol, _sortAsc) switch
            {
                ("name", true)       => list.OrderBy(p => p.FullName),
                ("name", false)      => list.OrderByDescending(p => p.FullName),
                ("hoursLeft", true)  => list.OrderBy(p => p.RemainSec),
                ("hoursLeft", false) => list.OrderByDescending(p => p.RemainSec),
                ("totalTime", true)  => list.OrderBy(p => p.TotalSessionSec),
                ("totalTime", false) => list.OrderByDescending(p => p.TotalSessionSec),
                ("visits", true)     => list.OrderBy(p => p.AcademyVisits),
                ("visits", false)    => list.OrderByDescending(p => p.AcademyVisits),
                ("purchased", true)  => list.OrderBy(p => p.HoursPurchased),
                ("purchased", false) => list.OrderByDescending(p => p.HoursPurchased),
                _ => list.OrderBy(p => p.RemainSec)
            };

            return list;
        }
    }

    async Task ToggleSort(string col)
    {
        if (_sortCol == col) _sortAsc = !_sortAsc;
        else { _sortCol = col; _sortAsc = true; }
        await JS.InvokeVoidAsync("localStorage.setItem", "pcs_sortCol", _sortCol);
        await JS.InvokeVoidAsync("localStorage.setItem", "pcs_sortAsc", _sortAsc.ToString());
    }

    string SortClass(string col) =>
        _sortCol != col ? "" : _sortAsc ? "sort-asc" : "sort-desc";



    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var col = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortCol");
            var asc = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortAsc");
            if (!string.IsNullOrEmpty(col)) _sortCol = col;
            if (!string.IsNullOrEmpty(asc)) _sortAsc = asc == "True";

            StateHasChanged();
            try { await JS.InvokeVoidAsync("lpmInitColResize", "pc-list-table"); }
            catch { /* non-critical: column resize unavailable */ }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _allPcsEx   = PcSvc.GetAllPcsExtended();
        _soloPcIds  = DashSvc.GetSoloPcIds();
        _allCourses = CourseSvc.GetAllCourses();
        _allBooks   = CourseSvc.GetAllBooks();
        _staff      = PcSvc.GetStaff();
        _allPersons = PcSvc.GetAllPersons();

        var auth = await AuthState.GetAuthenticationStateAsync();
        _username = auth.User.Identity?.Name ?? "";
        _isAdmin  = auth.User.IsInRole("Admin");
        _currentPersonId = !string.IsNullOrEmpty(_username) ? PcSvc.GetPersonIdByUsername(_username) : null;
    }

    void SelectPc(int pcId)
    {
        if (_selPcId == pcId) { _selPcId = null; return; }
        _selPcId = pcId;
        LoadDetail();
    }

    void CloseDrawer() => _selPcId = null;

    void LoadDetail()
    {
        if (!_selPcId.HasValue) return;
        _detail            = PcSvc.GetPcDetail(_selPcId.Value);
        _isSolo            = _soloPcIds.Contains(_selPcId.Value);
        _pcAuditorLabel    = DashSvc.GetLastAuditorLabel(_selPcId.Value);
        _pcPurchases       = PcSvc.GetAllPurchasesForPc(_selPcId.Value);
        var allCourses     = CourseSvc.GetStudentCourses(_selPcId.Value);
        _activeCourses     = allCourses.Where(c => c.DateFinished == null).ToList();
        _finishedCourses   = allCourses.Where(c => c.DateFinished != null).ToList();

        // Build CourseId → PurchaseId map, find latest auditing purchase, build auditing purchases list
        _coursePurchaseMap.Clear();
        _coursePurchaseStatusMap.Clear();
        _courseAmountMap.Clear();
        _latestAuditingPurchaseId = null;
        _auditingPurchases.Clear();
        _pcCompletions = CompletionSvc.GetByPcWithAuditorName(_selPcId.Value);
        if (_pcPurchases != null)
        {
            foreach (var p in _pcPurchases)
            {
                var detail = PcSvc.GetPurchaseDetail(p.PurchaseId);
                if (detail == null) continue;
                foreach (var item in detail.Items)
                {
                    if (item.CourseId.HasValue && !_coursePurchaseMap.ContainsKey(item.CourseId.Value))
                    {
                        _coursePurchaseMap[item.CourseId.Value] = p.PurchaseId;
                        _coursePurchaseStatusMap[item.CourseId.Value] = p.ApprovedStatus;
                        _courseAmountMap[item.CourseId.Value] = item.AmountPaid;
                    }
                    if (item.ItemType == "Auditing")
                    {
                        if (!_latestAuditingPurchaseId.HasValue)
                            _latestAuditingPurchaseId = p.PurchaseId;
                        _auditingPurchases.Add(new AuditingPurchaseDisplay(
                            p.PurchaseId, p.PurchaseDate, item.HoursBought, item.AmountPaid, p.ApprovedStatus));
                    }
                }
            }
        }
    }


    void OpenEditModal()
    {
        if (_detail == null) return;
        _existingPcNames = new HashSet<string>(
            _allPcsEx.Select(p => p.FullName), StringComparer.OrdinalIgnoreCase);
        _editModal.ShowForEdit(
            _detail.FirstName, _detail.LastName,
            _detail.Phone, _detail.Email,
            _detail.DateOfBirth, _detail.Gender,
            _detail.OrgId, _detail.Source, _detail.Notes, _detail.Nick);
    }

    void SaveEditFromModal((string FirstName, string LastName, string Phone, string Email,
        string DateOfBirth, string Gender, int OrgId, string Source, string Notes, int CourseId, string Nick) d)
    {
        Console.WriteLine($"[PCs] Updated PC {_selPcId!.Value} — '{d.FirstName} {d.LastName}' nick='{d.Nick}' by '{_username}'");
        PcSvc.UpdatePcDetail(_selPcId!.Value,
            d.FirstName, d.LastName, d.Nick,
            d.Phone, d.Email, d.Notes,
            d.DateOfBirth, d.Gender, orgId: d.OrgId > 0 ? d.OrgId : null);
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    // ── Course finish ──
    void AskFinishCourse(int studentCourseId, string courseName)
    {
        _confirmFinishCourseId = studentCourseId;
        _confirmFinishCourseName = courseName;
    }

    void ConfirmFinishCourse()
    {
        if (!_confirmFinishCourseId.HasValue) return;
        Console.WriteLine($"[PCs] Finished course enrollment {_confirmFinishCourseId.Value} for PC {_selPcId} by '{_username}'");
        CourseSvc.FinishStudentCourse(_confirmFinishCourseId.Value, DateTime.Today.ToString("yyyy-MM-dd"));
        _confirmFinishCourseId = null;
        LoadDetail();
    }

    // ── Purchase modal ──────────────────────────────────────────────

    string GetPurchaseSnapshot()
    {
        var items = string.Join("|", _purchaseItems.Select(i => $"{i.ItemType},{i.CourseId},{i.BookId},{i.HoursBought},{i.AmountPaid}"));
        var pms = string.Join("|", _purchasePaymentMethods.Select(m => $"{m.MethodType},{m.Amount},{m.PaymentDate?.ToString("yyyy-MM-dd")}"));
        return $"{_purchaseDate:yyyy-MM-dd}~{_purchaseNotes}~{_purchaseRegistrarId}~{_purchaseReferralId}~{items}~{pms}";
    }

    async Task OpenPurchaseModal()
    {
        _showPurchaseModal = true;
        _editingPurchaseId = null;
        _purchaseDate      = DateTime.Today;
        _purchaseNotes     = "";
        _purchaseError     = "";
        _skipSignature     = false;
        _hasSigned         = false;
        _allCourses        = CourseSvc.GetAllCourses();
        _allBooks          = CourseSvc.GetAllBooks();
        _purchaseRegistrarId = _currentPersonId ?? 0;
        _purchaseReferralId  = 0;
        _purchaseItems     = new List<PurchaseItemModel>
        {
            new PurchaseItemModel()
        };
        _purchasePaymentMethods = new List<PaymentMethodModel>
        {
            new PaymentMethodModel()
        };
        StateHasChanged();
        await Task.Delay(100);
        await InitSignaturePad();
        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task OpenEditPurchase(int purchaseId)
    {
        var detail = PcSvc.GetPurchaseDetail(purchaseId);
        if (detail == null) return;

        _showPurchaseModal = true;
        _editingPurchaseId = purchaseId;
        _purchaseError     = "";
        _skipSignature     = string.IsNullOrEmpty(detail.SignatureData);
        _hasSigned         = !string.IsNullOrEmpty(detail.SignatureData);
        _allCourses        = CourseSvc.GetAllCourses();
        _allBooks          = CourseSvc.GetAllBooks();

        _purchaseDate = DateTime.TryParse(detail.PurchaseDate, out var dt) ? dt : DateTime.Today;
        _purchaseNotes = detail.Notes ?? "";

        _purchaseRegistrarId = detail.RegistrarId ?? 0;
        _purchaseReferralId  = detail.ReferralId ?? 0;
        _purchaseItems = detail.Items.Select(it => new PurchaseItemModel
        {
            ItemType    = it.ItemType,
            CourseId    = it.CourseId ?? 0,
            BookId      = it.BookId ?? 0,
            HoursBought = it.HoursBought,
            AmountPaid  = it.AmountPaid
        }).ToList();
        if (_purchaseItems.Count == 0)
            _purchaseItems.Add(new PurchaseItemModel());

        _purchasePaymentMethods = detail.PaymentMethods.Select(pm => new PaymentMethodModel
        {
            MethodType  = pm.MethodType,
            Amount      = pm.Amount,
            PaymentDate = DateTime.TryParse(pm.PaymentDate, out var pdt) ? pdt : null
        }).ToList();
        if (_purchasePaymentMethods.Count == 0)
            _purchasePaymentMethods.Add(new PaymentMethodModel());

        StateHasChanged();
        await Task.Delay(100);
        if (!_skipSignature)
        {
            await InitSignaturePad();
            if (!string.IsNullOrEmpty(detail.SignatureData))
                await JS.InvokeVoidAsync("SignaturePad.drawImage", "signatureCanvas", detail.SignatureData);
        }

        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task ClosePurchaseModal()
    {
        _showPurchaseModal = false;
        if (!_skipSignature)
            await JS.InvokeVoidAsync("SignaturePad.dispose", "signatureCanvas");
        _sigRef?.Dispose();
        _sigRef = null;
    }

    void AddPurchaseItem()
    {
        _purchaseItems.Add(new PurchaseItemModel());
    }

    void AddPaymentMethod()
    {
        _purchasePaymentMethods.Add(new PaymentMethodModel());
    }

    void RemovePurchaseItem(int idx)
    {
        if (_purchaseItems.Count > 1)
            _purchaseItems.RemoveAt(idx);
    }

    void SetItemType(int idx, string type)
    {
        _purchaseItems[idx].ItemType = type;
        if (type != "Course") _purchaseItems[idx].CourseId = 0;
        if (type != "Book") _purchaseItems[idx].BookId = 0;
        if (type != "Auditing") _purchaseItems[idx].HoursBought = 0;
    }

    void AutoFillBookPrice(PurchaseItemModel item)
    {
        if (item.AmountPaid != 0) return;
        var book = _allBooks.FirstOrDefault(b => b.BookId == item.BookId);
        if (book != null) item.AmountPaid = book.Price;
    }

    bool HasValidPurchaseItems()
    {
        return _purchaseItems.Any(item =>
            (item.ItemType == "Auditing" && item.HoursBought > 0) ||
            (item.ItemType == "Course" && item.CourseId > 0) ||
            (item.ItemType == "Book" && item.BookId > 0));
    }

    bool IsItemValid(PurchaseItemModel item)
    {
        return (item.ItemType == "Auditing" && item.HoursBought > 0) ||
               (item.ItemType == "Course" && item.CourseId > 0) ||
               (item.ItemType == "Book" && item.BookId > 0);
    }

    bool CanAddMoreItems()
    {
        // Only allow adding a new item if the last one is valid
        return _purchaseItems.Count == 0 || IsItemValid(_purchaseItems[^1]);
    }

    bool CanAddMorePayments()
    {
        // Only allow adding a new payment if the last one has an amount
        return _purchasePaymentMethods.Count == 0 || _purchasePaymentMethods[^1].Amount > 0;
    }

    bool IsPaymentBalanced()
    {
        var itemsTotal = _purchaseItems.Sum(x => x.AmountPaid);
        var pmTotal = _purchasePaymentMethods.Sum(m => m.Amount);
        return pmTotal == itemsTotal;
    }

    async Task SavePurchase()
    {
        _purchaseError = "";

        // Validate items
        foreach (var item in _purchaseItems)
        {
            if (item.ItemType == "Course" && item.CourseId <= 0)
            { _purchaseError = LS.T("pcs.errorSelectCourse"); return; }
            if (item.ItemType == "Auditing" && item.HoursBought <= 0)
            { _purchaseError = LS.T("pcs.errorEnterHoursOrAmount"); return; }
            if (item.ItemType == "Book" && item.BookId <= 0)
            { _purchaseError = "Please select a book"; return; }
        }

        // Get signature — required unless skipped
        string? sigData = _skipSignature ? null
            : await JS.InvokeAsync<string?>("SignaturePad.getDataUrl", "signatureCanvas");
        if (!_skipSignature && string.IsNullOrEmpty(sigData))
        { _purchaseError = LS.T("pcs.signatureRequired"); return; }

        var items = _purchaseItems.Select(pi => (
            itemType:    pi.ItemType,
            courseId:    pi.ItemType == "Course" ? (int?)pi.CourseId : null,
            bookId:     pi.ItemType == "Book" ? (int?)pi.BookId : null,
            hoursBought: pi.ItemType == "Auditing" ? pi.HoursBought : 0,
            amountPaid:  pi.AmountPaid
        )).ToList();

        int? regId = _purchaseRegistrarId > 0 ? _purchaseRegistrarId : null;
        int? refId = _purchaseReferralId > 0 ? _purchaseReferralId : null;

        var pmList = _purchasePaymentMethods
            .Where(m => m.Amount > 0)
            .Select(m => (m.MethodType, m.Amount, paymentDate: m.PaymentDate?.ToString("yyyy-MM-dd")))
            .ToList();

        if (_editingPurchaseId.HasValue)
        {
            // Check if anything changed
            if (GetPurchaseSnapshot() == _origPurchaseSnapshot)
            {
                _purchaseError = LS.T("purchases.nothingChanged");
                return;
            }
            var itemsLog = string.Join("; ", items.Select(x => x.itemType == "Course" ? $"Course(id={x.courseId}) ₪{x.amountPaid}" : x.itemType == "Book" ? $"Book(id={x.bookId}) ₪{x.amountPaid}" : $"Auditing {x.hoursBought}h ₪{x.amountPaid}"));
            var pmLog    = string.Join("; ", pmList.Select(m => $"{m.MethodType} ₪{m.Amount} on {m.paymentDate}"));
            Console.WriteLine($"[PCs] Updated purchase {_editingPurchaseId.Value} for PC {_selPcId} date={_purchaseDate:yyyy-MM-dd} items=[{itemsLog}] payments=[{pmLog}] reg={regId} ref={refId} notes='{_purchaseNotes}' by '{_username}'");
            PcSvc.UpdatePurchase(_editingPurchaseId.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                items, pmList, regId, refId);
        }
        else
        {
            var itemsLog = string.Join("; ", items.Select(x => x.itemType == "Course" ? $"Course(id={x.courseId}) ₪{x.amountPaid}" : x.itemType == "Book" ? $"Book(id={x.bookId}) ₪{x.amountPaid}" : $"Auditing {x.hoursBought}h ₪{x.amountPaid}"));
            var pmLog    = string.Join("; ", pmList.Select(m => $"{m.MethodType} ₪{m.Amount} on {m.paymentDate}"));
            Console.WriteLine($"[PCs] Created purchase for PC {_selPcId!.Value} date={_purchaseDate:yyyy-MM-dd} items=[{itemsLog}] payments=[{pmLog}] reg={regId} ref={refId} notes='{_purchaseNotes}' by '{_username}'");
            PcSvc.CreatePurchase(
                _selPcId!.Value,
                _purchaseDate.ToString("yyyy-MM-dd"),
                string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
                sigData,
                _currentPersonId,
                items, pmList, regId, refId);

            // Send automatic message to admins about the purchase
            if (_currentPersonId.HasValue && _detail != null)
            {
                var totalAmt = items.Sum(i => i.amountPaid);
                var totalHrs = items.Where(i => i.itemType == "Auditing").Sum(i => i.hoursBought);
                var msg = $"Automatic msg: New purchase for {_detail.FullName}";
                if (totalHrs > 0) msg += $" — {totalHrs}h";
                if (totalAmt > 0) msg += $" — \u20AA{totalAmt}";
                DashSvc.SendAutoMessageToAdmins(_currentPersonId.Value, msg);
            }
        }

        await ClosePurchaseModal();
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    async Task ToggleSkipSignature(ChangeEventArgs e)
    {
        _skipSignature = (bool)(e.Value ?? false);
        _hasSigned = false;
        if (!_skipSignature)
        {
            StateHasChanged();
            await Task.Delay(100);
            await InitSignaturePad();
        }
    }

    async Task ClearSignature()
    {
        await JS.InvokeVoidAsync("SignaturePad.clear", "signatureCanvas");
        _hasSigned = false;
    }

    async Task InitSignaturePad()
    {
        _sigRef?.Dispose();
        _sigRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("SignaturePad.init", "signatureCanvas", _sigRef);
    }

    [JSInvokable]
    public void OnSignatureDrawn()
    {
        _hasSigned = true;
        InvokeAsync(StateHasChanged);
    }

    async Task PrintPurchase()
    {
        string? sigData = await JS.InvokeAsync<string?>("SignaturePad.getDataUrl", "signatureCanvas");

        var printItems = _purchaseItems.Select(pi => new
        {
            itemType = pi.ItemType,
            courseName = pi.ItemType == "Course" && pi.CourseId > 0
                ? _allCourses.FirstOrDefault(c => c.CourseId == pi.CourseId)?.Name ?? "Course"
                : "",
            hoursBought = pi.HoursBought,
            amountPaid = pi.AmountPaid,
            registrarName = _purchaseRegistrarId > 0
                ? _staff.FirstOrDefault(s => s.PersonId == _purchaseRegistrarId).FullName ?? ""
                : "",
            referralName = _purchaseReferralId > 0
                ? _allPersons.FirstOrDefault(p => p.PersonId == _purchaseReferralId).FullName ?? ""
                : ""
        }).ToArray();

        await JS.InvokeVoidAsync("PrintPurchase.printReceipt",
            _detail!.FullName,
            _purchaseDate.ToString("dd/MM/yyyy"),
            printItems,
            string.IsNullOrWhiteSpace(_purchaseNotes) ? null : _purchaseNotes,
            sigData);
    }

    void ConfirmDeletePurchase()
    {
        if (!_confirmDeletePurchaseId.HasValue) return;
        Console.WriteLine($"[PCs] Deleted purchase {_confirmDeletePurchaseId.Value} for PC {_selPcId} by '{_username}'");
        PcSvc.DeletePurchase(_confirmDeletePurchaseId.Value);
        _confirmDeletePurchaseId = null;
        _allPcsEx = PcSvc.GetAllPcsExtended();
        LoadDetail();
    }

    // Decimal hours label for PC list (e.g. "3:48" / "-1:25")
    static string HrsLabel(long secs)
    {
        var sign = secs < 0 ? "-" : "";
        var abs  = Math.Abs(secs);
        var h    = abs / 3600;
        var m    = (abs % 3600) / 60;
        return $"{sign}{h}:{m:D2}";
    }

    // H:MM from seconds — integer arithmetic, always exact
    static string Hmm(int secs)
    {
        int s = Math.Abs(secs);
        return $"{s / 3600}:{(s % 3600) / 60:00}";
    }
    static string FormatDate(string dateStr) =>
        DateOnly.TryParse(dateStr, out var d) ? d.ToString("dd/MM/yy") : dateStr;

    // ── Solo access toggle ──

    void AskToggleSolo()
    {
        if (_detail == null) return;
        if (!_isAdmin) { _showSoloAdminOnly = true; return; }
        _soloConfirmEnable = !_isSolo;
        // Pre-compute the username preview for the enable dialog
        if (_soloConfirmEnable)
        {
            var fn = _detail.FirstName.Trim().ToLower();
            var ln = _detail.LastName.Trim().ToLower();
            _soloConfirmUsername = string.IsNullOrEmpty(ln) ? fn : $"{fn}.{ln}";
        }
        _showSoloConfirm = true;
    }

    void ConfirmToggleSolo()
    {
        if (_detail == null || !_selPcId.HasValue) return;
        _showSoloConfirm = false;

        if (_soloConfirmEnable)
        {
            var (username, newPassword) = UserDb.EnableSoloAuditor(_selPcId.Value, _detail.FirstName, _detail.LastName);
            Console.WriteLine($"[PCs] Solo access granted for PC {_selPcId.Value} ('{username}') by '{_username}'");
            if (newPassword is not null)
            {
                var (_, phone) = PcSvc.GetPersonContact(_selPcId.Value);
                if (!string.IsNullOrWhiteSpace(phone))
                {
                    var msg = $"Welcome to LPM!\nUsername: {username}\nPassword: {newPassword}\nSite: lpmanager.cv";
                    _ = SmsSvc.SendSmsAsync(phone, msg);
                }
            }
        }
        else
        {
            UserDb.DisableSoloAuditor(_selPcId.Value);
            Console.WriteLine($"[PCs] Solo access revoked for PC {_selPcId.Value} by '{_username}'");
        }

        _soloPcIds = DashSvc.GetSoloPcIds();
        _isSolo    = _soloPcIds.Contains(_selPcId.Value);
    }

