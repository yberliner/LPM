<style>
    /* ── Responsive two-panel layout ── */
    .pc-layout { height: calc(100vh - 130px); overflow: hidden; }
    .pc-left-panel { width: 340px; min-width: 340px; }
    @@media (max-width: 768px) {
        .pc-layout { flex-direction: column; height: auto; overflow: visible; }
        .pc-left-panel { width: 100% !important; min-width: 0 !important; max-height: 40vh; overflow-y: auto; }
    }

    /* ── Header card ── */
    .pc-header-card {
        background: var(--custom-white, #fff);
        border-radius: 16px;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 16px rgba(0,0,0,.04);
        border: 1px solid rgba(0,0,0,.06);
        overflow: hidden;
    }
    .pc-header-top {
        display: flex; align-items: center; gap: 16px;
        padding: 14px 18px;
    }
    .pc-header-avatar {
        width: 50px; height: 50px; border-radius: 14px; flex-shrink: 0;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
