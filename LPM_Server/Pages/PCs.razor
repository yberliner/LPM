                                                                value="@(e.CsId?.ToString() ?? "0")"
                                                                @onchange="(ev) => OnPendingCsChanged(e.StudentCourseId, ev)">
                                                            <option value="0">None</option>
                                                            @foreach (var u in _csList)
                                                            {
                                                                <option value="@u.Id">@u.FullName</option>
                                                            }
                                                        </select>
                                                    }
                                                    else
