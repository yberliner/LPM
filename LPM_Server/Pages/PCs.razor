        _walletModalPcId = pcId;
        _walletModalPcName = pcName;
        _walletModalOpen = true;
    }

    async Task OpenEditWallet(int pcId, string pcName, int walletId)
    {
        await EnsureCurrentUserId();
        _walletModalEditingId = walletId;
        _walletModalPcId = pcId;
        _walletModalPcName = pcName;
        _walletModalOpen = true;
    }

    async Task OpenTransferWallet(int walletId)
    {
        await EnsureCurrentUserId();
        _walletTransferSourceId = walletId;
        _walletTransferModalOpen = true;
    }

    Task CloseWalletModal()
    {
        _walletModalOpen = false;
        _walletModalEditingId = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    void OnWalletSaved(int walletId)
    {
        _walletModalOpen = false;
        _walletModalEditingId = null;
        LoadWalletBalancesForAll();
        StateHasChanged();
    }

    void OnWalletDeleted(int walletId)
    {
        _walletModalOpen = false;
        _walletModalEditingId = null;
        LoadWalletBalancesForAll();
        StateHasChanged();
    }

    Task CloseTransferModal()
    {
        _walletTransferModalOpen = false;
        _walletTransferSourceId = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    void OnTransferred()
    {
        _walletTransferModalOpen = false;
        _walletTransferSourceId = null;
        LoadWalletBalancesForAll();
        _balances = PcSvc.GetAllPcBalances();
        StateHasChanged();
    }
}
