                    <span class="fw-semibold small" style="color:#3949ab;">
                        <i class="ri-hourglass-line me-1"></i>@LS.T("pcs.pendingCourses")
                        <span class="badge rounded-pill ms-1" style="background:#e0e7ff;color:#3949ab;font-size:.75rem;">@_pendingCourses.Count(e => e.DateFinished == null)</span>
                    </span>
