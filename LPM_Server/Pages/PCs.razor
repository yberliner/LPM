    string GetPurchaseSnapshot()
    {
        var items = string.Join("|", _purchaseItems.Select(i => $"{i.ItemType},{i.CourseId},{i.BookId},{i.HoursBought},{i.AmountPaid}"));
        var pms = string.Join("|", _purchasePaymentMethods.Select(m => $"{m.MethodType},{m.Amount},{m.PaymentDate?.ToString("yyyy-MM-dd")},{m.Installments}"));
        return $"{_purchaseDate:yyyy-MM-dd}~{_purchaseCurrency}~{_purchaseNotes}~{_purchaseRegistrarId}~{_purchaseReferralId}~{items}~{pms}";
    }

    async Task OpenPurchaseModal()
    {
        _showPurchaseModal = true;
        _editingPurchaseId = null;
        _purchaseDate      = DateTime.Today;
        _purchaseNotes     = "";
        _purchaseError     = "";
        _skipSignature     = false;
        _hasSigned         = false;
        _purchaseCurrency  = _selPcId.HasValue ? PcSvc.GetLastPurchaseCurrencyForPc(_selPcId.Value) : "ILS";
        LoadPurchaseWalletOptions();
        // Preselect wallet: active wallet matching last purchase currency; else first active
        {
            var active = _purchaseWalletOptions.Where(w => w.IsActive).ToList();
            var match = active.FirstOrDefault(w => w.Currency == _purchaseCurrency) ?? active.FirstOrDefault();
            _purchaseWalletId = match?.WalletId ?? 0;
            if (match != null) _purchaseCurrency = match.Currency;
        }
        _allCourses        = CourseSvc.GetAllCourses();
        _allBooks          = CourseSvc.GetAllBooks();
        _purchaseRegistrarId = _currentPersonId ?? 0;
        _purchaseReferralId  = 0;
        // Default rate: last purchase rate for the selected wallet; 0 if none.
        int _defAudRate = _purchaseWalletId > 0 ? PcSvc.GetLastPurchaseRateForWallet(_purchaseWalletId) : 0;
        _purchaseItems     = new List<PurchaseItemModel>
        {
            new PurchaseItemModel { RatePerHour = _defAudRate }
        };
        _purchasePaymentMethods = new List<PaymentMethodModel>
        {
            new PaymentMethodModel()
        };
        StateHasChanged();
        await Task.Delay(100);
        await InitSignaturePad();
        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task OpenEditPurchase(int purchaseId)
    {
        var detail = PcSvc.GetPurchaseDetail(purchaseId);
        if (detail == null) return;

        _showPurchaseModal = true;
        _editingPurchaseId = purchaseId;
        _purchaseError     = "";
        _skipSignature     = string.IsNullOrEmpty(detail.SignatureData);
        _hasSigned         = !string.IsNullOrEmpty(detail.SignatureData);
        _allCourses        = CourseSvc.GetAllCourses();
        _allBooks          = CourseSvc.GetAllBooks();

        _purchaseDate = DateTime.TryParse(detail.PurchaseDate, out var dt) ? dt : DateTime.Today;
        _purchaseNotes = detail.Notes ?? "";
        _purchaseCurrency = detail.Currency;
        _purchaseWalletId = detail.WalletId ?? 0;
        LoadPurchaseWalletOptions();

        _purchaseRegistrarId = detail.RegistrarId ?? 0;
        _purchaseReferralId  = detail.ReferralId ?? 0;
        _purchaseItems = detail.Items.Select(it =>
        {
            var m = new PurchaseItemModel
            {
                ItemType    = it.ItemType,
                CourseId    = it.CourseId ?? 0,
                BookId      = it.BookId ?? 0,
                HoursBought = it.HoursBought,
                AmountPaid  = it.AmountPaid
            };
            if (it.ItemType == "Auditing")
            {
                int totalSec = (int)Math.Round(Math.Abs(it.HoursBought) * 3600);
                int wh = totalSec / 3600;
                int wm = (totalSec % 3600) / 60;
                int ws = totalSec % 60;
                m.HoursH = wh.ToString();
                m.HoursM = wm.ToString("D2");
                m.Sec    = ws.ToString("D2");
                m.IsNegativeHours = it.HoursBought < 0;
                m.RatePerHour = it.HoursBought != 0 ? (int)Math.Round(Math.Abs(it.AmountPaid / it.HoursBought)) : 0; // double/double → exact rate
            }
            return m;
        }).ToList();
        if (_purchaseItems.Count == 0)
            _purchaseItems.Add(new PurchaseItemModel());

        // Merge installment rows back: group CreditCard rows with Installments > 1 by contiguous monthly dates
        var rawPms = detail.PaymentMethods.ToList();
        var mergedPms = new List<PaymentMethodModel>();
        var used = new HashSet<int>();
        for (int pi = 0; pi < rawPms.Count; pi++)
        {
            if (used.Contains(pi)) continue;
            var pm = rawPms[pi];
            if (pm.MethodType == "CreditCard" && pm.Installments > 1)
            {
                // Find all consecutive CC rows with same Installments value
                var group = new List<PurchasePaymentMethodInfo> { pm };
                used.Add(pi);
                for (int pj = pi + 1; pj < rawPms.Count; pj++)
                {
                    if (used.Contains(pj)) continue;
                    var next = rawPms[pj];
                    if (next.MethodType == "CreditCard" && next.Installments == pm.Installments)
                    { group.Add(next); used.Add(pj); }
                    else break;
                }
                var totalAmt = group.Sum(g => g.Amount);
                var earliest = group.Min(g => g.PaymentDate);
                mergedPms.Add(new PaymentMethodModel
                {
                    MethodType = "CreditCard", Amount = totalAmt, Installments = pm.Installments,
                    PaymentDate = DateTime.TryParse(earliest, out var epdt) ? epdt : null
                });
            }
            else
            {
                used.Add(pi);
                mergedPms.Add(new PaymentMethodModel
                {
                    MethodType = pm.MethodType, Amount = pm.Amount, Installments = pm.Installments,
                    PaymentDate = DateTime.TryParse(pm.PaymentDate, out var pdt) ? pdt : null
                });
            }
        }
        _purchasePaymentMethods = mergedPms;
        if (_purchasePaymentMethods.Count == 0)
            _purchasePaymentMethods.Add(new PaymentMethodModel());

        StateHasChanged();
        await Task.Delay(100);
        if (!_skipSignature)
        {
            await InitSignaturePad();
            if (!string.IsNullOrEmpty(detail.SignatureData))
                await JS.InvokeVoidAsync("SignaturePad.drawImage", "signatureCanvas", detail.SignatureData);
        }

        _origPurchaseSnapshot = GetPurchaseSnapshot();
    }

    async Task ClosePurchaseModal()
    {
        _showPurchaseModal = false;
        if (!_skipSignature)
            await JS.InvokeVoidAsync("SignaturePad.dispose", "signatureCanvas");
        _sigRef?.Dispose();
        _sigRef = null;
    }

    // ── Hard-delete purchase flow ──────────────────────────────────────
    void OpenDeletePurchaseConfirm()
    {
        if (!_editingPurchaseId.HasValue) return;
        _delPurchStep        = 1;
        _delPurchInput       = "";
        _delPurchError       = "";
        _delPurchBusy        = false;
        _delPurchRowsDeleted = 0;
        _delPurchInfo        = null;
        var pid   = _editingPurchaseId.Value;
        var token = ++_delPurchLoadToken;
        _ = Task.Run(() =>
        {
            try
            {
                var info = PcSvc.LoadPurchaseDeleteInfo(pid);
                InvokeAsync(() =>
                {
                    if (token == _delPurchLoadToken && _delPurchStep > 0)
                    {
                        _delPurchInfo = info;
                        StateHasChanged();
                    }
                });
            }
            catch (Exception ex)
            {
                InvokeAsync(() =>
                {
                    if (token == _delPurchLoadToken)
                    {
                        _delPurchError = ex.Message;
                        StateHasChanged();
                    }
                });
            }
        });
    }

    void CancelDeletePurchase()
    {
        _delPurchStep        = 0;
        _delPurchInput       = "";
        _delPurchError       = "";
        _delPurchBusy        = false;
        _delPurchInfo        = null;
        _delPurchRowsDeleted = 0;
        _delPurchLoadToken++;
    }

    async Task ExecuteHardDeletePurchase()
    {
        if (_delPurchInput != "delete" || !_editingPurchaseId.HasValue) return;
        _delPurchBusy  = true;
        _delPurchError = "";
        _delPurchStep  = 3;
        StateHasChanged();

        var pid = _editingPurchaseId.Value;
        var actor = _username ?? "unknown";

        // Audit log: dump every row we're about to delete
        if (_delPurchInfo != null)
        {
            Console.WriteLine($"[PCs] HardDeletePurchase initiated by '{actor}' — PurchaseId={pid} totalRows={_delPurchInfo.TotalRowCount}");
            foreach (var p in _delPurchInfo.Purchases)
                Console.WriteLine($"[PCs]   fin_purchases row: {string.Join(", ", p.Cols.Zip(p.Values, (c, v) => $"{c}={v}"))}");
            foreach (var fk in _delPurchInfo.FkTables)
                foreach (var row in fk.Rows)
                    Console.WriteLine($"[PCs]   {fk.Table} row: {string.Join(", ", fk.Cols.Zip(row, (c, v) => $"{c}={v}"))}");
            foreach (var row in _delPurchInfo.Enrollments.Rows)
                Console.WriteLine($"[PCs]   {_delPurchInfo.Enrollments.Table} row: {string.Join(", ", _delPurchInfo.Enrollments.Cols.Zip(row, (c, v) => $"{c}={v}"))}");
        }

        try
        {
            var deleted = await Task.Run(() => PcSvc.HardDeletePurchase(pid, actor));
            _delPurchRowsDeleted = deleted;
            _delPurchStep = 4;
            StateHasChanged();

            // Best-effort cleanup — failures here must NOT revert the success animation,
            // because the delete has already committed.
            try { await ClosePurchaseModal(); }
            catch (Exception ex) { Console.WriteLine($"[PCs] ClosePurchaseModal after hard-delete failed (ignored): {ex.Message}"); }
            try
            {
                if (_selPcId.HasValue)
                    _pcPurchases = PcSvc.GetAllPurchasesForPc(_selPcId.Value);
                _allPcsEx = PcSvc.GetAllPcsExtended();
                _balances = PcSvc.GetAllPcBalances();
                LoadWalletBalancesForAll();
                _mixedCurrencyPcs = PcSvc.GetPcsWithMixedCurrencies();
                _mixedRates = PcSvc.GetPcsWithMixedRates();
        _sessionMixedRates = PcSvc.GetPcsWithMixedSessionRatesIn30Days();
                LoadDetail();
            }
            catch (Exception ex) { Console.WriteLine($"[PCs] post-delete refresh failed (ignored): {ex.Message}"); }
            StateHasChanged();

            await Task.Delay(1800);
            CancelDeletePurchase();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _delPurchError = ex.Message;
            _delPurchStep  = 2;
            Console.WriteLine($"[PCs] HardDeletePurchase failed for {pid}: {ex.Message}");
        }
        finally
        {
            _delPurchBusy = false;
        }
    }

