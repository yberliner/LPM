    static string FormatNis(decimal amount) => $"₪{amount:N0}";
    static string FormatNis2(decimal amount) => $"₪{amount:N2}";

    // 10.5 → "10:30", 2.75 → "2:45" (always positive, sign handled separately)
    static string FormatHoursMinutes(double hours)
    {
        hours = Math.Abs(hours);
        int h = (int)hours;
        int m = (int)Math.Round((hours - h) * 60);
        if (m >= 60) { h++; m = 0; }
        return $"{h}:{m:D2}";
    }

    void RecalcAuditing(PurchaseItemModel item)
    {
        int.TryParse(item.HoursH, out var h);
        int.TryParse(item.HoursM, out var m);
        m = Math.Clamp(m, 0, 59);
        double hrs = Math.Abs(h) + m / 60.0;
        item.HoursBought = item.IsNegativeHours ? -hrs : hrs;
        item.AmountPaid = (int)(item.HoursBought * item.RatePerHour);
    }
