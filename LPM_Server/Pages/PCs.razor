    static string FormatRatePerHour(int cents)
    {
        var v = cents / 100.0;
        return v == Math.Truncate(v) ? ((int)v).ToString() : v.ToString("0.##");
    }

    static string FormatHM(int totalSec)
    {
        if (totalSec <= 0) return "0m";
        int h = totalSec / 3600;
        int m = (totalSec % 3600) / 60;
        if (h > 0 && m > 0) return $"{h}h {m}m";
        if (h > 0)          return $"{h}h";
        return $"{m}m";
    }

