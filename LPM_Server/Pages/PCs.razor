    void RecalcAuditing(PurchaseItemModel item)
    {
        int.TryParse(item.HoursH, out var h);
        int.TryParse(item.HoursM, out var m);
        int.TryParse(item.Sec,    out var s);
        m = Math.Clamp(m, 0, 59);
        s = Math.Clamp(s, 0, 59);
        double hrs = Math.Abs(h) + m / 60.0 + s / 3600.0;
        item.HoursBought = item.IsNegativeHours ? -hrs : hrs;
        item.AmountPaid = item.HoursBought * item.RatePerHour;
    }

    void OpenReverseCalc(int idx)
    {
        if (idx < 0 || idx >= _purchaseItems.Count) return;
        var it = _purchaseItems[idx];
        if (it.RatePerHour <= 0) return;
        _reverseCalcItemIdx = idx;
        _reverseCalcAmount = "";
    }

    void CloseReverseCalc()
    {
        _reverseCalcItemIdx = -1;
        _reverseCalcAmount = "";
    }

    void OnReverseCalcAmountChange(ChangeEventArgs e)
        => _reverseCalcAmount = e.Value?.ToString() ?? "";

    void OnReverseCalcKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplyReverseCalc();
        else if (e.Key == "Escape") CloseReverseCalc();
    }

    void ApplyReverseCalc()
    {
        if (_reverseCalcItemIdx < 0 || _reverseCalcItemIdx >= _purchaseItems.Count) return;
        var it = _purchaseItems[_reverseCalcItemIdx];
        if (it.RatePerHour <= 0) { CloseReverseCalc(); return; }
        if (!double.TryParse(_reverseCalcAmount, out var amount) || amount <= 0) return;
        int totalSec = (int)Math.Round(amount / it.RatePerHour * 3600.0);
        if (totalSec <= 0) { CloseReverseCalc(); return; }
        int h = totalSec / 3600;
        int m = (totalSec % 3600) / 60;
        int s = totalSec % 60;
        it.HoursH = h.ToString();
        it.HoursM = m.ToString("D2");
        it.Sec    = s.ToString("D2");
        double signedHrs = totalSec / 3600.0;
        it.HoursBought = it.IsNegativeHours ? -signedHrs : signedHrs;
        it.AmountPaid  = it.IsNegativeHours ? -amount    : amount;
        CloseReverseCalc();
    }
