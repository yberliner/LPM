                                <span class="badge rounded-pill ms-auto" style="background:rgba(255,255,255,.25);font-size:.72rem;">@otCourses.Count(e => e.DateFinished == null) @LS.T("pcs.active")</span>
                            </summary>
                            @if (otCourses.Count == 0)
                            {
                                <div class="small text-center py-3" style="color:#6b7280;border:1px solid #e5e7eb;border-top:none;border-radius:0 0 8px 8px;">@LS.T("pcs.noOtCourses")</div>
                            }
                            else
                            {
                            <div class="table-responsive" style="border:1px solid #e5e7eb;border-top:none;border-radius:0 0 8px 8px;">
