                            <summary class="d-flex align-items-center gap-2 px-3 py-2 rounded-top fw-semibold small"
                                     style="background:linear-gradient(135deg,#6d28d9,#a855f7);color:#fff;cursor:pointer;list-style:none;border-radius:8px 8px 0 0;">
                                <i class="ri-book-2-line me-1"></i>@LS.T("pcs.preClearCourses")
                                <span class="badge rounded-pill ms-auto" style="background:rgba(255,255,255,.25);font-size:.72rem;">@pcCourses.Count(e => e.DateFinished == null) @LS.T("pcs.active")</span>
