                <i class="ri-phone-fill me-1"></i>@_smsSuccessPhone
            </div>
            <div class="sms-success-hint">Click anywhere to dismiss</div>
        </div>
    </div>
}

@* ── Pending Courses Modal ── *@
@if (_pendingCoursesModal)
{
    var otCourses = _pendingCourses.Where(e => CourseTypes.IsAdvanced(e.CourseType)).OrderBy(x => x.DateFinished != null).ThenByDescending(x => x.DateStarted).ToList();
    var pcCourses = _pendingCourses.Where(e => !CourseTypes.IsAdvanced(e.CourseType)).OrderBy(x => x.DateFinished != null).ThenByDescending(x => x.DateStarted).ToList();
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.45);z-index:1050;">
