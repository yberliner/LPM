        {
            var col = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortCol");
            var asc = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_sortAsc");
            if (!string.IsNullOrEmpty(col)) _sortCol = col;
            if (!string.IsNullOrEmpty(asc)) _sortAsc = asc == "True";

            var orgFilter = await JS.InvokeAsync<string>("localStorage.getItem", "pcs_orgFilter");
            if (!string.IsNullOrEmpty(orgFilter) && int.TryParse(orgFilter, out var oid))
                _filterOrgId = oid == -1 ? null : oid;

            StateHasChanged();
            try { await JS.InvokeVoidAsync("lpmInitColResize", "pc-list-table"); }
            catch { /* non-critical: column resize unavailable */ }

            if (!_autoOpenHandled && QueryPcId.HasValue)
            {
                _autoOpenHandled = true;
                SelectPc(QueryPcId.Value);
                StateHasChanged();
                if (QueryOpenPurchase.HasValue)
                    await OpenEditPurchase(QueryOpenPurchase.Value);
            }
        }
    }

