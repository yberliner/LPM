    static readonly string[] _srmPalette = { "#22c55e", "#3b82f6", "#f59e0b", "#ef4444", "#a855f7", "#06b6d4", "#ec4899", "#14b8a6" };

    /// Build a stable rate→color map for a flagged PC's session list (rates sorted ascending,
    /// keyed by "currency:rate" so two currencies don't clash).
    static Dictionary<string, string> BuildSessionRateColorMap(List<PcService.SessionRateEntry> entries)
    {
        var map = new Dictionary<string, string>();
        var ordered = entries
            .Select(e => (Key: $"{e.Currency}:{e.RateCentsPerHour}", e.Currency, e.RateCentsPerHour))
            .DistinctBy(t => t.Key)
            .OrderBy(t => t.Currency)
            .ThenBy(t => t.RateCentsPerHour)
            .ToList();
        for (int i = 0; i < ordered.Count; i++)
            map[ordered[i].Key] = _srmPalette[i % _srmPalette.Length];
        return map;
    }

    static string SrmColor(Dictionary<string, string> map, PcService.SessionRateEntry e)
