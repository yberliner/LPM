@page "/Login2FA"
@layout CustomLayout
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IHttpContextAccessor HttpCtx
@inject LPM.Auth.UserDb UserDb

<div class="auth-bg">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-xxl-4 col-xl-4 col-lg-5 col-md-6 col-sm-8 col-12">
                <div class="auth-card">

                    <div class="auth-card-icon-wrap" style="background:linear-gradient(135deg,#7c3aed,#a855f7);">
                        <i class="ri-smartphone-line"></i>
                    </div>

                    <h4 class="auth-card-title">Two-Factor Authentication</h4>
                    @if (!string.IsNullOrEmpty(_displayName))
                    {
                        <p class="auth-card-user"><i class="ri-user-line"></i> @_displayName</p>
                    }
                    <p class="auth-card-sub">
                        Open your authenticator app and enter the 6-digit code.
                    </p>

                    @if (_error)
                    {
                        <div class="auth-alert auth-alert-danger @(_shake ? "auth-shake" : "")">
                            <i class="ri-error-warning-line"></i> Incorrect code — please try again.
                        </div>
                    }

                    <div class="auth-field">
                        <label class="auth-label">6-Digit Code</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon"><i class="ri-key-2-line"></i></span>
                            <input type="text" inputmode="numeric" maxlength="6"
                                   class="auth-input l2fa-code-input"
                                   placeholder="000 000"
                                   @bind="_code" @bind:event="oninput"
                                   @onkeydown="HandleKey" />
                        </div>
                    </div>

                    <button class="auth-submit-btn"
                            @onclick="Submit"
                            disabled="@(_loading || _code.Length < 6)">
                        @if (_loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="ri-shield-check-line me-2"></i>
                        }
                        Verify
                    </button>

                    <div class="l2fa-footer">
                        <a href="/login" class="l2fa-back-link">
                            <i class="ri-arrow-left-s-line"></i> Back to login
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    string _code = "";
    bool _error, _loading, _shake;
    string _displayName = "";

    protected override async Task OnInitializedAsync()
    {
        if (int.TryParse(HttpCtx.HttpContext?.Request.Cookies["lpm_pending"], out var uid))
        {
            var flags = UserDb.GetLoginFlagsById(uid);
            if (flags != null) _displayName = flags.Username;
        }
        var uri = new Uri(Nav.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _error = q["error"] == "1";
        if (_error) await TriggerShake();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("eval",
                "setTimeout(()=>{var el=document.querySelector('.l2fa-code-input');if(el)el.focus();},100)");
    }

    async Task TriggerShake()
    {
        _shake = true;
        StateHasChanged();
        await Task.Delay(400);
        _shake = false;
        StateHasChanged();
    }

    async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _code.Length == 6) await Submit();
    }

    async Task Submit()
    {
        _loading = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("lpmPostForm", "/loginpost-verify2fa",
            new Dictionary<string, string> { ["code"] = _code });
    }
}

<style>
    .auth-bg {
        min-height: 100vh;
        background: radial-gradient(ellipse at 60% 40%, #1e293b 0%, #0f172a 100%);
    }
    .auth-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 40px 36px 36px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        backdrop-filter: blur(12px);
        text-align: center;
    }
    .auth-card-icon-wrap {
        width: 64px; height: 64px; border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px; font-size: 1.8rem; color: #fff;
        box-shadow: 0 8px 24px rgba(168,85,247,0.4);
    }
    .auth-card-title { color: #f1f5f9; font-size: 1.4rem; font-weight: 700; margin-bottom: 6px; }
    .auth-card-user { color: #818cf8; font-size: 1rem; font-weight: 600; margin-bottom: 4px;
        display: flex; align-items: center; justify-content: center; gap: 6px; }
    .auth-card-sub { color: #94a3b8; font-size: .9rem; margin-bottom: 28px; line-height: 1.5; }
    .auth-alert { border-radius: 10px; padding: 10px 14px; font-size: .85rem;
                  display: flex; align-items: center; gap: 8px; margin-bottom: 18px; text-align: left; }
    .auth-alert-danger { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
    @@keyframes authShake {
        0%,100% { transform: translateX(0); }
        20%,60% { transform: translateX(-6px); }
        40%,80% { transform: translateX(6px); }
    }
    .auth-shake { animation: authShake 0.4s ease; }
    .auth-field { text-align: left; margin-bottom: 16px; }
    .auth-label { display: block; font-size: .8rem; font-weight: 600; color: #94a3b8;
                  letter-spacing: .05em; text-transform: uppercase; margin-bottom: 6px; }
    .auth-input-wrap { position: relative; display: flex; align-items: center; }
    .auth-input-icon { position: absolute; left: 14px; color: #475569; font-size: 1rem; pointer-events: none; }
    .auth-input {
        width: 100%; padding: 11px 14px 11px 40px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px; color: #f1f5f9; font-size: .95rem; outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .auth-input:focus { border-color: #a855f7; box-shadow: 0 0 0 3px rgba(168,85,247,0.2); }
    .auth-input::placeholder { color: #475569; }
    .l2fa-code-input { text-align: center; font-size: 1.6rem; letter-spacing: .35em; font-weight: 700; }
    .auth-submit-btn {
        width: 100%; margin-top: 8px; padding: 13px;
        background: linear-gradient(135deg, #7c3aed, #a855f7);
        border: none; border-radius: 12px; color: #fff;
        font-size: 1rem; font-weight: 600; cursor: pointer;
        transition: opacity .2s, transform .1s;
        box-shadow: 0 4px 16px rgba(168,85,247,0.4);
    }
    .auth-submit-btn:hover:not(:disabled) { opacity: .9; transform: translateY(-1px); }
    .auth-submit-btn:disabled { opacity: .5; cursor: not-allowed; }
    .l2fa-footer { margin-top: 20px; }
    .l2fa-back-link { color: #64748b; font-size: .85rem; text-decoration: none; }
    .l2fa-back-link:hover { color: #94a3b8; }
</style>
