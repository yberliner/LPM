@page "/Settings"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using LPM._Spk
@using System.Text.RegularExpressions
@inject AuthenticationStateProvider AuthStateProvider
@inject LPM.Auth.UserDb UserDb
@inject LPM.Services.PcService PcSvc
@inject IWebHostEnvironment Env
@inject NavigationManager Nav
@inject IJSRuntime JS

@* ── Profile hero banner ── *@
<div class="settings-hero">
    <div class="settings-hero-avatar">
        @if (_avatarUrl is not null)
        {
            <img src="@_avatarUrl" class="settings-hero-img" alt="avatar" />
        }
        else
        {
            <span class="settings-hero-initial">
                @(_username.Length > 0 ? _username[0].ToString().ToUpper() : "?")
            </span>
        }
    </div>
    <div>
        <div class="settings-hero-name">@_username</div>
        <div class="settings-hero-sub">@LS.T("settings.accountSettings")</div>
    </div>
</div>

<div class="container-xl py-4">
    <div class="row g-4">

        <!-- Card 1: Change Password -->
        <div class="col-md-6">
            <div class="card custom-card h-100 shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-header settings-card-header" style="background:linear-gradient(135deg,#1e40af,#6366f1);">
                    <div class="settings-card-header-icon">
                        <i class="ri-lock-password-fill"></i>
                    </div>
                    <div>
                        <div class="settings-card-header-title">@LS.T("settings.changePassword")</div>
                        <div class="settings-card-header-sub">@LS.T("settings.updateCredentials")</div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (_pwMsg is not null)
                    {
                        <div class="alert @(_pwOk ? "alert-success" : "alert-danger") alert-dismissible d-flex align-items-center gap-2" role="alert"
                             style="border-radius:10px;border:none;font-size:.88rem;">
                            <i class="@(_pwOk ? "ri-checkbox-circle-fill" : "ri-error-warning-fill")"></i>
                            <span class="flex-grow-1">@_pwMsg</span>
                            <button type="button" class="btn-close" @onclick="() => _pwMsg = null"></button>
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label settings-label">@LS.T("settings.currentPassword")</label>
                        <SpkPasswordToggle @bind-Password="_currentPwd" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label settings-label">@LS.T("settings.newPassword")</label>
                        <SpkPasswordToggle @bind-Password="_newPwd" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label settings-label">@LS.T("settings.confirmNewPassword")</label>
                        <SpkPasswordToggle @bind-Password="_confirmPwd" />
                    </div>
                    <button class="btn settings-save-btn" @onclick="HandleChangePassword">
                        <i class="ri-save-line me-2"></i>@LS.T("settings.updatePassword")
                    </button>
                </div>
            </div>
        </div>

        <!-- Card 2: Profile Picture -->
        <div class="col-md-6">
            <div class="card custom-card h-100 shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-header settings-card-header" style="background:linear-gradient(135deg,#0d9488,#22c55e);">
                    <div class="settings-card-header-icon">
                        <i class="ri-camera-fill"></i>
                    </div>
                    <div>
                        <div class="settings-card-header-title">@LS.T("settings.profilePicture")</div>
                        <div class="settings-card-header-sub">@LS.T("settings.uploadPhoto")</div>
                    </div>
                </div>
                <div class="card-body p-4 d-flex flex-column align-items-center gap-3">
                    <div class="settings-avatar-preview">
                        @if (_avatarUrl is not null)
                        {
                            <img src="@_avatarUrl" style="width:100%;height:100%;object-fit:cover;" alt="avatar" />
                        }
                        else
                        {
                            <span style="font-size:3rem;font-weight:700;color:#7986cb;">
                                @(_username.Length > 0 ? _username[0].ToString().ToUpper() : "?")
                            </span>
                        }
                    </div>

                    @if (_picMsg is not null)
                    {
                        <div class="alert @(_picOk ? "alert-success" : "alert-danger") w-100 text-center mb-0"
                             style="border-radius:10px;border:none;font-size:.88rem;" role="alert">
                            @_picMsg
                        </div>
                    }

                    <div class="settings-upload-zone">
                        <i class="ri-upload-cloud-2-line settings-upload-icon"></i>
                        <div class="settings-upload-label">@LS.T("settings.clickToUpload")</div>
                        <div class="settings-upload-sub">JPEG · PNG · GIF · WebP · max 2 MB</div>
                        <InputFile OnChange="HandleFileUpload" accept="image/*"
                                   class="settings-upload-input" />
                    </div>

                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-3 d-flex align-items-center gap-2"
                            @onclick="OpenCamera">
                        <i class="ri-camera-line"></i> Take Photo
                    </button>

                    @if (_avatarUrl is not null)
                    {
                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="HandleDeleteAvatar">
                            <i class="ri-delete-bin-line me-1"></i>@LS.T("settings.removePhoto")
                        </button>
                    }
                </div>
            </div>
        </div>

        @* ── Contact Info Card ── *@
        <div class="col-12">
            <div class="card custom-card shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-header settings-card-header" style="background:linear-gradient(135deg,#ea580c,#f59e0b);">
                    <div class="settings-card-header-icon">
                        <i class="ri-contacts-fill"></i>
                    </div>
                    <div>
                        <div class="settings-card-header-title">Contact Information</div>
                        <div class="settings-card-header-sub">Email address and phone number</div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (_contactMsg is not null)
                    {
                        <div class="alert @(_contactOk ? "alert-success" : "alert-danger") alert-dismissible d-flex align-items-center gap-2 mb-3"
                             style="border-radius:10px;border:none;font-size:.88rem;">
                            <i class="@(_contactOk ? "ri-checkbox-circle-fill" : "ri-error-warning-fill")"></i>
                            <span class="flex-grow-1">@_contactMsg</span>
                            <button type="button" class="btn-close" @onclick="() => _contactMsg = null"></button>
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label settings-label">Email address</label>
                            <input class="form-control" type="email" value="@_contactEmail" disabled
                                   style="opacity:.7;cursor:not-allowed;" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label settings-label">Phone number</label>
                            <input class="form-control" type="tel" value="@_contactLocalPhone" disabled
                                   style="opacity:.7;cursor:not-allowed;" />
                        </div>
                    </div>
                    <div class="text-muted mt-2" style="font-size:.82rem;">
                        <i class="ri-information-line me-1"></i>Contact your administrator to update email or phone number
                    </div>
                </div>
            </div>
        </div>

        @* ── Device Security Card ── *@
        <div class="col-12">
            <div class="card custom-card shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-header settings-card-header" style="background:linear-gradient(135deg,#7c3aed,#a855f7);">
                    <div class="settings-card-header-icon">
                        <i class="ri-shield-keyhole-fill"></i>
                    </div>
                    <div>
                        <div class="settings-card-header-title">Device Security</div>
                        <div class="settings-card-header-sub">Manage trusted devices for your account</div>
                    </div>
                    <div class="ms-auto d-flex align-items-center gap-2">
                        <span class="badge" style="background:rgba(34,197,94,.2);color:#4ade80;border:1px solid rgba(34,197,94,.3);border-radius:999px;padding:4px 12px;font-size:.75rem;">
                            <i class="ri-shield-check-line me-1"></i>Email Verified
                        </span>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-wrap gap-3 align-items-center">
                        <div>
                            <div class="fw-semibold" style="font-size:.9rem;">New devices are verified via email link.</div>
                            <div class="text-muted" style="font-size:.82rem;">
                                Trusted devices: <strong>@_trustedDeviceCount</strong>
                            </div>
                        </div>
                        <div class="ms-auto">
                            <button class="btn btn-sm btn-outline-warning" @onclick="RevokeDevices">
                                <i class="ri-device-line me-1"></i>Revoke All Trusted Devices
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* ── Passkeys Card ── *@
        <div class="col-12">
            <div class="card custom-card shadow-sm" style="border-radius:16px;border:none;">
                <div class="card-header settings-card-header" style="background:linear-gradient(135deg,#4f46e5,#6366f1);">
                    <div class="settings-card-header-icon">
                        <i class="ri-fingerprint-fill"></i>
                    </div>
                    <div>
                        <div class="settings-card-header-title">Passkeys</div>
                        <div class="settings-card-header-sub">Sign in with fingerprint, Face ID, or PIN</div>
                    </div>
                </div>
                <div class="card-body p-4">
                    @if (_passkeys.Count > 0)
                    {
                        <div class="mb-3">
                            @foreach (var pk in _passkeys)
                            {
                                <div class="d-flex align-items-center gap-3 py-2 px-3 mb-2" style="background:#f8fafc;border-radius:10px;">
                                    <i class="ri-fingerprint-line" style="font-size:1.3rem;color:#6366f1;"></i>
                                    <div class="flex-grow-1">
                                        <div class="fw-semibold" style="font-size:.88rem;">@pk.DeviceName</div>
                                        <div class="text-muted" style="font-size:.75rem;">Registered @pk.CreatedAt</div>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePasskey(pk.Id)">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-3" style="font-size:.88rem;">
                            No passkeys registered on this device. Register one to sign in with fingerprint or PIN.
                        </p>
                    }
                    <button class="btn btn-sm"
                            style="background:linear-gradient(135deg,#4f46e5,#6366f1);color:#fff;font-weight:600;border-radius:8px;padding:8px 20px;"
                            @onclick="RegisterPasskey"
                            disabled="@_registeringPasskey">
                        @if (_registeringPasskey)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        else
                        {
                            <i class="ri-add-line me-1"></i>
                        }
                        Register Passkey on This Device
                    </button>
                    @if (_passkeyMsg != null)
                    {
                        <div class="alert @(_passkeyOk ? "alert-success" : "alert-danger") mt-2 mb-0 py-2" style="font-size:.85rem;border-radius:8px;">
                            @_passkeyMsg
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>

@* ── Camera Modal ── *@
@if (_showCamera)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.65);z-index:9999;">
        <div class="modal-dialog modal-dialog-centered" style="max-width:480px;">
            <div class="modal-content" style="border-radius:16px;overflow:hidden;border:none;">
                <div class="modal-header" style="background:linear-gradient(135deg,#0d9488,#22c55e);color:#fff;border:none;">
                    <h6 class="modal-title fw-bold mb-0 d-flex align-items-center gap-2">
                        <i class="ri-camera-fill"></i> Take Photo
                    </h6>
                    <button class="btn-close btn-close-white" @onclick="CloseCamera"></button>
                </div>
                <div class="modal-body p-3 d-flex flex-column align-items-center gap-3" style="background:#0f172a;">
                    @if (_cameraError is not null)
                    {
                        <div class="alert alert-danger w-100 text-center mb-0" style="border-radius:10px;border:none;font-size:.88rem;">
                            <i class="ri-error-warning-fill me-1"></i>@_cameraError
                        </div>
                    }
                    <div style="position:relative;width:100%;border-radius:10px;overflow:hidden;background:#000;min-height:260px;display:flex;align-items:center;justify-content:center;">
                        <video id="cam-video" autoplay playsinline muted
                               style="width:100%;display:@(_snapped ? "none" : "block");border-radius:10px;"></video>
                        <canvas id="cam-canvas"
                                style="width:100%;display:@(_snapped ? "block" : "none");border-radius:10px;"></canvas>
                    </div>
                    <div class="d-flex gap-2 w-100 justify-content-center">
                        @if (!_snapped)
                        {
                            <button class="btn btn-success rounded-pill px-4 d-flex align-items-center gap-2"
                                    @onclick="SnapPhoto">
                                <i class="ri-camera-fill"></i> Snap
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-light btn-sm rounded-pill px-3 d-flex align-items-center gap-2"
                                    @onclick="Retake">
                                <i class="ri-refresh-line"></i> Retake
                            </button>
                            <button class="btn btn-success rounded-pill px-4 d-flex align-items-center gap-2"
                                    @onclick="UsePhoto" disabled="@_camerabusy">
                                @if (_camerabusy)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <i class="ri-checkbox-circle-fill"></i>
                                }
                                Use Photo
                            </button>
                        }
                        <button class="btn btn-outline-secondary btn-sm rounded-pill px-3" @onclick="CloseCamera">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<style>
    /* ── Hero banner ── */
    .settings-hero {
        display: flex; align-items: center; gap: 20px;
        padding: 24px 32px 20px;
        background: linear-gradient(135deg, #0f2057 0%, #1e40af 60%, #6366f1 100%);
        color: #fff;
    }
    .settings-hero-avatar {
        width: 72px; height: 72px; border-radius: 50%; flex-shrink: 0;
        background: rgba(255,255,255,.18);
        border: 3px solid rgba(255,255,255,.4);
        display: flex; align-items: center; justify-content: center;
        overflow: hidden;
        box-shadow: 0 4px 18px rgba(0,0,0,.22);
    }
    .settings-hero-img { width: 100%; height: 100%; object-fit: cover; }
    .settings-hero-initial { font-size: 2rem; font-weight: 700; color: #fff; }
    .settings-hero-name { font-size: 1.35rem; font-weight: 700; letter-spacing: -.2px; }
    .settings-hero-sub  { font-size: .82rem; opacity: .7; margin-top: 2px; }

    /* ── Card headers ── */
    .settings-card-header {
        display: flex; align-items: center; gap: 14px;
        padding: 14px 20px;
        border-radius: 16px 16px 0 0 !important;
        border: none !important;
        color: #fff;
    }
    .settings-card-header-icon {
        width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0;
        background: rgba(255,255,255,.2);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.15rem;
    }
    .settings-card-header-title { font-weight: 700; font-size: .97rem; }
    .settings-card-header-sub   { font-size: .78rem; opacity: .78; margin-top: 1px; }

    /* ── Labels & save button ── */
    .settings-label { font-size: .84rem; font-weight: 600; color: #374151; }
    .settings-save-btn {
        background: linear-gradient(135deg, #1e40af, #6366f1);
        color: #fff; border: none; border-radius: 10px;
        padding: .5rem 1.4rem; font-size: .9rem; font-weight: 600;
        box-shadow: 0 3px 14px rgba(99,102,241,.35);
        transition: box-shadow .2s, transform .18s;
    }
    .settings-save-btn:hover { box-shadow: 0 5px 20px rgba(99,102,241,.48); transform: translateY(-1px); color: #fff; }

    /* ── Avatar preview circle ── */
    .settings-avatar-preview {
        width: 120px; height: 120px; border-radius: 50%;
        background: rgba(99,102,241,.1);
        border: 3px solid #e0e7ff;
        display: flex; align-items: center; justify-content: center;
        overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.10);
    }

    /* ── Upload zone ── */
    .settings-upload-zone {
        position: relative; width: 100%;
        border: 2px dashed #c7d2fe; border-radius: 12px;
        padding: 24px 16px; text-align: center; cursor: pointer;
        background: #f8f9ff;
        transition: border-color .18s, background .18s;
    }
    .settings-upload-zone:hover { border-color: #6366f1; background: #eef2ff; }
    .settings-upload-icon  { font-size: 2rem; color: #818cf8; display: block; margin-bottom: 6px; }
    .settings-upload-label { font-size: .88rem; font-weight: 600; color: #374151; }
    .settings-upload-sub   { font-size: .75rem; color: #94a3b8; margin-top: 4px; }
    .settings-upload-input {
        position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
    }

    @@media (max-width: 768px) {
        .settings-hero { padding: 18px 20px 16px; gap: 14px; }
        .settings-hero-avatar { width: 56px; height: 56px; }
        .settings-hero-name { font-size: 1.1rem; }
    }
    @@media (max-width: 480px) {
        .settings-hero { padding: 14px 14px 12px; gap: 10px; flex-wrap: wrap; }
        .settings-hero-avatar { width: 48px; height: 48px; }
        .settings-hero-name { font-size: 1rem; }
        .settings-hero-sub { font-size: .75rem; }
        .settings-hero-initial { font-size: 1.5rem; }
        .settings-save-btn { width: 100%; min-height: 44px; touch-action: manipulation; }
        .settings-upload-zone { padding: 16px 12px; }
        input.form-control, select.form-select { font-size: 1rem !important; min-height: 44px; touch-action: manipulation; }
    }
</style>

@code {
    // Country list and phone helpers from shared component
    private static SpkCountryPicker.CountryInfo[] _contactCountries => SpkCountryPicker.Countries;

    private string _username = "";
    private string? _avatarUrl;
    private int _personId;

    // Password fields
    private string? _currentPwd;
    private string? _newPwd;
    private string? _confirmPwd;
    private string? _pwMsg;
    private bool _pwOk;

    // Picture fields
    private string? _picMsg;
    private bool _picOk;

    // Contact fields (read-only display)
    private string  _contactEmail      = "";
    private string  _contactLocalPhone = "";
    #pragma warning disable CS0414
    private bool    _contactEmailTouched;
    private bool    _contactEmailValid;
    private bool    _contactPhoneTouched;
    private int     _contactCountryIdx = 0;
    private string? _contactMsg;
    private bool    _contactOk;
    #pragma warning restore CS0414

    // Device security fields
    private int _trustedDeviceCount;
    private int _userId;

    // Passkey fields
    private List<LPM.Auth.UserDb.PasskeyInfo> _passkeys = new();
    private bool _registeringPasskey;
    private string? _passkeyMsg;
    private bool _passkeyOk;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = auth.User.Identity?.Name?.ToLower() ?? "";
        _avatarUrl = UserDb.GetAvatarPath(_username);

        var flags = UserDb.GetLoginFlags(_username);
        if (flags != null)
        {
            _userId   = flags.UserId;
            _personId = flags.PersonId;
            _trustedDeviceCount = UserDb.GetTrustedDeviceCount(_userId);
            _passkeys = UserDb.GetPasskeysByUser(_userId);
        }

        // Show success message when returning from voluntary 2FA setup
        var uri = new Uri(Nav.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (q["2fa"] == "ok")
        {
            // 2FA setup message (legacy — no longer used)
        }

        // Pre-populate contact info
        if (_personId > 0)
        {
            var (email, phone) = PcSvc.GetPersonContact(_personId);
            if (!string.IsNullOrEmpty(email))
            {
                _contactEmail        = email;
                _contactEmailTouched = true;
                _contactEmailValid   = IsContactEmailValid(email);
            }
            if (!string.IsNullOrEmpty(phone))
            {
                ParseContactPhone(phone);
                _contactPhoneTouched = true;
            }
        }
    }

    // ── Contact helpers ──
    private static bool IsContactEmailValid(string email) =>
        !string.IsNullOrWhiteSpace(email) &&
        Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]{2,}$");

    private bool IsContactPhoneValid() => SpkCountryPicker.IsValid(_contactCountryIdx, _contactLocalPhone);
    private string ContactPhoneErrorMessage() => SpkCountryPicker.ErrorMessage(_contactCountryIdx, _contactLocalPhone);
    private string ContactPhoneNormalized => SpkCountryPicker.Normalize(_contactCountryIdx, _contactLocalPhone);

    private void ParseContactPhone(string stored)
    {
        var (idx, local) = SpkCountryPicker.ParsePhone(stored);
        _contactCountryIdx = idx;
        _contactLocalPhone = local;
    }

    private void OnContactEmailInput(ChangeEventArgs e)
    {
        _contactEmail        = e.Value?.ToString() ?? "";
        _contactEmailTouched = true;
        _contactEmailValid   = IsContactEmailValid(_contactEmail);
    }

    private void OnContactPhoneInput(ChangeEventArgs e)
    {
        _contactLocalPhone   = e.Value?.ToString() ?? "";
        _contactPhoneTouched = true;
    }

    private void HandleSaveContact()
    {
        _contactMsg = null;
        if (!_contactEmailValid || !IsContactPhoneValid()) return;
        try
        {
            PcSvc.SaveContactInfo(_personId, _contactEmail, ContactPhoneNormalized);
            _contactMsg = "Contact information saved successfully.";
            _contactOk  = true;
        }
        catch (Exception ex)
        {
            _contactMsg = "Failed to save. Please try again.";
            _contactOk  = false;
            Console.WriteLine($"[UserSettings] Contact save error: {ex.Message}");
        }
    }

    private void RevokeDevices()
    {
        UserDb.RevokeAllTrustedDevices(_userId);
        _trustedDeviceCount = 0;
        // Devices revoked — user will need to verify via email on next login from any device
    }

    private async Task RegisterPasskey()
    {
        _passkeyMsg = null;
        _registeringPasskey = true;
        StateHasChanged();

        try
        {
            var supported = await JS.InvokeAsync<bool>("lpmPasskey.isSupported");
            if (!supported)
            {
                _passkeyMsg = "Passkeys are not supported on this browser.";
                _passkeyOk = false;
                return;
            }

            var result = await JS.InvokeAsync<string>("lpmPasskeyFlow.register");
            if (result == "success")
            {
                _passkeyMsg = "Passkey registered successfully!";
                _passkeyOk = true;
                _passkeys = UserDb.GetPasskeysByUser(_userId);
            }
            else if (result == "cancelled")
            {
                _passkeyMsg = null; // user cancelled — no message
            }
            else
            {
                _passkeyMsg = "Failed to register passkey. Please try again.";
                _passkeyOk = false;
            }
        }
        catch (Exception ex)
        {
            _passkeyMsg = $"Error: {ex.Message}";
            _passkeyOk = false;
        }
        finally
        {
            _registeringPasskey = false;
            StateHasChanged();
        }
    }

    private void RemovePasskey(int passkeyId)
    {
        UserDb.RemovePasskey(passkeyId, _userId);
        _passkeys = UserDb.GetPasskeysByUser(_userId);
        _passkeyMsg = "Passkey removed.";
        _passkeyOk = true;
    }

    private void HandleChangePassword()
    {
        _pwMsg = null;
        if (string.IsNullOrWhiteSpace(_currentPwd) || string.IsNullOrWhiteSpace(_newPwd) || string.IsNullOrWhiteSpace(_confirmPwd))
        {
            _pwMsg = LS.T("settings.allFieldsRequired"); _pwOk = false; return;
        }
        if (_newPwd != _confirmPwd)
        {
            _pwMsg = LS.T("settings.passwordsNoMatch"); _pwOk = false; return;
        }
        if (_newPwd.Length < 8)
        {
            _pwMsg = LS.T("settings.passwordTooShort"); _pwOk = false; return;
        }
        Console.WriteLine($"[UserSettings] Changed password by '{_username}'");
        var error = UserDb.ChangePassword(_username, _currentPwd, _newPwd);
        if (error is not null)
        {
            _pwMsg = error; _pwOk = false;
        }
        else
        {
            _pwMsg = LS.T("settings.passwordUpdated"); _pwOk = true;
            _currentPwd = _newPwd = _confirmPwd = null;
        }
    }

    private static readonly HashSet<string> AllowedMime = new() { "image/jpeg", "image/png", "image/gif", "image/webp" };

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _picMsg = null;
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024)
        {
            _picMsg = LS.T("settings.fileTooLarge"); _picOk = false; return;
        }
        if (!AllowedMime.Contains(file.ContentType))
        {
            _picMsg = LS.T("settings.invalidImageType"); _picOk = false; return;
        }

        var ext = Path.GetExtension(file.Name).ToLowerInvariant();
        if (string.IsNullOrEmpty(ext)) ext = ".jpg";

        var avatarsDir = Path.Combine(Env.WebRootPath, "avatars");
        Directory.CreateDirectory(avatarsDir);

        // Remove any existing avatar for this user
        foreach (var old in Directory.GetFiles(avatarsDir, $"{_username}.*"))
            File.Delete(old);

        var filePath = Path.Combine(avatarsDir, $"{_username}{ext}");
        await using var stream = new FileStream(filePath, FileMode.Create);
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(stream);

        Console.WriteLine($"[UserSettings] Uploaded avatar by '{_username}'");
        UserDb.SetAvatarPath(_username, $"/avatars/{_username}{ext}");
        Nav.NavigateTo("/Settings", forceLoad: true);
    }

    private void HandleDeleteAvatar()
    {
        if (_avatarUrl is null) return;
        Console.WriteLine($"[UserSettings] Deleted avatar by '{_username}'");
        var avatarsDir = Path.Combine(Env.WebRootPath, "avatars");
        foreach (var old in Directory.GetFiles(avatarsDir, $"{_username}.*"))
            File.Delete(old);
        UserDb.SetAvatarPath(_username, null);
        Nav.NavigateTo("/Settings", forceLoad: true);
    }

    // ── Camera ──
    private bool   _showCamera;
    private bool   _snapped;
    private bool   _camerabusy;
    private string? _cameraError;

    private async Task OpenCamera()
    {
        _snapped = false;
        _cameraError = null;
        _showCamera = true;
        StateHasChanged();
        await Task.Yield(); // let Blazor render video/canvas elements first
        var ok = await JS.InvokeAsync<bool>("lpmCamera.start");
        if (!ok)
        {
            _cameraError = "Camera access denied or not available.";
            StateHasChanged();
        }
    }

    private async Task SnapPhoto()
    {
        _snapped = true;
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("lpmCamera.snap");
    }

    private async Task Retake()
    {
        _snapped = false;
        StateHasChanged();
        await Task.Yield();
        await JS.InvokeVoidAsync("lpmCamera.retake");
    }

    private async Task UsePhoto()
    {
        _camerabusy = true;
        StateHasChanged();
        try
        {
            var dataUrl = await JS.InvokeAsync<string>("lpmCamera.getDataUrl");
            // dataUrl = "data:image/jpeg;base64,..."
            var comma = dataUrl.IndexOf(',');
            if (comma < 0) { _cameraError = "Failed to capture image."; return; }
            var bytes = Convert.FromBase64String(dataUrl[(comma + 1)..]);

            var avatarsDir = Path.Combine(Env.WebRootPath, "avatars");
            Directory.CreateDirectory(avatarsDir);
            foreach (var old in Directory.GetFiles(avatarsDir, $"{_username}.*"))
                File.Delete(old);
            var filePath = Path.Combine(avatarsDir, $"{_username}.jpg");
            await File.WriteAllBytesAsync(filePath, bytes);

            Console.WriteLine($"[UserSettings] Camera photo saved by '{_username}'");
            UserDb.SetAvatarPath(_username, $"/avatars/{_username}.jpg");
            await CloseCamera();
            Nav.NavigateTo("/Settings", forceLoad: true);
        }
        catch (Exception ex)
        {
            _cameraError = ex.Message;
        }
        finally
        {
            _camerabusy = false;
        }
    }

    private async Task CloseCamera()
    {
        await JS.InvokeVoidAsync("lpmCamera.stop");
        _showCamera = false;
        _snapped = false;
        _cameraError = null;
        StateHasChanged();
    }
}
