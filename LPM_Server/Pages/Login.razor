@page "/"
@page "/index"
@page "/login"
@layout CustomLayout
@using LPM._Spk
@inject IJSRuntime JS
@inject NavigationManager Nav

<div class="authentication-background">
    <div class="container">
        <div class="row justify-content-center align-items-center authentication h-100">
            <div class="col-xxl-5 col-xl-5 col-lg-5 col-md-6 col-sm-8 col-12">
                <div class="card custom-card my-4">
                    <div class="card-body p-5">

                        <div class="mb-3 d-flex justify-content-center">
                            <a href="/index">
                                <img src="/assets/images/brand-logos/desktop-logo.svg" alt="logo" class="desktop-logo authentication-logo" style="height:48px;">
                                @* <img src="/assets/images/brand-logos/desktop-dark.png"  alt="logo" class="desktop-dark  authentication-logo" style="height:48px;"> *@
                            </a>
                        </div>

                        <p class="h5 mb-2 text-center">@LS.T("login.signIn")</p>
                        <p class="mb-4 text-muted op-7 fw-normal text-center">@LS.T("login.welcomeBack")</p>

                        <div class="row gy-3">
                            <div class="col-xl-12">
                                <label for="signin-username" class="form-label text-default">
                                    @LS.T("login.userName")<sup class="fs-12 text-danger">*</sup>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="ri-user-line"></i>
                                    </span>
                                    <input type="text"
                                           class="form-control"
                                           id="signin-username"
                                           placeholder="@LS.T("login.enterUserName")"
                                           @bind="_username"
                                           @bind:event="oninput"
                                           @onkeydown="HandleKeyDown" />
                                </div>
                            </div>

                            <div class="col-xl-12 mb-2">
                                <label for="signin-password" class="form-label text-default d-block">
                                    @LS.T("login.password")<sup class="fs-12 text-danger">*</sup>
                                </label>
                                <div @onkeydown="HandleKeyDown">
                                    <SpkPasswordToggle @bind-Password="_password" />
                                </div>
                            </div>
                        </div>

                        @if (_locked)
                        {
                            <div class="alert alert-danger text-center mt-3 @(_shake ? "shake" : "")" role="alert">
                                <i class="ri-lock-line me-1"></i> Too many failed attempts. Try again in 10 minutes.
                            </div>
                        }
                        else if (_emailFail)
                        {
                            <div class="alert alert-danger text-center mt-3" role="alert">
                                <i class="ri-mail-close-line me-1"></i> Email system error — could not send verification email. Contact your administrator.
                            </div>
                        }
                        else if (_noEmail)
                        {
                            <div class="alert alert-warning text-center mt-3" role="alert">
                                <i class="ri-mail-close-line me-1"></i> No email configured. Contact your administrator.
                            </div>
                        }
                        else if (_expired)
                        {
                            <div class="alert alert-warning text-center mt-3" role="alert">
                                <i class="ri-time-line me-1"></i> Verification link expired or already used. Please log in again.
                            </div>
                        }
                        else if (_error)
                        {
                            <div class="alert alert-danger text-center mt-3 @(_shake ? "shake" : "")" role="alert">
                                <i class="ri-error-warning-line me-1"></i> @LS.T("login.invalidCredentials")
                            </div>
                        }

                        <div class="d-grid mt-4">
                            <button class="btn btn-primary btn-wave"
                                    @onclick="HandleLogin"
                                    disabled="@_loading">
                                @if (_loading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                }
                                @LS.T("login.signIn")
                            </button>
                        </div>

                        @if (_passkeyNoUser)
                        {
                            <div class="alert alert-warning text-center mt-2" style="font-size:.85rem;" role="alert">
                                <i class="ri-user-line me-1"></i> Enter your username first.
                            </div>
                        }
                        else if (_passkeyError)
                        {
                            <div class="alert alert-danger text-center mt-2" style="font-size:.85rem;" role="alert">
                                <i class="ri-fingerprint-line me-1"></i> Passkey login failed. Use password instead.
                            </div>
                        }

                        <div class="d-flex align-items-center gap-3 mt-3">
                            <hr class="flex-grow-1" style="border-color:#e2e8f0;" />
                            <span style="color:#94a3b8;font-size:.78rem;white-space:nowrap;">or</span>
                            <hr class="flex-grow-1" style="border-color:#e2e8f0;" />
                        </div>

                        <div class="d-grid mt-3">
                            <button class="btn btn-outline-secondary d-flex align-items-center justify-content-center gap-2"
                                    style="border-radius:10px;padding:10px;font-weight:600;"
                                    @onclick="HandlePasskeyLogin"
                                    disabled="@_passkeyLoading">
                                @if (_passkeyLoading)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                }
                                else
                                {
                                    <i class="ri-fingerprint-line" style="font-size:1.2rem;"></i>
                                }
                                Sign in with Passkey
                            </button>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes shake {
        0%   { transform: translateX(0); }
        25%  { transform: translateX(-5px); }
        50%  { transform: translateX(5px); }
        75%  { transform: translateX(-5px); }
        100% { transform: translateX(0); }
    }
    .shake {
        animation: shake 0.3s;
    }
</style>

@code {
    private string _username = "";
    private string _password = "";
    private bool _error;
    private bool _locked;
    private bool _noEmail;
    private bool _expired;
    private bool _emailFail;
    private bool _shake;
    private bool _loading;
    private bool _passkeyLoading;
    private bool _passkeyError;
    private bool _passkeyNoUser;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _error = query["error"] == "1";
        _locked = query["error"] == "2";
        _noEmail = query["error"] == "noemail";
        _expired = query["error"] == "expired" || query["error"] == "badlink";
        _emailFail = query["error"] == "emailfail";
        _username = query["username"] ?? "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && (_error || _locked))
            await ShowErrorAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await HandleLogin();
    }

    private async Task HandleLogin()
    {
        if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_password))
            return;

        _loading = true;
        Console.WriteLine($"[Login] Login attempt for '{_username}'");
        await InvokeAsync(StateHasChanged);
        await JS.InvokeVoidAsync("submitLoginForm", _username, _password);
    }

    private async Task HandlePasskeyLogin()
    {
        _passkeyError = false;
        _passkeyNoUser = false;
        if (string.IsNullOrWhiteSpace(_username))
        {
            _passkeyNoUser = true;
            StateHasChanged();
            return;
        }

        _passkeyLoading = true;
        StateHasChanged();

        try
        {
            var supported = await JS.InvokeAsync<bool>("lpmPasskey.isSupported");
            if (!supported) { _passkeyError = true; return; }

            var result = await JS.InvokeAsync<string>("lpmPasskeyFlow.login", _username);
            if (result == "success")
                Nav.NavigateTo("/Home", forceLoad: true);
            else if (result == "no_passkeys")
                _passkeyError = true; // no passkeys registered — use password
            else if (result != "cancelled")
                _passkeyError = true;
        }
        catch
        {
            _passkeyError = true;
        }
        finally
        {
            _passkeyLoading = false;
            StateHasChanged();
        }
    }

    private async Task ShowErrorAsync()
    {
        _error = true;
        _shake = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(350);
        _shake = false;
        await InvokeAsync(StateHasChanged);
    }
}
