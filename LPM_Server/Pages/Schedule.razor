@page "/Schedule"
@attribute [Authorize(Roles = "Admin,Customer")]
@using LPM.Services
@inject MeetingService MeetingSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="sched-page">

    <!-- Type toggle + Schedule button -->
    <div class="sched-topbar">
        <div class="btn-group btn-group-sm">
            <button class="btn @(_type == "Auditing" ? "btn-primary" : "btn-outline-primary")"
                    @onclick='() => SetType("Auditing")'>
                <i class="ri-headphone-line me-1"></i>Auditing
            </button>
            <button class="btn @(_type == "Academy" ? "btn-success" : "btn-outline-success")"
                    @onclick='() => SetType("Academy")'>
                <i class="ri-graduation-cap-line me-1"></i>Academy
            </button>
        </div>

        <!-- Auditor color legend -->
        @if (_legendItems.Any())
        {
            <div class="sched-legend">
                @foreach (var (name, color) in _legendItems)
                {
                    <span class="sched-legend-item">
                        <span style="width:10px;height:10px;border-radius:50%;background:@color;flex-shrink:0;display:inline-block;"></span>
                        @name
                    </span>
                }
            </div>
        }

    </div>

    <!-- FullCalendar container -->
    <div class="sched-cal-card">
        <div id="sched-cal"
             @oncontextmenu="OnCalContextMenu"
             @oncontextmenu:preventDefault="true"></div>
    </div>

</div>

<!-- Right-click context menu -->
@if (_ctxMeetingId.HasValue)
{
    <div style="position:fixed;z-index:9999;left:@(_ctxX)px;top:@(_ctxY)px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.2);min-width:160px;overflow:hidden;padding:4px 0;font-size:.84rem;"
         @onclick:stopPropagation="true">
        <div class="sched-ctx-item" style="color:#374151;" @onclick="EditCtx">
            <i class="ri-edit-line" style="color:#3b82f6;"></i><span>Edit</span>
        </div>
        <div style="height:1px;background:#e5e7eb;margin:2px 0;"></div>
        <div class="sched-ctx-item" style="color:#ef4444;" @onclick="() => _confirmDelete = true">
            <i class="ri-delete-bin-line"></i><span>Delete</span>
        </div>
    </div>
    <div style="position:fixed;inset:0;z-index:9998;" @onclick="CloseCtx"></div>
}

<!-- Delete confirm modal -->
@if (_confirmDelete && _ctxMeetingId.HasValue)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45);z-index:1060;">
        <div class="modal-dialog modal-dialog-centered modal-sm"
             @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title">Delete Meeting?</h6>
                </div>
                <div class="modal-body small">
                    @if (_ctxIsWeekly)
                    {
                        <div class="text-warning mb-1">
                            <i class="ri-repeat-line me-1"></i>This is a recurring meeting.
                        </div>
                        <div>All weekly occurrences will be removed.</div>
                    }
                    else
                    {
                        <div>Are you sure you want to delete this meeting?</div>
                    }
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-sm btn-secondary"
                            @onclick="() => _confirmDelete = false">Cancel</button>
                    <button class="btn btn-sm btn-danger"
                            @onclick="ConfirmDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

<SpkScheduleMeetingModal @ref="_modal" OnSaved="OnMeetingSaved" />

@code {
    SpkScheduleMeetingModal? _modal;
    DotNetObjectReference<Schedule>? _dotnetRef;

    string _type = "Auditing";
    bool _calInitialized;

    int? _ctxMeetingId;
    double _ctxX, _ctxY;
    bool _confirmDelete, _ctxIsWeekly;

    List<(string Name, string Color)> _legendItems = new();

    // Fixed palette — auditorId % length gives deterministic, consistent color
    private static readonly string[] AuditorPalette =
    {
        "#3b82f6", "#ef4444", "#10b981", "#f59e0b", "#8b5cf6",
        "#ec4899", "#06b6d4", "#f97316", "#14b8a6", "#6366f1",
        "#a855f7", "#84cc16", "#0ea5e9", "#fb923c", "#be185d"
    };
    private const string AcademyColor = "#22c55e";

    private string GetColor(int? auditorId) =>
        auditorId.HasValue
            ? AuditorPalette[Math.Abs(auditorId.Value) % AuditorPalette.Length]
            : AcademyColor;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _dotnetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("ScheduleCalendar.init", "sched-cal", _dotnetRef, "timeGridWeek");
        _calInitialized = true;
    }

    [JSInvokable]
    public Task<List<object>> FetchEvents(string startStr, string endStr)
    {
        var from = DateTime.Parse(startStr);
        var to   = DateTime.Parse(endStr);
        var meetings = MeetingSvc.GetMeetings(from, to, _type);

        // Build legend from distinct auditors visible in this range
        _legendItems = meetings
            .Where(m => m.AuditorName != null)
            .GroupBy(m => m.AuditorId)
            .Select(g => (g.First().AuditorName!, GetColor(g.Key)))
            .ToList();
        // Compute slot range: default 09:00–19:00, expand if meetings fall outside
        var defMin = TimeSpan.FromHours(9);
        var defMax = TimeSpan.FromHours(19);
        TimeSpan slotMin = defMin, slotMax = defMax;
        if (meetings.Any())
        {
            var earliest = meetings.Min(m => m.StartAt.TimeOfDay);
            var latest   = meetings.Max(m => m.StartAt.AddSeconds(m.LengthSeconds).TimeOfDay);
            // Round down to 30-min boundary, add 30-min buffer
            var rawMin = earliest - TimeSpan.FromMinutes(30);
            var rawMax = latest   + TimeSpan.FromMinutes(30);
            slotMin = TimeSpan.FromMinutes(Math.Floor(rawMin.TotalMinutes / 30) * 30);
            slotMax = TimeSpan.FromMinutes(Math.Ceiling(rawMax.TotalMinutes / 30) * 30);
            // Clamp and ensure at least the default window is shown
            if (slotMin > defMin) slotMin = defMin;
            if (slotMax < defMax) slotMax = defMax;
            if (slotMin < TimeSpan.Zero) slotMin = TimeSpan.Zero;
            if (slotMax > TimeSpan.FromHours(24)) slotMax = TimeSpan.FromHours(24);
        }
        var slotMinStr = $"{(int)slotMin.TotalHours:D2}:{slotMin.Minutes:D2}:00";
        var slotMaxStr = $"{(int)slotMax.TotalHours:D2}:{slotMax.Minutes:D2}:00";
        _ = InvokeAsync(async () =>
        {
            await JS.InvokeVoidAsync("ScheduleCalendar.updateSlotRange", slotMinStr, slotMaxStr);
            StateHasChanged();
        });

        var events = meetings.Select(m =>
        {
            var color = GetColor(m.AuditorId);
            var title = m.AuditorName != null
                ? $"{m.PcName}  ·  {m.AuditorName}"
                : m.PcName;

            return (object)new
            {
                id              = $"{m.MeetingId}_{m.StartAt.Ticks}",
                title,
                start           = m.StartAt.ToString("yyyy-MM-ddTHH:mm:ss"),
                end             = m.StartAt.AddSeconds(m.LengthSeconds).ToString("yyyy-MM-ddTHH:mm:ss"),
                backgroundColor = color,
                borderColor     = color,
                textColor       = "#ffffff",
                extendedProps   = new
                {
                    meetingId   = m.MeetingId,
                    pcName      = m.PcName,
                    auditorName = m.AuditorName,
                    durationMin = m.LengthSeconds / 60,
                    isWeekly    = m.IsWeekly
                }
            };
        }).ToList();

        return Task.FromResult(events);
    }

    // Click on empty cell → new meeting pre-filled with that date/time
    [JSInvokable]
    public async Task OnDateClick(string dateStr)
    {
        if (DateTime.TryParse(dateStr, out var dt))
            await InvokeAsync(async () => await _modal!.Show(dt, _type));
    }

    // Double-click on event → edit
    [JSInvokable]
    public async Task OnEventDblClick(int meetingId)
    {
        var meeting = MeetingSvc.GetMeetingById(meetingId);
        if (meeting == null) return;
        CloseCtx();
        await InvokeAsync(async () => await _modal!.ShowForEdit(meeting));
    }

    async Task OnCalContextMenu(MouseEventArgs e)
    {
        var meetingId = await JS.InvokeAsync<int>("ScheduleCalendar.getMeetingIdAt", e.ClientX, e.ClientY);
        if (meetingId <= 0) return;
        var meeting = MeetingSvc.GetMeetingById(meetingId);
        _ctxMeetingId  = meetingId;
        _ctxX          = e.ClientX;
        _ctxY          = e.ClientY;
        _ctxIsWeekly   = meeting?.IsWeekly ?? false;
        _confirmDelete = false;
        StateHasChanged();
    }

    void CloseCtx() { _ctxMeetingId = null; _confirmDelete = false; }

    async Task EditCtx()
    {
        if (!_ctxMeetingId.HasValue) return;
        var meeting = MeetingSvc.GetMeetingById(_ctxMeetingId.Value);
        CloseCtx();
        if (meeting != null)
            await _modal!.ShowForEdit(meeting);
    }

    void ConfirmDelete()
    {
        if (!_ctxMeetingId.HasValue) return;
        MeetingSvc.DeleteMeeting(_ctxMeetingId.Value);
        CloseCtx();
        if (_calInitialized)
            _ = JS.InvokeVoidAsync("ScheduleCalendar.refresh");
    }

    async Task SetType(string t)
    {
        _type = t;
        if (_calInitialized)
            await JS.InvokeVoidAsync("ScheduleCalendar.refresh");
    }

    async Task OnMeetingSaved()
    {
        if (_calInitialized)
            await JS.InvokeVoidAsync("ScheduleCalendar.refresh");
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_calInitialized)
                await JS.InvokeVoidAsync("ScheduleCalendar.destroy");
        }
        catch { }
        _dotnetRef?.Dispose();
    }
}
