@page "/Setup2FA"
@layout CustomLayout
@using QRCoder
@using OtpNet
@using LPM.Auth
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IConfiguration Config

<div class="auth-bg">
    <div class="container">
        <div class="row justify-content-center align-items-center vh-100">
            <div class="col-xxl-5 col-xl-5 col-lg-6 col-md-7 col-sm-9 col-12">
                <div class="auth-card">

                    <div class="auth-card-icon-wrap" style="background:linear-gradient(135deg,#0d9488,#22c55e);">
                        <i class="ri-shield-keyhole-line"></i>
                    </div>

                    <h4 class="auth-card-title">Set Up Two-Factor Authentication</h4>
                    <p class="auth-card-sub">
                        Scan the QR code with your authenticator app, then enter the 6-digit code to confirm.
                    </p>

                    @if (_error)
                    {
                        <div class="auth-alert auth-alert-danger">
                            <i class="ri-error-warning-line"></i> Incorrect code — please try again.
                        </div>
                    }

                    @* QR Code *@
                    <div class="s2fa-qr-wrap">
                        <img src="@_qrDataUri" alt="QR Code" class="s2fa-qr-img" />
                    </div>

                    @* App suggestions *@
                    <div class="s2fa-apps">
                        <span class="s2fa-app-label">Works with:</span>
                        <span class="s2fa-app-badge"><i class="ri-google-line"></i> Google Authenticator</span>
                        <span class="s2fa-app-badge"><i class="ri-microsoft-line"></i> Microsoft Authenticator</span>
                        <span class="s2fa-app-badge">Authy · 1Password · Bitwarden</span>
                    </div>

                    @* Manual entry *@
                    <details class="s2fa-manual">
                        <summary>Can't scan? Enter manually</summary>
                        <div class="s2fa-manual-key">
                            <span class="s2fa-key-label">Account:</span> <code>@_accountName</code><br/>
                            <span class="s2fa-key-label">Key:</span>
                            <code class="s2fa-secret-code">@FormatSecret(_base32Secret)</code>
                        </div>
                    </details>

                    @* Code input *@
                    <div class="auth-field" style="margin-top:24px;">
                        <label class="auth-label">Verification Code</label>
                        <div class="auth-input-wrap">
                            <span class="auth-input-icon"><i class="ri-key-2-line"></i></span>
                            <input type="text" inputmode="numeric" maxlength="6"
                                   class="auth-input s2fa-code-input"
                                   placeholder="000 000"
                                   @bind="_code" @bind:event="oninput"
                                   @onkeydown="HandleKey" />
                        </div>
                    </div>

                    <button class="auth-submit-btn" style="background:linear-gradient(135deg,#0d9488,#22c55e);box-shadow:0 4px 16px rgba(34,197,94,.35);"
                            @onclick="Submit" disabled="@(_loading || _code.Length < 6)">
                        @if (_loading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        else
                        {
                            <i class="ri-shield-check-line me-2"></i>
                        }
                        Verify &amp; Activate 2FA
                    </button>

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    string _base32Secret = "";
    byte[] _rawSecret = [];
    string _qrDataUri = "";
    string _accountName = "LPM";
    string _code = "";
    bool _error, _loading;
    string _rawSecretB64 = "";

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _error = q["error"] == "1";

        // If returning after a failed attempt, restore the same secret
        var rs = q["rs"];
        if (!string.IsNullOrEmpty(rs))
        {
            try
            {
                _rawSecret = Convert.FromBase64String(rs);
                _base32Secret = Base32Encoding.ToString(_rawSecret);
                _rawSecretB64 = rs;
            }
            catch { GenerateNewSecret(); }
        }
        else
        {
            GenerateNewSecret();
        }

        BuildQrCode();
    }

    void GenerateNewSecret()
    {
        var (raw, b32) = UserDb.GenerateTotpSecret();
        _rawSecret = raw;
        _base32Secret = b32;
        _rawSecretB64 = Convert.ToBase64String(raw);
    }

    void BuildQrCode()
    {
        var issuer = "LPM";
        var otpUri = $"otpauth://totp/{Uri.EscapeDataString(issuer)}?secret={_base32Secret}&issuer={Uri.EscapeDataString(issuer)}&algorithm=SHA1&digits=6&period=30";
        using var qrGenerator = new QRCodeGenerator();
        using var qrData = qrGenerator.CreateQrCode(otpUri, QRCodeGenerator.ECCLevel.M);
        using var qrCode = new PngByteQRCode(qrData);
        var pngBytes = qrCode.GetGraphic(6);
        _qrDataUri = $"data:image/png;base64,{Convert.ToBase64String(pngBytes)}";
    }

    static string FormatSecret(string s)
    {
        // Insert space every 4 chars for readability
        var chunks = new System.Text.StringBuilder();
        for (int i = 0; i < s.Length; i++)
        {
            if (i > 0 && i % 4 == 0) chunks.Append(' ');
            chunks.Append(s[i]);
        }
        return chunks.ToString();
    }

    async Task HandleKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && _code.Length == 6) await Submit();
    }

    async Task Submit()
    {
        _loading = true;
        StateHasChanged();
        await JS.InvokeVoidAsync("lpmPostForm", "/loginpost-setup2fa",
            new Dictionary<string, string>
            {
                ["code"] = _code,
                ["rawSecret"] = _rawSecretB64
            });
    }
}

<style>
    .auth-bg {
        min-height: 100vh;
        background: radial-gradient(ellipse at 60% 40%, #1e293b 0%, #0f172a 100%);
    }
    .auth-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 24px;
        padding: 40px 36px 36px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.5);
        backdrop-filter: blur(12px);
        text-align: center;
    }
    .auth-card-icon-wrap {
        width: 64px; height: 64px; border-radius: 18px;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 20px; font-size: 1.8rem; color: #fff;
        box-shadow: 0 8px 24px rgba(34,197,94,0.35);
    }
    .auth-card-title { color: #f1f5f9; font-size: 1.4rem; font-weight: 700; margin-bottom: 6px; }
    .auth-card-sub { color: #94a3b8; font-size: .88rem; margin-bottom: 20px; line-height: 1.5; }
    .auth-alert { border-radius: 10px; padding: 10px 14px; font-size: .85rem;
                  display: flex; align-items: center; gap: 8px; margin-bottom: 18px; text-align: left; }
    .auth-alert-danger { background: rgba(239,68,68,0.12); border: 1px solid rgba(239,68,68,0.3); color: #fca5a5; }
    .s2fa-qr-wrap {
        display: flex; justify-content: center; margin: 8px 0 16px;
    }
    .s2fa-qr-img {
        width: 180px; height: 180px; border-radius: 12px;
        padding: 10px; background: #fff;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }
    .s2fa-apps {
        display: flex; flex-wrap: wrap; justify-content: center;
        align-items: center; gap: 6px; margin-bottom: 14px;
    }
    .s2fa-app-label { color: #64748b; font-size: .75rem; }
    .s2fa-app-badge {
        background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 999px; padding: 3px 10px; font-size: .73rem; color: #94a3b8;
        display: flex; align-items: center; gap: 4px;
    }
    .s2fa-manual {
        text-align: left; margin-bottom: 6px;
        background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
        border-radius: 10px; padding: 10px 14px; font-size: .82rem; color: #94a3b8;
    }
    .s2fa-manual summary { cursor: pointer; color: #7dd3fc; font-size: .82rem; }
    .s2fa-manual-key { margin-top: 10px; line-height: 1.8; }
    .s2fa-key-label { color: #64748b; font-size: .75rem; }
    .s2fa-secret-code { letter-spacing: .12em; font-size: .8rem; color: #a5f3fc; word-break: break-all; }
    .auth-field { text-align: left; margin-bottom: 16px; }
    .auth-label { display: block; font-size: .8rem; font-weight: 600; color: #94a3b8;
                  letter-spacing: .05em; text-transform: uppercase; margin-bottom: 6px; }
    .auth-input-wrap { position: relative; display: flex; align-items: center; }
    .auth-input-icon { position: absolute; left: 14px; color: #475569; font-size: 1rem; pointer-events: none; }
    .auth-input {
        width: 100%; padding: 11px 14px 11px 40px;
        background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
        border-radius: 10px; color: #f1f5f9; font-size: .95rem; outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .auth-input:focus { border-color: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,0.2); }
    .auth-input::placeholder { color: #475569; }
    .s2fa-code-input { text-align: center; font-size: 1.5rem; letter-spacing: .3em; font-weight: 700; }
    .auth-submit-btn {
        width: 100%; margin-top: 8px; padding: 13px;
        border: none; border-radius: 12px; color: #fff;
        font-size: 1rem; font-weight: 600; cursor: pointer;
        transition: opacity .2s, transform .1s;
    }
    .auth-submit-btn:hover:not(:disabled) { opacity: .9; transform: translateY(-1px); }
    .auth-submit-btn:disabled { opacity: .5; cursor: not-allowed; }
</style>
