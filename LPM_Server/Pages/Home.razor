    void TogglePcsSort(string col)
    {
        if (_pcsSortCol == col) _pcsSortAsc = !_pcsSortAsc;
        else { _pcsSortCol = col; _pcsSortAsc = true; }
    }

    string PcsSortIcon(string col)
    {
        if (_pcsSortCol != col) return "ri-arrow-up-down-line" + " home-pcs-sort-idle";
        return _pcsSortAsc ? "ri-arrow-up-s-line home-pcs-sort-active" : "ri-arrow-down-s-line home-pcs-sort-active";
    }

    List<DashboardService.PendingCsSession> GetSortedPendingCs()
    {
        IEnumerable<DashboardService.PendingCsSession> q = _pendingCsSessions;
        q = _pcsSortCol switch
        {
            "date" => _pcsSortAsc
                ? q.OrderBy(s => DateTime.TryParse(s.CreatedAt, out var dt) ? dt : DateTime.MinValue).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => DateTime.TryParse(s.CreatedAt, out var dt) ? dt : DateTime.MinValue).ThenBy(s => s.PcName),
            "dur" => _pcsSortAsc
                ? q.OrderBy(s => s.TotalSeconds).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.TotalSeconds).ThenBy(s => s.PcName),
            _ => _pcsSortAsc
                ? q.OrderBy(s => s.PcName).ThenBy(s => s.SessionDate)
                : q.OrderByDescending(s => s.PcName).ThenBy(s => s.SessionDate),
        };
        return q.ToList();
    }

    void ToggleAudSort(string col)
    {
        if (_audSortCol == col) _audSortAsc = !_audSortAsc;
        else { _audSortCol = col; _audSortAsc = true; }
    }

    string AudSortIcon(string col)
    {
        if (_audSortCol != col) return "ri-arrow-up-down-line" + " home-pcs-sort-idle";
        return _audSortAsc ? "ri-arrow-up-s-line home-pcs-sort-active" : "ri-arrow-down-s-line home-pcs-sort-active";
    }

    List<DashboardService.AuditorSessionStatus> GetSortedAudStatuses()
    {
        IEnumerable<DashboardService.AuditorSessionStatus> q = _auditorStatuses;
        q = _audSortCol switch
        {
            "date" => _audSortAsc
                ? q.OrderBy(s => DateTime.TryParse(s.CreatedAt, out var dt) ? dt : DateTime.MinValue).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => DateTime.TryParse(s.CreatedAt, out var dt) ? dt : DateTime.MinValue).ThenBy(s => s.PcName),
            "dur" => _audSortAsc
                ? q.OrderBy(s => s.TotalSeconds).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.TotalSeconds).ThenBy(s => s.PcName),
            _ => _audSortAsc
                ? q.OrderBy(s => s.PcName).ThenBy(s => s.SessionDate)
                : q.OrderByDescending(s => s.PcName).ThenBy(s => s.SessionDate),
        };
        return q.ToList();
    }

