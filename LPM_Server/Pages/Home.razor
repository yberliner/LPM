@page "/Home"
@using System.Globalization
@using LPM.Services
@using LPM._Spk
@attribute [Authorize]
@inject DashboardService DashSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject PdfService PdfService
@inject CsNotificationService CsNotifySvc
@inject FolderService FolderSvc
@inject LPM.Auth.UserDb UserDb
@inject NavigationManager Nav
@inject CompletionService CompletionSvc
@inject QuestionService QuestionSvc
@inject EffortService EffortSvc
@implements IDisposable

<div @onclick="DismissMenu">

@if (_initialized)
{
    @if (!_dataLoaded)
    {
        <div class="d-flex justify-content-center align-items-center py-5 text-muted">
            <div class="spinner-border me-2" role="status" style="width:1.4rem;height:1.4rem;"></div>
            <span>Loading...</span>
        </div>
    }
    else if (_userId == null)
    {
        <div class="px-3 text-danger">@LS.T("home.userNotFound")</div>
    }
    else if (!_isAuditor && !_isCS && !_isSoloAuditor)
    {
        <div class="px-3 text-muted">@LS.T("home.noRole")</div>
    }
    else
    {
        @* ── Grids ── *@
        <div id="print-zone">

            @* ══════ PENDING CS TABLE ══════ *@
            @if (_isCS)
            {
                <div class="card mx-3 mt-3 mb-2 home-pending-cs-card">
                    <div class="card-header py-2 home-pending-cs-header"
                         style="cursor:pointer;" @onclick="() => _pendingCsExpanded = !_pendingCsExpanded">
                        <i class="@(_pendingCsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-clipboard-line me-1"></i>
                        <strong>My CS Queue</strong>
                        <span class="home-pending-cs-badge">@_pendingCsSessions.Count(s => string.IsNullOrEmpty(s.CsStatus))</span>
                        <button class="home-done-toggle @(_showDoneCs ? "home-done-toggle-on" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="ToggleShowDoneCs"
                                title="@(_showDoneCs ? "Hide completed CSes" : "Show completed CSes")">
                            <i class="ri-eye-@(_showDoneCs ? "off-" : "")line me-1"></i>Done
                        </button>
                        <select class="home-range-select" value="@_csQueueDays"
                                @onclick:stopPropagation="true"
                                @onchange="OnCsQueueRangeChanged">
                            <option value="1">Last 1 day</option>
                            <option value="3">Last 3 days</option>
                            <option value="7">Last 7 days</option>
                            <option value="21">Last 21 days</option>
                            <option value="0">All</option>
                        </select>
                    </div>
                    @if (_pendingCsExpanded)
                    {
                        <div class="card-body p-0">
                            @CsQueueTable(_pendingCsSessions, _pcsSortCol, _pcsSortAsc, TogglePcsSort, PcsSortIcon, 0)
                        </div>
                    }
                </div>
            }

            @* ── CS Queue context menu ── *@
            @if (_csCtxVisible && _csCtxSession != null)
            {
                var ctxSession = _csCtxSession;
                var canUndo = ctxSession.CsStatus is "Done" or "Approved";
                <div class="home-cs-ctx-menu" style="top:@(_csCtxY)px; left:@(_csCtxX)px;"
                     @onclick:stopPropagation="true">
                    @if (_csCtxConfirming)
                    {
                        <div class="home-cs-ctx-confirm">
                            <div class="home-cs-ctx-confirm-text">Mark as undone?</div>
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-sm btn-danger py-0 px-2" style="font-size:.78rem;"
                                        disabled="@_csCtxBusy"
                                        @onclick="ConfirmMarkUndone">
                                    @if (_csCtxBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Yes, delete
                                </button>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:.78rem;"
                                        @onclick="CloseCsCtxMenu">@LS.T("common.cancel")</button>
                            </div>
                            @if (!string.IsNullOrEmpty(_csCtxError))
                            {
                                <div style="color:#f87171; font-size:.72rem; margin-top:6px;">@_csCtxError</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="home-cs-ctx-item @(canUndo ? "" : "home-cs-ctx-item-disabled")"
                             @onclick="() => { if (canUndo) _csCtxConfirming = true; }">
                            <i class="ri-arrow-go-back-line me-2"></i>Mark Session as Undone
                        </div>
                    }
                </div>
                <div class="home-cs-ctx-backdrop" @onclick="CloseCsCtxMenu"></div>
            }

            @* ══════ MOBILE ADD SESSION BUTTON ══════ *@
            @if (_isAuditor || _isSolo)
            {
                <div class="d-md-none mx-3 mb-1" style="margin-top:-0.5rem;">
                    @if (_isSolo)
                    {
                    @* ── Solo hero name + badge ── *@
                    <div class="solo-hero">
                        <div class="solo-hero-orb"></div>
                        <div class="solo-hero-ring"></div>
                        <div class="solo-hero-name">@_soloFirstName</div>
                        <div class="solo-hero-name solo-hero-reflection">@_soloFirstName</div>
                        <div class="solo-hero-badge">
                            <span class="solo-badge-dot"></span>
                            Solo Auditor
                        </div>
                    </div>
                    }
                    <button class="home-mobile-add-session"
                            @onclick="OnMobileAddSession">
                        <span class="hmas-shimmer"></span>
                        <span class="hmas-content">
                            <i class="ri-upload-2-line hmas-icon"></i>
                            <span class="hmas-text">Add Session</span>
                            <i class="ri-arrow-right-line hmas-arrow"></i>
                        </span>
                    </button>
                    @if (_isSolo)
                    {
                    <button class="home-mobile-open-folder"
                            @onclick="OpenSoloFolder">
                        <span class="hmof-glow"></span>
                        <span class="hmof-particles">
                            <span class="hmof-particle"></span>
                            <span class="hmof-particle"></span>
                            <span class="hmof-particle"></span>
                        </span>
                        <span class="hmof-content">
                            <i class="ri-folder-open-line hmof-icon"></i>
                            <span class="hmof-text">Open Folder</span>
                            <i class="ri-arrow-right-up-line hmof-arrow"></i>
                        </span>
                    </button>
                    }
                </div>
            }

            @* ══════ MY AUDITING STATUS ══════ *@
            @if (_isAuditor || _isSolo)
            {
                <div class="card mx-3 mt-3 mb-2 home-aud-status-card">
                    <div class="card-header py-2 home-aud-status-header"
                         style="cursor:pointer;" @onclick="() => _audStatusExpanded = !_audStatusExpanded">
                        <i class="@(_audStatusExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-stethoscope-line me-1"></i>
                        <strong>My Auditing Status</strong>
                        <span class="home-aud-status-badge">@_auditorStatuses.Count</span>
                        <select class="home-range-select" value="@_audStatusDays"
                                @onclick:stopPropagation="true"
                                @onchange="OnAudStatusRangeChanged">
                            <option value="1">Last 1 day</option>
                            <option value="3">Last 3 days</option>
                            <option value="7">Last 7 days</option>
                            <option value="21">Last 21 days</option>
                            <option value="0">All</option>
                        </select>
                    </div>
                    @if (_audStatusExpanded)
                    {
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-sm table-hover mb-0 home-aud-status-table home-dual-table">
                                <colgroup>
                                    <col style="width:16%;" /><col style="width:14%;" /><col style="width:12%;" />
                                    <col style="width:10%;" /><col style="width:12%;" /><col style="width:10%;" />
                                    <col style="width:14%;" /><col style="width:12%;" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("pc")'>
                                            PC Name
                                            <i class="@AudSortIcon("pc")"></i>
                                        </th>
                                        <th>Name</th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("date")'>
                                            Date
                                            <i class="@AudSortIcon("date")"></i>
                                        </th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("dur")'>
                                            Duration
                                            <i class="@AudSortIcon("dur")"></i>
                                        </th>
                                        <th>CS Status</th>
                                        <th>CS By</th>
                                        <th style="text-align:center;">Questions</th>
                                        <th style="text-align:center;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string? prevAudPc = null;
                                        int audGroupIdx = 0;
                                    }
                                    @if (_auditorStatuses.Count == 0)
                                    {
                                        <tr><td colspan="8" class="text-center" style="padding:16px;color:#64748b;font-size:.8rem;">
                                            No sessions found for this period
                                        </td></tr>
                                    }
                                    @{ var sortedAud = GetSortedAudStatuses(); }
                                    @foreach (var s in sortedAud)
                                    {
                                        var isNewPc = s.PcName != prevAudPc;
                                        if (isNewPc) { audGroupIdx++; prevAudPc = s.PcName; }
                                        var rowClass = audGroupIdx % 2 == 0 ? "home-pcs-row-even" : "home-pcs-row-odd";
                                        var totalMin = s.TotalSeconds / 60;
                                        var hrs = totalMin / 60;
                                        var mins = totalMin % 60;
                                        var durStr = hrs > 0 ? $"{hrs}h {mins:D2}m" : $"{mins}m";
                                        var dateStr = DateOnly.TryParse(s.SessionDate, out var d2) ? d2.ToString("dd/MM/yy") : s.SessionDate;
                                        var (audDateDisp, audCreatedDisp, audDateTip) = FormatSessionDate(s.SessionDate, s.CreatedAt);
                                        var effectiveStatus = string.IsNullOrEmpty(s.CsStatus) ? "Waiting" : s.CsStatus;
                                        var hasNoCsAssigned = effectiveStatus == "Waiting" && !_pcsWithCs.Contains(s.PcId);
                                        var statusClass = hasNoCsAssigned ? "home-aud-st-no-cs"
                                            : effectiveStatus switch {
                                            "Waiting"    => "home-aud-st-waiting",
                                            "Done"       => "home-aud-st-done",
                                            "Approved"   => "home-aud-st-done",
                                            "Correction" => "home-aud-st-correction",
                                            _            => "home-aud-st-waiting"
                                        };
                                        var statusLabel = effectiveStatus == "Approved"
                                            ? (_csStatusLabels.TryGetValue("Done", out var doneLbl) ? doneLbl : "CS Done")
                                            : (_csStatusLabels.TryGetValue(effectiveStatus, out var lbl) ? lbl : effectiveStatus);
                                        var attTypes = _audAttachTypes.GetValueOrDefault(s.SessionId);
                                        var hasPink    = attTypes != null && attTypes.Contains("PinkSheet");
                                        var hasCram    = attTypes != null && attTypes.Contains("Cramming");
                                        var hasInstruct= attTypes != null && attTypes.Contains("Instruct");
                                        var attAnimClass = hasPink     ? "home-aud-att-pink"
                                                         : hasCram     ? "home-aud-att-orange"
                                                         : hasInstruct ? "home-aud-att-yellow"
                                                         : "";
                                        var hasAnyAtt = hasPink || hasCram || hasInstruct;
                                        var rowBorderClass = hasPink     ? "home-aud-row-att-pink"
                                                           : hasCram     ? "home-aud-row-att-orange"
                                                           : hasInstruct ? "home-aud-row-att-yellow"
                                                           : "";
                                        var attTooltip = s.CsStatus is "Waiting"
                                            ? "CSing was not done yet"
                                            : (hasPink && hasCram     ? "Pink Sheet + Cramming assignment from CS"
                                            :  hasPink && hasInstruct ? "Pink Sheet + Instruction assignment from CS"
                                            :  hasCram && hasInstruct ? "Cramming + Instruction assignment from CS"
                                            :  hasPink    ? "Pink Sheet added by CS"
                                            :  hasCram    ? "Cramming assignment from CS is pending"
                                            :  hasInstruct? "Instruction assignment from CS is pending"
                                            :  "No assignments from CS");
                                        var audPendingStyle = s.IsPendingApproval ? "opacity:.4; pointer-events:none;" : "";
                                        <tr class="@rowClass home-pcs-row @rowBorderClass" style="@audPendingStyle"
                                            title="@($"{s.PcName} — {RoleTooltip(s.WorkCapacity)} | {attTooltip}")"
                                            @onclick="() => { if (!s.IsPendingApproval) OpenAuditorSession(s); }">
                                            <td class="home-pcs-pcname">
                                                @if (isNewPc)
                                                {
                                                    @if (s.IsPendingApproval)
                                                    {
                                                        <i class="ri-time-line me-1" style="opacity:.5;color:#f59e0b;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="ri-user-line me-1" style="opacity:.5;"></i>
                                                    }
                                                    @s.PcName
                                                }
                                            </td>
                                            <td class="home-pcs-session">@s.SessionName</td>
                                            <td class="home-pcs-date">
                                                @if (audCreatedDisp != null)
                                                {
                                                    <span class="home-pcs-date-wrap">
                                                        @audDateDisp<span class="home-pcs-date-created"> (@audCreatedDisp)</span>
                                                        <div class="home-pcs-date-hover">
                                                            <div class="home-pcs-date-hover-title"><i class="ri-information-line me-1"></i>Date mismatch</div>
                                                            <div class="home-pcs-date-hover-body">@audDateTip</div>
                                                        </div>
                                                    </span>
                                                }
                                                else
                                                {
                                                    @audDateDisp
                                                }
                                            </td>
                                            <td class="home-pcs-dur">
                                                <i class="ri-time-line me-1" style="opacity:.4;"></i>@durStr
                                            </td>
                                            <td class="home-aud-st-cell @(hasNoCsAssigned ? "home-aud-no-cs-cell" : "")">
                                                @if (hasNoCsAssigned)
                                                {
                                                    <div class="home-no-cs-wrap">
                                                        <span class="home-aud-st-badge home-aud-st-no-cs">
                                                            <i class="ri-error-warning-fill me-1"></i>No CS
                                                        </span>
                                                        <div class="home-no-cs-tooltip">
                                                            <div class="home-no-cs-tooltip-icon"><i class="ri-shield-user-line"></i></div>
                                                            <div class="home-no-cs-tooltip-title">No Case Supervisor Assigned</div>
                                                            <div class="home-no-cs-tooltip-body">
                                                                This PC has no CS assigned in Staff Permissions.
                                                                The session cannot be reviewed until a CS is assigned.
                                                            </div>
                                                            <div class="home-no-cs-tooltip-action">
                                                                <i class="ri-arrow-right-line"></i> Ask an admin to assign a CS in <strong>Staff Permissions</strong>
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="home-aud-st-badge @statusClass">@statusLabel</span>
                                                }
                                                @if (s.IsSessionVerified) { <span class="home-approved-tick" title="Session approved by admin">✓</span> }
                                                @if (hasPink)    { <span class="home-att-chip home-att-chip-pink home-aud-att-pink">🩷 Pink</span> }
                                                @if (hasCram)    { <span class="home-att-chip home-att-chip-orange home-aud-att-orange">📙 Cram</span> }
                                                @if (hasInstruct){ <span class="home-att-chip home-att-chip-yellow home-aud-att-yellow">📋 Instr</span> }
                                            </td>
                                            <td class="home-pcs-staff">
                                                @(s.CsName ?? "—")
                                            </td>
                                            @{ var audHasQ = _sessionQuestions.TryGetValue(s.SessionId, out var audQInfo); }
                                            <td style="text-align:center;">
                                                @if (audHasQ && audQInfo!.Status == "Pending")
                                                {
                                                    <span class="home-q-badge home-q-pending" title="Question by @audQInfo.AskerName">
                                                        <i class="ri-question-line"></i> @audQInfo.AskerName
                                                    </span>
                                                }
                                                else if (audHasQ && audQInfo!.Status == "Replied")
                                                {
                                                    <span class="home-q-badge home-q-replied" title="Replied by @audQInfo.ReplierName">
                                                        <i class="ri-chat-check-line"></i> @audQInfo.ReplierName
                                                    </span>
                                                }
                                            </td>
                                            <td style="text-align:center;">
                                                <button class="home-pcs-cs-btn" style="background:#5c6bc0;"
                                                        title="Open PC Folder"
                                                        @onclick="() => OpenAuditorSession(s)">
                                                    <i class="ri-folder-open-line"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @* ══════ TEAM CS REVIEW (SeniorCS only) ══════ *@
            @if (_isSeniorCS)
            {
                var teamTotalPending = _teamCsQueues.Values.Sum(q => q.Count(s => string.IsNullOrEmpty(s.CsStatus)));
                <div class="card mx-3 mt-3 mb-2 home-team-cs-card">
                    <div class="card-header py-2 home-team-cs-header"
                         style="cursor:pointer;" @onclick="() => _teamCsExpanded = !_teamCsExpanded">
                        <i class="@(_teamCsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-team-line me-1 home-team-cs-icon"></i>
                        <strong class="home-team-cs-title">Team CS Review</strong>
                        <span class="home-team-cs-badge">@teamTotalPending</span>
                        <button class="home-done-toggle @(_showTeamCsDone ? "home-done-toggle-on" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="ToggleTeamCsDone"
                                title="@(_showTeamCsDone ? "Hide completed CSes" : "Show completed CSes")">
                            <i class="ri-eye-@(_showTeamCsDone ? "off-" : "")line me-1"></i>Done
                        </button>
                        <select class="home-range-select" value="@_teamCsDays"
                                @onclick:stopPropagation="true"
                                @onchange="OnTeamCsDaysChanged">
                            <option value="1">Last 1 day</option>
                            <option value="3">Last 3 days</option>
                            <option value="7">Last 7 days</option>
                            <option value="21">Last 21 days</option>
                            <option value="0">All</option>
                        </select>
                    </div>
                    @if (_teamCsExpanded)
                    {
                        <div class="card-body p-0">
                            @if (_teamCsStaff.Count == 0)
                            {
                                <div class="text-center py-3" style="color:#64748b;font-size:.8rem;">No other CS staff found</div>
                            }
                            @foreach (var cs in _teamCsStaff)
                            {
                                var csId = cs.PersonId;
                                var queue = _teamCsQueues.GetValueOrDefault(csId, []);
                                var expanded = _teamCsUserExpanded.GetValueOrDefault(csId, true);
                                var pendingCount = queue.Count(s => string.IsNullOrEmpty(s.CsStatus));
                                <div class="border-bottom">
                                    <div class="px-3 py-2 d-flex align-items-center gap-2" style="cursor:pointer;background:#f8fafc;"
                                         @onclick="() => ToggleTeamCsUser(csId)">
                                        <i class="@(expanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")" style="font-size:.9rem;"></i>
                                        <i class="ri-user-3-line" style="opacity:.5;"></i>
                                        <strong style="font-size:.85rem;">@cs.FullName</strong>
                                        <span class="home-pending-cs-badge" style="font-size:.7rem;">@pendingCount</span>
                                    </div>
                                    @if (expanded)
                                    {
                                        @CsQueueTable(queue, _teamCsSortCol, _teamCsSortAsc, ToggleTeamCsSort, TeamCsSortIcon, csId)
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }

            @if (!_isSolo)
            {
            @* ══════ WEEKLY OVERVIEW (collapsible) ══════ *@
            <div class="home-overview-header px-3 mt-1 mb-1 d-flex align-items-center flex-wrap gap-2">
                <div @onclick="() => _weeklyOverviewExpanded = !_weeklyOverviewExpanded"
                     style="display:flex;align-items:center;cursor:pointer;">
                    <i class="@(_weeklyOverviewExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                       style="font-size:1.1rem;"></i>
                    <i class="ri-calendar-check-line me-1"></i>
                    <strong>Weekly Overview</strong>
                </div>
                @if (!_isSolo)
                {
                    <div class="d-flex align-items-center gap-1 ms-2">
                        <button class="btn btn-sm home-nav-btn" @onclick="PrevWeek" title="@LS.T("common.prev")">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <span class="home-nav-week" style="font-size:.82rem; white-space:nowrap;">
                            <i class="ri-calendar-2-line me-1 opacity-75"></i>@DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
                        </span>
                        <button class="btn btn-sm home-nav-btn" @onclick="NextWeek" title="@LS.T("common.next")"
                                disabled="@(_weekStart >= DashboardService.GetWeekStart(MaxAllowedDate()))">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                    </div>
                }
                <div class="ms-auto d-flex align-items-center gap-2">
                    @if (!_isSolo && _weeklyOverviewExpanded)
                    {
                        <button class="btn btn-sm @(_hideEmpty?"home-filter-active":"home-filter-btn") d-flex align-items-center gap-1"
                                title="@(_hideEmpty?LS.T("home.showEmpty"):LS.T("home.hideEmpty"))"
                                @onclick="() => _hideEmpty = !_hideEmpty"
                                @onclick:stopPropagation="true"
                                style="font-size:.75rem;">
                            <i class="@(_hideEmpty?"ri-eye-line":"ri-eye-off-line")"></i>
                            @(_hideEmpty ? "Show empty PCs" : "Hide empty PCs")
                        </button>
                    }
                    <button class="btn btn-sm home-nav-btn" @onclick="PrintTable" title="@LS.T("common.print")"
                            @onclick:stopPropagation="true">
                        <i class="ri-printer-line me-1"></i>@LS.T("common.print")
                    </button>
                </div>
            </div>

            @if (_weeklyOverviewExpanded)
            {
            var _audPcs = AuditorPcs;

            @* ══════ AUDITOR TABLE ══════ *@
            @if (_audPcs.Count > 0 || _myPcs.Count == 0)
            {
                <div class="home-table-label px-3 mt-1 mb-1">
                    <i class="ri-user-line me-1"></i>@LS.T("home.aud")
                </div>
                <div id="week-table-scroll" class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _audPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        @* ── CS name row ── *@
                        <tr class="small" style="color:#495057; opacity:.85;">
                            <th style="min-width:110px;">@LS.T("home.csHeader")</th>
                            @foreach (var pc in _audPcs)
                            {
                                var csFullName   = _pcCsNames.TryGetValue(pc.PcId, out var cn) ? cn : "";
                                var csFirstName  = csFullName.Length > 0 ? csFullName.Split(' ')[0] : "NA";
                                var csColBlocked = _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center fw-normal user-select-none"
                                    style="@(csColBlocked ? "cursor:default;" : "cursor:context-menu;") position:relative;"
                                    @oncontextmenu="e => { if (!csColBlocked) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span title="@(csFullName.Length > 0 ? csFullName : "Unknown")">@csFirstName</span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
