        font-weight: 600;
        letter-spacing: .03em;
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 8px rgba(124, 58, 237, .4), 0 0 20px rgba(168, 85, 247, .2);
        animation: csSessionGlow 2s ease-in-out infinite;
        transition: transform .15s, box-shadow .15s;
    }
    .home-cs-session-btn:hover {
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 0 14px rgba(124, 58, 237, .6), 0 0 30px rgba(168, 85, 247, .35);
        color: #fff;
    }
    .home-cs-session-btn:active {
        transform: scale(.96);
    }
    /* Shimmer sweep */
    .home-cs-session-btn::after {
        content: '';
        position: absolute;
        top: 0; left: -100%; width: 60%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.25), transparent);
        animation: csSessionShimmer 3s ease-in-out infinite;
    }
    @@keyframes csSessionGlow {
        0%, 100% { box-shadow: 0 0 8px rgba(124,58,237,.4), 0 0 20px rgba(168,85,247,.2); }
        50%      { box-shadow: 0 0 16px rgba(124,58,237,.6), 0 0 35px rgba(168,85,247,.35); }
    }
    @@keyframes csSessionShimmer {
        0%   { left: -100%; }
        50%  { left: 150%; }
        100% { left: 150%; }
    }

    /* ── CS Queue context menu ── */
    .home-cs-ctx-backdrop {
        position: fixed; inset: 0; z-index: 1039;
    }
    .home-cs-ctx-menu {
        position: fixed; z-index: 1040;
        background: #1e293b; border: 1px solid #334155;
        border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.5);
        min-width: 210px; padding: 4px 0; font-size: .83rem;
    }
    .home-cs-ctx-item {
        padding: 9px 16px; cursor: pointer; color: #e2e8f0;
        display: flex; align-items: center;
        transition: background .12s;
    }
    .home-cs-ctx-item:hover {
        background: rgba(239,68,68,.15); color: #f87171;
    }
    .home-cs-ctx-item-disabled {
        opacity: .35; cursor: default; pointer-events: none;
    }
    .home-cs-ctx-confirm {
        padding: 10px 14px;
    }
    .home-cs-ctx-confirm-text {
        font-size: .82rem; color: #e2e8f0; font-weight: 600;
    }

