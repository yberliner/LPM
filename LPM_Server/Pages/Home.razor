@page "/Home"
@using System.Globalization
@using LPM.Services
@using LPM._Spk
@attribute [Authorize]
@inject DashboardService DashSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject PdfService PdfService
@inject CsNotificationService CsNotifySvc
@inject FolderService FolderSvc
@implements IDisposable

<div @onclick="DismissMenu">


    @if (_userId == null)
    {
        <div class="px-3 text-danger">@LS.T("home.userNotFound")</div>
    }
    else if (!_isAuditor && !_isCS && !_isSoloAuditor)
    {
        <div class="px-3 text-muted">@LS.T("home.noRole")</div>
    }
    else
    {
        @* ── Grids ── *@
        <div id="print-zone">

            @* ══════ PENDING CS TABLE ══════ *@
            @if (_isCS)
            {
                <div class="card mx-3 mt-3 mb-2 home-pending-cs-card">
                    <div class="card-header py-2 home-pending-cs-header"
                         style="cursor:pointer;" @onclick="() => _pendingCsExpanded = !_pendingCsExpanded">
                        <i class="@(_pendingCsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-clipboard-line me-1"></i>
                        <strong>My CS Queue</strong>
                        <span class="home-pending-cs-badge">@_pendingCsSessions.Count(s => string.IsNullOrEmpty(s.CsStatus))</span>
                        <button class="home-done-toggle @(_showDoneCs ? "home-done-toggle-on" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="ToggleShowDoneCs"
                                title="@(_showDoneCs ? "Hide completed CSes" : "Show completed CSes")">
                            <i class="ri-eye-@(_showDoneCs ? "off-" : "")line me-1"></i>Done
                        </button>
                        <select class="home-range-select" value="@_csQueueDays"
                                @onclick:stopPropagation="true"
                                @onchange="OnCsQueueRangeChanged">
                            <option value="1">Last 1 day</option>
                            <option value="3">Last 3 days</option>
                            <option value="7">Last 7 days</option>
                            <option value="10">Last 10 days</option>
                            <option value="0">All</option>
                        </select>
                    </div>
                    @if (_pendingCsExpanded)
                    {
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-sm table-hover mb-0 home-pending-cs-table home-dual-table">
                                <colgroup>
                                    <col style="width:18%;" /><col style="width:17%;" /><col style="width:13%;" />
                                    <col style="width:11%;" /><col style="width:14%;" /><col style="width:13%;" />
                                    <col style="width:14%;" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("pc")'>
                                            PC Name
                                            <i class="@PcsSortIcon("pc")"></i>
                                        </th>
                                        <th>Name</th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("date")'>
                                            Date
                                            <i class="@PcsSortIcon("date")"></i>
                                        </th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("dur")'>
                                            Duration
                                            <i class="@PcsSortIcon("dur")"></i>
                                        </th>
                                        <th>Auditor</th>
                                        <th>Type</th>
                                        <th style="text-align:center;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string? prevPcName = null;
                                        int pcGroupIdx = 0;
                                        var sorted = GetSortedPendingCs();
                                    }
                                    @if (sorted.Count == 0)
                                    {
                                        <tr><td colspan="7" class="text-center" style="padding:16px;color:#64748b;font-size:.8rem;">
                                            No sessions pending review for this period
                                        </td></tr>
                                    }
                                    @foreach (var s in sorted)
                                    {
                                        var isNewPc = s.PcName != prevPcName;
                                        if (isNewPc) { pcGroupIdx++; prevPcName = s.PcName; }
                                        var rowClass = pcGroupIdx % 2 == 0 ? "home-pcs-row-even" : "home-pcs-row-odd";
                                        var totalMin = s.TotalSeconds / 60;
                                        var hrs = totalMin / 60;
                                        var mins = totalMin % 60;
                                        var durStr = hrs > 0 ? $"{hrs}h {mins:D2}m" : $"{mins}m";
                                        var dateStr = DateTime.TryParse(s.CreatedAt, out var dt)
                                            ? dt.ToString("dd/MM/yy HH:mm")
                                            : (DateOnly.TryParse(s.SessionDate, out var d) ? d.ToString("dd/MM/yy") : s.SessionDate);
                                        var isDoneCs     = s.CsStatus is "Done" or "Approved";
                                        var isApprovedCs = s.CsStatus == "Approved";
                                        var pendingStyle = s.IsPendingApproval ? "opacity:.4; pointer-events:none;" : (isDoneCs ? "opacity:.55;" : "");
                                        <tr class="@rowClass home-pcs-row @(isDoneCs ? "home-csq-done-row" : "")" style="@pendingStyle"
                                            @onclick="() => { if (!s.IsPendingApproval) OpenPendingCs(s); }"
                                            @oncontextmenu="e => ShowCsCtxMenu(e, s)"
                                            @oncontextmenu:preventDefault="true">
                                            <td class="home-pcs-pcname">
                                                @if (isNewPc)
                                                {
                                                    @if (s.IsPendingApproval)
                                                    {
                                                        <i class="ri-time-line me-1" style="opacity:.5;color:#f59e0b;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="ri-user-line me-1" style="opacity:.5;"></i>
                                                    }
                                                    @s.PcName
                                                }
                                            </td>
                                            <td style="font-size:.78rem;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px;">@s.SessionName</td>
                                            <td class="home-pcs-date">@dateStr</td>
                                            <td class="home-pcs-dur">
                                                <i class="ri-time-line me-1" style="opacity:.4;"></i>@durStr
                                            </td>
                                            <td style="font-size:.78rem;color:#64748b;">
                                                @s.AuditorName
                                            </td>
                                            <td>
                                                @if (s.IsSolo)
                                                {
                                                    <span class="home-pcs-solo-badge">Solo</span>
                                                }
                                                else
                                                {
                                                    <span class="home-pcs-regular-badge">Regular</span>
                                                }
                                            </td>
                                            <td style="text-align:center;">
                                                @if (isApprovedCs)
                                                {
                                                    <span class="home-csq-approved-chip">
                                                        <i class="ri-check-double-line me-1"></i>Approved
                                                    </span>
                                                }
                                                else if (isDoneCs)
                                                {
                                                    <span class="home-csq-done-chip">
                                                        <i class="ri-check-line me-1"></i>Done
                                                    </span>
                                                }
                                                else
                                                {
                                                    <button class="home-pcs-cs-btn" title="Open CS for this session">
                                                        <i class="ri-eye-line me-1"></i>CS
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @* ── CS Queue context menu ── *@
            @if (_csCtxVisible && _csCtxSession != null)
            {
                var ctxSession = _csCtxSession;
                var canUndo = ctxSession.CsStatus is "Done" or "Approved";
                <div class="home-cs-ctx-menu" style="top:@(_csCtxY)px; left:@(_csCtxX)px;"
                     @onclick:stopPropagation="true">
                    @if (_csCtxConfirming)
                    {
                        <div class="home-cs-ctx-confirm">
                            <div class="home-cs-ctx-confirm-text">Mark as undone?</div>
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-sm btn-danger py-0 px-2" style="font-size:.78rem;"
                                        disabled="@_csCtxBusy"
                                        @onclick="ConfirmMarkUndone">
                                    @if (_csCtxBusy) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Yes, delete
                                </button>
                                <button class="btn btn-sm btn-outline-secondary py-0 px-2" style="font-size:.78rem;"
                                        @onclick="CloseCsCtxMenu">Cancel</button>
                            </div>
                            @if (!string.IsNullOrEmpty(_csCtxError))
                            {
                                <div style="color:#f87171; font-size:.72rem; margin-top:6px;">@_csCtxError</div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="home-cs-ctx-item @(canUndo ? "" : "home-cs-ctx-item-disabled")"
                             @onclick="() => { if (canUndo) _csCtxConfirming = true; }">
                            <i class="ri-arrow-go-back-line me-2"></i>Mark Session as Undone
                        </div>
                    }
                </div>
                <div class="home-cs-ctx-backdrop" @onclick="CloseCsCtxMenu"></div>
            }

            @* ══════ MY AUDITING STATUS ══════ *@
            @if (_isAuditor || _isSolo)
            {
                <div class="card mx-3 mt-3 mb-2 home-aud-status-card">
                    <div class="card-header py-2 home-aud-status-header"
                         style="cursor:pointer;" @onclick="() => _audStatusExpanded = !_audStatusExpanded">
                        <i class="@(_audStatusExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-stethoscope-line me-1"></i>
                        <strong>My Auditing Status</strong>
                        <span class="home-aud-status-badge">@_auditorStatuses.Count</span>
                        <select class="home-range-select" value="@_audStatusDays"
                                @onclick:stopPropagation="true"
                                @onchange="OnAudStatusRangeChanged">
                            <option value="1">Last 1 day</option>
                            <option value="3">Last 3 days</option>
                            <option value="7">Last 7 days</option>
                            <option value="10">Last 10 days</option>
                            <option value="30">Last 30 days</option>
                            <option value="0">All</option>
                        </select>
                    </div>
                    @if (_audStatusExpanded)
                    {
                        <div class="card-body p-0 table-responsive">
                            <table class="table table-sm table-hover mb-0 home-aud-status-table home-dual-table">
                                <colgroup>
                                    <col style="width:18%;" /><col style="width:17%;" /><col style="width:13%;" />
                                    <col style="width:11%;" /><col style="width:14%;" /><col style="width:13%;" />
                                    <col style="width:14%;" />
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("pc")'>
                                            PC Name
                                            <i class="@AudSortIcon("pc")"></i>
                                        </th>
                                        <th>Name</th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("date")'>
                                            Date
                                            <i class="@AudSortIcon("date")"></i>
                                        </th>
                                        <th class="home-pcs-sortable"
                                            @onclick='() => ToggleAudSort("dur")'>
                                            Duration
                                            <i class="@AudSortIcon("dur")"></i>
                                        </th>
                                        <th>CS Status</th>
                                        <th>CS By</th>
                                        <th style="text-align:center;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string? prevAudPc = null;
                                        int audGroupIdx = 0;
                                    }
                                    @if (_auditorStatuses.Count == 0)
                                    {
                                        <tr><td colspan="7" class="text-center" style="padding:16px;color:#64748b;font-size:.8rem;">
                                            No sessions found for this period
                                        </td></tr>
                                    }
                                    @{ var sortedAud = GetSortedAudStatuses(); }
                                    @foreach (var s in sortedAud)
                                    {
                                        var isNewPc = s.PcName != prevAudPc;
                                        if (isNewPc) { audGroupIdx++; prevAudPc = s.PcName; }
                                        var rowClass = audGroupIdx % 2 == 0 ? "home-pcs-row-even" : "home-pcs-row-odd";
                                        var totalMin = s.TotalSeconds / 60;
                                        var hrs = totalMin / 60;
                                        var mins = totalMin % 60;
                                        var durStr = hrs > 0 ? $"{hrs}h {mins:D2}m" : $"{mins}m";
                                        var dateStr = DateTime.TryParse(s.CreatedAt, out var dt2)
                                            ? dt2.ToString("dd/MM/yy HH:mm")
                                            : (DateOnly.TryParse(s.SessionDate, out var d2) ? d2.ToString("dd/MM/yy") : s.SessionDate);
                                        var statusClass = s.CsStatus switch {
                                            "Waiting"  => "home-aud-st-waiting",
                                            "Done"     => "home-aud-st-done",
                                            "Approved" => "home-aud-st-done",
                                            _          => ""
                                        };
                                        var statusLabel = s.CsStatus == "Approved"
                                            ? (_csStatusLabels.TryGetValue("Done", out var doneLbl) ? doneLbl : "CS Done")
                                            : (_csStatusLabels.TryGetValue(s.CsStatus ?? "", out var lbl) ? lbl : (s.CsStatus ?? ""));
                                        var attTypes = _audAttachTypes.GetValueOrDefault(s.SessionId);
                                        var hasPink    = attTypes != null && attTypes.Contains("PinkSheet");
                                        var hasCram    = attTypes != null && attTypes.Contains("Cramming");
                                        var hasInstruct= attTypes != null && attTypes.Contains("Instruct");
                                        var attAnimClass = hasPink     ? "home-aud-att-pink"
                                                         : hasCram     ? "home-aud-att-orange"
                                                         : hasInstruct ? "home-aud-att-yellow"
                                                         : "";
                                        var hasAnyAtt = hasPink || hasCram || hasInstruct;
                                        var rowBorderClass = hasPink     ? "home-aud-row-att-pink"
                                                           : hasCram     ? "home-aud-row-att-orange"
                                                           : hasInstruct ? "home-aud-row-att-yellow"
                                                           : "";
                                        var attTooltip = s.CsStatus is "Waiting"
                                            ? "CSing was not done yet"
                                            : (hasPink && hasCram     ? "Pink Sheet + Cramming assignment from CS"
                                            :  hasPink && hasInstruct ? "Pink Sheet + Instruction assignment from CS"
                                            :  hasCram && hasInstruct ? "Cramming + Instruction assignment from CS"
                                            :  hasPink    ? "Pink Sheet added by CS"
                                            :  hasCram    ? "Cramming assignment from CS is pending"
                                            :  hasInstruct? "Instruction assignment from CS is pending"
                                            :  "No assignments from CS");
                                        var attColor = (string?)null; // handled by animation class
                                        var audPendingStyle = s.IsPendingApproval ? "opacity:.4; pointer-events:none;" : "";
                                        <tr class="@rowClass home-pcs-row @rowBorderClass" style="@audPendingStyle"
                                            title="@attTooltip"
                                            @onclick="() => { if (!s.IsPendingApproval) OpenAuditorSession(s); }">
                                            <td class="home-pcs-pcname">
                                                @if (isNewPc)
                                                {
                                                    @if (s.IsPendingApproval)
                                                    {
                                                        <i class="ri-time-line me-1" style="opacity:.5;color:#f59e0b;"></i>
                                                    }
                                                    else
                                                    {
                                                        <i class="ri-user-line me-1" style="opacity:.5;"></i>
                                                    }
                                                    @s.PcName
                                                }
                                            </td>
                                            <td style="font-size:.78rem;color:#94a3b8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px;">@s.SessionName</td>
                                            <td class="home-pcs-date">@dateStr</td>
                                            <td class="home-pcs-dur">
                                                <i class="ri-time-line me-1" style="opacity:.4;"></i>@durStr
                                            </td>
                                            <td class="home-aud-st-cell">
                                                <span class="home-aud-st-badge @statusClass">@statusLabel</span>
                                                @if (s.IsSessionVerified) { <span class="home-approved-tick" title="Session approved by admin">✓</span> }
                                                @if (hasPink)    { <span class="home-att-chip home-att-chip-pink home-aud-att-pink">🩷 Pink</span> }
                                                @if (hasCram)    { <span class="home-att-chip home-att-chip-orange home-aud-att-orange">📙 Cram</span> }
                                                @if (hasInstruct){ <span class="home-att-chip home-att-chip-yellow home-aud-att-yellow">📋 Instr</span> }
                                            </td>
                                            <td style="font-size:.78rem;color:#64748b;">
                                                @(s.CsName ?? "—")
                                            </td>
                                            <td style="text-align:center;">
                                                <button class="home-pcs-cs-btn" style="background:#5c6bc0;"
                                                        title="Open PC Folder"
                                                        @onclick="() => OpenAuditorSession(s)">
                                                    <i class="ri-folder-open-line"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @if (!_isSolo)
            {
            @* ══════ WEEKLY OVERVIEW (collapsible) ══════ *@
            <div class="home-overview-header px-3 mt-1 mb-1 d-flex align-items-center flex-wrap gap-2">
                <div @onclick="() => _weeklyOverviewExpanded = !_weeklyOverviewExpanded"
                     style="display:flex;align-items:center;cursor:pointer;">
                    <i class="@(_weeklyOverviewExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                       style="font-size:1.1rem;"></i>
                    <i class="ri-calendar-check-line me-1"></i>
                    <strong>Weekly Overview</strong>
                </div>
                @if (!_isSolo)
                {
                    <div class="d-flex align-items-center gap-1 ms-2">
                        <button class="btn btn-sm home-nav-btn" @onclick="PrevWeek" title="@LS.T("common.prev")">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <span class="home-nav-week" style="font-size:.82rem; white-space:nowrap;">
                            <i class="ri-calendar-2-line me-1 opacity-75"></i>@DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
                        </span>
                        <button class="btn btn-sm home-nav-btn" @onclick="NextWeek" title="@LS.T("common.next")"
                                disabled="@(_weekStart >= DashboardService.GetWeekStart(MaxAllowedDate()))">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                    </div>
                }
                <div class="ms-auto d-flex align-items-center gap-2">
                    @if (!_isSolo && _weeklyOverviewExpanded)
                    {
                        <button class="btn btn-sm @(_hideEmpty?"home-filter-active":"home-filter-btn") d-flex align-items-center gap-1"
                                title="@(_hideEmpty?LS.T("home.showEmpty"):LS.T("home.hideEmpty"))"
                                @onclick="() => _hideEmpty = !_hideEmpty"
                                @onclick:stopPropagation="true"
                                style="font-size:.75rem;">
                            <i class="@(_hideEmpty?"ri-eye-line":"ri-eye-off-line")"></i>
                            @(_hideEmpty ? "Show empty PCs" : "Hide empty PCs")
                        </button>
                    }
                    <button class="btn btn-sm home-nav-btn" @onclick="PrintTable" title="@LS.T("common.print")"
                            @onclick:stopPropagation="true">
                        <i class="ri-printer-line me-1"></i>@LS.T("common.print")
                    </button>
                </div>
            </div>

            @if (_weeklyOverviewExpanded)
            {
            var _audPcs = AuditorPcs;

            @* ══════ AUDITOR TABLE ══════ *@
            @if (_audPcs.Count > 0 || _myPcs.Count == 0)
            {
                <div class="home-table-label px-3 mt-1 mb-1">
                    <i class="ri-user-line me-1"></i>@LS.T("home.aud")
                </div>
                <div id="week-table-scroll" class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _audPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        @* ── CS name row ── *@
                        <tr class="small" style="color:#495057; opacity:.85;">
                            <th style="min-width:110px;">@LS.T("home.csHeader")</th>
                            @foreach (var pc in _audPcs)
                            {
                                var csFullName   = _pcCsNames.TryGetValue(pc.PcId, out var cn) ? cn : "";
                                var csFirstName  = csFullName.Length > 0 ? csFullName.Split(' ')[0] : "NA";
                                var csColBlocked = _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center fw-normal user-select-none"
                                    style="@(csColBlocked ? "cursor:default;" : "cursor:context-menu;") position:relative;"
                                    @oncontextmenu="e => { if (!csColBlocked) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span title="@(csFullName.Length > 0 ? csFullName : "Unknown")">@csFirstName</span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                        @* ── Role row ── *@
                        @if (_audPcs.Any())
                        {
                            <tr class="table-light">
                                <th class="fw-semibold small py-1" style="color:#495057;">@LS.T("home.role")</th>
                                @foreach (var pc in _audPcs)
                                {
                                    var roleColBlocked = _unapprovedPcIds.Contains(pc.PcId);
                                    <th class="text-center py-1"
                                        style="@(roleColBlocked ? "opacity:.35; pointer-events:none;" : "")">
                                        <span class="badge bg-primary-transparent">@LS.T("home.aud")</span>
                                    </th>
                                }
                            </tr>
                        }
                        @* ── PC name row ── *@
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _audPcs)
                            {
                                var hasPendingCs   = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center user-select-none"
                                    style="@(isPendingApprv ? "cursor:not-allowed;" : "cursor:context-menu;") white-space:nowrap; min-width:90px;"
                                    @oncontextmenu="e => { if (!isPendingApprv) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@(isPendingApprv ? pc.FullName + " — " + LS.T("home.pendingApproval") : pc.FullName)"
                                          style="@(isPendingApprv
                                              ? "background:#f1f3f5; color:#868e96; border:1px solid #ced4da;"
                                              : hasPendingCs
                                                  ? "background:#fff3e0; color:#e65100; border:1px solid #ff9800;"
                                                  : "background:#e8f5e9; color:#2e7d32; border:1px solid #4caf50;")
                                                 font-weight:600; font-size:.85em; padding:.3em .75em;
                                                 @(isPendingApprv ? "opacity:0.6;" : "")">
                                        @if (isPendingApprv) { <i class="ri-time-line me-1" style="font-size:0.75em;"></i> }
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                </th>
                            }
                            @if (_myPcs.Count == 0)
                            {
                                <th class="text-muted fst-italic fw-normal">
                                    @LS.T("home.clickToBegin")
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="@(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @if (_myPcs.Count == 0)
                                {
                                    <td class="text-muted text-center small">—</td>
                                }
                                else
                                {
                                    @foreach (var pc in _audPcs)
                                    {
                                        var secs           = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                        var isSelected     = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                        var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                        <td class="text-center"
                                            style="@(isPendingApprv ? "opacity:.35;" : isFuture ? "opacity:.45;" : "")">
                                            @if (secs > 0)
                                            {
                                                <span>@DashboardService.Fmt(secs)</span>
                                            }
                                            else
                                            {
                                                <span style="opacity:.35;">-</span>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                    @if (_audPcs.Count > 0)
                    {
                        <tfoot class="table-light">
                            <tr style="color:#212529;">
                                <td><strong>Σ Week</strong></td>
                                @foreach (var pc in _audPcs)
                                {
                                    var total = Enumerable.Range(0, 7)
                                        .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                    <td class="text-center"><strong>@DashboardService.Fmt(total)</strong></td>
                                }
                            </tr>
                            @{
                                var audGrandTotal = _audPcs.Sum(pc => Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                            }
                            <tr style="background:linear-gradient(90deg,#1a237e 0%,#283593 100%) !important; color:#fff !important;">
                                <td class="fw-bold" style="letter-spacing:.03em;color:#fff;">Grand Total</td>
                                <td colspan="@_audPcs.Count" style="color:#fff;">
                                    <div class="d-flex align-items-center">
                                        <button type="button" class="btn btn-sm btn-light py-0 px-1 me-2"
                                                title="Scroll right" @onclick='() => ScrollWeekTable("right")'>
                                            <i class="ri-arrow-right-s-line"></i>
                                        </button>
                                        <div class="flex-grow-1 text-center">
                                            <span style="font-size:1.25rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                                @DashboardService.Fmt(audGrandTotal)
                                            </span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-light py-0 px-1"
                                                title="Scroll left" @onclick='() => ScrollWeekTable("left")'>
                                            <i class="ri-arrow-left-s-line"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole != "CS" && _selRole != "CSSolo")
                {
                    @DetailPanel
                }
            }

            @* ══════ CS SOLO TABLE ══════ *@
            var _csSoloPcs = CsSoloPcs;
            @if (_csSoloPcs.Count > 0)
            {
                <div class="home-table-label px-3 mt-3 mb-1" style="color:#ce93d8; font-weight:600; font-size:.85rem;">
                    <i class="ri-shield-star-line me-1"></i>CS Solo
                </div>
                <div class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _csSoloPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _csSoloPcs)
                            {
                                var hasPendingCs   = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center user-select-none"
                                    style="@(isPendingApprv ? "cursor:not-allowed;" : "cursor:context-menu;") white-space:nowrap; min-width:90px; position:relative;"
                                    @oncontextmenu="e => { if (!isPendingApprv) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@(isPendingApprv ? pc.FullName + " — " + LS.T("home.pendingApproval") : pc.FullName)"
                                          style="@(isPendingApprv
                                              ? "background:#f1f3f5; color:#868e96; border:1px solid #ced4da;"
                                              : hasPendingCs
                                                  ? "background:#f3e5f5; color:#6a1b9a; border:1px solid #ab47bc;"
                                                  : "background:#f3e5f5; color:#6a1b9a; border:1px solid #ce93d8;")
                                             font-weight:600; font-size:.82em; padding:.25em .6em;
                                             @(isPendingApprv ? "opacity:0.6;" : "")">
                                        @if (isPendingApprv) { <i class="ri-time-line me-1" style="font-size:0.75em;"></i> }
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="font-size:.82em; color:#ce93d8; @(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @foreach (var pc in _csSoloPcs)
                                {
                                    var secs       = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                    var isSelected = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                    var isPendingCs = _pendingCs.Contains((DashboardService.GKey(pc), dayIdx));
                                    var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                    <td class="text-center"
                                        style="@(isPendingApprv ? "opacity:.35;" : isFuture ? "opacity:.45;" : "") color:#ce93d8; font-size:.82em;">
                                        @if (secs > 0)
                                        {
                                            <span>
                                                @DashboardService.Fmt(secs)
                                                @if (isPendingCs)
                                                {
                                                    <span class="text-danger fw-bold ms-1" title="Pending CS review">*</span>
                                                }
                                            </span>
                                        }
                                        else if (isPendingCs)
                                        {
                                            <span class="text-danger fw-bold" title="Pending CS review">*</span>
                                        }
                                        else
                                        {
                                            <span style="opacity:.35;">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td style="font-size:.82em; color:#ce93d8;"><strong>Σ Week</strong></td>
                            @foreach (var pc in _csSoloPcs)
                            {
                                var total = Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                <td class="text-center" style="color:#ce93d8; font-size:.82em;">
                                    <strong>@DashboardService.Fmt(total)</strong>
                                </td>
                            }
                        </tr>
                        @{
                            var csSoloGrandTotal = _csSoloPcs.Sum(pc => Enumerable.Range(0, 7)
                                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                        }
                        <tr style="background:linear-gradient(90deg,#6a1b9a 0%,#8e24aa 100%) !important; color:#fff !important;">
                            <td class="fw-bold" style="letter-spacing:.03em; font-size:.85em;color:#fff;">CS Solo Total</td>
                            <td colspan="@_csSoloPcs.Count" style="color:#fff;">
                                <div class="text-center">
                                    <span style="font-size:1rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                        @DashboardService.Fmt(csSoloGrandTotal)
                                    </span>
                                </div>
                            </td>
                        </tr>
                    </tfoot>
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole == "CSSolo")
                {
                    @DetailPanel
                }
            }

            @* ══════ COMBINED GRAND TOTAL (Auditor + CS Solo) ══════ *@
            var combinedAudTotal = _audPcs.Sum(pc => Enumerable.Range(0, 7)
                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
            var combinedSoloTotal = _csSoloPcs.Sum(pc => Enumerable.Range(0, 7)
                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
            var combinedTotal = combinedAudTotal + combinedSoloTotal;
            @if (combinedTotal > 0)
            {
                <div class="px-3 mt-2 mb-1">
                    <div style="background:linear-gradient(90deg,#0d47a1 0%,#1565c0 100%); color:#fff;
                                padding:10px 16px; border-radius:6px; display:flex; align-items:center;">
                        <span class="fw-bold" style="letter-spacing:.03em;">Grand Total (Auditor + CS Solo)</span>
                        <span class="ms-auto" style="font-size:1.3rem; font-weight:700; letter-spacing:.04em;">
                            @DashboardService.Fmt(combinedTotal)
                        </span>
                    </div>
                </div>
            }

            @* ══════ CS TABLE ══════ *@
            var _csPcs = CsPcs;
            @if (_csPcs.Count > 0)
            {
                <div class="home-table-label home-table-label-cs px-3 mt-3 mb-1">
                    <i class="ri-briefcase-line me-1"></i>CS
                </div>
                <div class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _csPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        @* ── PC name row (no CS/Role rows needed — all are CS) ── *@
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _csPcs)
                            {
                                var hasPendingCs   = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center user-select-none"
                                    style="@(isPendingApprv ? "cursor:not-allowed;" : "cursor:context-menu;") white-space:nowrap; min-width:90px; position:relative;"
                                    @oncontextmenu="e => { if (!isPendingApprv) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@(isPendingApprv ? pc.FullName + " — " + LS.T("home.pendingApproval") : pc.FullName)"
                                          style="@(isPendingApprv
                                              ? "background:#f1f3f5; color:#868e96; border:1px solid #ced4da;"
                                              : hasPendingCs
                                                  ? "background:#fff3e0; color:#e65100; border:1px solid #ff9800;"
                                                  : "background:#e8f5e9; color:#2e7d32; border:1px solid #4caf50;")
                                             font-weight:600; font-size:.78em; padding:.25em .6em;
                                             @(isPendingApprv ? "opacity:0.6;" : "")">
                                        @if (isPendingApprv) { <i class="ri-time-line me-1" style="font-size:0.75em;"></i> }
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="font-size:.82em; @(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @foreach (var pc in _csPcs)
                                {
                                    var secs       = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                    var isSelected = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                    var isPendingCs = _pendingCs.Contains((DashboardService.GKey(pc), dayIdx));
                                    var isPendingApprv = _unapprovedPcIds.Contains(pc.PcId);
                                    <td class="text-center"
                                        style="@(isPendingApprv ? "opacity:.35;" : isFuture ? "opacity:.45;" : "") color:#adb5bd; font-size:.78em;">
                                        @if (secs > 0)
                                        {
                                            <span>
                                                @DashboardService.Fmt(secs)
                                                @if (isPendingCs)
                                                {
                                                    <span class="text-danger fw-bold ms-1" title="Pending CS review">*</span>
                                                }
                                            </span>
                                        }
                                        else if (isPendingCs)
                                        {
                                            <span class="text-danger fw-bold" title="Pending CS review">*</span>
                                        }
                                        else
                                        {
                                            <span style="opacity:.35;">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr style="color:#212529;">
                            <td style="font-size:.82em;"><strong>Σ Week</strong></td>
                            @foreach (var pc in _csPcs)
                            {
                                var total = Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                <td class="text-center" style="color:#adb5bd; font-size:.78em;">
                                    <strong>@DashboardService.Fmt(total)</strong>
                                </td>
                            }
                        </tr>
                        @{
                            var csGrandTotal = _csPcs.Sum(pc => Enumerable.Range(0, 7)
                                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                        }
                        <tr style="background:linear-gradient(90deg,#546e7a 0%,#78909c 100%) !important; color:#fff !important;">
                            <td class="fw-bold" style="letter-spacing:.03em; font-size:.85em;color:#fff;">CS Total</td>
                            <td colspan="@_csPcs.Count" style="color:#fff;">
                                <div class="text-center">
                                    <span style="font-size:1rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                        @DashboardService.Fmt(csGrandTotal)
                                    </span>
                                </div>
                            </td>
                        </tr>
                    </tfoot>
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole == "CS")
                {
                    @DetailPanel
                }
            }

            } @* end Weekly Overview *@

            @* ══════ WEEKLY REMARKS ══════ *@
            <div class="card mx-3 mt-3 mb-2">
                <div class="card-header py-2" style="background:rgba(63,81,181,0.15); color:#7986cb; font-size:.85rem; border-color:rgba(255,255,255,0.1);">
                    <i class="ri-edit-line me-1"></i>
                    <strong>@LS.T("home.weeklyRemarks")</strong>
                </div>
                <div class="card-body p-2" dir="auto">
                    <SpkRichEditor @key="_weekStart" Value="@_weekRemarks"
                                   ValueChanged="@(v => { _weekRemarks = v; _remarksSaved = false; })" />
                    <div class="d-flex align-items-center mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="SaveRemarks">
                            <i class="ri-save-line me-1"></i>@LS.T("common.save")
                        </button>
                        @if (_remarksSaved)
                        {
                            <span class="ms-2 small" style="color:#4ade80;">
                                <i class="ri-check-line"></i> @LS.T("common.saved")
                            </span>
                        }
                    </div>
                </div>
            </div>

            } @* end !_isSolo *@

        </div>

        @* ── Context menu ── *@
        @if (_showCtxMenu)
        {
            var ctxPc = _myPcs.FirstOrDefault(p => p.PcId == _ctxPcId && p.WorkCapacity == _ctxWorkCapacity);
            <div class="home-ctx-menu"
                 style="position:fixed; top:@(_ctxY)px; left:@(_ctxX)px; z-index:9999; min-width:170px;"
                 @onclick:stopPropagation="true">
                <div class="home-ctx-header">Options</div>
                <div class="list-group list-group-flush">
                    @if (CanOpenPcFolder(_ctxPcId))
                    {
                        <button class="list-group-item list-group-item-action py-2"
                                @onclick="() => OpenPcFolder(_ctxPcId)">
                            <i class="ri-folder-open-line me-2" style="color:#3b82f6;"></i>Open PC Folder
                        </button>
                    }
                    <button class="list-group-item list-group-item-action text-danger py-2"
                            @onclick="RemovePc">
                        <i class="ri-delete-bin-line me-2"></i>Remove PC
                    </button>
                </div>
            </div>
        }

        @* ── Weekly History Chart ── *@
        @if (_weeklyTotals.Count > 0)
        {
            <div class="card mx-3 mt-4 mb-3">
                <div class="card-header py-2 d-flex align-items-center gap-2"
                     style="background:linear-gradient(90deg,#1a237e 0%,#283593 100%); color:#fff;">
                    <strong class="fs-14">@LS.T("home.weeklyHoursTitle")</strong>
                    <span class="ms-auto small opacity-75">
                        @LS.T("home.total"): @DashboardService.Fmt(_weeklyTotals.Sum(w => w.TotalSeconds))
                    </span>
                </div>
                <div class="card-body py-1 px-2">
                    <ApexChart TItem="WeekTotal"
                               Options="@_chartOptions"
                               Height="220"
                               @key="_chartKey">
                        <ApexPointSeries TItem="WeekTotal"
                                         Items="@_weeklyTotals"
                                         Name="Hours"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(w => w.WeekLabel)"
                                         YValue="@(w => Math.Round((decimal)w.TotalSeconds / 3600m, 2))" />
                    </ApexChart>
                </div>
            </div>
        }

    }


</div>

<style>
    /* ── Nav bar ── */
    .home-nav-bar {
        background: linear-gradient(135deg, #0f2057 0%, #1a237e 55%, #283593 100%);
        color: #fff;
        box-shadow: 0 2px 12px rgba(26,35,126,.28);
        margin-bottom: 0.75rem;
    }
    .home-nav-week {
        font-weight: 600; font-size: .9rem; color: #fff; letter-spacing: .02em;
    }
    .home-nav-btn {
        background: rgba(255,255,255,.12); color: #fff;
        border: 1px solid rgba(255,255,255,.25); border-radius: 8px;
        transition: background .18s;
    }
    .home-nav-btn:hover, .home-nav-btn:focus { background: rgba(255,255,255,.22); color: #fff; border-color: rgba(255,255,255,.4); }
    .home-nav-btn:disabled { opacity: .4; color: #fff; }
    .home-nav-btn-accent {
        background: linear-gradient(135deg, #1565c0, #1e88e5);
        color: #fff; border: none; border-radius: 8px;
        box-shadow: 0 2px 8px rgba(21,101,192,.4);
        transition: box-shadow .18s, transform .18s;
    }
    .home-nav-btn-accent:hover { box-shadow: 0 4px 14px rgba(21,101,192,.55); transform: translateY(-1px); color: #fff; }
    .home-filter-btn {
        background: rgba(255,255,255,.1); color: rgba(255,255,255,.8);
        border: 1px solid rgba(255,255,255,.2);
    }
    .home-filter-btn:hover { background: rgba(255,255,255,.2); color: #fff; }
    .home-filter-active {
        background: rgba(255,255,255,.92); color: #1a237e;
        border: 1px solid rgba(255,255,255,.92); font-weight: 600;
    }
    .home-filter-active:hover { background: #fff; color: #1a237e; }
    .home-solo-btn {
        background: rgba(251,191,36,.15); color: #fbbf24;
        border: 1px solid rgba(251,191,36,.35); border-radius: 8px;
    }
    .home-solo-btn:hover { background: rgba(251,191,36,.25); color: #fbbf24; }
    .home-solo-active {
        background: #f59e0b; color: #fff; border: none; border-radius: 8px;
    }
    .home-solo-active:hover { background: #d97706; color: #fff; }

    /* ── Detail panel ── */
    .home-detail-card {
        border: none !important; border-radius: 14px !important; overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,.10);
    }
    .home-detail-header {
        background: linear-gradient(135deg, #1a237e 0%, #283593 55%, #3949ab 100%) !important;
        color: #fff !important; border-bottom: none;
    }
    .home-detail-header strong,
    .home-detail-header span,
    .home-detail-header i { color: #fff !important; }
    .home-role-badge {
        background: rgba(255,255,255,.22); color: #fff;
        font-weight: 600; border-radius: 20px; padding: .25em .7em;
    }

    /* ── Inline forms ── */
    .home-form-box {
        background: #f8faff; border: 1px solid #dde4f5;
        border-radius: 10px; padding: 12px 14px;
        color: #212529;
    }
    .home-form-box h6,
    .home-form-box .form-label,
    .home-form-box .form-check-label { color: #212529; }
    .home-form-box .form-control,
    .home-form-box .form-control-sm { color: #212529; background-color: #fff; border-color: #dee2e6; }
    .home-form-box .form-control::placeholder { color: #6c757d; }

    /* ── Context menu ── */
    .home-ctx-menu {
        background: #fff; border: none; border-radius: 12px; overflow: hidden;
        box-shadow: 0 8px 28px rgba(0,0,0,.16);
    }
    .home-ctx-header {
        font-size: .7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .08em; color: #9ca3af; padding: 8px 14px 4px;
    }
    .home-ctx-menu .list-group-item {
        border: none; padding: 9px 14px; font-size: .88rem; transition: background .15s;
    }
    .home-ctx-menu .list-group-item:hover { background: #f3f4f6; }
    .home-ctx-menu .list-group-item.text-danger:hover { background: #fff5f5; }


    .home-pc-item {
        padding: 10px 14px; cursor: pointer; font-size: .9rem;
        border-bottom: 1px solid #f3f4f6;
        transition: background .15s, color .15s;
        display: flex; align-items: center;
