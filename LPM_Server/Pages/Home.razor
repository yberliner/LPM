@code {

    string _displayName = "LP Management";
    string _username = "";
    string? _csNotifyKey;

    int?          _userId;
    bool          _isAuditor, _isCS;
    bool          _isSoloAuditor;
    bool          _isSolo;        // true = StaffRole is 'Solo' — always shows solo grid, no toggle
    PcInfo?       _soloSelf;
    DateOnly      _weekStart;
    List<PcInfo>   _myPcs  = [];
    HashSet<int>   _unapprovedPcIds = [];
    HashSet<int>   _soloPcIds = [];
    Dictionary<(int, int), int> _grid = [];
    Dictionary<string, string> _csStatusLabels = [];

    bool   _hideEmpty;

    bool HasWeekData(PcInfo pc) => Enumerable.Range(0, 7)
        .Any(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)) > 0
               || _pendingCs.Contains((DashboardService.GKey(pc), d)));

    List<PcInfo> AuditorPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "Auditor")
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();

    // CS-assigned PCs that are solo auditors — shown in the CS Solo table (negative GKey)
    List<PcInfo> CsSoloPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "CS" && _soloPcIds.Contains(pc.PcId))
        .Select(pc => pc with { WorkCapacity = "CSSolo" })
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();

    // All CS-assigned PCs — shown in the CS table (positive GKey)
    List<PcInfo> CsPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "CS")
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();
    HashSet<(int, int)>      _pendingCs   = [];
    Dictionary<int, string>  _pcCsNames   = [];
    List<DashboardService.PendingCsSession> _pendingCsSessions = [];
    bool _pendingCsExpanded = true;
    bool _weeklyOverviewExpanded = true;
    int  _csQueueDays = 7;
    bool _showDoneCs  = false;
    List<DashboardService.AuditorSessionStatus> _auditorStatuses = [];
    Dictionary<int, HashSet<string>> _audAttachTypes = new();
    bool _audStatusExpanded = true;
    int _audStatusDays = 7;
    string _pcsSortCol = "pc";   // "pc", "date", "dur"
    bool _pcsSortAsc = true;
    string _audSortCol = "pc";   // "pc", "date", "dur"
    bool _audSortAsc = true;

    int?       _selPcId;
    int?       _selDay;
    string     _selRole   = "Auditor";
    DayDetail? _detail;

    // Add Session form
    bool   _showAddSession;
    string _addDuration = "";
    string _addAdminMin = "0";
    bool   _addIsFree;
    string _addSummary  = "";
    string _addError    = "";

    // Add CS Review form
    bool   _showAddReview;
    int    _addReviewSessionId;
    string _addReviewDuration = "";
    string _addReviewNotes    = "";
    string _reviewError       = "";

    // Add General CS form
    bool   _showAddGeneralCs;
    string _addGeneralCsDuration = "";
    string _addGeneralCsNotes    = "";
    string _generalCsError       = "";

    // Edit Session form
    int?   _editSessionId;
    string _editDuration = "";
    string _editAdminMin = "0";
    bool   _editIsFree;
    string _editSummary  = "";
    string _editError    = "";

    // Context menu
    bool   _showCtxMenu;
    int    _ctxPcId;
    string _ctxWorkCapacity = "Auditor";
    double _ctxX, _ctxY;



    // Weekly remarks
    string _weekRemarks = "";
    bool   _remarksSaved;

    // Weekly history chart
    List<WeekTotal> _weeklyTotals = [];
    int _chartKey;
    ApexChartOptions<WeekTotal> _chartOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { ColumnWidth = "65%", BorderRadius = 4 } },
        Colors = new List<string> { "#3949ab" },
        Xaxis = new XAxis { Labels = new XAxisLabels { Rotate = -45, Style = new AxisLabelStyle { FontSize = "11px" } } },
        Grid = new Grid { BorderColor = "#e0e0e0" },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Labels = new YAxisLabels
                {
                    Formatter = "function(val){ var h=Math.floor(val); var m=Math.round((val-h)*60); return h+':'+String(m).padStart(2,'0'); }"
                }
            }
        },
        Tooltip = new Tooltip()
    };

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = auth.User.Identity?.Name ?? "";
        _username = username;
        _displayName = username.Length > 0
            ? char.ToUpper(username[0]) + username[1..]
            : "LP Management";

        var staffRole  = auth.User.FindFirst("StaffRole")?.Value ?? "None";
        _isSolo        = staffRole == "Solo";
        _userId = DashSvc.GetUserIdByUsername(username);
        if (_userId.HasValue)
        {
            _isAuditor     = DashSvc.IsAuditor(_userId.Value);
            _isCS          = DashSvc.IsCS(_userId.Value);
            _isSoloAuditor = _isSolo;
            if (_isSoloAuditor)
                _soloSelf = DashSvc.GetSoloAuditorInfo(_userId.Value);
        }
        _weekStart = TodayWeekStart;
        _csStatusLabels = DashSvc.GetCsStatusLabels();
        await RefreshAsync();

        // Subscribe to cross-user CS notifications
        if (_userId.HasValue)
        {
            _csNotifyKey = CsNotifySvc.Subscribe(_userId.Value, async pcId =>
            {
                await InvokeAsync(async () =>
                {
                    await RefreshAsync();
                    StateHasChanged();
                });
            });
        }
    }

    DotNetObjectReference<Home>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("lpmInitCsListener", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnCsDoneFromTab()
    {
        if (_isCS)
            _pendingCsSessions = DashSvc.GetPendingCsSessions(_userId!.Value, _csQueueDays, _showDoneCs);
        await RefreshAsync();
    }


    [JSInvokable]
    public async Task OnTabFocused()
    {
        if (!_isCS) return;
        var fresh = DashSvc.GetPendingCsSessions(_userId!.Value, _csQueueDays, _showDoneCs);
        if (fresh.Count != _pendingCsSessions.Count)
        {
            _pendingCsSessions = fresh;
            await RefreshAsync();
        }
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        if (_csNotifyKey != null)
            CsNotifySvc.Unsubscribe(_csNotifyKey);
    }

    DateOnly AllowedWeekStart => DashboardService.GetWeekStart(MaxAllowedDate());

    async Task RefreshAsync()
    {
        if (!_userId.HasValue) return;
        if (_isSolo && _soloSelf != null)
        {
            _myPcs        = [_soloSelf];
            _grid         = DashSvc.GetWeekGridSolo(_userId.Value, _weekStart);
            _weeklyTotals = DashSvc.GetWeeklyTotalsSolo(_userId.Value,
                                ChartLatestWeekStart(), 20);
            _detail = null; _selPcId = null; _selDay = null;
            _pendingCs = []; _pcCsNames = [];
        }
        else
        {
            _myPcs           = DashSvc.GetUserPcs(_userId.Value);
            _soloPcIds       = DashSvc.GetSoloPcIds();
            _unapprovedPcIds = DashSvc.GetUnapprovedPcIds(_userId.Value);
            _grid          = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
            _weeklyTotals  = DashSvc.GetWeeklyTotals(_userId.Value,
                                 ChartLatestWeekStart(),
                                 20, _myPcs);
            _detail = null; _selPcId = null; _selDay = null;

            RefreshCsMetadata();
        }

        if (_isCS)
            _pendingCsSessions = DashSvc.GetPendingCsSessions(_userId!.Value, _csQueueDays, _showDoneCs);

        if (_isAuditor || _isSolo)
        {
            _auditorStatuses = DashSvc.GetAuditorSessionStatuses(_userId.Value, _audStatusDays, isSolo: _isSolo);
            _audAttachTypes  = _auditorStatuses.ToDictionary(s => s.SessionId,
                                   s => FolderSvc.GetSessionAttachmentTypes(s.PcId, s.SessionName));
        }

        _weekRemarks = DashSvc.GetWeeklyRemarks(_userId.Value, _weekStart.ToString("yyyy-MM-dd")) ?? "";
        _remarksSaved = false;

        UpdateChartTooltip();
        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    async Task PrevWeek() { _weekStart = _weekStart.AddDays(-7); Console.WriteLine($"[Home] Navigated to week {_weekStart} by '{_username}'"); await RefreshAsync(); }
    async Task NextWeek()
    {
        var next = _weekStart.AddDays(7);
        if (next > DashboardService.GetWeekStart(MaxAllowedDate())) return;
        _weekStart = next;
        Console.WriteLine($"[Home] Navigated to week {_weekStart} by '{_username}'");
        await RefreshAsync();
    }

    // ── Future-date guard ──
    /// Server date + 1 day if server clock is past 14:00 (covers ≤10h timezone difference)
    static DateOnly MaxAllowedDate()
    {
        var now = DateTime.Now;
        var d   = DateOnly.FromDateTime(now);
        return now.Hour >= 14 ? d.AddDays(1) : d;
    }

    static bool IsFutureDate(DateOnly d) => d > MaxAllowedDate();

    void TrySelectCell(PcInfo pc, int dayIdx)
    {
        if (IsFutureDate(_weekStart.AddDays(dayIdx))) return;
        if (_unapprovedPcIds.Contains(pc.PcId)) return;
        SelectCell(pc, dayIdx);
    }

    // ── Role toggle ──
    Task SetPcRoleAud(int pcId) => SetPcRole(pcId, "Auditor");
    Task SetPcRoleCs(int pcId) => SetPcRole(pcId, "CS");

