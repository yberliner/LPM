@page "/Home"
@using System.Globalization
@using LPM.Services
@using LPM._Spk
@attribute [Authorize]
@inject DashboardService DashSvc
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject PdfService PdfService

<div @onclick="DismissMenu">

    @* ── Week navigation bar ── *@
    <div class="home-nav-bar d-flex align-items-center flex-wrap gap-2 px-3 py-2">
        <button class="btn btn-sm home-nav-btn" @onclick="PrevWeek">
            <i class="ri-arrow-left-s-line"></i> @LS.T("common.prev")
        </button>
        <span class="home-nav-week">
            <i class="ri-calendar-2-line me-1 opacity-75"></i>@DayLabel(_weekStart) – @DayLabel(_weekStart.AddDays(6))
        </span>
        <button class="btn btn-sm home-nav-btn" @onclick="NextWeek"
                disabled="@(_weekStart >= DashboardService.GetWeekStart(MaxAllowedDate()))">
            @LS.T("common.next") <i class="ri-arrow-right-s-line"></i>
        </button>
        <div class="d-flex align-items-center gap-2 ms-auto">
            <button class="btn btn-sm home-nav-btn" @onclick="PrintTable">
                <i class="ri-printer-line me-1"></i>@LS.T("common.print")
            </button>
            @if (!_soloMode)
            {
                <button class="btn btn-sm @(_hideEmpty?"home-filter-active":"home-filter-btn")"
                        title="@(_hideEmpty?LS.T("home.showEmpty"):LS.T("home.hideEmpty"))"
                        @onclick="() => _hideEmpty = !_hideEmpty">
                    <i class="@(_hideEmpty?"ri-eye-line":"ri-eye-off-line")"></i>
                </button>
            }
            @if (!_soloMode)
            {
                <button class="btn btn-sm home-nav-btn-accent" @onclick="ShowAddPcModal">
                    <i class="ri-add-line me-1"></i>@LS.T("home.addPC")
                </button>
            }
            @if (_auditorType == 3)
            {
                <button class="btn btn-sm @(_soloMode ? "home-solo-active" : "home-solo-btn")"
                        @onclick="ToggleSoloMode">
                    <i class="ri-user-line me-1"></i>@(_soloMode ? LS.T("home.solo") + " ✓" : LS.T("home.solo"))
                </button>
            }
        </div>
    </div>

    @if (_userId == null)
    {
        <div class="px-3 text-danger">@LS.T("home.userNotFound")</div>
    }
    else if (!_isAuditor && !_isCS && !_isSoloAuditor)
    {
        <div class="px-3 text-muted">@LS.T("home.noRole")</div>
    }
    else
    {
        @* ── Grids ── *@
        <div id="print-zone">

            @* ══════ AUDITOR TABLE ══════ *@
            @{ var _audPcs = AuditorPcs; }
            @if (_audPcs.Count > 0 || _myPcs.Count == 0)
            {
                <div class="home-table-label px-3 mt-1 mb-1">
                    <i class="ri-user-line me-1"></i>@LS.T("home.aud")
                </div>
                <div id="week-table-scroll" class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _audPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        @* ── CS name row ── *@
                        <tr class="small" style="color:#495057; opacity:.85;">
                            <th style="min-width:110px;">@LS.T("home.csHeader")</th>
                            @foreach (var pc in _audPcs)
                            {
                                var csFullName   = _pcCsNames.TryGetValue(pc.PcId, out var cn) ? cn : "";
                                var csFirstName  = csFullName.Length > 0 ? csFullName.Split(' ')[0] : "NA";
                                var csColBlocked = pc.WorkCapacity != "CSSolo" && _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center fw-normal user-select-none"
                                    style="@(csColBlocked ? "cursor:default;" : "cursor:context-menu;") position:relative;"
                                    @oncontextmenu="e => { if (!csColBlocked) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span title="@(csFullName.Length > 0 ? csFullName : "Unknown")">@csFirstName</span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                        @* ── Role row ── *@
                        @if (_audPcs.Any())
                        {
                            <tr class="table-light">
                                <th class="fw-semibold small py-1" style="color:#495057;">@LS.T("home.role")</th>
                                @foreach (var pc in _audPcs)
                                {
                                    var roleColBlocked = pc.WorkCapacity != "CSSolo" && _unapprovedPcIds.Contains(pc.PcId);
                                    <th class="text-center py-1"
                                        style="@(roleColBlocked ? "opacity:.35; pointer-events:none;" : "")">
                                        @if (pc.WorkCapacity == "Miscellaneous")
                                        {
                                            <span class="badge bg-secondary-transparent">@LS.T("home.other")</span>
                                        }
                                        else if (pc.WorkCapacity == "SoloAuditor")
                                        {
                                            <span class="badge bg-warning-transparent">@LS.T("home.solo")</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary-transparent">@LS.T("home.aud")</span>
                                        }
                                    </th>
                                }
                            </tr>
                        }
                        @* ── PC name row ── *@
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _audPcs)
                            {
                                var hasPendingCs   = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                var isPendingApprv = pc.WorkCapacity != "CSSolo" && _unapprovedPcIds.Contains(pc.PcId);
                                <th class="text-center user-select-none"
                                    style="@(isPendingApprv ? "cursor:not-allowed;" : "cursor:context-menu;") white-space:nowrap; min-width:90px;"
                                    @oncontextmenu="e => { if (!isPendingApprv) ShowCtxMenu(e, pc); }"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@(isPendingApprv ? pc.FullName + " — " + LS.T("home.pendingApproval") : pc.FullName)"
                                          style="@(isPendingApprv
                                              ? "background:#f1f3f5; color:#868e96; border:1px solid #ced4da;"
                                              : hasPendingCs
                                                  ? "background:#fff3e0; color:#e65100; border:1px solid #ff9800;"
                                                  : "background:#e8f5e9; color:#2e7d32; border:1px solid #4caf50;")
                                                 font-weight:600; font-size:.85em; padding:.3em .75em;
                                                 @(isPendingApprv ? "opacity:0.6;" : "")">
                                        @if (isPendingApprv) { <i class="ri-time-line me-1" style="font-size:0.75em;"></i> }
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                </th>
                            }
                            @if (_myPcs.Count == 0)
                            {
                                <th class="text-muted fst-italic fw-normal">
                                    @LS.T("home.clickToBegin")
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="@(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @if (_myPcs.Count == 0)
                                {
                                    <td class="text-muted text-center small">—</td>
                                }
                                else
                                {
                                    @foreach (var pc in _audPcs)
                                    {
                                        var secs           = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                        var isSelected     = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                        var isPendingApprv = pc.WorkCapacity != "CSSolo" && _unapprovedPcIds.Contains(pc.PcId);
                                        <td class="text-center @(isSelected && !isPendingApprv ? "table-primary fw-semibold" : "")"
                                            style="@(isPendingApprv ? "cursor:not-allowed; opacity:.35; pointer-events:none;" : isFuture ? "cursor:default; opacity:.45;" : "cursor:pointer;")"
                                            @onclick="() => { if (!isPendingApprv && !isFuture) TrySelectCell(pc, dayIdx); }">
                                            @if (secs > 0)
                                            {
                                                <span>@DashboardService.Fmt(secs)</span>
                                            }
                                            else
                                            {
                                                <span style="opacity:.35;">-</span>
                                            }
                                        </td>
                                    }
                                }
                            </tr>
                        }
                    </tbody>
                    @if (_audPcs.Count > 0)
                    {
                        <tfoot class="table-light">
                            <tr style="color:#212529;">
                                <td><strong>Σ Week</strong></td>
                                @foreach (var pc in _audPcs)
                                {
                                    var total = Enumerable.Range(0, 7)
                                        .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                    <td class="text-center"><strong>@DashboardService.Fmt(total)</strong></td>
                                }
                            </tr>
                            @{
                                var audGrandTotal = _audPcs.Sum(pc => Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                            }
                            <tr style="background:linear-gradient(90deg,#1a237e 0%,#283593 100%) !important; color:#fff !important;">
                                <td class="fw-bold" style="letter-spacing:.03em;color:#fff;">Grand Total</td>
                                <td colspan="@_audPcs.Count" style="color:#fff;">
                                    <div class="d-flex align-items-center">
                                        <button type="button" class="btn btn-sm btn-light py-0 px-1 me-2"
                                                title="Scroll right" @onclick='() => ScrollWeekTable("right")'>
                                            <i class="ri-arrow-right-s-line"></i>
                                        </button>
                                        <div class="flex-grow-1 text-center">
                                            <span style="font-size:1.25rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                                @DashboardService.Fmt(audGrandTotal)
                                            </span>
                                        </div>
                                        <button type="button" class="btn btn-sm btn-light py-0 px-1"
                                                title="Scroll left" @onclick='() => ScrollWeekTable("left")'>
                                            <i class="ri-arrow-left-s-line"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        </tfoot>
                    }
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole != "CS" && _selRole != "CSSolo")
                {
                    @DetailPanel
                }
            }

            @* ══════ CS SOLO TABLE ══════ *@
            @{ var _csSoloPcs = CsSoloPcs; }
            @if (_csSoloPcs.Count > 0)
            {
                <div class="home-table-label px-3 mt-3 mb-1" style="color:#ce93d8; font-weight:600; font-size:.85rem;">
                    <i class="ri-shield-star-line me-1"></i>CS Solo
                </div>
                <div class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _csSoloPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _csSoloPcs)
                            {
                                var hasPendingCs = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                <th class="text-center user-select-none"
                                    style="cursor:context-menu; white-space:nowrap; min-width:90px; position:relative;"
                                    @oncontextmenu="e => ShowCtxMenu(e, pc)"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@pc.FullName"
                                          style="@(hasPendingCs
                                              ? "background:#f3e5f5; color:#6a1b9a; border:1px solid #ab47bc;"
                                              : "background:#f3e5f5; color:#6a1b9a; border:1px solid #ce93d8;")
                                             font-weight:600; font-size:.82em; padding:.25em .6em;">
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="font-size:.82em; color:#ce93d8; @(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @foreach (var pc in _csSoloPcs)
                                {
                                    var secs       = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                    var isSelected = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                    var isPendingCs = _pendingCs.Contains((DashboardService.GKey(pc), dayIdx));
                                    <td class="text-center @(isSelected ? "table-primary fw-semibold" : "")"
                                        style="@(isFuture ? "cursor:default; opacity:.45;" : "cursor:pointer;") color:#ce93d8; font-size:.82em;"
                                        @onclick="() => { if (!isFuture) TrySelectCell(pc, dayIdx); }">
                                        @if (secs > 0)
                                        {
                                            <span>
                                                @DashboardService.Fmt(secs)
                                                @if (isPendingCs)
                                                {
                                                    <span class="text-danger fw-bold ms-1" title="Pending CS review">*</span>
                                                }
                                            </span>
                                        }
                                        else if (isPendingCs)
                                        {
                                            <span class="text-danger fw-bold" title="Pending CS review">*</span>
                                        }
                                        else
                                        {
                                            <span style="opacity:.35;">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td style="font-size:.82em; color:#ce93d8;"><strong>Σ Week</strong></td>
                            @foreach (var pc in _csSoloPcs)
                            {
                                var total = Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                <td class="text-center" style="color:#ce93d8; font-size:.82em;">
                                    <strong>@DashboardService.Fmt(total)</strong>
                                </td>
                            }
                        </tr>
                        @{
                            var csSoloGrandTotal = _csSoloPcs.Sum(pc => Enumerable.Range(0, 7)
                                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                        }
                        <tr style="background:linear-gradient(90deg,#6a1b9a 0%,#8e24aa 100%) !important; color:#fff !important;">
                            <td class="fw-bold" style="letter-spacing:.03em; font-size:.85em;color:#fff;">CS Solo Total</td>
                            <td colspan="@_csSoloPcs.Count" style="color:#fff;">
                                <div class="text-center">
                                    <span style="font-size:1rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                        @DashboardService.Fmt(csSoloGrandTotal)
                                    </span>
                                </div>
                            </td>
                        </tr>
                    </tfoot>
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole == "CSSolo")
                {
                    @DetailPanel
                }
            }

            @* ══════ COMBINED GRAND TOTAL (Auditor + CS Solo) ══════ *@
            @{
                var combinedAudTotal = _audPcs.Sum(pc => Enumerable.Range(0, 7)
                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                var combinedSoloTotal = _csSoloPcs.Sum(pc => Enumerable.Range(0, 7)
                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                var combinedTotal = combinedAudTotal + combinedSoloTotal;
            }
            @if (combinedTotal > 0)
            {
                <div class="px-3 mt-2 mb-1">
                    <div style="background:linear-gradient(90deg,#0d47a1 0%,#1565c0 100%); color:#fff;
                                padding:10px 16px; border-radius:6px; display:flex; align-items:center;">
                        <span class="fw-bold" style="letter-spacing:.03em;">Grand Total (Auditor + CS Solo)</span>
                        <span class="ms-auto" style="font-size:1.3rem; font-weight:700; letter-spacing:.04em;">
                            @DashboardService.Fmt(combinedTotal)
                        </span>
                    </div>
                </div>
            }

            @* ══════ CS TABLE ══════ *@
            @{ var _csPcs = CsPcs; }
            @if (_csPcs.Count > 0)
            {
                <div class="home-table-label home-table-label-cs px-3 mt-3 mb-1">
                    <i class="ri-briefcase-line me-1"></i>CS
                </div>
                <div class="table-responsive px-3 thick-scroll">
                <table class="table table-bordered table-hover table-sm mb-0" style="min-width:300px;">
                    <colgroup>
                        <col style="width:110px;" />
                        @foreach (var pc in _csPcs) { <col /> }
                    </colgroup>
                    <thead class="table-light">
                        @* ── PC name row (no CS/Role rows needed — all are CS) ── *@
                        <tr>
                            <th style="min-width:110px;color:#212529;">@LS.T("home.day")</th>
                            @foreach (var pc in _csPcs)
                            {
                                var hasPendingCs = Enumerable.Range(0, 7).Any(d => _pendingCs.Contains((DashboardService.GKey(pc), d)));
                                <th class="text-center user-select-none"
                                    style="cursor:context-menu; white-space:nowrap; min-width:90px; position:relative;"
                                    @oncontextmenu="e => ShowCtxMenu(e, pc)"
                                    @oncontextmenu:preventDefault="true">
                                    <span class="badge rounded-pill"
                                          title="@pc.FullName"
                                          style="@(hasPendingCs
                                              ? "background:#fff3e0; color:#e65100; border:1px solid #ff9800;"
                                              : "background:#e8f5e9; color:#2e7d32; border:1px solid #4caf50;")
                                             font-weight:600; font-size:.78em; padding:.25em .6em;">
                                        @pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75em;opacity:.7;"> (@pc.Nick)</span> }
                                    </span>
                                    <span style="position:absolute; top:1px; right:2px; line-height:1; cursor:pointer;
                                                 color:#aaa; font-size:11px; font-weight:700;"
                                          title="@LS.T("home.removeColumn")"
                                          @onclick="() => RemovePcDirectly(pc)"
                                          @onclick:stopPropagation="true">✕</span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @for (int d = 0; d < 7; d++)
                        {
                            var day    = _weekStart.AddDays(d);
                            var dayIdx = d;
                            var isFuture = day > MaxAllowedDate();
                            <tr>
                                <td class="text-nowrap" style="font-size:.82em; @(isFuture ? "opacity:.45;" : "")">@DayLabel(day)</td>
                                @foreach (var pc in _csPcs)
                                {
                                    var secs       = _grid.GetValueOrDefault((DashboardService.GKey(pc), dayIdx));
                                    var isSelected = _selPcId == pc.PcId && _selDay == dayIdx && _selRole == pc.WorkCapacity;
                                    var isPendingCs = _pendingCs.Contains((DashboardService.GKey(pc), dayIdx));
                                    <td class="text-center @(isSelected ? "table-primary fw-semibold" : "")"
                                        style="@(isFuture ? "cursor:default; opacity:.45;" : "cursor:pointer;") color:#adb5bd; font-size:.78em;"
                                        @onclick="() => { if (!isFuture) TrySelectCell(pc, dayIdx); }">
                                        @if (secs > 0)
                                        {
                                            <span>
                                                @DashboardService.Fmt(secs)
                                                @if (isPendingCs)
                                                {
                                                    <span class="text-danger fw-bold ms-1" title="Pending CS review">*</span>
                                                }
                                            </span>
                                        }
                                        else if (isPendingCs)
                                        {
                                            <span class="text-danger fw-bold" title="Pending CS review">*</span>
                                        }
                                        else
                                        {
                                            <span style="opacity:.35;">-</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr style="color:#212529;">
                            <td style="font-size:.82em;"><strong>Σ Week</strong></td>
                            @foreach (var pc in _csPcs)
                            {
                                var total = Enumerable.Range(0, 7)
                                    .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)));
                                <td class="text-center" style="color:#adb5bd; font-size:.78em;">
                                    <strong>@DashboardService.Fmt(total)</strong>
                                </td>
                            }
                        </tr>
                        @{
                            var csGrandTotal = _csPcs.Sum(pc => Enumerable.Range(0, 7)
                                .Sum(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d))));
                        }
                        <tr style="background:linear-gradient(90deg,#546e7a 0%,#78909c 100%) !important; color:#fff !important;">
                            <td class="fw-bold" style="letter-spacing:.03em; font-size:.85em;color:#fff;">CS Total</td>
                            <td colspan="@_csPcs.Count" style="color:#fff;">
                                <div class="text-center">
                                    <span style="font-size:1rem; font-weight:700; letter-spacing:.04em;color:#fff;">
                                        @DashboardService.Fmt(csGrandTotal)
                                    </span>
                                </div>
                            </td>
                        </tr>
                    </tfoot>
                </table>
                </div>

                @if (_selPcId.HasValue && _selDay.HasValue && _detail != null
                     && _selRole == "CS")
                {
                    @DetailPanel
                }
            }

            @* ══════ PENDING CS TABLE ══════ *@
            @if (_isCS && _pendingCsSessions.Count > 0)
            {
                <div class="card mx-3 mt-3 mb-2 home-pending-cs-card">
                    <div class="card-header py-2 home-pending-cs-header"
                         style="cursor:pointer;" @onclick="() => _pendingCsExpanded = !_pendingCsExpanded">
                        <i class="@(_pendingCsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"
                           style="font-size:1rem;"></i>
                        <i class="ri-clipboard-line me-1"></i>
                        <strong>Sessions Pending CS Review</strong>
                        <span class="home-pending-cs-badge">@_pendingCsSessions.Count</span>
                        <span style="margin-left:auto;font-size:.7rem;opacity:.6;">Last 10 days</span>
                    </div>
                    @if (_pendingCsExpanded)
                    {
                        <div class="card-body p-0">
                            <table class="table table-sm table-hover mb-0 home-pending-cs-table">
                                <thead>
                                    <tr>
                                        <th style="width:22%;" class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("pc")'>
                                            PC Name
                                            <i class="@PcsSortIcon("pc")"></i>
                                        </th>
                                        <th style="width:25%;">Session</th>
                                        <th style="width:16%;" class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("date")'>
                                            Date
                                            <i class="@PcsSortIcon("date")"></i>
                                        </th>
                                        <th style="width:12%;" class="home-pcs-sortable"
                                            @onclick='() => TogglePcsSort("dur")'>
                                            Duration
                                            <i class="@PcsSortIcon("dur")"></i>
                                        </th>
                                        <th style="width:10%;">Type</th>
                                        <th style="width:15%;text-align:center;">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        string? prevPcName = null;
                                        int pcGroupIdx = 0;
                                        var sorted = GetSortedPendingCs();
                                    }
                                    @foreach (var s in sorted)
                                    {
                                        var isNewPc = s.PcName != prevPcName;
                                        if (isNewPc) { pcGroupIdx++; prevPcName = s.PcName; }
                                        var rowClass = pcGroupIdx % 2 == 0 ? "home-pcs-row-even" : "home-pcs-row-odd";
                                        var totalMin = s.TotalSeconds / 60;
                                        var hrs = totalMin / 60;
                                        var mins = totalMin % 60;
                                        var durStr = hrs > 0 ? $"{hrs}h {mins:D2}m" : $"{mins}m";
                                        var dateStr = DateOnly.TryParse(s.SessionDate, out var d)
                                            ? d.ToString("dd/MM/yy") : s.SessionDate;
                                        <tr class="@rowClass home-pcs-row" @onclick="() => OpenPendingCs(s)">
                                            <td class="home-pcs-pcname">
                                                @if (isNewPc)
                                                {
                                                    <i class="ri-user-line me-1" style="opacity:.5;"></i>@s.PcName
                                                }
                                            </td>
                                            <td class="home-pcs-session">
                                                <i class="ri-file-text-line me-1" style="opacity:.4;"></i>
                                                @(string.IsNullOrEmpty(s.SessionName) ? "—" : s.SessionName)
                                            </td>
                                            <td class="home-pcs-date">@dateStr</td>
                                            <td class="home-pcs-dur">
                                                <i class="ri-time-line me-1" style="opacity:.4;"></i>@durStr
                                            </td>
                                            <td>
                                                @if (s.IsSolo)
                                                {
                                                    <span class="home-pcs-solo-badge">Solo</span>
                                                }
                                                else
                                                {
                                                    <span class="home-pcs-regular-badge">Regular</span>
                                                }
                                            </td>
                                            <td style="text-align:center;">
                                                <button class="home-pcs-cs-btn" title="Open CS for this session">
                                                    <i class="ri-eye-line me-1"></i>CS
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }

            @* ══════ WEEKLY REMARKS ══════ *@
            <div class="card mx-3 mt-3 mb-2">
                <div class="card-header py-2" style="background:rgba(63,81,181,0.15); color:#7986cb; font-size:.85rem; border-color:rgba(255,255,255,0.1);">
                    <i class="ri-edit-line me-1"></i>
                    <strong>@LS.T("home.weeklyRemarks")</strong>
                </div>
                <div class="card-body p-2" dir="auto">
                    <SpkRichEditor @key="_weekStart" Value="@_weekRemarks"
                                   ValueChanged="@(v => { _weekRemarks = v; _remarksSaved = false; })" />
                    <div class="d-flex align-items-center mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="SaveRemarks">
                            <i class="ri-save-line me-1"></i>@LS.T("common.save")
                        </button>
                        @if (_remarksSaved)
                        {
                            <span class="ms-2 small" style="color:#4ade80;">
                                <i class="ri-check-line"></i> @LS.T("common.saved")
                            </span>
                        }
                    </div>
                </div>
            </div>

        </div>

        @* ── Context menu ── *@
        @if (_showCtxMenu)
        {
            var ctxPc = _myPcs.FirstOrDefault(p => p.PcId == _ctxPcId && p.WorkCapacity == _ctxWorkCapacity);
            <div class="home-ctx-menu"
                 style="position:fixed; top:@(_ctxY)px; left:@(_ctxX)px; z-index:9999; min-width:170px;"
                 @onclick:stopPropagation="true">
                <div class="home-ctx-header">Options</div>
                <div class="list-group list-group-flush">
                    @if (_ctxWorkCapacity != "CSSolo")
                    {
                        @if (ctxPc?.WorkCapacity == "Miscellaneous")
                        {
                            <button class="list-group-item list-group-item-action py-2"
                                    @onclick="RemoveFromOthers">
                                <i class="ri-corner-up-left-line me-2 text-primary"></i>Remove from Others
                            </button>
                        }
                        else
                        {
                            <button class="list-group-item list-group-item-action py-2"
                                    @onclick="SetAsOther">
                                <i class="ri-shuffle-line me-2 text-secondary"></i>Set as Other
                            </button>
                        }
                    }
                    <button class="list-group-item list-group-item-action text-danger py-2"
                            @onclick="RemovePc">
                        <i class="ri-delete-bin-line me-2"></i>Remove PC
                    </button>
                </div>
            </div>
        }

        @* ── Weekly History Chart ── *@
        @if (_weeklyTotals.Count > 0)
        {
            <div class="card mx-3 mt-4 mb-3">
                <div class="card-header py-2 d-flex align-items-center gap-2"
                     style="background:linear-gradient(90deg,#1a237e 0%,#283593 100%); color:#fff;">
                    <strong class="fs-14">@LS.T("home.weeklyHoursTitle")</strong>
                    <span class="ms-auto small opacity-75">
                        @LS.T("home.total"): @DashboardService.Fmt(_weeklyTotals.Sum(w => w.TotalSeconds))
                    </span>
                </div>
                <div class="card-body py-1 px-2">
                    <ApexChart TItem="WeekTotal"
                               Options="@_chartOptions"
                               Height="220"
                               @key="_chartKey">
                        <ApexPointSeries TItem="WeekTotal"
                                         Items="@_weeklyTotals"
                                         Name="Hours"
                                         SeriesType="SeriesType.Bar"
                                         XValue="@(w => w.WeekLabel)"
                                         YValue="@(w => Math.Round((decimal)w.TotalSeconds / 3600m, 2))" />
                    </ApexChart>
                </div>
            </div>
        }

        @* ── Add-PC modal ── *@
        @if (_showAddPcModal)
        {
            <div class="modal show d-block" tabindex="-1"
                 style="background:rgba(0,0,0,.4);"
                 @onclick="() => _showAddPcModal = false">
                <div class="modal-dialog modal-dialog-centered"
                     @onclick:stopPropagation="true">
                    <div class="modal-content" style="background:#fff;color:#212529;">
                        <div class="modal-header py-2 home-modal-header">
                            <h5 class="modal-title fs-15 text-white">
                                <i class="ri-add-circle-line me-2"></i>@LS.T("home.addPcToDashboard")
                            </h5>
                            <button type="button" class="btn-close btn-close-white"
                                    @onclick="() => _showAddPcModal = false"></button>
                        </div>
                        <div class="modal-body">
                            @* ── Category selector ── *@
                            <div class="btn-group w-100 mb-3" role="group">
                                @if (_isAuditor)
                                {
                                    <button type="button"
                                            class="btn btn-sm @(_addPcCategory == "Auditor" ? "btn-primary" : "btn-outline-secondary")"
                                            @onclick='() => _addPcCategory = "Auditor"'>
                                        <i class="ri-user-line me-1"></i>Auditor
                                    </button>
                                }
                                @if (_isCS)
                                {
                                    <button type="button"
                                            class="btn btn-sm @(_addPcCategory == "CSSolo" ? "btn-purple" : "btn-outline-secondary")"
                                            style="@(_addPcCategory == "CSSolo" ? "background:#8e24aa; border-color:#8e24aa; color:#fff;" : "")"
                                            @onclick='() => _addPcCategory = "CSSolo"'>
                                        <i class="ri-shield-star-line me-1"></i>CS Solo
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm @(_addPcCategory == "CS" ? "btn-success" : "btn-outline-secondary")"
                                            @onclick='() => _addPcCategory = "CS"'>
                                        <i class="ri-briefcase-line me-1"></i>CS
                                    </button>
                                }
                            </div>
                            <input class="form-control mb-3" placeholder="Search..."
                                   @bind="_pcSearch" @bind:event="oninput" />
                            <div style="max-height:320px; overflow-y:auto;">
                                @{
                                    // Build set of PCs already in the user's list for this category
                                    var myPcSet   = _myPcs.Select(p => (p.PcId, p.WorkCapacity)).ToHashSet();
                                    var available = _allPcs
                                        .Where(p => !myPcSet.Contains((p.PcId, _addPcCategory)))
                                        .Where(p => string.IsNullOrEmpty(_pcSearch)
                                                    || p.FullName.Contains(_pcSearch, StringComparison.OrdinalIgnoreCase)
                                                    || p.Nick.Contains(_pcSearch, StringComparison.OrdinalIgnoreCase))
                                        .ToList();
                                    // Get PCs with pending solo CS reviews (PcId=AuditorId sessions without review)
                                    var pendingSoloPcIds = _addPcCategory == "CSSolo" ? GetPcIdsWithPendingSoloReviews() : new HashSet<int>();
                                    // Get PCs with pending regular CS reviews (PcId!=AuditorId sessions without review)
                                    var pendingRegularPcIds = _addPcCategory == "CS" ? GetPcIdsWithPendingRegularReviews() : new HashSet<int>();
                                }
                                @if (available.Count == 0)
                                {
                                    <p class="text-center" style="color:#6b7280;">No PCs available to add.</p>
                                }
                                @foreach (var pc in available)
                                {
                                    bool hasPending = (_addPcCategory == "CSSolo" && pendingSoloPcIds.Contains(pc.PcId))
                                                   || (_addPcCategory == "CS"     && pendingRegularPcIds.Contains(pc.PcId));
                                    <div class="home-pc-item"
                                         style="@(hasPending ? "background:#e8f5e9; border-left:3px solid #4caf50;" : "")"
                                         @onclick="() => AddPc(pc.PcId, _addPcCategory)">
                                        <i class="ri-user-line me-2 opacity-50"></i>@pc.FullName@if (!string.IsNullOrEmpty(pc.Nick)) { <span style="font-size:.75rem;color:#6b7280;opacity:.85;"> (@pc.Nick)</span> }
                                        @if (hasPending)
                                        {
                                            <span class="ms-auto badge bg-success" style="font-size:.7em;">pending</span>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }


</div>

<style>
    /* ── Nav bar ── */
    .home-nav-bar {
        background: linear-gradient(135deg, #0f2057 0%, #1a237e 55%, #283593 100%);
        color: #fff;
        box-shadow: 0 2px 12px rgba(26,35,126,.28);
        margin-bottom: 0.75rem;
    }
    .home-nav-week {
        font-weight: 600; font-size: .9rem; color: #fff; letter-spacing: .02em;
    }
    .home-nav-btn {
        background: rgba(255,255,255,.12); color: #fff;
        border: 1px solid rgba(255,255,255,.25); border-radius: 8px;
        transition: background .18s;
    }
    .home-nav-btn:hover, .home-nav-btn:focus { background: rgba(255,255,255,.22); color: #fff; border-color: rgba(255,255,255,.4); }
    .home-nav-btn:disabled { opacity: .4; color: #fff; }
    .home-nav-btn-accent {
        background: linear-gradient(135deg, #1565c0, #1e88e5);
        color: #fff; border: none; border-radius: 8px;
        box-shadow: 0 2px 8px rgba(21,101,192,.4);
        transition: box-shadow .18s, transform .18s;
    }
    .home-nav-btn-accent:hover { box-shadow: 0 4px 14px rgba(21,101,192,.55); transform: translateY(-1px); color: #fff; }
    .home-filter-btn {
        background: rgba(255,255,255,.1); color: rgba(255,255,255,.8);
        border: 1px solid rgba(255,255,255,.2);
    }
    .home-filter-btn:hover { background: rgba(255,255,255,.2); color: #fff; }
    .home-filter-active {
        background: rgba(255,255,255,.92); color: #1a237e;
