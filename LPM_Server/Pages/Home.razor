                    }
                    @if (sorted.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center" style="padding:16px;color:#64748b;font-size:.8rem;">
                            No sessions pending review for this period
                        </td></tr>
                    }
                    @foreach (var s in sorted)
                    {
                        var isNewPc = s.PcName != prevPc;
                        if (isNewPc) { grpIdx++; prevPc = s.PcName; }
                        var rowClass = grpIdx % 2 == 0 ? "home-pcs-row-even" : "home-pcs-row-odd";
                        var totalMin = s.TotalSeconds / 60;
                        var hrs = totalMin / 60;
                        var mins = totalMin % 60;
                        var durStr = hrs > 0 ? $"{hrs}h {mins:D2}m" : $"{mins}m";
                        var dateStr = DateOnly.TryParse(s.SessionDate, out var d) ? d.ToString("dd/MM/yy") : s.SessionDate;
