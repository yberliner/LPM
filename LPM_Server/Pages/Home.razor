        margin-top: -1px;
        height: 10px;
        overflow: hidden;
    }
    .solo-hero-badge {
        position: relative;
        z-index: 1;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        margin-top: 2px;
        padding: 2px 9px;
        font-size: .58rem;
        font-weight: 700;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: #c4b5fd;
        background: rgba(139,92,246,.1);
        border: 1px solid rgba(167,139,250,.18);
        border-radius: 999px;
        animation: soloBadgeFloat 4s ease-in-out infinite;
    }
    .solo-badge-dot {
        width: 4px; height: 4px;
        border-radius: 50%;
        background: #a78bfa;
        box-shadow: 0 0 4px 1px rgba(167,139,250,.5);
        animation: soloDotPulse 2s ease-in-out infinite;
    }

    @@keyframes soloNameShimmer {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    @@keyframes soloOrbDrift {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: .5; }
        50%      { transform: translate(5px, -3px) scale(1.08); opacity: .7; }
    }
    @@keyframes soloRingSpin {
        to { transform: rotate(360deg); }
    }
    @@keyframes soloBadgeFloat {
        0%, 100% { transform: translateY(0); }
        50%      { transform: translateY(-1.5px); }
    }
    @@keyframes soloDotPulse {
        0%, 100% { box-shadow: 0 0 3px 1px rgba(167,139,250,.4); opacity: .7; }
        50%      { box-shadow: 0 0 6px 2px rgba(167,139,250,.7); opacity: 1; }
    }

    /* ── Mobile Add Session button ── */
    .home-mobile-add-session {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 16px 24px;
        border-radius: 14px;
        border: none;
        min-height: 56px;
        overflow: hidden;
        cursor: pointer;
        background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 40%, #3b82f6 100%);
        box-shadow: 0 4px 20px rgba(37,99,235,.4),
                    0 0 0 0 rgba(59,130,246,0);
        animation: hmasPulse 3s ease-in-out infinite;
    }
    .home-mobile-add-session:active {
        transform: scale(0.96);
        animation: none;
        box-shadow: 0 2px 8px rgba(37,99,235,.3);
    }

    /* Shimmer sweep */
    .hmas-shimmer {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            105deg,
            transparent 30%,
            rgba(255,255,255,.15) 45%,
            rgba(255,255,255,.25) 50%,
            rgba(255,255,255,.15) 55%,
            transparent 70%
        );
        background-size: 250% 100%;
        animation: hmasShimmer 3.5s ease-in-out infinite;
        pointer-events: none;
    }

    /* Content row */
    .hmas-content {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #fff;
        z-index: 1;
    }
    .hmas-icon {
        font-size: 1.3rem;
        animation: hmasBounce 2.5s ease-in-out infinite;
    }
    .hmas-text {
        font-weight: 700;
        font-size: 1.05rem;
        letter-spacing: .03em;
    }
    .hmas-arrow {
        font-size: 1.1rem;
        opacity: .7;
        animation: hmasArrow 2s ease-in-out infinite;
    }

    /* Gentle glow pulse */
    @@keyframes hmasPulse {
        0%, 100% { box-shadow: 0 4px 20px rgba(37,99,235,.4), 0 0 0 0 rgba(59,130,246,0); }
        50%      { box-shadow: 0 6px 28px rgba(37,99,235,.5), 0 0 0 6px rgba(59,130,246,.12); }
    }

    /* Light sweep across button */
    @@keyframes hmasShimmer {
        0%, 100% { background-position: 150% 0; }
        50%      { background-position: -50% 0; }
    }

    /* Upload icon gentle bounce */
    @@keyframes hmasBounce {
        0%, 100% { transform: translateY(0); }
        40%      { transform: translateY(-3px); }
        60%      { transform: translateY(1px); }
    }

    /* Arrow nudge right */
    @@keyframes hmasArrow {
        0%, 100% { transform: translateX(0); opacity: .7; }
        50%      { transform: translateX(4px); opacity: 1; }
    }

    /* ── Mobile Open Folder button (Solo) ── */
    .home-mobile-open-folder {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 14px 24px;
        margin-top: 8px;
        border-radius: 14px;
        border: 1px solid rgba(139,92,246,.35);
        min-height: 52px;
        overflow: hidden;
        cursor: pointer;
        background: linear-gradient(135deg, #1e1046 0%, #2d1b69 40%, #4c1d95 100%);
        box-shadow: 0 4px 20px rgba(139,92,246,.3),
                    inset 0 1px 0 rgba(255,255,255,.08);
        animation: hmofBreath 4s ease-in-out infinite;
        transition: transform .15s, box-shadow .15s;
    }
    .home-mobile-open-folder:active {
        transform: scale(0.96);
        animation: none;
        box-shadow: 0 2px 8px rgba(139,92,246,.25);
    }

    .hmof-glow {
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse at 30% 50%, rgba(167,139,250,.2) 0%, transparent 60%);
        animation: hmofGlowMove 5s ease-in-out infinite;
        pointer-events: none;
    }

    .hmof-particles {
        position: absolute; inset: 0; pointer-events: none; overflow: hidden;
    }
    .hmof-particle {
        position: absolute;
        width: 3px; height: 3px;
        border-radius: 50%;
        background: rgba(196,181,253,.6);
        box-shadow: 0 0 6px 1px rgba(167,139,250,.4);
    }
    .hmof-particle:nth-child(1) {
        top: 25%; left: 15%;
        animation: hmofFloat 6s ease-in-out infinite;
    }
    .hmof-particle:nth-child(2) {
        top: 60%; left: 70%;
        animation: hmofFloat 5s ease-in-out 1.5s infinite;
    }
    .hmof-particle:nth-child(3) {
        top: 40%; left: 85%;
        animation: hmofFloat 7s ease-in-out 3s infinite;
    }

    .hmof-content {
        position: relative;
        display: flex;
        align-items: center;
        gap: 10px;
        color: #e9d5ff;
        z-index: 1;
    }
    .hmof-icon {
        font-size: 1.25rem;
        color: #c4b5fd;
        filter: drop-shadow(0 0 4px rgba(167,139,250,.5));
        animation: hmofIconPulse 3s ease-in-out infinite;
    }
    .hmof-text {
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: .03em;
        background: linear-gradient(90deg, #e9d5ff, #c4b5fd, #a78bfa, #c4b5fd, #e9d5ff);
        background-size: 200% 100%;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        animation: hmofTextShimmer 4s ease-in-out infinite;
    }
    .hmof-arrow {
        font-size: 1rem;
        color: #a78bfa;
        animation: hmofArrowDrift 2.5s ease-in-out infinite;
    }

    @@keyframes hmofBreath {
        0%, 100% { box-shadow: 0 4px 20px rgba(139,92,246,.3), inset 0 1px 0 rgba(255,255,255,.08); }
        50%      { box-shadow: 0 6px 30px rgba(139,92,246,.45), inset 0 1px 0 rgba(255,255,255,.12), 0 0 0 4px rgba(139,92,246,.08); }
    }
    @@keyframes hmofGlowMove {
        0%, 100% { background-position: 30% 50%; opacity: .6; }
        50%      { background-position: 70% 50%; opacity: 1; }
    }
    @@keyframes hmofFloat {
        0%, 100% { transform: translate(0, 0) scale(1); opacity: .4; }
        25%      { transform: translate(8px, -6px) scale(1.3); opacity: .8; }
        50%      { transform: translate(-4px, -10px) scale(1); opacity: .5; }
        75%      { transform: translate(6px, 4px) scale(1.2); opacity: .7; }
    }
    @@keyframes hmofIconPulse {
        0%, 100% { transform: scale(1); filter: drop-shadow(0 0 4px rgba(167,139,250,.5)); }
        50%      { transform: scale(1.08); filter: drop-shadow(0 0 8px rgba(167,139,250,.8)); }
    }
    @@keyframes hmofTextShimmer {
        0%, 100% { background-position: 0% 50%; }
        50%      { background-position: 100% 50%; }
    }
    @@keyframes hmofArrowDrift {
        0%, 100% { transform: translate(0, 0); opacity: .6; }
        50%      { transform: translate(3px, -3px); opacity: 1; }
    }

    /* ── Nav bar ── */
    .home-nav-bar {
        background: linear-gradient(135deg, #0f2057 0%, #1a237e 55%, #283593 100%);
