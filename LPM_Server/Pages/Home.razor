    .home-nav-btn:hover, .home-nav-btn:focus { background: rgba(255,255,255,.22); color: #fff; border-color: rgba(255,255,255,.4); }
    .home-nav-btn:disabled { opacity: .4; color: #fff; }
    .home-nav-btn-accent {
        background: linear-gradient(135deg, #1565c0, #1e88e5);
