    .home-done-toggle {
        font-size: .7rem; font-weight: 600; padding: 1px 9px; border-radius: 10px;
        border: 1px solid rgba(255,255,255,.2); background: rgba(255,255,255,.08);
        color: #94a3b8; cursor: pointer; transition: all .15s; white-space: nowrap;
    }
    .home-done-toggle:hover { background: rgba(255,255,255,.15); color: #e2e8f0; }
