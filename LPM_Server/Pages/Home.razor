    List<DashboardService.AuditorSessionStatus> GetSortedAudStatuses()
    {
        IEnumerable<DashboardService.AuditorSessionStatus> q = _auditorStatuses;
        q = _audSortCol switch
        {
            "date" => _audSortAsc
                ? q.OrderBy(s => DateOnly.TryParse(s.SessionDate, out var dt) ? dt : DateOnly.MinValue).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => DateOnly.TryParse(s.SessionDate, out var dt) ? dt : DateOnly.MinValue).ThenBy(s => s.PcName),
            "dur" => _audSortAsc
                ? q.OrderBy(s => s.TotalSeconds).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.TotalSeconds).ThenBy(s => s.PcName),
            _ => _audSortAsc
                ? q.OrderBy(s => s.PcName).ThenBy(s => s.SessionDate)
                : q.OrderByDescending(s => s.PcName).ThenBy(s => s.SessionDate),
        };
        return q.ToList();
    }

