    public void Dispose()
    {
        _refreshDebounce?.Cancel();
        _refreshDebounce?.Dispose();
        _dotNetRef?.Dispose();
        if (_csNotifyKey != null)
            CsNotifySvc.Unsubscribe(_csNotifyKey);
        if (_onDataChangedHandler != null) DashSvc.OnDataChanged -= _onDataChangedHandler;
    }

    DateOnly AllowedWeekStart => DashboardService.GetWeekStart(MaxAllowedDate());

    async Task RefreshAsync()
    {
        if (!_userId.HasValue) return;

        int uid = _userId.Value;

        if (_isSolo && _soloSelf != null)
        {
            // Solo path — all independent calls in parallel
            var chartStart = ChartLatestWeekStart();
            var weekKey    = _weekStart.ToString("yyyy-MM-dd");

            List<DashboardService.AuditorSessionStatus>? audStatuses = null;

            await Task.WhenAll(
                Task.Run(() => { _grid         = DashSvc.GetWeekGridSolo(uid, _weekStart); }),
                Task.Run(() => { _weeklyTotals = DashSvc.GetWeeklyTotalsSolo(uid, chartStart, 20); }),
                Task.Run(() => { _weekRemarks  = DashSvc.GetWeeklyRemarks(uid, weekKey) ?? ""; }),
                Task.Run(() => { audStatuses   = DashSvc.GetAuditorSessionStatuses(uid, _audStatusDays, isSolo: true); })
            );

            _myPcs           = [_soloSelf];
            _auditorStatuses = audStatuses ?? [];
            _pendingCs       = PendingCsMarkers.Empty(); _pcCsNames = [];

            // Attachment types per session — parallel
            var t_attachTasks = _auditorStatuses.Select(s =>
                Task.Run(() => (s.SessionId, Types: FolderSvc.GetSessionAttachmentTypes(s.PcId, s.SessionName)))
            ).ToList();
            if (t_attachTasks.Count > 0) await Task.WhenAll(t_attachTasks);
            _audAttachTypes = t_attachTasks.ToDictionary(t => t.Result.SessionId, t => t.Result.Types);
        }
        else
        {
            // ── Phase 1: independent calls ───────────────────────────────────
            var chartStart = ChartLatestWeekStart();
            var weekKey    = _weekStart.ToString("yyyy-MM-dd");

            var t_pcs        = Task.Run(() => DashSvc.GetUserPcs(uid));
            var t_solo       = Task.Run(() => DashSvc.GetSoloPcIds());
            var t_pcsWithCs  = Task.Run(() => DashSvc.GetPcIdsWithCsAssigned());
            var t_unapproved = Task.Run(() => DashSvc.GetUnapprovedPcIds(uid, _username));
            var t_remarks    = Task.Run(() => DashSvc.GetWeeklyRemarks(uid, weekKey) ?? "");
            var t_csQueue    = _isCS
                ? Task.Run(() => (IReadOnlyList<DashboardService.PendingCsSession>)DashSvc.GetPendingCsSessions(uid, _csQueueDays, _showDoneCs))
                : Task.FromResult<IReadOnlyList<DashboardService.PendingCsSession>>(_pendingCsSessions);
            var t_audStatus  = (_isAuditor || _isSolo)
                ? Task.Run(() => (IReadOnlyList<DashboardService.AuditorSessionStatus>)DashSvc.GetAuditorSessionStatuses(uid, _audStatusDays, isSolo: _isSolo))
                : Task.FromResult<IReadOnlyList<DashboardService.AuditorSessionStatus>>(_auditorStatuses);

            // Team CS Review: load staff list + all queues in parallel
            var t_teamStaff = _isSeniorCS
                ? Task.Run(() => DashSvc.GetCsStaffList(uid))
                : Task.FromResult(_teamCsStaff);

            await Task.WhenAll(t_pcs, t_solo, t_unapproved, t_remarks, t_csQueue, t_audStatus, t_teamStaff, t_pcsWithCs);

            _myPcs           = t_pcs.Result;
            _soloPcIds       = t_solo.Result;
            _pcsWithCs       = t_pcsWithCs.Result;
            _unapprovedPcIds = t_unapproved.Result;
            _weekRemarks     = t_remarks.Result;
            if (_isCS)                  _pendingCsSessions = t_csQueue.Result.ToList();
            if (_isSeniorCS)
            {
                _teamCsStaff = t_teamStaff.Result;
                var teamTasks = _teamCsStaff.Select(cs =>
                    Task.Run(() => (cs.PersonId, Queue: DashSvc.GetPendingCsSessions(cs.PersonId, _teamCsDays, _showTeamCsDone)))
                ).ToList();
                if (teamTasks.Count > 0) await Task.WhenAll(teamTasks);
                _teamCsQueues = teamTasks.ToDictionary(t => t.Result.PersonId, t => t.Result.Queue);
                // Ensure expand state entries exist for new staff
                foreach (var cs in _teamCsStaff)
                    _teamCsUserExpanded.TryAdd(cs.PersonId, true);
            }
            if (_isAuditor || _isSolo)  _auditorStatuses   = t_audStatus.Result.ToList();

            // ── Phase 2: calls that depend on _myPcs / _auditorStatuses ──────
            var auditorPcIds = _myPcs.Where(p => StaffRoles.IsAuditorCapacity(p.WorkCapacity)).Select(p => p.PcId).ToList();
            var weekStart    = _weekStart;
            var myPcsSnap    = _myPcs;

            var t_grid     = Task.Run(() => DashSvc.GetWeekGrid(uid, weekStart, myPcsSnap));
            var t_totals   = Task.Run(() => DashSvc.GetWeeklyTotals(uid, chartStart, 20, myPcsSnap));
            var t_csMarks  = Task.Run(() => DashSvc.GetPendingCsMarkers(uid, weekStart, myPcsSnap));
            var t_csNames  = Task.Run(() => DashSvc.GetLastCsNamesByPc(auditorPcIds));

            // Attachment types: parallel per session
            var audStatSnap  = _auditorStatuses;
            var t_attachTasks = audStatSnap.Select(s =>
                Task.Run(() => (s.SessionId, Types: FolderSvc.GetSessionAttachmentTypes(s.PcId, s.SessionName)))
            ).ToList();

            await Task.WhenAll(
                new Task[] { t_grid, t_totals, t_csMarks, t_csNames }
                    .Concat(t_attachTasks)
            );

            _grid         = t_grid.Result;
            _weeklyTotals = t_totals.Result;
            _pendingCs    = t_csMarks.Result;
            _pcCsNames    = t_csNames.Result;
            _audAttachTypes = t_attachTasks.ToDictionary(t => t.Result.SessionId, t => t.Result.Types);

            // Extra Effort grid (non-solo users only)
            var eff = EffortSvc.GetWeekEffortGridByPerson(uid, weekStart);
            _effortPcs  = eff.Pcs;
            _effortGrid = eff.Grid;
        }

        // Fetch question status for all visible sessions
        RefreshQuestions();

        _detail = null; _selPcId = null; _selDay = null;
        _remarksSaved = false;

        UpdateChartTooltip();
        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    void RefreshQuestions()
    {
        var ids = new HashSet<int>();
        foreach (var s in _pendingCsSessions) ids.Add(s.SessionId);
        foreach (var s in _auditorStatuses)   ids.Add(s.SessionId);
        foreach (var q in _teamCsQueues.Values)
            foreach (var s in q) ids.Add(s.SessionId);
        _sessionQuestions = ids.Count > 0
            ? QuestionSvc.GetQuestionsForSessions(ids.ToList())
            : new();
    }

