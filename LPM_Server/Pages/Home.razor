    RenderFragment CsQueueTable(List<DashboardService.PendingCsSession> sessions,
        string sortCol, bool sortAsc, Action<string> toggleSort, Func<string, string> sortIcon,
        int ctxOwnerId) => __builder =>
    {
        var sorted = SortCsSessions(sessions, sortCol, sortAsc);
