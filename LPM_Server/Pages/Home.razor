    async Task ConfirmMarkUndone()
    {
        if (_csCtxSession == null) return;
        _csCtxBusy  = true;
        _csCtxError = "";
        StateHasChanged();

        try
        {
            var sessionId = _csCtxSession.SessionId;
            if (DashSvc.IsCsReviewApproved(sessionId))
            {
                _csCtxError = "This review has been approved with salary data. It cannot be undone from here — use the Sessions admin page to manage approved reviews.";
                return;
            }
            var affected  = await Task.Run(() => DashSvc.DeleteCsReview(sessionId));
            if (affected != 1)
            {
                _csCtxError = $"Unexpected: {affected} row(s) deleted (expected 1). No change applied.";
                return;
            }
            CloseCsCtxMenu();
            if (_csCtxOwnerUserId > 0 && _teamCsQueues.ContainsKey(_csCtxOwnerUserId))
                _teamCsQueues[_csCtxOwnerUserId] = DashSvc.GetPendingCsSessions(_csCtxOwnerUserId, _teamCsDays, _showTeamCsDone);
            else
                _pendingCsSessions = DashSvc.GetPendingCsSessions(_userId!.Value, _csQueueDays, _showDoneCs);
        }
        catch (Exception ex)
        {
            _csCtxError = $"Error: {ex.Message}";
        }
        finally
        {
            _csCtxBusy = false;
            StateHasChanged();
        }
    }

