        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(59,130,246,.4);
    }
    .home-pcs-cs-btn::after {
        content: ''; position: absolute; top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.2), transparent);
        animation: csSessionShimmer 3s ease-in-out infinite;
    }
</style>

@code {

    string _displayName = "LP Management";

    int?          _userId;
    bool          _isAuditor, _isCS;
    bool          _isSoloAuditor;
    int           _auditorType;   // 0=InActive 1=RegularOnly 2=SoloOnly 3=RegularAndSolo
    bool          _soloMode;
    PcInfo?       _soloSelf;
    DateOnly      _weekStart;
    List<PcInfo>   _myPcs  = [];
    List<PcInfo>   _allPcs = [];
    HashSet<int>   _unapprovedPcIds = [];
    Dictionary<(int, int), int> _grid = [];

    bool   _hideEmpty;

    bool HasWeekData(PcInfo pc) => Enumerable.Range(0, 7)
        .Any(d => _grid.GetValueOrDefault((DashboardService.GKey(pc), d)) > 0
               || _pendingCs.Contains((DashboardService.GKey(pc), d)));

    List<PcInfo> AuditorPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "Auditor" || pc.WorkCapacity == "Miscellaneous" || pc.WorkCapacity == "SoloAuditor")
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();

    List<PcInfo> CsSoloPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "CSSolo")
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();

    List<PcInfo> CsPcs => _myPcs
        .Where(pc => pc.WorkCapacity == "CS")
        .Where(pc => !_hideEmpty || HasWeekData(pc))
        .ToList();
    HashSet<(int, int)>      _pendingCs   = [];
    Dictionary<int, string>  _pcCsNames   = [];
    List<DashboardService.PendingCsSession> _pendingCsSessions = [];
    bool _pendingCsExpanded = true;
    string _pcsSortCol = "pc";   // "pc", "date", "dur"
    bool _pcsSortAsc = true;

    int?       _selPcId;
    int?       _selDay;
    string     _selRole   = "Auditor";
    DayDetail? _detail;

    // Add Session form
    bool   _showAddSession;
    string _addDuration = "";
    string _addAdminMin = "0";
    bool   _addIsFree;
    string _addSummary  = "";
    string _addError    = "";

    // Add CS Review form
    bool   _showAddReview;
    int    _addReviewSessionId;
    string _addReviewDuration = "";
    string _addReviewNotes    = "";
    string _reviewError       = "";

    // Add General CS form
    bool   _showAddGeneralCs;
    string _addGeneralCsDuration = "";
    string _addGeneralCsNotes    = "";
    string _generalCsError       = "";

    // Edit Session form
    int?   _editSessionId;
    string _editDuration = "";
    string _editAdminMin = "0";
    bool   _editIsFree;
    string _editSummary  = "";
    string _editError    = "";

    // Edit CS Review form
    int?   _editReviewId;
    string _editRevDuration = "";
    string _editRevNotes    = "";
    string _editRevError    = "";

    // Context menu
    bool   _showCtxMenu;
    int    _ctxPcId;
    string _ctxWorkCapacity = "Auditor";
    double _ctxX, _ctxY;

    // Add-PC modal
    bool   _showAddPcModal;
    string _pcSearch = "";
    string _addPcCategory = "Auditor"; // "Auditor", "CSSolo", "CS"


    // Weekly remarks
    string _weekRemarks = "";
    bool   _remarksSaved;

    // Weekly history chart
    List<WeekTotal> _weeklyTotals = [];
    int _chartKey;
    ApexChartOptions<WeekTotal> _chartOptions = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false }, Background = "transparent" },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { ColumnWidth = "65%", BorderRadius = 4 } },
        Colors = new List<string> { "#3949ab" },
        Xaxis = new XAxis { Labels = new XAxisLabels { Rotate = -45, Style = new AxisLabelStyle { FontSize = "11px" } } },
        Grid = new Grid { BorderColor = "#e0e0e0" },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Labels = new YAxisLabels
                {
                    Formatter = "function(val){ var h=Math.floor(val); var m=Math.round((val-h)*60); return h+':'+String(m).padStart(2,'0'); }"
                }
            }
        },
        Tooltip = new Tooltip()
    };

    protected override async Task OnInitializedAsync()
    {
        var auth     = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = auth.User.Identity?.Name ?? "";
        _displayName = username.Length > 0
            ? char.ToUpper(username[0]) + username[1..]
            : "LP Management";

        _userId = DashSvc.GetUserIdByUsername(username);
        if (_userId.HasValue)
        {
            _auditorType   = DashSvc.GetAuditorType(_userId.Value);
            _isAuditor     = DashSvc.IsAuditor(_userId.Value);
            _isCS          = DashSvc.IsCS(_userId.Value);
            _isSoloAuditor = DashSvc.IsSoloAuditor(_userId.Value);
            if (_isSoloAuditor)
                _soloSelf = DashSvc.GetSoloAuditorInfo(_userId.Value);
            // SoloOnly (2) auto-enters solo mode; RegularAndSolo (3) starts in regular mode with toggle
            _soloMode = _auditorType == 2;
        }
        _weekStart = TodayWeekStart;
        await RefreshAsync();
    }

    DateOnly AllowedWeekStart => DashboardService.GetWeekStart(MaxAllowedDate());

    async Task RefreshAsync()
    {
        if (!_userId.HasValue) return;
        if (_soloMode && _soloSelf != null)
        {
            _myPcs        = [_soloSelf];
            _allPcs       = [];
            _grid         = DashSvc.GetWeekGridSolo(_userId.Value, _weekStart);
            _weeklyTotals = DashSvc.GetWeeklyTotalsSolo(_userId.Value,
                                ChartLatestWeekStart(), 20);
            _detail = null; _selPcId = null; _selDay = null;
            _pendingCs = []; _pcCsNames = [];
        }
        else
        {
            _myPcs           = DashSvc.GetUserPcs(_userId.Value);
            _allPcs          = DashSvc.GetAllPcs();
            _unapprovedPcIds = DashSvc.GetUnapprovedPcIds(_userId.Value);
            _grid          = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
            _weeklyTotals  = DashSvc.GetWeeklyTotals(_userId.Value,
                                 ChartLatestWeekStart(),
                                 20, _myPcs);
            _detail = null; _selPcId = null; _selDay = null;

            RefreshCsMetadata();
        }

        if (_isCS)
            _pendingCsSessions = DashSvc.GetPendingCsSessions();

        _weekRemarks = DashSvc.GetWeeklyRemarks(_userId.Value, _weekStart.ToString("yyyy-MM-dd")) ?? "";
        _remarksSaved = false;

        UpdateChartTooltip();
        _chartKey++;
        await InvokeAsync(StateHasChanged);
    }

    async Task PrevWeek() { _weekStart = _weekStart.AddDays(-7); await RefreshAsync(); }
    async Task NextWeek()
    {
        var next = _weekStart.AddDays(7);
        if (next > DashboardService.GetWeekStart(MaxAllowedDate())) return;
        _weekStart = next;
        await RefreshAsync();
    }

    // ── Future-date guard ──
    /// Server date + 1 day if server clock is past 14:00 (covers ≤10h timezone difference)
    static DateOnly MaxAllowedDate()
    {
        var now = DateTime.Now;
        var d   = DateOnly.FromDateTime(now);
        return now.Hour >= 14 ? d.AddDays(1) : d;
    }

    static bool IsFutureDate(DateOnly d) => d > MaxAllowedDate();

    void TrySelectCell(PcInfo pc, int dayIdx)
    {
        if (IsFutureDate(_weekStart.AddDays(dayIdx))) return;
        if (pc.WorkCapacity != "CSSolo" && _unapprovedPcIds.Contains(pc.PcId)) return;
        SelectCell(pc, dayIdx);
    }

    // ── Role toggle ──
    Task SetPcRoleAud(int pcId) => SetPcRole(pcId, "Auditor");
    Task SetPcRoleCs(int pcId) => SetPcRole(pcId, "CS");

    async Task SetPcRole(int pcId, string role)
    {
        DashSvc.SetUserPcRole(_userId!.Value, pcId, role);
        _myPcs = DashSvc.GetUserPcs(_userId.Value);
        _grid  = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);

        RefreshCsMetadata();

        if (_selPcId == pcId && _selRole != "CSSolo") ClearSelection();

        await InvokeAsync(StateHasChanged);
    }

    async Task ToggleSoloMode()
    {
        _soloMode = !_soloMode;
        _detail = null; _selPcId = null; _selDay = null;
        await RefreshAsync();
    }

    HashSet<int> GetPcIdsWithPendingSoloReviews() => DashSvc.GetPcIdsWithPendingSoloReviews();
    HashSet<int> GetPcIdsWithPendingRegularReviews() => DashSvc.GetPcIdsWithPendingRegularReviews();

    void RefreshCsMetadata()
    {
        _pendingCs = DashSvc.GetPendingCsMarkers(_userId!.Value, _weekStart, _myPcs);
        _pcCsNames = DashSvc.GetLastCsNamesByPc(
            _myPcs.Where(p => p.WorkCapacity != "Miscellaneous" && p.WorkCapacity != "CSSolo").Select(p => p.PcId).ToList());
    }

    static DateOnly TodayWeekStart => DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));

    string AudBtnClass(PcInfo pc) =>
        pc.WorkCapacity == "Auditor" ? "btn-sm btn-primary" : "btn-sm btn-outline-secondary";
    string CsBtnClass(PcInfo pc) =>
        pc.WorkCapacity == "CS" ? "btn-sm btn-success" : "btn-sm btn-outline-secondary";

    // ── Context menu ──
    void ShowCtxMenu(MouseEventArgs e, PcInfo pc)
    {
        _showCtxMenu      = true;
        _ctxPcId          = pc.PcId;
        _ctxWorkCapacity  = pc.WorkCapacity;
        _ctxX             = e.ClientX;
        _ctxY             = e.ClientY;
    }

    void DismissMenu() => _showCtxMenu = false;

    async Task RemovePc()
    {
        DashSvc.RemoveUserPc(_userId!.Value, _ctxPcId, _ctxWorkCapacity);
        _showCtxMenu = false;
        await RefreshAsync();
    }

    async Task RemovePcDirectly(PcInfo pc)
    {
        DashSvc.RemoveUserPc(_userId!.Value, pc.PcId, pc.WorkCapacity);
        await RefreshAsync();
    }

    // ── Edit Session ──
    void OpenEditSession(SessionRow s)
    {
        _editSessionId = s.SessionId;
        _editDuration  = SecsToHMM(s.LengthSec);
        _editAdminMin  = (s.AdminSec / 60).ToString();
        _editIsFree    = s.IsFree;
        _editSummary   = s.Summary ?? "";
        _editError     = "";
    }

    void CancelEditSession() { _editSessionId = null; _editError = ""; }

    void SaveEditSession()
    {
        int secs = ParseTime(_editDuration);
        if (secs <= 0) { _editError = "Invalid duration — use H:MM (e.g. 1:30)."; return; }
        if (!int.TryParse(_editAdminMin, out int adminMin) || adminMin < 0) { _editError = "Invalid admin time."; return; }
        DashSvc.UpdateSession(_editSessionId!.Value, secs, adminMin * 60, _editIsFree,
            string.IsNullOrWhiteSpace(_editSummary) ? null : _editSummary);
        _editSessionId = null;
        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay!.Value), _selRole);
        _grid = _soloMode
            ? DashSvc.GetWeekGridSolo(_userId.Value, _weekStart)
            : DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        _pendingCs = _soloMode ? [] : DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);
        _weeklyTotals = _soloMode
            ? DashSvc.GetWeeklyTotalsSolo(_userId.Value, ChartLatestWeekStart(), 20)
            : DashSvc.GetWeeklyTotals(_userId.Value, ChartLatestWeekStart(), 20, _myPcs);
        _chartKey++;
    }

    // ── CS The Session ──
    async Task OnCsTheSession(int sessionId, string? sessionName)
    {
        if (!_selPcId.HasValue) return;
        var url = $"/PcFolder/{_selPcId.Value}?sessionId={sessionId}";
        if (!string.IsNullOrWhiteSpace(sessionName))
            url += $"&file={Uri.EscapeDataString(sessionName)}";
        await JS.InvokeVoidAsync("pcfOpenTab", url);
    }

    // ── Pending CS table ──
    async Task OpenPendingCs(DashboardService.PendingCsSession s)
    {
        var url = $"/PcFolder/{s.PcId}?sessionId={s.SessionId}";
        if (!string.IsNullOrWhiteSpace(s.SessionName))
            url += $"&file={Uri.EscapeDataString(s.SessionName)}";
        await JS.InvokeVoidAsync("pcfOpenTab", url);
    }

    void TogglePcsSort(string col)
    {
        if (_pcsSortCol == col) _pcsSortAsc = !_pcsSortAsc;
        else { _pcsSortCol = col; _pcsSortAsc = true; }
    }

    string PcsSortIcon(string col)
    {
        if (_pcsSortCol != col) return "ri-arrow-up-down-line" + " home-pcs-sort-idle";
        return _pcsSortAsc ? "ri-arrow-up-s-line home-pcs-sort-active" : "ri-arrow-down-s-line home-pcs-sort-active";
    }

    List<DashboardService.PendingCsSession> GetSortedPendingCs()
    {
        IEnumerable<DashboardService.PendingCsSession> q = _pendingCsSessions;
        q = _pcsSortCol switch
        {
            "date" => _pcsSortAsc
                ? q.OrderBy(s => s.SessionDate).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.SessionDate).ThenBy(s => s.PcName),
            "dur" => _pcsSortAsc
                ? q.OrderBy(s => s.TotalSeconds).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.TotalSeconds).ThenBy(s => s.PcName),
            _ => _pcsSortAsc
                ? q.OrderBy(s => s.PcName).ThenBy(s => s.SessionDate)
                : q.OrderByDescending(s => s.PcName).ThenBy(s => s.SessionDate),
        };
        return q.ToList();
    }

    // ── Edit CS Review ──
    void OpenEditReview(CsReviewRow rev)
    {
        _editReviewId    = rev.CsReviewId;
        _editRevDuration = SecsToHMM(rev.ReviewSec);
        _editRevNotes    = rev.Notes ?? "";
        _editRevError    = "";
    }

    void CancelEditReview() { _editReviewId = null; _editRevError = ""; }

    void SaveEditReview()
    {
        int secs = ParseTime(_editRevDuration);
        if (secs <= 0) { _editRevError = "Invalid duration — use H:MM (e.g. 0:30)."; return; }
        DashSvc.UpdateCsReview(_editReviewId!.Value, secs, "Pending",
            string.IsNullOrWhiteSpace(_editRevNotes) ? null : _editRevNotes);
        _editReviewId = null;
        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay!.Value), _selRole);
        _grid = _soloMode
            ? DashSvc.GetWeekGridSolo(_userId.Value, _weekStart)
            : DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        _pendingCs = _soloMode ? [] : DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);
        _weeklyTotals = _soloMode
            ? DashSvc.GetWeeklyTotalsSolo(_userId.Value, ChartLatestWeekStart(), 20)
            : DashSvc.GetWeeklyTotals(_userId.Value, ChartLatestWeekStart(), 20, _myPcs);
        _chartKey++;
    }

    static string SecsToHMM(int secs) => $"{secs / 3600}:{(secs % 3600) / 60:00}";

    void SetAsOther()
    {
        // Solo columns cannot be set to Other — they are always CS
        if (_ctxWorkCapacity == "CSSolo") { _showCtxMenu = false; return; }
        DashSvc.SetUserPcRole(_userId!.Value, _ctxPcId, "Miscellaneous");
        _showCtxMenu = false;
        _myPcs = DashSvc.GetUserPcs(_userId.Value);
        _grid  = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        RefreshCsMetadata();
        if (_selPcId == _ctxPcId && _selRole != "CSSolo") ClearSelection();
    }

    void RemoveFromOthers()
    {
        DashSvc.SetUserPcRole(_userId!.Value, _ctxPcId, "Auditor");
        _showCtxMenu = false;
        _myPcs = DashSvc.GetUserPcs(_userId.Value);
        _grid  = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        RefreshCsMetadata();
        if (_selPcId == _ctxPcId && _selRole != "CSSolo") ClearSelection();
    }

    void SaveRemarks()
    {
        if (!_userId.HasValue) return;
        DashSvc.SaveWeeklyRemarks(_userId.Value, _weekStart.ToString("yyyy-MM-dd"), _weekRemarks);
        _remarksSaved = true;
    }

    async Task PrintTable()
    {
        var pdfBytes = PdfService.GenerateWeeklyTablePdf(_displayName, _weekStart, _myPcs, _grid, _pcCsNames, _weekRemarks);

        var fileName = $"Week_{_weekStart:yyyy_MM_dd}.pdf";
        await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(pdfBytes));
    }

    // ── Add-PC modal ──
    void ShowAddPcModal()
    {
        _showAddPcModal = true;
        _pcSearch = "";
        // Default to the first available category the user can use
        _addPcCategory = _isAuditor ? "Auditor" : _isCS ? "CSSolo" : "Auditor";
    }

    async Task AddPc(int pcId, string workCapacity = "Auditor")
    {
        DashSvc.AddUserPc(_userId!.Value, pcId, workCapacity);
        // For regular (non-CSSolo) PCs added as Auditor, check permission
        if (workCapacity == "Auditor") DashSvc.CheckOrRequestPermission(_userId!.Value, pcId);
        _showAddPcModal = false;
        _pcSearch = "";
        await RefreshAsync();
    }

    // ── Cell selection ──
    void SelectCell(PcInfo pc, int dayIdx)
    {
        _selPcId   = pc.PcId;
        _selDay    = dayIdx;
        _selRole   = pc.WorkCapacity;
        _detail    = DashSvc.GetDayDetail(_userId!.Value, pc.PcId, _weekStart.AddDays(dayIdx), _selRole);
        _showAddSession   = false;
        _showAddReview    = false;
        _showAddGeneralCs = false;
        _addError         = "";
        _reviewError      = "";
        _generalCsError   = "";
        _editSessionId    = null;
        _editReviewId     = null;
    }

    RenderFragment DetailPanel => __builder =>
    {
        var selPcName = _myPcs.FirstOrDefault(p => p.PcId == _selPcId!.Value)?.FullName ?? "";
        var selDate   = _weekStart.AddDays(_selDay!.Value);
        var roleLabel = _selRole switch {
            "CS"           => "CS",
            "CSSolo"       => "CS Solo",
            "Miscellaneous"=> "Other",
            "SoloAuditor"  => "Solo",
            _              => "Auditor"
        };

        <div class="card mx-3 mt-3 mb-3 home-detail-card" @onclick:stopPropagation="true">
            <div class="card-header home-detail-header d-flex align-items-center gap-2 py-2">
                <i class="ri-layout-grid-line opacity-75"></i>
                <strong>@selPcName</strong>
                <span class="opacity-60">—</span>
                <span>@DayLabel(selDate)</span>
                <span class="badge home-role-badge ms-1">@roleLabel</span>
                <button class="btn-close btn-close-white ms-auto" title="Close" @onclick="ClearSelection"></button>
            </div>
            <div class="card-body py-2">

                @if (_selRole != "CS" && _selRole != "CSSolo")
                {
                    @* ── Auditor view: own sessions ── *@
                    @if (_detail!.Sessions.Count == 0)
                    {
                        <p class="text-muted mb-2 small">No sessions recorded for this day.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-2">
                            @foreach (var s in _detail.Sessions)
                            {
                                var audSessionTime = !string.IsNullOrEmpty(s.CreatedAt) && s.CreatedAt.Contains(' ')
                                    ? s.CreatedAt.Split(' ')[1][..5]
                                    : "";
                                <li class="mb-1">
                                    @if (_editSessionId == s.SessionId)
                                    {
                                        <div class="home-form-box">
                                            <div class="row g-2 align-items-center mb-2">
                                                <div class="col-auto">
                                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                                    <input class="form-control form-control-sm" style="width:90px;"
                                                           @bind="_editDuration" @bind:event="oninput" />
                                                </div>
                                                <div class="col-auto">
                                                    <label class="form-label mb-0 small">@LS.T("home.adminMin")</label>
                                                    <input class="form-control form-control-sm" style="width:70px;" type="number" min="0"
                                                           @bind="_editAdminMin" />
                                                </div>
                                                <div class="col-auto d-flex align-items-end pb-1">
                                                    <div class="form-check mb-0">
                                                        <input class="form-check-input" type="checkbox" id="chkEditFree" @bind="_editIsFree" />
                                                        <label class="form-check-label small" for="chkEditFree">@LS.T("home.free")</label>
                                                    </div>
                                                </div>
                                                <div class="col-auto ms-auto">
                                                    <button class="btn btn-sm btn-primary" @onclick="SaveEditSession">@LS.T("common.save")</button>
                                                    <button class="btn btn-sm btn-link text-danger" @onclick="CancelEditSession">@LS.T("common.cancel")</button>
                                                </div>
                                            </div>
                                            <div class="mb-1">
                                                <label class="form-label mb-1 small">@LS.T("home.summary")</label>
                                                <SpkRichEditor Value="@_editSummary" ValueChanged="@(v => _editSummary = v)" />
                                            </div>
                                            @if (!string.IsNullOrEmpty(_editError))
                                            {
                                                <div class="text-danger small mt-1">@_editError</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center flex-wrap gap-2">
                                            @if (!string.IsNullOrEmpty(audSessionTime))
                                            {
                                                <span class="text-muted small">
                                                    <i class="ri-time-line"></i> @audSessionTime
                                                </span>
                                            }
                                            @if (!string.IsNullOrEmpty(s.AuditorName))
                                            {
                                                <span class="fw-semibold small" style="color:#a78bfa;">
                                                    <i class="ri-user-line me-1"></i>@s.AuditorName
                                                </span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(s.Name))
                                            {
                                                <span class="badge rounded-pill" style="background:#ede9fe;color:#5b21b6;font-size:.72rem;">
                                                    <i class="ri-file-text-line me-1"></i>@s.Name
                                                </span>
                                            }
                                            <span class="badge bg-primary-transparent fs-12">
                                                @DashboardService.Fmt(s.LengthSec)
                                            </span>
                                            @if (s.AdminSec > 0)
                                            {
                                                <span class="text-muted small">
                                                    (@LS.T("home.admin"): @DashboardService.Fmt(s.AdminSec))
                                                </span>
                                            }
                                            @if (s.IsFree)
                                            {
                                                <span class="badge bg-warning-transparent">@LS.T("home.free")</span>
                                            }
                                            @{ var sessionApproved = s.VerifiedStatus == "Approved"; }
                                            <button class="btn btn-link btn-sm py-0 px-1 ms-auto" style="font-size:0.75rem;"
                                                    title="@(sessionApproved ? LS.T("home.cannotEditApproved") : LS.T("home.editSession"))"
                                                    disabled="@sessionApproved"
                                                    @onclick="() => OpenEditSession(s)">
                                                <i class="ri-edit-line"></i> @LS.T("common.edit")
                                            </button>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(s.Summary))
                                        {
                                            <div class="text-muted small mt-1">@((MarkupString)s.Summary)</div>
                                        }
                                    }
                                </li>
                            }
                        </ul>
                    }

                    @* Add Session / Misc Entry button and form *@
                    @if (!_showAddSession)
                    {
                        <button class="btn btn-sm home-nav-btn-accent"
                                @onclick="OpenAddSession">
                            <i class="ri-add-line me-1"></i>@(_selRole == "Miscellaneous" ? LS.T("home.addMiscEntry") : LS.T("home.addSession"))
                        </button>
                    }
                    else
                    {
                        <div class="home-form-box mt-2">
                            <h6 class="mb-2">@(_selRole == "Miscellaneous" ? LS.T("home.addMiscEntry") : LS.T("home.addSession"))</h6>
                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:90px;" placeholder="1:30"
                                           @bind="_addDuration" @bind:event="oninput" />
                                </div>
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.adminMin")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:70px;" type="number" min="0"
                                           @bind="_addAdminMin" />
                                </div>
                                <div class="col-auto d-flex align-items-end pb-1">
                                    <div class="form-check mb-0">
                                        <input class="form-check-input" type="checkbox"
                                               id="chkFree" @bind="_addIsFree" />
                                        <label class="form-check-label small" for="chkFree">@LS.T("home.free")</label>
                                    </div>
                                </div>
                                <div class="col-auto ms-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SaveSession">@LS.T("common.save")</button>
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="CancelAddSession">@LS.T("common.cancel")</button>
                                </div>
                            </div>
                            <div class="mb-1">
                                <label class="form-label mb-1 small">@LS.T("home.summary")</label>
                                <SpkRichEditor Value="@_addSummary" ValueChanged="@(v => _addSummary = v)" />
                            </div>
                            @if (!string.IsNullOrEmpty(_addError))
                            {
                                <div class="text-danger small mt-1">@_addError</div>
                            }
                        </div>
                    }
                }
                else
                {
                    @* ── CS view: all sessions (read-only) with review status ── *@
                    @if (_detail!.Sessions.Count == 0)
                    {
                        <p class="text-muted mb-2 small">No sessions recorded for this day.</p>
                    }
                    else
                    {
                        <ul class="list-unstyled mb-2">
                            @foreach (var s in _detail.Sessions)
                            {
                                var rev = _detail.Reviews.FirstOrDefault(r => r.SessionId == s.SessionId);
                                var sessionTime = !string.IsNullOrEmpty(s.CreatedAt) && s.CreatedAt.Contains(' ')
                                    ? s.CreatedAt.Split(' ')[1][..5]
                                    : "";
                                <li class="mb-2 border rounded p-2">
                                    <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
                                        @if (!string.IsNullOrEmpty(sessionTime))
                                        {
                                            <span class="text-muted small">
                                                <i class="ri-time-line"></i> @sessionTime
                                            </span>
                                        }
                                        <span class="fw-semibold small" style="color:#a78bfa;">
                                            <i class="ri-user-line me-1"></i>@s.AuditorName
                                        </span>
                                        @if (!string.IsNullOrWhiteSpace(s.Name))
                                        {
                                            <span class="badge rounded-pill" style="background:#ede9fe;color:#5b21b6;font-size:.72rem;">
                                                <i class="ri-file-text-line me-1"></i>@s.Name
                                            </span>
                                        }
                                        <span class="badge bg-primary-transparent fs-12">
                                            @DashboardService.Fmt(s.LengthSec)
                                        </span>
                                        @if (s.AdminSec > 0)
                                        {
                                            <span class="text-muted small">
                                                (@LS.T("home.admin"): @DashboardService.Fmt(s.AdminSec))
                                            </span>
                                        }
                                        @if (s.IsFree)
                                        {
                                            <span class="badge bg-warning-transparent">@LS.T("home.free")</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(s.Summary))
                                        {
                                            <div class="text-muted small mt-1">@((MarkupString)s.Summary)</div>
                                        }
                                    </div>
                                    <div class="mt-1 mb-1">
                                        <button class="btn btn-sm home-cs-session-btn"
                                                @onclick="() => OnCsTheSession(s.SessionId, s.Name)">
                                            <i class="ri-folder-open-line me-1"></i>CS The Session
                                        </button>
                                    </div>
                                    @if (rev != null)
                                    {
                                        @if (_editReviewId == rev.CsReviewId)
                                        {
                                            <div class="home-form-box mt-1">
                                                <div class="row g-2 align-items-center mb-2">
                                                    <div class="col-auto">
                                                        <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                                        <input class="form-control form-control-sm" style="width:90px;"
                                                               @bind="_editRevDuration" @bind:event="oninput" />
                                                    </div>
                                                    <div class="col-auto ms-auto">
                                                        <button class="btn btn-sm btn-primary" @onclick="SaveEditReview">@LS.T("common.save")</button>
                                                        <button class="btn btn-sm btn-link text-danger" @onclick="CancelEditReview">@LS.T("common.cancel")</button>
                                                    </div>
                                                </div>
                                                <div class="mb-1">
                                                    <label class="form-label mb-1 small">@LS.T("home.notes")</label>
                                                    <SpkRichEditor Value="@_editRevNotes" ValueChanged="@(v => _editRevNotes = v)" />
                                                </div>
                                                @if (!string.IsNullOrEmpty(_editRevError))
                                                {
                                                    <div class="text-danger small mt-1">@_editRevError</div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="d-flex align-items-center flex-wrap gap-2 small">
                                                <i class="ri-checkbox-circle-line text-success"></i>
                                                <span class="fw-semibold small" style="color:#4ade80;">
                                                    <i class="ri-user-star-line me-1"></i>@_displayName
                                                </span>
                                                <span class="badge bg-success-transparent">
                                                    @DashboardService.Fmt(rev.ReviewSec)
                                                </span>
                                                <span>@rev.Status</span>
                                                <button class="btn btn-link btn-sm py-0 px-1 ms-auto" style="font-size:0.75rem;"
                                                        title="@(rev.Status == "Approved" ? LS.T("home.cannotEditReviewApproved") : LS.T("home.editReview"))"
                                                        disabled="@(rev.Status == "Approved")"
                                                        @onclick="() => OpenEditReview(rev)">
                                                    <i class="ri-edit-line"></i> @LS.T("common.edit")
                                                </button>
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(rev.Notes))
                                            {
                                                <div class="text-muted small mt-1">@((MarkupString)rev.Notes)</div>
                                            }
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success rounded-pill px-3 py-0 mt-1"
                                                @onclick="() => StartAddReview(s.SessionId, s.LengthSec + s.AdminSec)">
                                            <i class="ri-add-line me-1"></i>@LS.T("home.csReview")
                                        </button>
                                    }
                                </li>
                            }
                        </ul>
                    }

                    @* Add CS Review form *@
                    @if (_showAddReview)
                    {
                        <div class="home-form-box mt-2">
                            <h6 class="mb-2">@LS.T("home.addCsReview") (Session #@_addReviewSessionId)</h6>
                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:90px;" placeholder="0:30"
                                           @bind="_addReviewDuration" @bind:event="oninput" />
                                </div>
                                <div class="col-auto ms-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SaveReview">@LS.T("common.save")</button>
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="CancelAddReview">@LS.T("common.cancel")</button>
                                </div>
                            </div>
                            <div class="mb-1">
                                <label class="form-label mb-1 small">@LS.T("home.notes")</label>
                                <SpkRichEditor Value="@_addReviewNotes" ValueChanged="@(v => _addReviewNotes = v)" />
                            </div>
                            @if (!string.IsNullOrEmpty(_reviewError))
                            {
                                <div class="text-danger small mt-1">@_reviewError</div>
                            }
                        </div>
                    }

                    @* ── General CS Work ── *@
                    <hr class="my-3" />
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="ri-briefcase-line text-info"></i>
                        <span class="fw-semibold small" style="color:#5eead4;">@LS.T("home.generalCsWork")</span>
                    </div>
                    @if (_detail.GeneralWork != null && _detail.GeneralWork.Count > 0)
                    {
                        <ul class="list-unstyled mb-2">
                            @foreach (var w in _detail.GeneralWork)
                            {
                                <li class="mb-1 d-flex align-items-center gap-2">
                                    <span class="badge bg-info-transparent fs-12">
                                        @DashboardService.Fmt(w.LengthSec)
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(w.Notes))
                                    {
                                        <div class="text-muted small mt-1">@((MarkupString)w.Notes)</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small mb-1">No general CS work recorded.</p>
                    }

                    @if (!_showAddGeneralCs)
                    {
                        <button class="btn btn-sm btn-outline-info rounded-pill px-3"
                                @onclick="OpenAddGeneralCs">
                            <i class="ri-add-line me-1"></i>General CS
                        </button>
                    }
                    else
                    {
                        <div class="home-form-box mt-2">
                            <h6 class="mb-2">@LS.T("home.addGeneralCsWork")</h6>
                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:90px;" placeholder="0:30"
                                           @bind="_addGeneralCsDuration" @bind:event="oninput" />
                                </div>
                                <div class="col-auto ms-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SaveGeneralCs">@LS.T("common.save")</button>
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="CancelAddGeneralCs">@LS.T("common.cancel")</button>
                                </div>
                            </div>
                            <div class="mb-1">
                                <label class="form-label mb-1 small">@LS.T("home.notes")</label>
                                <SpkRichEditor Value="@_addGeneralCsNotes" ValueChanged="@(v => _addGeneralCsNotes = v)" />
                            </div>
                            @if (!string.IsNullOrEmpty(_generalCsError))
                            {
                                <div class="text-danger small mt-1">@_generalCsError</div>
                            }
                        </div>
                    }
                }

            </div>
        </div>
    };

    void ClearSelection() { _selPcId = null; _selDay = null; _detail = null; }

    // ── Add Session ──
    void OpenAddSession()   { _showAddSession = true;  _addError = ""; }
    void CancelAddSession() { _showAddSession = false; _addError = ""; }

    void SaveSession()
    {
        int secs = ParseTime(_addDuration);
        if (secs <= 0) { _addError = "Invalid duration — use H:MM (e.g. 1:30)."; return; }
        if (!int.TryParse(_addAdminMin, out int adminMin) || adminMin < 0)
        {
            _addError = "Invalid admin time.";
            return;
        }

        if (_selRole == "Miscellaneous")
            DashSvc.AddMiscCharge(
                _userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);
        else if (_selRole == "SoloAuditor")
            DashSvc.AddSoloSession(
                _userId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);
        else
            DashSvc.AddSession(
                _userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);

        _showAddSession = false;
        _addDuration = ""; _addAdminMin = "0"; _addIsFree = false;
        _addSummary = ""; _addError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay ?? 0), _selRole);
        _grid = _soloMode
            ? DashSvc.GetWeekGridSolo(_userId.Value, _weekStart)
            : DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        _pendingCs = _soloMode ? [] : DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);
        RefreshWeeklyTotals();
    }

    // ── Add CS Review ──
    void StartAddReview(int sessionId, int sessionLengthSec)
    {
        _addReviewSessionId  = sessionId;
        _addReviewDuration   = DashboardService.FmtOrBlank(sessionLengthSec);
        _showAddReview       = true;
        _reviewError         = "";
    }

    void CancelAddReview() { _showAddReview = false; _reviewError = ""; }

    // ── Add General CS ──
    void OpenAddGeneralCs()   { _showAddGeneralCs = true;  _generalCsError = ""; }
    void CancelAddGeneralCs() { _showAddGeneralCs = false; _generalCsError = ""; }

    void SaveGeneralCs()
    {
        int secs = ParseTime(_addGeneralCsDuration);
        if (secs <= 0) { _generalCsError = "Invalid duration — use H:MM (e.g. 0:30)."; return; }

        DashSvc.AddCsWork(
            _userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay!.Value),
            secs,
            string.IsNullOrWhiteSpace(_addGeneralCsNotes) ? null : _addGeneralCsNotes);

        _showAddGeneralCs = false;
        _addGeneralCsDuration = ""; _addGeneralCsNotes = ""; _generalCsError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay ?? 0), _selRole);
        _grid = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        RefreshWeeklyTotals();
    }

    void SaveReview()
    {
        int secs = ParseTime(_addReviewDuration);
        if (secs <= 0) { _reviewError = "Invalid duration — use H:MM (e.g. 0:30)."; return; }

        try
        {
            DashSvc.AddCsReview(
                _userId!.Value, _addReviewSessionId, secs, "Pending",
                string.IsNullOrWhiteSpace(_addReviewNotes) ? null : _addReviewNotes);
        }
        catch (Exception ex) when (ex.Message.Contains("UNIQUE"))
        {
            _reviewError = "A CS review already exists for this session.";
            return;
        }

        _showAddReview = false;
        _addReviewDuration = "";
        _addReviewNotes = ""; _reviewError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value), _selRole);

        _grid = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);

        // ✅ NEW: recompute pending markers so "*" disappears immediately when done
        _pendingCs = DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);

        RefreshWeeklyTotals();
        StateHasChanged();
    }

    void UpdateChartTooltip()
    {
        var sb = new System.Text.StringBuilder("[");
        for (int i = 0; i < _weeklyTotals.Count; i++)
        {
            if (i > 0) sb.Append(',');
            sb.Append('[');
            var pcs = _weeklyTotals[i].TopPcs ?? [];
            for (int j = 0; j < pcs.Count; j++)
            {
                if (j > 0) sb.Append(',');
                var name = pcs[j].FullName.Replace("\\", "\\\\").Replace("'", "\\'");
                sb.Append($"['{name}',{pcs[j].Seconds}]");
            }
            sb.Append(']');
        }
        sb.Append(']');
        var data = sb.ToString();

        var fn =
            "function(opts){" +
            "var d=" + data + ";" +
            "var idx=opts.dataPointIndex;" +
            "var t=opts.series[0][idx];" +
            "var pcs=d[idx]||[];" +
            "var th=Math.floor(t);" +
            "var tm=Math.round((t-th)*60);" +
            "var r='<div style=\"padding:10px 14px;min-width:220px;font-family:inherit;background:#fff;" +
                    "border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.14)\">';" +
            "r+='<div style=\"font-weight:700;font-size:.93rem;color:#1a237e;" +
                    "border-bottom:1px solid #c5cae9;padding-bottom:5px;margin-bottom:8px\">" +
                    "Total: '+th+':'+String(tm).padStart(2,'0')+'</div>';" +
            "if(pcs.length){" +
            "r+='<div style=\"font-size:.7rem;color:#adb5bd;text-transform:uppercase;" +
                    "letter-spacing:.7px;margin-bottom:5px\">Top PCs</div>';" +
            "for(var i=0;i<pcs.length;i++){" +
            "var ph=Math.floor(pcs[i][1]/3600);" +
            "var pm=Math.floor((pcs[i][1]%3600)/60);" +
            "r+='<div style=\"display:flex;justify-content:space-between;gap:20px;padding:3px 6px;" +
                    "border-radius:4px;background:'+(i%2===0?'#f3f4fb':'transparent')+'\">';" +
            "r+='<span style=\"color:#212529;font-size:.82rem\">'+pcs[i][0]+'</span>';" +
            "r+='<span style=\"color:#3949ab;font-weight:700;font-size:.82rem\">'+" +
                    "ph+':'+String(pm).padStart(2,'0')+'</span>';" +
            "r+='</div>';}" +
            "}" +
            "r+='</div>';return r;}";

        _chartOptions.Tooltip = new Tooltip { Custom = fn };
    }

    void RefreshWeeklyTotals()
    {
        _weeklyTotals = _soloMode
            ? DashSvc.GetWeeklyTotalsSolo(_userId!.Value,
                  ChartLatestWeekStart(), 20)
            : DashSvc.GetWeeklyTotals(_userId!.Value,
                  ChartLatestWeekStart(), 20, _myPcs);
        UpdateChartTooltip();
        _chartKey++;
    }

    // ── Helpers ──
    static int ParseTime(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return 0;

        input = input.Trim();

        // If user typed only minutes (e.g. "45")
        if (!input.Contains(':'))
        {
            if (!int.TryParse(input, out int minutes) || minutes < 0) return 0;
            return minutes * 60;
        }

        // If user typed H:MM or HH:MM
        var parts = input.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 2) return 0;

        if (!int.TryParse(parts[0], out int hours) || hours < 0) return 0;
        if (!int.TryParse(parts[1], out int minutesPart) || minutesPart < 0 || minutesPart > 59) return 0;

        return (hours * 3600) + (minutesPart * 60);
    }

    static string DayLabel(DateOnly d) =>
        d.ToString("ddd dd/MM", CultureInfo.InvariantCulture);

    async Task ScrollWeekTable(string dir)
    {
        await JS.InvokeVoidAsync("scrollToEdge", "week-table-scroll", dir);
    }

    DateOnly ChartLatestWeekStart()
    {
        var thisWeek = TodayWeekStart;
        var nextWeek = thisWeek.AddDays(7);

        // Only show next week if something exists there
        var hasNextWeek =
            _soloMode
                ? DashSvc.HasAnyWorkInWeek(_userId!.Value, nextWeek, _myPcs, soloMode: true)
                : DashSvc.HasAnyWorkInWeek(_userId!.Value, nextWeek, _myPcs, soloMode: false);

        return hasNextWeek ? nextWeek : thisWeek;
    }
}
