    // ── Edit Session ──
    void OpenEditSession(SessionRow s)
    {
        _editSessionId = s.SessionId;
        _editDuration  = SecsToHMM(s.LengthSec);
        _editAdminMin  = (s.AdminSec / 60).ToString();
        _editIsFree    = s.IsFree;
        _editSummary   = s.Summary ?? "";
        _editError     = "";
    }

    void CancelEditSession() { _editSessionId = null; _editError = ""; }

    void SaveEditSession()
    {
        Console.WriteLine($"[Home] Updated session {_editSessionId} — duration={_editDuration}, admin={_editAdminMin}m, free={_editIsFree} by '{_username}'");
        int secs = ParseTime(_editDuration);
        if (secs <= 0) { _editError = "Invalid duration — use H:MM (e.g. 1:30)."; return; }
        if (!int.TryParse(_editAdminMin, out int adminMin) || adminMin < 0) { _editError = "Invalid admin time."; return; }
        DashSvc.UpdateSession(_editSessionId!.Value, secs, adminMin * 60, _editIsFree,
            string.IsNullOrWhiteSpace(_editSummary) ? null : _editSummary);
        _editSessionId = null;
        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay!.Value), _selRole);
        _grid = _isSolo
            ? DashSvc.GetWeekGridSolo(_userId.Value, _weekStart)
            : DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        _pendingCs = _isSolo ? [] : DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);
        _weeklyTotals = _isSolo
            ? DashSvc.GetWeeklyTotalsSolo(_userId.Value, ChartLatestWeekStart(), 20)
            : DashSvc.GetWeeklyTotals(_userId.Value, ChartLatestWeekStart(), 20, _myPcs);
        _chartKey++;
    }

    // ── CS The Session ──
    async Task OnCsTheSession(int sessionId, string? sessionName)
    {
        Console.WriteLine($"[Home] CS The Session — sessionId={sessionId}, sessionName={sessionName}, pcId={_selPcId} by '{_username}'");
        if (!_selPcId.HasValue) return;
        var url = $"/PcFolder/{_selPcId.Value}?sessionId={sessionId}&csMode=true";
        if (!string.IsNullOrWhiteSpace(sessionName))
            url += $"&file={Uri.EscapeDataString(sessionName)}";
        await JS.InvokeVoidAsync("pcfOpenTab", url);
    }

    // ── CS Queue context menu ──

    DashboardService.PendingCsSession? _csCtxSession;
    bool _csCtxVisible;
    double _csCtxX, _csCtxY;
    bool _csCtxConfirming;
    bool _csCtxBusy;
    string _csCtxError = "";

    void ShowCsCtxMenu(MouseEventArgs e, DashboardService.PendingCsSession s)
    {
        _csCtxSession    = s;
        _csCtxX          = e.ClientX;
        _csCtxY          = e.ClientY;
        _csCtxVisible    = true;
        _csCtxConfirming = false;
        _csCtxBusy       = false;
        _csCtxError      = "";
    }

    void CloseCsCtxMenu()
    {
        _csCtxVisible    = false;
        _csCtxConfirming = false;
        _csCtxError      = "";
    }

    async Task ConfirmMarkUndone()
    {
        if (_csCtxSession == null) return;
        _csCtxBusy  = true;
        _csCtxError = "";
        StateHasChanged();

        try
        {
            var sessionId = _csCtxSession.SessionId;
            var affected  = await Task.Run(() => DashSvc.DeleteCsReview(sessionId));
            if (affected != 1)
            {
                _csCtxError = $"Unexpected: {affected} row(s) deleted (expected 1). No change applied.";
                return;
            }
            CloseCsCtxMenu();
            _pendingCsSessions = DashSvc.GetPendingCsSessions(_userId!.Value, _csQueueDays, _showDoneCs);
        }
        catch (Exception ex)
        {
            _csCtxError = $"Error: {ex.Message}";
        }
        finally
        {
            _csCtxBusy = false;
            StateHasChanged();
        }
    }

