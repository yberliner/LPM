    /* ── Detail panel ── */
    .home-detail-card {
        border: none !important; border-radius: 14px !important; overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,.10);
    }
    .home-detail-header {
        background: linear-gradient(135deg, #1a237e 0%, #283593 55%, #3949ab 100%) !important;
        color: #fff !important; border-bottom: none;
    }
    .home-detail-header strong,
    .home-detail-header span,
    .home-detail-header i { color: #fff !important; }
    .home-role-badge {
        background: rgba(255,255,255,.22); color: #fff;
        font-weight: 600; border-radius: 20px; padding: .25em .7em;
    }

    /* ── Inline forms ── */
    .home-form-box {
        background: #f8faff; border: 1px solid #dde4f5;
        border-radius: 10px; padding: 12px 14px;
        color: #212529;
    }
    .home-form-box h6,
    .home-form-box .form-label,
    .home-form-box .form-check-label { color: #212529; }
    .home-form-box .form-control,
    .home-form-box .form-control-sm { color: #212529; background-color: #fff; border-color: #dee2e6; }
    .home-form-box .form-control::placeholder { color: #6c757d; }

    /* ── Context menu ── */
    .home-ctx-menu {
        background: #fff; border: none; border-radius: 12px; overflow: hidden;
        box-shadow: 0 8px 28px rgba(0,0,0,.16);
    }
    .home-ctx-header {
        font-size: .7rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .08em; color: #9ca3af; padding: 8px 14px 4px;
    }
    .home-ctx-menu .list-group-item {
        border: none; padding: 9px 14px; font-size: .88rem; transition: background .15s;
    }
    .home-ctx-menu .list-group-item:hover { background: #f3f4f6; }
    .home-ctx-menu .list-group-item.text-danger:hover { background: #fff5f5; }

    /* ── Add-PC modal ── */
    .home-modal-header {
        background: linear-gradient(135deg, #1a237e, #3949ab); border-bottom: none;
    }
    .home-pc-item {
        padding: 10px 14px; cursor: pointer; font-size: .9rem;
        border-bottom: 1px solid #f3f4f6;
        transition: background .15s, color .15s;
        display: flex; align-items: center;
    }
    .home-pc-item:last-child { border-bottom: none; }
    .home-pc-item:hover { background: #eef2ff; color: #3949ab; font-weight: 600; }

    /* ── Table section labels ── */
    .home-table-label {
        font-size: .85rem; font-weight: 700; color: #7986cb;
        letter-spacing: .03em;
    }
    .home-table-label-cs {
        color: #adb5bd; font-size: .8rem;
    }

    /* Dashboard table-light headers/footers have white bg even in dark mode */
    .table-light th, .table-light td { color: #212529; }

    /* Force dark text inside white-bg add-PC modal */
    .modal-content .form-control { color: #212529 !important; background-color: #fff !important; border-color: #dee2e6 !important; }
    .modal-content .home-pc-item { color: #374151; }

    /* ── CS The Session button ── */
    .home-cs-session-btn {
        background: linear-gradient(135deg, #7c3aed, #a855f7);
        color: #fff;
        border: none;
        border-radius: 20px;
        padding: 4px 16px;
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: .03em;
        position: relative;
        overflow: hidden;
        box-shadow: 0 0 8px rgba(124, 58, 237, .4), 0 0 20px rgba(168, 85, 247, .2);
        animation: csSessionGlow 2s ease-in-out infinite;
        transition: transform .15s, box-shadow .15s;
    }
    .home-cs-session-btn:hover {
        transform: translateY(-1px) scale(1.03);
        box-shadow: 0 0 14px rgba(124, 58, 237, .6), 0 0 30px rgba(168, 85, 247, .35);
        color: #fff;
    }
    .home-cs-session-btn:active {
        transform: scale(.96);
    }
    /* Shimmer sweep */
    .home-cs-session-btn::after {
        content: '';
        position: absolute;
        top: 0; left: -100%; width: 60%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,.25), transparent);
        animation: csSessionShimmer 3s ease-in-out infinite;
    }
    @@keyframes csSessionGlow {
        0%, 100% { box-shadow: 0 0 8px rgba(124,58,237,.4), 0 0 20px rgba(168,85,247,.2); }
        50%      { box-shadow: 0 0 16px rgba(124,58,237,.6), 0 0 35px rgba(168,85,247,.35); }
    }
    @@keyframes csSessionShimmer {
        0%   { left: -100%; }
        50%  { left: 150%; }
        100% { left: 150%; }
    }

    /* ── Pending CS Table ── */
    .home-pending-cs-card {
        border: 1px solid rgba(244,114,182,.25);
        overflow: hidden;
        animation: pendingCsFadeIn .4s ease-out;
    }
    @@keyframes pendingCsFadeIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .home-pending-cs-header {
        background: linear-gradient(135deg, rgba(244,114,182,.15), rgba(168,85,247,.12));
        color: #f472b6; font-size: .85rem;
        border-color: rgba(244,114,182,.2);
        display: flex; align-items: center; gap: 4px;
    }
    .home-pending-cs-badge {
        background: #ec4899; color: #fff;
        border-radius: 10px; padding: 0 8px;
        font-size: .7rem; font-weight: 700;
        min-width: 22px; text-align: center;
        animation: pendingCsPulse 2s ease-in-out infinite;
    }
    @@keyframes pendingCsPulse {
        0%, 100% { box-shadow: 0 0 4px rgba(236,72,153,.3); }
        50%      { box-shadow: 0 0 12px rgba(236,72,153,.6); }
    }
    .home-pending-cs-table {
        font-size: .78rem; color: #e2e8f0;
    }
    .home-pending-cs-table thead th {
        background: rgba(0,0,0,.2); color: #94a3b8;
        font-size: .7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        border-bottom: 1px solid rgba(255,255,255,.08);
        padding: 8px 12px;
    }
    .home-pcs-sortable {
        cursor: pointer; user-select: none; transition: color .15s;
    }
    .home-pcs-sortable:hover { color: #e2e8f0; }
    .home-pcs-sort-idle { opacity: .3; font-size: .65rem; margin-left: 2px; }
    .home-pcs-sort-active { color: #f472b6; font-size: .75rem; margin-left: 2px; }
    .home-pcs-row {
        cursor: pointer; transition: background .15s;
    }
    .home-pcs-row:hover {
        background: rgba(244,114,182,.1) !important;
    }
    .home-pcs-row td {
        padding: 7px 12px; vertical-align: middle;
        border-bottom: 1px solid rgba(255,255,255,.04);
    }
    .home-pcs-row-odd td { background: rgba(255,255,255,.02); }
    .home-pcs-row-even td { background: rgba(0,0,0,.08); }
    .home-pcs-pcname {
        font-weight: 700; color: #f8fafc;
    }
    .home-pcs-session {
        color: #cbd5e1;
    }
