            <table class="table table-sm table-hover mb-0 home-pending-cs-table home-dual-table">
                <colgroup>
                    <col style="width:16%;" /><col style="width:14%;" /><col style="width:12%;" />
                    <col style="width:10%;" /><col style="width:12%;" /><col style="width:10%;" />
                    <col style="width:14%;" /><col style="width:12%;" />
                </colgroup>
                <thead>
                    <tr>
                        <th class="home-pcs-sortable" @onclick='() => toggleSort("pc")'>
                            PC Name <i class="@sortIcon("pc")"></i>
                        </th>
                        <th>Name</th>
                        <th class="home-pcs-sortable" @onclick='() => toggleSort("date")'>
                            Date <i class="@sortIcon("date")"></i>
                        </th>
                        <th class="home-pcs-sortable" @onclick='() => toggleSort("dur")'>
                            Duration <i class="@sortIcon("dur")"></i>
