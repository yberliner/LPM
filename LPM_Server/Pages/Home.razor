                                            <i class="ri-checkbox-circle-line text-success"></i>
                                            <span class="fw-semibold small" style="color:#4ade80;">
                                                <i class="ri-user-star-line me-1"></i>@_displayName
                                            </span>
                                            <span class="badge bg-success-transparent">
                                                @DashboardService.Fmt(rev.ReviewSec)
                                            </span>
                                            <span>@rev.Status</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(rev.Notes))
                                        {
                                            <div class="text-muted small mt-1">@((MarkupString)rev.Notes)</div>
                                        }
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-success rounded-pill px-3 py-0 mt-1"
                                                @onclick="() => StartAddReview(s.SessionId, s.LengthSec + s.AdminSec)">
                                            <i class="ri-add-line me-1"></i>@LS.T("home.csReview")
                                        </button>
                                    }
                                </li>
                            }
                        </ul>
                    }

                    @* Add CS Review form *@
                    @if (_showAddReview)
                    {
                        <div class="home-form-box mt-2">
                            <h6 class="mb-2">@LS.T("home.addCsReview") (Session #@_addReviewSessionId)</h6>
                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:90px;" placeholder="0:30"
                                           @bind="_addReviewDuration" @bind:event="oninput" />
                                </div>
                                <div class="col-auto ms-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SaveReview">@LS.T("common.save")</button>
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="CancelAddReview">@LS.T("common.cancel")</button>
                                </div>
                            </div>
                            <div class="mb-1">
                                <label class="form-label mb-1 small">@LS.T("home.notes")</label>
                                <SpkRichEditor Value="@_addReviewNotes" ValueChanged="@(v => _addReviewNotes = v)" />
                            </div>
                            @if (!string.IsNullOrEmpty(_reviewError))
                            {
                                <div class="text-danger small mt-1">@_reviewError</div>
                            }
                        </div>
                    }

                    @* ── General CS Work ── *@
                    <hr class="my-3" />
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="ri-briefcase-line text-info"></i>
                        <span class="fw-semibold small" style="color:#5eead4;">@LS.T("home.generalCsWork")</span>
                    </div>
                    @if (_detail.GeneralWork != null && _detail.GeneralWork.Count > 0)
                    {
                        <ul class="list-unstyled mb-2">
                            @foreach (var w in _detail.GeneralWork)
                            {
                                <li class="mb-1 d-flex align-items-center gap-2">
                                    <span class="badge bg-info-transparent fs-12">
                                        @DashboardService.Fmt(w.LengthSec)
                                    </span>
                                    @if (!string.IsNullOrWhiteSpace(w.Notes))
                                    {
                                        <div class="text-muted small mt-1">@((MarkupString)w.Notes)</div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted small mb-1">No general CS work recorded.</p>
                    }

                    @if (!_showAddGeneralCs)
                    {
                        <button class="btn btn-sm btn-outline-info rounded-pill px-3"
                                @onclick="OpenAddGeneralCs">
                            <i class="ri-add-line me-1"></i>General CS
                        </button>
                    }
                    else
                    {
                        <div class="home-form-box mt-2">
                            <h6 class="mb-2">@LS.T("home.addGeneralCsWork")</h6>
                            <div class="row g-2 align-items-center mb-2">
                                <div class="col-auto">
                                    <label class="form-label mb-0 small">@LS.T("home.duration")</label>
                                    <input class="form-control form-control-sm"
                                           style="width:90px;" placeholder="0:30"
                                           @bind="_addGeneralCsDuration" @bind:event="oninput" />
                                </div>
                                <div class="col-auto ms-auto">
                                    <button class="btn btn-sm btn-primary" @onclick="SaveGeneralCs">@LS.T("common.save")</button>
                                    <button class="btn btn-sm btn-link text-danger"
                                            @onclick="CancelAddGeneralCs">@LS.T("common.cancel")</button>
                                </div>
                            </div>
                            <div class="mb-1">
                                <label class="form-label mb-1 small">@LS.T("home.notes")</label>
                                <SpkRichEditor Value="@_addGeneralCsNotes" ValueChanged="@(v => _addGeneralCsNotes = v)" />
                            </div>
                            @if (!string.IsNullOrEmpty(_generalCsError))
                            {
                                <div class="text-danger small mt-1">@_generalCsError</div>
                            }
                        </div>
                    }
                }

            </div>
        </div>
    };

    void ClearSelection() { _selPcId = null; _selDay = null; _detail = null; }

    // ── Add Session ──
    void OpenAddSession()   { _showAddSession = true;  _addError = ""; }
    void CancelAddSession() { _showAddSession = false; _addError = ""; }

    void SaveSession()
    {
        Console.WriteLine($"[Home] Adding session — PC={_selPcId}, role={_selRole}, duration={_addDuration}, admin={_addAdminMin}m, free={_addIsFree} by '{_username}'");
        int secs = ParseTime(_addDuration);
        if (secs <= 0) { _addError = "Invalid duration — use H:MM (e.g. 1:30)."; return; }
        if (!int.TryParse(_addAdminMin, out int adminMin) || adminMin < 0)
        {
            _addError = "Invalid admin time.";
            return;
        }

        if (_selRole == "Miscellaneous")
            DashSvc.AddMiscCharge(
                _userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);
        else if (_selRole == "SoloAuditor")
            DashSvc.AddSoloSession(
                _userId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);
        else
            DashSvc.AddSession(
                _userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value),
                secs, adminMin * 60, _addIsFree,
                string.IsNullOrWhiteSpace(_addSummary) ? null : _addSummary);

        _showAddSession = false;
        _addDuration = ""; _addAdminMin = "0"; _addIsFree = false;
        _addSummary = ""; _addError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay ?? 0), _selRole);
        _grid = _isSolo
            ? DashSvc.GetWeekGridSolo(_userId.Value, _weekStart)
            : DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        _pendingCs = _isSolo ? [] : DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);
        RefreshWeeklyTotals();
    }

    // ── Add CS Review ──
    void StartAddReview(int sessionId, int sessionLengthSec)
    {
        _addReviewSessionId  = sessionId;
        _addReviewDuration   = DashboardService.FmtOrBlank(sessionLengthSec);
        _showAddReview       = true;
        _reviewError         = "";
    }

    void CancelAddReview() { _showAddReview = false; _reviewError = ""; }

    // ── Add General CS ──
    void OpenAddGeneralCs()   { _showAddGeneralCs = true;  _generalCsError = ""; }
    void CancelAddGeneralCs() { _showAddGeneralCs = false; _generalCsError = ""; }

    void SaveGeneralCs()
    {
        Console.WriteLine($"[Home] Adding general CS work — PC={_selPcId}, duration={_addGeneralCsDuration} by '{_username}'");
        int secs = ParseTime(_addGeneralCsDuration);
        if (secs <= 0) { _generalCsError = "Invalid duration — use H:MM (e.g. 0:30)."; return; }

        DashSvc.AddCsWork(
            _userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay!.Value),
            secs,
            string.IsNullOrWhiteSpace(_addGeneralCsNotes) ? null : _addGeneralCsNotes);

        _showAddGeneralCs = false;
        _addGeneralCsDuration = ""; _addGeneralCsNotes = ""; _generalCsError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
            _weekStart.AddDays(_selDay ?? 0), _selRole);
        _grid = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);
        RefreshWeeklyTotals();
    }

    void SaveReview()
    {
        Console.WriteLine($"[Home] Adding CS review — sessionId={_addReviewSessionId}, duration={_addReviewDuration} by '{_username}'");
        int secs = ParseTime(_addReviewDuration);
        if (secs <= 0) { _reviewError = "Invalid duration — use H:MM (e.g. 0:30)."; return; }

        try
        {
            DashSvc.AddCsReview(
                _userId!.Value, _addReviewSessionId, secs, "Pending",
                string.IsNullOrWhiteSpace(_addReviewNotes) ? null : _addReviewNotes);
        }
        catch (Exception ex) when (ex.Message.Contains("UNIQUE"))
        {
            _reviewError = "A CS review already exists for this session.";
            return;
        }

        _showAddReview = false;
        _addReviewDuration = "";
        _addReviewNotes = ""; _reviewError = "";

        _detail = DashSvc.GetDayDetail(_userId!.Value, _selPcId!.Value,
                _weekStart.AddDays(_selDay!.Value), _selRole);

        _grid = DashSvc.GetWeekGrid(_userId.Value, _weekStart, _myPcs);

        // ✅ NEW: recompute pending markers so "*" disappears immediately when done
        _pendingCs = DashSvc.GetPendingCsMarkers(_userId.Value, _weekStart, _myPcs);

        RefreshWeeklyTotals();
        StateHasChanged();
    }

    void UpdateChartTooltip()
    {
        var sb = new System.Text.StringBuilder("[");
        for (int i = 0; i < _weeklyTotals.Count; i++)
        {
            if (i > 0) sb.Append(',');
            sb.Append('[');
            var pcs = _weeklyTotals[i].TopPcs ?? [];
            for (int j = 0; j < pcs.Count; j++)
            {
                if (j > 0) sb.Append(',');
                var name = pcs[j].FullName.Replace("\\", "\\\\").Replace("'", "\\'");
                sb.Append($"['{name}',{pcs[j].Seconds}]");
            }
            sb.Append(']');
        }
        sb.Append(']');
        var data = sb.ToString();

        var fn =
            "function(opts){" +
            "var d=" + data + ";" +
            "var idx=opts.dataPointIndex;" +
            "var t=opts.series[0][idx];" +
            "var pcs=d[idx]||[];" +
            "var th=Math.floor(t);" +
            "var tm=Math.round((t-th)*60);" +
            "var r='<div style=\"padding:10px 14px;min-width:220px;font-family:inherit;background:#fff;" +
                    "border-radius:8px;box-shadow:0 4px 20px rgba(0,0,0,.14)\">';" +
            "r+='<div style=\"font-weight:700;font-size:.93rem;color:#1a237e;" +
                    "border-bottom:1px solid #c5cae9;padding-bottom:5px;margin-bottom:8px\">" +
                    "Total: '+th+':'+String(tm).padStart(2,'0')+'</div>';" +
            "if(pcs.length){" +
            "r+='<div style=\"font-size:.7rem;color:#adb5bd;text-transform:uppercase;" +
                    "letter-spacing:.7px;margin-bottom:5px\">Top PCs</div>';" +
            "for(var i=0;i<pcs.length;i++){" +
            "var ph=Math.floor(pcs[i][1]/3600);" +
            "var pm=Math.floor((pcs[i][1]%3600)/60);" +
            "r+='<div style=\"display:flex;justify-content:space-between;gap:20px;padding:3px 6px;" +
                    "border-radius:4px;background:'+(i%2===0?'#f3f4fb':'transparent')+'\">';" +
            "r+='<span style=\"color:#212529;font-size:.82rem\">'+pcs[i][0]+'</span>';" +
            "r+='<span style=\"color:#3949ab;font-weight:700;font-size:.82rem\">'+" +
                    "ph+':'+String(pm).padStart(2,'0')+'</span>';" +
            "r+='</div>';}" +
            "}" +
            "r+='</div>';return r;}";

        _chartOptions.Tooltip = new Tooltip { Custom = fn };
    }

    void RefreshWeeklyTotals()
    {
        _weeklyTotals = _isSolo
            ? DashSvc.GetWeeklyTotalsSolo(_userId!.Value,
                  ChartLatestWeekStart(), 20)
            : DashSvc.GetWeeklyTotals(_userId!.Value,
                  ChartLatestWeekStart(), 20, _myPcs);
        UpdateChartTooltip();
        _chartKey++;
    }

    // ── Helpers ──
    static int ParseTime(string input)
    {
        if (string.IsNullOrWhiteSpace(input)) return 0;

        input = input.Trim();

        // If user typed only minutes (e.g. "45")
        if (!input.Contains(':'))
        {
            if (!int.TryParse(input, out int minutes) || minutes < 0) return 0;
            return minutes * 60;
        }

        // If user typed H:MM or HH:MM
        var parts = input.Split(':', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length != 2) return 0;

        if (!int.TryParse(parts[0], out int hours) || hours < 0) return 0;
        if (!int.TryParse(parts[1], out int minutesPart) || minutesPart < 0 || minutesPart > 59) return 0;

        return (hours * 3600) + (minutesPart * 60);
    }

    static string DayLabel(DateOnly d) =>
        d.ToString("ddd dd/MM", CultureInfo.InvariantCulture);

    async Task ScrollWeekTable(string dir)
    {
        await JS.InvokeVoidAsync("scrollToEdge", "week-table-scroll", dir);
    }

    DateOnly ChartLatestWeekStart()
    {
        var thisWeek = TodayWeekStart;
        var nextWeek = thisWeek.AddDays(7);

        // Only show next week if something exists there
        var hasNextWeek =
            _isSolo
                ? DashSvc.HasAnyWorkInWeek(_userId!.Value, nextWeek, _myPcs, soloMode: true)
                : DashSvc.HasAnyWorkInWeek(_userId!.Value, nextWeek, _myPcs, soloMode: false);

        return hasNextWeek ? nextWeek : thisWeek;
    }
}
