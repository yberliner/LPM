                        var isDoneCs     = s.CsStatus is "Done" or "Approved";
                        var isApprovedCs = s.CsStatus == "Approved";
                        var hasActiveQ   = _sessionQuestions.TryGetValue(s.SessionId, out var qInfo);
                        var pendingStyle = s.IsPendingApproval ? "opacity:.4; pointer-events:none;" : (isDoneCs && !hasActiveQ ? "opacity:.55;" : "");
                        <tr class="@rowClass home-pcs-row @(isDoneCs ? "home-csq-done-row" : "")" style="@pendingStyle"
                            title="@($"{s.PcName} — {RoleTooltip(s.WorkCapacity)}")"
                            @onclick="() => { if (!s.IsPendingApproval) OpenPendingCs(s); }"
                            @oncontextmenu="e => ShowCsCtxMenu(e, s, ctxOwnerId)"
                            @oncontextmenu:preventDefault="true">
                            <td class="home-pcs-pcname">
                                @if (isNewPc)
                                {
                                    @if (s.IsPendingApproval)
                                    {
                                        <i class="ri-time-line me-1" style="opacity:.5;color:#f59e0b;"></i>
                                    }
                                    else
                                    {
                                        <i class="ri-user-line me-1" style="opacity:.5;"></i>
                                    }
                                    @s.PcName
                                }
                            </td>
                            <td class="home-pcs-session">@s.SessionName</td>
                            <td class="home-pcs-date">
                                @if (csCreatedDisp != null)
                                {
                                    <span class="home-pcs-date-wrap">
                                        @csDateDisp<span class="home-pcs-date-created"> (@csCreatedDisp)</span>
                                        <div class="home-pcs-date-hover">
                                            <div class="home-pcs-date-hover-title"><i class="ri-information-line me-1"></i>Date mismatch</div>
                                            <div class="home-pcs-date-hover-body">@csDateTip</div>
                                        </div>
                                    </span>
                                }
                                else
                                {
                                    @csDateDisp
                                }
                            </td>
                            <td class="home-pcs-dur">
                                <i class="ri-time-line me-1" style="opacity:.4;"></i>@durStr
                            </td>
                            <td class="home-pcs-staff">@s.AuditorName</td>
                            <td>
                                @if (s.IsSolo)
                                {
                                    <span class="home-pcs-solo-badge">Solo</span>
                                    @if (s.IsCsFree)
                                    {
                                        <span class="home-pcs-free-badge ms-1"
                                              title="This solo session's CS review is marked Free — verify this is intentional">Free</span>
                                    }
                                }
                                else
                                {
                                    <span class="home-pcs-regular-badge">Regular</span>
                                }
                            </td>
                            <td style="text-align:center;">
                                @if (hasActiveQ && qInfo!.Status == "Pending")
                                {
                                    <span class="home-q-badge home-q-pending" title="Question by @qInfo.AskerName">
                                        <i class="ri-question-line"></i> @qInfo.AskerName
                                    </span>
                                }
                                else if (hasActiveQ && qInfo!.Status == "Replied")
                                {
                                    <span class="home-q-badge home-q-replied" title="Replied by @qInfo.ReplierName">
                                        <i class="ri-chat-check-line"></i> @qInfo.ReplierName
                                    </span>
                                }
                            </td>
                            <td style="text-align:center;">
                                @if (isApprovedCs)
                                {
                                    <span class="home-csq-approved-chip">
                                        <i class="ri-check-double-line me-1"></i>Approved
                                    </span>
                                }
                                else if (isDoneCs)
                                {
                                    <span class="home-csq-done-chip">
                                        <i class="ri-check-line me-1"></i>Done
                                    </span>
                                }
                                else
                                {
                                    <button class="home-pcs-cs-btn" title="Open CS for this session">
                                        <i class="ri-eye-line me-1"></i>CS
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    };

    List<DashboardService.PendingCsSession> GetSortedPendingCs()
        => SortCsSessions(_pendingCsSessions, _pcsSortCol, _pcsSortAsc);

    static List<DashboardService.PendingCsSession> SortCsSessions(
        List<DashboardService.PendingCsSession> sessions, string sortCol, bool sortAsc)
    {
        IEnumerable<DashboardService.PendingCsSession> q = sessions;
        q = sortCol switch
        {
            "date" => sortAsc
                ? q.OrderBy(s => DateOnly.TryParse(s.SessionDate, out var dt) ? dt : DateOnly.MinValue).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => DateOnly.TryParse(s.SessionDate, out var dt) ? dt : DateOnly.MinValue).ThenBy(s => s.PcName),
            "dur" => sortAsc
                ? q.OrderBy(s => s.TotalSeconds).ThenBy(s => s.PcName)
                : q.OrderByDescending(s => s.TotalSeconds).ThenBy(s => s.PcName),
            _ => sortAsc
                ? q.OrderBy(s => s.PcName).ThenBy(s => s.SessionDate)
                : q.OrderByDescending(s => s.PcName).ThenBy(s => s.SessionDate),
        };
        return q.ToList();
    }

