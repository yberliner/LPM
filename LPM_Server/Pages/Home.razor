    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("[Home] OnInitializedAsync START");
        var auth     = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = auth.User.Identity?.Name ?? "";
        _username = username;
        _displayName = username.Length > 0
            ? char.ToUpper(username[0]) + username[1..]
            : "LP Management";

        var staffRole  = auth.User.FindFirst("StaffRole")?.Value ?? StaffRoles.None;
        _isSolo        = staffRole == StaffRoles.Solo;
        _userId = DashSvc.GetUserIdByUsername(username);
        if (_isSolo && _userId.HasValue)
        {
            var fullName = DashSvc.GetPersonName(_userId.Value);
            _soloFirstName = fullName.Split(' ')[0];
        }
        // NeedsContactConfirm operates on core_users.Id, not PersonId — use GetLoginFlags for the correct Id
        var loginFlags = UserDb.GetLoginFlags(username);
        var coreUserId = loginFlags?.UserId ?? 0;
        Console.WriteLine($"[Home] user='{username}' PersonId={_userId} coreUserId={coreUserId} NeedsContactConfirm={coreUserId > 0 && UserDb.NeedsContactConfirm(coreUserId)}");
        if (coreUserId > 0 && loginFlags != null)
        {
            // Force password change if flagged
            if (loginFlags.MustChangePassword)
            {
                Console.WriteLine("[Home] Redirecting to /ChangePassword — password change required");
                Nav.NavigateTo("/ChangePassword");
                return;
            }
            if (UserDb.NeedsContactConfirm(coreUserId))
            {
                Console.WriteLine("[Home] Redirecting to /WelcomeContact");
                Nav.NavigateTo("/WelcomeContact");
                return;
            }
        }
        if (_userId.HasValue)
        {
            _isAuditor     = StaffRoles.IsAuditorOrCS(staffRole);
            _isCS          = StaffRoles.IsCS(staffRole);
            _isSeniorCS    = staffRole == StaffRoles.SeniorCS;
            _isSoloAuditor = _isSolo;
            if (_isSoloAuditor)
                _soloSelf = DashSvc.GetSoloAuditorInfo(_userId.Value);
        }
        _weekStart = TodayWeekStart;
        _csStatusLabels = DashSvc.GetCsStatusLabels();
        _initialized = true;
        // Data load + subscriptions moved to OnAfterRenderAsync so the page skeleton
        // renders immediately and tables fill in after the first paint.
        Console.WriteLine("[Home] OnInitializedAsync DONE — _initialized=true");
    }

    private Action? _onDataChangedHandler;
    private CancellationTokenSource? _refreshDebounce;
    private async Task _onDataChangedAsync()
    {
        // Debounce: cancel any pending refresh and wait 300ms before actually refreshing.
        // This prevents redundant DB queries when multiple NotifyDataChanged fire in quick succession.
        try
        {
            _refreshDebounce?.Cancel();
            _refreshDebounce = new CancellationTokenSource();
            var token = _refreshDebounce.Token;
            await Task.Delay(300, token);
            if (token.IsCancellationRequested) return;
            await InvokeAsync(async () => { await RefreshAsync(); StateHasChanged(); });
        }
        catch (TaskCanceledException) { /* debounced — newer refresh pending */ }
        catch (Exception ex) { Console.WriteLine($"[Home] _onDataChanged error: {ex.Message}"); }
    }

    DotNetObjectReference<Home>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("lpmInitCsListener", _dotNetRef);

            // Subscribe to events before loading data so no notifications are missed.
            if (_userId.HasValue)
            {
                _csNotifyKey = CsNotifySvc.Subscribe(_userId.Value, async pcId =>
                {
                    await InvokeAsync(async () =>
                    {
                        await RefreshAsync();
                        StateHasChanged();
                    });
                });
            }
            _onDataChangedHandler = () => _ = _onDataChangedAsync();
            DashSvc.OnDataChanged += _onDataChangedHandler;

            // Load dashboard data — happens after first paint so user sees page immediately.
            await RefreshAsync();
            _dataLoaded = true;
            StateHasChanged();
        }
    }

