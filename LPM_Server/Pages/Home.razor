@code {

    async Task OnMobileAddSession() => await JS.InvokeVoidAsync("lpmClickById", "btn-add-session");

    void OpenSoloFolder() => Nav.NavigateTo($"/PcFolder/{_userId}?solo=true", forceLoad: true);

    string _displayName = "LP Management";
    string _username = "";
    string? _csNotifyKey;

    int?          _userId;
    bool          _isAuditor, _isCS;
    bool          _isSoloAuditor;
    bool          _isSolo;        // true = StaffRole is 'Solo' — always shows solo grid, no toggle
    string        _soloFirstName = "";
    PcInfo?       _soloSelf;
    DateOnly      _weekStart;
    List<PcInfo>   _myPcs  = [];
    HashSet<int>   _unapprovedPcIds = [];
    HashSet<int>   _soloPcIds = [];
    HashSet<int>   _pcsWithCs = [];
    WeekGrid _grid = WeekGrid.Empty();
    Dictionary<string, string> _csStatusLabels = [];

    // ── Extra Effort state ──
    List<(int PcId, string FullName)>   _effortPcs  = new();
    Dictionary<(int, int), int>         _effortGrid = new();

    bool   _hideEmpty = true;

    // If SessionDate and the local-date of CreatedAt differ, returns the extra "(createdDate)"
    // string plus a tooltip. Returns (display, null, null) when they match or parsing fails.
    // CreatedAt from SQLite is UTC — convert to local (server TZ = Jerusalem) before comparing.
    (string display, string? createdStr, string? tip) FormatSessionDate(string sessionDate, string createdAt)
    {
        if (!DateOnly.TryParse(sessionDate, out var sd))
            return (sessionDate ?? "", null, null);
        var sdDisp = sd.ToString("dd/MM/yy");

        if (string.IsNullOrWhiteSpace(createdAt)) return (sdDisp, null, null);
        if (!DateTime.TryParse(createdAt, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.AssumeUniversal | System.Globalization.DateTimeStyles.AdjustToUniversal,
                out var utc))
            return (sdDisp, null, null);
        var cdLocal = DateOnly.FromDateTime(utc.ToLocalTime());
        if (cdLocal == sd) return (sdDisp, null, null);

        var cdStr = cdLocal.ToString("dd/MM/yy");
        var tip = $"Session date {sdDisp} differs from the date it was entered into the system ({cdStr}). " +
                  "The session actually happened on " + sdDisp + " but the record was created on " + cdStr + ".";
        return (sdDisp, cdStr, tip);
    }

    bool HasWeekData(Dictionary<(int pcId, int dayIdx), int> slot, HashSet<(int pcId, int dayIdx)> pending, int pcId) =>
        Enumerable.Range(0, 7).Any(d => slot.GetValueOrDefault((pcId, d)) > 0
                                     || pending.Contains((pcId, d)));

    List<PcInfo> AuditorPcs => _myPcs
        .Where(pc => StaffRoles.IsAuditorCapacity(pc.WorkCapacity))
        .Where(pc => !_hideEmpty || HasWeekData(_grid.Auditor, _pendingCs.Regular, pc.PcId))
        .ToList();

    // CS-assigned PCs that are solo auditors — shown in the CS Solo table.
    // Includes: CS/AuditorAndCS capacity where PC is solo, plus CSSolo/AuditorAndCSSolo capacity always.
    // WorkCapacity is normalized to "CSSolo" so _selRole comparisons in the CS Solo render match.
    List<PcInfo> CsSoloPcs => _myPcs
        .Where(pc => StaffRoles.IsCsSoloCapacity(pc.WorkCapacity)
            || (StaffRoles.IsCsCapacity(pc.WorkCapacity) && !StaffRoles.IsCsReviewCapacity(pc.WorkCapacity) && _soloPcIds.Contains(pc.PcId)))
        .Select(pc => pc with { WorkCapacity = "CSSolo" })
