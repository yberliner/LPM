    async Task SaveEditSummary()
    {
        if (_editSummaryId <= 0) { _showEditSummary = false; return; }
        var html = await JS.InvokeAsync<string>("eval",
            "window._pcfSummaryQuill ? window._pcfSummaryQuill.root.innerHTML : ''");
        DashSvc.UpdateFolderSummary(_editSummaryId, html ?? "");
        _showEditSummary = false;
        Console.WriteLine($"[PcFolder] Session summary updated for session {_csSessionId} by '{_userName}'");

        // Regenerate arf.pdf if ARF data was stored at session creation
        if (!string.IsNullOrEmpty(_editSummaryArfJson))
        {
            try
            {
                var arfData = System.Text.Json.JsonSerializer.Deserialize<PdfService.ArfData>(_editSummaryArfJson);
                var sessionFileName = DashSvc.GetSessionName(_csSessionId);
                if (arfData != null && !string.IsNullOrEmpty(sessionFileName))
                {
                    var pdfBytes = PdfSvc.GenerateArfPdf(
                        arfData.PcName, arfData.Date, arfData.Grade, arfData.SessionLength,
                        arfData.AdminTime, arfData.TotalTa, arfData.TaRange,
                        arfData.Rows, html);
                    if (FolderSvc.TryOverwriteArfPdf(PcId, sessionFileName, pdfBytes, Solo))
                    {
                        // Reload any pane that currently shows arf.pdf
                        var arfFileName = $"{Path.GetFileNameWithoutExtension(sessionFileName)}_att_arf.pdf";
                        for (int i = 0; i < _paneCount; i++)
                        {
                            var pf = _panes[i].File;
                            if (pf != null && Path.GetFileName(pf).Equals(arfFileName, StringComparison.OrdinalIgnoreCase))
                            {
                                var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(pf)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
                                await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, PaneIds[i]);
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PcFolder] Failed to regenerate arf.pdf: {ex.Message}");
            }
        }

        // Reload folder summary pane if open
        for (int i = 0; i < _paneCount; i++)
        {
            var f = _panes[i].File;
            var fn = _panes[i].FileName;
            if (f != null && fn != null && IsFolderSummaryFile(fn, f))
            {
                var url = $"/api/pc-file-folder-summary?pcId={PcId}&path={Uri.EscapeDataString(f)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
                await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, PaneIds[i]);
            }
        }
    }

