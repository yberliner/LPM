        display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 14px;
        background: radial-gradient(ellipse at center, rgba(251,191,36,.07) 0%, rgba(10,14,26,.72) 65%);
        backdrop-filter: blur(10px) saturate(1.6);
        color: #f1f5f9; pointer-events: none; border-radius: inherit;
        animation: pcf-expand-flash 1.1s ease forwards;
