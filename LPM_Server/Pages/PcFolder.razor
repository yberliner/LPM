    void ExpandPathHierarchy(string folderRelPath)
    {
        // Expand all parent folders in the path: "Front_Cover/A/B" → expand "Front_Cover", "Front_Cover/A", "Front_Cover/A/B"
        var parts = folderRelPath.Split('/');
        var path = "";
        foreach (var part in parts)
        {
            path = string.IsNullOrEmpty(path) ? part : $"{path}/{part}";
            _expandedTreeFolders.Add(path);
        }
    }

    bool IsFolderExpanded(string relPath) => _expandedTreeFolders.Contains(relPath);

    void ToggleTreeFolder(string relPath)
    {
        if (!_expandedTreeFolders.Remove(relPath))
            _expandedTreeFolders.Add(relPath);
    }

    string FolderDisplayPath(string relPath)
    {
        // "Front_Cover/Medical/Imaging" → "Medical / Imaging"
        var parts = relPath.Split('/');
        return parts.Length <= 1 ? "(root)" : string.Join(" / ", parts.Skip(1));
    }

    RenderFragment RenderTreeNode(FolderTreeNode node, string section, int depth) => __builder =>
    {
        if (node.IsFolder)
        {
            var isExpanded = IsFolderExpanded(node.RelativePath);
            var isDropTarget = _dragNode != null && _dragSection == section;
            <div class="pcf-tree-folder"
                 style="padding-left:@(14 + depth * 18)px;"
                 @oncontextmenu="e => ShowCtxMenu(e, node, section)"
                 @oncontextmenu:preventDefault="true"
                 ondragover="event.preventDefault();"
                 @ondrop="() => OnTreeDrop(node.RelativePath, section)"
                 @onclick="() => ToggleTreeFolder(node.RelativePath)">
                <i class="@(isExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")" style="font-size:.85rem;"></i>
                <i class="@(isExpanded ? "ri-folder-open-line" : "ri-folder-line")" style="color:#fbbf24;"></i>
                @if (_isRenaming && _renameTargetPath == node.RelativePath)
                {
                    <input class="pcf-rename-input" value="@_renameValue"
                           @oninput="e => _renameValue = e.Value?.ToString() ?? string.Empty"
                           @onkeydown="e => OnRenameKey(e, true)"
                           @onfocusout="CancelRename"
                           @onclick:stopPropagation="true" />
                }
                else
                {
                    <span class="pcf-file-name" style="color:#fbbf24;">@node.Name</span>
                    <span class="pcf-section-count" style="font-size:.6rem;">@node.Children.Count(c => !c.IsFolder)</span>
                }
            </div>
            @if (isExpanded)
            {
                @foreach (var child in node.Children)
                {
                    @RenderTreeNode(child, section, depth + 1)
                }
                @if (_isCreatingFolder && _createFolderParent == node.RelativePath && _createFolderSection == section)
                {
                    <div class="pcf-tree-folder pcf-create-folder-row" style="padding-left:@(14 + (depth + 1) * 18)px;">
                        <i class="ri-folder-add-line" style="color:#fbbf24;"></i>
                        <input class="pcf-rename-input" value="@_createFolderName"
                               @oninput="e => _createFolderName = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnCreateFolderKey"
                               placeholder="Folder name" />
                        <button class="pcf-create-folder-ok" @onclick="ConfirmCreateFolder"
                                disabled="@string.IsNullOrWhiteSpace(_createFolderName)">
                            <i class="ri-check-line"></i>
                        </button>
                        <button class="pcf-create-folder-cancel" @onclick="CancelCreateFolder">
                            <i class="ri-close-line"></i>
                        </button>
                    </div>
                }
            }
        }
        else
        {
            var active = IsFileActive(node.RelativePath);
            var clr = GetCoverBorderColor(node.Name);
            var coverStyle = !string.IsNullOrEmpty(clr)
                ? $"border-left:3px solid {clr}; background:rgba({HexToRgb(clr)},.08);" : "";
            var sectionLabel = section == "Front_Cover" ? "Front Cover" : "Back Cover";
            var fileParentFolder = Path.GetDirectoryName(node.RelativePath)?.Replace('\\', '/') ?? section;
            <div class="pcf-file-item @active"
                 style="padding-left:@(14 + depth * 18)px; @coverStyle"
                 draggable="true"
                 @ondragstart="() => OnDragStart(node, section)"
                 @ondragend="OnDragEnd"
                 ondragover="event.preventDefault();"
                 @ondrop="() => OnTreeDrop(fileParentFolder, section)"
                 @ondrop:stopPropagation="true"
                 @oncontextmenu="e => ShowCtxMenu(e, node, section)"
                 @oncontextmenu:preventDefault="true"
                 @onclick="@(() => SelectFile(node.RelativePath, node.Name, sectionLabel))">
                @if (_isRenaming && _renameTargetPath == node.RelativePath)
                {
                    <input class="pcf-rename-input" value="@_renameValue"
                           @oninput="e => _renameValue = e.Value?.ToString() ?? string.Empty"
                           @onkeydown="e => OnRenameKey(e, false)"
                           @onfocusout="CancelRename"
                           @onclick:stopPropagation="true" />
                }
                else
                {
                    @if (!string.IsNullOrEmpty(clr))
                    {
                        <span class="pcf-cover-dot" style="background:@clr;"></span>
                    }
                    <span class="pcf-file-name">@SessionDisplayName(node.Name)</span>
                }
            </div>
        }
    };

    // ── Context menu ──

    void ShowCtxMenu(MouseEventArgs e, FolderTreeNode node, string section)
    {
        _ctxNode = node;
        _ctxSection = section;
        // Clamp to prevent off-screen (approx menu size 200x200)
        _ctxMenuX = Math.Min(e.ClientX, Math.Max(e.ClientX, 10));
        _ctxMenuY = Math.Min(e.ClientY, Math.Max(e.ClientY, 10));
        _showCtxMenu = true;
        CloseNewMenu();
    }

    void CloseCtxMenu() { _showCtxMenu = false; _ctxNode = null; }

    // ── Context menu actions ──

    void CtxNewFolder()
    {
        if (_ctxNode == null) return;
        var parent = _ctxNode.IsFolder ? _ctxNode.RelativePath : Path.GetDirectoryName(_ctxNode.RelativePath)!.Replace('\\', '/');
        Console.WriteLine($"[PcFolder] New folder requested in '{parent}' by '{_userName}' — PC {PcId}");
        _createFolderParent = parent;
        _createFolderSection = _ctxSection;
        _createFolderName = "";
        _isCreatingFolder = true;
        if (!_expandedTreeFolders.Contains(parent)) _expandedTreeFolders.Add(parent);
        CloseCtxMenu();
    }

    void CtxRename()
    {
        if (_ctxNode == null) return;
        _renameTargetPath = _ctxNode.RelativePath;
        _renameValue = _ctxNode.IsFolder ? _ctxNode.Name : Path.GetFileNameWithoutExtension(_ctxNode.Name);
        _isRenaming = true;
        CloseCtxMenu();
    }

    void CtxDelete()
    {
        if (_ctxNode == null) return;
        _deleteTargetPath = _ctxNode.RelativePath;
        _deleteTargetName = _ctxNode.Name;
        _deleteIsFolder = _ctxNode.IsFolder;
        _showDeleteConfirm = true;
        CloseCtxMenu();
    }

    void CtxMoveTo()
    {
        if (_ctxNode == null || _ctxNode.IsFolder) return;
        if (IsFolderSummaryFile(_ctxNode.Name, _ctxNode.RelativePath))
        {
            CloseCtxMenu();
            ShowErrorToast("Folder Summary file cannot be moved to a different location.");
            return;
        }
        _moveFilePath = _ctxNode.RelativePath;
        _moveFileName = _ctxNode.Name;
        _moveFileSection = _ctxSection;
        _moveSelectedFolder = "";
        _moveNewFolderMode = false;
        _moveNewFolderName = "";
        _showMoveModal = true;
        CloseCtxMenu();
    }

    async Task CtxDownload()
    {
        if (_ctxNode == null || _ctxNode.IsFolder) return;
        var relPath = _ctxNode.RelativePath;
        var fileName = _ctxNode.Name;
        Console.WriteLine($"[PcFolder] Downloaded (ctx) '{fileName}' by '{_userName}' — PC {PcId}");
        CloseCtxMenu();
        var apiEndpoint = IsFolderSummaryFile(fileName, relPath)
            ? $"/api/pc-file-folder-summary?pcId={PcId}&path={Uri.EscapeDataString(relPath)}{SoloParam}&_t={DateTime.UtcNow.Ticks}"
            : $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(relPath)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
        var js = $"var a=document.createElement('a');a.href='{apiEndpoint}';a.download='{fileName.Replace("'", "\\'")}';document.body.appendChild(a);a.click();document.body.removeChild(a);";
        await JS.InvokeVoidAsync("eval", js);
    }

    async Task CtxUploadFile()
    {
        if (_ctxNode == null) return;
        _newMenuParentFolder = _ctxNode.IsFolder ? _ctxNode.RelativePath : Path.GetDirectoryName(_ctxNode.RelativePath)!.Replace('\\', '/');
        _newMenuSection = _ctxSection;
        CloseCtxMenu();
        await JS.InvokeVoidAsync("eval", "document.getElementById('pcf-upload-input').click()");
    }

    void CtxNewEmptyPdf()
    {
        if (_ctxNode == null) return;
        var parent = _ctxNode.IsFolder ? _ctxNode.RelativePath : Path.GetDirectoryName(_ctxNode.RelativePath)!.Replace('\\', '/');
        var pdfBytes = FolderSvc.CreateEmptyPdf();
        var fileName = $"new-{DateTime.Now:yyMMdd-HHmmss}.pdf";
        Console.WriteLine($"[PcFolder] Created empty PDF '{fileName}' in '{parent}' by '{_userName}' — PC {PcId}");
        FolderSvc.SaveSectionFileToPath(PcId, parent, fileName, pdfBytes, solo: Solo);
        RefreshFolder();
        CloseCtxMenu();
    }

    // ── Rename ──

    void OnRenameKey(KeyboardEventArgs e, bool isFolder)
    {
        if (e.Key == "Enter")
        {
            if (!string.IsNullOrWhiteSpace(_renameValue))
            {
                Console.WriteLine($"[PcFolder] Renamed '{_renameTargetPath}' to '{_renameValue}' (isFolder={isFolder}) by '{_userName}' — PC {PcId}");
                if (isFolder)
                    FolderSvc.RenameFolder(PcId, _renameTargetPath, _renameValue, Solo);
                else
                    FolderSvc.RenameFile(PcId, _renameTargetPath, _renameValue, Solo);
                RefreshFolder();
            }
            CancelRename();
        }
        else if (e.Key == "Escape") CancelRename();
    }

    void CancelRename() { _isRenaming = false; _renameTargetPath = ""; }

    // ── Create folder ──

    void OnCreateFolderKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ConfirmCreateFolder();
        else if (e.Key == "Escape") CancelCreateFolder();
    }

    void ConfirmCreateFolder()
    {
        if (!string.IsNullOrWhiteSpace(_createFolderName))
        {
            Console.WriteLine($"[PcFolder] Created folder '{_createFolderName}' in '{_createFolderParent}' by '{_userName}' — PC {PcId}");
            FolderSvc.CreateSubfolder(PcId, _createFolderParent, _createFolderName, Solo);
            RefreshFolder();
        }
        CancelCreateFolder();
    }

    void CancelCreateFolder() { _isCreatingFolder = false; _createFolderName = ""; }

    // ── New menu ──

    void ShowNewMenu(MouseEventArgs e, string section, string parentFolder)
    {
        _newMenuSection = _newMenuSection == section ? null : section;
        _newMenuParentFolder = parentFolder;
        _newMenuX = e.ClientX;
        _newMenuY = e.ClientY - 100; // position above the click
    }

    async Task NewMenuUploadClick()
    {
        CloseNewMenu();
        await JS.InvokeVoidAsync("eval", "document.getElementById('pcf-upload-input').click()");
    }

    void CloseNewMenu() { _newMenuSection = null; }

    void NewMenuFolder()
    {
        _createFolderParent = _newMenuParentFolder;
        _createFolderSection = _newMenuSection!;
        _createFolderName = "";
        _isCreatingFolder = true;
        if (!_expandedTreeFolders.Contains(_newMenuParentFolder))
            _expandedTreeFolders.Add(_newMenuParentFolder);
        CloseNewMenu();
    }

    void NewMenuEmptyPdf()
    {
        var pdfBytes = FolderSvc.CreateEmptyPdf();
        var fileName = $"new-{DateTime.Now:yyMMdd-HHmmss}.pdf";
        Console.WriteLine($"[PcFolder] Created empty PDF '{fileName}' in '{_newMenuParentFolder}' (new menu) by '{_userName}' — PC {PcId}");
        FolderSvc.SaveSectionFileToPath(PcId, _newMenuParentFolder, fileName, pdfBytes, solo: Solo);
        RefreshFolder();
        CloseNewMenu();
    }

    async Task NewMenuUploadFile(InputFileChangeEventArgs e)
    {
        _uploadPendingFiles.Clear();
        _uploadDuplicateNames.Clear();
        var parentFolder = _newMenuParentFolder;

        var pdfsToSave = new List<(string Name, byte[] Data)>();

        foreach (var file in e.GetMultipleFiles(20))
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
            var rawBytes = ms.ToArray();

            var ext = Path.GetExtension(file.Name);
            if (FolderService.ConvertibleExtensions.Contains(ext))
            {
                // Fire background conversion — close menu immediately
                var toast = new ConversionToast(Guid.NewGuid(), file.Name);
                _conversionToasts.Add(toast);
                var capturedName = file.Name;
                var capturedBytes = rawBytes;
                var capturedParent = parentFolder;
                _ = RunConversionAsync(toast, capturedBytes, capturedName, capturedParent);
            }
            else
            {
                pdfsToSave.Add((file.Name, rawBytes));
            }
        }

        // Handle plain PDF uploads synchronously (existing behaviour)
        foreach (var (name, data) in pdfsToSave)
        {
            if (FolderSvc.SectionFileExistsAtPath(PcId, parentFolder, name, Solo))
            {
                _uploadPendingFiles.Add((name, data));
                _uploadDuplicateNames.Add(name);
            }
            else
            {
                Console.WriteLine($"[PcFolder] Uploaded file '{name}' to '{parentFolder}' by '{_userName}' — PC {PcId}");
                FolderSvc.SaveSectionFileToPath(PcId, parentFolder, name, data, solo: Solo);
            }
        }

        if (_uploadDuplicateNames.Count > 0)
        {
            _showOverwriteConfirm = true;
            CloseNewMenu();
        }
        else
        {
            RefreshFolder();
            CloseNewMenu();
        }
    }

    async Task RunConversionAsync(ConversionToast toast, byte[] docBytes, string originalName, string parentFolder)
    {
        var pdfName = Path.GetFileNameWithoutExtension(originalName) + ".pdf";
        try
        {
            var pdfBytes = await Task.Run(() => FolderSvc.ConvertToPdf(docBytes, originalName));
            if (pdfBytes == null)
            {
                toast.Status = ConvStatus.Failed;
                await InvokeAsync(StateHasChanged);
                return;
            }

            // Save (overwrite if exists — doc upload implies intent to replace)
            var overwrite = FolderSvc.SectionFileExistsAtPath(PcId, parentFolder, pdfName, Solo);
            FolderSvc.SaveSectionFileToPath(PcId, parentFolder, pdfName, pdfBytes, overwrite, Solo);
            Console.WriteLine($"[PcFolder] Converted+saved '{pdfName}' to '{parentFolder}' by '{_userName}' — PC {PcId}");

            toast.Status = ConvStatus.Done;
            RefreshFolder();
            await InvokeAsync(StateHasChanged);

            // Auto-dismiss the Done toast after 3 s
            await Task.Delay(3000);
            _conversionToasts.Remove(toast);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PcFolder] Conversion error for '{originalName}': {ex.Message}");
            toast.Status = ConvStatus.Failed;
            await InvokeAsync(StateHasChanged);
        }
    }

    void ConfirmOverwrite()
    {
        foreach (var (name, data) in _uploadPendingFiles)
        {
            Console.WriteLine($"[PcFolder] Overwriting file '{name}' in '{_newMenuParentFolder}' by '{_userName}' — PC {PcId}");
            FolderSvc.SaveSectionFileToPath(PcId, _newMenuParentFolder, name, data, overwrite: true, solo: Solo);
        }
        _uploadPendingFiles.Clear();
        _uploadDuplicateNames.Clear();
        _showOverwriteConfirm = false;
        RefreshFolder();
    }

    void CancelOverwrite()
    {
        _uploadPendingFiles.Clear();
        _uploadDuplicateNames.Clear();
        _showOverwriteConfirm = false;
        RefreshFolder(); // still refresh for non-duplicate files that were saved
    }

    // ── Delete ──

    void ExecuteDelete()
    {
        Console.WriteLine($"[PcFolder] Deleted '{_deleteTargetName}' (isFolder={_deleteIsFolder}) by '{_userName}' — PC {PcId}");
        if (_deleteIsFolder)
            FolderSvc.DeleteEmptyFolder(PcId, _deleteTargetPath, Solo);
        else
        {
            FolderSvc.DeleteFileToBackup(PcId, _deleteTargetPath, Solo);
            // Clear pane if showing deleted file, and close the pane if possible
            for (int i = _paneCount - 1; i >= 0; i--)
            {
                if (_panes[i].File == _deleteTargetPath)
                {
                    _panes[i].File = null; _panes[i].FileName = null; _panes[i].Section = "";
                    _ = JS.InvokeVoidAsync("eval", $"var v=document.getElementById('pcf-viewer-{PaneIds[i]}');if(v)v.innerHTML='';");
                    // Close the pane if more than 1 open
                    if (_paneCount > 1)
                    {
                        _paneCount--;
                        if (_activeIdx >= _paneCount) _activeIdx = _paneCount - 1;
                    }
                }
            }
        }
        RefreshFolder();
        _showDeleteConfirm = false;
    }

    // ── Move modal ──

    FolderTreeNode? GetSectionTree(string section) =>
        section == "Front_Cover" ? _folder?.FrontCoverTree : _folder?.BackCoverTree;

    RenderFragment RenderMoveFolderTree(FolderTreeNode? node, int depth) => __builder =>
    {
        if (node == null) return;
        var isSelected = _moveSelectedFolder == node.RelativePath;
        <div class="pcf-move-folder @(isSelected ? "pcf-move-folder-selected" : "")"
             style="padding-left:@(8 + depth * 18)px;"
             @onclick="() => _moveSelectedFolder = node.RelativePath"
             @onclick:stopPropagation="true">
            <i class="ri-folder-line" style="color:#fbbf24;"></i>
            <span>@(depth == 0 ? "(root)" : node.Name)</span>
        </div>
        @foreach (var child in node.Children.Where(c => c.IsFolder))
        {
            @RenderMoveFolderTree(child, depth + 1)
        }
    };

    void ExecuteMove()
    {
        if (string.IsNullOrEmpty(_moveSelectedFolder)) return;
        Console.WriteLine($"[PcFolder] Moved '{_moveFileName}' to '{_moveSelectedFolder}' by '{_userName}' — PC {PcId}");
        var ok = FolderSvc.MoveFile(PcId, _moveFilePath, _moveSelectedFolder, Solo);
        if (!ok)
        {
            ShowErrorToast($"A file named '{_moveFileName}' already exists in the destination folder.");
            _showMoveModal = false;
            return;
        }
        ExpandPathHierarchy(_moveSelectedFolder);
        RefreshFolder();
        _showMoveModal = false;
    }

    void CreateMoveDestFolder()
    {
        if (string.IsNullOrWhiteSpace(_moveNewFolderName)) return;
        var parent = string.IsNullOrEmpty(_moveSelectedFolder)
            ? _moveFileSection
            : _moveSelectedFolder;
        Console.WriteLine($"[PcFolder] Created destination folder '{_moveNewFolderName}' under '{parent}' by '{_userName}' — PC {PcId}");
        FolderSvc.CreateSubfolder(PcId, parent, _moveNewFolderName, Solo);
        RefreshFolder();
        _moveNewFolderName = "";
        _moveNewFolderMode = false;
    }

    // ── Drag & drop ──

    void OnDragStart(FolderTreeNode node, string section)
    {
        _dragNode = node;
        _dragSection = section;
        Console.WriteLine($"[PcFolder] Drag started: '{node.Name}' from {section} — PC {PcId}");
    }

    void OnDragEnd()
    {
        // Only clear if no confirmation dialog is pending
        if (!_showDragConfirm)
        {
            _dragNode = null;
            _dragSection = "";
        }
    }

    void OnTreeDrop(string folderRelPath, string section)
    {
        if (_dragNode == null || _dragNode.IsFolder || _dragSection != section)
        {
            _dragNode = null; _dragSection = "";
            return;
        }
        var srcFolder = Path.GetDirectoryName(_dragNode.RelativePath)?.Replace('\\', '/') ?? "";
        if (srcFolder == folderRelPath) { _dragNode = null; _dragSection = ""; return; }

        _dragConfirmFileName = _dragNode.Name;
        _dragConfirmFrom = FolderDisplayPath(srcFolder);
        _dragConfirmTo = FolderDisplayPath(folderRelPath);
        _dragConfirmToPath = folderRelPath;
        _showDragConfirm = true;
        Console.WriteLine($"[PcFolder] Drop requested: '{_dragNode.Name}' from '{srcFolder}' to '{folderRelPath}' — PC {PcId}");
    }

    void ExecuteDragMove()
    {
        if (_dragNode == null) return;
        if (IsFolderSummaryFile(_dragNode.Name, _dragNode.RelativePath))
        {
            ShowErrorToast("Folder Summary file cannot be moved to a different location.");
            _showDragConfirm = false;
            _dragNode = null; _dragSection = "";
            return;
        }
        Console.WriteLine($"[PcFolder] Drag move confirmed: '{_dragNode.RelativePath}' → '{_dragConfirmToPath}' by '{_userName}' — PC {PcId}");
        var ok = FolderSvc.MoveFile(PcId, _dragNode.RelativePath, _dragConfirmToPath, Solo);
        if (!ok)
        {
            ShowErrorToast($"A file named '{_dragNode.Name}' already exists in the destination folder.");
            _showDragConfirm = false;
            _dragNode = null; _dragSection = "";
            return;
        }
        ExpandPathHierarchy(_dragConfirmToPath);
        RefreshFolder();
        _showDragConfirm = false;
        _dragNode = null; _dragSection = "";
    }

    async void ShowErrorToast(string msg)
    {
        _errorToast = msg;
        StateHasChanged();
        await Task.Delay(3000);
        _errorToast = "";
        await InvokeAsync(StateHasChanged);
    }

    void CancelDragMove()
    {
        Console.WriteLine($"[PcFolder] Drag move cancelled by '{_userName}' — PC {PcId}");
        _showDragConfirm = false;
        _dragNode = null; _dragSection = "";
    }
}
