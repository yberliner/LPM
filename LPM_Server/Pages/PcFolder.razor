    void ConfirmRenameAtt()
    {
        if (!string.IsNullOrWhiteSpace(_renameAttValue))
        {
            Console.WriteLine($"[PcFolder] Renamed attachment '{_renameAttPath}' suffix to '{_renameAttValue}' by '{_userName}' — PC {PcId}");
            var oldPath = _renameAttPath;
            FolderSvc.RenameAttachment(PcId, _renameAttPath, _renameAttValue, Solo);
            RefreshFolder();

            // Update pane if renamed file is currently displayed
            // Build expected new filename: same prefix up to _att_ + new suffix
            var oldFileName = Path.GetFileName(oldPath);
            var attIdx = oldFileName.IndexOf("_att_", StringComparison.OrdinalIgnoreCase);
            if (attIdx >= 0)
            {
                var prefix = oldFileName[..(attIdx + 5)];
                var newSuffix = _renameAttValue;
                if (!newSuffix.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
                    newSuffix += ".pdf";
                var expectedNewName = prefix + newSuffix;
                var expectedNewPath = "WorkSheets/" + expectedNewName;

                for (int i = 0; i < _paneCount; i++)
                {
                    if (_panes[i].File == oldPath)
                    {
                        _panes[i].File = expectedNewPath;
                        _panes[i].FileName = expectedNewName;
                    }
                }
            }
        }
        CancelRenameAtt();
    }

    void CancelRenameAtt() { _isRenamingAtt = false; _renameAttPath = ""; _renameAttValue = ""; }

    // ── Excel editor methods ──

    void OnExcelCellEdit(int row, int col, string value)
    {
        _excelEdits[(row, col)] = value;
        _excelDirty = true;
        RecalcFormulas(row, col);
    }

    void RecalcFormulas(int editedRow, int editedCol)
    {
        if (_excelData == null) return;
        // Only B and C affect formulas
        if (editedCol != 2 && editedCol != 3) return;

        var dataRows = _excelData.Cells
            .Where(c => c.Row >= 7)
            .Select(c => c.Row).Distinct().OrderBy(r => r).ToList();

        // Recalc D for the edited row: D = C*60/B
        {
            double b = GetEffectiveNumeric(editedRow, 2);
            double c = GetEffectiveNumeric(editedRow, 3);
            _formulaOverrides[(editedRow, 4)] = b != 0 ? (c * 60 / b).ToString("0.##") : "0";
        }

        // If B changed, recalc E for edited row and all below: E = cumulative sum of B / 1440 as [h]:mm
        if (editedCol == 2)
        {
            double cumSum = 0;
            foreach (var r in dataRows)
            {
                cumSum += GetEffectiveNumeric(r, 2);
                double totalMinutes = cumSum / 1440.0 * 24 * 60; // back to minutes
                int hours = (int)(cumSum / 60);
                int mins = (int)(cumSum % 60);
                _formulaOverrides[(r, 5)] = $"{hours}:{mins:D2}";
            }
        }
    }

    string FormatFormulaCell(string value, int col)
    {
        // Column D is numeric — limit to 2 decimal places
        if (col == 4 && double.TryParse(value, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var num))
            return num.ToString("0.##");
        return value;
    }

    double GetEffectiveNumeric(int row, int col)
    {
        string val;
        if (_excelEdits.TryGetValue((row, col), out var edited))
            val = edited;
        else
            val = _excelData?.Cells.FirstOrDefault(c => c.Row == row && c.Col == col)?.Value ?? "0";
        return double.TryParse(val, System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out var num) ? num : 0;
    }

    void SaveExcelChanges()
    {
        if (!_excelDirty || string.IsNullOrEmpty(_excelRelPath)) return;
        var updates = _excelEdits
            .Select(kv => new FolderService.ExcelCellUpdate(kv.Key.Row, kv.Key.Col, kv.Value))
            .ToList();
        // Save Action field (B4) if edited
        if (_excelActionEdit != null)
            updates.Add(new FolderService.ExcelCellUpdate(4, 2, _excelActionEdit));
        Console.WriteLine($"[PcFolder] Saving {updates.Count} Excel changes to '{_excelRelPath}' by '{_userName}' — PC {PcId}");
        FolderSvc.SaveExcelChanges(PcId, _excelRelPath, updates, Solo);
        // Reload
        _excelData = FolderSvc.ReadExcelFile(PcId, _excelRelPath, Solo);
        _excelEdits.Clear();
        _formulaOverrides.Clear();
        _excelActionEdit = null;
        _excelDirty = false;
    }

    void AddExcelRow()
    {
        if (string.IsNullOrEmpty(_excelRelPath)) return;
        // Save pending edits first
        if (_excelDirty) SaveExcelChanges();
        Console.WriteLine($"[PcFolder] Adding Excel row to '{_excelRelPath}' by '{_userName}' — PC {PcId}");
        FolderSvc.AddExcelRow(PcId, _excelRelPath, Solo);
        _excelData = FolderSvc.ReadExcelFile(PcId, _excelRelPath, Solo);
        _excelEdits.Clear();
        _formulaOverrides.Clear();
        _excelDirty = false;
    }

    void DeleteExcelRow(int row)
    {
        if (string.IsNullOrEmpty(_excelRelPath)) return;
        Console.WriteLine($"[PcFolder] Deleting Excel row {row} from '{_excelRelPath}' by '{_userName}' — PC {PcId}");
        FolderSvc.DeleteExcelRow(PcId, _excelRelPath, row, Solo);
        _excelData = FolderSvc.ReadExcelFile(PcId, _excelRelPath, Solo);
        _excelEdits.Clear();
        _formulaOverrides.Clear();
        _excelDirty = false;
    }

