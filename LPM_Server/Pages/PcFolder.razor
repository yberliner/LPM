    Dictionary<string, (int page, int total)> _dualInfo = new();
    bool    _showEditSummary;
    int     _editSummaryId;
    string  _editSummaryHtml    = "";
    string? _editSummaryArfJson = null;

    // ── Folder Summary modal ──
    bool   _showFsModal;
    bool   _fsModeMaximized;
    bool   _showFsEditModal;
    List<DashboardService.SessionSummaryEditInfo> _fsEntries = new();
    int?   _fsEditingId;

    // Computed initial width for the Session Name column based on longest entry
    int FsNameColWidth => _fsEntries.Count == 0 ? 120
        : Math.Clamp(_fsEntries.Max(e => e.Name.Length) * 7, 80, 220);

    static readonly int[] _fontSizes = [10, 12, 14, 18, 24, 32, 40, 56];
    static readonly string[] _palette = [
        "#000000", "#ffffff", "#e11d48", "#f97316", "#eab308",
        "#22c55e", "#06b6d4", "#3b82f6", "#8b5cf6", "#ec4899",
        "#78716c", "#475569", "#dc2626", "#16a34a", "#2563eb"
    ];

    List<WorkSheetItem> GetWsPage(out int totalPages)
    {
        var sorted = _folder!.WorkSheets
            .OrderByDescending(ws =>
            {
                var name = SessionDisplayName(ws.File.FileName);
                return _nameToCreatedAt.TryGetValue(name, out var dt) ? dt : DateTime.MinValue;
            })
            .ToList();
        var filtered = string.IsNullOrWhiteSpace(_wsFilter)
            ? sorted
            : sorted.Where(ws => SessionDisplayName(ws.File.FileName)
                    .Contains(_wsFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)WsPageSize));
        if (_wsPage >= totalPages) _wsPage = totalPages - 1;
        return filtered.Skip(_wsPage * WsPageSize).Take(WsPageSize).ToList();
    }

    int WsTotalPages => _folder == null ? 1 : Math.Max(1,
        (int)Math.Ceiling((_folder.WorkSheets.Count(ws =>
            string.IsNullOrWhiteSpace(_wsFilter) ||
            SessionDisplayName(ws.File.FileName).Contains(_wsFilter, StringComparison.OrdinalIgnoreCase)))
        / (double)WsPageSize));

    int WsFilteredCount => _folder == null ? 0 : _folder.WorkSheets.Count(ws =>
        string.IsNullOrWhiteSpace(_wsFilter) ||
        SessionDisplayName(ws.File.FileName).Contains(_wsFilter, StringComparison.OrdinalIgnoreCase));

    void OnWsFilterChanged(ChangeEventArgs e)
    {
        _wsFilter = e.Value?.ToString() ?? "";
        _wsPage = 0;
    }

    void ClearWsFilter()
    {
        _wsFilter = "";
        _wsPage = 0;
    }

    string IsFileActive(string relativePath)
    {
        for (int i = 0; i < _paneCount; i++)
        {
            if (relativePath == _panes[i].File)
                return "pcf-file-active-" + PaneIds[i];
        }
        return "";
    }

    protected override void OnInitialized()
    {
        // Guard: enforce folder access rules — use cookie StaffRole claim (unique per login)
        // NOT IsSoloAuditor(PersonId) which returns true for dual-role users (Auditor + Solo)
        var _pcfStaffRole = HttpContextAccessor.HttpContext?.User.FindFirst("StaffRole")?.Value ?? "";
        var _pcfUsername  = HttpContextAccessor.HttpContext?.User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "";
        if (_pcfStaffRole == "Solo")
        {
            // Solo user: can only open their own PC's solo folder
            if (PcId != UserPersonId || !Solo)
            {
                NavManager.NavigateTo($"/PcFolder/{UserPersonId}?solo=true", replace: true);
                return;
            }
        }
        else
        {
            if (!DashSvc.CanAccessPcFolder(UserPersonId, PcId, _pcfUsername))
            {
                NavManager.NavigateTo("/Home", replace: true);
                return;
            }
        }

        // Restore preferences from cookies (before first render — no flicker)
        var cookies = HttpContextAccessor.HttpContext?.Request.Cookies;
        if (cookies != null)
        {
            if (cookies.TryGetValue("lpmVoiceOn", out var vc) && vc == "true") _voiceOn = true;
            if (cookies.TryGetValue("lpmFontSize", out var fc) && int.TryParse(fc, out var fs) && _fontSizes.Contains(fs)) _fontSize = fs;
            if (cookies.TryGetValue("lpmStrokeWidth", out var wc) && double.TryParse(wc, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var dw) && _strokeWidths.Contains(dw)) _drawWidth = dw;
        }

        _userName = DashSvc.GetPersonName(UserPersonId) ?? $"User {UserPersonId}";
        RefreshFolder();
        EnsureFolderSummaryExists();
        _pcName = FolderSvc.GetPcName(PcId) ?? $"PC {PcId}";
        _programInsertFiles = FolderSvc.GetProgramInsertFiles();
        Console.WriteLine($"[PcFolder] Opened PC folder for '{_pcName}' (PC {PcId}) by '{_userName}'{(SessionId > 0 ? $" — CS session {SessionId}" : "")}");
        _csedSessionIds = DashSvc.GetCsedSessionIdsForPc(PcId, isSolo: Solo);
        foreach (var pair in DashSvc.GetSessionsForPc(PcId, isSolo: Solo))
        {
            if (!string.IsNullOrEmpty(pair.Name))
            {
                _nameToSessionId.TryAdd(pair.Name, pair.SessionId);
                if (DateTime.TryParse(pair.CreatedAt, out var dt))
                    _nameToCreatedAt.TryAdd(pair.Name, dt);
            }
        }

        // Session ID passed from Dashboard "CS The Session" button (via host page parameter)
        _csSessionId = SessionId;

        // Derive session name and review time from DB
        if (_csSessionId > 0)
        {
            _csSessionName = DashSvc.GetSessionName(_csSessionId);
            _csReviewMinutes = (int)Math.Round(DashSvc.GetSessionTotalSeconds(_csSessionId) / 60.0);

            // Check if another tab is already CSing this session
            var userName = DashSvc.GetPersonName(UserPersonId) ?? $"User {UserPersonId}";
            if (_activeCsSessions.TryGetValue(_csSessionId, out var existingUser))
            {
                _csLocked = true;
                _csLockedBy = existingUser;
                Console.WriteLine($"[PcFolder] CS session {_csSessionId} LOCKED — already being CSed by '{existingUser}', attempted by '{_userName}'");
            }
            else
            {
                _activeCsSessions[_csSessionId] = userName;
                Console.WriteLine($"[PcFolder] CS session {_csSessionId} ('{_csSessionName}') started by '{_userName}' for PC {PcId}");
            }
            _csAlreadyDone = _csedSessionIds.Contains(_csSessionId);
            if (_csAlreadyDone)
                Console.WriteLine($"[PcFolder] CS session {_csSessionId} already reviewed — Done button disabled for '{_userName}'");
        }

        WorkSheetItem? match = null;
        if (!string.IsNullOrWhiteSpace(_csSessionName) && _folder != null)
        {
            match = _folder.WorkSheets
                .FirstOrDefault(ws => SessionDisplayName(ws.File.FileName)
                    .Equals(_csSessionName, StringComparison.OrdinalIgnoreCase));
            if (match == null)
                Console.WriteLine($"ERROR: [PcFolder] CS session file missing — session='{_csSessionName}' (ID={_csSessionId}), PC={PcId}, user='{_userName}'");
        }

        if (match != null)
        {
            _panes[0].File = match.File.RelativePath;
            _panes[0].FileName = SessionDisplayName(match.File.FileName);
            _panes[0].Section = "WorkSheet";
            var attCount = Math.Min(match.Attachments.Count, 2);
            if (attCount > 0)
            {
                _paneCount = 1 + attCount;
                _activeIdx = attCount; // select last pane so session stays in pane 0
                for (int i = 0; i < attCount; i++)
                {
                    _panes[i + 1].File = match.Attachments[i].RelativePath;
                    _panes[i + 1].FileName = match.Attachments[i].FileName;
                    _panes[i + 1].Section = "WorkSheet";
                }
            }
            // 3rd attachment can't fit in any pane — open in float window
            if (match.Attachments.Count >= 3)
            {
                _floatAttFile = match.Attachments[2].RelativePath;
                _floatAttName = match.Attachments[2].FileName;
            }
        }
        else if (_folder?.WorkSheets.Count > 0)
        {
            var latest = _folder.WorkSheets[0];
            _panes[0].File = latest.File.RelativePath;
            _panes[0].FileName = SessionDisplayName(latest.File.FileName);
            _panes[0].Section = "WorkSheet";
            if (latest.Attachments.Count > 0)
            {
                _paneCount = 2;
                _activeIdx = 1; // select last pane so session stays in pane 0
                var firstAtt = latest.Attachments[0];
                _panes[1].File = firstAtt.RelativePath;
                _panes[1].FileName = firstAtt.FileName;
                _panes[1].Section = "WorkSheet";
            }
        }
    }

    DotNetObjectReference<PcFolder>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pcfViewer.setDotNetRef", _dotNetRef);
            await JS.InvokeVoidAsync("pcfViewer.setPcId", PcId);
            await JS.InvokeVoidAsync("pcfViewer.setTextSelectMode", true);

            // Load all panes in parallel — each loadPdf is independent
            var paneTasks = new List<Task>();
            for (int i = 0; i < _paneCount; i++)
            {
                if (!string.IsNullOrEmpty(_panes[i].File))
                {
                    var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(_panes[i].File!)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
                    var paneId = PaneIds[i];
                    paneTasks.Add(JS.InvokeVoidAsync("pcfViewer.loadPdf", url, paneId).AsTask());
                }
            }
            // If 3rd attachment couldn't fit in a pane, open it in the float window — in parallel with pane loads
            if (!string.IsNullOrEmpty(_floatAttFile))
            {
                var floatUrl = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(_floatAttFile)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
                paneTasks.Add(JS.InvokeVoidAsync("pcfViewer.floatFile", floatUrl, _floatAttName ?? _floatAttFile).AsTask());
            }
            await Task.WhenAll(paneTasks);

            // (context menu attachment happens for all renders below)

            // Load Ctrl+key shortcuts
            try
            {
                var sc = ShortcutSvc.GetShortcuts();
                await JS.InvokeVoidAsync("lpmLoadShortcuts", sc);
            }
            catch { }

            // Drag-and-drop: handle dragover/dragleave on drop zones and tree folders
            await JS.InvokeVoidAsync("eval", @"
                (function() {
                    var sidebar = document.querySelector('.pcf-sidebar');
                    if (!sidebar || sidebar._dragSetup) return;
                    sidebar._dragSetup = true;
                    sidebar.addEventListener('dragover', function(e) {
                        var zone = e.target.closest('.pcf-drop-zone, .pcf-tree-folder, .pcf-file-item');
                        if (zone) { e.preventDefault(); zone.classList.add('pcf-drop-target'); }
                    });
                    sidebar.addEventListener('dragleave', function(e) {
                        var zone = e.target.closest('.pcf-drop-zone, .pcf-tree-folder, .pcf-file-item');
                        if (zone && !zone.contains(e.relatedTarget)) {
                            zone.classList.remove('pcf-drop-target');
                        }
                    });
                    sidebar.addEventListener('drop', function(e) {
                        sidebar.querySelectorAll('.pcf-drop-target').forEach(function(el) {
                            el.classList.remove('pcf-drop-target');
                        });
                    });
                })();
            ");

            // Ctrl+Z → Undo
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('keydown', function(e) {
                    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
                        var el = document.activeElement;
                        if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA')) return;
                        e.preventDefault();
                        if (window.pcfViewer && window.pcfViewer.dotNetRef)
                            window.pcfViewer.dotNetRef.invokeMethodAsync('OnCtrlZ');
                    }
                });
            ");

            // Arrow keys → dual-page navigation
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('keydown', function(e) {
                    if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
                    var el = document.activeElement;
                    if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.tagName === 'SELECT')) return;
                    if (window.pcfViewer && window.pcfViewer.dotNetRef)
                        window.pcfViewer.dotNetRef.invokeMethodAsync('OnArrowKey', e.key === 'ArrowRight' ? 1 : -1);
                });
            ");

            // Apply restored preferences to the JS viewer
            if (_fontSize != 14)
                await JS.InvokeVoidAsync("pcfViewer.setFontSize", _fontSize);
            if (_drawWidth != 2.5)
                await JS.InvokeVoidAsync("pcfViewer.setWidth", _drawWidth);

            // Voice commands — dynamically load script if not already present
            try
            {
                // Inject loader helper once, then call it — handles both pre-loaded and missing script
                await JS.InvokeVoidAsync("eval", @"
                    window._lpmEnsureVoice = window._lpmEnsureVoice || function() {
                        return new Promise(function(resolve) {
                            if (window.lpmVoice) { resolve(); return; }
                            var s = document.createElement('script');
                            s.src = '/js/voice-commands.js';
                            s.onload = function() { console.log('[lpmVoice] loaded dynamically'); resolve(); };
                            s.onerror = function() { console.error('[lpmVoice] failed to load /js/voice-commands.js'); resolve(); };
                            document.head.appendChild(s);
                        });
                    };
                ");
                await JS.InvokeVoidAsync("_lpmEnsureVoice");
                await JS.InvokeVoidAsync("lpmVoice.init", _dotNetRef, PaneIds[_activeIdx]);
                if (_voiceOn) await JS.InvokeVoidAsync("lpmVoice.start");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[PcFolder] Voice init error: {ex.Message}");
                await JS.InvokeVoidAsync("console.error", "[PcFolder] Voice init error: " + ex.Message);
            }
        }

        if (_pendingReloads != null)
        {
            var reloads = _pendingReloads;
            _pendingReloads = null;

            // Capture current page positions before reload
            var savedPages = new Dictionary<string, int>();
            foreach (var (paneId, _) in reloads)
            {
                try { savedPages[paneId] = await JS.InvokeAsync<int>("pcfViewer.getCurrentPage", paneId); }
                catch { savedPages[paneId] = 0; }
            }

            // Prepare urls + capture dual state synchronously before any awaits
            var items = reloads.Select(item =>
            {
                var (paneId, file) = item;
                var endpoint = IsFolderSummaryFile(Path.GetFileName(file), file)
                    ? "/api/pc-file-folder-summary"
                    : "/api/pc-file";
                var url = $"{endpoint}?pcId={PcId}&path={Uri.EscapeDataString(file)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
                bool wasDual = _dualPanes.Contains(paneId);
                int savedPage = savedPages.GetValueOrDefault(paneId, 0);
                _dualPanes.Remove(paneId);
                _dualInfo.Remove(paneId);
                return (paneId, url, wasDual, savedPage);
            }).ToList();

            // Load all panes in parallel
            await Task.WhenAll(items.Select(i =>
                JS.InvokeVoidAsync("pcfViewer.loadPdf", i.url, i.paneId).AsTask()));

            // Restore dual mode (with saved page) and scroll position after all panes are loaded
            foreach (var (paneId, _, wasDual, savedPage) in items)
            {
                if (wasDual)
                {
                    var result = await JS.InvokeAsync<int[]>("pcfViewer.enterDualMode", paneId, savedPage);
                    if (result != null && result.Length == 2 && result[1] > 0)
                    {
                        _dualPanes.Add(paneId);
                        _dualInfo[paneId] = (result[0], result[1]);
                    }
                }
                else if (savedPage > 0)
                {
                    await JS.InvokeVoidAsync("pcfViewer.scrollToPage", paneId, savedPage);
                }
            }

            StateHasChanged();
        }

        // Session pane maximize: no reload was issued — enter dual mode on already-rendered pages
        if (_pendingDualPaneId != null)
        {
            var paneId = _pendingDualPaneId;
            _pendingDualPaneId = null;
            int savedPage = 0;
            try { savedPage = await JS.InvokeAsync<int>("pcfViewer.getCurrentPage", paneId); }
            catch { }
            var result = await JS.InvokeAsync<int[]>("pcfViewer.enterDualMode", paneId, savedPage);
            if (result != null && result.Length == 2 && result[1] > 0)
            {
                _dualPanes.Add(paneId);
                _dualInfo[paneId] = (result[0], result[1]);
                await JS.InvokeVoidAsync("pcfViewer.showExpandAnimation", paneId);
                StateHasChanged();
            }
        }

        // Attach right-click handler for any newly-rendered pane viewers.
        // Called every render; JS guards against double-attachment via _ctxMenuAttached flag.
        try
        {
            for (int i = 0; i < 3; i++)
                await JS.InvokeVoidAsync("pcfViewer.attachPageContextMenu", PaneIds[i]);
        }
        catch { }
    }

    [JSInvokable]
