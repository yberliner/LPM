    async Task OnInsertFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.GetMultipleFiles(1).FirstOrDefault();
        if (file == null) return;

        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
        var rawBytes = ms.ToArray();

        var ext = Path.GetExtension(file.Name);
        if (FolderService.ConvertibleExtensions.Contains(ext))
        {
            // Background conversion with toast, then insert
            var toast = new ConversionToast(Guid.NewGuid(), file.Name);
            _conversionToasts.Add(toast);
            var paneId = _pageBgPaneId;
            var pageIdx = _pageBgPageIdx;
            _ = RunInsertConversionAsync(toast, rawBytes, file.Name, paneId, pageIdx);
        }
        else
        {
            // PDF — insert directly as data URL
            var dataUrl = "data:application/pdf;base64," + Convert.ToBase64String(rawBytes);
            var count = await JS.InvokeAsync<int>("pcfViewer.insertPdfPages", _pageBgPaneId, _pageBgPageIdx, dataUrl);
            Console.WriteLine($"[PcFolder] Inserted {count} pages from '{file.Name}' above page {_pageBgPageIdx + 1} in pane {_pageBgPaneId} by '{_userName}' — PC {PcId}");
            if (count > 0) _hasAnnotations = true;
        }
    }

    async Task RunInsertConversionAsync(ConversionToast toast, byte[] docBytes, string originalName, string paneId, int pageIdx)
    {
        try
        {
            var pdfBytes = await Task.Run(() => FolderSvc.ConvertToPdf(docBytes, originalName));
            if (pdfBytes == null)
            {
                toast.Status = ConvStatus.Failed;
                await InvokeAsync(StateHasChanged);
                return;
            }

            toast.Status = ConvStatus.Done;
            await InvokeAsync(StateHasChanged);

            var dataUrl = "data:application/pdf;base64," + Convert.ToBase64String(pdfBytes);
            int count = 0;
            await InvokeAsync(async () =>
            {
                count = await JS.InvokeAsync<int>("pcfViewer.insertPdfPages", paneId, pageIdx, dataUrl);
            });
            Console.WriteLine($"[PcFolder] Inserted {count} pages from '{originalName}' above page {pageIdx + 1} in pane {paneId} by '{_userName}' — PC {PcId}");
            if (count > 0) _hasAnnotations = true;

            await Task.Delay(3000);
            _conversionToasts.Remove(toast);
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[PcFolder] Insert conversion error for '{originalName}': {ex.Message}");
            toast.Status = ConvStatus.Failed;
            await InvokeAsync(StateHasChanged);
        }
    }

