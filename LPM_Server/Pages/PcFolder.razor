    async Task SelectFile(string relativePath, string fileName, string section = "")
    {
        var idx = _paneCount == 1 ? 0 : _activeIdx;
        var paneId = PaneIds[idx];

        // Auto-save current pane before switching
        await JS.InvokeVoidAsync("pcfViewer.savePane", paneId);

        _panes[idx].File = relativePath;
        _panes[idx].FileName = StripDatePrefix(fileName);
        _panes[idx].Section = section;

        _hasAnnotations = false;
        _toolMode = "";
        StateHasChanged();

        var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(relativePath)}&_t={DateTime.UtcNow.Ticks}";
        await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, paneId);
        await JS.InvokeVoidAsync("pcfViewer.setTool", "");
    }

    void SetActiveIdx(int idx)
    {
        if (_activeIdx == idx) return;
        _activeIdx = idx;
        var paneId = PaneIds[idx];
        _ = JS.InvokeAsync<bool>("pcfViewer.hasAnnotations", paneId).AsTask().ContinueWith(t =>
        {
            if (t.IsCompletedSuccessfully)
            {
                _hasAnnotations = t.Result;
                InvokeAsync(StateHasChanged);
            }
        });
    }

    async Task CyclePanes()
    {
        var oldCount = _paneCount;
        var newCount = oldCount >= 3 ? 1 : oldCount + 1;

        // Auto-save panes being removed
        for (int i = newCount; i < oldCount; i++)
            await JS.InvokeVoidAsync("pcfViewer.savePane", PaneIds[i]);

        // Clear removed panes
        for (int i = newCount; i < 3; i++)
        {
            _panes[i].File = null;
            _panes[i].FileName = null;
            _panes[i].Section = "";
        }

        _paneCount = newCount;

        // Clamp active pane
        if (_activeIdx >= newCount)
            _activeIdx = 0;

        // When adding panes, set active to the new empty one
        if (newCount > oldCount)
            _activeIdx = newCount - 1;

        // Schedule reload of all existing panes to fit new width
        var reloads = new List<(string, string)>();
        for (int i = 0; i < newCount; i++)
        {
            if (!string.IsNullOrEmpty(_panes[i].File))
                reloads.Add((PaneIds[i], _panes[i].File!));
        }
        if (reloads.Count > 0)
            _pendingReloads = reloads;

        await JS.InvokeVoidAsync("pcfViewer.setActivePane", PaneIds[_activeIdx]);
    }

    async Task SetTool(string mode)
    {
        _toolMode = _toolMode == mode ? "" : mode;
        await JS.InvokeVoidAsync("pcfViewer.setTool", _toolMode);
    }

    async Task Undo()
    {
        await JS.InvokeVoidAsync("pcfViewer.undo", PaneIds[_activeIdx]);
        _hasAnnotations = await JS.InvokeAsync<bool>("pcfViewer.hasAnnotations", PaneIds[_activeIdx]);
    }

    [JSInvokable]
    public async Task OnCtrlZ()
    {
        await Undo();
    }

    bool _showAddPageMenu;

    void ToggleAddPageMenu() => _showAddPageMenu = !_showAddPageMenu;

    async Task AddBlankPageAbove()
    {
        _showAddPageMenu = false;
        await JS.InvokeVoidAsync("pcfViewer.addBlankPage", PaneIds[_activeIdx], "above");
    }

    async Task AddBlankPageBelow()
    {
        _showAddPageMenu = false;
        await JS.InvokeVoidAsync("pcfViewer.addBlankPage", PaneIds[_activeIdx], "below");
    }

    async Task PickColor(string color)
    {
        _drawColor = color;
        _showColors = false;
        await JS.InvokeVoidAsync("pcfViewer.setColor", color);
    }

    async Task PickSize(int size)
    {
        _fontSize = size;
        _showSizes = false;
        await JS.InvokeVoidAsync("pcfViewer.setFontSize", size);
    }

    async Task SaveAnnotations()
    {
        var file = _panes[_activeIdx].File;
        if (string.IsNullOrEmpty(file)) return;
        _saving = true;
        StateHasChanged();

        try
        {
            var paneId = PaneIds[_activeIdx];
            var pagesJson = await JS.InvokeAsync<string>("pcfViewer.getAnnotatedPdf", paneId);
            await JS.InvokeVoidAsync("pcfSaveAnnotatedPdf", PcId, file, pagesJson);

            _hasAnnotations = false;
            var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(file)}&_t={DateTime.UtcNow.Ticks}";
            await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, paneId);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    void OnTimerHoursChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var h) && h >= 0)
            _csReviewMinutes = h * 60 + (_csReviewMinutes % 60);
        else
            _csReviewMinutes = _csReviewMinutes % 60;
    }

    void OnTimerMinsChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var m) && m >= 0)
            _csReviewMinutes = (_csReviewMinutes / 60) * 60 + Math.Min(m, 59);
        else
            _csReviewMinutes = (_csReviewMinutes / 60) * 60;
    }

    async Task DoneCs()
    {
        if (_csSessionId == 0) return;

        // Validate review time — if 0, warn user and abort
        if (_csReviewMinutes <= 0)
        {
            await JS.InvokeVoidAsync("alert",
                "Review time is 0 minutes. Please update the session's admin time before marking CS as done.");
            return;
        }

        // Auto-save all visible panes
        for (int i = 0; i < _paneCount; i++)
            await JS.InvokeVoidAsync("pcfViewer.savePane", PaneIds[i]);

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            $"Mark this session's CS review as done?\nReview time: {_csReviewMinutes} minutes");
        if (!confirmed) return;

        try
        {
            // Create cs_review if one doesn't already exist — use the GUI value
            if (!DashSvc.HasCsReview(_csSessionId))
            {
                var reviewSec = _csReviewMinutes * 60;
                DashSvc.AddCsReview(csId: UserPersonId, sessionId: _csSessionId,
                    reviewSec: reviewSec, status: "Draft", notes: null);
            }

            // Refresh the CSed session IDs so sidebar turns green
            _csedSessionIds = DashSvc.GetCsedSessionIdsForPc(PcId);
            _csDone = true;
            StateHasChanged();

            // Notify other tabs (Dashboard) that a CS review was completed
            await JS.InvokeVoidAsync("eval",
                "try { new BroadcastChannel('lpm-cs-done').postMessage('done'); } catch(e) {}");

            // Notify all connected users who have permission for this PC
            _ = CsNotifySvc.NotifyCsDone(PcId, DashSvc.UserHasApprovedPcOnDashboard);

            // Try to close the tab (works if opened via window.open)
            await JS.InvokeVoidAsync("window.close");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Failed to mark CS done: {ex.Message}");
        }
    }

    public void Dispose()
    {
        // Unregister this session from active CS tracker (only if we own it)
        if (_csSessionId > 0 && !_csLocked)
            _activeCsSessions.TryRemove(_csSessionId, out _);
        _dotNetRef?.Dispose();
    }

    // ── Cover file type detection for color-coded borders ──
    static string GetCoverBorderColor(string fileName)
    {
        var nameNoExt = Path.GetFileNameWithoutExtension(fileName);
        // Strip date prefixes: yyMMdd or yy-MM-dd_
        if (nameNoExt.Length >= 7)
        {
            var prefix = nameNoExt.Substring(0, 6);
            if (prefix.All(char.IsDigit) && !char.IsDigit(nameNoExt[6]))
                nameNoExt = nameNoExt.Substring(6).TrimStart(' ', '_', '-');
        }
        if (nameNoExt.Length >= 9 && nameNoExt[2] == '-' && nameNoExt[5] == '-' && nameNoExt[8] == '_')
            nameNoExt = nameNoExt.Substring(9);

        var lower = nameNoExt.ToLowerInvariant().Replace("_", " ").Replace("-", " ").Replace(".", " ");

        if (lower.Contains("folder summary") || lower.Contains("summary")) return "#f59e0b"; // amber
        if (lower.Contains("process")) return "#3b82f6"; // blue
        if (lower.Contains("case progress") || lower.Contains("progress sheet") || lower.Contains("cps") || lower.Contains("case data")) return "#a855f7"; // purple
        if (lower.Contains("program") || lower.Contains("prog")) return "#22c55e"; // green
        if (lower.Contains("oca")) return "#f97316"; // orange
        if (lower.Contains("yellow")) return "#eab308"; // yellow
        if (lower.Contains("fes")) return "#ec4899"; // pink
        if (lower.Contains("dn flow") || lower.Contains("flow table") || lower.Contains("dnflow")) return "#14b8a6"; // teal
        if (lower.Contains("routing")) return "#6366f1"; // indigo
        if (lower.Contains("invoice")) return "#64748b"; // slate

        return "";
    }

    static string HexToRgb(string hex)
    {
        if (string.IsNullOrEmpty(hex) || hex.Length != 7) return "255,255,255";
        var r = Convert.ToInt32(hex.Substring(1, 2), 16);
        var g = Convert.ToInt32(hex.Substring(3, 2), 16);
        var b = Convert.ToInt32(hex.Substring(5, 2), 16);
        return $"{r},{g},{b}";
    }

    static string StripDatePrefix(string fileName)
    {
        var name = Path.GetFileNameWithoutExtension(fileName);
        if (name.Length > 9 && name[2] == '-' && name[5] == '-' && name[8] == '_')
            name = name[9..];
        return name;
    }
}
