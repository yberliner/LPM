    static string FsFormatDate(string dateStr) =>
        DateTime.TryParse(dateStr, out var dt) ? dt.ToString("dd-MM-yy") : dateStr;

    static string FsFormatTime(string dateStr) =>
        DateTime.TryParse(dateStr, out var dt) && dt.TimeOfDay > TimeSpan.Zero ? dt.ToString("HH:mm") : "";

    static string FsSecsToHMM(int secs) => secs <= 0 ? "" : $"{secs / 3600}:{(secs % 3600) / 60:D2}";

    void SetActiveIdx(int idx)
    {
        if (_activeIdx == idx) return;
        if (_extractMode) _ = CancelExtract();
        _activeIdx = idx;
        var paneId = PaneIds[idx];
        _ = Task.Run(async () =>
        {
            try
            {
                var ha = await JS.InvokeAsync<bool>("pcfViewer.hasAnnotations", paneId);
                var zp = await JS.InvokeAsync<int>("pcfViewer.getZoomPercent", paneId);
                await InvokeAsync(() =>
                {
                    _hasAnnotations = ha;
                    _zoomPercent = zp;
                    StateHasChanged();
                });
            }
            catch { }
        });
    }

    async Task CyclePanes() =>
        await SetPaneCount(_paneCount >= 3 ? 1 : _paneCount + 1);

    async Task SetPaneCount(int newCount)
    {
        _maximizedPane = null; // always exit maximize mode when changing pane layout
        if (newCount == _paneCount) return;
        newCount = Math.Clamp(newCount, 1, 3);
        var oldCount = _paneCount;
        Console.WriteLine($"[PcFolder] Changed pane count to {newCount} by '{_userName}' — for PC {PcId}");

        // Cancel any in-flight PDF renders BEFORE the layout changes.
        for (int i = 0; i < oldCount; i++)
            if (!string.IsNullOrEmpty(_panes[i].File) && !_panes[i].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                await JS.InvokeVoidAsync("pcfViewer.cancelLoad", PaneIds[i]);

        // Save panes being hidden in parallel (keep File/FileName — just hidden, not closed)
        if (newCount < oldCount)
        {
            await Task.WhenAll(Enumerable.Range(newCount, oldCount - newCount)
                .Select(i => JS.InvokeVoidAsync("pcfViewer.savePane", PaneIds[i]).AsTask()));
        }

        // Pane count is show/hide only — do NOT clear hidden panes' state.
        // Exception: if a hidden pane holds the same file as a currently-visible pane,
        // clear it to prevent two panes editing the same file simultaneously (data mismatch).
        if (newCount > oldCount)
        {
            var visibleFiles = Enumerable.Range(0, oldCount)
                                         .Where(i => !string.IsNullOrEmpty(_panes[i].File))
                                         .Select(i => _panes[i].File!)
                                         .ToHashSet(StringComparer.OrdinalIgnoreCase);

            for (int i = oldCount; i < newCount; i++)
            {
                if (!string.IsNullOrEmpty(_panes[i].File) && visibleFiles.Contains(_panes[i].File!))
                {
                    _panes[i].File     = null;
                    _panes[i].FileName = null;
                    _panes[i].Section  = "";
                    _dualPanes.Remove(PaneIds[i]);
                    _dualInfo.Remove(PaneIds[i]);
                }
            }
        }

        _paneCount = newCount;

        // Clamp active pane to visible range
        if (_activeIdx >= newCount)
            _activeIdx = 0;

        // When revealing panes, move focus to the first newly-visible empty slot (if any)
        if (newCount > oldCount)
        {
            var firstEmpty = Enumerable.Range(oldCount, newCount - oldCount)
                                       .FirstOrDefault(i => string.IsNullOrEmpty(_panes[i].File), -1);
            if (firstEmpty >= 0) _activeIdx = firstEmpty;
        }

        // Reload all visible panes so they re-render at the new width
        var reloads = new List<(string, string)>();
        for (int i = 0; i < newCount; i++)
        {
            if (!string.IsNullOrEmpty(_panes[i].File) && !_panes[i].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                reloads.Add((PaneIds[i], _panes[i].File!));
        }
        if (reloads.Count > 0)
            _pendingReloads = reloads;

        await JS.InvokeVoidAsync("pcfViewer.setActivePane", PaneIds[_activeIdx]);
    }

    async Task MaximizePane(int idx)
    {
        if (_paneCount == 1) return;
        Console.WriteLine($"[PcFolder] Maximized pane {idx} ('{_panes[idx].FileName}') by '{_userName}' — PC {PcId}");
        _maximizedPane = idx;
        _activeIdx = idx;

        // Session pane going to dual mode: skip the reload entirely.
        // In split view each pane is ~half-screen wide; in maximized+dual mode each
        // page is also ~half-screen wide — identical resolution, zoom ≈ 1, no quality
        // loss. The reload would re-render at full width only to be halved immediately.
        bool isSessionPane = !string.IsNullOrEmpty(_csSessionName)
            && !string.IsNullOrEmpty(_panes[idx].File)
            && SessionDisplayName(Path.GetFileName(_panes[idx].File!))
                .Equals(_csSessionName, StringComparison.OrdinalIgnoreCase);
        if (isSessionPane && !_dualPanes.Contains(PaneIds[idx]))
            _pendingDualPaneId = PaneIds[idx];
        else if (!string.IsNullOrEmpty(_panes[idx].File) && !_panes[idx].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
            _pendingReloads = [(PaneIds[idx], _panes[idx].File!)];  // normal maximize: reload for full-width sharpness

        await JS.InvokeVoidAsync("pcfViewer.setActivePane", PaneIds[idx]);
    }

    async Task RestorePane()
    {
        var idx = _maximizedPane ?? _activeIdx;
        Console.WriteLine($"[PcFolder] Restored from maximize by '{_userName}' — PC {PcId}");
        _maximizedPane = null;
        // Reload all visible panes so they re-fit their now-narrower viewports
        var reloads = new List<(string, string)>();
        for (int i = 0; i < _paneCount; i++)
            if (!string.IsNullOrEmpty(_panes[i].File) && !_panes[i].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                reloads.Add((PaneIds[i], _panes[i].File!));
        if (reloads.Count > 0)
            _pendingReloads = reloads;
        await JS.InvokeVoidAsync("pcfViewer.setActivePane", PaneIds[idx]);
    }

    async Task ClosePane(int idx)
    {
        Console.WriteLine($"[PcFolder] Closed pane {idx} ('{_panes[idx].FileName}') by '{_userName}' — PC {PcId}");
        // Auto-save the pane being closed
        if (!string.IsNullOrEmpty(_panes[idx].File))
            await JS.InvokeVoidAsync("pcfViewer.savePane", PaneIds[idx]);

        _dualPanes.Remove(PaneIds[idx]);
        _dualInfo.Remove(PaneIds[idx]);

        // If the closed pane was maximized, clear maximize state
        if (_maximizedPane == idx)
            _maximizedPane = null;

        // Last pane — just clear it to empty (reopen with no file selected)
        if (_paneCount == 1)
        {
            _panes[0].File = null; _panes[0].FileName = null; _panes[0].Section = "";
            return;
        }

        // Shift panes down
        for (int i = idx; i < _paneCount - 1; i++)
        {
            _panes[i].File     = _panes[i + 1].File;
            _panes[i].FileName = _panes[i + 1].FileName;
            _panes[i].Section  = _panes[i + 1].Section;

            // Carry dual state
            _dualPanes.Remove(PaneIds[i]);
            _dualInfo.Remove(PaneIds[i]);
            if (_dualPanes.Contains(PaneIds[i + 1]))
            {
                _dualPanes.Remove(PaneIds[i + 1]);
                _dualInfo.TryGetValue(PaneIds[i + 1], out var di);
                _dualInfo.Remove(PaneIds[i + 1]);
                _dualPanes.Add(PaneIds[i]);
                _dualInfo[PaneIds[i]] = di;
            }
        }

        // Clear the vacated last slot
        int last = _paneCount - 1;
        _panes[last].File = null; _panes[last].FileName = null; _panes[last].Section = "";
        _dualPanes.Remove(PaneIds[last]); _dualInfo.Remove(PaneIds[last]);

        _paneCount--;
        if (_activeIdx >= _paneCount) _activeIdx = _paneCount - 1;

        // Reload remaining PDF panes to fill new width
        var reloads = new List<(string, string)>();
        for (int i = 0; i < _paneCount; i++)
            if (!string.IsNullOrEmpty(_panes[i].File) && !_panes[i].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                reloads.Add((PaneIds[i], _panes[i].File!));
        if (reloads.Count > 0)
            _pendingReloads = reloads;

        await JS.InvokeVoidAsync("pcfViewer.setActivePane", PaneIds[_activeIdx]);
    }

