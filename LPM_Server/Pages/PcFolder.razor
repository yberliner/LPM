    // ── Active CS session tracker (shared across all circuits) ──
    static readonly System.Collections.Concurrent.ConcurrentDictionary<int, string> _activeCsSessions = new();
    bool _csLocked;        // true if another tab is already CSing this session
    string? _csLockedBy;   // who is CSing it

    static readonly string[] PaneIds = ["p1", "p2", "p3"];

    string _pcName = "";
    PcFolderInfo? _folder;
    int _csSessionId;            // session ID passed from Dashboard (0 = not from CS button)
    string? _csSessionName;      // name of the session being CSed
    bool _csDone;                // true after "Mark CS Done" was executed
    int _csReviewMinutes;        // editable review time (session + admin) in minutes
    HashSet<int> _csedSessionIds = new();                    // session IDs that have cs_reviews
    Dictionary<string, int> _nameToSessionId = new(StringComparer.OrdinalIgnoreCase);  // session name → ID

    // Per-pane state (always 3 slots; _paneCount controls how many are visible)
    class PaneState { public string? File; public string? FileName; public string Section = ""; }
    PaneState[] _panes = [new(), new(), new()];

    int _paneCount = 1;   // 1, 2, or 3
    int _activeIdx = 0;   // index into _panes / PaneIds

    bool _sidebarOpen = true;
    bool _frontExpanded = true;
    bool _backExpanded = true;
    bool _wsExpanded = true;
    string _wsFilter = "";
    HashSet<string> _collapsedAttachments = [];

    void ToggleAttachments(string wsKey)
    {
        if (!_collapsedAttachments.Remove(wsKey))
            _collapsedAttachments.Add(wsKey);
    }
    int _wsPage;
    const int WsPageSize = 10;
    string _toolMode = "";
    string _drawColor = "#e11d48";
    int _fontSize = 14;
    bool _showColors;
    bool _showSizes;
    bool _hasAnnotations;
    bool _saving;
    List<(string paneId, string file)>? _pendingReloads;

    static readonly int[] _fontSizes = [10, 12, 14, 18, 24, 32, 40, 56];
    static readonly string[] _palette = [
        "#000000", "#ffffff", "#e11d48", "#f97316",
        "#eab308", "#22c55e", "#06b6d4", "#3b82f6",
        "#8b5cf6", "#ec4899", "#78716c", "#475569",
        "#dc2626", "#16a34a", "#2563eb", "#7c3aed"
    ];

    List<WorkSheetItem> GetWsPage(out int totalPages)
    {
        var all = _folder!.WorkSheets;
        var filtered = string.IsNullOrWhiteSpace(_wsFilter)
            ? all
            : all.Where(ws => StripDatePrefix(ws.File.FileName)
                    .Contains(_wsFilter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        totalPages = Math.Max(1, (int)Math.Ceiling(filtered.Count / (double)WsPageSize));
        if (_wsPage >= totalPages) _wsPage = totalPages - 1;
        return filtered.Skip(_wsPage * WsPageSize).Take(WsPageSize).ToList();
    }

    int WsTotalPages => _folder == null ? 1 : Math.Max(1,
        (int)Math.Ceiling((_folder.WorkSheets.Count(ws =>
            string.IsNullOrWhiteSpace(_wsFilter) ||
            StripDatePrefix(ws.File.FileName).Contains(_wsFilter, StringComparison.OrdinalIgnoreCase)))
        / (double)WsPageSize));

    int WsFilteredCount => _folder == null ? 0 : _folder.WorkSheets.Count(ws =>
        string.IsNullOrWhiteSpace(_wsFilter) ||
        StripDatePrefix(ws.File.FileName).Contains(_wsFilter, StringComparison.OrdinalIgnoreCase));

    void OnWsFilterChanged(ChangeEventArgs e)
    {
        _wsFilter = e.Value?.ToString() ?? "";
        _wsPage = 0;
    }

    void ClearWsFilter()
    {
        _wsFilter = "";
        _wsPage = 0;
    }

    string IsFileActive(string relativePath)
    {
        for (int i = 0; i < _paneCount; i++)
        {
            if (relativePath == _panes[i].File)
                return "pcf-file-active-" + PaneIds[i];
        }
        return "";
    }

    protected override void OnInitialized()
    {
        _folder = FolderSvc.GetPcFolder(PcId);
        _pcName = _folder?.PcName ?? $"PC {PcId}";
        _csedSessionIds = DashSvc.GetCsedSessionIdsForPc(PcId);
        foreach (var pair in DashSvc.GetSessionsForPc(PcId))
        {
            if (!string.IsNullOrEmpty(pair.Name))
                _nameToSessionId.TryAdd(pair.Name, pair.SessionId);
        }

        // Session ID passed from Dashboard "CS The Session" button (via host page parameter)
        _csSessionId = SessionId;

        // Derive session name and review time from DB
        if (_csSessionId > 0)
        {
            _csSessionName = DashSvc.GetSessionName(_csSessionId);
            _csReviewMinutes = (int)Math.Round(DashSvc.GetSessionTotalSeconds(_csSessionId) / 60.0);

            // Check if another tab is already CSing this session
            var userName = DashSvc.GetPersonName(UserPersonId) ?? $"User {UserPersonId}";
            if (_activeCsSessions.TryGetValue(_csSessionId, out var existingUser))
            {
                _csLocked = true;
                _csLockedBy = existingUser;
            }
            else
            {
                _activeCsSessions[_csSessionId] = userName;
            }
        }

        WorkSheetItem? match = null;
        if (!string.IsNullOrWhiteSpace(_csSessionName) && _folder != null)
        {
            match = _folder.WorkSheets
                .FirstOrDefault(ws => StripDatePrefix(ws.File.FileName)
                    .Equals(_csSessionName, StringComparison.OrdinalIgnoreCase));
        }

        if (match != null)
        {
            _panes[0].File = match.File.RelativePath;
            _panes[0].FileName = StripDatePrefix(match.File.FileName);
            _panes[0].Section = "WorkSheet";
            if (match.Attachments.Count > 0)
            {
                _paneCount = 2;
                var firstAtt = match.Attachments[0];
                _panes[1].File = firstAtt.RelativePath;
                _panes[1].FileName = firstAtt.FileName;
                _panes[1].Section = "WorkSheet";
            }
        }
        else if (_folder?.WorkSheets.Count > 0)
        {
            var latest = _folder.WorkSheets[0];
            _panes[0].File = latest.File.RelativePath;
            _panes[0].FileName = StripDatePrefix(latest.File.FileName);
            _panes[0].Section = "WorkSheet";
            if (latest.Attachments.Count > 0)
            {
                _paneCount = 2;
                var firstAtt = latest.Attachments[0];
                _panes[1].File = firstAtt.RelativePath;
                _panes[1].FileName = firstAtt.FileName;
                _panes[1].Section = "WorkSheet";
            }
        }
    }

    DotNetObjectReference<PcFolder>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pcfViewer.setDotNetRef", _dotNetRef);
            await JS.InvokeVoidAsync("pcfViewer.setPcId", PcId);

            for (int i = 0; i < _paneCount; i++)
            {
                if (!string.IsNullOrEmpty(_panes[i].File))
                {
                    var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(_panes[i].File)}&_t={DateTime.UtcNow.Ticks}";
                    await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, PaneIds[i]);
                }
            }

            // Load Ctrl+key shortcuts
            try
            {
                var sc = ShortcutSvc.GetShortcuts();
                await JS.InvokeVoidAsync("lpmLoadShortcuts", sc);
            }
            catch { }

            // Ctrl+Z → Undo
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('keydown', function(e) {
                    if ((e.ctrlKey || e.metaKey) && e.key === 'z' && !e.shiftKey) {
                        var el = document.activeElement;
                        if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA')) return;
                        e.preventDefault();
                        if (window.pcfViewer && window.pcfViewer.dotNetRef)
                            window.pcfViewer.dotNetRef.invokeMethodAsync('OnCtrlZ');
                    }
                });
            ");
        }

        if (_pendingReloads != null)
        {
            var reloads = _pendingReloads;
            _pendingReloads = null;
            foreach (var (paneId, file) in reloads)
            {
                var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(file)}&_t={DateTime.UtcNow.Ticks}";
                await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, paneId);
            }
        }
    }

    [JSInvokable]
