@inject LPM.Services.FolderService FolderSvc
@inject LPM.Services.DashboardService DashSvc
@inject PdfService PdfSvc
@inject LPM.Services.CsNotificationService CsNotifySvc
@inject LPM.Services.ShortcutService ShortcutSvc
@inject IJSRuntime JS
@inject NavigationManager NavManager
@inject IHttpContextAccessor HttpContextAccessor
@using LPM.Services
@implements IDisposable

<div class="pcf-container">
    @* ── Left sidebar ── *@
    <div class="pcf-sidebar @(_sidebarOpen ? "" : "pcf-sidebar-collapsed")">
        <div class="pcf-sidebar-header">
            <i class="ri-folder-user-line me-2"></i>
            <span class="pcf-pc-name">@_pcName</span>
            @if (Solo)
            {
                <span class="pcf-solo-badge"><i class="ri-user-star-line"></i>Solo</span>
            }
            <button class="pcf-sidebar-toggle" title="Collapse sidebar" @onclick="() => _sidebarOpen = false">
                <i class="ri-arrow-left-double-line"></i>
            </button>
        </div>

        @if (_folder != null)
        {
            @* ── Front Cover ── *@
            <div class="pcf-section-title pcf-section-front pcf-drop-zone"
                 @oncontextmenu="OnFrontCoverCtx"
                 @oncontextmenu:preventDefault="true"
                 @ondrop="OnFrontCoverDrop">
                <div class="pcf-drop-zone-inner" @onclick="() => _frontExpanded = !_frontExpanded">
                    <i class="@(_frontExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                    <i class="ri-book-open-line me-1"></i>
                    Front Cover
                    <span class="pcf-section-count">@_folder.FrontCover.Count</span>
                </div>
            </div>
            @if (_frontExpanded)
            {
                @foreach (var child in _folder.FrontCoverTree.Children)
                {
                    @RenderTreeNode(child, "Front_Cover", 0)
                }
                @if (_isCreatingFolder && _createFolderParent == "Front_Cover" && _createFolderSection == "Front_Cover")
                {
                    <div class="pcf-tree-folder pcf-create-folder-row" style="padding-left:14px;">
                        <i class="ri-folder-add-line" style="color:#fbbf24;"></i>
                        <input class="pcf-rename-input" value="@_createFolderName"
                               @oninput="e => _createFolderName = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnCreateFolderKey"
                               placeholder="Folder name" />
                        <button class="pcf-create-folder-ok" @onclick="ConfirmCreateFolder"
                                disabled="@string.IsNullOrWhiteSpace(_createFolderName)">
                            <i class="ri-check-line"></i>
                        </button>
                        <button class="pcf-create-folder-cancel" @onclick="CancelCreateFolder">
                            <i class="ri-close-line"></i>
                        </button>
                    </div>
                }
                <div class="pcf-new-btn" @onclick="OnFrontCoverNew">
                    <i class="ri-add-line"></i> New...
                </div>
            }

            @* ── Back Cover ── *@
            <div class="pcf-section-title pcf-section-back pcf-drop-zone"
                 @oncontextmenu="OnBackCoverCtx"
                 @oncontextmenu:preventDefault="true"
                 @ondrop="OnBackCoverDrop">
                <div class="pcf-drop-zone-inner" @onclick="() => _backExpanded = !_backExpanded">
                    <i class="@(_backExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                    <i class="ri-book-3-line me-1"></i>
                    Back Cover
                    <span class="pcf-section-count">@_folder.BackCover.Count</span>
                </div>
            </div>
            @if (_backExpanded)
            {
                @foreach (var child in _folder.BackCoverTree.Children)
                {
                    @RenderTreeNode(child, "Back_Cover", 0)
                }
                @if (_isCreatingFolder && _createFolderParent == "Back_Cover" && _createFolderSection == "Back_Cover")
                {
                    <div class="pcf-tree-folder pcf-create-folder-row" style="padding-left:14px;">
                        <i class="ri-folder-add-line" style="color:#fbbf24;"></i>
                        <input class="pcf-rename-input" value="@_createFolderName"
                               @oninput="e => _createFolderName = e.Value?.ToString() ?? string.Empty"
                               @onkeydown="OnCreateFolderKey"
                               placeholder="Folder name" />
                        <button class="pcf-create-folder-ok" @onclick="ConfirmCreateFolder"
                                disabled="@string.IsNullOrWhiteSpace(_createFolderName)">
                            <i class="ri-check-line"></i>
                        </button>
                        <button class="pcf-create-folder-cancel" @onclick="CancelCreateFolder">
                            <i class="ri-close-line"></i>
                        </button>
                    </div>
                }
                <div class="pcf-new-btn" @onclick="OnBackCoverNew">
                    <i class="ri-add-line"></i> New...
                </div>
            }

            @* ── WorkSheets ── *@
            <div class="pcf-section-title pcf-section-ws" @onclick="() => _wsExpanded = !_wsExpanded">
                <i class="@(_wsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-file-list-3-line me-1"></i>
                WorkSheets
                <span class="pcf-section-count">@_folder.WorkSheets.Count</span>
            </div>
            @if (_wsExpanded)
            {
                @* ── Search filter ── *@
                <div class="pcf-ws-search">
                    <i class="ri-search-line"></i>
                    <input type="text" placeholder="Search worksheets..."
                           value="@_wsFilter" @oninput="OnWsFilterChanged" />
                    @if (!string.IsNullOrEmpty(_wsFilter))
                    {
                        <i class="ri-close-line pcf-ws-search-clear" @onclick="ClearWsFilter"></i>
                    }
                </div>

                @foreach (var ws in GetWsPage(out var totalPages))
                {
                    var f = ws.File;
                    var active = IsFileActive(f.RelativePath);
                    var sessionName = Path.GetFileNameWithoutExtension(f.FileName);
                    var csed = _nameToSessionId.TryGetValue(sessionName, out var fSid) && _csedSessionIds.Contains(fSid);
                    var isCsTarget = !string.IsNullOrEmpty(_csSessionName)
                        && sessionName.Equals(_csSessionName, StringComparison.OrdinalIgnoreCase);
                    var hasAtt = ws.Attachments.Count > 0;
                    var wsKey = f.RelativePath;
                    var attExpanded = !_collapsedAttachments.Contains(wsKey);

                    @* ── Session row ── *@
                    <div class="pcf-file-item @active @(isCsTarget ? "pcf-file-cs-target" : "")"
                         @oncontextmenu="e => ShowWsCtxMenu(e, f.FileName, false, string.Empty)"
                         @oncontextmenu:preventDefault="true">
                        @if (hasAtt)
                        {
                            <i class="@(attExpanded ? "ri-arrow-down-s-fill" : "ri-arrow-right-s-fill") pcf-att-toggle"
                               @onclick="() => ToggleAttachments(wsKey)"
                               @onclick:stopPropagation="true"></i>
                        }
                        <span style="flex:1; display:flex; align-items:center; gap:4px; min-width:0;"
                              @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "WorkSheet"))">
                            @if (isCsTarget)
                            {
                                <i class="ri-star-fill pcf-star-pulse" style="flex-shrink:0;"></i>
                            }
                            else
                            {
                                <i class="ri-file-pdf-2-line @(csed ? "text-success" : "")" style="flex-shrink:0;"></i>
                            }
                            <span class="pcf-file-name @(csed ? "pcf-file-csed" : "")">@sessionName</span>
                            @if (csed)
                            {
                                <i class="ri-check-line" style="color:#22c55e;font-size:.7rem;flex-shrink:0;" title="CS Done"></i>
                            }
                        </span>
                        @if (hasAtt)
                        {
                            <span class="pcf-att-count">@ws.Attachments.Count</span>
                        }
                        @if (_nameToCreatedAt.TryGetValue(sessionName, out var createdAt))
                        {
                            <span class="pcf-file-date">@createdAt.ToString("dd/MM/yy")</span>
                        }
                    </div>

                    @* ── Attachment children ── *@
                    @if (hasAtt && attExpanded)
                    {
                        <div class="pcf-att-group">
                            @foreach (var att in ws.Attachments)
                            {
                                var attActive = IsFileActive(att.RelativePath);
                                var attRelPath = att.RelativePath;
                                var attName = att.FileName;
                                <div class="pcf-att-child @attActive"
                                     @oncontextmenu="e => ShowWsCtxMenu(e, f.FileName, true, attRelPath)"
                                     @oncontextmenu:preventDefault="true"
                                     @onclick="@(() => SelectFile(att.RelativePath, att.FileName, "WorkSheet"))">
                                    <span class="pcf-att-line"></span>
                                    <i class="ri-file-pdf-2-line" style="font-size:.7rem; opacity:.5; flex-shrink:0;"></i>
                                    @if (_isRenamingAtt && _renameAttPath == attRelPath)
                                    {
                                        <input class="pcf-rename-input" value="@_renameAttValue"
                                               @oninput="e => _renameAttValue = e.Value?.ToString() ?? string.Empty"
                                               @onkeydown="OnRenameAttKey"
                                               @onclick:stopPropagation="true"
                                               placeholder="attachment name" />
                                        <button class="pcf-create-folder-ok" @onclick="ConfirmRenameAtt"
                                                @onclick:stopPropagation="true"
                                                disabled="@string.IsNullOrWhiteSpace(_renameAttValue)">
                                            <i class="ri-check-line"></i>
                                        </button>
                                        <button class="pcf-create-folder-cancel" @onclick="CancelRenameAtt"
                                                @onclick:stopPropagation="true">
                                            <i class="ri-close-line"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="pcf-file-name">@attName</span>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                @* ── Pagination ── *@
                @if (WsTotalPages > 1)
                {
                    <div class="pcf-ws-pager">
                        <button disabled="@(_wsPage == 0)" @onclick="() => _wsPage--">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <span>@(_wsPage + 1) / @WsTotalPages</span>
                        <button disabled="@(_wsPage >= WsTotalPages - 1)" @onclick="() => _wsPage++">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                        <span class="pcf-ws-pager-total">(@WsFilteredCount)</span>
                    </div>
                }
                else if (WsFilteredCount == 0 && !string.IsNullOrWhiteSpace(_wsFilter))
                {
                    <div style="padding:8px 28px;font-size:.76rem;color:#94a3b8;">No matches</div>
                }
            }
        }
    </div>

    @* ── Sidebar backdrop for mobile ── *@
    @if (_sidebarOpen)
    {
        <div class="pcf-sidebar-backdrop" @onclick="() => _sidebarOpen = false"></div>
    }

    @* ── Annotation settings / zoom menu / add-page menu backdrops ── *@
    @if (_showAnnotSettings)
    {
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:99;"
             @onclick="() => _showAnnotSettings = false"></div>
    }
    @if (_showZoomMenu)
    {
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:99;"
             @onclick="() => _showZoomMenu = false"></div>
    }
    @if (_showPaneMenu)
    {
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:99;"
             @onclick="() => _showPaneMenu = false"></div>
    }
    @if (_showAddPageMenu)
    {
        <div style="position:fixed;top:0;left:0;right:0;bottom:0;z-index:99;"
             @onclick="() => _showAddPageMenu = false"></div>
    }

    @* ── Page right-click context menu ── *@
    @if (_showPageCtxMenu)
    {
        <div class="pcf-ctx-backdrop" @onclick="() => _showPageCtxMenu = false"></div>
        <div class="pcf-ctx-menu" style="top:@(_pageBgY)px;left:@(_pageBgX)px;">
            @if (_pageCtxIsProgram)
            {
                <button class="pcf-ctx-item" @onclick="ShowInsertFormFromCtx">
                    <i class="ri-file-add-line me-2"></i>Insert Form
                </button>
                <button class="pcf-ctx-item" @onclick="InsertFileAboveClick">
                    <i class="ri-upload-2-line me-2"></i>Insert file above
                </button>
            }
            @if (_pageCtxIsCover)
            {
                <button class="pcf-ctx-item" @onclick="ShowPageBgFromCtx">
                    <i class="ri-palette-line me-2"></i>Change Background
                </button>
            }
            <button class="pcf-ctx-item" @onclick="FloatPage">
                <i class="ri-lock-line me-2"></i>Float Page
            </button>
        </div>
    }

    @* ── Page background color picker ── *@
    @if (_showPageBgPicker)
    {
        <div class="pcf-ctx-backdrop" @onclick="() => _showPageBgPicker = false"></div>
        <div class="pcf-pagebg-picker" style="top:@(_pageBgY)px;left:@(_pageBgX)px;">
            <div class="pcf-pagebg-title">
                <i class="ri-palette-line me-1"></i>Page @(_pageBgPageIdx + 1) Background
            </div>
            <div class="pcf-pagebg-grid">
                @for (int i = 0; i < _pageBgColors.Length; i++)
                {
                    var color = _pageBgColors[i];
                    var label = _pageBgLabels[i];
                    var bgStyle = string.IsNullOrEmpty(color) ? "#ffffff" : color;
                    <button class="pcf-pagebg-swatch @(string.IsNullOrEmpty(color) ? "pcf-pagebg-white" : "")"
                            title="@label"
                            style="background:@bgStyle;"
                            @onclick="() => SetPageBgColor(color)">
                    </button>
                }
            </div>
        </div>
    }

    @* ── Insert Form picker (program files) ── *@
    @if (_showInsertFormPicker)
    {
        <div class="pcf-ctx-backdrop" @onclick="() => _showInsertFormPicker = false"></div>
        <div class="pcf-insertform-picker" style="top:@(_pageBgY)px;left:@(_pageBgX)px;">
            <div class="pcf-pagebg-title">
                <i class="ri-file-add-line me-1"></i>Insert Form Above Page @(_pageBgPageIdx + 1)
            </div>
            <div class="pcf-insertform-list">
                @foreach (var f in _programInsertFiles)
                {
                    <button class="pcf-insertform-item" @onclick="() => InsertFormFile(f)">
                        <i class="ri-file-pdf-2-line me-2" style="color:#e11d48;"></i>
                        @Path.GetFileNameWithoutExtension(f)
                    </button>
                }
                @if (_programInsertFiles.Count == 0)
                {
                    <div style="padding:12px;color:#94a3b8;font-size:.82rem;text-align:center;">
                        No template files found in ProgramInserts folder.
                    </div>
                }
            </div>
        </div>
    }

    @* ── Worksheet context menu ── *@
    @if (_showWsCtxMenu)
    {
        <div class="pcf-ctx-backdrop" @onclick="CloseWsCtxMenu"></div>
        <div class="pcf-ctx-menu" style="top:@(_wsCtxY)px;left:@(_wsCtxX)px;">
            @if (!_wsCtxIsAttachment)
            {
                @if (CsMode)
                {
                    <button @onclick="WsCtxAddPinkSheet"><i class="ri-file-add-line me-2" style="color:#ec4899 !important;"></i>Add Pink Sheet</button>
                    <button @onclick='() => WsCtxAddWhiteSheet("Instruct")'><i class="ri-file-add-line me-2" style="color:#60a5fa !important;"></i>Add Instruct</button>
                    <button @onclick='() => WsCtxAddWhiteSheet("Cramming")'><i class="ri-file-add-line me-2" style="color:#34d399 !important;"></i>Add Cramming</button>
                    <div class="pcf-ctx-divider"></div>
                }

                <button @onclick="WsCtxUploadAttachment"><i class="ri-upload-2-line me-2"></i>Upload Attachment</button>
                <div class="pcf-ctx-divider"></div>
                <button @onclick="WsCtxDownloadSession"><i class="ri-download-2-line me-2"></i>Download entire session</button>
            }
            else
            {
                <button @onclick="WsCtxRenameAtt"><i class="ri-edit-line me-2"></i>Rename</button>
                @if (_wsCtxAttRelPath.Contains("PinkSheet", StringComparison.OrdinalIgnoreCase)
                  || _wsCtxAttRelPath.Contains("Instruct",  StringComparison.OrdinalIgnoreCase)
                  || _wsCtxAttRelPath.Contains("Cramming",  StringComparison.OrdinalIgnoreCase))
                {
                    <div class="pcf-ctx-divider"></div>
                    <button class="pcf-ctx-danger" @onclick="WsCtxDeletePinkSheet"><i class="ri-delete-bin-line me-2"></i>Delete</button>
                }
            }
        </div>
    }

    @* ── Context menu ── *@
    @if (_showCtxMenu && _ctxNode != null)
    {
        <div class="pcf-ctx-backdrop" @onclick="CloseCtxMenu"></div>
        <div class="pcf-ctx-menu" style="top:@(_ctxMenuY)px;left:@(_ctxMenuX)px;">
            @if (_ctxNode.IsFolder)
            {
                <button @onclick="CtxNewFolder"><i class="ri-folder-add-line me-2"></i>New Folder</button>
                <button @onclick="CtxUploadFile"><i class="ri-upload-2-line me-2"></i>Upload File</button>
                <button @onclick="CtxNewEmptyPdf"><i class="ri-file-add-line me-2"></i>New Empty PDF</button>
                @if (_ctxNode.RelativePath != "Front_Cover" && _ctxNode.RelativePath != "Back_Cover")
                {
                    <div class="pcf-ctx-divider"></div>
                    <button @onclick="CtxRename"><i class="ri-edit-line me-2"></i>Rename</button>
                    <button class="pcf-ctx-danger" @onclick="CtxDelete"><i class="ri-delete-bin-line me-2"></i>Delete Folder</button>
                }
            }
            else
            {
                <button @onclick="CtxMoveTo"><i class="ri-folder-transfer-line me-2"></i>Move to...</button>
                <button @onclick="CtxRename"><i class="ri-edit-line me-2"></i>Rename</button>
                <button class="pcf-ctx-danger" @onclick="CtxDelete"><i class="ri-delete-bin-line me-2"></i>Delete</button>
                <div class="pcf-ctx-divider"></div>
                <button @onclick="CtxDownload"><i class="ri-download-2-line me-2"></i>Download</button>
            }
        </div>
    }

    @* ── New menu popover ── *@
    @* Hidden file input — always in DOM, triggered programmatically *@
    <InputFile id="pcf-upload-input" accept=".pdf,.doc,.docx" multiple OnChange="NewMenuUploadFile"
               style="display:none;" />
    @* Hidden file input for "Insert file above" in program pages *@
    <InputFile id="pcf-insert-input" accept=".pdf,.doc,.docx" OnChange="OnInsertFileSelected"
               style="display:none;" />
    @* Hidden file input for worksheet "Upload Attachment" context menu *@
    <InputFile id="pcf-ws-att-input" accept=".pdf,.doc,.docx,.odt,.rtf,.txt,.xls,.xlsx,.png,.jpg,.jpeg" OnChange="OnWsAttFileSelected"
               style="display:none;" />

    @if (_newMenuSection != null)
    {
        <div class="pcf-ctx-backdrop" @onclick="CloseNewMenu"></div>
        <div class="pcf-new-popover" style="top:@(_newMenuY)px;left:@(_newMenuX)px;">
            <button @onclick="NewMenuFolder"><i class="ri-folder-add-line me-2"></i>New Folder</button>
            <button @onclick="NewMenuUploadClick"><i class="ri-upload-2-line me-2"></i>Upload File</button>
            <button @onclick="NewMenuEmptyPdf"><i class="ri-file-add-line me-2"></i>New Empty PDF</button>
        </div>
    }

    @* ── Delete confirmation modal ── *@
    @if (_showDeleteConfirm)
    {
        <div class="pcf-modal-backdrop" @onclick="() => _showDeleteConfirm = false">
            <div class="pcf-modal-sm" @onclick:stopPropagation="true">
                <div class="pcf-modal-icon-danger"><i class="ri-delete-bin-line"></i></div>
                <div style="font-weight:700; font-size:.95rem; margin-bottom:4px;">
                    Delete @(_deleteIsFolder ? "folder" : "file")?
                </div>
                <div style="font-size:.82rem; color:#94a3b8; margin-bottom:16px; word-break:break-word;">
                    "@_deleteTargetName"
                    @if (!_deleteIsFolder) { <span> will be backed up.</span> }
                    else { <span> (must be empty)</span> }
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                    <button class="btn btn-sm btn-danger" @onclick="ExecuteDelete">Delete</button>
                </div>
            </div>
        </div>
    }

    @* ── Upload overwrite confirmation modal ── *@
    @if (_showOverwriteConfirm)
    {
        <div class="pcf-modal-backdrop" @onclick="CancelOverwrite">
            <div class="pcf-modal-sm" @onclick:stopPropagation="true">
                <div class="pcf-modal-icon-danger"><i class="ri-file-warning-line"></i></div>
                <div style="font-weight:700; font-size:.95rem; margin-bottom:8px;">
                    File@(_uploadDuplicateNames.Count > 1 ? "s" : "") already exist@(_uploadDuplicateNames.Count == 1 ? "s" : "")
                </div>
                <div style="font-size:.82rem; color:#94a3b8; margin-bottom:4px;">
                    @foreach (var name in _uploadDuplicateNames)
                    {
                        <div style="color:#fbbf24; font-weight:600;">@name</div>
                    }
                </div>
                <div style="font-size:.78rem; color:#64748b; margin-bottom:16px;">
                    The existing file@(_uploadDuplicateNames.Count > 1 ? "s" : "") will be backed up before overwriting.
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelOverwrite">Cancel</button>
                    <button class="btn btn-sm btn-warning" @onclick="ConfirmOverwrite">Overwrite</button>
                </div>
            </div>
        </div>
    }

    @* ── Drag-drop confirmation modal ── *@
    @if (_showDragConfirm)
    {
        <div class="pcf-modal-backdrop" @onclick="CancelDragMove">
            <div class="pcf-modal-sm" @onclick:stopPropagation="true">
                <div class="pcf-modal-icon-move"><i class="ri-folder-transfer-line"></i></div>
                <div style="font-weight:700; font-size:.95rem; margin-bottom:12px;">Confirm Move</div>
                <div style="font-size:.84rem; color:#e2e8f0; margin-bottom:4px; word-break:break-word;">
                    Move "<strong>@_dragConfirmFileName</strong>"
                </div>
                <div style="font-size:.78rem; color:#94a3b8; margin-bottom:3px;">
                    <i class="ri-folder-line me-1" style="color:#f59e0b;"></i>From: <strong style="color:#e2e8f0;">@_dragConfirmFrom</strong>
                </div>
                <div style="font-size:.78rem; color:#94a3b8; margin-bottom:16px;">
                    <i class="ri-folder-open-line me-1" style="color:#22c55e;"></i>To: <strong style="color:#e2e8f0;">@_dragConfirmTo</strong>
                </div>
                <div class="d-flex gap-2 justify-content-center">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelDragMove">Cancel</button>
                    <button class="btn btn-sm btn-primary" @onclick="ExecuteDragMove">Move</button>
                </div>
            </div>
        </div>
    }

    @* ── Edit Session Summary modal ── *@
    @if (_showEditSummary)
    {
        <div class="pcf-modal-backdrop" @onclick="() => _showEditSummary = false">
            <div class="pcf-modal-summary" @onclick:stopPropagation="true">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <div style="font-weight:700; font-size:.95rem;">
                        <i class="ri-edit-2-line me-2" style="color:#60a5fa;"></i>Edit Session Summary
                        @if (!string.IsNullOrEmpty(_csSessionName))
                        {
                            <span style="font-size:.8rem; font-weight:400; opacity:.7;"> — @_csSessionName</span>
                        }
                    </div>
                    <button class="btn-close btn-close-white btn-sm" @onclick="() => _showEditSummary = false"></button>
                </div>
                <div id="pcf-summary-editor" style="background:#fff; border-radius:4px; min-height:200px; max-height:420px; overflow-y:auto;"></div>
                <div class="d-flex gap-2 justify-content-end mt-3">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showEditSummary = false">Cancel</button>
                    <button class="btn btn-sm btn-primary" @onclick="SaveEditSummary">
                        <i class="ri-save-line me-1"></i>Save
                    </button>
                </div>
            </div>
        </div>
    }

    @* ── Folder Summary Modal ── *@
    @if (_showFsModal)
    {
        <div class="pcf-modal-backdrop" @onclick="CloseFsModal">
            <div class="pcf-fs-modal @(_fsModeMaximized ? "pcf-fs-modal--max" : "")" @onclick:stopPropagation="true">

                <div class="pcf-fs-header">
                    <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
                        <i class="ri-file-list-3-line" style="font-size:1.1rem;color:#60a5fa;flex-shrink:0;"></i>
                        <span style="font-weight:700;font-size:.95rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                            Folder Summary — @_pcName
                        </span>
                    </div>
                    <button class="pcf-fs-nav-btn ms-1" title="@(_fsModeMaximized ? "Restore" : "Maximize")"
                            @onclick="() => _fsModeMaximized = !_fsModeMaximized">
                        <i class="@(_fsModeMaximized ? "ri-fullscreen-exit-line" : "ri-fullscreen-line")"></i>
                    </button>
                    <button class="btn-close btn-close-white btn-sm ms-2" @onclick="CloseFsModal"></button>
                </div>

                <div class="pcf-fs-body">
                    <table class="pcf-fs-table">
                        <thead>
                            <tr>
                                <th style="width:100px;">Date</th>
                                <th style="width:@(FsNameColWidth)px;">Session Name</th>
                                <th style="width:120px;">Auditor</th>
                                <th style="width:60px;">Duration</th>
                                <th>Summary</th>
                                <th style="width:36px;"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var e in _fsEntries)
                            {
                                <tr>
                                    <td class="pcf-fs-td-date">
                                        @FsFormatDate(e.SessionDate)
                                        @{ var _t = FsFormatTime(e.CreatedAt); }
                                        @if (!string.IsNullOrEmpty(_t))
                                        { <span class="pcf-fs-td-time">@_t</span> }
                                    </td>
                                    <td class="pcf-fs-td-name">@e.Name</td>
                                    <td class="pcf-fs-td-name">@e.AuditorName</td>
                                    <td class="pcf-fs-td-dur">@FsSecsToHMM(e.LengthSeconds + e.AdminSeconds)</td>
                                    <td class="pcf-fs-td-html">@((MarkupString)(e.SummaryHtml ?? ""))</td>
                                    <td class="pcf-fs-td-btn">
                                        <button class="pcf-fs-edit-btn pcf-fs-edit-btn--inline" title="Edit"
                                                @onclick="() => _ = FsStartEdit(e.SummaryId)">
                                            <i class="ri-pencil-line"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    }

    @* ── Folder Summary Cell Edit Modal ── *@
    @if (_showFsEditModal && _fsEditingId.HasValue)
    {
        var _editEntry = _fsEntries.FirstOrDefault(e => e.SummaryId == _fsEditingId.Value);
        <div class="pcf-modal-backdrop" style="z-index:10020;" @onclick="FsCancelEdit">
            <div class="pcf-fs-edit-modal" @onclick:stopPropagation="true">
                @if (_editEntry != null)
                {
                    <div class="pcf-fs-edit-title">
                        <i class="ri-calendar-line me-1" style="opacity:.6;"></i>@FsFormatDate(_editEntry.SessionDate)
                        @if (!string.IsNullOrEmpty(_editEntry.Name))
                        { <span style="color:#94a3b8;font-weight:400;"> — @_editEntry.Name</span> }
                    </div>
                }
                <div id="pcf-fs-editor" style="background:#fff;border-radius:4px 4px 0 0;min-height:150px;"></div>
                <div class="pcf-fs-save-row">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="FsCancelEdit">Cancel</button>
                    <button class="btn btn-sm btn-primary" @onclick="FsSaveEdit">
                        <i class="ri-save-line me-1"></i>Save
                    </button>
                </div>
            </div>
        </div>
    }

    @* ── Move-to modal ── *@
    @if (_showMoveModal && _folder != null)
    {
        <div class="pcf-modal-backdrop" @onclick="() => _showMoveModal = false">
            <div class="pcf-modal-move" @onclick:stopPropagation="true">
                <div style="font-weight:700; font-size:.92rem; margin-bottom:4px;">
                    <i class="ri-folder-transfer-line me-2" style="color:#3b82f6;"></i>Move "@_moveFileName"
                </div>
                <div style="font-size:.75rem; color:#64748b; margin-bottom:12px;">Select destination folder</div>
                <div style="max-height:40vh; overflow-y:auto; margin-bottom:12px; background:#0f172a; border-radius:6px; padding:6px 0;">
                    @RenderMoveFolderTree(GetSectionTree(_moveFileSection), 0)
                </div>
                @if (_moveNewFolderMode)
                {
                    <div class="d-flex gap-2 mb-2">
                        <input class="form-control form-control-sm" @bind="_moveNewFolderName"
                               placeholder="New folder name"
                               style="background:#0f172a; color:#e2e8f0; border-color:#475569; font-size:.82rem;" />
                        <button class="btn btn-sm btn-primary" style="white-space:nowrap;"
                                disabled="@string.IsNullOrWhiteSpace(_moveNewFolderName)"
                                @onclick="CreateMoveDestFolder">Create</button>
                    </div>
                }
                <div class="d-flex gap-2 justify-content-between">
                    <button class="btn btn-sm btn-outline-light d-flex align-items-center gap-1"
                            @onclick="() => _moveNewFolderMode = !_moveNewFolderMode">
                        <i class="ri-folder-add-line"></i>New Folder
                    </button>
                    <div class="d-flex gap-2">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showMoveModal = false">Cancel</button>
                        <button class="btn btn-sm btn-primary" @onclick="ExecuteMove"
                                disabled="@string.IsNullOrEmpty(_moveSelectedFolder)">Move Here</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* ── Main content: PDF viewer ── *@
    <div class="pcf-main">
        @* ── Toolbar ── *@
        <div class="pcf-toolbar">
            <div class="d-flex align-items-center gap-2" style="min-width:0;overflow:hidden;flex-shrink:0;">
                @if (!_sidebarOpen)
                {
                    <button class="pcf-tool-btn" title="Open sidebar — show file list"
                            @onclick="() => _sidebarOpen = true">
                        <i class="ri-side-bar-line"></i>
                    </button>
                    <div class="vr mx-0" style="border-color:rgba(255,255,255,.3);"></div>
                }
            </div>
            @* Pane dropdown must be OUTSIDE the overflow:hidden group so the menu is not clipped *@
            <div style="position:relative;flex-shrink:0;">
                <button class="pcf-tool-btn @(_paneCount > 1 ? "pcf-tool-active" : "")"
                        title="Split view — choose 1, 2, or 3 side-by-side panes"
                        @onclick="() => _showPaneMenu = !_showPaneMenu">
                    <i class="ri-layout-column-line"></i>
                    <span style="font-size:.7rem;margin-left:2px;">@_paneCount</span>
                </button>
                @if (_showPaneMenu)
                {
                    <div class="pcf-zoom-menu" style="min-width:0;" @onclick:stopPropagation="true">
                        <div class="pcf-zoom-chips">
                            @foreach (var n in new[]{ 1, 2, 3 })
                            {
                                <button class="pcf-zoom-chip @(_paneCount == n ? "pcf-zoom-chip-active" : "")"
                                        @onclick="async () => { _showPaneMenu = false; await SetPaneCount(n); }">
                                    @n
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
            <div class="vr mx-0" style="border-color:rgba(255,255,255,.3);flex-shrink:0;"></div>
            @if (!string.IsNullOrEmpty(_csSessionName))
            {
                var _csFileMissing = _folder != null && !_folder.WorkSheets.Any(ws =>
                    SessionDisplayName(ws.File.FileName).Equals(_csSessionName, StringComparison.OrdinalIgnoreCase));
                <div class="flex-grow-1 d-flex justify-content-center align-items-center gap-3">
                    <span class="pcf-cs-session-label @(_csFileMissing ? "pcf-cs-session-label--missing" : "")"
                          title="@(_csFileMissing ? "File is missing" : "Open this session file in the active pane")"
                          @onclick="@(async () => { if (!_csFileMissing) await OpenCsFile(); })"
                          style="@(_csFileMissing ? "" : "cursor:pointer;")">
                        <span style="opacity:.7;font-weight:400;">CSing:</span> @_csSessionName
                    </span>
                    <div class="pcf-timer @(_csReviewMinutes <= 0 ? "pcf-timer-zero" : "")"
                         title="CS Review time (session + admin). This value will be saved when you press Mark CS Done. Edit hours and minutes if needed.">
                        <i class="ri-timer-line pcf-timer-icon"></i>
                        <div class="pcf-timer-display">
                            <input type="number" min="0" class="pcf-timer-num"
                                   value="@(_csReviewMinutes / 60)"
                                   @onchange="e => OnTimerHoursChanged(e)" />
                            <span class="pcf-timer-colon">:</span>
                            <input type="number" min="0" max="59" class="pcf-timer-num"
                                   value="@(_csReviewMinutes % 60)"
                                   @onchange="e => OnTimerMinsChanged(e)" />
                        </div>
                        @if (_csReviewMinutes <= 0)
                        {
                            <i class="ri-error-warning-line pcf-timer-warn" title="Review time is 0 — update before marking done"></i>
                        }
                    </div>
                </div>
            }
            <div class="pcf-tools-right">
                <button class="pcf-tool-btn @(_textSelectMode ? "pcf-tool-active" : "")"
                        title="Select Text — select PDF text with the mouse, then Ctrl+C to copy"
                        @onclick="ToggleTextSelectMode">
                    <i class="ri-cursor-line"></i>
                </button>
                <button class="pcf-tool-btn @(_panMode ? "pcf-tool-active" : "")"
                        title="@(_panMode ? "Pan mode ON — click again to turn off" : "Pan — drag to scroll when zoomed in")"
                        style="@(_panMode ? "color:#fb923c;" : "")"
                        @onclick="TogglePan">
                    <i class="ri-drag-move-line"></i>
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-tool-btn @(_toolMode == "draw" ? "pcf-tool-active" : "")"
                        title="Draw — click and drag on the PDF to draw freehand annotations"
                        @onclick='() => SetTool("draw")'>
                    <i class="ri-pencil-line"></i>
                </button>
                <button class="pcf-tool-btn @(_toolMode == "brush" ? "pcf-tool-active" : "")"
                        title="Brush — semi-transparent highlighter brush"
                        @onclick='() => SetTool("brush")'>
                    <i class="ri-brush-line"></i>
                </button>
                <button class="pcf-tool-btn @(_toolMode == "text" ? "pcf-tool-active" : "")"
                        title="Add Text — click anywhere on the PDF to place a text note"
                        @onclick='() => SetTool("text")'>
                    <i class="ri-text"></i>
                </button>
                <div class="pcf-color-wrap">
                    <button class="pcf-tool-btn" title="Annotation settings — stroke width, color, text size"
                            style="border-bottom: 3px solid @_drawColor;"
                            @onclick="() => _showAnnotSettings = !_showAnnotSettings">
                        <i class="ri-settings-3-line"></i>
                    </button>
                    @if (_showAnnotSettings)
                    {
                        <div class="pcf-annot-popup" @onclick:stopPropagation="true">
                            <div class="d-flex align-items-center justify-content-between mb-1">
                                <span class="pcf-annot-section-label" style="margin:0;">Annotation Settings</span>
                                <button class="pcf-annot-close" @onclick="() => _showAnnotSettings = false" title="Close">
                                    <i class="ri-close-line"></i>
                                </button>
                            </div>
                            <div class="pcf-annot-section-label">Stroke Width</div>
                            <div class="pcf-annot-widths">
                                @foreach (var w in _strokeWidths)
                                {
                                    <div class="pcf-size-item @(w == _drawWidth ? "pcf-size-active" : "")"
                                         @onclick="() => PickWidth(w)">
                                        <span style="display:inline-block;width:20px;height:@(Math.Min(w,8))px;background:@_drawColor;border-radius:@(w)px;"></span>
                                        <span>@(w)px</span>
                                    </div>
                                }
                            </div>
                            <div class="pcf-annot-section-label">Color</div>
                            <div class="pcf-annot-colors">
                                @foreach (var c in _palette)
                                {
                                    <div class="pcf-color-swatch @(c == _drawColor ? "pcf-swatch-active" : "")"
                                         style="background:@c;" title="@c"
                                         @onclick="() => PickColor(c)"></div>
                                }
                            </div>
                            <div class="pcf-annot-section-label">Text Size</div>
                            <div class="pcf-annot-sizes">
                                @foreach (var s in _fontSizes)
                                {
                                    <div class="pcf-size-item @(s == _fontSize ? "pcf-size-active" : "")"
                                         @onclick="() => PickSize(s)">
                                        <span style="font-size:@(Math.Min(s, 20))px;">A</span>
                                        <span>@(s)px</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                <button class="pcf-tool-btn" title="Undo — remove the last annotation on the active pane (Ctrl+Z)" @onclick="Undo">
                    <i class="ri-arrow-go-back-line"></i>
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <div class="pcf-addpage-wrap">
                    <button class="pcf-tool-btn" title="Add blank page" @onclick="ToggleAddPageMenu">
                        <i class="ri-file-add-line"></i>
                    </button>
                    @if (_showAddPageMenu)
                    {
                        <div class="pcf-addpage-menu">
                            <button @onclick="AddBlankPageAbove">
                                <i class="ri-arrow-up-line me-2"></i>Add Page Above
                            </button>
                            <button @onclick="AddBlankPageBelow">
                                <i class="ri-arrow-down-line me-2"></i>Add Page Below
                            </button>
                        </div>
                    }
                </div>
                @if (CanExtract)
                {
                    <button class="pcf-tool-btn @(_extractMode ? "pcf-tool-active" : "")"
                            title="Extract Pages — select pages to extract into a new attachment"
                            @onclick="ToggleExtractMode">
                        <i class="ri-scissors-line"></i>
                    </button>
                }
                <div class="pcf-color-wrap">
                    <button class="pcf-zoom-single" title="Zoom — click to set zoom level"
                            @onclick="() => _showZoomMenu = !_showZoomMenu">
                        @(_fitMode ? "Fit" : $"{_zoomPercent}%")
                    </button>
                    @if (_showZoomMenu)
                    {
                        <div class="pcf-zoom-menu" @onclick:stopPropagation="true">
                            <div class="pcf-zoom-row">
                                <button class="pcf-zoom-icon-btn" title="Zoom out" @onclick="ZoomOut" disabled="@(_zoomPercent <= 10)">
                                    <i class="ri-subtract-line"></i>
                                </button>
                                <span class="pcf-zoom-current">@(_zoomPercent)%</span>
                                <button class="pcf-zoom-icon-btn" title="Zoom in" @onclick="ZoomIn" disabled="@(_zoomPercent >= 300)">
                                    <i class="ri-add-line"></i>
                                </button>
                            </div>
                            <div class="pcf-zoom-chips">
                                @foreach (var pct in new[]{ 50, 75, 100, 125, 150, 200 })
                                {
                                    <button class="pcf-zoom-chip @(!_fitMode && _zoomPercent == pct ? "pcf-zoom-chip-active" : "")"
                                            @onclick="() => SetZoom(pct)">@(pct)%</button>
                                }
                                <button class="pcf-zoom-chip @(_fitMode ? "pcf-zoom-chip-active" : "")"
                                        @onclick="FitToPage">Fit Page</button>
                            </div>
                        </div>
                    }
                </div>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-save-btn" title="Save — save annotations to the PDF now (also auto-saves when switching files or closing)"
                        @onclick="SaveAnnotations"
                        disabled="@(!_hasAnnotations)">
                    <i class="ri-save-line me-1"></i>Save
                </button>
                <button class="pcf-tool-btn" title="Download — download the currently selected file"
                        @onclick="DownloadFile"
                        disabled="@(string.IsNullOrEmpty(_panes[_activeIdx].File))">
                    <i class="ri-download-2-line"></i>
                </button>
                <button class="pcf-tool-btn pcf-voice-btn @(_voiceOn ? "pcf-voice-active" : "")"
                        title="@(_voiceOn ? "Voice commands ON — click to turn off" : "Voice commands OFF — click to turn on")"
                        @onclick="ToggleVoice">
                    <i class="ri-mic-@(_voiceOn ? "fill" : "line")"></i>
                </button>
                @if (_csSessionId > 0)
                {
                    <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                    @if (!_csDone)
                    {
                        <button class="pcf-tool-btn" title="Browse &amp; edit folder summary"
                                @onclick="OpenFsModal">
                            <i class="ri-file-list-3-line me-1"></i><span style="font-size:.72rem;">FS</span><i class="ri-pencil-line ms-1" style="font-size:.7rem;opacity:.7;"></i>
                        </button>
                    }
                    @if (CsMode)
                    {
                        @if (_csDone)
                        {
                            <button class="pcf-done-btn pcf-done-success" disabled>
                                <i class="ri-check-line me-1"></i>CS Done
                            </button>
                        }
                        else
                        {
                            <button class="pcf-done-btn @(_csAlreadyDone ? "pcf-done-already" : "")"
                                    title="@(_csAlreadyDone ? "CS was already done" : _csLocked ? "Another tab is already CSing this session" : "Done — saves all annotations, records the CS review with the displayed time, and returns to Home")"
                                    @onclick="DoneCs" disabled="@(_csLocked || _csAlreadyDone)">
                                <i class="@(_csAlreadyDone ? "ri-check-double-line me-1" : "ri-check-double-line me-1")"></i>Done
                            </button>
                        }
                    }
                }
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-tool-btn pcf-close-btn" title="Close — return to Home" @onclick="CloseToHome">
                    <i class="ri-close-line"></i>
                </button>
            </div>
        </div>

        @if (_csLocked)
        {
            <div class="pcf-lock-banner">
                <i class="ri-lock-line me-2"></i>
                This session is already being CSed by <strong>@_csLockedBy</strong> in another tab.
                You can view the files but cannot mark CS as done.
            </div>
        }
        @if (_csAlreadyDone && !_csAlreadyDoneBannerDismissed)
        {
            <div class="pcf-already-done-banner">
                <i class="ri-checkbox-circle-line me-2" style="font-size:1.1rem;flex-shrink:0;"></i>
                This session was already CS reviewed. The <strong style="margin:0 3px;">Done</strong> button is disabled.
                <button class="pcf-banner-dismiss" @onclick="@(() => _csAlreadyDoneBannerDismissed = true)" title="Dismiss">&times;</button>
            </div>
        }

        @* ── PDF viewer area ── *@
        <div class="pcf-viewer-area @(_paneCount > 1 ? "pcf-split" : "")">
            @for (int pi = 0; pi < _paneCount; pi++)
            {
                var idx = pi;
                var p = _panes[idx];
                <div class="pcf-pane pcf-pane-@PaneIds[idx] @(_activeIdx == idx ? "pcf-pane-active" : "") @(_maximizedPane.HasValue && _maximizedPane.Value != idx ? "d-none" : "")"
                     @onclick="() => SetActiveIdx(idx)">
                    @{
                        var isDual = _dualPanes.Contains(PaneIds[idx]);
                        var isPdf  = p.File?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true;
                        _dualInfo.TryGetValue(PaneIds[idx], out var di);
                        var isPaneSession = !string.IsNullOrEmpty(_csSessionName) && !string.IsNullOrEmpty(p.File)
                            && SessionDisplayName(Path.GetFileName(p.File)).Equals(_csSessionName, StringComparison.OrdinalIgnoreCase);
                    }
                    @if (isPaneSession)
                    {
                        <i class="ri-star-fill pcf-pane-session-star" title="@_csSessionName"></i>
                    }
                    @if (!string.IsNullOrEmpty(p.File) && IsFolderSummaryFile(p.FileName ?? "", p.File))
                    {
                        <span class="pcf-pane-fs-icon" title="Folder Summary">FS</span>
                    }
                    @* ── Floating pane button overlay ── *@
                    <div class="pcf-pane-overlay">
                        <span class="pcf-overlay-name" title="@p.FileName">@(p.FileName ?? "Empty")</span>
                        @if (isDual)
                        {
                            <span class="pcf-overlay-counter">@di.page–@(Math.Min(di.page + 1, di.total)) / @di.total</span>
                        }
                        @if (isPdf)
                        {
                            <button class="pcf-overlay-btn @(isDual ? "pcf-overlay-btn-active" : "")"
                                    title="@(isDual ? "Exit side-by-side view" : "Side-by-side view")"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => ToggleDualMode(PaneIds[idx])">
                                <i class="@(isDual ? "ri-book-open-fill" : "ri-book-open-line")"></i>
                            </button>
                        }
                        @if (CanExtractPane(idx))
                        {
                            <button class="pcf-overlay-btn @(_extractMode ? "pcf-overlay-btn-active" : "")"
                                    title="Extract pages"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => { SetActiveIdx(idx); _ = ToggleExtractMode(); }">
                                <i class="ri-scissors-line"></i>
                            </button>
                        }
                        @if (_maximizedPane == idx)
                        {
                            <button class="pcf-overlay-btn pcf-overlay-btn-active"
                                    title="Restore — return to split view"
                                    @onclick:stopPropagation="true"
                                    @onclick="RestorePane">
                                <i class="ri-fullscreen-exit-line"></i>
                            </button>
                        }
                        else
                        {
                            <button class="pcf-overlay-btn"
                                    title="Maximize pane"
                                    disabled="@(_paneCount == 1)"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => MaximizePane(idx)">
                                <i class="ri-fullscreen-line"></i>
                            </button>
                        }
                        <button class="pcf-overlay-btn pcf-overlay-close"
                                title="Close pane"
                                @onclick:stopPropagation="true"
                                @onclick="() => ClosePane(idx)">
                            <i class="ri-close-line"></i>
                        </button>
                    </div>
                    @{
                        var isExcelPane = _excelData != null && p.File == _excelRelPath && idx == _activeIdx;
                        var isPdfPane = !string.IsNullOrEmpty(p.File) && !isExcelPane;
                        var isEmptyPane = string.IsNullOrEmpty(p.File);
                    }
                    @* JS-managed PDF viewer — always present, hidden when not showing PDF *@
                    <div class="pcf-viewer" id="pcf-viewer-@PaneIds[idx]"
                         style="@(isPdfPane ? "" : "display:none !important;")">
                    </div>
                    @if (isEmptyPane)
                    {
                        <div class="pcf-viewer" style="justify-content:center;">
                            <div class="pcf-empty">
                                <i class="ri-file-search-line" style="font-size:3rem;opacity:.3;"></i>
                                <div class="mt-2" style="font-size:.9rem;">Select a file from the sidebar</div>
                            </div>
                        </div>
                    }
                    else if (isExcelPane)
                    {
                        <div class="pcf-viewer" style="align-items:stretch; padding:16px;">
                            <div class="pcf-excel-editor">
                                @* ── Toolbar (above header) ── *@
                                <div class="pcf-excel-toolbar">
                                    <button class="btn btn-success d-flex align-items-center gap-1 pcf-excel-btn"
                                            disabled="@(!_excelDirty)"
                                            @onclick="SaveExcelChanges">
                                        <i class="ri-save-line"></i> Save
                                    </button>
                                    <button class="btn btn-primary d-flex align-items-center gap-1 pcf-excel-btn"
                                            @onclick="AddExcelRow">
                                        <i class="ri-add-line"></i> Add Row
                                    </button>
                                    @if (_excelDirty)
                                    {
                                        <span style="font-size:.72rem; color:#f59e0b; margin-left:8px;">
                                            <i class="ri-error-warning-line me-1"></i>Unsaved changes
                                        </span>
                                    }
                                </div>

                                @* ── Header info rows ── *@
                                <div class="pcf-excel-header-info">
                                    <div class="pcf-excel-title">TAA Table</div>
                                    <div class="pcf-excel-meta">
                                        <span><strong>PC Name:</strong> @_excelData?.PcName</span>
                                        <span><strong>Action:</strong>
                                            <input value="@(_excelActionEdit ?? _excelData?.Action)"
                                                   @oninput="e => { _excelActionEdit = e.Value?.ToString() ?? string.Empty; _excelDirty = true; }"
                                                   class="pcf-excel-action-input" />
                                        </span>
                                    </div>
                                </div>

                                @* ── Data table ── *@
                                <div class="pcf-excel-table-wrap">
                                    <table class="pcf-excel-table">
                                        <thead>
                                            <tr>
                                                <th class="pcf-excel-rownum">#</th>
                                                @foreach (var h in (_excelData?.ColumnHeaders ?? []).Take(6))
                                                {
                                                    <th>@h</th>
                                                }
                                                <th style="width:36px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{
                                                var dataRows = (_excelData?.Cells ?? [])
                                                    .Where(c => c.Row >= 7 && c.Col <= 6)
                                                    .GroupBy(c => c.Row)
                                                    .OrderBy(g => g.Key)
                                                    .ToList();
                                            }
                                            @foreach (var rowGroup in dataRows)
                                            {
                                                var row = rowGroup.Key;
                                                <tr>
                                                    <td class="pcf-excel-rownum">@(row - 6)</td>
                                                    @foreach (var cell in rowGroup.OrderBy(c => c.Col))
                                                    {
                                                        var r = cell.Row;
                                                        var c = cell.Col;
                                                        var isEditable = c <= 3 || c == 6; // A,B,C,F editable; D,E are formulas
                                                        var displayVal = _excelEdits.TryGetValue((r, c), out var edited) ? edited : cell.Value;
                                                        @if (isEditable)
                                                        {
                                                            <td class="pcf-excel-editable">
                                                                <input value="@displayVal"
                                                                       @oninput="e => OnExcelCellEdit(r, c, e.Value?.ToString() ?? string.Empty)"
                                                                       class="pcf-excel-input" />
                                                            </td>
                                                        }
                                                        else
                                                        {
                                                            var formulaVal = _formulaOverrides.TryGetValue((r, c), out var ov) ? ov : FormatFormulaCell(cell.Value, c);
                                                            <td class="pcf-excel-formula">@formulaVal</td>
                                                        }
                                                    }
                                                    <td class="pcf-excel-actions">
                                                        <button class="pcf-excel-del-btn" title="Delete row"
                                                                @onclick="() => DeleteExcelRow(row)">
                                                            <i class="ri-close-line"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                            @if (dataRows.Count == 0)
                                            {
                                                <tr>
                                                    <td colspan="8" style="text-align:center; padding:20px; color:#64748b;">
                                                        No data rows. Click "Add Row" to start.
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    @{
                        var dualActive = _dualPanes.Contains(PaneIds[idx]);
                        _dualInfo.TryGetValue(PaneIds[idx], out var dualNavInfo);
                    }
                    @if (dualActive)
                    {
                        var canBack  = dualNavInfo.page > 1;
                        var canFwd   = dualNavInfo.page + 2 <= dualNavInfo.total;
                        var navPaneId = PaneIds[idx];
                        <button class="pcf-dual-nav pcf-dual-prev" disabled="@(!canBack)"
                                @onclick:stopPropagation="true"
                                @onclick="() => DualNav(navPaneId, -1)">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <button class="pcf-dual-nav pcf-dual-next" disabled="@(!canFwd)"
                                @onclick:stopPropagation="true"
                                @onclick="() => DualNav(navPaneId, 1)">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

@* ── CS Close Warning ── *@
@if (_showCsCloseWarning)
{
    <div class="pcf-cswarn-overlay" @onclick="() => _showCsCloseWarning = false">
        <div class="pcf-cswarn-dialog" @onclick:stopPropagation="true">
            <div class="pcf-cswarn-icon-wrap">
                <i class="ri-alert-fill pcf-cswarn-icon"></i>
            </div>
            <h3 class="pcf-cswarn-title">Close Without CS Done?</h3>
            <p class="pcf-cswarn-body">
                You are about to close CSing<br />
                <strong>without marking the CS Done.</strong><br />
                Are you sure you want to close without marking it done?
            </p>
            <div class="pcf-cswarn-actions">
                <button class="pcf-cswarn-btn-stay" @onclick="() => _showCsCloseWarning = false">
                    <i class="ri-arrow-left-line me-1"></i>Stay &amp; Finish CS
                </button>
                <button class="pcf-cswarn-btn-close" @onclick="DoCloseToHome">
                    <i class="ri-close-circle-line me-1"></i>Close Without Done
                </button>
            </div>
        </div>
    </div>
}

@* ── Saving indicator ── *@
@if (_saving)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:10001;
                display:flex;align-items:center;justify-content:center;">
        <div class="text-white text-center">
            <div class="spinner-border mb-2" role="status"></div>
            <div>Saving...</div>
        </div>
    </div>
}

@if (_extractMode)
{
    <div class="pcf-extract-bar">
        <span><i class="ri-scissors-line me-2"></i><strong>@_extractCount</strong> page(s) selected</span>
        <div class="d-flex align-items-center gap-2">
            <span style="color:#94a3b8;font-size:.78rem;white-space:nowrap;">Attachment name:</span>
            <input type="text" class="form-control form-control-sm"
                   style="width:160px;background:#0f172a;color:#e2e8f0;border-color:#475569;font-size:.78rem;"
                   @bind="_extractAttName" @bind:event="oninput" />
            <button class="btn btn-sm btn-light" @onclick="CancelExtract">Cancel</button>
            <button class="btn btn-sm btn-primary" @onclick="DoExtract"
                    disabled="@(_extractCount == 0 || string.IsNullOrWhiteSpace(_extractAttName) || _saving)">
                <i class="ri-download-line me-1"></i>Extract
            </button>
        </div>
    </div>
}


@if (!string.IsNullOrEmpty(_errorToast))
{
    <div class="pcf-toast-error">
        <i class="ri-error-warning-line me-2" style="font-size:1.2rem;"></i>
        @_errorToast
    </div>
}

<style>
