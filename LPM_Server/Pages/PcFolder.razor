    async Task DoExtract()
    {
        var file = _panes[_activeIdx].File;
        if (string.IsNullOrEmpty(file)) return;

        Console.WriteLine($"[PcFolder] Extracting pages by '{_userName}' — from '{file}' for PC {PcId}, attachment: '{_extractAttName}'");
        _saving = true;
        StateHasChanged();

        try
        {
            var paneId = PaneIds[_activeIdx];

            // Get selected page indices from JS
            var indices = await JS.InvokeAsync<int[]>("pcfViewer.getSelectedPageIndices");
            if (indices == null || indices.Length == 0) return;

            // Backup the original file before modifying
            FolderSvc.BackupFile(PcId, file, Solo);

            // Read the original PDF (decrypted)
            var srcBytes = FolderSvc.ReadFileBytes(PcId, file, Solo);
            if (srcBytes == null) return;

            // Extract selected pages using PdfSharpCore
            using var srcStream = new System.IO.MemoryStream(srcBytes);
            using var srcDoc = PdfSharpCore.Pdf.IO.PdfReader.Open(srcStream, PdfSharpCore.Pdf.IO.PdfDocumentOpenMode.Import);
            using var newDoc = new PdfSharpCore.Pdf.PdfDocument();

            foreach (var idx in indices)
            {
                if (idx >= 0 && idx < srcDoc.PageCount)
                    newDoc.AddPage(srcDoc.Pages[idx]);
            }

            using var outStream = new System.IO.MemoryStream();
            newDoc.Save(outStream);

            // Save as attachment
            var sessionFileName = System.IO.Path.GetFileName(file);
            var nameNoExt = System.IO.Path.GetFileNameWithoutExtension(sessionFileName);
            var safeName = string.Join("_", _extractAttName.Trim().Split(System.IO.Path.GetInvalidFileNameChars()));
            var attFileName = $"{safeName}.pdf";
            FolderSvc.SaveAttachment(PcId, sessionFileName, attFileName, outStream.ToArray(), Solo);

            // Remove extracted pages from the original PDF
            var selectedSet = new HashSet<int>(indices);
            using var srcStream2 = new System.IO.MemoryStream(srcBytes);
            using var srcDoc2 = PdfSharpCore.Pdf.IO.PdfReader.Open(srcStream2, PdfSharpCore.Pdf.IO.PdfDocumentOpenMode.Import);
            using var remainingDoc = new PdfSharpCore.Pdf.PdfDocument();
            for (int i = 0; i < srcDoc2.PageCount; i++)
            {
                if (!selectedSet.Contains(i))
                    remainingDoc.AddPage(srcDoc2.Pages[i]);
            }
            using var remainingStream = new System.IO.MemoryStream();
            remainingDoc.Save(remainingStream);
            FolderSvc.SaveFile(PcId, file, remainingStream.ToArray(), Solo);

            Console.WriteLine($"[PcFolder] Extracted {indices.Length} pages from '{file}' by '{_userName}' — for PC {PcId}, attachment: '{_extractAttName}'");

            // Exit extract mode
            await JS.InvokeVoidAsync("pcfViewer.exitExtractMode", paneId);
            _extractMode = false;
            _extractCount = 0;

            // Reload the original (now trimmed) PDF in the current pane
            var reloadUrl = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(file)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
            await JS.InvokeVoidAsync("pcfViewer.loadPdf", reloadUrl, paneId);

            // Refresh sidebar to show the new attachment
            RefreshFolder();

            // Find the session worksheet and load the new attachment into a pane
            var sessionNoExt = System.IO.Path.GetFileNameWithoutExtension(sessionFileName);
            var ws = _folder?.WorkSheets.FirstOrDefault(w =>
                System.IO.Path.GetFileNameWithoutExtension(w.File.FileName)
                    .Equals(sessionNoExt, StringComparison.OrdinalIgnoreCase));
            if (ws != null && ws.Attachments.Count > 0)
            {
                var newAtt = ws.Attachments.Last();
                int targetPane;
                if (_paneCount < 3)
                {
                    targetPane = _paneCount;
                    _paneCount++;
                }
                else
                {
                    targetPane = 2;
                }
                _panes[targetPane].File = newAtt.RelativePath;
                _panes[targetPane].FileName = newAtt.FileName;
                _panes[targetPane].Section = "WorkSheet";

                // Reload ALL PDF panes so they resize to the new pane layout (skip .xlsx)
                _pendingReloads ??= new();
                for (int i = 0; i < _paneCount; i++)
                {
                    if (!string.IsNullOrEmpty(_panes[i].File) && !_panes[i].File!.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
                        _pendingReloads.Add((PaneIds[i], _panes[i].File!));
                }
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Extract failed: {ex.Message}");
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

