    int _selectGeneration; // incremented on each click to detect stale loads

    async Task SelectFile(string relativePath, string fileName, string section = "", bool fitAfterLoad = false)
    {
        // Block if this file is already open in a DIFFERENT pane
        var idx = _paneCount == 1 ? 0 : _activeIdx;
        for (int pi = 0; pi < _paneCount; pi++)
        {
            if (pi != idx && _panes[pi].File == relativePath)
            {
                await ShowDupeToast(_panes[pi].FileName ?? fileName, pi + 1);
                return;
            }
        }

        Console.WriteLine($"[PcFolder] Selected file '{fileName}' (section: {section}) by '{_userName}' — for PC {PcId}");
        if (_extractMode) _ = CancelExtract();
        var gen = ++_selectGeneration;
        var paneId = PaneIds[idx];

        // Await save before loading new file to prevent race with loadPdf resetting pane state
        await JS.InvokeVoidAsync("pcfViewer.savePane", paneId);

        _panes[idx].File = relativePath;
        _panes[idx].FileName = SessionDisplayName(fileName);
        _panes[idx].Section = section;

        // Check if this is an Excel file
        if (fileName.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase))
        {
            _excelRelPath = relativePath;
            _excelData = FolderSvc.ReadExcelFile(PcId, relativePath, Solo);
            _excelEdits.Clear();
            _excelDirty = false;
            // Clear the PDF viewer for this pane
            _ = JS.InvokeVoidAsync("eval", $"var v=document.getElementById('pcf-viewer-{paneId}');if(v)v.innerHTML='';");
            return;
        }

        _excelData = null; // clear excel mode
        _excelRelPath = "";

        _hasAnnotations = false;
        _toolMode = "";
        _zoomPercent = 100;

        // Fire-and-forget the PDF load — use special endpoint for folder summary files (Front Cover only)
        var apiPath = IsFolderSummaryFile(fileName, relativePath)
            ? $"/api/pc-file-folder-summary?pcId={PcId}&path={Uri.EscapeDataString(relativePath)}{SoloParam}&_t={DateTime.UtcNow.Ticks}"
            : $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(relativePath)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
        _ = LoadPdfAsync(gen, apiPath, paneId, fitAfterLoad);
    }

    async Task LoadPdfAsync(int gen, string url, string paneId, bool fitAfterLoad = false)
    {
        await Task.Yield(); // release the Blazor sync context immediately
        if (gen != _selectGeneration) return;
        bool wasDual = _dualPanes.Contains(paneId);
        // loadPdf resets dual state in JS; remove tracking before reload
        _dualPanes.Remove(paneId);
        _dualInfo.Remove(paneId);
        await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, paneId);
        if (gen != _selectGeneration) return;
        await JS.InvokeVoidAsync("pcfViewer.setTool", "");
        if (fitAfterLoad)
        {
            var pct = await JS.InvokeAsync<int>("pcfViewer.fitPage", paneId);
            _zoomPercent = pct;
            _fitMode = true;
            await InvokeAsync(StateHasChanged);
        }
        // restore dual mode if it was active before the file change
        if (wasDual)
        {
            var result = await JS.InvokeAsync<int[]>("pcfViewer.enterDualMode", paneId);
            if (result != null && result.Length == 2 && result[1] > 0)
            {
                _dualPanes.Add(paneId);
                _dualInfo[paneId] = (result[0], result[1]);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    // ── Dual-page mode ──

    async Task ToggleDualMode(string paneId)
    {
        if (_dualPanes.Contains(paneId))
        {
            Console.WriteLine($"[PcFolder] Exited dual-page mode on pane '{paneId}' by '{_userName}' — PC {PcId}");
            _dualPanes.Remove(paneId);
            _dualInfo.Remove(paneId);
            await JS.InvokeVoidAsync("pcfViewer.exitDualMode", paneId);
        }
        else
        {
            Console.WriteLine($"[PcFolder] Entered dual-page mode on pane '{paneId}' by '{_userName}' — PC {PcId}");
            var result = await JS.InvokeAsync<int[]>("pcfViewer.enterDualMode", paneId);
            if (result?.Length == 2)
            {
                _dualPanes.Add(paneId);
                _dualInfo[paneId] = (result[0], result[1]);
            }
        }
    }

    async Task ShowDupeToast(string fileName, int paneNum)
    {
        _dupeCts?.Cancel();
        _dupeCts = new System.Threading.CancellationTokenSource();
        _dupeFileName = fileName;
        _dupePaneNum  = paneNum;
        _dupeVisible  = true;
        StateHasChanged();
        var token = _dupeCts.Token;
        try { await Task.Delay(3200, token); } catch (TaskCanceledException) { return; }
        _dupeVisible = false;
        StateHasChanged();
    }

    async Task OpenCsFile()
    {
        if (_folder == null || string.IsNullOrEmpty(_csSessionName)) return;
        var match = _folder.WorkSheets
            .FirstOrDefault(ws => SessionDisplayName(ws.File.FileName)
                .Equals(_csSessionName, StringComparison.OrdinalIgnoreCase));
        if (match != null)
            await SelectFile(match.File.RelativePath, SessionDisplayName(match.File.FileName), "WorkSheet");
    }

    // Voice "Double" command: collapse to single pane, show the right file, enter dual mode.
    async Task VoiceDual()
    {
        string? targetFile = null;
        string? targetFileName = null;
        string targetSection = "";

        // CS mode: use the session being CS'd
        if (_csSessionId > 0 && !string.IsNullOrEmpty(_csSessionName) && _folder != null)
        {
            var match = _folder.WorkSheets
                .FirstOrDefault(ws => SessionDisplayName(ws.File.FileName)
                    .Equals(_csSessionName, StringComparison.OrdinalIgnoreCase));
            if (match != null)
            {
                targetFile = match.File.RelativePath;
                targetFileName = SessionDisplayName(match.File.FileName);
                targetSection = "WorkSheet";
            }
        }

        // Non-CS mode (or CS file not found): use the current active pane
        if (targetFile == null)
        {
            targetFile     = _panes[_activeIdx].File;
            targetFileName = _panes[_activeIdx].FileName;
            targetSection  = _panes[_activeIdx].Section;
        }

        if (string.IsNullOrEmpty(targetFile) || !targetFile.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase))
            return;

        // Already in single-pane dual mode with the right file → toggle off
        if (_paneCount == 1 && _panes[0].File == targetFile && _dualPanes.Contains(PaneIds[0]))
        {
            _dualPanes.Remove(PaneIds[0]);
            _dualInfo.Remove(PaneIds[0]);
            await JS.InvokeVoidAsync("pcfViewer.exitDualMode", PaneIds[0]);
            return;
        }

        // Collapse to single pane with the target file if needed
        bool sameFile = _paneCount == 1 && _panes[0].File == targetFile;
        if (!sameFile)
        {
            for (int i = 0; i < 3; i++) { _panes[i].File = null; _panes[i].FileName = null; _panes[i].Section = ""; }
            _dualPanes.Clear();
            _dualInfo.Clear();
            _paneCount = 1;
            _activeIdx = 0;
            _panes[0].File     = targetFile;
            _panes[0].FileName = targetFileName;
            _panes[0].Section  = targetSection;
            StateHasChanged();
            var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(targetFile)}{SoloParam}&_t={DateTime.UtcNow.Ticks}";
            await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, PaneIds[0]);
        }

        // Enter dual mode
        var result = await JS.InvokeAsync<int[]>("pcfViewer.enterDualMode", PaneIds[0]);
        if (result?.Length == 2)
        {
            _dualPanes.Add(PaneIds[0]);
            _dualInfo[PaneIds[0]] = (result[0], result[1]);
        }
    }

