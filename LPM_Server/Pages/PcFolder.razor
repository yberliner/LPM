@inject LPM.Services.FolderService FolderSvc
@inject IJSRuntime JS
@inject IHttpContextAccessor HttpCtx
@using LPM.Services
@implements IDisposable

<div class="pcf-container">
    @* ── Left sidebar ── *@
    <div class="pcf-sidebar">
        <div class="pcf-sidebar-header">
            <i class="ri-folder-user-line me-2"></i>
            <span class="pcf-pc-name">@_pcName</span>
        </div>

        @if (_folder != null)
        {
            @* ── Front Cover ── *@
            <div class="pcf-section-title pcf-section-front" @onclick="() => _frontExpanded = !_frontExpanded">
                <i class="@(_frontExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-book-open-line me-1"></i>
                Front Cover
                <span class="pcf-section-count">@_folder.FrontCover.Count</span>
            </div>
            @if (_frontExpanded)
            {
                @foreach (var f in _folder.FrontCover)
                {
                    var active = IsFileActive(f.RelativePath);
                    <div class="pcf-file-item @active"
                         @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "Front Cover"))">
                        <i class="ri-file-pdf-2-line me-1"></i>
                        <span class="pcf-file-name">@StripDatePrefix(f.FileName)</span>
                    </div>
                }
            }

            @* ── Back Cover ── *@
            <div class="pcf-section-title pcf-section-back" @onclick="() => _backExpanded = !_backExpanded">
                <i class="@(_backExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-book-3-line me-1"></i>
                Back Cover
                <span class="pcf-section-count">@_folder.BackCover.Count</span>
            </div>
            @if (_backExpanded)
            {
                @foreach (var f in _folder.BackCover)
                {
                    var active = IsFileActive(f.RelativePath);
                    <div class="pcf-file-item @active"
                         @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "Back Cover"))">
                        <i class="ri-file-pdf-2-line me-1"></i>
                        <span class="pcf-file-name">@StripDatePrefix(f.FileName)</span>
                    </div>
                }
            }

            @* ── WorkSheets ── *@
            <div class="pcf-section-title pcf-section-ws" @onclick="() => _wsExpanded = !_wsExpanded">
                <i class="@(_wsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-file-list-3-line me-1"></i>
                WorkSheets
                <span class="pcf-section-count">@_folder.WorkSheets.Count</span>
            </div>
            @if (_wsExpanded)
            {
                var visibleWs = _showAllWorksheets
                    ? _folder.WorkSheets
                    : _folder.WorkSheets.Take(5).ToList();
                @foreach (var f in visibleWs)
                {
                    var active = IsFileActive(f.RelativePath);
                    <div class="pcf-file-item @active"
                         @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "WorkSheet"))">
                        <i class="ri-file-pdf-2-line me-1"></i>
                        <span class="pcf-file-name">@StripDatePrefix(f.FileName)</span>
                        @if (f.DateParsed.HasValue)
                        {
                            <span class="pcf-file-date">@f.DateParsed.Value.ToString("dd/MM/yy")</span>
                        }
                    </div>
                }
                @if (_folder.WorkSheets.Count > 5 && !_showAllWorksheets)
                {
                    <div class="pcf-show-more" @onclick="() => _showAllWorksheets = true">
                        <i class="ri-arrow-down-line me-1"></i>Show @(_folder.WorkSheets.Count - 5) older...
                    </div>
                }
                else if (_showAllWorksheets && _folder.WorkSheets.Count > 5)
                {
                    <div class="pcf-show-more" @onclick="() => _showAllWorksheets = false">
                        <i class="ri-arrow-up-line me-1"></i>Show less
                    </div>
                }
            }
        }
    </div>

    @* ── Main content: PDF viewer ── *@
    <div class="pcf-main">
        @* ── Toolbar ── *@
        <div class="pcf-toolbar">
            <div class="d-flex align-items-center gap-2 flex-grow-1 overflow-hidden">
                <span class="pcf-toolbar-file">
                    <i class="ri-file-pdf-2-line me-1"></i>
                    @if (!string.IsNullOrEmpty(ActiveSection))
                    {
                        <span class="pcf-toolbar-section">@ActiveSection</span>
                    }
                    @(ActiveFileName ?? "Select a file")
                </span>
            </div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0 flex-nowrap">
                <button class="pcf-tool-btn @(_toolMode == "draw" ? "pcf-tool-active" : "")"
                        title="Draw" @onclick='() => SetTool("draw")'>
                    <i class="ri-pencil-line"></i>
                </button>
                <button class="pcf-tool-btn @(_toolMode == "text" ? "pcf-tool-active" : "")"
                        title="Add Text" @onclick='() => SetTool("text")'>
                    <i class="ri-text"></i>
                </button>
                <div class="pcf-color-wrap">
                    <button class="pcf-tool-btn" title="Color" @onclick="() => _showColors = !_showColors"
                            style="border-bottom: 3px solid @_drawColor;">
                        <i class="ri-palette-line"></i>
                    </button>
                    @if (_showColors)
                    {
                        <div class="pcf-color-popup">
                            @foreach (var c in _palette)
                            {
                                <div class="pcf-color-swatch @(c == _drawColor ? "pcf-swatch-active" : "")"
                                     style="background:@c;" title="@c"
                                     @onclick="() => PickColor(c)"></div>
                            }
                        </div>
                    }
                </div>
                <div class="pcf-color-wrap">
                    <button class="pcf-tool-btn" title="Text size" @onclick="() => _showSizes = !_showSizes"
                            style="font-size:.75rem;min-width:36px;">
                        @(_fontSize)px
                    </button>
                    @if (_showSizes)
                    {
                        <div class="pcf-size-popup">
                            @foreach (var s in _fontSizes)
                            {
                                <div class="pcf-size-item @(s == _fontSize ? "pcf-size-active" : "")"
                                     @onclick="() => PickSize(s)">
                                    <span style="font-size:@(Math.Min(s, 20))px;">A</span>
                                    <span>@(s)px</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <button class="pcf-tool-btn" title="Undo" @onclick="Undo">
                    <i class="ri-arrow-go-back-line"></i>
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-save-btn" title="Save" @onclick="SaveAnnotations"
                        disabled="@(!_hasAnnotations)">
                    <i class="ri-save-line me-1"></i>Save
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                @* Split toggle *@
                <button class="pcf-tool-btn @(_splitMode ? "pcf-tool-active" : "")"
                        title="@(_splitMode ? "Single view" : "Split view")"
                        @onclick="ToggleSplit">
                    <i class="ri-layout-column-line"></i>
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-done-btn" title="Close" @onclick="DoneCs">
                    <i class="ri-check-double-line me-1"></i>Done
                </button>
            </div>
        </div>

        @* ── PDF viewer area ── *@
        <div class="pcf-viewer-area @(_splitMode ? "pcf-split" : "")">
            @* Left pane (always visible) *@
            <div class="pcf-pane @(_activePane == "left" ? "pcf-pane-active" : "")"
                 @onclick='() => SetActivePane("left")'>
                @if (_splitMode)
                {
                    <div class="pcf-pane-header">
                        <i class="ri-file-pdf-2-line me-1"></i>
                        @if (!string.IsNullOrEmpty(_leftSection))
                        {
                            <span class="pcf-toolbar-section" style="font-size:.65rem;">@_leftSection</span>
                        }
                        @(_leftFileName ?? "Empty")
                    </div>
                }
                <div class="pcf-viewer" id="pcf-viewer-left">
                    @if (string.IsNullOrEmpty(_leftFile))
                    {
                        <div class="pcf-empty">
                            <i class="ri-file-search-line" style="font-size:3rem;opacity:.3;"></i>
                            <div class="mt-2" style="font-size:.9rem;">Select a file from the sidebar</div>
                        </div>
                    }
                </div>
            </div>

            @* Right pane (only in split mode) *@
            @if (_splitMode)
            {
                <div class="pcf-pane @(_activePane == "right" ? "pcf-pane-active" : "")"
                     @onclick='() => SetActivePane("right")'>
                    <div class="pcf-pane-header">
                        <i class="ri-file-pdf-2-line me-1"></i>
                        @if (!string.IsNullOrEmpty(_rightSection))
                        {
                            <span class="pcf-toolbar-section" style="font-size:.65rem;">@_rightSection</span>
                        }
                        @(_rightFileName ?? "Empty")
                    </div>
                    <div class="pcf-viewer" id="pcf-viewer-right">
                        @if (string.IsNullOrEmpty(_rightFile))
                        {
                            <div class="pcf-empty">
                                <i class="ri-file-search-line" style="font-size:3rem;opacity:.3;"></i>
                                <div class="mt-2" style="font-size:.9rem;">Select a file to view here</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ── Saving indicator ── *@
@if (_saving)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:9999;
                display:flex;align-items:center;justify-content:center;">
        <div class="text-white text-center">
            <div class="spinner-border mb-2" role="status"></div>
            <div>Saving...</div>
        </div>
    </div>
}

<style>
    /* ── Container — fixed overlay to bypass all theme CSS ── */
    .pcf-container {
        display: flex !important; overflow: hidden;
        background: #f1f5f9 !important; color: #1e293b !important;
        position: fixed !important; top: 0; left: 0; right: 0; bottom: 0;
        z-index: 9999; margin: 0 !important; padding: 0 !important;
    }

    /* ── Sidebar ── */
    .pcf-sidebar {
        width: 280px; min-width: 240px; flex-shrink: 0;
        background: #1e293b; color: #e2e8f0;
        overflow-y: auto; display: flex; flex-direction: column;
        scrollbar-width: thin; scrollbar-color: #475569 transparent;
    }
    .pcf-sidebar-header {
        padding: 16px 14px; display: flex; align-items: center;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        border-bottom: 1px solid #334155;
        font-size: 1rem; font-weight: 700; color: #f8fafc;
    }
    .pcf-pc-name {
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .pcf-section-title {
        display: flex; align-items: center; gap: 6px;
        padding: 12px 14px; font-size: .95rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        cursor: pointer; border-bottom: 1px solid #334155;
        transition: background .12s;
    }
    .pcf-section-title:hover { background: #334155; }
    .pcf-section-front { color: #60a5fa; }
    .pcf-section-back  { color: #34d399; }
    .pcf-section-ws    { color: #c084fc; }
    .pcf-section-count {
        margin-left: auto; font-size: .7rem;
        background: #475569; color: #e2e8f0;
        border-radius: 10px; padding: 1px 7px; min-width: 20px; text-align: center;
    }
    .pcf-file-item {
        display: flex; align-items: center; gap: 4px;
        padding: 7px 14px 7px 28px; font-size: .8rem;
        cursor: pointer; transition: background .12s;
        color: #cbd5e1;
    }
    .pcf-file-item:hover { background: #334155; color: #f1f5f9; }
    .pcf-file-active-left {
        background: #3b82f6 !important; color: #fff !important; font-weight: 600;
    }
    .pcf-file-active-right {
        background: #7c3aed !important; color: #fff !important; font-weight: 600;
    }
    .pcf-file-name {
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        flex-grow: 1; min-width: 0;
    }
    .pcf-file-date {
        font-size: .68rem; color: #64748b; flex-shrink: 0;
    }
    .pcf-file-active-left .pcf-file-date,
    .pcf-file-active-right .pcf-file-date { color: rgba(255,255,255,.7); }
    .pcf-show-more {
        padding: 6px 14px 6px 28px; font-size: .76rem;
        color: #60a5fa; cursor: pointer; font-weight: 600;
        transition: background .12s;
    }
    .pcf-show-more:hover { background: #334155; }

    /* ── Main area ── */
    .pcf-main {
        flex-grow: 1; display: flex; flex-direction: column;
        min-width: 0; min-height: 0; overflow: hidden;
    }
    .pcf-toolbar {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 16px;
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        color: #fff; flex-shrink: 0; flex-wrap: nowrap;
        white-space: nowrap; min-height: 44px;
    }
    .pcf-toolbar-file {
        font-size: .85rem; font-weight: 600;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .pcf-toolbar-section {
        background: rgba(255,255,255,.2); border-radius: 4px;
        padding: 1px 8px; margin-right: 6px;
        font-size: .75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .5px;
    }
    .pcf-tool-btn {
        background: rgba(255,255,255,.15); border: 1px solid rgba(255,255,255,.25);
        color: #fff; border-radius: 6px; padding: 4px 10px;
        font-size: .85rem; cursor: pointer;
        transition: background .15s;
    }
    .pcf-tool-btn:hover { background: rgba(255,255,255,.3); }
    .pcf-tool-active {
        background: #fff !important; color: #1e40af !important;
        font-weight: 700;
    }
    .pcf-color-wrap { position: relative; }
    .pcf-color-popup {
        position: absolute; top: 110%; right: 0; z-index: 100;
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px;
        padding: 8px; background: #1e293b; border: 1px solid #475569;
        border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.4);
    }
    .pcf-color-swatch {
        width: 28px; height: 28px; border-radius: 5px; cursor: pointer;
        border: 2px solid transparent; transition: transform .1s, border-color .1s;
    }
    .pcf-color-swatch:hover { transform: scale(1.15); border-color: rgba(255,255,255,.6); }
    .pcf-swatch-active { border-color: #fff !important; box-shadow: 0 0 0 2px #3b82f6; }
    .pcf-size-popup {
        position: absolute; top: 110%; right: 0; z-index: 100;
        display: flex; flex-direction: column; gap: 2px;
        padding: 6px; background: #1e293b; border: 1px solid #475569;
        border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.4);
        min-width: 80px;
    }
    .pcf-size-item {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        padding: 4px 10px; border-radius: 4px; cursor: pointer;
        color: #cbd5e1; font-size: .8rem; transition: background .1s;
    }
    .pcf-size-item:hover { background: #334155; color: #f1f5f9; }
    .pcf-size-active { background: #3b82f6 !important; color: #fff !important; font-weight: 600; }
    .pcf-save-btn {
        background: linear-gradient(135deg, #059669, #10b981);
        border: none; color: #fff; border-radius: 6px;
        padding: 4px 14px; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: opacity .15s, transform .15s;
    }
    .pcf-save-btn:hover:not(:disabled) { transform: translateY(-1px); }
    .pcf-save-btn:disabled { opacity: .4; cursor: default; }
    .pcf-done-btn {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border: none; color: #fff; border-radius: 6px;
        padding: 4px 14px; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: opacity .15s, transform .15s;
    }
    .pcf-done-btn:hover { transform: translateY(-1px); }

    /* ── Viewer area — single or split ── */
    .pcf-viewer-area {
        flex-grow: 1; display: flex; overflow: hidden; min-height: 0;
    }
    .pcf-viewer-area.pcf-split {
        gap: 3px;
    }
    .pcf-pane {
        flex: 1; display: flex; flex-direction: column;
        min-width: 0; min-height: 0; overflow: hidden;
        border: 2px solid transparent;
        transition: border-color .15s;
    }
    .pcf-pane-active {
        border-color: #3b82f6;
    }
    .pcf-pane-header {
        padding: 4px 12px; font-size: .78rem; font-weight: 600;
        background: #334155; color: #e2e8f0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        flex-shrink: 0;
    }
    .pcf-viewer {
        flex-grow: 1; overflow-y: auto; overflow-x: auto;
        display: flex; flex-direction: column; align-items: center;
        padding: 20px; gap: 12px;
        background: #64748b;
    }
    .pcf-empty {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; height: 100%; color: #94a3b8;
    }

    /* ── PDF page wrapper ── */
    .pcf-page-wrapper {
        position: relative; box-shadow: 0 4px 20px rgba(0,0,0,.3);
        background: #fff;
    }
    .pcf-page-wrapper canvas { display: block; }
    .pcf-annotation-canvas {
        position: absolute; top: 0; left: 0;
        cursor: crosshair;
    }

    /* Text input overlay */
    .pcf-text-input {
        position: absolute; border: 2px solid #3b82f6;
        background: rgba(255,255,255,.9); color: #1e293b;
        font-size: 14px; padding: 2px 4px; min-width: 120px;
        outline: none; border-radius: 3px; z-index: 10;
    }

    @@media (max-width: 768px) {
        .pcf-sidebar { width: 200px; min-width: 180px; }
        .pcf-viewer { padding: 10px; }
    }
</style>

@code {
    [Parameter] public int PcId { get; set; }

    string _pcName = "";
    PcFolderInfo? _folder;

    // Per-pane state
    string? _leftFile;
    string? _leftFileName;
    string _leftSection = "";
    string? _rightFile;
    string? _rightFileName;
    string _rightSection = "";

    string _activePane = "left";
    bool _splitMode;

    bool _frontExpanded = true;
    bool _backExpanded = true;
    bool _wsExpanded = true;
    bool _showAllWorksheets;
    string _toolMode = "";
    string _drawColor = "#e11d48";
    int _fontSize = 14;
    bool _showColors;
    bool _showSizes;
    bool _hasAnnotations;
    bool _saving;

    // Computed properties for active pane
    string? ActiveFile => _activePane == "right" ? _rightFile : _leftFile;
    string? ActiveFileName => _activePane == "right" ? _rightFileName : _leftFileName;
    string ActiveSection => _activePane == "right" ? _rightSection : _leftSection;

    static readonly int[] _fontSizes = [10, 12, 14, 18, 24, 32, 40, 56];

    static readonly string[] _palette = [
        "#000000", "#ffffff", "#e11d48", "#f97316",
        "#eab308", "#22c55e", "#06b6d4", "#3b82f6",
        "#8b5cf6", "#ec4899", "#78716c", "#475569",
        "#dc2626", "#16a34a", "#2563eb", "#7c3aed"
    ];

    string IsFileActive(string relativePath)
    {
        if (relativePath == _leftFile) return "pcf-file-active-left";
        if (_splitMode && relativePath == _rightFile) return "pcf-file-active-right";
        return "";
    }

    protected override void OnInitialized()
    {
        _folder = FolderSvc.GetPcFolder(PcId);
        _pcName = _folder?.PcName ?? $"PC {PcId}";

        // Check for ?file=SessionName query parameter
        var requestedFile = HttpCtx.HttpContext?.Request.Query["file"].ToString();

        FolderFileItem? match = null;
        if (!string.IsNullOrWhiteSpace(requestedFile) && _folder != null)
        {
            match = _folder.WorkSheets
                .FirstOrDefault(f => StripDatePrefix(f.FileName)
                    .Equals(requestedFile, StringComparison.OrdinalIgnoreCase));
        }

        if (match != null)
        {
            _leftFile = match.RelativePath;
            _leftFileName = StripDatePrefix(match.FileName);
            _leftSection = "WorkSheet";
        }
        else if (_folder?.WorkSheets.Count > 0)
        {
            var latest = _folder.WorkSheets[0];
            _leftFile = latest.RelativePath;
            _leftFileName = StripDatePrefix(latest.FileName);
            _leftSection = "WorkSheet";
        }
    }

    DotNetObjectReference<PcFolder>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("pcfViewer.setDotNetRef", _dotNetRef);
            await JS.InvokeVoidAsync("pcfViewer.setPcId", PcId);

            if (!string.IsNullOrEmpty(_leftFile))
            {
                var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(_leftFile)}&_t={DateTime.UtcNow.Ticks}";
                await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, "left");
            }
        }

        if (_pendingReload != null)
        {
            var (pane, file) = _pendingReload.Value;
            _pendingReload = null;
            var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(file)}&_t={DateTime.UtcNow.Ticks}";
            await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, pane);
        }
    }

    (string pane, string file)? _pendingReload;

    [JSInvokable]
    public void OnAnnotationChanged()
    {
        _hasAnnotations = true;
        InvokeAsync(StateHasChanged);
    }

    async Task SelectFile(string relativePath, string fileName, string section = "")
    {
        var pane = _activePane;
        if (!_splitMode) pane = "left";

        // Auto-save current pane before switching
        await JS.InvokeVoidAsync("pcfViewer.savePane", pane);

        // Update state for the target pane
        if (pane == "right")
        {
            _rightFile = relativePath;
            _rightFileName = StripDatePrefix(fileName);
            _rightSection = section;
        }
        else
        {
            _leftFile = relativePath;
            _leftFileName = StripDatePrefix(fileName);
            _leftSection = section;
        }

        _hasAnnotations = false;
        _toolMode = "";
        StateHasChanged();

        var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(relativePath)}&_t={DateTime.UtcNow.Ticks}";
        await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, pane);
        await JS.InvokeVoidAsync("pcfViewer.setTool", "");
    }

    void SetActivePane(string pane)
    {
        if (_activePane == pane) return;
        _activePane = pane;
        // Update toolbar annotation state for the new active pane
        _ = JS.InvokeAsync<bool>("pcfViewer.hasAnnotations", pane).AsTask().ContinueWith(t =>
        {
            if (t.IsCompletedSuccessfully)
            {
                _hasAnnotations = t.Result;
                InvokeAsync(StateHasChanged);
            }
        });
    }

    async Task ToggleSplit()
    {
        _splitMode = !_splitMode;
        if (!_splitMode)
        {
            // Closing split — auto-save right pane if it has annotations
            await JS.InvokeVoidAsync("pcfViewer.savePane", "right");
            _rightFile = null;
            _rightFileName = null;
            _rightSection = "";
            _activePane = "left";
            // Reload left pane to fit new (full) width after next render
            if (!string.IsNullOrEmpty(_leftFile))
                _pendingReload = ("left", _leftFile);
        }
        else
        {
            // Opening split — set active to right so next file click goes there
            _activePane = "right";
            // Reload left pane to fit new (half) width after next render
            if (!string.IsNullOrEmpty(_leftFile))
                _pendingReload = ("left", _leftFile);
        }
        await JS.InvokeVoidAsync("pcfViewer.setActivePane", _activePane);
    }

    async Task SetTool(string mode)
    {
        _toolMode = _toolMode == mode ? "" : mode;
        await JS.InvokeVoidAsync("pcfViewer.setTool", _toolMode);
    }

    async Task Undo()
    {
        await JS.InvokeVoidAsync("pcfViewer.undo", _activePane);
        _hasAnnotations = await JS.InvokeAsync<bool>("pcfViewer.hasAnnotations", _activePane);
    }

    async Task PickColor(string color)
    {
        _drawColor = color;
        _showColors = false;
        await JS.InvokeVoidAsync("pcfViewer.setColor", color);
    }

    async Task PickSize(int size)
    {
        _fontSize = size;
        _showSizes = false;
        await JS.InvokeVoidAsync("pcfViewer.setFontSize", size);
    }

    async Task SaveAnnotations()
    {
        var file = ActiveFile;
        if (string.IsNullOrEmpty(file)) return;
        _saving = true;
        StateHasChanged();

        try
        {
            var pagesJson = await JS.InvokeAsync<string>("pcfViewer.getAnnotatedPdf", _activePane);
            await JS.InvokeVoidAsync("pcfSaveAnnotatedPdf", PcId, file, pagesJson);

            _hasAnnotations = false;
            var url = $"/api/pc-file?pcId={PcId}&path={Uri.EscapeDataString(file)}&_t={DateTime.UtcNow.Ticks}";
            await JS.InvokeVoidAsync("pcfViewer.loadPdf", url, _activePane);
        }
        finally
        {
            _saving = false;
            StateHasChanged();
        }
    }

    async Task DoneCs()
    {
        // Auto-save all panes before closing
        await JS.InvokeVoidAsync("pcfViewer.savePane", "left");
        if (_splitMode)
            await JS.InvokeVoidAsync("pcfViewer.savePane", "right");

        var confirmed = await JS.InvokeAsync<bool>("confirm", "Is CSing done?");
        if (confirmed)
            await JS.InvokeVoidAsync("window.close");
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    static string StripDatePrefix(string fileName)
    {
        var name = Path.GetFileNameWithoutExtension(fileName);
        if (name.Length > 9 && name[2] == '-' && name[5] == '-' && name[8] == '_')
            name = name[9..];
        return name;
    }
}
