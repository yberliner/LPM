@inject LPM.Services.FolderService FolderSvc
@inject LPM.Services.DashboardService DashSvc
@inject LPM.Services.CsNotificationService CsNotifySvc
@inject LPM.Services.ShortcutService ShortcutSvc
@inject IJSRuntime JS
@using LPM.Services
@implements IDisposable

<div class="pcf-container">
    @* ── Left sidebar ── *@
    <div class="pcf-sidebar @(_sidebarOpen ? "" : "pcf-sidebar-collapsed")">
        <div class="pcf-sidebar-header">
            <i class="ri-folder-user-line me-2"></i>
            <span class="pcf-pc-name">@_pcName</span>
            <button class="pcf-sidebar-toggle" title="Collapse sidebar" @onclick="() => _sidebarOpen = false">
                <i class="ri-arrow-left-double-line"></i>
            </button>
        </div>

        @if (_folder != null)
        {
            @* ── Front Cover ── *@
            <div class="pcf-section-title pcf-section-front" @onclick="() => _frontExpanded = !_frontExpanded">
                <i class="@(_frontExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-book-open-line me-1"></i>
                Front Cover
                <span class="pcf-section-count">@_folder.FrontCover.Count</span>
            </div>
            @if (_frontExpanded)
            {
                @foreach (var f in _folder.FrontCover)
                {
                    var active = IsFileActive(f.RelativePath);
                    var clr = GetCoverBorderColor(f.FileName);
                    var coverStyle = !string.IsNullOrEmpty(clr)
                        ? $"border-left:3px solid {clr}; background:rgba({HexToRgb(clr)},.08);" : "";
                    <div class="pcf-file-item @active"
                         style="@coverStyle"
                         @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "Front Cover"))">
                        @if (!string.IsNullOrEmpty(clr))
                        {
                            <span class="pcf-cover-dot" style="background:@clr;"></span>
                        }
                        <span class="pcf-file-name">@StripDatePrefix(f.FileName)</span>
                    </div>
                }
            }

            @* ── Back Cover ── *@
            <div class="pcf-section-title pcf-section-back" @onclick="() => _backExpanded = !_backExpanded">
                <i class="@(_backExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-book-3-line me-1"></i>
                Back Cover
                <span class="pcf-section-count">@_folder.BackCover.Count</span>
            </div>
            @if (_backExpanded)
            {
                @foreach (var f in _folder.BackCover)
                {
                    var active = IsFileActive(f.RelativePath);
                    var clr = GetCoverBorderColor(f.FileName);
                    var coverStyle = !string.IsNullOrEmpty(clr)
                        ? $"border-left:3px solid {clr}; background:rgba({HexToRgb(clr)},.08);" : "";
                    <div class="pcf-file-item @active"
                         style="@coverStyle"
                         @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "Back Cover"))">
                        @if (!string.IsNullOrEmpty(clr))
                        {
                            <span class="pcf-cover-dot" style="background:@clr;"></span>
                        }
                        <span class="pcf-file-name">@StripDatePrefix(f.FileName)</span>
                    </div>
                }
            }

            @* ── WorkSheets ── *@
            <div class="pcf-section-title pcf-section-ws" @onclick="() => _wsExpanded = !_wsExpanded">
                <i class="@(_wsExpanded ? "ri-arrow-down-s-line" : "ri-arrow-right-s-line")"></i>
                <i class="ri-file-list-3-line me-1"></i>
                WorkSheets
                <span class="pcf-section-count">@_folder.WorkSheets.Count</span>
            </div>
            @if (_wsExpanded)
            {
                @* ── Search filter ── *@
                <div class="pcf-ws-search">
                    <i class="ri-search-line"></i>
                    <input type="text" placeholder="Search worksheets..."
                           value="@_wsFilter" @oninput="OnWsFilterChanged" />
                    @if (!string.IsNullOrEmpty(_wsFilter))
                    {
                        <i class="ri-close-line pcf-ws-search-clear" @onclick="ClearWsFilter"></i>
                    }
                </div>

                @foreach (var ws in GetWsPage(out var totalPages))
                {
                    var f = ws.File;
                    var active = IsFileActive(f.RelativePath);
                    var stripped = StripDatePrefix(f.FileName);
                    var csed = _nameToSessionId.TryGetValue(stripped, out var fSid) && _csedSessionIds.Contains(fSid);
                    var isCsTarget = !string.IsNullOrEmpty(_csSessionName)
                        && stripped.Equals(_csSessionName, StringComparison.OrdinalIgnoreCase);
                    var hasAtt = ws.Attachments.Count > 0;
                    var wsKey = f.RelativePath;
                    var attExpanded = !_collapsedAttachments.Contains(wsKey);

                    @* ── Session row ── *@
                    <div class="pcf-file-item @active @(isCsTarget ? "pcf-file-cs-target" : "")">
                        @if (hasAtt)
                        {
                            <i class="@(attExpanded ? "ri-arrow-down-s-fill" : "ri-arrow-right-s-fill") pcf-att-toggle"
                               @onclick="() => ToggleAttachments(wsKey)"
                               @onclick:stopPropagation="true"></i>
                        }
                        <span style="flex:1; display:flex; align-items:center; gap:4px; min-width:0;"
                              @onclick="@(() => SelectFile(f.RelativePath, f.FileName, "WorkSheet"))">
                            @if (isCsTarget)
                            {
                                <i class="ri-star-fill pcf-star-pulse" style="flex-shrink:0;"></i>
                            }
                            else
                            {
                                <i class="ri-file-pdf-2-line @(csed ? "text-success" : "")" style="flex-shrink:0;"></i>
                            }
                            <span class="pcf-file-name @(csed ? "pcf-file-csed" : "")">@stripped</span>
                            @if (csed)
                            {
                                <i class="ri-check-line" style="color:#22c55e;font-size:.7rem;flex-shrink:0;" title="CS Done"></i>
                            }
                        </span>
                        @if (hasAtt)
                        {
                            <span class="pcf-att-count">@ws.Attachments.Count</span>
                        }
                        @if (f.DateParsed.HasValue)
                        {
                            <span class="pcf-file-date">@f.DateParsed.Value.ToString("dd/MM/yy")</span>
                        }
                    </div>

                    @* ── Attachment children ── *@
                    @if (hasAtt && attExpanded)
                    {
                        <div class="pcf-att-group">
                            @foreach (var att in ws.Attachments)
                            {
                                var attActive = IsFileActive(att.RelativePath);
                                <div class="pcf-att-child @attActive"
                                     @onclick="@(() => SelectFile(att.RelativePath, att.FileName, "WorkSheet"))">
                                    <span class="pcf-att-line"></span>
                                    <i class="ri-file-pdf-2-line" style="font-size:.7rem; opacity:.5; flex-shrink:0;"></i>
                                    <span class="pcf-file-name">@att.FileName</span>
                                </div>
                            }
                        </div>
                    }
                }

                @* ── Pagination ── *@
                @if (WsTotalPages > 1)
                {
                    <div class="pcf-ws-pager">
                        <button disabled="@(_wsPage == 0)" @onclick="() => _wsPage--">
                            <i class="ri-arrow-left-s-line"></i>
                        </button>
                        <span>@(_wsPage + 1) / @WsTotalPages</span>
                        <button disabled="@(_wsPage >= WsTotalPages - 1)" @onclick="() => _wsPage++">
                            <i class="ri-arrow-right-s-line"></i>
                        </button>
                        <span class="pcf-ws-pager-total">(@WsFilteredCount)</span>
                    </div>
                }
                else if (WsFilteredCount == 0 && !string.IsNullOrWhiteSpace(_wsFilter))
                {
                    <div style="padding:8px 28px;font-size:.76rem;color:#94a3b8;">No matches</div>
                }
            }
        }
    </div>

    @* ── Sidebar backdrop for mobile ── *@
    @if (_sidebarOpen)
    {
        <div class="pcf-sidebar-backdrop" @onclick="() => _sidebarOpen = false"></div>
    }

    @* ── Main content: PDF viewer ── *@
    <div class="pcf-main">
        @* ── Toolbar ── *@
        <div class="pcf-toolbar">
            <div class="d-flex align-items-center gap-2 flex-shrink-0" style="min-width:0;overflow:hidden;">
                @if (!_sidebarOpen)
                {
                    <button class="pcf-tool-btn" title="Open sidebar — show file list"
                            @onclick="() => _sidebarOpen = true">
                        <i class="ri-side-bar-line"></i>
                    </button>
                    <div class="vr mx-0" style="border-color:rgba(255,255,255,.3);"></div>
                }
                <span class="pcf-toolbar-file">
                    <i class="ri-file-pdf-2-line me-1"></i>
                    @{ var ap = _panes[_activeIdx]; }
                    @if (!string.IsNullOrEmpty(ap.Section))
                    {
                        <span class="pcf-toolbar-section">@ap.Section</span>
                    }
                    @(ap.FileName ?? "Select a file")
                </span>
            </div>
            @if (!string.IsNullOrEmpty(_csSessionName))
            {
                <div class="flex-grow-1 d-flex justify-content-center align-items-center gap-3">
                    <span class="pcf-cs-session-label">
                        <span style="opacity:.7;font-weight:400;">CSing:</span> @_csSessionName
                    </span>
                    <div class="pcf-timer @(_csReviewMinutes <= 0 ? "pcf-timer-zero" : "")"
                         title="CS Review time (session + admin). This value will be saved when you press Mark CS Done. Edit hours and minutes if needed.">
                        <i class="ri-timer-line pcf-timer-icon"></i>
                        <div class="pcf-timer-display">
                            <input type="number" min="0" class="pcf-timer-num"
                                   value="@(_csReviewMinutes / 60)"
                                   @onchange="e => OnTimerHoursChanged(e)" />
                            <span class="pcf-timer-colon">:</span>
                            <input type="number" min="0" max="59" class="pcf-timer-num"
                                   value="@(_csReviewMinutes % 60)"
                                   @onchange="e => OnTimerMinsChanged(e)" />
                        </div>
                        @if (_csReviewMinutes <= 0)
                        {
                            <i class="ri-error-warning-line pcf-timer-warn" title="Review time is 0 — update before marking done"></i>
                        }
                    </div>
                </div>
            }
            <div class="pcf-tools-right">
                <button class="pcf-tool-btn @(_toolMode == "draw" ? "pcf-tool-active" : "")"
                        title="Draw — click and drag on the PDF to draw freehand annotations"
                        @onclick='() => SetTool("draw")'>
                    <i class="ri-pencil-line"></i>
                </button>
                <button class="pcf-tool-btn @(_toolMode == "text" ? "pcf-tool-active" : "")"
                        title="Add Text — click anywhere on the PDF to place a text note"
                        @onclick='() => SetTool("text")'>
                    <i class="ri-text"></i>
                </button>
                <div class="pcf-color-wrap">
                    <button class="pcf-tool-btn" title="Pick color — choose a color for drawing and text annotations"
                            @onclick="() => _showColors = !_showColors"
                            style="border-bottom: 3px solid @_drawColor;">
                        <i class="ri-palette-line"></i>
                    </button>
                    @if (_showColors)
                    {
                        <div class="pcf-color-popup">
                            @foreach (var c in _palette)
                            {
                                <div class="pcf-color-swatch @(c == _drawColor ? "pcf-swatch-active" : "")"
                                     style="background:@c;" title="@c"
                                     @onclick="() => PickColor(c)"></div>
                            }
                        </div>
                    }
                </div>
                <div class="pcf-color-wrap">
                    <button class="pcf-tool-btn" title="Text size — change the font size for text annotations"
                            @onclick="() => _showSizes = !_showSizes"
                            style="font-size:.75rem;min-width:36px;">
                        @(_fontSize)px
                    </button>
                    @if (_showSizes)
                    {
                        <div class="pcf-size-popup">
                            @foreach (var s in _fontSizes)
                            {
                                <div class="pcf-size-item @(s == _fontSize ? "pcf-size-active" : "")"
                                     @onclick="() => PickSize(s)">
                                    <span style="font-size:@(Math.Min(s, 20))px;">A</span>
                                    <span>@(s)px</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <button class="pcf-tool-btn" title="Undo — remove the last annotation on the active pane (Ctrl+Z)" @onclick="Undo">
                    <i class="ri-arrow-go-back-line"></i>
                </button>
                <div class="pcf-addpage-wrap">
                    <button class="pcf-tool-btn" title="Add blank page" @onclick="ToggleAddPageMenu">
                        <i class="ri-file-add-line"></i>
                    </button>
                    @if (_showAddPageMenu)
                    {
                        <div class="pcf-addpage-menu">
                            <button @onclick="AddBlankPageAbove">
                                <i class="ri-arrow-up-line me-2"></i>Add Page Above
                            </button>
                            <button @onclick="AddBlankPageBelow">
                                <i class="ri-arrow-down-line me-2"></i>Add Page Below
                            </button>
                        </div>
                    }
                </div>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                <button class="pcf-save-btn" title="Save — save annotations to the PDF now (also auto-saves when switching files or closing)"
                        @onclick="SaveAnnotations"
                        disabled="@(!_hasAnnotations)">
                    <i class="ri-save-line me-1"></i>Save
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                @* Pane count toggle: cycles 1→2→3→1 *@
                <button class="pcf-tool-btn @(_paneCount > 1 ? "pcf-tool-active" : "")"
                        title="Split view — currently @_paneCount pane(s). Click to cycle between 1, 2, or 3 side-by-side panes for comparing files"
                        @onclick="CyclePanes">
                    <i class="ri-layout-column-line"></i>
                    <span style="font-size:.7rem;margin-left:2px;">@_paneCount</span>
                </button>
                <div class="vr mx-1" style="border-color:rgba(255,255,255,.3);"></div>
                @if (_csDone)
                {
                    <button class="pcf-done-btn pcf-done-success" disabled>
                        <i class="ri-check-line me-1"></i>CS Done
                    </button>
                }
                else
                {
                    <button class="pcf-done-btn" title="@(_csLocked ? "Another tab is already CSing this session" : "Mark CS Done — saves all annotations, records the CS review with the displayed time, and closes the tab")"
                            @onclick="DoneCs" disabled="@(_csSessionId == 0 || _csLocked)">
                        <i class="ri-check-double-line me-1"></i>Mark CS Done
                    </button>
                }
            </div>
        </div>

        @if (_csLocked)
        {
            <div class="pcf-lock-banner">
                <i class="ri-lock-line me-2"></i>
                This session is already being CSed by <strong>@_csLockedBy</strong> in another tab.
                You can view the files but cannot mark CS as done.
            </div>
        }

        @* ── PDF viewer area ── *@
        <div class="pcf-viewer-area @(_paneCount > 1 ? "pcf-split" : "")">
            @for (int pi = 0; pi < _paneCount; pi++)
            {
                var idx = pi;
                var p = _panes[idx];
                <div class="pcf-pane @(_activeIdx == idx ? "pcf-pane-active" : "")"
                     @onclick="() => SetActiveIdx(idx)">
                    @if (_paneCount > 1)
                    {
                        <div class="pcf-pane-header pcf-pane-hdr-@PaneIds[idx]">
                            <i class="ri-file-pdf-2-line me-1"></i>
                            @if (!string.IsNullOrEmpty(p.Section))
                            {
                                <span class="pcf-toolbar-section" style="font-size:.65rem;">@p.Section</span>
                            }
                            @(p.FileName ?? "Empty")
                        </div>
                    }
                    <div class="pcf-viewer" id="pcf-viewer-@PaneIds[idx]">
                        @if (string.IsNullOrEmpty(p.File))
                        {
                            <div class="pcf-empty">
                                <i class="ri-file-search-line" style="font-size:3rem;opacity:.3;"></i>
                                <div class="mt-2" style="font-size:.9rem;">Select a file from the sidebar</div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* ── Saving indicator ── *@
@if (_saving)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:10001;
                display:flex;align-items:center;justify-content:center;">
        <div class="text-white text-center">
            <div class="spinner-border mb-2" role="status"></div>
            <div>Saving...</div>
        </div>
    </div>
}

@if (_csDone)
{
    <div class="pcf-toast-success">
        <i class="ri-check-double-line me-2" style="font-size:1.2rem;"></i>
        CS review marked as done! You can close this tab.
    </div>
}

<style>
    .pcf-container {
        display: flex !important; overflow: hidden;
        background: #f1f5f9 !important; color: #1e293b !important;
        position: fixed !important; top: 0; left: 0; right: 0; bottom: 0;
        z-index: 9999; margin: 0 !important; padding: 0 !important;
    }

    /* ── Sidebar ── */
    .pcf-sidebar {
        width: 280px; min-width: 240px; flex-shrink: 0;
        background: #1e293b; color: #e2e8f0;
        overflow-y: auto; display: flex; flex-direction: column;
        scrollbar-width: thin; scrollbar-color: #475569 transparent;
        -webkit-overflow-scrolling: touch;
    }
    .pcf-sidebar-collapsed { display: none; }
    .pcf-sidebar-backdrop { display: none; }
    .pcf-sidebar-header {
        padding: 16px 14px; display: flex; align-items: center;
        background: linear-gradient(135deg, #0f172a, #1e293b);
        border-bottom: 1px solid #334155;
        font-size: 1rem; font-weight: 700; color: #f8fafc;
    }
    .pcf-sidebar-toggle {
        margin-left: auto; background: transparent; border: none;
        color: #94a3b8; cursor: pointer; font-size: .85rem;
        padding: 2px 6px; border-radius: 4px; transition: all .15s;
    }
    .pcf-sidebar-toggle:hover { color: #f1f5f9; background: rgba(255,255,255,.1); }
    .pcf-pc-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .pcf-section-title {
        display: flex; align-items: center; gap: 6px;
        padding: 12px 14px; font-size: .95rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .5px;
        cursor: pointer; border-bottom: 1px solid #334155;
        transition: background .12s;
    }
    .pcf-section-title:hover { background: #334155; }
    .pcf-section-front { color: #60a5fa; }
    .pcf-section-back  { color: #34d399; }
    .pcf-section-ws    { color: #c084fc; }
    .pcf-section-count {
        margin-left: auto; font-size: .7rem;
        background: #475569; color: #e2e8f0;
        border-radius: 10px; padding: 1px 7px; min-width: 20px; text-align: center;
    }
    .pcf-file-item {
        display: flex; align-items: center; gap: 4px;
        padding: 7px 14px 7px 28px; font-size: .8rem;
        cursor: pointer; transition: background .12s; color: #cbd5e1;
    }
    .pcf-file-item:hover { background: #334155; color: #f1f5f9; }
    .pcf-file-active-p1 { background: #3b82f6 !important; color: #fff !important; font-weight: 600; }
    .pcf-file-active-p2 { background: #7c3aed !important; color: #fff !important; font-weight: 600; }
    .pcf-file-active-p3 { background: #d97706 !important; color: #fff !important; font-weight: 600; }
    .pcf-file-name { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex-grow: 1; min-width: 0; }
    .pcf-file-csed { color: #22c55e !important; }
    .pcf-file-cs-target {
        border-left: 3px solid #fbbf24 !important;
        animation: pcf-target-glow 2.5s ease-in-out infinite;
    }
    @@keyframes pcf-target-glow {
        0%, 100% { background: rgba(251,191,36,.06); box-shadow: inset 0 0 8px rgba(251,191,36,.05); }
        50%      { background: rgba(251,191,36,.18); box-shadow: inset 0 0 16px rgba(251,191,36,.12); }
    }
    .pcf-star-pulse {
        color: #fbbf24; font-size: .85rem;
        animation: pcf-star-blink 2s ease-in-out infinite;
    }
    @@keyframes pcf-star-blink {
        0%, 100% { opacity: .5; transform: scale(.9); }
        50%      { opacity: 1; transform: scale(1.1); }
    }
    .pcf-att-toggle {
        font-size: .75rem; color: #64748b; cursor: pointer;
        flex-shrink: 0; padding: 0 2px; transition: color .12s;
    }
    .pcf-att-toggle:hover { color: #e2e8f0; }
    .pcf-att-count {
        font-size: .58rem; color: #64748b; background: rgba(255,255,255,.06);
        border-radius: 6px; padding: 0 4px; flex-shrink: 0;
        min-width: 14px; text-align: center;
    }
    .pcf-att-group {
        margin-left: 20px; border-left: 1px solid #334155;
    }
    .pcf-att-child {
        display: flex; align-items: center; gap: 4px;
        padding: 4px 10px 4px 12px; font-size: .72rem;
        color: #94a3b8; cursor: pointer; transition: background .12s;
    }
    .pcf-att-child:hover { background: #334155; color: #cbd5e1; }
    .pcf-att-child.pcf-file-active-p1 { background: rgba(59,130,246,.25) !important; color: #fff !important; }
    .pcf-att-child.pcf-file-active-p2 { background: rgba(124,58,237,.25) !important; color: #fff !important; }
    .pcf-att-child.pcf-file-active-p3 { background: rgba(217,119,6,.25) !important; color: #fff !important; }
    .pcf-att-line {
        width: 10px; height: 1px; background: #334155; flex-shrink: 0;
    }
    .pcf-cover-dot {
        width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0;
    }
    .pcf-file-date { font-size: .68rem; color: #64748b; flex-shrink: 0; }
    .pcf-file-active-p1 .pcf-file-date,
    .pcf-file-active-p2 .pcf-file-date,
    .pcf-file-active-p3 .pcf-file-date { color: rgba(255,255,255,.7); }
    .pcf-ws-search {
        display: flex; align-items: center; gap: 6px;
        padding: 6px 14px; border-bottom: 1px solid #334155;
    }
    .pcf-ws-search i { color: #64748b; font-size: .8rem; }
    .pcf-ws-search input {
        flex: 1; background: #0f172a; border: 1px solid #475569;
        color: #e2e8f0; border-radius: 4px; padding: 3px 8px;
        font-size: .76rem; outline: none; min-width: 0;
    }
    .pcf-ws-search input::placeholder { color: #64748b; }
    .pcf-ws-search input:focus { border-color: #60a5fa; }
    .pcf-ws-search-clear { cursor: pointer; color: #94a3b8 !important; }
    .pcf-ws-search-clear:hover { color: #e2e8f0 !important; }
    .pcf-ws-pager {
        display: flex; align-items: center; justify-content: center;
        gap: 8px; padding: 6px 14px; border-top: 1px solid #334155;
        font-size: .72rem; color: #94a3b8;
    }
    .pcf-ws-pager button {
        background: #334155; border: none; color: #e2e8f0;
        border-radius: 4px; padding: 2px 8px; cursor: pointer;
        font-size: .76rem; transition: background .12s;
    }
    .pcf-ws-pager button:hover:not(:disabled) { background: #475569; }
    .pcf-ws-pager button:disabled { opacity: .3; cursor: default; }
