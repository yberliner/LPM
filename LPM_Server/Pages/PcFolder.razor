@* ── Conversion toast panel ── *@
@if (_conversionToasts.Count > 0)
{
    <div class="pcf-toast-panel">
        @foreach (var toast in _conversionToasts)
        {
            <div class="pcf-toast @(toast.Status == ConvStatus.Done ? "pcf-toast-done" : toast.Status == ConvStatus.Failed ? "pcf-toast-error" : "")">
                <span class="pcf-toast-icon">
                    @if (toast.Status == ConvStatus.Running)
                    {
                        <span class="spinner-border spinner-border-sm text-info" role="status"></span>
                    }
                    else if (toast.Status == ConvStatus.Done)
                    {
                        <i class="ri-checkbox-circle-line text-success"></i>
                    }
                    else
                    {
                        <i class="ri-error-warning-line text-danger"></i>
                    }
                </span>
                <div class="pcf-toast-text">
                    <div class="pcf-toast-name">@toast.FileName</div>
                    <div class="pcf-toast-sub">
                        @if (toast.Status == ConvStatus.Running) { <span>Converting to PDF...</span> }
                        else if (toast.Status == ConvStatus.Done) { <span>Added to folder</span> }
                        else { <span>Conversion failed</span> }
                    </div>
                </div>
                @if (toast.Status != ConvStatus.Running)
                {
                    <button class="pcf-toast-close" @onclick="() => _conversionToasts.Remove(toast)">
                        <i class="ri-close-line"></i>
                    </button>
                }
            </div>
        }
    </div>
}

@* ── "Already open in pane N" toast ── *@
@if (_dupeVisible)
{
    var _dupeColor  = _dupePaneNum == 1 ? "#3b82f6" : _dupePaneNum == 2 ? "#8b5cf6" : "#f59e0b";
    var _dupeGlow   = _dupePaneNum == 1 ? "rgba(59,130,246,.35)" : _dupePaneNum == 2 ? "rgba(139,92,246,.35)" : "rgba(245,158,11,.35)";
    <div class="pcf-dupe-toast" style="--dupe-color:@_dupeColor;--dupe-glow:@_dupeGlow;">
        <div class="pcf-dupe-icon">
            <i class="ri-layout-column-line"></i>
        </div>
        <div class="pcf-dupe-body">
            <div class="pcf-dupe-name">@_dupeFileName</div>
            <div class="pcf-dupe-sub">Already open in <span class="pcf-dupe-badge">Pane @_dupePaneNum</span></div>
        </div>
    </div>
}

