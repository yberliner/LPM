    async Task OpenFsModal()
    {
        _fsEntries = DashSvc.GetSessionSummariesForPcEdit(PcId, Solo);
        _fsEditingId = null;
        _showFsModal = true;
        StateHasChanged();
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval", @"
            (function() {
                var tbl = document.querySelector('.pcf-fs-table');
                if (!tbl || tbl._resizeInit) return;
                tbl._resizeInit = true;
                tbl.querySelectorAll('thead th').forEach(function(th) {
                    th.style.position = 'relative';
                    var handle = document.createElement('div');
                    handle.className = 'pcf-fs-col-resize';
                    th.appendChild(handle);
                    handle.addEventListener('mousedown', function(e) {
                        e.preventDefault(); e.stopPropagation();
                        handle.classList.add('dragging');
                        var startX = e.pageX, startW = th.offsetWidth;
                        function onMove(e) {
                            th.style.width = Math.max(36, startW + e.pageX - startX) + 'px';
                        }
                        function onUp() {
                            handle.classList.remove('dragging');
                            document.removeEventListener('mousemove', onMove);
                            document.removeEventListener('mouseup', onUp);
                        }
                        document.addEventListener('mousemove', onMove);
                        document.addEventListener('mouseup', onUp);
                    });
                    th.addEventListener('dblclick', function(e) {
                        if (e.target === handle) return;
                        var idx = Array.from(th.parentElement.children).indexOf(th);
                        var maxW = th.scrollWidth;
                        tbl.querySelectorAll('tbody tr').forEach(function(row) {
                            var td = row.cells[idx];
                            if (td) maxW = Math.max(maxW, td.scrollWidth);
                        });
                        th.style.width = Math.min(maxW + 16, 420) + 'px';
                    });
                });
            })();
        ");
    }

