        cursor: pointer; white-space: nowrap; min-height: 44px;
    }
    .pcf-addpage-menu button:hover { background: rgba(255,255,255,.15); }
    .pcf-tool-active { background: #fff !important; color: #1e40af !important; font-weight: 700; }

    /* ── Voice mic button ── */
    .pcf-voice-btn { position: relative; }
    .pcf-voice-active { background: rgba(34,197,94,.25) !important; color: #4ade80 !important; border-color: rgba(34,197,94,.5) !important; }
    .pcf-voice-active::after {
        content: ''; position: absolute; inset: -3px; border-radius: 8px;
        border: 2px solid rgba(34,197,94,.5);
        animation: voicePulse 1.6s ease-in-out infinite;
        pointer-events: none;
    }
    @@keyframes voicePulse {
        0%,100% { opacity: .7; transform: scale(1); }
        50%      { opacity: 0; transform: scale(1.45); }
    }

    /* ── Voice command badge ── */
    .lpm-voice-badge {
        position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(12px);
        background: rgba(15,23,42,.92); color: #4ade80;
        border: 1px solid rgba(34,197,94,.4); border-radius: 20px;
        padding: 7px 18px; font-size: .82rem; font-weight: 600;
        display: flex; align-items: center; gap: 4px;
        z-index: 99999; pointer-events: none;
        opacity: 0; transition: opacity .2s ease, transform .2s ease;
    }
    .lpm-voice-badge-show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .lpm-voice-badge-hide { opacity: 0; transform: translateX(-50%) translateY(-8px); }
    .pcf-color-wrap { position: relative; }
    .pcf-color-popup {
        position: absolute; top: 110%; right: 0; z-index: 100;
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px;
        padding: 8px; background: #1e293b; border: 1px solid #475569;
        border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.4);
    }
    .pcf-color-swatch {
        width: 28px; height: 28px; border-radius: 5px; cursor: pointer;
        border: 2px solid transparent; transition: transform .1s, border-color .1s;
    }
    .pcf-color-swatch:hover { transform: scale(1.15); border-color: rgba(255,255,255,.6); }
    .pcf-swatch-active { border-color: #fff !important; box-shadow: 0 0 0 2px #3b82f6; }
    .pcf-size-popup {
        position: absolute; top: 110%; right: 0; z-index: 100;
        display: flex; flex-direction: column; gap: 2px;
        padding: 6px; background: #1e293b; border: 1px solid #475569;
        border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,.4); min-width: 80px;
    }
    .pcf-size-item {
        display: flex; align-items: center; justify-content: space-between; gap: 8px;
        padding: 4px 10px; border-radius: 4px; cursor: pointer;
        color: #cbd5e1; font-size: .8rem; transition: background .1s;
    }
    .pcf-size-item:hover { background: #334155; color: #f1f5f9; }
    .pcf-size-active { background: #3b82f6 !important; color: #fff !important; font-weight: 600; }
    .pcf-save-btn {
        background: linear-gradient(135deg, #059669, #10b981);
        border: none; color: #fff; border-radius: 6px;
        padding: 4px 14px; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: opacity .15s, transform .15s;
    }
    .pcf-save-btn:hover:not(:disabled) { transform: translateY(-1px); }
    .pcf-save-btn:disabled { opacity: .4; cursor: default; }
    .pcf-done-btn {
        background: linear-gradient(135deg, #dc2626, #ef4444);
        border: none; color: #fff; border-radius: 6px;
        padding: 4px 14px; font-size: .82rem; font-weight: 600;
        cursor: pointer; transition: opacity .15s, transform .15s;
        animation: pcf-done-pulse 2.4s ease-in-out infinite;
    }
    @@keyframes pcf-done-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,.0); }
        50%       { box-shadow: 0 0 0 5px rgba(239,68,68,.35); }
    }
    .pcf-cs-session-label {
        background: rgba(255,255,255,.12); border: 1px solid rgba(255,255,255,.3);
        border-radius: 6px; padding: 3px 12px;
        font-size: .8rem; font-weight: 700; color: #fbbf24;
        animation: pcf-glow 2s ease-in-out infinite;
    }
    .pcf-cs-session-label--missing {
        background: rgba(239,68,68,.12) !important;
        border-color: #ef4444 !important;
        color: #f87171 !important;
        animation: pcf-missing-pulse 1.4s ease-in-out infinite !important;
        cursor: default !important;
    }
    @@keyframes pcf-missing-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,.0); border-color: #ef4444; }
        50%       { box-shadow: 0 0 0 6px rgba(239,68,68,.3); border-color: #fca5a5; }
    }
    .pcf-timer {
        display: flex; align-items: center; gap: 4px;
        background: rgba(0,0,0,.25); border: 1px solid rgba(255,255,255,.15);
        border-radius: 6px; padding: 2px 7px;
        backdrop-filter: blur(4px);
    }
    .pcf-timer-icon { font-size: .7rem; color: #94a3b8; }
    .pcf-timer-display {
        display: flex; align-items: center; gap: 0;
    }
    .pcf-timer-num {
        width: 24px; background: rgba(255,255,255,.1); border: 1px solid rgba(255,255,255,.15);
        color: #f1f5f9; border-radius: 3px; padding: 0 1px;
        text-align: center; font-size: .72rem; font-weight: 800;
        font-family: 'Segoe UI', system-ui, monospace;
        letter-spacing: .5px; outline: none;
        -moz-appearance: textfield; transition: all .15s;
    }
    .pcf-timer-num::-webkit-outer-spin-button,
    .pcf-timer-num::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
    .pcf-timer-num:focus {
        background: rgba(255,255,255,.18);
        border-color: #60a5fa; box-shadow: 0 0 6px rgba(96,165,250,.35);
    }
    .pcf-timer-colon {
        font-size: .72rem; font-weight: 800; color: #64748b;
        margin: 0 1px;
    }
    .pcf-timer-zero {
        border-color: #ef4444 !important;
        animation: pcf-timer-pulse 1.5s ease-in-out infinite;
    }
    .pcf-timer-zero .pcf-timer-num {
        background: rgba(239,68,68,.2); border-color: rgba(239,68,68,.5);
        color: #fca5a5;
    }
    .pcf-timer-zero .pcf-timer-icon { color: #ef4444; }
    .pcf-timer-warn {
        color: #ef4444; font-size: .7rem;
        animation: pcf-warn-blink 1s ease-in-out infinite;
    }
    @@keyframes pcf-timer-pulse {
        0%, 100% { box-shadow: 0 0 4px rgba(239,68,68,.2), inset 0 0 4px rgba(239,68,68,.1); }
        50%      { box-shadow: 0 0 16px rgba(239,68,68,.5), inset 0 0 8px rgba(239,68,68,.15); }
    }
    @@keyframes pcf-warn-blink {
        0%, 100% { opacity: .4; transform: scale(.9); }
        50%      { opacity: 1; transform: scale(1.1); }
    }
    @@keyframes pcf-glow {
        0%, 100% { box-shadow: 0 0 4px rgba(251,191,36,.2); }
        50%      { box-shadow: 0 0 12px rgba(251,191,36,.5); }
    }
    .pcf-done-btn:hover:not(:disabled) { transform: translateY(-1px); }
    .pcf-done-btn:disabled { opacity: .5; cursor: default; }
    .pcf-done-success {
        background: linear-gradient(135deg, #059669, #10b981) !important;
        opacity: 1 !important;
    }
    .pcf-extract-bar {
        position: fixed; bottom: 0; left: 0; right: 0; z-index: 10000;
        background: linear-gradient(135deg, #1e40af, #3b82f6);
        color: #fff; padding: 12px 24px;
        display: flex; align-items: center; justify-content: space-between;
        box-shadow: 0 -4px 20px rgba(0,0,0,.3);
        font-size: .9rem;
    }
    .pcf-extract-cb {
        display: flex; align-items: center; justify-content: center;
        width: 28px; height: 28px; background: rgba(255,255,255,.9);
        border-radius: 6px; box-shadow: 0 2px 6px rgba(0,0,0,.3);
    }
    .pcf-extract-cb input[type="checkbox"] {
        width: 18px; height: 18px; cursor: pointer; accent-color: #3b82f6;
    }
    .pcf-extract-cb span { display: none; }
    .pcf-toast-success {
        position: fixed; top: 56px; left: 50%; transform: translateX(-50%);
        z-index: 10000; background: #059669; color: #fff;
        padding: 12px 28px; border-radius: 10px;
        font-size: .9rem; font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.3);
        display: flex; align-items: center;
        animation: pcf-toast-in .3s ease-out;
    }
    @@keyframes pcf-toast-in {
        from { opacity: 0; transform: translateX(-50%) translateY(-20px); }
        to   { opacity: 1; transform: translateX(-50%) translateY(0); }
    }
    .pcf-toast-error {
        position: fixed; top: 56px; left: 50%; transform: translateX(-50%);
        z-index: 10000; background: #dc2626; color: #fff;
        padding: 12px 28px; border-radius: 10px;
        font-size: .9rem; font-weight: 600;
        box-shadow: 0 8px 24px rgba(0,0,0,.3);
        display: flex; align-items: center;
        animation: pcf-toast-in .3s ease-out;
    }

    .pcf-lock-banner {
        background: linear-gradient(135deg, #92400e, #b45309);
        color: #fef3c7; padding: 8px 16px;
        font-size: .82rem; display: flex; align-items: center;
        flex-shrink: 0;
    }
    .pcf-already-done-banner {
        background: linear-gradient(135deg, #065f46, #047857);
        color: #d1fae5; padding: 8px 16px;
        font-size: .82rem; display: flex; align-items: center;
        flex-shrink: 0; gap: 0;
    }
    .pcf-banner-dismiss {
        margin-left: auto; background: none; border: none; color: inherit;
        opacity: .7; font-size: 1.2rem; line-height: 1; cursor: pointer;
        padding: 0 2px; flex-shrink: 0;
    }
    .pcf-banner-dismiss:hover { opacity: 1; }
    .pcf-done-already { opacity: .5; cursor: default; }

    /* ── Viewer area ── */
    .pcf-viewer-area {
        flex-grow: 1; display: flex; overflow: hidden; min-height: 0;
    }
    .pcf-viewer-area.pcf-split { gap: 3px; }
    .pcf-pane {
        flex: 1; display: flex; flex-direction: column;
        min-width: 0; min-height: 0; overflow: hidden;
        border: 2px solid transparent; transition: border-color .15s;
        position: relative;
    }
    .pcf-pane-active { border-color: #3b82f6; }
    /* Thin top-border color to distinguish panes in multi-pane mode */
    .pcf-split .pcf-pane-p1 { border-top-color: #3b82f6; }
    .pcf-split .pcf-pane-p2 { border-top-color: #8b5cf6; }
    .pcf-split .pcf-pane-p3 { border-top-color: #f59e0b; }
    /* ── Floating overlay ── */
    .pcf-pane-overlay {
        position: absolute; top: 6px; right: 6px; z-index: 20;
        display: flex; align-items: center; gap: 2px;
        background: rgba(15,23,42,.72); backdrop-filter: blur(4px);
        border-radius: 6px; padding: 2px 3px;
        opacity: 0; transition: opacity .18s;
        pointer-events: none;
    }
    .pcf-pane:hover .pcf-pane-overlay { opacity: 1; pointer-events: auto; }
    /* Always slightly visible on touch devices */
    @@media (hover: none) {
        .pcf-pane-overlay { opacity: .55; pointer-events: auto; }
        /* Enlarge touch targets inside the pane overlay */
        .pcf-overlay-btn { width: 36px; height: 36px; }
        /* Popup controls — bigger tap targets on touch screens */
        .pcf-annot-close { width: 36px; height: 36px; font-size: 1rem; }
        .pcf-color-swatch { width: 36px; height: 36px; }
        .pcf-annot-popup { min-width: 210px; }
        .pcf-annot-colors { gap: 6px; }
        .pcf-size-item { min-height: 40px; padding: 8px 12px; }
        .pcf-zoom-icon-btn { width: 40px; height: 40px; }
        .pcf-zoom-chip { min-height: 36px; font-size: .85rem; }
        /* Create-folder confirm/cancel buttons */
        .pcf-create-folder-ok, .pcf-create-folder-cancel { width: 36px; height: 36px; }
    }
    .pcf-overlay-name {
        font-size: .68rem; color: #e2e8f0; font-weight: 600;
        padding: 0 4px; max-width: 160px;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .pcf-overlay-counter {
        font-size: .62rem; color: #cbd5e1; padding: 0 4px; white-space: nowrap;
    }
    .pcf-overlay-btn {
        background: transparent; border: none; color: #cbd5e1;
        width: 26px; height: 26px; border-radius: 4px; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: .85rem; transition: background .12s, color .12s;
        flex-shrink: 0;
    }
    .pcf-overlay-btn:hover:not([disabled]) { background: rgba(255,255,255,.12); color: #fff; }
    .pcf-overlay-btn[disabled] { opacity: .2; cursor: default; }
    .pcf-overlay-btn.pcf-overlay-btn-active { color: #fb923c; }
    .pcf-overlay-close:hover:not([disabled]) { background: rgba(248,113,113,.18); color: #f87171; }
    .pcf-dual-counter { display: none; } /* legacy — kept for compat, now in overlay */
    .pcf-dual-nav {
        position: absolute; top: 50%; transform: translateY(-50%);
        background: rgba(0,0,0,.55); border: none; color: #e2e8f0;
        width: 32px; height: 72px; border-radius: 4px; z-index: 10;
        cursor: pointer; font-size: 1.3rem;
        display: flex; align-items: center; justify-content: center;
        opacity: .55; transition: opacity .15s, background .15s;
    }
    .pcf-dual-nav:hover:not([disabled]) { background: rgba(0,0,0,.8); opacity: 1; }
    .pcf-dual-nav[disabled] { opacity: .18; cursor: default; pointer-events: none; }
    .pcf-dual-prev { left: 4px; }
    .pcf-dual-next { right: 4px; }
    .pcf-viewer {
        flex-grow: 1; overflow-y: scroll; overflow-x: auto;
        display: flex; flex-direction: column; align-items: flex-start;
        padding: 20px; gap: 12px; background: #64748b;
        scrollbar-width: auto; scrollbar-color: #475569 #64748b;
    }
    .pcf-viewer.pcf-dual-mode { overflow: hidden !important; scrollbar-width: none !important; }
    .pcf-viewer.pcf-dual-mode::-webkit-scrollbar { display: none !important; }
    .pcf-viewer.pcf-pan-mode { cursor: grab; }
    .pcf-viewer.pcf-pan-mode.pcf-panning { cursor: grabbing; }
    .pcf-viewer.pcf-pan-mode .pcf-annotation-canvas { pointer-events: none; }
    .pcf-viewer::-webkit-scrollbar { width: 10px; }
    .pcf-viewer::-webkit-scrollbar-track { background: #64748b; }
    .pcf-viewer::-webkit-scrollbar-thumb {
        background: #475569; border-radius: 5px;
        border: 2px solid #64748b;
    }
    .pcf-viewer::-webkit-scrollbar-thumb:hover { background: #334155; }
    .pcf-empty {
        display: flex; flex-direction: column; align-items: center;
        justify-content: center; height: 100%; color: #94a3b8;
    }

    /* ── PDF page wrapper ── */
    .pcf-page-wrapper {
        position: relative; box-shadow: 0 4px 20px rgba(0,0,0,.3); background: #fff;
        margin-left: auto; margin-right: auto; flex-shrink: 0;
    }
    .pcf-page-wrapper canvas { display: block; }
    .pcf-annotation-canvas { position: absolute; top: 0; left: 0; cursor: crosshair; }

    /* ── PDF text selection layer ── */
    .pcf-text-layer {
        position: absolute; top: 0; left: 0;
        overflow: hidden; line-height: 1;
        pointer-events: none; /* enabled via JS when in text-select mode */
        cursor: text;
        user-select: text !important;
        -webkit-user-select: text !important;
        -webkit-text-size-adjust: none;
        text-size-adjust: none;
        forced-color-adjust: none;
    }
    .pcf-text-layer span, .pcf-text-layer br {
        color: transparent;
        position: absolute;
        white-space: pre;
        cursor: text;
        transform-origin: 0% 0%;
    }
    .pcf-text-layer ::selection { background: rgba(0, 102, 255, 0.28); color: transparent; }

    /* ── Annotation text select layer (transparent selectable spans over canvas text) ── */
    .pcf-text-select-layer {
        position: absolute; top: 0; left: 0;
        pointer-events: none; user-select: none;
        z-index: 6; /* above annotation canvas */
    }
    .pcf-text-select-span {
        position: absolute; color: transparent;
        pointer-events: none; /* enabled via JS in text-select mode */
        user-select: text; -webkit-user-select: text;
        cursor: text; white-space: pre-wrap; word-break: break-word;
        font-family: Arial; line-height: 1.3;
    }
    .pcf-text-select-span::selection, .pcf-text-select-span *::selection {
        background: rgba(0, 102, 255, 0.28); color: transparent;
    }

    .pcf-text-input {
        position: absolute; border: 2px solid #3b82f6;
        background: rgba(255,255,255,.9); color: #1e293b;
        font-size: 14px; padding: 2px 4px; min-width: 120px;
        outline: none; border-radius: 3px; z-index: 10;
    }
    .pcf-text-resize-handle {
        position: absolute; z-index: 11;
        width: 18px; height: 18px; cursor: se-resize;
        background: #3b82f6; border-radius: 3px;
        opacity: .75; transition: opacity .15s;
    }
    .pcf-text-resize-handle:hover { opacity: 1; }

    /* ── Tablet ── */
    @@media (max-width: 768px) {
        .pcf-sidebar {
            position: absolute; z-index: 200; height: 100%;
            width: 260px; min-width: 220px;
            box-shadow: 4px 0 16px rgba(0,0,0,.3);
        }
        .pcf-sidebar-backdrop {
            display: block; position: absolute; z-index: 199;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,0,0,.4);
        }
        .pcf-toolbar {
            padding: 6px 10px; gap: 4px 8px;
            flex-wrap: wrap; min-height: auto;
        }
        .pcf-toolbar > .pcf-tools-right { flex-wrap: wrap; gap: 4px; }
        .pcf-toolbar .vr { display: none; }
        .pcf-toolbar-file { font-size: .78rem; max-width: 160px; overflow: hidden; text-overflow: ellipsis; }
        .pcf-tool-btn { padding: 4px 8px; font-size: .78rem; min-height: 44px; }
        .pcf-save-btn, .pcf-done-btn { padding: 4px 10px; font-size: .78rem; min-height: 44px; }
        .pcf-zoom-single { height: 44px; }
        .pcf-viewer { padding: 10px; gap: 8px; }
        .pcf-timer-num { width: 32px; font-size: 16px; } /* 16px prevents iOS auto-zoom on tablets */
        .pcf-cs-session-label { font-size: .75rem; padding: 2px 8px; min-height: 44px; display: inline-flex; align-items: center; }
        .pcf-color-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-size-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-annot-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-zoom-menu { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-viewer-area.pcf-split { flex-direction: column; }
        .pcf-toast-success { padding: 10px 16px; font-size: .82rem; max-width: 90vw; }
        .pcf-lock-banner { flex-wrap: wrap; font-size: .78rem; }
        .pcf-already-done-banner { flex-wrap: wrap; font-size: .78rem; }
        .pcf-text-input { min-width: 80px; font-size: 16px; } /* 16px prevents iOS auto-zoom on tablets */
        .pcf-page-wrapper { max-width: calc(100vw - 40px); overflow: hidden; }
    }

    /* ── Phone ── */
    @@media (max-width: 480px) {
        .pcf-sidebar { width: 85vw; min-width: 0; max-width: 300px; }
        .pcf-sidebar-header { padding: 10px; font-size: .88rem; }
        .pcf-section-title { padding: 10px 10px; font-size: .82rem; min-height: 44px; }
        .pcf-file-item { padding: 10px 10px 10px 20px; font-size: .75rem; min-height: 44px; }
        .pcf-toolbar { padding: 5px 8px; gap: 3px 6px; }
        .pcf-toolbar-file { font-size: .72rem; max-width: 100px; }
        .pcf-toolbar-section { font-size: .65rem; padding: 1px 5px; }
        .pcf-tool-btn { padding: 4px 8px; font-size: .78rem; min-height: 44px; min-width: 44px;
                        display: inline-flex; align-items: center; justify-content: center; }
        .pcf-save-btn { padding: 4px 10px; font-size: .72rem; min-height: 44px; }
        .pcf-done-btn { padding: 4px 10px; font-size: .72rem; white-space: nowrap; min-height: 44px; }
        .pcf-zoom-single { height: 44px; min-width: 54px; }
        .pcf-cs-session-label { font-size: .65rem; padding: 2px 6px; min-height: 44px; display: inline-flex; align-items: center; }
        .pcf-timer { padding: 1px 4px; }
        .pcf-timer-num { width: 32px; font-size: 16px; } /* 16px prevents iOS auto-zoom on focus */
        .pcf-viewer { padding: 4px; gap: 4px; -webkit-overflow-scrolling: touch; }
        .pcf-pane-header { padding: 3px 8px; font-size: .7rem; }
        .pcf-lock-banner { font-size: .72rem; padding: 6px 8px; }
        .pcf-already-done-banner { font-size: .72rem; padding: 6px 8px; }
        .pcf-toast-success { padding: 8px 12px; font-size: .78rem; max-width: 95vw; border-radius: 8px; }
        .pcf-empty i { font-size: 2rem !important; }
        .pcf-empty div { font-size: .8rem !important; }
        .pcf-text-input { min-width: 60px; font-size: 16px; } /* 16px prevents iOS auto-zoom */
        .pcf-rename-input { font-size: 16px; } /* 16px prevents iOS auto-zoom */
        .pcf-color-swatch { width: 28px; height: 28px; }
        .pcf-ws-pager button { padding: 6px 12px; min-height: 44px; }
        .pcf-annotation-canvas { cursor: default; }
        .pcf-annot-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-zoom-menu { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-color-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-size-popup { right: 0; left: auto; max-width: calc(100vw - 10px); }
        .pcf-pagebg-picker { max-width: calc(100vw - 20px); }
