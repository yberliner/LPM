    [JSInvokable]
    public async Task OnVoiceCommand(string cmd)
    {
        Console.WriteLine($"[PcFolder] Voice command: '{cmd}' by '{_userName}' — PC {PcId}");
        switch (cmd)
        {
            case "dual":
                await VoiceDual();
                break;
            case "split":
                await CyclePanes();
                break;
            case "text":
                if (_toolMode != "text") await SetTool("text");
                await JS.InvokeVoidAsync("lpmVoice.triggerClickAtCursor");
                break;
            case "next":
            case "prev":
                // Executed directly in JS by lpmVoice for instant response — no round-trip needed
                break;
            case "zoomin":
                _fitMode = false;
                _zoomPercent = await JS.InvokeAsync<int>("pcfViewer.zoomIn", PaneIds[_activeIdx]);
                break;
            case "zoomout":
                _fitMode = false;
                _zoomPercent = await JS.InvokeAsync<int>("pcfViewer.zoomOut", PaneIds[_activeIdx]);
                break;
            case "summary":
                await OpenFsModal();
                break;
            case "undo":
                await Undo();
                break;
            case "download":
                await DownloadFile();
                break;
        }
        await InvokeAsync(StateHasChanged);
    }

