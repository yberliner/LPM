@using Microsoft.AspNetCore.Components.Web
@namespace LPM.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PC Folder</title>
    <link rel="icon" href="/assets/images/brand-logos/lp-favicon.svg" type="image/svg+xml">
    <link href="/assets/css/styles.css" rel="stylesheet">
    <link href="/assets/css/icons.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; overflow: hidden; }
        /* Quill size picker: show actual pixel values instead of "Normal" */
        .ql-snow .ql-picker.ql-size .ql-picker-label::before,
        .ql-snow .ql-picker.ql-size .ql-picker-item::before { content: attr(data-value) !important; }
        .ql-snow .ql-picker.ql-size .ql-picker-label[data-value=""]::before,
        .ql-snow .ql-picker.ql-size .ql-picker-item[data-value=""]::before { content: 'Normal' !important; }
    </style>
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:99999;
        padding:12px 20px;background:#ffdd57;color:#333;text-align:center;font-size:14px;">
        An error has occurred. <a href="" onclick="location.reload()">Reload</a>
    </div>

    <script src="/assets/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/_framework/blazor.server.js"></script>

    <!-- PDF.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        if (window['pdfjs-dist/build/pdf']) {
            window['pdfjs-dist/build/pdf'].GlobalWorkerOptions.workerSrc =
                'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        }
    </script>

    <!-- Ctrl+key shortcuts (shared with main layout) -->
    <script>
        window._lpmShortcuts = {};
        window._lpmReservedKeys = ['c','v','z','x','a','s','p','f','r','t','w','n','l'];
        window.lpmLoadShortcuts = function(shortcuts) {
            window._lpmShortcuts = shortcuts || {};
        };
        document.addEventListener('keydown', function(e) {
            if (!(e.ctrlKey || e.metaKey) || e.altKey || e.shiftKey) return;
            var key = e.key.toLowerCase();
            if (window._lpmReservedKeys.indexOf(key) >= 0) return;
            var text = window._lpmShortcuts[key];
            if (!text) return;
            var el = document.activeElement;
            if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable)) {
                e.preventDefault();
                if (el.isContentEditable) {
                    document.execCommand('insertText', false, text);
                } else {
                    var start = el.selectionStart;
                    var end = el.selectionEnd;
                    var val = el.value;
                    el.value = val.substring(0, start) + text + val.substring(end);
                    el.selectionStart = el.selectionEnd = start + text.length;
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
        });
    </script>

    <!-- Quill rich-text editor -->
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script src="/js/quill-interop.js"></script>

    <!-- PC Folder viewer -->
    <script src="/js/pcf-viewer.js?v=11"></script>
    <script>
        window.pcfSaveAnnotatedPdf = async function(pcId, filePath, pagesJson) {
            const pages = JSON.parse(pagesJson);
            const formData = new FormData();
            for (let i = 0; i < pages.length; i++) {
                const resp = await fetch(pages[i].dataUrl);
                const blob = await resp.blob();
                formData.append('page_' + i, blob, 'page_' + i + '.png');
            }
            formData.append('pageCount', pages.length.toString());
            formData.append('widths', JSON.stringify(pages.map(p => p.width)));
            formData.append('heights', JSON.stringify(pages.map(p => p.height)));

            const saveResp = await fetch('/api/pc-file-save-annotated?pcId=' + pcId + '&path=' + encodeURIComponent(filePath), {
                method: 'POST',
                body: formData
            });
            if (!saveResp.ok) throw new Error('Save failed: ' + saveResp.status);
        };

        window.showCsDoneAndClose = function(pcName, sessionName) {
            const overlay = document.createElement('div');
            overlay.id = 'cs-done-overlay';
            overlay.innerHTML = `
                <style>
                    #cs-done-overlay {
                        position: fixed; inset: 0; z-index: 99999;
                        background: rgba(10, 17, 32, 0.93);
                        backdrop-filter: blur(10px);
                        display: flex; align-items: center; justify-content: center;
                        animation: csDoneFadeIn 0.22s ease both;
                    }
                    @@keyframes csDoneFadeIn  { from { opacity:0; } to { opacity:1; } }
                    @@keyframes csDoneFadeOut { from { opacity:1; } to { opacity:0; } }
                    @@keyframes csDoneCardIn  { from { opacity:0; transform:scale(0.7); } to { opacity:1; transform:scale(1); } }
                    @@keyframes csDoneCircle  { from { stroke-dashoffset:339; } to { stroke-dashoffset:0; } }
                    @@keyframes csDoneCheck   { from { stroke-dashoffset:100; } to { stroke-dashoffset:0; } }
                    @@keyframes csDoneTextIn  { from { opacity:0; transform:translateY(18px); } to { opacity:1; transform:translateY(0); } }
                    @@keyframes csDoneBar     { from { width:0%; } to { width:100%; } }
                    @@keyframes csDonePulse   { 0%,100%{opacity:.9;} 50%{opacity:.35;} }
                    @@keyframes csDoneGlow    { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0);} 60%{box-shadow:0 0 40px 12px rgba(34,197,94,0.18);} }
                    #cs-done-card {
                        text-align: center;
                        animation: csDoneCardIn 0.28s cubic-bezier(0.175,0.885,0.32,1.275) 0.05s both,
                                   csDoneGlow 1.25s ease 0.4s infinite;
                        padding: 52px 64px 44px;
                        border-radius: 24px;
                        background: rgba(255,255,255,0.04);
                        border: 1px solid rgba(34,197,94,0.2);
                    }
                    #cs-done-svg circle.track  { fill:none; stroke:rgba(34,197,94,0.12); stroke-width:7; }
                    #cs-done-svg circle.ring   {
                        fill:none; stroke:#22c55e; stroke-width:7; stroke-linecap:round;
                        stroke-dasharray:339; stroke-dashoffset:339;
                        transform:rotate(-90deg); transform-origin:60px 60px;
                        animation: csDoneCircle 0.45s cubic-bezier(0.4,0,0.2,1) 0.13s forwards;
                    }
                    #cs-done-svg polyline {
                        fill:none; stroke:#22c55e; stroke-width:7;
                        stroke-linecap:round; stroke-linejoin:round;
                        stroke-dasharray:100; stroke-dashoffset:100;
                        animation: csDoneCheck 0.22s ease 0.48s forwards;
                    }
                    #cs-done-title {
                        color:#22c55e; font-size:2rem; font-weight:700;
                        letter-spacing:-0.5px; margin-top:20px;
                        animation: csDoneTextIn 0.25s ease 0.35s both;
                    }
                    #cs-done-sub {
                        color:#94a3b8; font-size:0.95rem; margin-top:6px;
                        animation: csDoneTextIn 0.25s ease 0.43s both;
                    }
                    #cs-done-progress {
                        margin-top:36px; width:200px; margin-left:auto; margin-right:auto;
                        animation: csDoneTextIn 0.25s ease 0.5s both;
                    }
                    #cs-done-track {
                        height:3px; background:rgba(255,255,255,0.08);
                        border-radius:999px; overflow:hidden;
                    }
                    #cs-done-fill {
                        height:100%; background:linear-gradient(90deg,#16a34a,#22c55e);
                        border-radius:999px;
                        animation: csDoneBar 1.2s linear 0.5s both;
                    }
                    #cs-done-closing {
                        color:#475569; font-size:0.72rem; margin-top:10px; letter-spacing:.5px;
                        text-transform:uppercase;
                        animation: csDonePulse 0.6s ease 0.6s infinite;
                    }
                </style>
                <div id="cs-done-card">
                    <svg id="cs-done-svg" width="110" height="110" viewBox="0 0 120 120">
                        <circle class="track" cx="60" cy="60" r="54"/>
                        <circle class="ring"  cx="60" cy="60" r="54"/>
                        <polyline points="36,63 52,80 84,42"/>
                    </svg>
                    <div id="cs-done-title">CS Review Complete!</div>
                    <div id="cs-done-sub">${pcName || ''}${sessionName ? ' &nbsp;·&nbsp; ' + sessionName : ''}</div>
                    <div id="cs-done-progress">
                        <div id="cs-done-track"><div id="cs-done-fill"></div></div>
                        <div id="cs-done-closing">Closing tab&hellip;</div>
                    </div>
                </div>`;
            document.body.appendChild(overlay);
            setTimeout(() => {
                overlay.style.animation = 'csDoneFadeOut 0.25s ease forwards';
                setTimeout(() => window.close(), 240);
            }, 1600);
        };
    </script>
</body>
</html>
