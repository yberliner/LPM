@using Microsoft.AspNetCore.Components.Web
@namespace LPM.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <base href="/" />
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>PC Folder</title>
    <link rel="icon" href="/assets/images/brand-logos/lp-favicon.svg" type="image/svg+xml">
    <link href="/assets/css/styles.css" rel="stylesheet">
    <link href="/assets/css/icons.css" rel="stylesheet">
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; overflow: hidden; }
        /* Quill size picker: show actual pixel values instead of "Normal" */
        .ql-snow .ql-picker.ql-size .ql-picker-label::before,
        .ql-snow .ql-picker.ql-size .ql-picker-item::before { content: attr(data-value) !important; }
        .ql-snow .ql-picker.ql-size .ql-picker-label[data-value=""]::before,
        .ql-snow .ql-picker.ql-size .ql-picker-item[data-value=""]::before { content: 'Normal' !important; }
    </style>
    <script>
        // Block the browser from closing the tab on Ctrl+W (PWA + regular window).
        // Must be in <head>, capture phase, so it runs before the browser's default.
        // DO NOT add stopPropagation() or stopImmediatePropagation() here — the Blazor
        // handler in PcFolder.razor needs to see this event to fire OnCtrlW
        // (Save & Close / CS Done). Only preventDefault() is needed to stop the browser
        // from closing the tab; propagation must continue downstream.
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && !e.altKey && !e.shiftKey && e.code === 'KeyW') {
                e.preventDefault();
            }
        }, true);
    </script>
</head>
<body>
    @RenderBody()

    <div id="blazor-error-ui" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:99999;
        padding:12px 20px;background:#ffdd57;color:#333;text-align:center;font-size:14px;">
        An error has occurred. <a href="" onclick="location.reload()">Reload</a>
    </div>

    <script src="/assets/libs/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Same helper used by the main layout; needed here so the Session Data modal
        // (and any other PcFolder feature) can trigger a file download.
        window.downloadFile = (fileName, base64Data) => {
            try {
                const bytes = Uint8Array.from(atob(base64Data), c => c.charCodeAt(0));
                const blob = new Blob([bytes], { type: "application/pdf" });
                const url = URL.createObjectURL(blob);
                const a = document.createElement("a");
                a.href = url;
                a.download = fileName;
                a.click();
                setTimeout(() => {
                    try { URL.revokeObjectURL(url); } catch { }
                    try { a.remove(); } catch { }
                }, 0);
            } catch (e) {
                console.error("downloadFile failed:", e);
            }
        };
    </script>

    <!-- PDF.js and PC Folder viewer must load before Blazor connects to avoid race condition -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        if (window['pdfjs-dist/build/pdf']) {
            window['pdfjs-dist/build/pdf'].GlobalWorkerOptions.workerSrc =
                'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        }
    </script>

    <!-- Ctrl+key shortcuts (shared with main layout) -->
    <script>
        window._lpmShortcuts = {};
        window._lpmReservedKeys = ['c','v','z','x','a','s','p','f','r','t','w','n','l'];
        window.lpmLoadShortcuts = function(shortcuts) {
            window._lpmShortcuts = shortcuts || {};
        };
        document.addEventListener('keydown', function(e) {
            if (!(e.ctrlKey || e.metaKey) || e.altKey || e.shiftKey) return;
            var key = e.key.toLowerCase();
            // Ctrl+D is handled in PcFolder.razor component handler
            if (window._lpmReservedKeys.indexOf(key) >= 0) return;
            var text = window._lpmShortcuts[key];
            if (!text) return;
            var el = document.activeElement;
            if (el && (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA' || el.isContentEditable)) {
                e.preventDefault();
                if (el.isContentEditable) {
                    document.execCommand('insertText', false, text);
                } else {
                    var start = el.selectionStart;
                    var end = el.selectionEnd;
                    var val = el.value;
                    el.value = val.substring(0, start) + text + val.substring(end);
                    el.selectionStart = el.selectionEnd = start + text.length;
                    el.dispatchEvent(new Event('input', { bubbles: true }));
                    el.dispatchEvent(new Event('change', { bubbles: true }));
                }
            }
        });
    </script>

    <!-- Quill rich-text editor -->
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <script src="/js/quill-interop.js"></script>

    <!-- Shared JS utilities (lpmTriggerDownload, etc.) -->
    <script src="/js/javaScriptInterop.js?v=4"></script>

    <!-- PC Folder viewer -->
    <script src="/js/pcf-viewer.js?v=73"></script>

    <script src="/_framework/blazor.server.js"></script>
    <script>
        // CSP-safe base64 dataURL → Blob (no fetch on data: URLs — connect-src blocks them).
        window.pcfDataUrlToBlob = function(dataUrl) {
            const comma = dataUrl.indexOf(',');
            const meta  = dataUrl.substring(0, comma);
            const b64   = dataUrl.substring(comma + 1);
            const m     = meta.match(/^data:([^;]+)(;base64)?$/);
            const mime  = (m && m[1]) ? m[1] : 'application/octet-stream';
            const bin   = atob(b64);
            const bytes = new Uint8Array(bin.length);
            for (let i = 0; i < bin.length; i++) bytes[i] = bin.charCodeAt(i);
            return new Blob([bytes], { type: mime });
        };

        // Network-resilient fetch: retries on TypeError (failed-to-fetch) up to 5 attempts
        // with exponential backoff. Does NOT retry on HTTP responses (non-OK status returned
        // as-is so callers can react to specific codes like 422).
        window.pcfFetchWithRetry = async function(url, options) {
            const delays = [1000, 2000, 4000, 8000, 16000];
            let lastError = null;
            for (let attempt = 0; attempt < 5; attempt++) {
                try {
                    return await fetch(url, options);
                } catch (err) {
                    lastError = err;
                    console.warn('[pcfSave] Network attempt ' + (attempt + 1) + '/5 failed: ' + (err && err.message));
                    if (attempt < 4) await new Promise(r => setTimeout(r, delays[attempt]));
                }
            }
            const e = new Error('NETWORK_FAIL: ' + (lastError && lastError.message ? lastError.message : 'Could not reach server after 5 attempts'));
            e.code = 'NETWORK_FAIL';
            throw e;
        };

        // Recovery scanner: list/retry/discard pending-save snapshots that survived
        // a browser close or fatal error. dataJson in each snapshot already contains
        // the page images (base64 dataURLs) so we can re-POST without the original DOM.
        window.pcfRecoverySaves = {
            list: function(pcId) {
                const out = [];
                const prefix = 'lpm-pending-save|' + pcId + '|';
                for (let i = 0; i < localStorage.length; i++) {
                    const k = localStorage.key(i);
                    if (!k || !k.startsWith(prefix)) continue;
                    try {
                        const o = JSON.parse(localStorage.getItem(k));
                        out.push({ key: k, pcId: o.pcId, filePath: o.filePath, ts: o.ts || 0 });
                    } catch(e) {}
                }
                out.sort((a, b) => b.ts - a.ts);
                return out;
            },
            retry: async function(key) {
                const raw = localStorage.getItem(key);
                if (!raw) return { ok: false, error: 'snapshot_missing' };
                let snap;
                try { snap = JSON.parse(raw); } catch(e) { return { ok: false, error: 'snapshot_corrupt' }; }
                try {
                    await window.pcfSaveAnnotatedPdf(snap.pcId, snap.filePath, snap.dataJson, !!snap.solo, null);
                    return { ok: true };
                } catch(e) {
                    return { ok: false, error: (e && e.message) || 'unknown' };
                }
            },
            discard: function(key) {
                try { localStorage.removeItem(key); } catch(e) {}
            }
        };

        window.pcfSaveAnnotatedPdf = async function(pcId, filePath, dataJson, solo, paneId) {
            const meta = JSON.parse(dataJson);
            const formData = new FormData();
            const metaForSend = { totalPages: meta.totalPages, pages: [] };
            let imgIdx = 0;

            for (const p of meta.pages) {
                if (p.action === 'original') {
                    metaForSend.pages.push({ action: 'original', srcPageIdx: p.srcPageIdx });
                } else if (p.action === 'bg_color') {
                    metaForSend.pages.push({ action: 'bg_color', srcPageIdx: p.srcPageIdx, color: p.color });
                } else if (p.action === 'bg_color_overlay') {
                    const blob = window.pcfDataUrlToBlob(p.dataUrl);
                    formData.append('img_' + imgIdx, blob, 'img_' + imgIdx + '.png');
                    metaForSend.pages.push({ action: 'bg_color_overlay', srcPageIdx: p.srcPageIdx, color: p.color, w: p.w, h: p.h, imgIdx });
                    imgIdx++;
                } else {
                    const blob = window.pcfDataUrlToBlob(p.dataUrl);
                    formData.append('img_' + imgIdx, blob, 'img_' + imgIdx + '.png');
                    const entry = { action: p.action, srcPageIdx: p.srcPageIdx ?? -1, w: p.w, h: p.h, imgIdx };
                    if (p.pdfPtW > 0 && p.pdfPtH > 0) { entry.pdfPtW = p.pdfPtW; entry.pdfPtH = p.pdfPtH; }
                    metaForSend.pages.push(entry);
                    imgIdx++;
                }
            }
            formData.append('meta', JSON.stringify(metaForSend));

            const soloParam = solo ? '&solo=true' : '';
            const saveUrl = '/api/pc-file-save-annotated?pcId=' + pcId + '&path=' + encodeURIComponent(filePath) + soloParam;

            // Recovery snapshot: keep the data in localStorage until we successfully save.
            // If the browser closes / app dies, the user can recover next session.
            const recoveryKey = 'lpm-pending-save|' + pcId + '|' + filePath;
            try {
                localStorage.setItem(recoveryKey, JSON.stringify({
                    ts: Date.now(), pcId, filePath, solo: !!solo, dataJson
                }));
            } catch (e) { /* storage full or disabled */ }

            let saveResp;
            try {
                saveResp = await window.pcfFetchWithRetry(saveUrl, { method: 'POST', body: formData });
            } catch (err) {
                // All 5 retries exhausted — leave the snapshot in localStorage and rethrow
                // so the Blazor side can show a retry dialog.
                console.error('[pcfSave] All retries failed for ' + filePath + ': ' + (err && err.message));
                throw err;
            }

            if (saveResp.status === 422 && paneId) {
                // Corrupt XRef — retry by rasterising ALL pages from the live canvases
                console.warn('[pcfSave] 422 corrupt XRef, retrying as full raster for pane:', paneId);
                const pane = window.pcfViewer && window.pcfViewer.panes && window.pcfViewer.panes[paneId];
                if (pane && pane.pages && pane.pages.length > 0) {
                    const rfd = new FormData();
                    const rmeta = { totalPages: pane.pages.length, pages: [] };
                    let ri = 0;
                    for (const pg of pane.pages) {
                        const off = document.createElement('canvas');
                        off.width  = pg.canvas.width;
                        off.height = pg.canvas.height;
                        const ctx = off.getContext('2d');
                        ctx.drawImage(pg.canvas, 0, 0);
                        ctx.drawImage(pg.overlay, 0, 0);
                        const blob = await new Promise(res => off.toBlob(res, 'image/png'));
                        rfd.append('img_' + ri, blob, 'img_' + ri + '.png');
                        const rentry = { action: 'full_new', srcPageIdx: -1, w: pg.canvas.width, h: pg.canvas.height, imgIdx: ri };
                        if (pg.pdfPtW > 0 && pg.pdfPtH > 0) { rentry.pdfPtW = pg.pdfPtW; rentry.pdfPtH = pg.pdfPtH; }
                        rmeta.pages.push(rentry);
                        ri++;
                    }
                    rfd.append('meta', JSON.stringify(rmeta));
                    let retryResp;
                    try {
                        retryResp = await window.pcfFetchWithRetry(saveUrl, { method: 'POST', body: rfd });
                    } catch (err) {
                        console.error('[pcfSave] 422-retry network failure: ' + (err && err.message));
                        throw err;
                    }
                    if (retryResp.ok) {
                        try { localStorage.removeItem(recoveryKey); } catch (e) {}
                        console.log('[pcfSave] Raster retry succeeded');
                        return;
                    }
                    throw new Error('Save failed (422 fallback returned ' + retryResp.status + ')');
                }
                // 422 but pane is unavailable (e.g. recovery flow with no live DOM): surface the error
                // so the caller can show the retry dialog. Snapshot stays in localStorage.
                throw new Error('Save failed: 422 (corrupt PDF, no live pane to re-rasterize)');
            }
            if (!saveResp.ok) throw new Error('Save failed: ' + saveResp.status);
            try { localStorage.removeItem(recoveryKey); } catch (e) {}
        };

        window.lpmNavigateTo = function(url) { window.location.href = url; };

        window.showCsDoneAndClose = function(pcName, sessionName, smsInfo) {
            const overlay = document.createElement('div');
            overlay.id = 'cs-done-overlay';
            const smsHtml = smsInfo
                ? `<div id="cs-done-sms">
                       <span class="cs-done-sms-icon">&#9993;</span>
                       <span class="cs-done-sms-label">SMS sent to <strong>${smsInfo.auditorName}</strong></span>
                       <span class="cs-done-sms-detail">${smsInfo.phone} &nbsp;·&nbsp; &ldquo;${smsInfo.message}&rdquo;</span>
                   </div>`
                : '';
            overlay.innerHTML = `
                <style>
                    #cs-done-overlay {
                        position: fixed; inset: 0; z-index: 99999;
                        background: rgba(10, 17, 32, 0.93);
                        backdrop-filter: blur(10px);
                        display: flex; align-items: center; justify-content: center;
                        animation: csDoneFadeIn 0.22s ease both;
                    }
                    @@keyframes csDoneFadeIn  { from { opacity:0; } to { opacity:1; } }
                    @@keyframes csDoneFadeOut { from { opacity:1; } to { opacity:0; } }
                    @@keyframes csDoneCardIn  { from { opacity:0; transform:scale(0.7); } to { opacity:1; transform:scale(1); } }
                    @@keyframes csDoneCircle  { from { stroke-dashoffset:339; } to { stroke-dashoffset:0; } }
                    @@keyframes csDoneCheck   { from { stroke-dashoffset:100; } to { stroke-dashoffset:0; } }
                    @@keyframes csDoneTextIn  { from { opacity:0; transform:translateY(18px); } to { opacity:1; transform:translateY(0); } }
                    @@keyframes csDoneBar     { from { width:0%; } to { width:100%; } }
                    @@keyframes csDonePulse   { 0%,100%{opacity:.9;} 50%{opacity:.35;} }
                    @@keyframes csDoneGlow    { 0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,0);} 60%{box-shadow:0 0 40px 12px rgba(34,197,94,0.18);} }
                    #cs-done-card {
                        text-align: center;
                        animation: csDoneCardIn 0.28s cubic-bezier(0.175,0.885,0.32,1.275) 0.05s both,
                                   csDoneGlow 1.25s ease 0.4s infinite;
                        padding: 52px 64px 44px;
                        border-radius: 24px;
                        background: rgba(255,255,255,0.04);
                        border: 1px solid rgba(34,197,94,0.2);
                    }
                    #cs-done-svg circle.track  { fill:none; stroke:rgba(34,197,94,0.12); stroke-width:7; }
                    #cs-done-svg circle.ring   {
                        fill:none; stroke:#22c55e; stroke-width:7; stroke-linecap:round;
                        stroke-dasharray:339; stroke-dashoffset:339;
                        transform:rotate(-90deg); transform-origin:60px 60px;
                        animation: csDoneCircle 0.45s cubic-bezier(0.4,0,0.2,1) 0.13s forwards;
                    }
                    #cs-done-svg polyline {
                        fill:none; stroke:#22c55e; stroke-width:7;
                        stroke-linecap:round; stroke-linejoin:round;
                        stroke-dasharray:100; stroke-dashoffset:100;
                        animation: csDoneCheck 0.22s ease 0.48s forwards;
                    }
                    #cs-done-title {
                        color:#22c55e; font-size:2rem; font-weight:700;
                        letter-spacing:-0.5px; margin-top:20px;
                        animation: csDoneTextIn 0.25s ease 0.35s both;
                    }
                    #cs-done-sub {
                        color:#94a3b8; font-size:0.95rem; margin-top:6px;
                        animation: csDoneTextIn 0.25s ease 0.43s both;
                    }
                    #cs-done-sms {
                        display:flex; flex-direction:column; align-items:center; gap:3px;
                        margin-top:18px; padding:10px 18px;
                        border-radius:10px;
                        background:rgba(34,197,94,0.08);
                        border:1px solid rgba(34,197,94,0.18);
                        animation: csDoneTextIn 0.25s ease 0.48s both;
                    }
                    .cs-done-sms-icon { font-size:1.2rem; line-height:1; }
                    .cs-done-sms-label { color:#86efac; font-size:0.88rem; }
                    .cs-done-sms-detail { color:#64748b; font-size:0.76rem; }
                    #cs-done-progress {
                        margin-top:28px; width:200px; margin-left:auto; margin-right:auto;
                        animation: csDoneTextIn 0.25s ease 0.5s both;
                    }
                    #cs-done-track {
                        height:3px; background:rgba(255,255,255,0.08);
                        border-radius:999px; overflow:hidden;
                    }
                    #cs-done-fill {
                        height:100%; background:linear-gradient(90deg,#16a34a,#22c55e);
                        border-radius:999px;
                        animation: csDoneBar 1.2s linear 0.5s both;
                    }
                    #cs-done-closing {
                        color:#475569; font-size:0.72rem; margin-top:10px; letter-spacing:.5px;
                        text-transform:uppercase;
                        animation: csDonePulse 0.6s ease 0.6s infinite;
                    }
                </style>
                <div id="cs-done-card">
                    <svg id="cs-done-svg" width="110" height="110" viewBox="0 0 120 120">
                        <circle class="track" cx="60" cy="60" r="54"/>
                        <circle class="ring"  cx="60" cy="60" r="54"/>
                        <polyline points="36,63 52,80 84,42"/>
                    </svg>
                    <div id="cs-done-title">CS Review Complete!</div>
                    <div id="cs-done-sub">${pcName || ''}${sessionName ? ' &nbsp;·&nbsp; ' + sessionName : ''}</div>
                    ${smsHtml}
                    <div id="cs-done-progress">
                        <div id="cs-done-track"><div id="cs-done-fill"></div></div>
                        <div id="cs-done-closing">Returning to Home&hellip;</div>
                    </div>
                </div>`;
            document.body.appendChild(overlay);
            setTimeout(() => {
                overlay.style.animation = 'csDoneFadeOut 0.25s ease forwards';
                setTimeout(() => window.location.href = '/Home', 240);
            }, 1600);
        };

        window.showCsTimeUpdated = function(pcName, sessionName, oldSec, newSec) {
            function fmtSec(s) {
                var h = Math.floor(s/3600), m = Math.floor((s%3600)/60), ss = s%60;
                return h + ':' + String(m).padStart(2,'0') + ':' + String(ss).padStart(2,'0');
            }
            const overlay = document.createElement('div');
            overlay.id = 'cs-done-overlay';
            overlay.innerHTML = `
                <style>
                    #cs-done-overlay {
                        position: fixed; inset: 0; z-index: 99999;
                        background: rgba(10, 17, 32, 0.93);
                        backdrop-filter: blur(10px);
                        display: flex; align-items: center; justify-content: center;
                        animation: csDoneFadeIn 0.22s ease both;
                    }
                    #cs-time-card {
                        text-align: center;
                        animation: csDoneCardIn 0.28s cubic-bezier(0.175,0.885,0.32,1.275) 0.05s both;
                        padding: 52px 64px 44px;
                        border-radius: 24px;
                        background: rgba(255,255,255,0.04);
                        border: 1px solid rgba(59,130,246,0.25);
                    }
                    #cs-time-icon {
                        font-size: 3.5rem; line-height: 1;
                        animation: csDoneTextIn 0.25s ease 0.15s both;
                    }
                    #cs-time-title {
                        color: #60a5fa; font-size: 1.8rem; font-weight: 700;
                        letter-spacing: -0.5px; margin-top: 16px;
                        animation: csDoneTextIn 0.25s ease 0.25s both;
                    }
                    #cs-time-sub {
                        color: #94a3b8; font-size: 0.95rem; margin-top: 6px;
                        animation: csDoneTextIn 0.25s ease 0.33s both;
                    }
                    #cs-time-change {
                        display: flex; align-items: center; justify-content: center; gap: 16px;
                        margin-top: 24px; padding: 14px 28px;
                        border-radius: 14px;
                        background: rgba(59,130,246,0.08);
                        border: 1px solid rgba(59,130,246,0.18);
                        animation: csDoneTextIn 0.3s ease 0.4s both;
                    }
                    .cs-time-val {
                        font-size: 2rem; font-weight: 700; font-variant-numeric: tabular-nums;
                    }
                    .cs-time-old { color: #94a3b8; text-decoration: line-through; opacity: .7; }
                    .cs-time-arrow { color: #60a5fa; font-size: 1.4rem; animation: csDoneTextIn 0.2s ease 0.5s both; }
                    .cs-time-new { color: #60a5fa; }

                    #cs-time-progress {
                        margin-top: 28px; width: 200px; margin-left: auto; margin-right: auto;
                        animation: csDoneTextIn 0.25s ease 0.55s both;
                    }
                    #cs-time-track {
                        height: 3px; background: rgba(255,255,255,0.08);
                        border-radius: 999px; overflow: hidden;
                    }
                    #cs-time-fill {
                        height: 100%; background: linear-gradient(90deg, #2563eb, #60a5fa);
                        border-radius: 999px;
                        animation: csDoneBar 1.2s linear 0.55s both;
                    }
                    #cs-time-closing {
                        color: #475569; font-size: 0.72rem; margin-top: 10px; letter-spacing: .5px;
                        text-transform: uppercase;
                        animation: csDonePulse 0.6s ease 0.6s infinite;
                    }
                </style>
                <div id="cs-time-card">
                    <div id="cs-time-icon">&#128337;</div>
                    <div id="cs-time-title">Review Time Updated</div>
                    <div id="cs-time-sub">${pcName || ''}${sessionName ? ' &nbsp;&middot;&nbsp; ' + sessionName : ''}</div>
                    <div id="cs-time-change">
                        <span class="cs-time-val cs-time-old">${fmtSec(oldSec)}</span>
                        <span class="cs-time-arrow">&rarr;</span>
                        <span class="cs-time-val cs-time-new">${fmtSec(newSec)}</span>
                    </div>
                    <div id="cs-time-progress">
                        <div id="cs-time-track"><div id="cs-time-fill"></div></div>
                        <div id="cs-time-closing">Returning to Home&hellip;</div>
                    </div>
                </div>`;
            document.body.appendChild(overlay);
            setTimeout(() => {
                overlay.style.animation = 'csDoneFadeOut 0.25s ease forwards';
                setTimeout(() => window.location.href = '/Home', 240);
            }, 1600);
        };
    </script>
</body>
</html>
