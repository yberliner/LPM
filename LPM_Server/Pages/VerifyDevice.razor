@page "/VerifyDevice"
@layout CustomLayout
@inject NavigationManager Navigation

<PageTitle>Verify Device — LPM</PageTitle>

@code {
    string _email = "your email";
    bool _invalid;
    bool _locked;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var q = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var email = q["email"] ?? "";
        _invalid = q["error"] == "invalid";
        _locked  = q["error"] == "locked";
        if (!string.IsNullOrWhiteSpace(email))
        {
            var at = email.IndexOf('@');
            if (at > 2)
                _email = email[..2] + new string('*', Math.Min(at - 2, 5)) + email[at..];
            else
                _email = email;
        }
    }
}

<div class="vd-container">
    <div class="vd-card">
        <div class="vd-header">
            <div class="vd-icon-wrap">
                <div class="vd-icon-pulse"></div>
                <i class="ri-shield-keyhole-line vd-icon"></i>
            </div>
            <h2 class="vd-title">Verify Your Device</h2>
            <p class="vd-sub">We sent a 6-digit code to your email:</p>
            <p class="vd-email"><i class="ri-mail-line"></i> @_email</p>
        </div>

        <div class="vd-body">
            @if (_locked)
            {
                <div class="vd-error">
                    <i class="ri-lock-line me-1"></i>Too many incorrect attempts. Please try again in 15 minutes.
                </div>
            }
            else if (_invalid)
            {
                <div class="vd-error">
                    <i class="ri-error-warning-line me-1"></i>Invalid or expired code. Please try again.
                </div>
            }

            <form method="post" action="/verify-code" class="vd-code-form">
                <label class="vd-code-label">Enter verification code</label>
                <input type="text" name="code" class="vd-code-input @(_invalid ? "vd-code-invalid" : "")"
                       maxlength="6" inputmode="numeric" pattern="[0-9]*"
                       placeholder="000000" autocomplete="one-time-code" autofocus />
                <button type="submit" class="vd-submit-btn">
                    <i class="ri-check-line me-2"></i>Verify
                </button>
            </form>

            <div class="vd-note">
                <i class="ri-mail-check-line"></i>
                Check your email inbox — the code expires in 10 minutes
            </div>
        </div>

        <div class="vd-footer">
            <a href="/login" class="vd-back-btn">
                <i class="ri-arrow-left-line me-1"></i>Back to Login
            </a>
        </div>
    </div>
</div>

<style>
    .vd-container {
        min-height: 100vh; display: flex; align-items: center; justify-content: center;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
        padding: 20px;
    }
    .vd-card {
        width: 440px; max-width: 100%;
        background: #fff; border-radius: 24px;
        box-shadow: 0 25px 80px rgba(0,0,0,.3);
        overflow: hidden;
        animation: vdSlideUp .5s cubic-bezier(.16,1,.3,1);
    }
    @@keyframes vdSlideUp { from { opacity:0; transform:translateY(30px); } to { opacity:1; transform:none; } }

    .vd-header {
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        padding: 40px 32px 32px; text-align: center; color: #fff;
        position: relative; overflow: hidden;
    }
    .vd-icon-wrap {
        position: relative; display: inline-flex;
        align-items: center; justify-content: center;
        width: 72px; height: 72px; margin-bottom: 16px;
    }
    .vd-icon-pulse {
        position: absolute; inset: 0; border-radius: 50%;
        background: rgba(255,255,255,.15);
        animation: vdPulse 2s ease-in-out infinite;
    }
    @@keyframes vdPulse { 0%,100% { transform:scale(1); opacity:.15; } 50% { transform:scale(1.3); opacity:.05; } }
    .vd-icon { font-size: 2.2rem; position: relative; z-index: 1; }
    .vd-title { font-size: 1.4rem; font-weight: 800; margin: 0 0 8px; }
    .vd-sub { font-size: 1rem; opacity: .9; margin: 0 0 12px; }
    .vd-email {
        font-size: 1.15rem; font-weight: 700; margin: 0;
        background: rgba(255,255,255,.18); border-radius: 10px;
        padding: 10px 18px; display: inline-flex; align-items: center; gap: 8px;
        letter-spacing: .3px;
    }
    .vd-email i { font-size: 1.3rem; }

    .vd-body { padding: 32px; }

    .vd-error {
        background: #fef2f2; color: #dc2626; border: 1px solid #fecaca;
        border-radius: 10px; padding: 10px 16px; margin-bottom: 20px;
        font-size: .88rem; font-weight: 600;
        animation: vdShake .4s ease;
    }
    @@keyframes vdShake { 0%,100% { transform:translateX(0); } 25% { transform:translateX(-6px); } 50% { transform:translateX(6px); } 75% { transform:translateX(-6px); } }

    .vd-code-form { display: flex; flex-direction: column; gap: 12px; }
    .vd-code-label { font-size: .82rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: .5px; }
    .vd-code-input {
        width: 100%; text-align: center; font-size: 2rem; font-weight: 800;
        letter-spacing: 12px; padding: 16px; border: 2px solid #e2e8f0;
        border-radius: 14px; outline: none; font-family: monospace;
        color: #1e293b; background: #f8fafc;
        transition: border-color .2s, box-shadow .2s;
    }
    .vd-code-input:focus { border-color: #6366f1; box-shadow: 0 0 0 4px rgba(99,102,241,.15); }
    .vd-code-invalid { border-color: #ef4444 !important; box-shadow: 0 0 0 4px rgba(239,68,68,.1) !important; }

    .vd-submit-btn {
        width: 100%; padding: 14px; border: none; border-radius: 12px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff;
        font-weight: 700; font-size: .95rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 16px rgba(99,102,241,.35);
        transition: transform .15s, box-shadow .15s;
    }
    .vd-submit-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(99,102,241,.45); }

    .vd-note {
        margin-top: 20px; padding: 10px 16px;
        background: #fef3c7; border-radius: 10px;
        color: #92400e; font-size: .82rem; font-weight: 600;
        display: flex; align-items: center; gap: 8px;
    }

    .vd-footer { padding: 16px 32px 24px; text-align: center; }
    .vd-back-btn {
        color: #6366f1; text-decoration: none; font-weight: 600; font-size: .88rem;
        display: inline-flex; align-items: center;
    }
    .vd-back-btn:hover { text-decoration: underline; }

    @@media (max-width: 480px) {
        .vd-code-input { font-size: 1.6rem; letter-spacing: 8px; padding: 14px; }
    }
</style>
