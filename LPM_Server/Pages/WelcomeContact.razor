@page "/WelcomeContact"
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Text.RegularExpressions
@implements IDisposable
@inject AuthenticationStateProvider AuthStateProvider
@inject LPM.Auth.UserDb UserDb
@inject LPM.Services.PcService PcSvc
@inject NavigationManager Nav

<PageTitle>Welcome — LPM</PageTitle>

@if (!_initialized) { return; }

<div class="wc-overlay">
    <div class="wc-card @(_submitted ? "wc-thankyou-state" : "")">

        @if (_submitted)
        {
            <div class="wc-thankyou">
                <svg class="wc-checkmark" viewBox="0 0 52 52">
                    <circle class="wc-checkmark-circle" cx="26" cy="26" r="25" fill="none" />
                    <path class="wc-checkmark-path" fill="none" d="M14 27 l8 8 l16-16" />
                </svg>
                <h2 class="wc-ty-title">Thank you!</h2>
                <p class="wc-ty-sub">Your contact information has been saved.</p>
            </div>
        }
        else
        {
            <div class="wc-header">
                <div class="wc-logo-ring"><i class="ri-shield-check-line"></i></div>
                <h1 class="wc-title">Welcome to LPM</h1>
                @if (!string.IsNullOrEmpty(_username))
                {
                    <p class="wc-username"><i class="ri-user-line"></i> @_username</p>
                }
                <p class="wc-subtitle">@(_hasExistingData ? "Please review your contact details — update if needed, then press Go." : "Before you continue, please provide your contact details.")</p>
            </div>

            <div class="wc-callout @(_isSolo ? "wc-callout-solo" : "wc-callout-staff")">
                <i class="ri-lock-line wc-callout-icon"></i>
                <div>
                    <strong>Why do we need this?</strong>
                    <p>Your contact information is used for secure account recovery and important notifications. It is never shared with third parties.</p>
                    @if (_isSolo)
                    {
                        <p class="wc-callout-solo-msg"><i class="ri-user-star-line"></i> As a solo auditor, keeping your contact details current ensures uninterrupted access to your personal folder.</p>
                    }
                </div>
            </div>

            <div class="wc-form">
                <!-- Email (read-only) -->
                <div class="wc-field">
                    <label class="wc-label">Email address</label>
                    <div class="wc-input-wrap">
                        <input class="wc-input" type="email" value="@_email" disabled
                               style="opacity:.7;cursor:not-allowed;" />
                    </div>
                </div>

                <!-- Phone (read-only) -->
                <div class="wc-field">
                    <label class="wc-label">Phone number</label>
                    <div class="wc-input-wrap">
                        <input class="wc-input" type="tel" value="@_normalizedPhone" disabled
                               style="opacity:.7;cursor:not-allowed;" />
                    </div>
                </div>

                <div class="wc-phone-preview" style="text-align:center;margin-bottom:12px;">
                    <i class="ri-information-line me-1"></i>Contact your administrator to update email or phone
                </div>

                <button class="wc-submit-btn" @onclick="Submit">
                    <i class="ri-arrow-right-circle-line"></i>
                    Continue
                </button>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="wc-error">@_error</div>
                }
            </div>
        }
    </div>
</div>

<style>
    .wc-overlay {
        position: fixed;
        inset: 0;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        overflow-y: auto;
        padding: 24px 16px;          /* horizontal padding so card never touches edges */
        -webkit-overflow-scrolling: touch;
    }

    .wc-card {
        background: rgba(255,255,255,0.07);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 24px;
        padding: 48px 44px;
        max-width: 520px;
        width: 100%;               /* fill available width (capped by overlay padding) */
        color: #f1f5f9;
        box-shadow: 0 25px 60px rgba(0,0,0,0.55), inset 0 1px 0 rgba(255,255,255,0.12);
        animation: wc-slide-in 0.65s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        transition: all 0.4s ease;
        box-sizing: border-box;
    }

    @@keyframes wc-slide-in {
        from { opacity: 0; transform: translateY(40px) scale(0.95); }
        to   { opacity: 1; transform: translateY(0)   scale(1); }
    }

    .wc-header { text-align: center; margin-bottom: 28px; }

    .wc-logo-ring {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: inline-flex; align-items: center; justify-content: center;
        font-size: 28px;
        margin-bottom: 16px;
        box-shadow: 0 0 0 8px rgba(99,102,241,0.15);
    }

    .wc-title {
        font-size: 1.8rem;
        font-weight: 700;
        margin: 0 0 8px;
        background: linear-gradient(90deg, #a5b4fc, #e879f9);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .wc-username {
        color: #818cf8; font-size: 1rem; font-weight: 600; margin: 4px 0 2px;
        display: flex; align-items: center; justify-content: center; gap: 6px;
    }
    .wc-subtitle {
        font-size: 0.95rem;
        color: #94a3b8;
        margin: 0;
    }

    .wc-callout {
        display: flex;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 14px;
        margin-bottom: 28px;
        font-size: 0.88rem;
        line-height: 1.55;
    }

    .wc-callout-staff {
        background: rgba(99,102,241,0.12);
        border: 1px solid rgba(99,102,241,0.3);
    }

    .wc-callout-solo {
        background: rgba(234,88,12,0.12);
        border: 1px solid rgba(234,88,12,0.3);
    }

    .wc-callout-icon {
        font-size: 20px;
        margin-top: 2px;
        flex-shrink: 0;
        color: #a5b4fc;
    }

    .wc-callout-solo .wc-callout-icon { color: #fb923c; }

    .wc-callout p { margin: 6px 0 0; color: #cbd5e1; }
    .wc-callout strong { color: #e2e8f0; }

    .wc-callout-solo-msg {
        color: #fdba74 !important;
        margin-top: 8px !important;
    }

    .wc-form { display: flex; flex-direction: column; gap: 20px; }

    .wc-field { display: flex; flex-direction: column; gap: 8px; }

    .wc-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #94a3b8;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .wc-input-wrap { position: relative; }

    .wc-input {
        width: 100%;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.18);
        border-radius: 10px;
        padding: 13px 16px;          /* 13px top/bottom ≈ 46px total — good touch target */
        color: #f1f5f9;
        font-size: 1rem;             /* 16px prevents iOS zoom-on-focus */
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;
        appearance: none;
        -webkit-appearance: none;
    }

    .wc-input::placeholder { color: #475569; }

    .wc-input:focus {
        border-color: rgba(99,102,241,0.6);
        box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
    }

    .wc-input-valid {
        border-color: rgba(34,197,94,0.6) !important;
        padding-right: 40px;
    }

    .wc-input-invalid {
        border-color: rgba(239,68,68,0.6) !important;
        padding-right: 40px;
    }

    .wc-valid-icon {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        color: #22c55e; font-size: 18px;
    }

    .wc-invalid-icon {
        position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
        color: #ef4444; font-size: 18px;
    }

    @@keyframes wc-shake {
        0%, 100% { transform: translateX(0); }
        20%       { transform: translateX(-6px); }
        40%       { transform: translateX(6px); }
        60%       { transform: translateX(-4px); }
        80%       { transform: translateX(4px); }
    }

    .wc-shake { animation: wc-shake 0.35s ease-in-out; }

    .wc-phone-row {
        display: flex;
        gap: 10px;
    }

    /* Country picker styles are in SpkCountryPicker.razor */

    .wc-phone-input { flex: 1; }

    .wc-phone-preview {
        font-size: 0.82rem;
        color: #64748b;
        padding: 4px 2px;
    }

    .wc-phone-preview strong { color: #94a3b8; }

    .wc-phone-error {
        font-size: 0.82rem;
        color: #f87171;
        padding: 4px 2px;
    }

    /* ── Tablet (768px and below) ── */
    @@media (max-width: 768px) {
        .wc-card {
            padding: 40px 32px;
        }
    }

    /* ── Mobile (480px and below) ── */
    @@media (max-width: 480px) {
        .wc-overlay {
            align-items: flex-start;   /* let card sit near top so keyboard doesn't push it off screen */
            padding: 20px 12px 40px;
        }
        .wc-card {
            padding: 28px 18px;
            border-radius: 18px;
        }
        .wc-logo-ring {
            width: 52px; height: 52px; font-size: 22px;
            margin-bottom: 12px;
        }
        .wc-title { font-size: 1.45rem; }
        .wc-subtitle { font-size: 0.88rem; }
        .wc-callout { padding: 13px 14px; font-size: 0.85rem; gap: 10px; }
        .wc-phone-row { flex-direction: column; gap: 8px; }
        .wc-header { margin-bottom: 20px; }
        .wc-form { gap: 16px; }
    }

    /* ── Very small phones (360px and below) ── */
    @@media (max-width: 360px) {
        .wc-card { padding: 22px 14px; border-radius: 14px; }
        .wc-title { font-size: 1.3rem; }
        .wc-label { font-size: 0.78rem; }
    }

    .wc-submit-btn {
        margin-top: 8px;
        padding: 15px 24px;
        width: 100%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        border-radius: 12px;
        color: white;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 4px 15px rgba(99,102,241,0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        min-height: 50px;
        -webkit-tap-highlight-color: transparent;
        touch-action: manipulation;
    }

    .wc-submit-btn:hover:not(:disabled) {
        opacity: 0.92;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(99,102,241,0.45);
    }

    .wc-submit-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .wc-error {
        font-size: 0.87rem;
        color: #f87171;
        text-align: center;
        padding: 10px;
        background: rgba(239,68,68,0.1);
        border-radius: 8px;
        border: 1px solid rgba(239,68,68,0.25);
    }

    /* Thank-you state */
    .wc-thankyou {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 20px 0;
        text-align: center;
        min-height: 200px;
    }

    .wc-checkmark {
        width: 80px; height: 80px;
        margin-bottom: 24px;
    }

    .wc-checkmark-circle {
        stroke: #22c55e;
        stroke-width: 2;
        stroke-dasharray: 166;
        stroke-dashoffset: 166;
        animation: wc-stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) 0.1s forwards;
    }

    .wc-checkmark-path {
        stroke: #22c55e;
        stroke-width: 3;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 48;
        stroke-dashoffset: 48;
        animation: wc-stroke 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.65s forwards;
    }

    @@keyframes wc-stroke {
        100% { stroke-dashoffset: 0; }
    }

    .wc-ty-title {
        font-size: 1.7rem;
        font-weight: 700;
        color: #f1f5f9;
        margin: 0 0 10px;
    }

    .wc-ty-sub {
        color: #94a3b8;
        font-size: 0.97rem;
        margin: 0;
    }
</style>

@code {
    // Country list from shared component
    private static SpkCountryPicker.CountryInfo[] _countries => SpkCountryPicker.Countries;

    private bool _initialized; // stays false until we've confirmed this user needs the form
    private int _userId;
    private int _personId;
    private string _username = "";
    private bool _isSolo;
    private bool _hasExistingData;
    private string _email = "";
    private bool _emailTouched;
    private bool _emailValid;
    private bool _emailShake;
    private System.Threading.Timer? _emailTimer;
    private int _selectedCountryIndex = 0; // Israel default
    private string _localPhone = "";
    #pragma warning disable CS0414
    private bool _phoneTouched;
    #pragma warning restore CS0414
    private bool _submitted;
    private string _error = "";

    private string EmailInputClass
    {
        get
        {
            if (!_emailTouched) return "wc-input";
            if (_emailValid) return "wc-input wc-input-valid";
            var shake = _emailShake ? " wc-shake" : "";
            return $"wc-input wc-input-invalid{shake}";
        }
    }

    private string _normalizedPhone => SpkCountryPicker.Normalize(_selectedCountryIndex, _localPhone);
    private bool IsPhoneValid() => SpkCountryPicker.IsValid(_selectedCountryIndex, _localPhone);
    private string PhoneErrorMessage() => SpkCountryPicker.ErrorMessage(_selectedCountryIndex, _localPhone);

    private void ParseStoredPhone(string stored)
    {
        var (idx, local) = SpkCountryPicker.ParsePhone(stored);
        _selectedCountryIndex = idx;
        _localPhone = local;
    }

    private bool CanSubmit => _emailValid && IsPhoneValid();

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("[WelcomeContact] OnInitializedAsync START");
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (!user.Identity?.IsAuthenticated ?? false)
        {
            Console.WriteLine("[WelcomeContact] Not authenticated → /login");
            Nav.NavigateTo("/login");
            return;
        }

        if (!int.TryParse(user.FindFirst("PersonId")?.Value, out _personId) || _personId == 0)
        {
            var username = user.FindFirst(ClaimTypes.Name)?.Value ?? "";
            _personId = UserDb.GetPersonId(username) ?? 0;
        }

        var username2 = user.FindFirst(ClaimTypes.Name)?.Value ?? "";
        _username = username2;
        var flags = UserDb.GetLoginFlags(username2);
        if (flags is not null)
        {
            _userId = flags.UserId;
            _isSolo = flags.StaffRole == StaffRoles.Solo;
        }

        // If the user doesn't need to confirm contact details, redirect immediately
        // before the first render so the form is never shown (no flicker).
        Console.WriteLine($"[WelcomeContact] userId={_userId} NeedsContactConfirm={(_userId > 0 ? UserDb.NeedsContactConfirm(_userId) : false)}");
        if (_userId > 0 && !UserDb.NeedsContactConfirm(_userId))
        {
            Console.WriteLine("[WelcomeContact] Redirecting to /Home");
            Nav.NavigateTo("/Home");
            return;
        }

        // Pre-populate existing contact data if available
        if (_personId > 0)
        {
            var (email, phone) = PcSvc.GetPersonContact(_personId);
            if (!string.IsNullOrEmpty(email))
            {
                _email        = email;
                _emailTouched = true;
                _emailValid   = IsValidEmail(email);
            }
            if (!string.IsNullOrEmpty(phone))
            {
                ParseStoredPhone(phone);
                _phoneTouched = true;
            }
            _hasExistingData = !string.IsNullOrEmpty(email) || !string.IsNullOrEmpty(phone);
        }

        // Only now allow the form to render
        _initialized = true;
        Console.WriteLine("[WelcomeContact] OnInitializedAsync DONE — _initialized=true");
    }

    private void OnPhoneInput(ChangeEventArgs e)
    {
        _localPhone   = e.Value?.ToString() ?? "";
        _phoneTouched = true;
    }

    private void OnEmailInput(ChangeEventArgs e)
    {
        _email = e.Value?.ToString() ?? "";
        _emailTouched = true;
        _emailShake = false;
        _emailTimer?.Dispose();
        _emailTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            var valid = IsValidEmail(_email);
            if (_emailTouched && !valid && !string.IsNullOrEmpty(_email))
                TriggerShake();
            _emailValid = valid;
            StateHasChanged();
        }), null, 400, System.Threading.Timeout.Infinite);
    }

    private async void TriggerShake()
    {
        _emailShake = true;
        StateHasChanged();
        await Task.Delay(400);
        _emailShake = false;
        StateHasChanged();
    }

    private static bool IsValidEmail(string email)
    {
        if (string.IsNullOrWhiteSpace(email)) return false;
        return Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]{2,}$");
    }

    private async Task Submit()
    {
        _error = "";
        try
        {
            if (_userId > 0)
                UserDb.SetContactConfirmed(_userId);
            Console.WriteLine($"[WelcomeContact] Contact confirmed (read-only): user='{_username}'");
            _submitted = true;
            StateHasChanged();
            await Task.Delay(1500);
            Nav.NavigateTo("/Home");
        }
        catch (Exception ex)
        {
            _error = "An error occurred. Please try again.";
            Console.WriteLine($"[WelcomeContact] Error: {ex.Message}");
        }
    }

    public void Dispose()
    {
        _emailTimer?.Dispose();
    }
}
