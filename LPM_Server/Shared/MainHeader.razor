    // Strip everything except digits and '.' — user literally cannot enter letters
    string FilterNumeric(string? val)
    {
        if (string.IsNullOrEmpty(val)) return "";
        var sb = new System.Text.StringBuilder();
        bool hasDot = false;
        foreach (var c in val)
        {
            if (char.IsDigit(c)) sb.Append(c);
            else if (c == '.' && !hasDot) { sb.Append(c); hasDot = true; }
        }
        return sb.ToString();
    }

    // Auto-format time live: insert colon but do NOT pad with leading zero
    // (padding happens on blur via SetArfTimeCell → FormatArfTime)
    void OnArfTimeLive(int tblIdx, int rowIdx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim() ?? "";
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (digits.Length >= 4)
        {
            // Insert colon without zero-padding so the user doesn't see extra characters
            var h = digits[..^2];
            var m = digits[^2..];
            _arfTables[tblIdx].Rows[rowIdx].Time = $"{h}:{m}";
            RecalcSessionLength();
        }
    }

    void SetArfTimeCell(int tblIdx, int rowIdx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim() ?? "";
        _arfTables[tblIdx].Rows[rowIdx].Time = FormatArfTime(raw);
        RecalcSessionLength();
        RebuildArfSummary();
    }

    void RecalcSessionLength()
    {
        _arfSessionLength = "";
        int totalMinutes = 0;
        foreach (var tbl in _arfTables)
        {
            var validTimes = tbl.Rows
                .Select(r => ArfTimeToMinutes(r.Time))
                .Where(t => t >= 0)
                .ToList();
            if (validTimes.Count >= 2)
            {
                var diff = validTimes[^1] - validTimes[0];
                if (diff > 0) totalMinutes += diff;
            }
        }
        if (totalMinutes > 0)
            _arfSessionLength = $"{totalMinutes / 60}:{totalMinutes % 60:D2}";
    }

    string FormatArfTime(string raw)
    {
        if (string.IsNullOrEmpty(raw)) return "";
        if (raw.Contains(':'))
        {
            // Pad existing h:mm to HH:MM
            var p = raw.Split(':');
            if (p.Length == 2 && int.TryParse(p[0], out var ph) && int.TryParse(p[1], out var pm))
                return $"{ph:D2}:{pm:D2}";
            return raw;
        }
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (digits.Length == 0) return "";
        if (digits.Length <= 2)
        {
            var m = int.Parse(digits);
            return $"00:{m:D2}";
        }
        if (digits.Length == 3)
        {
            var h = int.Parse(digits[..1]);
            var m = int.Parse(digits[1..]);
            return $"{h:D2}:{m:D2}";
        }
        if (digits.Length >= 4)
        {
            var h = int.Parse(digits[..^2]);
            var m = int.Parse(digits[^2..]);
            return $"{h:D2}:{m:D2}";
        }
        return raw;
    }

    bool IsValidArfTime(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return true;
        var parts = val.Split(':');
        if (parts.Length != 2) return false;
        if (!int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return false;
        if (h < 0 || h > 23 || m < 0 || m > 59) return false;
        // Must be exactly HH:MM (2 digits : 2 digits)
        return parts[0].Length == 2 && parts[1].Length == 2;
    }

    int ArfTimeToMinutes(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return -1;
        var parts = val.Split(':');
        if (parts.Length != 2 || !int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return -1;
        return h * 60 + m;
    }

    bool IsArfTimeOrdered(int tblIdx, int rowIdx)
    {
        var rows = _arfTables[tblIdx].Rows;
        var cur = ArfTimeToMinutes(rows[rowIdx].Time);
        if (cur < 0) return true; // empty/invalid — nothing to check
        // Look back to the nearest previous row with a valid time
        for (int i = rowIdx - 1; i >= 0; i--)
        {
            var prev = ArfTimeToMinutes(rows[i].Time);
            if (prev >= 0) return cur >= prev;
        }
        return true; // no prior valid time found
    }

    bool ArfHasInvalidFormat => _arfTables.SelectMany(tbl => tbl.Rows)
        .Any(r => !IsValidArfTime(r.Time) && !string.IsNullOrWhiteSpace(r.Time));

    bool ArfHasTimeOrderErrors => _arfTables.Select((tbl, tIdx) => new { tbl, tIdx })
        .Any(x => x.tbl.Rows.Select((r, rIdx) => rIdx)
            .Any(rIdx => !IsArfTimeOrdered(x.tIdx, rIdx)));

    bool ArfHasTimeErrors => ArfHasInvalidFormat || ArfHasTimeOrderErrors;

    bool ArfHasIncompleteRows => AllArfRows.Any(r =>
        !string.IsNullOrWhiteSpace(r.Time) && !IsValidArfTime(r.Time));

    bool IsArfTableEmpty => AllArfRows.All(r =>
        string.IsNullOrWhiteSpace(r.Time)
        && string.IsNullOrWhiteSpace(r.ToneArm));

    /// Finds rows where time goes backwards and checks if it looks like an AM/PM mistake.
    /// Returns a list of detailed reason strings for the tooltip.
    List<string> GetArfTimeOrderReasons()
    {
        var reasons = new List<string>();
        for (int tIdx = 0; tIdx < _arfTables.Count; tIdx++)
        {
            var rows = _arfTables[tIdx].Rows;
            for (int rIdx = 1; rIdx < rows.Count; rIdx++)
            {
                var cur = ArfTimeToMinutes(rows[rIdx].Time);
                if (cur < 0) continue;

                // Find the nearest earlier row with a valid time
                int prev = -1;
                string prevTime = "";
                for (int i = rIdx - 1; i >= 0; i--)
                {
                    prev = ArfTimeToMinutes(rows[i].Time);
                    if (prev >= 0) { prevTime = rows[i].Time; break; }
                }
                if (prev < 0 || cur >= prev) continue;

                // Time goes backwards — check if adding 12 hours fixes it (AM/PM confusion)
                var corrected = cur + 12 * 60;
                var curTime = rows[rIdx].Time;
                var tableLabel = _arfTables.Count > 1 ? $"ARF {tIdx + 1}, " : "";

                if (corrected < 24 * 60 && corrected >= prev)
                {
                    var suggestedH = corrected / 60;
                    var suggestedM = corrected % 60;
                    reasons.Add($"{tableLabel}Row {rIdx + 1}: {curTime} is earlier than {prevTime} — " +
                        $"did you mean {suggestedH:D2}:{suggestedM:D2}? (AM/PM mix-up)");
                }
                else
                {
                    reasons.Add($"{tableLabel}Row {rIdx + 1}: {curTime} is earlier than the previous time {prevTime} — " +
                        "times must go forward within a session");
                }
            }
        }
        return reasons;
    }

    List<string> Step2DisabledReasons
    {
        get
        {
            var reasons = new List<string>();
            if (_importSessionBytes == null || string.IsNullOrEmpty(_importNormalizedFileName))
                reasons.Add("Upload a session file");
            if (_importDuplicate)
                reasons.Add("Duplicate session — this file already exists");
            if (!string.IsNullOrEmpty(_importNameEditError))
                reasons.Add($"File name error: {_importNameEditError}");
            if (!IsArfTableEmpty && ArfHasInvalidFormat)
                reasons.Add("Fix time format errors — every time must be exactly HH:MM (e.g. 01:30, not 1:30)");
            if (!IsArfTableEmpty && ArfHasTimeOrderErrors)
            {
                var orderReasons = GetArfTimeOrderReasons();
                foreach (var r in orderReasons)
                    reasons.Add(r);
            }
            if (string.IsNullOrWhiteSpace(_arfSessionLength))
                reasons.Add("Enter the Session Length");
            return reasons;
        }
    }

    // Formats raw input as #.##.
    // With dot:    "3.42" → "3.42", "3." → "3." (in-progress), "3.4" → "3.4"
    // Without dot: "342"  → "3.42", "34" → "3.4", "3" → "3"
    static string FormatToneArm(string raw)
    {
        if (raw.Contains('.'))
        {
            var parts  = raw.Split('.', 2);
            var before = new string(parts[0].Where(char.IsDigit).Take(1).ToArray());
            var after  = new string(parts[1].Where(char.IsDigit).Take(2).ToArray());
            if (before.Length == 0) return string.Empty;
            return $"{before}.{after}";   // "3." preserved while user is still typing
        }
        var digits = new System.Text.StringBuilder();
        foreach (var c in raw)
            if (char.IsDigit(c) && digits.Length < 3)
                digits.Append(c);
        return digits.Length switch
        {
            0 => "",
            1 => digits.ToString(),
            2 => $"{digits[0]}.{digits[1]}",
            _ => $"{digits[0]}.{digits[1]}{digits[2]}"
        };
    }

