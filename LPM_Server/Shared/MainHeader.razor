    async Task SmSaveAdd()
    {
        _smAddError = "";
        if (_smAddPcId <= 0) { _smAddError = "Please select a PC."; return; }
        if (_smAddLenMin <= 0) { _smAddError = "Session length must be greater than 0."; return; }

        _smAddSaving = true;
        try
        {
            var auditorId = _smAddAuditorId > 0 ? (int?)_smAddAuditorId : null;
            var dateStr = _smAddDate.ToString("yyyy-MM-dd");
            var lengthSec = _smAddLenMin * 60;
            var adminSec = _smAddAdminMin * 60;
            bool isSolo = auditorId == null;

            await Task.Run(() =>
            {
                // Generate session name with unique index
                var datePrefix = DateTime.Now.ToString("yyMMdd");
                string sessionName = "";
                for (int i = 1; i <= 100; i++)
                {
                    var candidate = $"{datePrefix} Added manual session {i}";
                    if (!FolderSvc.SectionFileExistsAtPath(_smAddPcId, "WorkSheets", $"{candidate}.pdf", solo: isSolo))
                    {
                        sessionName = candidate;
                        break;
                    }
                }
                if (string.IsNullOrEmpty(sessionName))
                    sessionName = $"{datePrefix} Added manual session";

                // Create dummy PDF and save to WorkSheets (encrypted)
                var pdfBytes = FolderSvc.CreateDummySessionPdf();
                var saved = FolderSvc.SaveSectionFileToPath(_smAddPcId, "WorkSheets", $"{sessionName}.pdf", pdfBytes, solo: isSolo);
                if (!saved)
                    Console.WriteLine($"[SessionManager] Warning: could not save PDF for PC {_smAddPcId} (folder may not exist)");

                DashSvc.AddSessionFromManager(_smAddPcId, auditorId, _smAddCsId, dateStr,
                    lengthSec, adminSec, _smAddIsFree,
                    string.IsNullOrWhiteSpace(_smAddNotes) ? null : _smAddNotes,
                    _msgUserId!.Value, sessionName);
            });

            _smAddMode = false;
            _smSuccess = "Session added successfully.";
            if (_smSoloMode) SmLoadSoloSessions();
            else if (_smPcId > 0) SmLoadPage(_smPage);
            DashSvc.NotifyDataChanged();
        }
        catch (Exception ex) { _smAddError = $"Failed: {ex.Message}"; }
        finally { _smAddSaving = false; }
    }

    static string FormatSec(int sec)
    {
        if (sec <= 0) return "0:00";
        var m = sec / 60; var s = sec % 60;
        return $"{m}:{s:D2}";
    }

