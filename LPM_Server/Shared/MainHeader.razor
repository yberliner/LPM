@* ── Assign PC drawer ── *@
@if (_showAssignPcModal || _apcClosing)
{
    <div class="apc-overlay @(_apcClosing ? "apc-overlay-out" : "")"
         @onclick="CloseAssignPcAnimated">
        <div class="apc-drawer @(_apcClosing ? "apc-drawer-out" : "")"
             @onclick:stopPropagation="true">

            <div class="apc-drawer-hdr">
                <div class="d-flex align-items-center gap-2">
                    <i class="ri-shield-user-line" style="font-size:1.2rem;"></i>
                    <span style="font-weight:700;font-size:1.05rem;">Manage PC Assignments</span>
                </div>
                <button type="button" class="btn-close btn-close-white"
                        @onclick="CloseAssignPcAnimated"></button>
            </div>

            <div class="apc-drawer-body">
                @{
                    var myPcRoles = _apcMyPcs
                        .GroupBy(p => p.PcId)
                        .ToDictionary(g => g.Key, g => (
                            HasAud: g.Any(p => StaffRoles.IsAuditorCapacity(p.WorkCapacity)),
                            HasCS: g.Any(p => StaffRoles.IsCsCapacity(p.WorkCapacity))
                        ));
                    bool dualRole = _apcIsAuditor && _apcIsCS;
                    var singleRole = _apcIsAuditor ? StaffRoles.Auditor : StaffRoles.CS;

                    var searchResults = (string.IsNullOrWhiteSpace(_apcSearch)
                        ? _apcAllPcs
                        : _apcAllPcs
                            .Where(p => p.FullName.Contains(_apcSearch, StringComparison.OrdinalIgnoreCase)
                                        || p.Nick.Contains(_apcSearch, StringComparison.OrdinalIgnoreCase)))
                        .Where(p => p.PcId != _apcUserId)
                        .ToList();
                    bool isFiltering = !string.IsNullOrWhiteSpace(_apcSearch);
                }

                @* ── Browse panel ── *@
                <div class="apc-panel apc-browse-panel">
                    <div class="apc-section-hdr">
                        <i class="ri-search-eye-line"></i>Browse PCs
                        <span class="apc-section-count">@_apcAllPcs.Count(p => p.PcId != _apcUserId)</span>
                    </div>
                    <div class="apc-search-bar">
                        <div class="input-group">
                            <span class="input-group-text apc-search-icon"><i class="ri-search-line"></i></span>
                            <input class="form-control apc-search-input"
                                   placeholder="Search by name..."
                                   @bind="_apcSearch" @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(_apcSearch))
                            {
                                <button class="btn btn-outline-secondary apc-clear-btn"
                                        @onclick='() => _apcSearch = ""' title="Clear">
                                    <i class="ri-close-line"></i>
                                </button>
                            }
                        </div>
                        @if (isFiltering)
                        {
                            <div class="apc-filter-hint">
                                <i class="ri-filter-line me-1"></i>@searchResults.Count result@(searchResults.Count != 1 ? "s" : "")
                            </div>
                        }
                    </div>
                    <div class="apc-browse-list">
                        @if (searchResults.Count == 0)
                        {
                            <div class="apc-search-empty">
                                <i class="ri-search-line d-block mb-1" style="font-size:1.5rem;opacity:.3;"></i>
                                No PCs match "@_apcSearch"
                            </div>
                        }
                        @foreach (var pc in searchResults)
                        {
                            myPcRoles.TryGetValue(pc.PcId, out var pcR);
                            bool fullyAdded = (!_apcIsAuditor || pcR.HasAud) && (!_apcIsCS || pcR.HasCS);

                            <div class="apc-browse-item @(fullyAdded ? "apc-browse-done" : "")">
                                <i class="ri-user-line apc-browse-icon"></i>
                                <div class="apc-browse-name">
                                    @pc.FullName
                                    @if (!string.IsNullOrEmpty(pc.Nick))
                                    {
                                        <span class="apc-nick">(@pc.Nick)</span>
                                    }
                                </div>
                                <div class="apc-browse-actions">
                                    @if (fullyAdded)
                                    {
                                        <span class="apc-added-badge"><i class="ri-check-line me-1"></i>Added</span>
                                    }
                                    else if (dualRole)
                                    {
                                        @if (pcR.HasAud)
                                        {
                                            <span class="apc-qr-done apc-qr-done-aud"><i class="ri-check-line"></i> Aud</span>
                                        }
                                        else
                                        {
                                            <button class="apc-qr-btn apc-qr-aud"
                                                    @onclick="() => ApcAddPcWithRole(pc.PcId, StaffRoles.Auditor)">
                                                <i class="ri-add-line"></i> Aud
                                            </button>
                                        }
                                        @if (pcR.HasCS)
                                        {
                                            <span class="apc-qr-done apc-qr-done-cs"><i class="ri-check-line"></i> CS</span>
                                        }
                                        else
                                        {
                                            <button class="apc-qr-btn apc-qr-cs"
                                                    @onclick="() => ApcAddPcWithRole(pc.PcId, StaffRoles.CS)">
                                                <i class="ri-add-line"></i> CS
                                            </button>
                                        }
                                    }
                                    else
                                    {
                                        <button class="apc-qr-btn apc-qr-add"
                                                @onclick="() => ApcAddPcWithRole(pc.PcId, singleRole)">
                                            <i class="ri-add-circle-line"></i> Add
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @* ── Divider ── *@
                <div class="apc-divider"></div>

                @* ── Assignments panel ── *@
                <div class="apc-panel apc-assign-panel">
                    @{
                        var assignedGroups = _apcMyPcs
                            .GroupBy(p => p.PcId)
                            .Select(g => new {
                                PcId = g.Key,
                                FullName = g.First().FullName,
                                Nick = g.First().Nick,
                                HasAuditor = g.Any(p => StaffRoles.IsAuditorCapacity(p.WorkCapacity)),
                                HasCS = g.Any(p => StaffRoles.IsCsCapacity(p.WorkCapacity)),
                                IsPending = _apcUnapproved.Contains(g.Key)
                            })
                            .OrderBy(x => x.FullName)
                            .ToList();
                    }
                    <div class="apc-section-hdr">
                        <i class="ri-shield-check-line"></i>My Assignments
                        <span class="apc-section-count @(_apcNewPcId != 0 ? "apc-count-pulse" : "")">@assignedGroups.Count</span>
                    </div>
                    <div class="apc-assign-list">
                        @if (assignedGroups.Count == 0)
                        {
                            <div class="apc-assign-empty">
                                <i class="ri-inbox-line d-block mb-2" style="font-size:2rem;opacity:.3;"></i>
                                No PCs assigned yet.<br/>Search above to add.
                            </div>
                        }
                        else
                        {
                            <table class="apc-table">
                                <thead>
                                    <tr>
                                        <th class="apc-th-pc">PC / Person</th>
                                        @if (_apcIsAuditor) { <th class="apc-th-role">Auditor</th> }
                                        @if (_apcIsCS)      { <th class="apc-th-role">CS</th> }
                                        <th class="apc-th-remove"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int apcRowIdx = 0; }
                                    @foreach (var item in assignedGroups)
                                    {
                                        var ri = apcRowIdx++;
                                        <tr id="apc-row-@item.PcId"
                                            class="apc-row @(item.IsPending ? "apc-row-pending" : "") @(item.PcId == _apcNewPcId ? "apc-row-new" : "")"
                                            style="animation-delay:@(ri * 35)ms">
                                            <td class="apc-td-pc">
                                                @if (item.IsPending)
                                                {
                                                    <i class="ri-time-line me-2" style="color:#f59e0b;opacity:.7;"></i>
                                                }
                                                else
                                                {
                                                    <i class="ri-user-line me-2 opacity-40"></i>
                                                }
                                                <span>@item.FullName</span>
                                                @if (!string.IsNullOrEmpty(item.Nick))
                                                {
                                                    <span class="apc-nick"> (@item.Nick)</span>
                                                }
                                                @if (item.IsPending)
                                                {
                                                    <span class="apc-pending-badge ms-2">Pending</span>
                                                }
                                            </td>
                                            @if (_apcIsAuditor)
                                            {
                                                <td class="apc-td-role">
                                                    <button class="apc-role-pill @(item.HasAuditor ? "apc-pill-active-aud" : "apc-pill-inactive")"
                                                            title="@(item.HasAuditor ? "Remove Auditor role" : "Add as Auditor")"
                                                            @onclick='async () => await ApcTogglePcRole(item.PcId, "Auditor", item.HasAuditor)'>
                                                        <i class="@(item.HasAuditor ? "ri-checkbox-circle-fill" : "ri-add-circle-line") me-1"></i>Aud
                                                    </button>
                                                </td>
                                            }
                                            @if (_apcIsCS)
                                            {
                                                <td class="apc-td-role">
                                                    <button class="apc-role-pill @(item.HasCS ? "apc-pill-active-cs" : "apc-pill-inactive")"
                                                            title="@(item.HasCS ? "Remove CS role" : "Add as CS")"
                                                            @onclick='async () => await ApcTogglePcRole(item.PcId, "CS", item.HasCS)'>
                                                        <i class="@(item.HasCS ? "ri-checkbox-circle-fill" : "ri-add-circle-line") me-1"></i>CS
                                                    </button>
                                                </td>
                                            }
                                            <td class="apc-td-remove">
                                                <button class="apc-remove-btn" title="Remove all roles"
                                                        @onclick="async () => await ApcRemovePcAllRoles(item.PcId)">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@* ── Upload to Front Cover modal ── *@
@if (_showUploadFrontCover)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;"
         @onclick="() => _showUploadFrontCover = false">
        <div class="modal-dialog modal-dialog-centered modal-md"
             @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#1e293b; color:#e2e8f0; border:1px solid #334155;">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#065f46,#10b981); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-upload-cloud-2-line"></i>@LS.T("actions.uploadFrontCover")
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showUploadFrontCover = false"></button>
                </div>
                <div class="modal-body">
                    @if (_ufcSuccess)
                    {
                        <div class="ufc-success-content @(_ufcFading ? "ufc-fading" : "")"
                             style="text-align:center; padding:36px 16px 28px;">
                            <div class="ufc-success-wrap">
                                <div class="ufc-ripple"></div>
                                <div class="ufc-ripple ufc-ripple-2"></div>
                                <div class="ufc-ripple ufc-ripple-3"></div>
                                <div class="ufc-success-circle">
                                    <i class="ri-check-line"></i>
                                </div>
                            </div>
                            <div style="color:#10b981; font-weight:700; font-size:1rem; margin-top:18px; letter-spacing:.01em;">
                                Uploaded successfully!
                            </div>
                            <div style="color:#e2e8f0; font-size:.85rem; margin-top:8px; font-weight:600;">@_ufcSuccessPcName</div>
                            <div style="color:#64748b; font-size:.75rem; margin-top:3px;">@_ufcSuccessFileName</div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                            <select class="form-select form-select-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                    value="@_ufcPcId" @onchange="OnUfcPcChanged">
                                <option value="0">— Choose a PC —</option>
                                @foreach (var pc in _ufcAllPcs)
                                {
                                    <option value="@pc.PcId">@pc.FullName</option>
                                }
                            </select>
                        </div>

                        @if (_ufcPcId > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">
                                    File <span class="text-danger">*</span> <span class="text-muted">(PDF)</span>
                                </label>
                                <InputFile accept=".pdf" OnChange="OnUfcFileSelected"
                                           class="form-control form-control-sm"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                            </div>

                            @if (_ufcFile != null)
                            {
                                <div class="imp-file-card @(_ufcDuplicate ? "imp-file-dup imp-shake" : "")">
                                    <i class="ri-file-pdf-2-line" style="color:@(_ufcDuplicate ? "#ef4444" : "#10b981");"></i>
                                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @_ufcFile.Name
                                    </span>
                                    <span style="color:#64748b; font-size:.7rem;">@FormatFileSize(_ufcFile.Size)</span>
                                </div>
                                @if (_ufcDuplicate)
                                {
                                    <div class="imp-dup-msg">
                                        <i class="ri-error-warning-fill me-1"></i>A file with this name already exists in this PC's Front Cover. Rename the file and try again.
                                    </div>
                                }
                            }
                        }

                        @if (!string.IsNullOrEmpty(_ufcError))
                        {
                            <div class="alert alert-danger py-1 mt-2" style="font-size:.82rem;">@_ufcError</div>
                        }
                    }
                </div>
                @if (!_ufcSuccess)
                {
                <div class="modal-footer py-2" style="border-top:1px solid #334155;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showUploadFrontCover = false">@LS.T("common.cancel")</button>
                    <button class="btn btn-sm btn-success d-flex align-items-center gap-1"
                            disabled="@(_ufcPcId == 0 || _ufcFile == null || _ufcDuplicate || _ufcBusy)"
                            @onclick="DoUploadFrontCover">
                        @if (_ufcBusy)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <i class="ri-upload-cloud-2-line"></i>
                        }
                        Go
                    </button>
                </div>
                }
            </div>
        </div>
    </div>
}

@* ── PC Completions Modal ── *@
@if (_completionsOpen)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.45); z-index:9990;">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#7c3aed,#a855f7);">
                    <h6 class="modal-title text-white fw-bold mb-0 d-flex align-items-center gap-2">
                        <i class="ri-trophy-line"></i>@LS.T("actions.finishGrade")
                    </h6>
                    <button type="button" class="btn-close btn-close-white btn-sm"
                            @onclick="CloseCompletions"></button>
                </div>
                <div class="modal-body">
                    @* PC Selector *@
                    <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
                        <label class="fw-semibold text-nowrap mb-0">Select PC:</label>
                        <select class="form-select form-select-sm" style="max-width:280px;"
                                value="@_completionPcId"
                                @onchange="OnCompletionPcChanged">
                            <option value="0">-- choose a PC --</option>
                            @foreach (var pc in _completionAllPcs)
                            {
                                <option value="@pc.PcId">@pc.FullName</option>
                            }
                        </select>
                        @if (_completionPcId > 0)
                        {
                            <button class="btn btn-sm btn-primary ms-auto d-flex align-items-center gap-1"
                                    @onclick="StartAddCompletion">
                                <i class="ri-add-line"></i>Add
                            </button>
                        }
                    </div>

                    @* Table *@
                    @if (_completionPcId > 0)
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="min-width:130px;">Complete Date</th>
                                        <th style="min-width:130px;">Create Date</th>
                                        <th style="min-width:160px;">Finished Grade</th>
                                        <th style="min-width:160px;">Auditor</th>
                                        <th style="width:80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @* Add row *@
                                    @if (_completionAddMode)
                                    {
                                        <tr style="background:#f0fdf4;">
                                            <td><input type="date" class="form-control form-control-sm" value="@_editCompleteDate" @onchange="e => _editCompleteDate = e.Value?.ToString() ?? string.Empty" /></td>
                                            <td><span class="text-muted small">@DateTime.Today.ToString("yyyy-MM-dd")</span></td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="_editFinishedGrade">
                                                    <option value="">-- none --</option>
                                                    @foreach (var g in _completionGrades)
                                                    {
                                                        <option value="@g.Code">@g.Code</option>
                                                    }
                                                </select>
                                            </td>
                                            <td>
                                                <select class="form-select form-select-sm" @bind="_editAuditorId">
                                                    <option value="0">-- none --</option>
                                                    @foreach (var a in _completionAuditors)
                                                    {
                                                        <option value="@a.PersonId">@a.FullName</option>
                                                    }
                                                </select>
                                            </td>
                                            <td class="text-nowrap">
                                                <button class="btn btn-xs btn-success me-1" title="Save" @onclick="SaveAddCompletion">
                                                    <i class="ri-check-line"></i>
                                                </button>
                                                <button class="btn btn-xs btn-outline-secondary" title="Cancel" @onclick="CancelEditCompletion">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                    @* Existing rows *@
                                    @foreach (var row in _completions)
                                    {
                                        @if (_completionEditId == row.Id)
                                        {
                                            <tr style="background:#eff6ff;">
                                                <td><input type="date" class="form-control form-control-sm" value="@_editCompleteDate" @onchange="e => _editCompleteDate = e.Value?.ToString() ?? string.Empty" /></td>
                                                <td><span class="text-muted small">@row.CreateDate</span></td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="_editFinishedGrade">
                                                        <option value="">-- none --</option>
                                                        @foreach (var g in _completionGrades)
                                                        {
                                                            <option value="@g.Code">@g.Code</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td>
                                                    <select class="form-select form-select-sm" @bind="_editAuditorId">
                                                        <option value="0">-- none --</option>
                                                        @foreach (var a in _completionAuditors)
                                                        {
                                                            <option value="@a.PersonId">@a.FullName</option>
                                                        }
                                                    </select>
                                                </td>
                                                <td class="text-nowrap">
                                                    <button class="btn btn-xs btn-success me-1" title="Save" @onclick="() => SaveEditCompletion(row.Id)">
                                                        <i class="ri-check-line"></i>
                                                    </button>
                                                    <button class="btn btn-xs btn-outline-secondary" title="Cancel" @onclick="CancelEditCompletion">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                        else
                                        {
                                            <tr>
                                                <td>@(row.CompleteDate ?? "—")</td>
                                                <td>@row.CreateDate</td>
                                                <td>@(row.FinishedGrade ?? "—")</td>
                                                <td>@(_completionAuditors.FirstOrDefault(a => a.PersonId == row.AuditorId)?.FullName ?? "—")</td>
                                                <td class="text-nowrap">
                                                    <button class="btn btn-xs btn-outline-primary me-1" title="Edit"
                                                            @onclick="() => StartEditCompletion(row)">
                                                        <i class="ri-edit-line"></i>
                                                    </button>
                                                    <button class="btn btn-xs btn-outline-danger" title="Delete"
                                                            @onclick="() => DeleteCompletion(row.Id)">
                                                        <i class="ri-delete-bin-line"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    @if (!_completionAddMode && _completions.Count == 0)
                                    {
                                        <tr><td colspan="5" class="text-center text-muted py-3">No completions yet.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CloseCompletions">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Add Session Wizard ── *@
@if (_showImportWizard)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable wiz-modal-dialog @(_importStep >= 2 ? "modal-lg" : "modal-md")"
             @onclick:stopPropagation="true">
            <div class="modal-content wiz-modal-content">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1565c0,#1e88e5); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-upload-2-line"></i>@LS.T("actions.addSession")
                        @if (_importStep >= 2 && _importPcId > 0)
                        {
                            var pcName = _approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "";
                            <span style="opacity:.85; font-size:.82rem; font-weight:400;">
                                — @pcName
                                @if ((_importStep == 3 || _isSoloUser) && !string.IsNullOrWhiteSpace(_arfSessionLength))
                                {
                                    <span style="margin-left:8px; opacity:.7;">(@_arfSessionLength)</span>
                                }
                            </span>
                        }
                    </h5>
                    <div class="d-flex align-items-center gap-2 ms-auto me-2">
                        @if (_importStep >= 2 && _importPcId > 0)
                        {
                            <div style="position:relative;">
                                <button class="btn btn-sm py-0 px-2"
                                        style="background:rgba(255,255,255,.15); color:#e2e8f0; border:1px solid rgba(255,255,255,.25); font-size:.75rem; border-radius:4px;"
                                        @onclick="OpenRefBrowser"
                                        title="Open a reference file from this PC's folder">
                                    <i class="ri-eye-line me-1"></i>Reference
                                </button>
                                @if (_refBrowserOpen)
                                {
                                    <div style="position:absolute; right:0; top:calc(100% + 6px);
                                                background:#1e293b; border:1px solid #3b82f6; border-radius:6px;
                                                min-width:290px; max-height:420px; overflow-y:auto;
                                                z-index:10001; box-shadow:0 8px 24px rgba(0,0,0,.6);"
                                         @onclick:stopPropagation="true">
                                        <div style="padding:6px 10px; border-bottom:1px solid #334155;
                                                    font-size:.73rem; color:#94a3b8;
                                                    display:flex; justify-content:space-between; align-items:center;">
                                            <span><i class="ri-folder-open-line me-1"></i>Choose reference file</span>
                                            <button class="btn btn-sm p-0" style="color:#94a3b8; line-height:1;"
                                                    @onclick="() => _refBrowserOpen = false">
                                                <i class="ri-close-line"></i>
                                            </button>
                                        </div>
                                        @if (!_refFileList.Any())
                                        {
                                            <div style="padding:14px; color:#64748b; font-size:.8rem; text-align:center;">
                                                No files found in Front/Back Cover
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var grp in _refFileList.GroupBy(f => f.Section))
                                            {
                                                <div style="padding:4px 10px; font-size:.68rem; color:#64748b;
                                                            text-transform:uppercase; letter-spacing:.5px;
                                                            background:rgba(255,255,255,.03); border-bottom:1px solid #0f172a;">
                                                    <i class="ri-folder-line me-1"></i>@grp.Key
                                                </div>
                                                @foreach (var f in grp)
                                                {
                                                    var rf = f;
                                                    <button class="btn btn-sm w-100 text-start px-3 py-1"
                                                            style="color:#e2e8f0; font-size:.8rem; border-radius:0;
                                                                   border:none; background:transparent; border-bottom:1px solid #0f172a;"
                                                            @onclick="async () => await OpenRefFile(rf.RelPath, rf.Name)">
                                                        <i class="@(grp.Key == "Recent Worksheets" ? "ri-time-line" : "ri-file-pdf-2-line") me-2"
                                                           style="color:@(grp.Key == "Recent Worksheets" ? "#60a5fa" : "#ef5350");"></i>@rf.Name
                                                    </button>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="CloseWizard"></button>
                </div>
                <div class="modal-body">

                    @* ── Stepper (hidden for solo — single page) ── *@
                    @if (!_isSoloUser)
                    {
                    <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
                        <div class="wiz-stepper">
                            @{
                                var stepLabels = new[] { "Choose PC", "Fill ARF", "Next C/S" };
                            }
                            @for (int s = 1; s <= 3; s++)
                            {
                                var sn = s;
                                var lbl = stepLabels[sn - 1];
                                var isDone   = _importStep > sn;
                                var isActive = _importStep == sn;
                                var cls = isActive ? "wiz-active" : isDone ? "wiz-done" : "wiz-future";
                                <div class="wiz-step @cls">
                                    <div class="wiz-circle">
                                        @if (isDone) { <i class="ri-check-line"></i> }
                                        else { @sn }
                                    </div>
                                    <div class="wiz-label">@lbl</div>
                                </div>
                                @if (sn < 3)
                                {
                                    <div class="wiz-conn @(isDone ? "wiz-conn-done" : "")"></div>
                                }
                            }
                        </div>
                        @if (_importStep == 3 && _showArfSkipBadge)
                        {
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge bg-secondary" style="font-size:.72rem;">
                                    <i class="ri-file-forbid-line me-1"></i>ARF not generated
                                </span>
                            </div>
                        }
                    </div>
                    }

                    @if (_importStep == 1)
                    {
                        @* ── Step 1: Select PC + Files ── *@
                        @if (!_isSoloUser && _approvedPcs.Count == 0)
                        {
                            <div class="act-noperm-screen" style="padding:28px 16px 20px;">
                                <div class="act-noperm-icon-wrap">
                                    <div class="act-noperm-ring" style="border-color:rgba(220,38,38,.25);"></div>
                                    <i class="ri-lock-line act-noperm-icon"></i>
                                </div>
                                <div class="act-noperm-title" style="color:#e2e8f0;">@LS.T("actions.noFoldersAssigned")</div>
                                <div class="act-noperm-sub" style="color:#94a3b8;">@LS.T("actions.noFoldersMsg")<br>@LS.T("actions.contactAdmin")</div>
                            </div>
                        }
                        else
                        {
                        <div class="mb-3 d-flex align-items-center gap-2">
                            <input type="checkbox" id="chk-free-session" class="form-check-input"
                                   checked="@_importFreeSession"
                                   @onchange="e => _importFreeSession = (bool)(e.Value ?? false)"
                                   style="accent-color:#3b82f6; cursor:pointer; width:1rem; height:1rem;" />
                            <label for="chk-free-session" class="form-check-label"
                                   style="font-size:.82rem; color:#94a3b8; cursor:pointer; user-select:none;">
                                Free Session
                            </label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                            @if (_isSoloUser)
                            {
                                <div class="form-control form-control-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;">
                                    @(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "Solo")
                                    <span class="badge bg-primary ms-2" style="font-size:.7rem;">Solo</span>
                                </div>
                            }
                            else
                            {
                                <select class="form-select form-select-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                        value="@_importPcId" @onchange="OnPcChanged">
                                    <option value="0">— Choose a PC —</option>
                                    @foreach (var pc in _approvedPcs)
                                    {
                                        <option value="@pc.PcId">@pc.FullName</option>
                                    }
                                </select>
                            }
                        </div>
                        } @* end else (has approved PCs) *@
                    }
                    else if (_importStep == 2)
                    {
                        @* ── Step 2: File Upload + Auditor Report Form ── *@

                        @* Files section *@
                        <div class="mb-2">
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">
                                    Session File <span class="text-danger">*</span> <span class="text-muted">(PDF, single file)</span>
                                </label>
                                <div class="drop-zone" id="dz-session"
                                     ondragover="event.preventDefault();this.classList.add('drop-zone-active');"
                                     ondragleave="this.classList.remove('drop-zone-active');"
                                     ondrop="event.preventDefault();this.classList.remove('drop-zone-active');window._lpmDrop(event,'session');">
                                    <InputFile accept=".pdf" OnChange="OnSessionFileSelected"
                                               class="form-control form-control-sm"
                                               style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                                    <div class="drop-zone-hint">
                                        <i class="ri-drag-drop-line"></i> Drop PDF here
                                    </div>
                                </div>
                            </div>

                            @if (_importSessionBytes != null)
                            {
                                <div class="imp-file-card @(_importDuplicate ? "imp-file-dup imp-shake" : "")">
                                    <i class="@(_importSessionFile == null ? "ri-camera-line" : "ri-file-pdf-2-line")" style="color:@(_importDuplicate ? "#ef4444" : _importSessionFile == null ? "#14b8a6" : "#3b82f6");"></i>
                                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @_importSessionFileName
                                    </span>
                                    <span style="color:#64748b; font-size:.7rem;">@FormatFileSize(_importSessionBytes.Length)</span>
                                    <button class="btn btn-sm p-0" style="color:#ef5350; font-size:.85rem;"
                                            @onclick="ClearSessionFile">
                                        <i class="ri-close-line"></i>
                                    </button>
                                </div>
                                @if (_importDuplicate)
                                {
                                    <div class="imp-dup-msg">
                                        <i class="ri-error-warning-fill me-1"></i>@_importFileWarning
                                    </div>
                                }
                                @if (_importSessionBytes != null)
                                {
                                    <div style="font-size:.75rem; margin-top:6px;">
                                        <div style="display:flex; align-items:center; gap:5px; flex-wrap:wrap;">
                                            <i class="ri-edit-line" style="color:#f59e0b;"></i>
                                            <span style="color:#f59e0b; white-space:nowrap;">Save as:</span>
                                            <div style="display:flex; align-items:center; gap:2px; flex:1; min-width:0;">
                                                <input type="text"
                                                       value="@_importNormalizedFileName"
                                                       @oninput="OnNormalizedNameChanged"
                                                       style="flex:1; min-width:0; background:#0f172a; color:#e2e8f0;
                                                              border:1px solid @(string.IsNullOrEmpty(_importNameEditError) ? "#475569" : "#ef4444");
                                                              border-radius:4px; padding:2px 6px; font-size:.75rem;" />
                                                <span style="color:#94a3b8; white-space:nowrap;">.pdf</span>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(_importNameEditError))
                                        {
                                            <div style="color:#ef4444; margin-top:3px; padding-left:18px;">
                                                <i class="ri-error-warning-line me-1"></i>@_importNameEditError
                                            </div>
                                        }
                                        @if (_importDateWasPrepended)
                                        {
                                            <div style="display:flex; align-items:center; gap:5px; margin-top:4px; padding-left:18px;">
                                                <i class="ri-calendar-line" style="color:#94a3b8;"></i>
                                                <span style="color:#94a3b8;">Change date:</span>
                                                <input type="date"
                                                       value="@_importNormalizedDate.ToString("yyyy-MM-dd")"
                                                       @onchange="OnNormalizedDateChanged"
                                                       style="background:#0f172a; color:#e2e8f0; border:1px solid #475569;
                                                              border-radius:4px; padding:1px 4px; font-size:.75rem; cursor:pointer;" />
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            @{  var attDisabled = _importSessionBytes == null; }
                            <div class="mb-2" style="@(attDisabled ? "opacity:.45; pointer-events:none;" : "")">
                                <label class="form-label d-flex align-items-center gap-1" style="font-size:.82rem; color:@(_isSoloUser ? "#a78bfa" : "#94a3b8");">
                                    <i class="ri-attachment-line" style="color:@(_isSoloUser ? "#a78bfa" : "#94a3b8");"></i>
                                    Attachments <span class="text-muted">(optional, multiple PDFs)</span>
                                    @if (!attDisabled)
                                    {
                                    <span class="att-info-trigger" tabindex="0">
                                        <i class="ri-question-line" style="color:#a78bfa; cursor:pointer; font-size:.9rem;"></i>
                                        <span class="att-info-tooltip">
                                            <i class="ri-lightbulb-flash-line" style="color:#fbbf24; margin-right:4px;"></i>
                                            Attach extra documents for this session — worksheets, notes, references. They'll be saved alongside the session file.
                                        </span>
                                    </span>
                                    }
                                </label>
                                @if (attDisabled)
                                {
                                    <div style="font-size:.75rem; color:#64748b; font-style:italic;">
                                        <i class="ri-arrow-up-line me-1"></i>Upload a session file first
                                    </div>
                                }
                                else
                                {
                                <div class="drop-zone" id="dz-attachments"
                                     ondragover="event.preventDefault();this.classList.add('drop-zone-active');"
                                     ondragleave="this.classList.remove('drop-zone-active');"
                                     ondrop="event.preventDefault();this.classList.remove('drop-zone-active');window._lpmDrop(event,'attachment');">
                                    <InputFile multiple accept=".pdf" OnChange="OnAttachmentFilesSelected"
                                               class="form-control form-control-sm"
                                               style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                                    <div class="drop-zone-hint">
                                        <i class="ri-drag-drop-line"></i> Drop PDFs here
                                    </div>
                                </div>
                                }
                            </div>

                            @if (_importAttachmentBytes.Count > 0)
                            {
                                <div class="mb-2">
                                    <div style="font-size:.78rem; color:#94a3b8;" class="mb-1">
                                        <i class="ri-attachment-line me-1"></i>@_importAttachmentBytes.Count attachment(s):
                                    </div>
                                    @for (int ai = 0; ai < _importAttachmentBytes.Count; ai++)
                                    {
                                        var attIdx = ai;
                                        var att = _importAttachmentBytes[attIdx];
                                        <div class="d-flex align-items-center gap-2 py-1 px-2 mb-1"
                                             style="background:rgba(255,255,255,.05); border-radius:4px; font-size:.78rem;">
                                            <i class="@(att.IsScanned ? "ri-camera-line" : "ri-file-pdf-2-line")"
                                               style="color:@(att.IsScanned ? "#14b8a6" : "#ef5350");"></i>
                                            <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                @att.Name
                                            </span>
                                            <span style="color:#64748b; font-size:.7rem;">
                                                @FormatFileSize(att.Data.Length)
                                            </span>
                                            <button class="btn btn-sm p-0" style="color:#ef5350; font-size:.85rem;"
                                                    @onclick="() => _importAttachmentBytes.RemoveAt(attIdx)">
                                                <i class="ri-close-line"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="mb-2 d-flex align-items-center gap-2 flex-wrap">
                            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                    style="font-size:.78rem;"
                                    @onclick="PickFromInbox">
                                <i class="ri-inbox-line"></i> Pick from Inbox
                            </button>
                            @if (!string.IsNullOrEmpty(_inboxMessage))
                            {
                                <span style="font-size:.75rem; color:@(_inboxMessage.StartsWith("Error") || _inboxMessage == "Inbox is empty" ? "#f59e0b" : "#10b981");">
                                    <i class="@(_inboxMessage.StartsWith("Error") || _inboxMessage == "Inbox is empty" ? "ri-information-line" : "ri-check-line") me-1"></i>@_inboxMessage
                                </span>
                            }
                        </div>

                        @if (_isSoloUser)
                        {
                        @* ── Solo: multi-section (date + length + admin + summary) ── *@
                        <hr style="border-color:#334155; margin:4px 0 12px;" />

                        @for (int si = 0; si < _soloSections.Count; si++)
                        {
                            var idx = si;
                            var sec = _soloSections[idx];
                            var secLabel = _soloSections.Count > 1 ? $"Section {idx + 1}" : "";
                            <div class="solo-section @(idx > 0 ? "solo-section-extra" : "")">
                                @if (_soloSections.Count > 1)
                                {
                                    <div class="solo-section-header">
                                        <span class="solo-section-badge">@secLabel</span>
                                        <button class="solo-section-remove" title="Remove this section"
                                                @onclick="() => _soloSections.RemoveAt(idx)">
                                            <i class="ri-close-circle-line"></i>
                                        </button>
                                    </div>
                                }
                                <div class="solo-section-fields">
                                    <div class="solo-field">
                                        <label class="solo-field-label">Date</label>
                                        <input type="date" class="form-control form-control-sm solo-input"
                                               value="@sec.Date"
                                               @onchange="e => { sec.Date = e.Value?.ToString() ?? SoloTodayStr(); }" />
                                    </div>
                                    <div class="solo-field">
                                        <label class="solo-field-label">
                                            Length
                                            @if (string.IsNullOrWhiteSpace(sec.SessionLength))
                                            {
                                                <span class="solo-required">*</span>
                                            }
                                        </label>
                                        <input type="text" inputmode="numeric" maxlength="5"
                                               class="form-control form-control-sm solo-input solo-time @(string.IsNullOrWhiteSpace(sec.SessionLength) ? "solo-input-error" : "")"
                                               placeholder="H:MM"
                                               value="@sec.SessionLength"
                                               @oninput="e => sec.SessionLength = e.Value?.ToString() ?? string.Empty" />
                                    </div>
                                    <div class="solo-field">
                                        <label class="solo-field-label">
                                            Admin
                                            @if (string.IsNullOrWhiteSpace(sec.AdminTime))
                                            {
                                                <span class="solo-required">*</span>
                                            }
                                        </label>
                                        <input type="text" inputmode="numeric" maxlength="5"
                                               class="form-control form-control-sm solo-input solo-time @(string.IsNullOrWhiteSpace(sec.AdminTime) ? "solo-input-error" : "")"
                                               placeholder="H:MM"
                                               value="@sec.AdminTime"
                                               @oninput="e => sec.AdminTime = e.Value?.ToString() ?? string.Empty" />
                                    </div>
                                </div>
                                <div class="solo-summary-wrap">
                                    <label class="solo-field-label">
                                        Summary
                                        @if (string.IsNullOrWhiteSpace(sec.Summary))
                                        {
                                            <span class="solo-required">*</span>
                                        }
                                    </label>
                                    <textarea class="form-control form-control-sm solo-summary @(string.IsNullOrWhiteSpace(sec.Summary) ? "solo-input-error" : "")"
                                              rows="2" placeholder="Session summary..."
                                              value="@sec.Summary"
                                              @oninput="e => sec.Summary = e.Value?.ToString() ?? string.Empty"></textarea>
                                </div>
                            </div>
                        }

                        <button class="solo-add-btn" @onclick="() => _soloSections.Add(new SoloSection())">
                            <i class="ri-add-circle-line me-1"></i> Add session summary
                        </button>
                        }
                        else
                        {
                        @* ── Non-solo: full ARF form ── *@
                        <hr style="border-color:#334155; margin:4px 0 12px;" />

                        <div class="arf">
                            <div class="arf-subtitle">Dror Center, Haifa, Israel</div>
                            <div class="arf-title">Auditor Report Form</div>

                            @* Row 1: PC's Name + Date *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">PC's Name</span>
                                    <span class="arf-val">@(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "")</span>
                                </div>
                                <div class="arf-field">
                                    <span class="arf-lbl arf-lbl-right-fixed">Date</span>
                                    <input type="text" class="form-control form-control-sm arf-input-short"
                                           @bind="_arfDate" @bind:event="oninput" @bind:after="SyncArfDate"
                                           placeholder="dd/mm/yy" maxlength="8"
                                           style="width:5.5rem; text-align:center;" />
                                </div>
                            </div>

                            @* Row 2: PC's Grade + Session Length *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">PC's Grade</span>
                                    <input type="text" class="form-control form-control-sm arf-input-short"
                                           @bind="_arfGrade" @bind:event="oninput" />
                                </div>
                                <div class="arf-field">
                                    <span class="arf-lbl arf-lbl-right-fixed">
                                        Session Length
                                        @if (string.IsNullOrWhiteSpace(_arfSessionLength))
                                        {
                                            <span style="color:#ef4444;font-weight:700;margin-left:2px;">*</span>
                                        }
                                    </span>
                                    <input type="text" inputmode="numeric" maxlength="5"
                                           class="form-control form-control-sm arf-input-xs arf-time-input"
                                           style="@(string.IsNullOrWhiteSpace(_arfSessionLength) ? "border:2px solid #ef4444 !important;background:rgba(239,68,68,.08) !important;" : "")"
                                           placeholder="H:MM"
                                           value="@_arfSessionLength"
                                           @oninput="e => _arfSessionLength = e.Value?.ToString() ?? string.Empty" />
                                </div>
                            </div>

                            @* Row 3: Total TA (Admin Time moved to Step 3) *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">Total TA</span>
                                    <input type="number" step="any"
                                           class="form-control form-control-sm arf-input-xs"
                                           @bind="_arfTotalTa" @bind:event="oninput" />
                                </div>
                            </div>

                            @* ── ARF Tables: Process / Time / Tone Arm Reads / Results and Comments ── *@
                            @for (int ti = 0; ti < _arfTables.Count; ti++)
                            {
                                var tIdx = ti;
                                var tblDuration = GetArfTableDuration(tIdx);
                                <div class="arf-table-card">
                                    <div class="arf-table-header">
                                        <span>ARF @(tIdx + 1)</span>
                                        @if (!string.IsNullOrEmpty(tblDuration))
                                        {
                                            <span class="arf-table-duration">Duration: @tblDuration</span>
                                        }
                                    </div>
                                    <table class="arf-table">
                                        <thead>
                                            <tr>
                                                <th style="width:3%;"></th>
                                                <th style="width:35%;">Process</th>
                                                <th style="width:10%;">Time</th>
                                                <th style="width:10%;">Tone Arm<br/>Reads</th>
                                                <th style="width:35%;">Results and Comments</th>
                                                <th style="width:7%;"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (int ri = 0; ri < _arfTables[tIdx].Rows.Count; ri++)
                                            {
                                                var rIdx = ri;
                                                var row = _arfTables[tIdx].Rows[rIdx];
                                                <tr>
                                                    <td style="text-align:center; vertical-align:middle;">
                                                        <input type="checkbox" checked="@row.Checked"
                                                               @onchange="e => { _arfTables[tIdx].Rows[rIdx].Checked = (bool)(e.Value ?? false); RebuildArfSummary(); }"
                                                               style="accent-color:#3b82f6; cursor:pointer;" />
                                                    </td>
                                                    <td style="vertical-align:top;">
                                                        <textarea id="arf-c-@tIdx-@rIdx-0"
                                                               class="arf-cell-input arf-cell-textarea"
                                                               rows="1" dir="auto"
                                                               @onblur="() => _arfTables[tIdx].Rows[rIdx].Touched = true"
                                                               @oninput="e => { _arfTables[tIdx].Rows[rIdx].Process = e.Value?.ToString() ?? string.Empty; var _kw = HasAutoUncheckKeyword(_arfTables[tIdx].Rows[rIdx].Process); if (!_kw) _arfTables[tIdx].Rows[rIdx].AutoUnchecked = false; if (_kw && !_arfTables[tIdx].Rows[rIdx].AutoUnchecked && _arfTables[tIdx].Rows[rIdx].Checked) { _arfTables[tIdx].Rows[rIdx].Checked = false; _arfTables[tIdx].Rows[rIdx].AutoUnchecked = true; } RebuildArfSummary(); }">@row.Process</textarea>
                                                    </td>
                                                    <td>
                                                        <input id="arf-c-@tIdx-@rIdx-1" type="text" inputmode="numeric" maxlength="5"
                                                               class="arf-cell-input arf-cell-center arf-time-input @(!IsValidArfTime(row.Time) || (!string.IsNullOrWhiteSpace(row.Time) && !IsArfTimeOrdered(tIdx, rIdx)) ? "arf-cell-invalid" : "")"
                                                               placeholder="HH:MM"
                                                               value="@row.Time"
                                                               @onblur="() => _arfTables[tIdx].Rows[rIdx].Touched = true"
                                                               @oninput="e => OnArfTimeLive(tIdx, rIdx, e)"
                                                               @onchange="e => SetArfTimeCell(tIdx, rIdx, e)"/>
                                                    </td>
                                                    <td>
                                                        <input id="arf-c-@tIdx-@rIdx-2" type="text" inputmode="numeric" maxlength="4"
                                                               class="arf-cell-input arf-cell-center"
                                                               onkeydown="var k=event.key,v=event.target.value;if(['Backspace','Delete','Tab','ArrowLeft','ArrowRight','ArrowUp','ArrowDown','Home','End'].includes(k))return;if(k==='.'&&!v.includes('.')&&v.length===1)return;if(/[0-9]/.test(k))return;event.preventDefault();"
                                                               value="@row.ToneArm"
                                                               @oninput="e => { _arfTables[tIdx].Rows[rIdx].ToneArm = FormatToneArm(e.Value?.ToString() ?? string.Empty); RebuildArfSummary(); }"/>
                                                    </td>
                                                    <td style="vertical-align:top;">
                                                        <textarea id="arf-c-@tIdx-@rIdx-3" class="arf-cell-input arf-cell-textarea"
                                                               rows="1" dir="auto"
                                                               @oninput="e => { _arfTables[tIdx].Rows[rIdx].Results = e.Value?.ToString() ?? string.Empty; RebuildArfSummary(); }"
                                                               @onkeydown="e => OnArfResultsKeyDown(e, tIdx, rIdx)">@row.Results</textarea>
                                                    </td>
                                                    <td style="text-align:center; vertical-align:middle;">
                                                        <div class="d-flex align-items-center justify-content-center gap-0">
                                                            <button class="btn btn-sm p-0 arf-row-action-btn" title="Insert row above"
                                                                    @onclick="() => InsertArfRow(tIdx, rIdx, false)">
                                                                <i class="ri-arrow-up-s-line"></i>
                                                            </button>
                                                            <button class="btn btn-sm p-0 arf-row-action-btn" title="Insert row below"
                                                                    @onclick="() => InsertArfRow(tIdx, rIdx, true)">
                                                                <i class="ri-arrow-down-s-line"></i>
                                                            </button>
                                                            @if (!(_arfTables.Count == 1 && _arfTables[0].Rows.Count == 1))
                                                            {
                                                                <button class="btn btn-sm p-0 arf-del-row-btn" title="Delete row"
                                                                        @onclick="() => RemoveArfRow(tIdx, rIdx)">
                                                                    <i class="ri-close-line"></i>
                                                                </button>
                                                            }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                    <div class="d-flex justify-content-end mt-1">
                                        <button class="btn btn-sm p-0 d-flex align-items-center gap-1"
                                                style="color:#64748b; font-size:.72rem;"
                                                title="Add a row to this ARF table"
                                                @onclick="() => AddArfRow(tIdx)">
                                            <i class="ri-add-line"></i> + Row
                                        </button>
                                    </div>
                                </div>
                            }
                            <div class="d-flex justify-content-end mt-1">
                                <button class="btn btn-sm p-0 d-flex align-items-center gap-1"
                                        style="color:#3b82f6; font-size:.76rem; font-weight:600;"
                                        title="Add a new independent ARF session table"
                                        @onclick="AddArfTable">
                                    <i class="ri-file-add-line"></i> + Add Session ARF
                                </button>
                            </div>

                            @* ── TA Range at bottom *@
                            <div class="arf-row mt-3">
                                <div class="arf-field">
                                    <span class="arf-lbl">TA Range</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="text" inputmode="numeric" maxlength="4" id="arf-ta-from"
                                               class="form-control form-control-sm arf-input-short"
                                               placeholder="from"
                                               onkeydown="var k=event.key,v=event.target.value;if(['Backspace','Delete','Tab','ArrowLeft','ArrowRight','Home','End'].includes(k))return;if(k==='.'&&!v.includes('.')&&v.length===1)return;if(/[0-9]/.test(k))return;event.preventDefault();"
                                               value="@_arfTaRangeFrom"
                                               @oninput="SetTaRangeFrom" />
                                        <span style="font-weight:600;">-</span>
                                        <input type="text" inputmode="numeric" maxlength="4" id="arf-ta-to"
                                               class="form-control form-control-sm arf-input-short"
                                               placeholder="to"
                                               style="@(TaRangeInvalid ? "border-color:red;background-color:#fff0f0;" : "")"
                                               onkeydown="var k=event.key,v=event.target.value;if(['Backspace','Delete','Tab','ArrowLeft','ArrowRight','Home','End'].includes(k))return;if(k==='.'&&!v.includes('.')&&v.length===1)return;if(/[0-9]/.test(k))return;event.preventDefault();"
                                               value="@_arfTaRangeTo"
                                               @oninput="SetTaRangeTo" />
                                    </div>
                                </div>
                            </div>

                            @* ── Exam Report ── *@
                            <div class="arf-row mt-2">
                                <div class="arf-field">
                                    <span class="arf-lbl">Exam report</span>
                                    <div class="d-flex gap-2">
                                        @foreach (var opt in new[] { "F/N", "RT", "YT", "PT" })
                                        {
                                            var localOpt = opt;
                                            var isActive = _arfExamReport == localOpt;
                                            var examColor = localOpt switch {
                                                "F/N" => "#16a34a",
                                                "RT"  => "#dc2626",
                                                "YT"  => "#ca8a04",
                                                "PT"  => "#db2777",
                                                _     => "#64748b"
                                            };
                                            var btnClass = isActive ? "btn btn-sm" : "btn btn-sm btn-outline-secondary";
                                            var btnStyle = isActive
                                                ? $"background:{examColor};border-color:{examColor};color:#fff;font-weight:600;"
                                                : $"color:{examColor};border-color:{examColor};";
                                            <button type="button" class="@btnClass" style="@btnStyle"
                                                    @onclick="() => ToggleExamReport(localOpt)">
                                                @localOpt
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* ── Summary (auto-built from checked rows, also editable with rich text) ── *@
                            <div class="mt-3">
                                <span class="arf-lbl">Summary</span>
                                <div id="arf-summary-wrap">
                                    <div id="arf-summary-editor"></div>
                                </div>
                            </div>
                        </div>
                        } @* end non-solo ARF *@
                    }
                    else
                    {
                        @* ── Step 3: Next C/S Sheet ── *@
                        <div class="arf wiz-step3-content" style="display:flex; flex-direction:column; min-height:480px;">
                            <div class="s3-subtitle">Dror Center, Haifa, Israel</div>

                            @* extra line *@
                            <div style="height:.9rem;"></div>

                            @* PC Name + Date row *@
                            <div style="display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:8px;">
                                <span class="s3-label" style="font-size:1.35rem;">
                                    PC's Name:&nbsp;<span class="s3-value">@(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "")</span>
                                </span>
                                <span class="s3-label" style="font-size:1.35rem;">
                                    Date:&nbsp;<span class="s3-value">@_arfDate</span>
                                </span>
                            </div>

                            @* Auditor row *@
                            <div class="s3-label" style="font-size:1.35rem; margin-top:4px;">
                                Auditor:&nbsp;<span class="s3-value">@(string.IsNullOrWhiteSpace(_importAuditorFullName) ? _logUsername : _importAuditorFullName)</span>
                            </div>

                            @* Free text — above "The Next C/S:" *@
                            <div class="mt-2">
                                <div id="step3-top-editor"></div>
                            </div>

                            @* ~20% spacer *@
                            <div style="min-height:32px;"></div>

                            @* The Next C/S: — centred, bold, underlined *@
                            <div class="s3-heading">
                                The Next C/S:
                            </div>

                            @* Free text — below "The Next C/S:" *@
                            <div class="mt-2">
                                <div id="step3-bottom-editor"></div>
                            </div>

                            @* lower spacer *@
                            <div style="min-height:32px;"></div>

                            @* Auditor signature — bottom right *@
                            <div class="s3-signature">
                                @(string.IsNullOrWhiteSpace(_importAuditorFullName) ? _logUsername : _importAuditorFullName)
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_importError))
                    {
                        <div class="alert alert-danger py-1 mb-2" style="font-size:.8rem;">
                            <i class="ri-error-warning-line me-1"></i>@_importError
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_importSuccess))
                    {
                        <div class="alert alert-success py-1 mb-2" style="font-size:.8rem;">
                            <i class="ri-check-double-line me-1"></i>@_importSuccess
                        </div>
                    }
                </div>
                <div class="modal-footer py-2" style="border-color:#334155;">
                    @if (_importStep == 1)
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseWizard">@LS.T("common.cancel")</button>
                        @if (_isSoloUser)
                        {
                            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                    disabled="@(_importPcId == 0)"
                                    @onclick="GoToExamStep">
                                Next <i class="ri-arrow-right-s-line"></i>
                            </button>
                        }
                    }
                    else if (_importStep == 2)
                    {
                        @if (_isSoloUser)
                        {
                        @* ── Solo footer: Back, Cancel, Go with validation ── *@
                        <div class="d-flex align-items-center w-100 gap-2 wiz-step3-footer">
                            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                    @onclick="() => { _importStep = 1; }">
                                <i class="ri-arrow-left-s-line"></i> Back
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseWizard">@LS.T("common.cancel")</button>
                            @{
                                var soloReasons = GetSoloGoReasons();
                            }
                            <div class="wiz-next-wrap ms-auto">
                                <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                        disabled="@(soloReasons.Count > 0)"
                                        @onclick="ExecuteSoloImport">
                                    <i class="ri-upload-2-line"></i> Go
                                </button>
                                @if (soloReasons.Count > 0)
                                {
                                    <div class="wiz-next-hover-zone"></div>
                                    <div class="wiz-next-tooltip">
                                        <div class="wiz-next-tooltip-title"><i class="ri-error-warning-line"></i> Cannot submit</div>
                                        @foreach (var reason in soloReasons)
                                        {
                                            <div class="wiz-next-tooltip-item"><i class="ri-close-circle-line"></i> @reason</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        }
                        else
                        {
                        @* ── Non-solo footer: Back, Cancel, Next ── *@
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                @onclick="() => { _importStep = 1; if (!_isSoloUser) _importPcId = 0; }">
                            <i class="ri-arrow-left-s-line"></i> Back
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CloseWizard">@LS.T("common.cancel")</button>
                        var step2Reasons = Step2DisabledReasons;
                        <div class="wiz-next-wrap">
                            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                    disabled="@(step2Reasons.Count > 0)"
                                    @onclick="GoToStep3">
                                Next <i class="ri-arrow-right-s-line"></i>
                            </button>
                            @if (step2Reasons.Count > 0)
                            {
                                <div class="wiz-next-hover-zone"></div>
                                <div class="wiz-next-tooltip">
                                    <div class="wiz-next-tooltip-title"><i class="ri-error-warning-line"></i> Cannot proceed</div>
                                    @{ var hasAnyAmPm = false; }
                                    @foreach (var reason in step2Reasons)
                                    {
                                        var isAmPm = reason.Contains("AM/PM");
                                        if (isAmPm) hasAnyAmPm = true;
                                        <div class="wiz-next-tooltip-item @(isAmPm ? "wiz-tooltip-ampm" : "")">
                                            <i class="@(isAmPm ? "ri-time-line" : "ri-close-circle-line")"></i>
                                            @reason
                                        </div>
                                    }
                                    @if (hasAnyAmPm)
                                    {
                                        <div class="wiz-tooltip-hint">
                                            <i class="ri-lightbulb-line"></i>
                                            Tip: Use 24-hour format — add 12 to PM hours (e.g. 2:32 PM → 14:32)
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex align-items-center w-100 gap-2 wiz-step3-footer">
                            <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                    @onclick="Step3Back">
                                <i class="ri-arrow-left-s-line"></i> Back
                            </button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CloseWizard">@LS.T("common.cancel")</button>
                            <div class="d-flex align-items-center gap-2 ms-auto wiz-admin-time-group">
                                <span style="font-weight:600; color:#cbd5e1; font-size:.85rem; white-space:nowrap;">
                                    Admin Time
                                    @if (string.IsNullOrWhiteSpace(_arfAdminTime))
                                    {
                                        <span style="color:#ef4444;font-weight:700;margin-left:2px;">*</span>
                                    }
                                </span>
                                <input type="text" inputmode="numeric" maxlength="5"
                                       class="form-control form-control-sm arf-time-input"
                                       style="width:72px; color:#e2e8f0; background:#1e293b; border-color:#475569; @(string.IsNullOrWhiteSpace(_arfAdminTime) ? "border:2px solid #ef4444 !important;background:rgba(239,68,68,.08) !important;" : "")"
                                       placeholder="H:MM"
                                       value="@_arfAdminTime"
                                       @oninput="e => _arfAdminTime = e.Value?.ToString() ?? string.Empty" />
                                <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                        disabled="@(string.IsNullOrWhiteSpace(_arfAdminTime))"
                                        @onclick="ExecuteImport">
                                    <i class="ri-upload-2-line"></i>
                                    Go
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Transfer Balance Modal ── *@
@if (_showTransfer)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.55); z-index:9999;">
        <div class="modal-dialog modal-dialog-centered modal-lg" @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#0f172a; color:#e2e8f0; border:1px solid #1e293b; border-radius:16px; overflow:hidden;">
                <div class="modal-header py-3 px-4" style="background:linear-gradient(135deg,#0c4a6e,#0ea5e9); border-bottom:none;">
                    <h5 class="modal-title text-white d-flex align-items-center gap-2" style="font-size:1.05rem; font-weight:700;">
                        <i class="ri-exchange-funds-line"></i>@LS.T("transfer.title")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showTransfer = false"></button>
                </div>
                <div class="modal-body px-4 py-3">

                    @* ── Split layout: FROM | ARROW | TO ── *@
                    <div class="xfer-split">
                        @* ── LEFT: FROM PC ── *@
                        <div class="xfer-card xfer-from">
                            <div class="xfer-card-label"><i class="ri-logout-box-r-line me-1"></i>@LS.T("transfer.fromPc")</div>
                            <select class="form-select form-select-sm xfer-select"
                                    value="@_xferFromPcId" @onchange="OnXferFromChanged">
                                <option value="0">— Select PC —</option>
                                @foreach (var pc in _xferPcList.Where(p => p.RemainHrs > 0))
                                {
                                    <option value="@pc.PcId">@pc.Name</option>
                                }
                            </select>

                            @if (_xferFromPcId > 0)
                            {
                                <div class="xfer-balance">
                                    <div class="xfer-balance-row">
                                        <span class="xfer-balance-label">Balance</span>
                                        <span class="xfer-balance-val" style="color:#38bdf8;">@_xferFromRemainHrs hrs</span>
                                    </div>
                                    <div class="xfer-balance-row">
                                        <span class="xfer-balance-label">Value</span>
                                        <span class="xfer-balance-val">@CurrSymbol@_xferFromRemainNis</span>
                                    </div>
                                    <div class="xfer-balance-row">
                                        <span class="xfer-balance-label">Rate</span>
                                        <span class="xfer-balance-val" style="color:#94a3b8;">@CurrSymbol@_xferFromRate/hr</span>
                                    </div>
                                </div>

                                <div class="xfer-input-group">
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="flex:1;">
                                            <label class="xfer-input-label">@LS.T("transfer.amount") (@CurrSymbol)</label>
                                            <input type="number" min="1" max="@_xferFromRemainNis"
                                                   class="form-control form-control-sm xfer-input"
                                                   value="@_xferAmount" @oninput="OnXferAmountChanged"
                                                   disabled="@_xferFullAmount"
                                                   style="@(_xferAmount > _xferFromRemainNis ? "border-color:#ef4444 !important;" : "")" />
                                        </div>
                                        <div style="padding-top:18px;">
                                            <label class="d-flex align-items-center gap-1" style="font-size:.72rem; color:#94a3b8; cursor:pointer; white-space:nowrap;">
                                                <input type="checkbox" class="form-check-input" style="margin-top:0;"
                                                       checked="@_xferFullAmount" @onchange="OnXferFullAmountChanged" />
                                                All
                                            </label>
                                        </div>
                                    </div>
                                    @if (_xferAmount > _xferFromRemainNis)
                                    {
                                        <div style="color:#ef4444; font-size:.7rem; margin-top:2px;">Max: @CurrSymbol@_xferFromRemainNis</div>
                                    }
                                </div>

                                @if (_xferAmount > 0 && _xferFromRate > 0)
                                {
                                    <div class="xfer-deduct-badge">
                                        <i class="ri-arrow-up-line me-1"></i>@LS.T("transfer.deductHours"):
                                        <strong>@_xferDeductHours.ToString("0.##") hrs</strong>
                                    </div>
                                }
                            }
                        </div>

                        @* ── CENTER: ARROW ── *@
                        <div class="xfer-arrow-wrap">
                            <div class="xfer-arrow @(_xferFromPcId > 0 && _xferToPcId > 0 && _xferAmount > 0 ? "xfer-arrow-active" : "")">
                                <i class="ri-arrow-right-line"></i>
                            </div>
                            @if (_xferAmount > 0)
                            {
                                <div class="xfer-arrow-amount">@CurrSymbol@_xferAmount</div>
                            }
                        </div>

                        @* ── RIGHT: TO PC ── *@
                        <div class="xfer-card xfer-to">
                            <div class="xfer-card-label"><i class="ri-login-box-line me-1"></i>@LS.T("transfer.toPc")</div>
                            <select class="form-select form-select-sm xfer-select"
                                    value="@_xferToPcId" @onchange="OnXferToChanged">
                                <option value="0">— Select PC —</option>
                                @foreach (var pc in _xferPcList.Where(p => p.PcId != _xferFromPcId))
                                {
                                    <option value="@pc.PcId">@pc.Name</option>
                                }
                            </select>

                            @if (_xferToPcId > 0 && _xferAmount > 0)
                            {
                                <div class="xfer-input-group" style="margin-top:16px;">
                                    <label class="xfer-input-label">@LS.T("transfer.addHours")</label>
                                    <input type="number" min="0.01" step="0.01"
                                           class="form-control form-control-sm xfer-input xfer-input-green"
                                           value="@_xferAddHours.ToString("0.##")" @oninput="OnXferAddHoursChanged" />
                                </div>

                                @if (_xferAddHours > 0)
                                {
                                    <div class="xfer-add-badge">
                                        <i class="ri-arrow-down-line me-1"></i>Receives
                                        <strong>@_xferAddHours.ToString("0.##") hrs</strong>
                                        <span style="color:#64748b; font-size:.7rem; margin-left:4px;">
                                            (@CurrSymbol@(_xferAddHours > 0 ? ((double)_xferAmount / _xferAddHours).ToString("0.##") : "0")/hr)
                                        </span>
                                    </div>
                                }
                            }
                        </div>
                    </div>

                    @* ── Messages ── *@
                    @if (!string.IsNullOrEmpty(_xferError))
                    {
                        <div class="alert alert-danger py-1 mt-3 mb-0" style="font-size:.8rem; border-radius:8px;">
                            <i class="ri-error-warning-line me-1"></i>@_xferError
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_xferSuccess))
                    {
                        <div class="xfer-success-banner mt-3 mb-0">
                            <i class="ri-check-double-line me-1"></i>@_xferSuccess
                        </div>
                    }
                </div>
                <div class="modal-footer py-2 px-4" style="border-color:#1e293b;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showTransfer = false">@LS.T("common.cancel")</button>
                    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                            style="min-width:120px; justify-content:center;"
                            disabled="@(_xferBusy || _xferFromPcId == 0 || _xferToPcId == 0 || _xferDeductHours <= 0 || _xferAddHours <= 0 || _xferAmount <= 0 || _xferAmount > _xferFromRemainNis || !string.IsNullOrEmpty(_xferSuccess))"
                            @onclick="ExecuteTransfer">
                        @if (_xferBusy) { <span class="spinner-border spinner-border-sm"></span> }
                        else { <i class="ri-exchange-funds-line me-1"></i> }
                        @LS.T("transfer.confirm")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Background Import Toast ── *@
@if (_bgImportRunning || _bgImportDone || !string.IsNullOrEmpty(_bgImportError))
{
    var _bgDoneCount  = _bgSteps.Count(s => s.Status == 2);
    var _bgTotalCount = _bgSteps.Count;
    var _bgPct        = _bgTotalCount > 0 ? (int)(_bgDoneCount * 100.0 / _bgTotalCount) : 0;

    <div style="position:fixed;bottom:24px;right:24px;z-index:99999;min-width:310px;max-width:390px;
                border-radius:14px;box-shadow:0 16px 48px rgba(0,0,0,.45);
                background:#0f172a;color:#f1f5f9;overflow:hidden;
                animation:bgImportSlideIn .3s cubic-bezier(.175,.885,.32,1.275) both;">
        <style>
            @@keyframes bgImportSlideIn { from{opacity:0;transform:translateY(24px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
            @@keyframes bgBarPulse { 0%,100%{opacity:1} 50%{opacity:.65} }
        </style>

        @* ── Header ── *@
        <div style="padding:13px 16px 11px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:10px;">
            @if (_bgImportRunning)
            {
                <span class="spinner-border spinner-border-sm flex-shrink-0" style="color:#60a5fa;width:15px;height:15px;border-width:2px;"></span>
            }
            else if (_bgImportDone)
            {
                <i class="ri-checkbox-circle-fill flex-shrink-0" style="font-size:1.15rem;color:#22c55e;line-height:1;"></i>
            }
            else
            {
                <i class="ri-error-warning-fill flex-shrink-0" style="font-size:1.15rem;color:#f87171;line-height:1;"></i>
            }
            <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:.875rem;letter-spacing:.01em;line-height:1.3;">
                    @if (_bgImportRunning)      { <text>Uploading Session&hellip;</text> }
                    else if (_bgImportDone)     { <span style="color:#22c55e;">Session Imported!</span> }
                    else                        { <span style="color:#f87171;">Import Failed</span> }
                </div>
                <div style="font-size:.71rem;color:#475569;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@_bgImportLabel">
                    @_bgImportLabel
                </div>
            </div>
        </div>

        @* ── Step list (running or done) ── *@
        @if (_bgImportRunning || _bgImportDone)
        {
            <div style="padding:10px 16px 4px;display:flex;flex-direction:column;gap:5px;">
                @foreach (var _bgStep in _bgSteps)
                {
                    var _sc = _bgStep.Status switch {
                        1 => "#e2e8f0",
                        2 => "#22c55e",
                        3 => "#f87171",
                        _ => "#334155"
                    };
                    <div style="display:flex;align-items:flex-start;gap:8px;font-size:.78rem;color:@_sc;">
                        <span style="width:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding-top:1px;">
                            @if (_bgStep.Status == 1)
                            {
                                <span class="spinner-border" style="width:10px;height:10px;border-width:1.5px;color:#60a5fa;flex-shrink:0;"></span>
                            }
                            else if (_bgStep.Status == 2)
                            {
                                <i class="ri-check-line" style="color:#22c55e;font-size:.8rem;"></i>
                            }
                            else if (_bgStep.Status == 3)
                            {
                                <i class="ri-close-line" style="color:#f87171;font-size:.8rem;"></i>
                            }
                            else
                            {
                                <span style="width:5px;height:5px;border-radius:50%;background:#1e293b;display:inline-block;"></span>
                            }
                        </span>
                        <div>
                            <div style="@(_bgStep.Status == 1 ? "font-weight:600;" : "")">@_bgStep.Label</div>
                            @if (!string.IsNullOrEmpty(_bgStep.SubLabel))
                            {
                                <div style="font-size:.7rem;color:@(_bgStep.Status == 3 ? "#f87171" : "#64748b");margin-top:1px;font-variant-numeric:tabular-nums;">@_bgStep.SubLabel</div>
                            }
                        </div>
                    </div>
                }
            </div>

            @* ── Progress bar ── *@
            <div style="margin:10px 16px 14px;height:3px;background:#1e293b;border-radius:2px;overflow:hidden;">
                <div style="height:100%;width:@(_bgPct)%;border-radius:2px;
                            background:linear-gradient(90deg,#2563eb,#60a5fa);
                            transition:width .35s ease;
                            @(_bgImportRunning && _bgPct < 100 ? "animation:bgBarPulse 1.8s ease-in-out infinite;" : "")"></div>
            </div>
        }
        else
        {
            @* ── Error detail ── *@
            <div style="padding:10px 16px 14px;">
                @if (_bgSteps.Any(s => s.Status == 3))
                {
                    <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:8px;">
                        @foreach (var _bgStep in _bgSteps)
                        {
                            var _sc2 = _bgStep.Status switch { 2 => "#22c55e", 3 => "#f87171", 1 => "#60a5fa", _ => "#334155" };
                            <div style="display:flex;align-items:center;gap:8px;font-size:.77rem;color:@_sc2;">
                                <span style="width:14px;flex-shrink:0;text-align:center;">
                                    @if (_bgStep.Status == 2) { <i class="ri-check-line"></i> }
                                    else if (_bgStep.Status == 3) { <i class="ri-close-line"></i> }
                                    else { <span style="opacity:.4;">·</span> }
                                </span>
                                @_bgStep.Label
                            </div>
                        }
                    </div>
                }
                <div style="font-size:.75rem;color:#94a3b8;word-break:break-all;">@_bgImportError</div>
                <button class="btn btn-sm btn-outline-secondary mt-2" style="font-size:.72rem;padding:2px 10px;"
                        @onclick="() => { _bgImportError = string.Empty; _bgSteps.Clear(); }">@LS.T("common.dismiss")</button>
            </div>
        }
    </div>
}

@* ── Add Memo Wizard ── *@
@if (_showMemoWizard)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;">
        <div class="modal-dialog modal-dialog-centered @(_memoStep == 2 ? "modal-lg" : "modal-md")"
             @onclick:stopPropagation="true">
            <div class="modal-content memo-modal-content">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#be185d,#ec4899); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-sticky-note-line"></i>@LS.T("actions.addMemo")
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showMemoWizard = false"></button>
                </div>
                <div class="modal-body">

                    @* ── Stepper ── *@
                    <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
                        <div class="wiz-stepper">
                            @{
                                var memoStepLabels = new[] { LS.T("actions.choosePcStep"), LS.T("actions.writeMemoStep") };
                            }
                            @for (int s = 1; s <= 2; s++)
                            {
                                var sn  = s;
                                var lbl = memoStepLabels[sn - 1];
                                var isDone   = _memoStep > sn;
                                var isActive = _memoStep == sn;
                                var cls = isActive ? "wiz-active" : isDone ? "wiz-done" : "wiz-future";
                                <div class="wiz-step @cls">
                                    <div class="wiz-circle">
                                        @if (isDone) { <i class="ri-check-line"></i> }
                                        else { @sn }
                                    </div>
                                    <div class="wiz-label">@lbl</div>
                                </div>
                                @if (sn < 2)
                                {
                                    <div class="wiz-conn @(isDone ? "wiz-conn-done" : "")"></div>
                                }
                            }
                        </div>
                    </div>

                    @if (_memoStep == 1)
                    {
                        @* ── Step 1: Choose PC ── *@
                        @if (!_isSoloUser && _memoPcs.Count == 0)
                        {
                            <div class="act-noperm-screen" style="padding:28px 16px 20px;">
                                <div class="act-noperm-icon-wrap">
                                    <div class="act-noperm-ring" style="border-color:rgba(220,38,38,.25);"></div>
                                    <i class="ri-lock-line act-noperm-icon"></i>
                                </div>
                                <div class="act-noperm-title" style="color:#e2e8f0;">@LS.T("actions.noFoldersAssigned")</div>
                                <div class="act-noperm-sub" style="color:#94a3b8;">@LS.T("actions.noFoldersMsg")<br>@LS.T("actions.contactAdmin")</div>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                                @if (_isSoloUser)
                                {
                                    <div class="form-control form-control-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;">
                                        @(_memoPcs.FirstOrDefault(p => p.PcId == _memoPcId)?.FullName ?? "Solo")
                                        <span class="badge bg-primary ms-2" style="font-size:.7rem;">Solo</span>
                                    </div>
                                }
                                else
                                {
                                    <input type="text" class="form-control form-control-sm mb-2" placeholder="@LS.T("actions.searchPcs")"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                           @bind="_memoPcSearch" @bind:event="oninput" />
                                    <div style="max-height:240px; overflow-y:auto;">
                                        @foreach (var pc in _memoPcs.Where(p => string.IsNullOrEmpty(_memoPcSearch) || p.FullName.Contains(_memoPcSearch, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            var thisPc = pc;
                                            @if (!(_isSoloUser && thisPc.IsAlsoSolo))
                                            {
                                                <div class="memo-pc-item @(_memoPcId == thisPc.PcId && !_memoSolo ? "memo-pc-sel" : "")"
                                                     @onclick="() => { _memoPcId = thisPc.PcId; _memoSolo = false; MemoNext(); }">
                                                    <i class="ri-user-line" style="color:#60a5fa; opacity:.7;"></i>
                                                    <span>@thisPc.FullName</span>
                                                </div>
                                            }
                                            @if (thisPc.IsAlsoSolo)
                                            {
                                                <div class="memo-pc-item @(_memoPcId == thisPc.PcId && _memoSolo ? "memo-pc-sel" : "")"
                                                     @onclick="() => { _memoPcId = thisPc.PcId; _memoSolo = true; MemoNext(); }">
                                                    <i class="ri-user-line" style="color:#ef4444; opacity:.7;"></i>
                                                    <span>@thisPc.FullName</span>
                                                    <span style="font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
                                                                 color:#fff; background:linear-gradient(135deg,#ef4444,#b91c1c);
                                                                 border-radius:999px; padding:2px 8px; margin-left:4px;">Solo</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else if (_memoScanBoxAnim)
                    {
                        @* ── ScanBox success animation ── *@
                        <div class="scanbox-success-screen">
                            <div class="scanbox-ripple"></div>
                            <div class="scanbox-icon-wrap">
                                <i class="ri-file-download-line scanbox-file-icon"></i>
                                <i class="ri-checkbox-circle-fill scanbox-check-icon"></i>
                            </div>
                            <div class="scanbox-msg">File imported from ScanBox</div>
                            <div class="scanbox-sub">@_memoScanBoxFileName</div>
                        </div>
                    }
                    else
                    {
                        @* ── Step 2: Write Memo ── *@
                        <div class="mb-2 d-flex align-items-center gap-2">
                            <label style="font-size:.82rem; color:#94a3b8; white-space:nowrap;">Date</label>
                            <input type="date" class="form-control form-control-sm"
                                   style="width:160px; background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                   value="@_memoDate.ToString("yyyy-MM-dd")"
                                   @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _memoDate = d; }" />
                        </div>
                        <div class="mb-2 d-flex align-items-center gap-2">
                            <label style="font-size:.82rem; color:#94a3b8; white-space:nowrap;">Name</label>
                            <div class="d-flex align-items-center gap-1" style="flex:1; min-width:0;">
                                <span style="font-size:.78rem; color:#64748b; white-space:nowrap;">@_memoDate.ToString("yyMMdd")</span>
                                <input type="text" class="form-control form-control-sm"
                                       style="background:#0f172a; color:#e2e8f0; border-color:#475569; flex:1;"
                                       placeholder="e.g. progress update"
                                       @bind="_memoFileName" @bind:event="oninput" />
                                @{ var _memoPreviewName = BuildMemoFileName(_memoDate, _memoFileName); }
                            </div>
                        </div>
                        <div style="font-size:.7rem; color:#64748b; margin:-4px 0 8px 52px;">
                            File will be saved as: <span style="color:#94a3b8; font-weight:600;">@(_memoPreviewName).pdf</span>
                        </div>
                        <div class="mb-1" id="memo-quill-wrap">
                            <label class="form-label" style="font-size:.82rem; color:#94a3b8;">@LS.T("actions.memoText")</label>
                            <div id="memo-quill-editor"
                                 style="background:#fff; color:#000; min-height:260px; border-radius:0 0 4px 4px;">
                            </div>
                        </div>
                        <div style="font-size:.72rem; color:#64748b; margin-top:6px;">
                            <i class="ri-information-line me-1"></i>
                            @LS.T("actions.memoSaveNote")
                        </div>
                        @if (!string.IsNullOrEmpty(_memoScanBoxError))
                        {
                            <div class="alert alert-warning d-flex align-items-center gap-2 mt-2 mb-0 py-2" style="font-size:.82rem;">
                                <i class="ri-inbox-archive-line"></i>@_memoScanBoxError
                            </div>
                        }
                    }

                </div>
                <div class="modal-footer" style="background:#0f172a; border-top:1px solid #1e293b;">
                    @if (_memoStep == 1)
                    {
                        <button class="btn btn-sm btn-outline-light" @onclick="() => _showMemoWizard = false">@LS.T("common.cancel")</button>
                    }
                    else if (!_memoScanBoxAnim)
                    {
                        <button class="btn btn-sm btn-outline-light d-flex align-items-center gap-1"
                                @onclick="() => _memoStep = 1">
                            <i class="ri-arrow-left-s-line"></i> Back
                        </button>
                        <button class="btn btn-sm d-flex align-items-center gap-1"
                                style="background:linear-gradient(135deg,#0ea5e9,#6366f1); color:#fff; border:none;"
                                @onclick="ExecuteMemoFromScanBox">
                            <i class="ri-inbox-archive-line me-1"></i>Import from ScanBox
                        </button>
                        <button class="btn btn-sm btn-outline-light" @onclick="() => _showMemoWizard = false">@LS.T("common.cancel")</button>
                        <button class="btn btn-sm d-flex align-items-center gap-1"
                                style="background:linear-gradient(135deg,#be185d,#ec4899); color:#fff; border:none;"
                                @onclick="ExecuteMemo">
                            <i class="ri-sticky-note-line"></i>Submit
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════════ *@
@* ── Add Next C/S Wizard ── *@
@* ══════════════════════════════════════════════════════════════════════ *@
@if (_showNcWizard)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable @(_ncStep == 2 ? "modal-lg" : "modal-md")"
             @onclick:stopPropagation="true">
            <div class="modal-content memo-modal-content">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#0d9488,#14b8a6); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-user-follow-line"></i>Add Next C/S
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showNcWizard = false"></button>
                </div>
                <div class="modal-body">

                    @* ── Stepper ── *@
                    <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
                        <div class="wiz-stepper">
                            @{
                                var ncStepLabels = new[] { "Choose PC", "Next C/S" };
                            }
                            @for (int s = 1; s <= 2; s++)
                            {
                                var sn  = s;
                                var lbl = ncStepLabels[sn - 1];
                                var isDone   = _ncStep > sn;
                                var isActive = _ncStep == sn;
                                var cls = isActive ? "wiz-active" : isDone ? "wiz-done" : "wiz-future";
                                <div class="wiz-step @cls">
                                    <div class="wiz-circle">
                                        @if (isDone) { <i class="ri-check-line"></i> }
                                        else { @sn }
                                    </div>
                                    <div class="wiz-label">@lbl</div>
                                </div>
                                @if (sn < 2)
                                {
                                    <div class="wiz-conn @(isDone ? "wiz-conn-done" : "")"></div>
                                }
                            }
                        </div>
                    </div>

                    @if (_ncStep == 1)
                    {
                        @* ── Step 1: Choose PC ── *@
                        @if (!_isSoloUser && _ncPcs.Count == 0)
                        {
                            <div class="act-noperm-screen" style="padding:28px 16px 20px;">
                                <div class="act-noperm-icon-wrap">
                                    <div class="act-noperm-ring" style="border-color:rgba(220,38,38,.25);"></div>
                                    <i class="ri-lock-line act-noperm-icon"></i>
                                </div>
                                <div class="act-noperm-title" style="color:#e2e8f0;">@LS.T("actions.noFoldersAssigned")</div>
                                <div class="act-noperm-sub" style="color:#94a3b8;">@LS.T("actions.noFoldersMsg")<br>@LS.T("actions.contactAdmin")</div>
                            </div>
