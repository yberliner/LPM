    RenderFragment RenderFhTree(List<FolderTreeNode> nodes, int depth) => __builder =>
    {
        foreach (var node in nodes)
        {
            if (node.IsFolder)
            {
                <div style="padding-left:@(depth * 16)px;padding:2px 0;">
                    <i class="ri-folder-line" style="color:#f59e0b;font-size:.7rem;"></i>
                    <span style="font-size:.78rem;color:#94a3b8;font-weight:600;">@node.Name</span>
                </div>
                @RenderFhTree(node.Children, depth + 1)
            }
            else
            {
                var nodeStats = _fhAuditStats.GetValueOrDefault(node.RelativePath);
                <div class="fh-file-item" style="padding-left:@(depth * 16 + 4)px;" @onclick="() => FhSelectFile(node.RelativePath)">
                    <i class="ri-file-pdf-2-line" style="color:#ef5350;font-size:.7rem;"></i>
                    <span style="font-size:.8rem;">@node.Name</span>
                    @if (nodeStats != null)
                    {
                        <span class="fh-stats-badge">@nodeStats.Count</span>
                        <span class="fh-stats-date">@nodeStats.LastChange</span>
                    }
                </div>
            }
        }
    };

