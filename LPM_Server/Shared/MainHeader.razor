                    });
                    window[key] = q;
                    var defColor = _defaultColors[id];
                    if (defColor) {
                        q.format('color', defColor);
                        q.on('selection-change', function(range) {
                            if (range && range.length === 0) {
                                var fmt = q.getFormat(range.index);
                                if (!fmt.color) q.format('color', defColor, 'silent');
                            }
                        });
                        q.on('text-change', function() {
                            var sel = q.getSelection();
                            if (sel) {
                                var fmt = q.getFormat(sel.index);
                                if (!fmt.color) q.format('color', defColor, 'silent');
                            }
                        });
                    }
                });
            ");
            if (isFirstVisit)
            {
                if (!string.IsNullOrWhiteSpace(prevNextCs))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_nc-bottom-editor']; if(q){{ q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(prevNextCs)}; setTimeout(function(){{ q.formatText(0, q.getLength(), 'color', '#2563eb'); q.setSelection(q.getLength(),0); }}, 50); }}");
                }
            }
            else
            {
                if (!string.IsNullOrEmpty(restoreTop))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_nc-top-editor']; if(q) q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(restoreTop)};");
                }
                if (!string.IsNullOrEmpty(restoreBot))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_nc-bottom-editor']; if(q) q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(restoreBot)};");
                }
            }
        });
    }

    async Task NcBack()
    {
        await ReadNcHtml();
        _ncStep = 1;
    }

    async Task ReadNcHtml()
    {
        var top = await JSRuntime.InvokeAsync<string>("eval",
            "window['_quill_nc-top-editor'] ? window['_quill_nc-top-editor'].root.innerHTML : ''");
        _ncTopHtml = (top == "<p><br></p>" || string.IsNullOrWhiteSpace(top)) ? "" : top;

        var bot = await JSRuntime.InvokeAsync<string>("eval",
            "window['_quill_nc-bottom-editor'] ? window['_quill_nc-bottom-editor'].root.innerHTML : ''");
        _ncBottomHtml = (bot == "<p><br></p>" || string.IsNullOrWhiteSpace(bot)) ? "" : bot;
    }

    async Task ExecuteNc()
    {
        await ReadNcHtml();

        var capturedPcId        = _ncPcId;
        var capturedSolo        = _ncSolo || _isSoloUser;
        var capturedAudId       = _msgUserId!.Value;
        var capturedPcName      = _ncPcs.FirstOrDefault(p => p.PcId == _ncPcId)?.FullName ?? "";
        var capturedDate        = _ncDate;
        var capturedDateStr     = _ncDate.ToString("dd/MM/yy");
        var capturedFileName    = _ncDate.ToString("yyMMdd") + " Next CS";
        var capturedAuditorName = _ncAuditorName;
        var capturedTopHtml     = _ncTopHtml;
        var capturedBottomHtml  = _ncBottomHtml;

        _showNcWizard = false;
        _ncRunning    = true;
        _ncDone       = false;
        _ncError      = "";
        _ncLabel      = capturedSolo ? $"{capturedPcName} [Solo]" : capturedPcName;
        _ncSteps = new List<BgStep>
        {
            new("Generating Next C/S PDF"),
            new("Saving to WorkSheets"),
            new("Adding session entry"),
        };
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                var sGen  = _ncSteps[0];
                var sSave = _ncSteps[1];
                var sDb   = _ncSteps[2];

                // Step 1: Generate PDF
                sGen.Status = 1;
                await InvokeAsync(StateHasChanged);
                string? footer = capturedSolo ? DashSvc.GetCsNameForPc(capturedPcId) : null;
                var pdfBytes = PdfSvc.GenerateNextCsPdf(
                    capturedPcName, capturedDateStr,
                    capturedAuditorName, capturedTopHtml, capturedBottomHtml,
                    footerName: footer);
                sGen.Status = 2;
                await InvokeAsync(StateHasChanged);

                // Step 2: Save to WorkSheets
                sSave.Status = 1;
                await InvokeAsync(StateHasChanged);
                var savedName = await Task.Run(() =>
                    FolderSvc.SaveMemoFile(capturedPcId, capturedFileName, pdfBytes, capturedSolo));
                sSave.Status = 2;
                await InvokeAsync(StateHasChanged);

                // Step 3: Add session entry + save Next CS to DB
                sDb.Status = 1;
                await InvokeAsync(StateHasChanged);
                var sessionId = DashSvc.AddMemoSession(capturedAudId, capturedPcId, savedName, capturedDate, capturedSolo);
                if (!string.IsNullOrWhiteSpace(capturedBottomHtml))
                    DashSvc.SaveNextCs(sessionId, capturedBottomHtml);
                DashSvc.NotifyDataChanged();
                sDb.Status = 2;
                await InvokeAsync(StateHasChanged);

                await InvokeAsync(() =>
                {
                    _ncRunning = false;
                    _ncDone    = true;
                    StateHasChanged();
                });

                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    _ncDone = false;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                foreach (var s in _ncSteps.Where(s => s.Status == 1))
                    s.Status = 3;
                await InvokeAsync(() =>
                {
                    _ncRunning = false;
                    _ncError   = ex.Message;
                    StateHasChanged();
                });
            }
        });
    }

    // ── Show Stat ────────────────────────────────────────────────────────────

    async Task OpenShowStat()
    {
        _statStaffList = DashSvc.GetNonSoloStaffWithRoles()
            .Where(s => !s.FullName.Equals("BBB", StringComparison.OrdinalIgnoreCase))
            .ToList();
        _statWeekStart = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today)).AddDays(-7);
        _statSelectedId = _statStaffList.FirstOrDefault()?.PersonId ?? 0;
        _statPdfBase64 = null;
        _statPdfUrl = null;
        _statSidebarOpen = true;
        _statCache = new();
        _showStat = true;
        StateHasChanged();
        await GenerateAllStatPdfs();
    }

    async Task CloseShowStat()
    {
        _showStat = false;
        _statPdfUrl = null;
        _statPdfBase64 = null;
        _statCache = new();
        try { await JSRuntime.InvokeVoidAsync("clearPdfCache"); } catch { }
    }

    async Task SelectStatUser(int personId)
    {
        if (personId == _statSelectedId) return;
        _statSelectedId = personId;
        if (_statCache.TryGetValue(personId, out var cached))
        {
            _statPdfUrl = cached.Url;
            _statPdfBase64 = cached.Base64;
            _statBusy = false;
            StateHasChanged();
            await JSRuntime.InvokeVoidAsync("showPdfFromUrl", "stat-pdf-viewer", cached.Url);
        }
    }

    async Task StatWeekPrev()
    {
        _statCacheCancelled = true; // stop current build
        _statWeekStart = _statWeekStart.AddDays(-7);
        await RestartStatCache();
    }

    bool StatIsCurrentWeek => _statWeekStart >= DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));

    async Task StatWeekToday()
    {
        if (StatIsCurrentWeek) return;
        _statCacheCancelled = true;
        _statWeekStart = DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today));
        await RestartStatCache();
    }

    async Task StatWeekNext()
    {
        if (StatIsCurrentWeek) return;
        _statCacheCancelled = true;
        _statWeekStart = _statWeekStart.AddDays(7);
        await RestartStatCache();
    }

    async Task RestartStatCache()
    {
        // Wait for running loop to notice the cancel flag
        while (_statCaching) await Task.Delay(50);
        _statCache = new();
        _statPdfUrl = null;
        _statPdfBase64 = null;
        await JSRuntime.InvokeVoidAsync("clearPdfCache");
        StateHasChanged();
        await GenerateAllStatPdfs();
    }

    async Task GenerateAllStatPdfs()
    {
        _statCacheCancelled = false;
        _statCaching = true;
        _statBusy = true;
        _statCacheProgress = 0;
        _statCacheTotal = _statStaffList.Count;
        StateHasChanged();

        var weekStart = _statWeekStart;
        var soloPcIds = DashSvc.GetSoloPcIds();
        var tempDir = Path.Combine("wwwroot", "temp");
        Directory.CreateDirectory(tempDir);
        foreach (var old in Directory.GetFiles(tempDir, "stat_*.pdf"))
            try { File.Delete(old); } catch { }

        // Generate ALL PDFs in parallel
        var tasks = _statStaffList.Select(staff => Task.Run(() =>
        {
            var sid = staff.PersonId;
            var pcs = DashSvc.GetUserPcs(sid);
            var grid = DashSvc.GetWeekGrid(sid, weekStart, pcs);
            var pcIds = pcs.Select(p => p.PcId).ToList();
            var csNames = DashSvc.GetLastCsNamesByPc(pcIds);
            var weekKey = weekStart.ToString("yyyy-MM-dd");
            var remarks = DashSvc.GetWeeklyRemarks(sid, weekKey);
            var completions = CompletionSvc.GetForWeek(sid, weekStart, weekStart.AddDays(6));
            var pdfBytes = PdfSvc.GenerateWeeklyTablePdf(staff.FullName, weekStart, pcs, grid, csNames, remarks, soloPcIds, completions);
            var fileName = $"stat_{sid}_{weekStart:yyyyMMdd}.pdf";
            File.WriteAllBytes(Path.Combine(tempDir, fileName), pdfBytes);
            return (sid, fileName, pdfBytes);
        })).ToList();

        // Process each as it completes
        while (tasks.Count > 0)
        {
            var completed = await Task.WhenAny(tasks);
            tasks.Remove(completed);
            if (_statCacheCancelled || !_showStat || _isDisposed) break;

            var (sid, fileName, pdfBytes) = await completed;
            var url = $"/temp/{fileName}?t={DateTime.Now.Ticks}";
            var b64 = Convert.ToBase64String(pdfBytes);
            _statCache[sid] = (url, b64);
            _statCacheProgress++;

            if (sid == _statSelectedId)
            {
                _statPdfUrl = url;
                _statPdfBase64 = b64;
                _statBusy = false;
                await InvokeAsync(StateHasChanged);
                await JSRuntime.InvokeVoidAsync("showPdfFromUrl", "stat-pdf-viewer", url);
            }
            else
            {
                await InvokeAsync(StateHasChanged);
            }
        }

        // Pre-render canvases sequentially (JS is single-threaded)
        if (!_statCacheCancelled && _showStat && !_isDisposed)
        {
            foreach (var kv in _statCache)
            {
                if (_statCacheCancelled || !_showStat || _isDisposed) break;
                if (kv.Key != _statSelectedId)
                    await JSRuntime.InvokeVoidAsync("preRenderPdf", kv.Value.Url);
            }
        }

        _statCaching = false;
        _statBusy = false;
        await InvokeAsync(StateHasChanged);
    }

