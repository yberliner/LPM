    async Task ApcTogglePcRole(int pcId, string workCapacity, bool currentlyActive)
    {
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        if (currentlyActive)
        {
            // Don't allow removing the last role — use the delete button for that
            var rolesForPc = _apcMyPcs.Count(p => p.PcId == pcId);
            if (rolesForPc <= 1)
            {
                Console.WriteLine($"[MainHeader] Assign PC: blocked removing last role '{workCapacity}' from PC='{pcName}' (use delete button instead)");
                return;
            }
            DashSvc.RemoveUserPc(_apcUserId, pcId, workCapacity);
            Console.WriteLine($"[MainHeader] Assign PC: removed role '{workCapacity}' from PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        }
        else
        {
            DashSvc.AddUserPc(_apcUserId, pcId, workCapacity);
            DashSvc.CheckOrRequestPermission(_apcUserId, pcId, _logUsername);
            Console.WriteLine($"[MainHeader] Assign PC: added role '{workCapacity}' to PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        }
        ApcRefreshData();
        DashSvc.NotifyDataChanged();
        await InvokeAsync(StateHasChanged);
    }

    async Task ApcRemovePcAllRoles(int pcId)
    {
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        var roles = string.Join(", ", _apcMyPcs.Where(p => p.PcId == pcId).Select(p => p.WorkCapacity));
        foreach (var pc in _apcMyPcs.Where(p => p.PcId == pcId).ToList())
            DashSvc.RemoveUserPc(_apcUserId, pcId, pc.WorkCapacity);
        Console.WriteLine($"[MainHeader] Assign PC: removed all roles ({roles}) from PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        ApcRefreshData();
        DashSvc.NotifyDataChanged();
        await InvokeAsync(StateHasChanged);
    }

