                // Step 2: Insert session row
                sDb.Status = 1;
                await InvokeAsync(StateHasChanged);
                DashSvc.AddMemoSession(capturedAudId, capturedPcId, savedName, capturedDate, capturedSolo);
                DashSvc.NotifyDataChanged();
                sDb.Status = 2;
                await InvokeAsync(StateHasChanged);

                // Step 3: Clear ScanBox
                sClr.Status = 1;
                await InvokeAsync(StateHasChanged);
                FolderSvc.ClearScanInbox(_logUsername);
                sClr.Status = 2;
                await InvokeAsync(StateHasChanged);

                await InvokeAsync(() =>
                {
                    _memoRunning = false;
                    _memoDone    = true;
                    StateHasChanged();
                });

                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    _memoDone = false;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                foreach (var s in _memoSteps.Where(s => s.Status == 1))
                    s.Status = 3;
                await InvokeAsync(() =>
                {
                    _memoRunning = false;
                    _memoError   = ex.Message;
                    StateHasChanged();
                });
            }
        });
