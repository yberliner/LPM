<SpkScheduleMeetingModal @ref="_meetingModal" OnSaved="StateHasChanged" />

@code {
    private bool _isDisposed = false;
    private string _displayName = "";
    private string _logUsername = "";
    private string? _avatarUrl;
    private bool _isSoloUser;   // true when logged-in user has StaffRole = "Solo"

    // ── Add PC state ──
    SpkNewPersonModal _addPcModal = default!;
    HashSet<string>? _existingPcNames;

    // ── Add Session state ──
    bool _showImportWizard;
    int  _importStep = 1;      // 1 = file upload, 2 = examiner worksheet
    int  _importPcId;
    IBrowserFile? _importSessionFile;
    byte[]? _importSessionBytes;
    string _importSessionFileName = "";
    List<IBrowserFile> _importAttachments = [];
    List<(string Name, byte[] Data)> _importAttachmentBytes = [];
    List<DashboardService.ApprovedPc> _approvedPcs = [];
    bool   _importBusy;
    bool   _importDuplicate;
    bool   _importFreeSession;
    string _importFileWarning = "";  // duplicate or _att_ warning
    string _importError   = "";
    string _importSuccess = "";

    // Background import toast state
    bool   _bgImportRunning;
    bool   _bgImportDone;
    string _bgImportError   = "";
    string _bgImportLabel   = "";

    // Auditor Report Form fields (step 2)
    string _arfDate          = "";
    string _arfGrade         = "";
    string _arfSessionLength = "";  // read-only, calculated
    string _arfAdminTime     = "";
    string _arfTotalTa       = "";
    string _arfTaRangeFrom   = "";
    string _arfTaRangeTo     = "";
    string _arfExamReport    = "F/N";
    string _arfSummary       = "";
    List<ArfRow> _arfRows    = [new()];

    class ArfRow
    {
        public bool   Checked       = true;
        public bool   AutoUnchecked = false;
        public string Process       = "";
        public string Time          = "";
        public string ToneArm       = "";
        public string Results       = "";
    }

    static bool HasAutoUncheckKeyword(string text) =>
        System.Text.RegularExpressions.Regex.IsMatch(
            text ?? "", @"\b(TITS|EOS)\b",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

    static string FilterNumericDot(string? raw) =>
        new string((raw ?? "").Where(c => char.IsDigit(c) || c == '.').ToArray());

    async Task SetTaRangeFrom(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        _arfTaRangeFrom = FilterNumericDot(raw);
        if (_arfTaRangeFrom != raw)
            await JSRuntime.InvokeVoidAsync("eval",
                $"var el=document.getElementById('arf-ta-from');if(el)el.value={System.Text.Json.JsonSerializer.Serialize(_arfTaRangeFrom)};");
    }
    async Task SetTaRangeTo(ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        _arfTaRangeTo = FilterNumericDot(raw);
        if (_arfTaRangeTo != raw)
            await JSRuntime.InvokeVoidAsync("eval",
                $"var el=document.getElementById('arf-ta-to');if(el)el.value={System.Text.Json.JsonSerializer.Serialize(_arfTaRangeTo)};");
    }

    bool CanAddArfRow => _arfRows.Count == 0 || _arfRows.All(r =>
        !string.IsNullOrWhiteSpace(r.Process) &&
        IsValidArfTime(r.Time) && !string.IsNullOrWhiteSpace(r.Time));

    void AddArfRow() { if (CanAddArfRow) { _arfRows.Add(new ArfRow()); RebuildArfSummary(); } }
    void RemoveArfRow(int idx) { if (_arfRows.Count > 1) { _arfRows.RemoveAt(idx); RecalcSessionLength(); RebuildArfSummary(); } }

    void RebuildArfSummary(bool pushToEditor = true)
    {
        var lines = _arfRows
            .Where(r => r.Checked && !string.IsNullOrWhiteSpace(r.Process))
            .Select(r =>
            {
                var proc = System.Net.WebUtility.HtmlEncode(r.Process.Trim());
                var res  = System.Net.WebUtility.HtmlEncode(r.Results.Trim());
                return string.IsNullOrWhiteSpace(res) ? proc : $"{proc} TO {res}";
            })
            .ToList();

        var examColor = _arfExamReport switch {
            "F/N" => "#16a34a",
            "RT"  => "#dc2626",
            "YT"  => "#ca8a04",
            "PT"  => "#db2777",
            _     => "#64748b"
        };
        lines.Add($"<span style=\"color:{examColor};\">Exam report: {System.Net.WebUtility.HtmlEncode(_arfExamReport)}</span>");

        _arfSummary = string.Join("", lines.Select(l => $"<p style=\"margin:0;line-height:1.35;\">{l}</p>"));
        if (pushToEditor)
        {
            _ = JSRuntime.InvokeVoidAsync("eval",
                $"if(window._arfQuill) window._arfQuill.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(_arfSummary)};");
        }
    }

    async Task ReadArfSummaryFromEditor()
    {
        var html = await JSRuntime.InvokeAsync<string>("eval",
            "window._arfQuill ? window._arfQuill.root.innerHTML : ''");
        _arfSummary = (html == "<p><br></p>" || string.IsNullOrWhiteSpace(html)) ? "" : html;
        Console.WriteLine($"[ARF] Summary HTML read from editor: {_arfSummary}");
    }

    // Strip everything except digits and '.' — user literally cannot enter letters
    string FilterNumeric(string? val)
    {
        if (string.IsNullOrEmpty(val)) return "";
        var sb = new System.Text.StringBuilder();
        bool hasDot = false;
        foreach (var c in val)
        {
            if (char.IsDigit(c)) sb.Append(c);
            else if (c == '.' && !hasDot) { sb.Append(c); hasDot = true; }
        }
        return sb.ToString();
    }

    // Auto-format time: "2347" → "23:47", "947" → "9:47", "23:47" stays
    void SetArfTimeCell(int idx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim() ?? "";
        _arfRows[idx].Time = FormatArfTime(raw);
        RecalcSessionLength();
        RebuildArfSummary();
    }

    void RecalcSessionLength()
    {
        _arfSessionLength = "";
        var validRows = _arfRows.Where(r => ArfTimeToMinutes(r.Time) >= 0).ToList();
        if (validRows.Count < 2) return;
        var first = ArfTimeToMinutes(validRows[0].Time);
        var last = ArfTimeToMinutes(validRows[^1].Time);
        var diff = last - first;
        if (diff < 0) return;
        _arfSessionLength = $"{diff / 60}:{diff % 60:D2}";
    }

    string FormatArfTime(string raw)
    {
        if (string.IsNullOrEmpty(raw)) return "";
        if (raw.Contains(':')) return raw;
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (digits.Length == 0) return "";
        if (digits.Length <= 2)  // 1-2 digits = minutes → "0:MM"
        {
            var m = int.Parse(digits);
            return $"0:{m:D2}";
        }
        if (digits.Length == 3) return digits[..1] + ":" + digits[1..];
        if (digits.Length >= 4) return digits[..^2] + ":" + digits[^2..];
        return raw;
    }

    bool IsValidArfTime(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return true;
        var parts = val.Split(':');
        if (parts.Length != 2) return false;
        if (!int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return false;
        return h >= 0 && h <= 23 && m >= 0 && m <= 59;
    }

    int ArfTimeToMinutes(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return -1;
        var parts = val.Split(':');
        if (parts.Length != 2 || !int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return -1;
        return h * 60 + m;
    }

    bool IsArfTimeOrdered(int idx)
    {
        if (idx == 0) return true;
        var cur = ArfTimeToMinutes(_arfRows[idx].Time);
        var prev = ArfTimeToMinutes(_arfRows[idx - 1].Time);
        if (cur < 0 || prev < 0) return true; // don't flag if either is empty/invalid
        return cur >= prev;
    }

    bool ArfHasTimeErrors => _arfRows.Select((_, i) => i).Any(i =>
        (!IsValidArfTime(_arfRows[i].Time) && !string.IsNullOrWhiteSpace(_arfRows[i].Time))
        || !IsArfTimeOrdered(i));

    bool ArfHasIncompleteRows => _arfRows.Any(r =>
        string.IsNullOrWhiteSpace(r.Process) || string.IsNullOrWhiteSpace(r.Time) || !IsValidArfTime(r.Time));

    void SetArfCell(int row, int col, ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? string.Empty;
        switch (col)
        {
            case 0: _arfRows[row].Process = v; break;
            case 1: _arfRows[row].Time    = v; break;
            case 2: _arfRows[row].ToneArm = v; break;
            case 3: _arfRows[row].Results = v; break;
        }
        RebuildArfSummary();
    }

    void OpenImportSession()
    {
        if (!_msgUserId.HasValue) return;
        _approvedPcs = DashSvc.GetApprovedPcsForUser(_msgUserId.Value);
        // Solo user: always their own PC (PersonId == PcId)
        _importPcId = _isSoloUser ? _msgUserId.Value : 0;
        _importSessionFile = null;
        _importSessionBytes = null;
        _importSessionFileName = "";
        _importAttachments.Clear();
        _importAttachmentBytes.Clear();
        _importError = "";
        _importSuccess = "";
        _importBusy = false;
        _importDuplicate = false;
        _importFreeSession = false;
        _importStep = 1;
        _arfDate = ""; _arfGrade = ""; _arfSessionLength = ""; _arfAdminTime = ""; _arfTotalTa = ""; _arfTaRangeFrom = ""; _arfTaRangeTo = ""; _arfExamReport = "F/N"; _arfSummary = "";
        _arfRows = [new ArfRow()];
        _showImportWizard = true;
    }

    void GoToExamStep()
    {
        if (_importPcId == 0 || _importSessionFile == null || _importDuplicate) return;
        // Try to parse date from file name (e.g. "260315" → 15/03/2026)
        _arfDate = "";
        if (_importSessionFile != null)
        {
            var name = Path.GetFileNameWithoutExtension(_importSessionFile.Name);
            if (name.Length == 6 && int.TryParse(name, out _))
            {
                var yy = name[..2]; var mm = name[2..4]; var dd = name[4..6];
                _arfDate = $"{dd}/{mm}/20{yy}";
            }
        }
        _importStep = 2;
        // Initialize Quill on summary editor after render
        _ = Task.Run(async () =>
        {
            await Task.Delay(100); // wait for DOM
            await JSRuntime.InvokeVoidAsync("eval", @"
                if (window._arfQuill) { try { window._arfQuill.container.parentElement.removeChild(window._arfQuill.container.previousSibling); window._arfQuill.container.remove(); } catch(e){} }
                var el = document.getElementById('arf-summary-editor');
                if (el) {
                    window._arfQuill = new Quill(el, {
                        theme: 'snow',
                        placeholder: 'Auto-generated from checked rows. You can also edit here...',
                        modules: { toolbar: [
                            ['bold', 'italic', 'underline'],
                            [{ 'color': [] }],
                            [{ 'size': ['10px', '14px', '18px', '24px'] }],
                            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                            ['clean']
                        ]}
                    });
                }
            ");
            await InvokeAsync(() => RebuildArfSummary(pushToEditor: true));
        });
    }

    async Task OnSessionFileSelected(InputFileChangeEventArgs e)
    {
        _importSessionFile = e.File;
        _importError = "";
        // Read bytes now so we don't need the IBrowserFile reference later
        using var ms = new MemoryStream();
        await e.File.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
        _importSessionBytes = ms.ToArray();
        _importSessionFileName = e.File.Name;
        CheckDuplicateSession();
    }

    void ClearSessionFile()
    {
        _importSessionFile = null;
        _importSessionBytes = null;
        _importSessionFileName = "";
        _importDuplicate = false;
        _importFileWarning = "";
    }

    void OnPcChanged(ChangeEventArgs e)
    {
        _importPcId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        CheckDuplicateSession();
    }

    void CheckDuplicateSession()
    {
        _importDuplicate = false;
        _importFileWarning = "";
        if (_importPcId <= 0 || _importSessionFile == null) return;
        var fileName = _importSessionFile.Name;
        var sessionName = Path.GetFileNameWithoutExtension(fileName);

        // Block files containing "_att_" — reserved for attachment naming
        if (fileName.Contains("_att_", StringComparison.OrdinalIgnoreCase))
        {
            _importDuplicate = true;
            _importFileWarning = "File name cannot contain \"_att_\" — this is reserved for attachments.";
            return;
        }

        var exists = FolderSvc.SessionFileExistsByName(_importPcId, sessionName, _isSoloUser);
        if (exists)
        {
            _importDuplicate = true;
            _importFileWarning = $"A session named \"{sessionName}\" already exists for this PC.";
        }
    }

    async Task OnAttachmentFilesSelected(InputFileChangeEventArgs e)
    {
        _importAttachments = e.GetMultipleFiles(20).ToList();
        _importAttachmentBytes.Clear();
        foreach (var f in _importAttachments)
        {
            using var ms = new MemoryStream();
            await f.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
            _importAttachmentBytes.Add((f.Name, ms.ToArray()));
        }
        _importError = "";
    }

    async Task ExecuteImport()
    {
        if (!_msgUserId.HasValue || _importPcId == 0 || _importSessionBytes == null) return;
        // Read final summary from Quill editor before closing modal
        await ReadArfSummaryFromEditor();

        // Capture all needed data now (fields will be reset)
        var capturedPcId        = _importPcId;
        var capturedUserId      = _msgUserId.Value;
        var capturedFileName    = _importSessionFileName;
        var capturedBytes       = _importSessionBytes;
        var capturedAttachments = _importAttachmentBytes.ToList();
        var capturedFreeSession = _importFreeSession;
        var capturedGrade       = _arfGrade;
        var capturedSessLen     = _arfSessionLength;
        var capturedAdminTime   = _arfAdminTime;
        var capturedTotalTa     = _arfTotalTa;
        var capturedTaFrom      = _arfTaRangeFrom;
        var capturedTaTo        = _arfTaRangeTo;
        var capturedDate        = _arfDate;
        var capturedSummary     = string.IsNullOrWhiteSpace(_arfSummary) ? null : _arfSummary;
        var capturedRows        = _arfRows.Select(r => new PdfService.ArfRowData(r.Checked, r.Process, r.Time, r.ToneArm, r.Results)).ToList();
        var capturedPcName      = _approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "";
        var capturedUsername    = _logUsername;
        var capturedIsSolo      = _isSoloUser;

        // Close modal immediately and reset fields
        _showImportWizard = false;
        _importSessionFile    = null;
        _importSessionBytes   = null;
        _importSessionFileName = "";
        _importAttachments.Clear();
        _importAttachmentBytes.Clear();
        _importPcId   = 0;
        _importStep   = 1;
        _importError  = "";
        _importSuccess = "";

        // Start background toast
        _bgImportRunning = true;
        _bgImportDone    = false;
        _bgImportError   = "";
        _bgImportLabel   = capturedFileName;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                var sessionName   = Path.GetFileNameWithoutExtension(capturedFileName);
                var sessionLenSec = ArfTimeToMinutes(capturedSessLen) * 60;
                if (sessionLenSec < 0) sessionLenSec = 0;
                var adminSec = ArfTimeToMinutes(capturedAdminTime) * 60;
                if (adminSec < 0) adminSec = 0;
                var taRange = string.IsNullOrWhiteSpace(capturedTaTo) ? capturedTaFrom : $"{capturedTaFrom}-{capturedTaTo}";

                // Create session record (AuditorId = NULL for solo users)
                var sessionId = DashSvc.CreateImportedSession(capturedPcId, capturedUserId, sessionName,
                    sessionLenSec, adminSec, capturedFreeSession, isSolo: capturedIsSolo);

                // Save folder summary
                var arfData = new PdfService.ArfData
                {
                    PcName        = capturedPcName,
                    Date          = DateTime.Today.ToString("dd/MM/yyyy"),
                    Grade         = capturedGrade,
                    SessionLength = capturedSessLen,
                    AdminTime     = capturedAdminTime,
                    TotalTa       = capturedTotalTa,
                    TaRange       = taRange,
                    Rows          = capturedRows
                };
                var arfJson = System.Text.Json.JsonSerializer.Serialize(arfData);
                DashSvc.AddFolderSummary(sessionId, capturedPcId, capturedIsSolo ? null : capturedUserId, capturedSummary ?? "", arfJson);

                // Upload session file to the correct folder
                var savedSessionFileName = capturedIsSolo
                    ? FolderSvc.SaveSoloUploadedFile(capturedPcId, capturedFileName, capturedBytes)!
                    : FolderSvc.SaveUploadedFile(capturedPcId, capturedFileName, capturedBytes)!;

                // Upload attachments
                foreach (var (name, data) in capturedAttachments)
                    FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, name, data, capturedIsSolo);

                // Generate ARF PDF
                var arfPdfBytes = PdfSvc.GenerateArfPdf(
                    capturedPcName, DateTime.Today.ToString("dd/MM/yyyy"),
                    capturedGrade, capturedSessLen, capturedAdminTime,
                    capturedTotalTa, taRange, capturedRows, capturedSummary);
                FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, "arf.pdf", arfPdfBytes, capturedIsSolo);

                // Append TAA row
                var sessionMinutes = sessionLenSec / 60;
                var taaDate = !string.IsNullOrEmpty(capturedDate) ? capturedDate : DateTime.Today.ToString("d.M.yy");
                if (DateTime.TryParseExact(taaDate, "dd/MM/yyyy", null, System.Globalization.DateTimeStyles.None, out var parsedDate))
                    taaDate = parsedDate.ToString("d.M.yy");
                FolderSvc.AppendTaaRow(capturedPcId, taaDate, sessionMinutes, capturedTotalTa);

                Console.WriteLine($"[MainHeader] Imported session '{capturedFileName}' for PC {capturedPcId} with {capturedAttachments.Count} attachments by '{capturedUsername}'");

                await InvokeAsync(() =>
                {
                    _bgImportRunning = false;
                    _bgImportDone    = true;
                    StateHasChanged();
                });

                await Task.Delay(2500);
                await InvokeAsync(() =>
                {
                    _bgImportDone = false;
                    StateHasChanged();
                    NavigationManager.NavigateTo("/Home", forceLoad: true);
                });
            }
            catch (Exception ex)
            {
                await InvokeAsync(() =>
                {
                    _bgImportRunning = false;
                    _bgImportDone    = false;
                    _bgImportError   = ex.Message;
                    StateHasChanged();
                });
            }
        });
    }

    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1048576.0:F1} MB";
    }

