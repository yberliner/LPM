    void OnActionFolderPcSelected(int pcId, bool solo)
    {
        if (!_msgUserId.HasValue) return;
        var hasPermission = DashSvc.CanAccessPcFolder(_msgUserId.Value, pcId, _logUsername);
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        if (hasPermission)
        {
            _showActionOpenFolder = false;
            var soloParam = solo ? "?solo=true" : "";
            Console.WriteLine($"[MainHeader] Open Folder: PC='{pcName}' (id={pcId}) solo={solo} user='{_logUsername}'");
            NavigationManager.NavigateTo($"/PcFolder/{pcId}{soloParam}", forceLoad: true);
        }
        else
        {
            // Request permission (creates pending request + auto-message to admins)
            DashSvc.CheckOrRequestPermission(_msgUserId.Value, pcId, _logUsername);
            _actionPermMsg = "You do not have permissions for this PC. An approval request was sent to admin.";
            Console.WriteLine($"[MainHeader] Open Folder DENIED + permission requested: PC='{pcName}' (id={pcId}) user='{_logUsername}'");
        }
    }

    void OpenActionSummary()
    {
        if (!_msgUserId.HasValue) return;
        _actionPcSearch = "";
        _actionPermMsg = "";
        _actionSuccessMsg = "";
        _actionSummaryBusy = false;
        _showActionSummary = true;

        if (_isSoloUser)
        {
            // Solo users go straight to the editor — their own folder is the only option
            var soloName = FolderSvc.GetPcName(_msgUserId.Value) ?? "";
            OnActionSummaryPcSelected(_msgUserId.Value, soloName, isSoloFolder: true);
        }
        else
        {
            LoadAllPcs();
            _actionSummaryStep = 1;
            _actionSummaryPcId = 0;
            _actionSummaryPcName = "";
            _actionSummaryIsSoloFolder = false;
        }
