    void RebuildArfSummary(bool pushToEditor = true)
    {
        var lines = _arfRows
            .Where(r => r.Checked && !string.IsNullOrWhiteSpace(r.Process))
            .Select(r =>
            {
                var proc = System.Net.WebUtility.HtmlEncode(r.Process.Trim());
                var res  = System.Net.WebUtility.HtmlEncode(r.Results.Trim());
                return string.IsNullOrWhiteSpace(res) ? proc : $"{proc} TO {res}";
            })
            .ToList();

        var examColor = _arfExamReport switch {
            "F/N" => "#16a34a",
            "RT"  => "#dc2626",
            "YT"  => "#ca8a04",
            "PT"  => "#db2777",
            _     => "#64748b"
        };
        lines.Add($"<span style=\"color:{examColor};\">Exam report: {System.Net.WebUtility.HtmlEncode(_arfExamReport)}</span>");

        _arfSummary = string.Join("", lines.Select(l => $"<p style=\"margin:0;line-height:1.35;\">{l}</p>"));
        if (pushToEditor)
        {
            _ = JSRuntime.InvokeVoidAsync("eval",
                $"if(window._arfQuill) window._arfQuill.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(_arfSummary)};");
        }
    }

