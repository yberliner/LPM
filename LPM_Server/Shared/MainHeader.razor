    void SaveNewPc((string FirstName, string LastName, string Phone, string Email,
                    string DateOfBirth, string Gender, int OrgId, string Source,
                    string Notes, int CourseId, string Nick) d)
    {
        var firstName = PcService.StripDiacritics(d.FirstName);
        var lastName  = PcService.StripDiacritics(d.LastName);
        var nick      = PcService.StripDiacritics(d.Nick);
        var dup = PcSvc.CheckDuplicatePc(firstName, lastName, nick);
        if (dup == "ACTIVE_DUPLICATE")
        {
            Console.WriteLine($"[MainHeader] New PC BLOCKED (duplicate): '{firstName} {lastName}' nick='{nick}' by '{_logUsername}'");
            return;
        }
        var newPcId = PcSvc.AddPcWithPerson(firstName, lastName, d.Phone, d.Email,
            d.DateOfBirth, d.Gender, orgId: d.OrgId > 0 ? d.OrgId : null, notes: d.Notes, nick: nick,
            createdByUserId: _msgUserId);
        PcSvc.RecordPcHistory(newPcId, "Created", $"{firstName} {lastName}", _logUsername);
        Console.WriteLine($"[MainHeader] New PC created: '{firstName} {lastName}' nick='{nick}' phone='{d.Phone}' dob='{d.DateOfBirth}' by '{_logUsername}'");
        // Refresh duplicate-detection set
        _existingPcNames = new HashSet<string>(
            PcSvc.GetAllPcs().Select(p => p.FullName), StringComparer.OrdinalIgnoreCase);
        NavigationManager.NavigateTo("/PCs", forceLoad: true);
