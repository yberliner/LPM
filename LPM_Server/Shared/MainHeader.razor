    // Strip everything except digits and '.' — user literally cannot enter letters
    string FilterNumeric(string? val)
    {
        if (string.IsNullOrEmpty(val)) return "";
        var sb = new System.Text.StringBuilder();
        bool hasDot = false;
        foreach (var c in val)
        {
            if (char.IsDigit(c)) sb.Append(c);
            else if (c == '.' && !hasDot) { sb.Append(c); hasDot = true; }
        }
        return sb.ToString();
    }

    // Auto-format time: "2347" → "23:47", "947" → "9:47", "23:47" stays
    void SetArfTimeCell(int idx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString()?.Trim() ?? "";
        _arfRows[idx].Time = FormatArfTime(raw);
        RecalcSessionLength();
        RebuildArfSummary();
    }

    void RecalcSessionLength()
    {
        _arfSessionLength = "";
        var validRows = _arfRows.Where(r => ArfTimeToMinutes(r.Time) >= 0).ToList();
        if (validRows.Count < 2) return;
        var first = ArfTimeToMinutes(validRows[0].Time);
        var last = ArfTimeToMinutes(validRows[^1].Time);
        var diff = last - first;
        if (diff < 0) return;
        _arfSessionLength = $"{diff / 60}:{diff % 60:D2}";
    }

    string FormatArfTime(string raw)
    {
        if (string.IsNullOrEmpty(raw)) return "";
        if (raw.Contains(':')) return raw;
        var digits = new string(raw.Where(char.IsDigit).ToArray());
        if (digits.Length == 0) return "";
        if (digits.Length <= 2)  // 1-2 digits = minutes → "0:MM"
        {
            var m = int.Parse(digits);
            return $"0:{m:D2}";
        }
        if (digits.Length == 3) return digits[..1] + ":" + digits[1..];
        if (digits.Length >= 4) return digits[..^2] + ":" + digits[^2..];
        return raw;
    }

    bool IsValidArfTime(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return true;
        var parts = val.Split(':');
        if (parts.Length != 2) return false;
        if (!int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return false;
        return h >= 0 && h <= 23 && m >= 0 && m <= 59;
    }

    int ArfTimeToMinutes(string val)
    {
        if (string.IsNullOrWhiteSpace(val)) return -1;
        var parts = val.Split(':');
        if (parts.Length != 2 || !int.TryParse(parts[0], out var h) || !int.TryParse(parts[1], out var m)) return -1;
        return h * 60 + m;
    }

    bool IsArfTimeOrdered(int idx)
    {
        if (idx == 0) return true;
        var cur = ArfTimeToMinutes(_arfRows[idx].Time);
        var prev = ArfTimeToMinutes(_arfRows[idx - 1].Time);
        if (cur < 0 || prev < 0) return true; // don't flag if either is empty/invalid
        return cur >= prev;
    }

    bool ArfHasTimeErrors => _arfRows.Select((_, i) => i).Any(i =>
        (!IsValidArfTime(_arfRows[i].Time) && !string.IsNullOrWhiteSpace(_arfRows[i].Time))
        || !IsArfTimeOrdered(i));

    bool ArfHasIncompleteRows => _arfRows.Any(r =>
        string.IsNullOrWhiteSpace(r.Process) || string.IsNullOrWhiteSpace(r.Time) || !IsValidArfTime(r.Time));

    void SetArfCell(int row, int col, ChangeEventArgs e)
    {
        var v = e.Value?.ToString() ?? string.Empty;
        switch (col)
        {
            case 0: _arfRows[row].Process = v; break;
            case 1: _arfRows[row].Time    = v; break;
            case 2: _arfRows[row].ToneArm = v; break;
            case 3: _arfRows[row].Results = v; break;
        }
        RebuildArfSummary();
    }

