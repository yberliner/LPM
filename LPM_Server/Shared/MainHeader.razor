    async Task SmDeleteConfirmed()
    {
        if (_smDetail == null) return;
        _smDeleting = true; _smDelError = "";
        try
        {
            var sessId = _smDetail.SessionId;
            var pcId = _smDetail.PcId;
            var sessName = _smDetail.Name ?? "";
            await Task.Run(() =>
            {
                var info = DashSvc.LoadSessionDeleteInfo(sessId, pcId, sessName, FolderSvc);
                DashSvc.ExecuteSessionDeletion(info, _logUsername, FolderSvc);
            });
            _smDetail = null;
            _smDelStage1 = false; _smDelStage2 = false; _smDelInput = "";
            _smSuccess = $"Session #{sessId} deleted.";
            if (_smSoloMode)
                SmLoadSoloSessions();
