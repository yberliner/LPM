                <div class="ms-auto d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="SmBackToList">@LS.T("common.cancel")</button>
                    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                            disabled="@(_smSaving || _smSaveSuccess)"
                            @onclick="SmSave">
                        @if (_smSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
