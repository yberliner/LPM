            Console.WriteLine($"[MainHeader] Open Folder (solo): PC={_msgUserId.Value} user='{_logUsername}'");
            NavigationManager.NavigateTo($"/PcFolder/{_msgUserId.Value}?solo=true", forceLoad: true);
