    void OpenMessages()
    {
        if (!_msgUserId.HasValue) return;
        try
        {
            _staffMembers    = DashSvc.GetActiveStaffMembers();
            _pendingMessages = DashSvc.GetPendingMessages(_msgUserId.Value);
            _pendingMsgCount = _pendingMessages.Count;
            _msgStatus       = "";
            _showMessagesModal = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] OpenMessages error: {ex.Message}");
            _msgStatus = $"Error loading messages: {ex.Message}";
            _msgStatusIsError = true;
            _showMessagesModal = true;
        }
    }

    Task SendMessage()
    {
        if (!_msgUserId.HasValue || _msgRecipientId == 0 || string.IsNullOrWhiteSpace(_msgText)) return Task.CompletedTask;
        try
        {
            Console.WriteLine($"[MainHeader] Sending message to recipientId={_msgRecipientId} by '{_logUsername}'");
            DashSvc.SendMessage(_msgUserId.Value, _msgRecipientId, _msgText.Trim());
            _msgText        = "";
            _msgRecipientId = 0;
            _msgStatus      = LS.T("msg.sentSuccess");
            _msgStatusIsError = false;
            Console.WriteLine($"[MainHeader] Message sent OK");
            // Fire-and-forget notify — don't let it crash the circuit
            _ = Task.Run(() => { try { DashSvc.NotifyDataChanged(); } catch { } });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] SendMessage error: {ex.Message}");
            _msgStatus = $"Error: {ex.Message}";
            _msgStatusIsError = true;
        }
        return Task.CompletedTask;
    }

    async Task MsgKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendMessage();
    }

    void AcknowledgeMsg(int messageId)
    {
        if (!_msgUserId.HasValue) return;
        try
        {
            Console.WriteLine($"[MainHeader] Acknowledged message {messageId} by '{_logUsername}'");
            DashSvc.AcknowledgeMessage(messageId, _msgUserId.Value);
            _ = Task.Run(() => { try { DashSvc.NotifyDataChanged(); } catch { } });
            _pendingMessages = _pendingMessages.Where(m => m.Id != messageId).ToList();
            _pendingMsgCount = _pendingMessages.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] AcknowledgeMsg error: {ex.Message}");
        }
    }

    void AcknowledgeAllMsgs()
    {
        if (!_msgUserId.HasValue) return;
        try
        {
            foreach (var msg in _pendingMessages)
                DashSvc.AcknowledgeMessage(msg.Id, _msgUserId.Value);
            _ = Task.Run(() => { try { DashSvc.NotifyDataChanged(); } catch { } });
            Console.WriteLine($"[MainHeader] Acknowledged all {_pendingMessages.Count} messages by '{_logUsername}'");
            _pendingMessages.Clear();
            _pendingMsgCount = 0;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] AcknowledgeAllMsgs error: {ex.Message}");
        }
    }

    static string FormatMsgTime(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
        {
            var diff = DateTime.UtcNow - dt;
            if (diff.TotalMinutes < 1) return "now";
            if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
            if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
            return dt.ToString("dd/MM HH:mm");
        }
        return isoDate;
    }

