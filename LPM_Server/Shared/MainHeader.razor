    }
    .stat-week-btn {
        background: rgba(255,255,255,.1); border: none; color: #e2e8f0;
        width: 30px; height: 30px; border-radius: 50% !important;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: background .15s; font-size: 1.1rem;
    }
    .stat-week-btn:hover { background: rgba(255,255,255,.2); }
    .stat-week-btn:disabled { opacity: .4; cursor: default; }
    .stat-today-btn {
        background: rgba(59,130,246,.2); border: 1px solid rgba(59,130,246,.4);
        color: #60a5fa; font-size: .72rem; font-weight: 600;
        padding: 3px 10px; border-radius: 12px !important; cursor: pointer;
        transition: all .15s; white-space: nowrap;
    }
    .stat-today-btn:hover:not(:disabled) { background: #3b82f6; color: #fff; }
    .stat-today-btn:disabled { opacity: .4; cursor: default; }
    .stat-week-label {
        font-size: .85rem; font-weight: 600; color: #94a3b8;
        min-width: 200px; text-align: center;
    }
    .stat-body { flex: 1; display: flex; overflow: hidden; }

    .stat-sidebar {
        width: 160px; flex-shrink: 0;
        background: #1e293b; border-right: 1px solid #334155;
        display: flex; flex-direction: column;
        transition: width 0.25s cubic-bezier(0.4,0,0.2,1);
        overflow: hidden;
    }
    .stat-sidebar-collapsed { width: 44px; }
    .stat-sidebar-toggle {
        background: none; border: none; color: #64748b;
        padding: 10px; text-align: center; cursor: pointer;
        border-bottom: 1px solid #334155;
        transition: color .15s; font-size: 1rem;
    }
    .stat-sidebar-toggle:hover { color: #e2e8f0; }
    .stat-sidebar-list { flex: 1; overflow-y: auto; padding: 4px 0; }

    .stat-user-btn {
        display: flex; align-items: center; gap: 8px;
        width: 100%; padding: 9px 12px;
        background: none; border: none; color: #94a3b8;
        cursor: pointer; transition: all .15s;
        font-size: .82rem; text-align: left;
        white-space: nowrap; overflow: hidden;
    }
    .stat-user-btn:hover:not(:disabled) { background: #334155; color: #e2e8f0; }
    .stat-user-btn:disabled { cursor: default; }
    .stat-user-pending { opacity: .35; }
    .stat-user-active { background: #1e3a5f !important; color: #60a5fa !important; font-weight: 600; border-right: 3px solid #3b82f6; }
    .stat-user-dot { width: 8px; height: 8px; border-radius: 50% !important; flex-shrink: 0; }
    .stat-user-name { overflow: hidden; text-overflow: ellipsis; }

    .stat-sidebar-collapsed .stat-user-btn { padding: 9px 0; justify-content: center; }
    .stat-sidebar-collapsed .stat-user-name { display: none; }
    .stat-sidebar-collapsed .stat-user-active { border-right: none; }

    .stat-viewer {
        flex: 1; display: flex; flex-direction: column;
        position: relative; background: #1a1a2e;
    }
    .stat-pdf-container { flex: 1; overflow-y: auto; padding: 12px; background: #d1d5db; }
    .stat-loading {
        position: absolute; inset: 0;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 8px; color: #64748b; font-size: .88rem; z-index: 1;
    }
    .stat-download {
        padding: 8px 16px; background: #1e293b;
        border-top: 1px solid #334155;
        display: flex; justify-content: flex-end;
    }

    @@keyframes statFadeIn { from { opacity: 0; } to { opacity: 1; } }

    @@media (max-width: 768px) {
        .stat-sidebar { width: 44px; }
        .stat-sidebar .stat-user-name { display: none; }
        .stat-sidebar .stat-user-btn { padding: 9px 0; justify-content: center; }
        .stat-sidebar-toggle { display: none; }
        .stat-week-label { min-width: 140px; font-size: .75rem; }
    }
</style>

