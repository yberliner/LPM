    void OpenTransferModal()
    {
        _showTransfer = true;
        _xferFromPcId = 0;
        _xferToPcId = 0;
        _xferAmount = 0;
        _xferDeductHours = 0;
        _xferAddHours = 0;
        _xferError = "";
        _xferSuccess = "";
        _xferBusy = false;
        _xferFromRemainHrs = 0;
        _xferFromRemainNis = 0;
        _xferFromRate = 0;

        // Load all PCs with auditing balance
        var allPcs = PcSvc.GetAllPcs();
        _xferPcList = allPcs.Select(pc =>
        {
            var bal = PcSvc.GetPcAuditingBalance(pc.PcId);
            return (pc.PcId, pc.FullName, bal.RemainingHours, bal.RemainingNis, bal.RatePerHour);
        }).OrderBy(x => x.FullName).ToList();
    }

    void OnXferFromChanged(ChangeEventArgs e)
    {
        _xferFromPcId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        _xferError = "";
        _xferSuccess = "";
        if (_xferFromPcId > 0)
        {
            var pc = _xferPcList.FirstOrDefault(p => p.PcId == _xferFromPcId);
            _xferFromRemainHrs = pc.RemainHrs;
            _xferFromRemainNis = pc.RemainNis;
            _xferFromRate = pc.Rate;
        }
        else
        {
            _xferFromRemainHrs = 0;
            _xferFromRemainNis = 0;
            _xferFromRate = 0;
        }
        _xferAmount = 0;
        _xferDeductHours = 0;
        _xferAddHours = 0;
        _xferFullAmount = false;
    }

    void OnXferToChanged(ChangeEventArgs e)
    {
        _xferToPcId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        _xferError = "";
        RecalcXferHours();
    }

    void OnXferAmountChanged(ChangeEventArgs e)
    {
        _xferAmount = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        _xferFullAmount = (_xferAmount == _xferFromRemainNis);
        _xferError = "";
        RecalcXferHours();
    }

    void OnXferFullAmountChanged(ChangeEventArgs e)
    {
        _xferFullAmount = (bool)(e.Value ?? false);
        if (_xferFullAmount)
            _xferAmount = _xferFromRemainNis;
        else
            _xferAmount = 0;
        _xferError = "";
        RecalcXferHours();
    }

    void OnXferAddHoursChanged(ChangeEventArgs e)
    {
        _xferAddHours = double.TryParse(e.Value?.ToString(), out var v) ? Math.Round(v, 2) : 0;
        _xferError = "";
    }

    void RecalcXferHours()
    {
        _xferDeductHours = _xferFromRate > 0 ? Math.Round((double)_xferAmount / _xferFromRate, 2) : 0;
        // Cap at remaining
        if (_xferDeductHours > _xferFromRemainHrs)
            _xferDeductHours = _xferFromRemainHrs;
        // Default addHours to same as deductHours, admin can override
        _xferAddHours = _xferDeductHours;
    }

    void ExecuteTransfer()
    {
        _xferError = "";
        _xferSuccess = "";

        if (_xferFromPcId == 0 || _xferToPcId == 0 || _xferFromPcId == _xferToPcId)
        { _xferError = "Select different From and To PCs"; return; }
        if (_xferAmount <= 0)
        { _xferError = "Amount must be greater than 0"; return; }
        if (_xferAmount > _xferFromRemainNis)
        { _xferError = LS.T("transfer.exceedsBalance"); return; }
        if (_xferDeductHours <= 0)
        { _xferError = "Hours to deduct must be greater than 0"; return; }
        if (_xferDeductHours > _xferFromRemainHrs)
        { _xferError = "Cannot deduct more hours than remaining"; return; }
        if (_xferAddHours <= 0)
        { _xferError = "Hours to add must be greater than 0"; return; }

        _xferBusy = true;
        StateHasChanged();

        try
        {
            if (!_msgUserId.HasValue) return;
            PcSvc.CreateTransfer(_xferFromPcId, _xferToPcId, _xferDeductHours, _xferAddHours, _msgUserId.Value);
            var fromName = _xferPcList.FirstOrDefault(p => p.PcId == _xferFromPcId).Name;
            var toName = _xferPcList.FirstOrDefault(p => p.PcId == _xferToPcId).Name;
            _xferSuccess = $"{LS.T("transfer.success")}: {_xferDeductHours:0.##} hrs from {fromName} → {_xferAddHours:0.##} hrs to {toName}";
            DashSvc.NotifyDataChanged();
        }
        catch (Exception ex)
        {
            _xferError = ex.Message;
            Console.WriteLine($"[Transfer] Failed: {ex}");
        }
        finally
        {
            _xferBusy = false;
            StateHasChanged();
        }
    }

