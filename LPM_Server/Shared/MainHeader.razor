    static string AvatarColor(int id)
    {
        var colors = new[] { "#6366f1", "#ec4899", "#f59e0b", "#10b981", "#3b82f6", "#8b5cf6", "#ef4444", "#14b8a6", "#f97316", "#06b6d4" };
        return colors[Math.Abs(id) % colors.Length];
    }

    async Task GenerateAllStaffPdf()
    {
        var selected = _psaList.Where(s => s.Selected).Select(s => s.Staff).ToList();
        if (selected.Count == 0) return;

        _psaBusy = true;
        _psaProgress = 0;
        _psaTotal = selected.Count;
        _psaCurrentName = "";
        StateHasChanged();
        await Task.Yield();

        var weekStart = _psaWeekStart;
        var weekKey = weekStart.ToString("yyyy-MM-dd");
        var soloPcIds = DashSvc.GetSoloPcIds();

        byte[]? merged = null;

        foreach (var staff in selected)
        {
            _psaCurrentName = staff.FullName;
            _psaProgress++;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(50); // let UI paint

            var pcs = DashSvc.GetUserPcs(staff.PersonId);
            var grid = DashSvc.GetWeekGrid(staff.PersonId, weekStart, pcs);
            var pcIds = pcs.Select(p => p.PcId).ToList();
            var csNames = DashSvc.GetLastCsNamesByPc(pcIds);
            var remarks = DashSvc.GetWeeklyRemarks(staff.PersonId, weekKey);
            var completions = CompletionSvc.GetForWeek(staff.PersonId, weekStart, weekStart.AddDays(6));

            var pdfBytes = PdfSvc.GenerateWeeklyTablePdf(
                staff.FullName, weekStart, pcs, grid, csNames, remarks, soloPcIds, completions);

            merged = merged == null ? pdfBytes : PdfSvc.CombinePdfs(merged, pdfBytes);
        }

        if (merged != null)
        {
            var fileName = $"Staff_Reports_{weekStart:yyyy_MM_dd}.pdf";
            await JSRuntime.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(merged));
        }

        _psaBusy = false;
        _psaDone = true;
        await InvokeAsync(StateHasChanged);
    }

