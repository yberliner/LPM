    void SyncArfDate()
    {
        // Sync the file name prefix when user types a valid dd/MM/yy date
        if (DateTime.TryParseExact(_arfDate, "d/M/yy",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var parsed))
        {
            _importNormalizedDate = parsed;
            _importNormalizedFileName = string.IsNullOrEmpty(_importNormalizedSuffix)
                ? parsed.ToString("yyMMdd")
                : $"{parsed:yyMMdd} {_importNormalizedSuffix}";
        }
    }

    void GoToExamStep()
    {
        if (_importPcId == 0) return;
        // Default date from Step 1 (synced from filename date picker); override from filename prefix if present
        _arfDate = _importNormalizedDate.ToString("dd/MM/yy");
        if (!string.IsNullOrEmpty(_importNormalizedFileName) && _importNormalizedFileName.Length >= 6
            && int.TryParse(_importNormalizedFileName[..6], out _))
        {
            var yy = _importNormalizedFileName[..2];
            var mm = _importNormalizedFileName[2..4];
            var dd = _importNormalizedFileName[4..6];
            _arfDate = $"{dd}/{mm}/{yy}";
        }
        // Pre-fill grade from previous session
        if (string.IsNullOrWhiteSpace(_arfGrade))
        {
            var lastGrade = DashSvc.GetLastArfGrade(_importPcId);
            if (!string.IsNullOrEmpty(lastGrade))
                _arfGrade = lastGrade;
        }
        _importStep = 2;
        // Setup drag-and-drop + arrow navigation for ARF table
        _dropRef?.Dispose();
        _dropRef = DotNetObjectReference.Create(this);
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("interop.setupFileDrop", _dropRef);
            await JSRuntime.InvokeVoidAsync("interop.setupArfNavigation");
        });
        // Initialize Quill on summary editor after render
        _ = Task.Run(async () =>
        {
            await Task.Delay(100); // wait for DOM
            await JSRuntime.InvokeVoidAsync("eval", @"
                if (window._arfQuill) { try { window._arfQuill.container.parentElement.removeChild(window._arfQuill.container.previousSibling); window._arfQuill.container.remove(); } catch(e){} }
                var el = document.getElementById('arf-summary-editor');
                if (el) {
                    window._arfQuill = new Quill(el, {
                        theme: 'snow',
                        placeholder: 'Auto-generated from checked rows. You can also edit here...',
                        modules: { toolbar: [
                            ['bold', 'italic', 'underline'],
                            [{ 'color': [] }],
                            [{ 'size': ['10px', '14px', '18px', '24px'] }],
                            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                            ['clean']
                        ]}
                    });
                }
            ");
            await InvokeAsync(() => RebuildArfSummary(pushToEditor: true));
        });
    }

    void GoToStep3()
    {
        _arfSessionLength = FormatArfTime(_arfSessionLength.Trim());
        _showArfSkipBadge    = IsArfTableEmpty;

        // Only fetch previous session's NextCS on first visit; subsequent visits restore user edits
        string? prevNextCs = null;
        if (!_step3Visited)
        {
            prevNextCs = _importPcId > 0 ? DashSvc.GetLastNextCs(_importPcId) : null;
            _showNextCsSkipBadge = string.IsNullOrWhiteSpace(prevNextCs);
        }

        var isFirstVisit = !_step3Visited;
        var restoreTop = _step3TopHtml;
        var restoreBot = _step3BottomHtml;
        _step3Visited = true;

        _importStep = 3;

        _step3DotNetRef?.Dispose();
        _step3DotNetRef = DotNetObjectReference.Create(this);
        var dotNetRef = _step3DotNetRef;

        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", @"
                var _defaultColors = { 'step3-top-editor': '#dc2626', 'step3-bottom-editor': '#2563eb' };
                ['step3-top-editor','step3-bottom-editor'].forEach(function(id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    var key = '_quill_' + id;
                    if (window[key]) {
                        try { window[key].container.parentElement.removeChild(window[key].container.previousSibling); window[key].container.remove(); } catch(e) {}
                    }
                    var q = new Quill(el, {
                        theme: 'snow',
                        placeholder: 'Type here...',
                        modules: { toolbar: [
                            ['bold','italic','underline'],
                            [{ 'color': [] }],
                            [{ 'size': ['10px','14px','18px','24px'] }],
                            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                            ['clean']
                        ]}
                    });
                    window[key] = q;
                    var defColor = _defaultColors[id];
                    if (defColor) {
                        q.format('color', defColor);
                        // Keep default color — re-apply when format is lost
                        q.on('selection-change', function(range) {
                            if (range && range.length === 0) {
                                var fmt = q.getFormat(range.index);
                                if (!fmt.color) q.format('color', defColor, 'silent');
                            }
                        });
                        q.on('text-change', function() {
                            var sel = q.getSelection();
                            if (sel) {
                                var fmt = q.getFormat(sel.index);
                                if (!fmt.color) q.format('color', defColor, 'silent');
                            }
                        });
                    }
                });
            ");
            if (isFirstVisit)
            {
                // First visit: inject previous session's NextCS into bottom editor
                if (!string.IsNullOrWhiteSpace(prevNextCs))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_step3-bottom-editor']; if(q){{ q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(prevNextCs)}; setTimeout(function(){{ q.formatText(0, q.getLength(), 'color', '#2563eb'); q.setSelection(q.getLength(),0); }}, 50); }}");
                }
            }
            else
            {
                // Returning visit: restore user's previous edits
                if (!string.IsNullOrEmpty(restoreTop))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_step3-top-editor']; if(q) q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(restoreTop)};");
                }
                if (!string.IsNullOrEmpty(restoreBot))
                {
                    await JSRuntime.InvokeVoidAsync("eval",
                        $"var q=window['_quill_step3-bottom-editor']; if(q) q.root.innerHTML={System.Text.Json.JsonSerializer.Serialize(restoreBot)};");
                }
            }
            await JSRuntime.InvokeVoidAsync("step3Quill.attachListeners", dotNetRef);
        });
    }

