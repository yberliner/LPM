                        else
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                                @if (_isSoloUser)
                                {
                                    <div class="form-control form-control-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;">
                                        @(_ncPcs.FirstOrDefault(p => p.PcId == _ncPcId)?.FullName ?? "Solo")
                                        <span class="badge bg-primary ms-2" style="font-size:.7rem;">Solo</span>
                                    </div>
                                }
                                else
                                {
                                    <input type="text" class="form-control form-control-sm mb-2" placeholder="@LS.T("actions.searchPcs")"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                           @bind="_ncPcSearch" @bind:event="oninput" />
                                    <div style="max-height:240px; overflow-y:auto;">
                                        @foreach (var pc in _ncPcs.Where(p => string.IsNullOrEmpty(_ncPcSearch) || p.FullName.Contains(_ncPcSearch, StringComparison.OrdinalIgnoreCase)))
                                        {
                                            var thisPc = pc;
                                            @if (!(_isSoloUser && thisPc.IsAlsoSolo))
                                            {
                                                <div class="memo-pc-item @(_ncPcId == thisPc.PcId && !_ncSolo ? "memo-pc-sel" : "")"
                                                     @onclick="() => { _ncPcId = thisPc.PcId; _ncSolo = false; NcNext(); }">
                                                    <i class="ri-user-line" style="color:#60a5fa; opacity:.7;"></i>
                                                    <span>@thisPc.FullName</span>
                                                </div>
                                            }
                                            @if (thisPc.IsAlsoSolo)
                                            {
                                                <div class="memo-pc-item @(_ncPcId == thisPc.PcId && _ncSolo ? "memo-pc-sel" : "")"
                                                     @onclick="() => { _ncPcId = thisPc.PcId; _ncSolo = true; NcNext(); }">
                                                    <i class="ri-user-line" style="color:#ef4444; opacity:.7;"></i>
                                                    <span>@thisPc.FullName</span>
                                                    <span style="font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
                                                                 color:#fff; background:linear-gradient(135deg,#ef4444,#b91c1c);
                                                                 border-radius:999px; padding:2px 8px; margin-left:4px;">Solo</span>
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        @* ── Step 2: Next C/S Form ── *@
                        <div class="arf wiz-step3-content" style="display:flex; flex-direction:column; min-height:480px;">
                            <div class="s3-subtitle">Dror Center, Haifa, Israel</div>
                            <div style="height:.9rem;"></div>
                            <div style="display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:8px;">
                                <span class="s3-label" style="font-size:1.35rem;">
                                    PC's Name:&nbsp;<span class="s3-value">@(_ncPcs.FirstOrDefault(p => p.PcId == _ncPcId)?.FullName ?? "")</span>
                                </span>
                                <span class="s3-label d-flex align-items-center gap-1" style="font-size:1.35rem;">
                                    Date:&nbsp;
                                    <input type="date" class="form-control form-control-sm"
                                           style="width:150px; background:#0f172a; color:#e2e8f0; border-color:#475569; font-size:.9rem;"
                                           value="@_ncDate.ToString("yyyy-MM-dd")"
                                           @onchange="e => { if (DateOnly.TryParse(e.Value?.ToString(), out var d)) _ncDate = d; }" />
                                </span>
                            </div>
                            <div class="s3-label" style="font-size:1.35rem; margin-top:4px;">
                                Auditor:&nbsp;<span class="s3-value">@_ncAuditorName</span>
                            </div>
                            <div class="mt-2">
                                <div id="nc-top-editor"></div>
                            </div>
                            <div style="min-height:32px;"></div>
                            <div class="s3-heading">
                                The Next C/S:
                            </div>
                            <div class="mt-2">
                                <div id="nc-bottom-editor"></div>
                            </div>
                            <div style="min-height:32px;"></div>
                            <div class="s3-signature">
                                @_ncAuditorName
                            </div>
                        </div>
                    }

                </div>
                <div class="modal-footer" style="background:#0f172a; border-top:1px solid #1e293b;">
                    @if (_ncStep == 1)
                    {
                        <button class="btn btn-sm btn-outline-light" @onclick="() => _showNcWizard = false">@LS.T("common.cancel")</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-light d-flex align-items-center gap-1"
                                @onclick="NcBack">
                            <i class="ri-arrow-left-s-line"></i> Back
                        </button>
                        <button class="btn btn-sm btn-outline-light" @onclick="() => _showNcWizard = false">@LS.T("common.cancel")</button>
                        <button class="btn btn-sm d-flex align-items-center gap-1"
                                style="background:linear-gradient(135deg,#0d9488,#14b8a6); color:#fff; border:none;"
                                @onclick="ExecuteNc">
                            <i class="ri-user-follow-line"></i>Submit
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Next C/S Toast ── *@
@if (_ncRunning || _ncDone || !string.IsNullOrEmpty(_ncError))
{
    var ncDoneCount  = _ncSteps.Count(s => s.Status == 2);
    var ncTotalCount = _ncSteps.Count;
    var ncPct        = ncTotalCount > 0 ? (int)(ncDoneCount * 100.0 / ncTotalCount) : 0;

    <div style="position:fixed;bottom:24px;right:24px;z-index:99999;min-width:310px;max-width:390px;
                border-radius:14px;box-shadow:0 16px 48px rgba(0,0,0,.45);
                background:#0f172a;color:#f1f5f9;overflow:hidden;
                animation:bgImportSlideIn .3s cubic-bezier(.175,.885,.32,1.275) both;">

        <div style="padding:13px 16px 11px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:10px;">
            @if (_ncRunning)
            {
                <span class="spinner-border spinner-border-sm flex-shrink-0" style="color:#14b8a6;width:15px;height:15px;border-width:2px;"></span>
            }
            else if (_ncDone)
            {
                <i class="ri-checkbox-circle-fill flex-shrink-0" style="font-size:1.15rem;color:#22c55e;line-height:1;"></i>
            }
            else
            {
                <i class="ri-error-warning-fill flex-shrink-0" style="font-size:1.15rem;color:#f87171;line-height:1;"></i>
            }
            <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:.875rem;letter-spacing:.01em;line-height:1.3;">
                    @if (_ncRunning)      { <text>Adding Next C/S&hellip;</text> }
                    else if (_ncDone)     { <span style="color:#22c55e;">Next C/S Added!</span> }
                    else                  { <span style="color:#f87171;">Next C/S Failed</span> }
                </div>
                <div style="font-size:.71rem;color:#475569;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@_ncLabel">
                    @_ncLabel
                </div>
            </div>
        </div>

        @if (_ncRunning || _ncDone)
        {
            <div style="padding:10px 16px 4px;display:flex;flex-direction:column;gap:5px;">
                @foreach (var ns in _ncSteps)
                {
                    var nsc = ns.Status switch {
                        1 => "#e2e8f0",
                        2 => "#22c55e",
                        3 => "#f87171",
                        _ => "#334155"
                    };
                    <div style="display:flex;align-items:flex-start;gap:8px;font-size:.78rem;color:@nsc;">
                        @if (ns.Status == 1) { <span class="spinner-border spinner-border-sm flex-shrink-0" style="width:12px;height:12px;border-width:1.5px;color:#14b8a6;margin-top:2px;"></span> }
                        else if (ns.Status == 2) { <i class="ri-checkbox-circle-fill flex-shrink-0" style="font-size:.85rem;margin-top:1px;"></i> }
                        else if (ns.Status == 3) { <i class="ri-close-circle-fill flex-shrink-0" style="font-size:.85rem;margin-top:1px;"></i> }
                        else { <i class="ri-time-line flex-shrink-0" style="font-size:.85rem;margin-top:1px;opacity:.5;"></i> }
                        <span>@ns.Label</span>
                    </div>
                }
            </div>
            <div style="margin:8px 16px 12px;height:4px;border-radius:2px;background:#1e293b;overflow:hidden;">
                <div style="height:100%;width:@(ncPct)%;background:linear-gradient(90deg,#14b8a6,#22c55e);transition:width .4s;border-radius:2px;
                            @(_ncRunning ? "animation:bgBarPulse 1.2s ease-in-out infinite;" : "")"></div>
            </div>
        }
        else
        {
            <div style="padding:10px 16px 14px;">
                <div style="font-size:.75rem;color:#94a3b8;word-break:break-all;">@_ncError</div>
                <button class="btn btn-sm btn-outline-secondary mt-2" style="font-size:.72rem;padding:2px 10px;"
                        @onclick="() => { _ncError = string.Empty; _ncSteps.Clear(); }">@LS.T("common.dismiss")</button>
            </div>
        }
    </div>
}

@* ── Memo Toast ── *@
@if (_memoRunning || _memoDone || !string.IsNullOrEmpty(_memoError))
{
    var _memoDoneCount  = _memoSteps.Count(s => s.Status == 2);
    var _memoTotalCount = _memoSteps.Count;
    var _memoPct        = _memoTotalCount > 0 ? (int)(_memoDoneCount * 100.0 / _memoTotalCount) : 0;

    <div style="position:fixed;bottom:24px;right:24px;z-index:99999;min-width:310px;max-width:390px;
                border-radius:14px;box-shadow:0 16px 48px rgba(0,0,0,.45);
                background:#0f172a;color:#f1f5f9;overflow:hidden;
                animation:bgImportSlideIn .3s cubic-bezier(.175,.885,.32,1.275) both;">

        @* ── Header ── *@
        <div style="padding:13px 16px 11px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:10px;">
            @if (_memoRunning)
            {
                <span class="spinner-border spinner-border-sm flex-shrink-0" style="color:#ec4899;width:15px;height:15px;border-width:2px;"></span>
            }
            else if (_memoDone)
            {
                <i class="ri-checkbox-circle-fill flex-shrink-0" style="font-size:1.15rem;color:#22c55e;line-height:1;"></i>
            }
            else
            {
                <i class="ri-error-warning-fill flex-shrink-0" style="font-size:1.15rem;color:#f87171;line-height:1;"></i>
            }
            <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:.875rem;letter-spacing:.01em;line-height:1.3;">
                    @if (_memoRunning)      { <text>Adding Report&hellip;</text> }
                    else if (_memoDone)     { <span style="color:#22c55e;">Report Added!</span> }
                    else                    { <span style="color:#f87171;">Report Failed</span> }
                </div>
                <div style="font-size:.71rem;color:#475569;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@_memoLabel">
                    @_memoLabel
                </div>
            </div>
        </div>

        @* ── Step list ── *@
        @if (_memoRunning || _memoDone)
        {
            <div style="padding:10px 16px 4px;display:flex;flex-direction:column;gap:5px;">
                @foreach (var _ms in _memoSteps)
                {
                    var _msc = _ms.Status switch {
                        1 => "#e2e8f0",
                        2 => "#22c55e",
                        3 => "#f87171",
                        _ => "#334155"
                    };
                    <div style="display:flex;align-items:flex-start;gap:8px;font-size:.78rem;color:@_msc;">
                        <span style="width:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding-top:1px;">
                            @if (_ms.Status == 1)
                            {
                                <span class="spinner-border" style="width:10px;height:10px;border-width:1.5px;color:#ec4899;flex-shrink:0;"></span>
                            }
                            else if (_ms.Status == 2)
                            {
                                <i class="ri-check-line" style="color:#22c55e;font-size:.8rem;"></i>
                            }
                            else if (_ms.Status == 3)
                            {
                                <i class="ri-close-line" style="color:#f87171;font-size:.8rem;"></i>
                            }
                            else
                            {
                                <span style="width:5px;height:5px;border-radius:50%;background:#1e293b;display:inline-block;"></span>
                            }
                        </span>
                        <div style="@(_ms.Status == 1 ? "font-weight:600;" : "")">@_ms.Label</div>
                    </div>
                }
            </div>
            @* ── Progress bar ── *@
            <div style="margin:10px 16px 14px;height:3px;background:#1e293b;border-radius:2px;overflow:hidden;">
                <div style="height:100%;width:@(_memoPct)%;border-radius:2px;
                            background:linear-gradient(90deg,#be185d,#ec4899);
                            transition:width .35s ease;
                            @(_memoRunning && _memoPct < 100 ? "animation:bgBarPulse 1.8s ease-in-out infinite;" : "")"></div>
            </div>
        }
        else
        {
            @* ── Error ── *@
            <div style="padding:10px 16px 14px;">
                <div style="font-size:.75rem;color:#94a3b8;word-break:break-all;">@_memoError</div>
                <button class="btn btn-sm btn-outline-secondary mt-2" style="font-size:.72rem;padding:2px 10px;"
                        @onclick="() => { _memoError = string.Empty; _memoSteps.Clear(); }">@LS.T("common.dismiss")</button>
            </div>
        }
    </div>
}

@* ── Messages Modal ── *@
@if (_showMessagesModal)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45); z-index:9999;"
         @onclick="() => _showMessagesModal = false">
        <div class="modal-dialog modal-dialog-centered modal-md"
             @onclick:stopPropagation="true">
            <div class="modal-content hdr-msg-modal">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1a237e,#3949ab); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-mail-send-line"></i>@LS.T("msg.messages")
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showMessagesModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    @* ── Compose ── *@
                    <div class="hdr-msg-compose">
                        <div class="d-flex align-items-center gap-2">
                            <select class="form-select form-select-sm hdr-msg-select" @bind="_msgRecipientId">
                                <option value="0">@LS.T("msg.selectRecipient")</option>
                                @foreach (var s in _staffMembers.Where(s => s.PersonId != _msgUserId))
                                {
                                    <option value="@s.PersonId">@s.FullName</option>
                                }
                            </select>
                            <input class="form-control form-control-sm hdr-msg-input"
                                   placeholder="@LS.T("msg.typeMessage")"
                                   @bind="_msgText" @bind:event="oninput"
                                   @onkeydown="MsgKeyDown" />
                            <button class="btn btn-sm hdr-msg-send-btn" @onclick="SendMessage"
                                    disabled="@(_msgRecipientId == 0 || string.IsNullOrWhiteSpace(_msgText))">
                                <i class="ri-send-plane-2-fill"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_msgStatus))
                        {
                            <div class="hdr-msg-status @(_msgStatusIsError ? "text-danger" : "text-success")">
                                <i class="@(_msgStatusIsError ? "ri-error-warning-line" : "ri-check-line") me-1"></i>@_msgStatus
                            </div>
                        }
                    </div>

                    @* ── Inbox ── *@
                    <div class="hdr-msg-inbox-header">
                        <i class="ri-inbox-line me-1"></i>@LS.T("msg.inbox")
                        @if (_pendingMessages.Count > 0)
                        {
                            <span class="hdr-msg-inbox-count">@_pendingMessages.Count</span>
                            <button class="btn btn-sm hdr-msg-okall-btn ms-auto"
                                    @onclick="AcknowledgeAllMsgs">
                                <i class="ri-check-double-line me-1"></i>OK All
                            </button>
                        }
                    </div>
                    @if (_pendingMessages.Count == 0)
                    {
                        <div class="hdr-msg-empty">
                            <i class="ri-checkbox-circle-line"></i>
                            <span>@LS.T("msg.noMessages")</span>
                        </div>
                    }
                    else
                    {
                        <div class="hdr-msg-list">
                            @foreach (var msg in _pendingMessages)
                            {
                                <div class="hdr-msg-item">
                                    <div class="hdr-msg-item-content">
                                        <div class="hdr-msg-item-header">
                                            <span class="hdr-msg-from">
                                                <i class="ri-user-3-line me-1"></i>@msg.FromName
                                            </span>
                                            <span class="hdr-msg-time">@FormatMsgTime(msg.CreatedAt)</span>
                                        </div>
                                        <div class="hdr-msg-text">@msg.MsgText</div>
                                    </div>
                                    <button class="btn btn-sm hdr-msg-ack-btn"
                                            @onclick="() => AcknowledgeMsg(msg.Id)">
                                        <i class="ri-check-double-line me-1"></i>OK
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Open Folder Modal ── *@
@if (_showActionOpenFolder)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45); z-index:9999;"
         @onclick="() => _showActionOpenFolder = false">
        <div class="modal-dialog modal-dialog-centered modal-sm"
             @onclick:stopPropagation="true">
