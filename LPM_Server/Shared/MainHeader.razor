        .wiz-modal-dialog .modal-body { max-height: 70vh; overflow-y: auto; }
    }

    /* ── Assign PC drawer ── */
    .apc-overlay {
        position: fixed; inset: 0; z-index: 9999;
        background: rgba(0,0,0,.5);
        animation: apcFadeIn 0.25s ease;
    }
    .apc-overlay-out { animation: apcFadeOut 0.3s ease forwards; }

    .apc-drawer {
        position: fixed; top: 0; right: 0; bottom: 0;
        width: min(920px, 95vw); background: #fff;
        display: flex; flex-direction: column;
        box-shadow: -8px 0 30px rgba(0,0,0,.2);
        animation: apcSlideIn 0.35s cubic-bezier(0.4,0,0.2,1);
        z-index: 10000;
    }
    .apc-drawer-out { animation: apcSlideOut 0.3s cubic-bezier(0.4,0,0.2,1) forwards; }

    .apc-drawer-hdr {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px;
        background: linear-gradient(135deg, #1a237e, #3949ab);
        color: #fff; flex-shrink: 0;
    }

    .apc-drawer-body {
        flex: 1; display: flex; flex-direction: row;
        overflow: hidden; min-height: 0;
    }

    .apc-panel { display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
    .apc-browse-panel { flex: 1; }
    .apc-assign-panel { flex: 1; }

    .apc-section-hdr {
        display: flex; align-items: center; gap: 6px;
        padding: 10px 20px;
        font-size: .78rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .06em;
        color: #64748b; background: #f8fafc;
        border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
    }
    .apc-section-count {
        background: #e2e8f0; color: #475569;
        font-size: .72rem; font-weight: 700;
        padding: 1px 8px; border-radius: 10px;
        min-width: 22px; text-align: center;
        transition: transform .2s;
    }
    .apc-count-pulse { animation: apcPulse 0.5s ease; }

    .apc-divider {
        width: 2px; flex-shrink: 0; align-self: stretch;
        background: linear-gradient(180deg, #e2e8f0 0%, #cbd5e1 50%, #e2e8f0 100%);
    }

    /* ── Browse panel ── */
    .apc-search-bar {
        padding: 12px 20px; background: #f8fafc;
        border-bottom: 1px solid #e2e8f0; flex-shrink: 0;
    }
    .apc-search-icon { background: #f8fafc !important; border-right: none; color: #64748b; border-color: #e2e8f0; }
    .apc-search-input { border-left: none; border-color: #e2e8f0 !important; background: #f8fafc !important; color: #1e293b !important; font-size: .9rem; }
    .apc-search-input::placeholder { color: #94a3b8 !important; }
    .apc-search-input:focus { box-shadow: none !important; border-color: #cbd5e1 !important; background: #fff !important; }
    .apc-clear-btn { border-color: #e2e8f0; color: #64748b; background: #f8fafc; }
    .apc-filter-hint { font-size: .75rem; color: #64748b; margin-top: 6px; }

    .apc-browse-list { flex: 1; overflow-y: auto; }
    .apc-browse-item {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 20px; border-bottom: 1px solid #f1f5f9;
        font-size: .88rem; color: #1e293b; transition: background .12s;
    }
    .apc-browse-item:hover { background: #f0f4ff; }
    .apc-browse-done { opacity: .45; }
    .apc-browse-done:hover { background: transparent; }
    .apc-browse-icon { color: #94a3b8; flex-shrink: 0; }
    .apc-browse-name {
        flex: 1; min-width: 0; overflow: hidden;
        text-overflow: ellipsis; white-space: nowrap;
    }
    .apc-browse-actions { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
    .apc-nick { font-size: .78rem; color: #94a3b8; margin-left: 4px; }
    .apc-added-badge {
        font-size: .72rem; color: #16a34a; background: #dcfce7;
        padding: 2px 8px; border-radius: 12px; font-weight: 600;
    }
    .apc-search-empty { padding: 20px; text-align: center; color: #94a3b8; font-size: .85rem; }

    /* Quick-role buttons in browse list */
    .apc-qr-btn {
        display: inline-flex; align-items: center; gap: 3px;
        padding: 4px 10px; border-radius: 14px !important;
        font-size: .74rem; font-weight: 600;
        border: none; cursor: pointer; transition: all .18s ease;
    }
    .apc-qr-aud { background: #eff6ff; color: #2563eb; }
    .apc-qr-aud:hover { background: #3b82f6; color: #fff; box-shadow: 0 2px 8px rgba(59,130,246,.3); transform: translateY(-1px); }
    .apc-qr-cs { background: #f0fdf4; color: #16a34a; }
    .apc-qr-cs:hover { background: #16a34a; color: #fff; box-shadow: 0 2px 8px rgba(22,163,74,.3); transform: translateY(-1px); }
    .apc-qr-add { background: #eff6ff; color: #2563eb; }
    .apc-qr-add:hover { background: #3b82f6; color: #fff; box-shadow: 0 2px 8px rgba(59,130,246,.3); transform: translateY(-1px); }
    .apc-qr-done {
        display: inline-flex; align-items: center; gap: 2px;
        padding: 4px 8px; border-radius: 14px; font-size: .72rem; font-weight: 600;
    }
    .apc-qr-done-aud { background: #dbeafe; color: #1d4ed8; }
    .apc-qr-done-cs  { background: #dcfce7; color: #15803d; }

    /* ── Assignments panel ── */
    .apc-assign-list { flex: 1; overflow-y: auto; }
    .apc-assign-empty { text-align: center; padding: 30px 20px; color: #94a3b8; font-size: .85rem; }

    .apc-table { border-collapse: collapse; width: 100%; background: #fff; }
    .apc-table thead tr { background: #f8fafc; border-bottom: 2px solid #e2e8f0; position: sticky; top: 0; z-index: 1; }
    .apc-th-pc { padding: 10px 20px; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #64748b; }
    .apc-th-role { padding: 10px 12px; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: #64748b; white-space: nowrap; text-align: center; }
    .apc-th-remove { width: 44px; }
    .apc-row { border-bottom: 1px solid #f1f5f9; animation: apcRowIn .22s ease both; transition: background .12s; background: #fff; color: #1e293b; }
    .apc-row:hover { background: #f0f4ff; }
    .apc-row-pending { opacity: .55; }
    .apc-td-pc { padding: 11px 20px; font-size: .88rem; }
    .apc-td-role { padding: 6px 12px; text-align: center; white-space: nowrap; }
    .apc-td-remove { padding: 6px 10px; text-align: center; }
    .apc-role-pill { display: inline-flex; align-items: center; padding: 5px 13px; border-radius: 20px !important; font-size: .78rem; font-weight: 600; border: none; cursor: pointer; min-width: 68px; justify-content: center; transition: all .18s cubic-bezier(.4,0,.2,1); }
    .apc-pill-active-aud { background: #3b82f6; color: #fff; box-shadow: 0 2px 8px rgba(59,130,246,.3); }
    .apc-pill-active-aud:hover { background: #2563eb; }
    .apc-pill-active-cs  { background: #16a34a; color: #fff; box-shadow: 0 2px 8px rgba(22,163,74,.3); }
    .apc-pill-active-cs:hover  { background: #15803d; }
    .apc-pill-inactive { background: #f1f5f9; color: #94a3b8; }
    .apc-pill-inactive:hover { background: #e2e8f0; color: #64748b; }
    .apc-remove-btn { background: none; border: none; color: #ef4444; opacity: .45; cursor: pointer; padding: 4px 8px; border-radius: 6px; transition: opacity .15s, background .15s; }
    .apc-remove-btn:hover { opacity: 1; background: #fef2f2; }
    .apc-pending-badge { font-size: .72rem; color: #d97706; background: #fef3c7; padding: 2px 7px; border-radius: 10px; }

    /* ── Drawer animations ── */
    @@keyframes apcFadeIn   { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes apcFadeOut  { from { opacity: 1; } to { opacity: 0; } }
    @@keyframes apcSlideIn  { from { transform: translateX(100%); } to { transform: translateX(0); } }
    @@keyframes apcSlideOut { from { transform: translateX(0); }    to { transform: translateX(100%); } }
    @@keyframes apcRowIn    { from { opacity: 0; transform: translateX(12px); } to { opacity: 1; transform: translateX(0); } }
    @@keyframes apcRowHighlight { 0%,60% { background: #fef9c3; } 100% { background: #fff; } }
    @@keyframes apcPulse { 0% { transform: scale(1); } 50% { transform: scale(1.35); background: #3b82f6; color: #fff; } 100% { transform: scale(1); } }
    .apc-row-new { animation: apcRowHighlight 1.6s ease forwards !important; }

    /* ── Drawer mobile ── */
    @@media (max-width: 768px) {
        .apc-drawer { width: 100vw; }
        .apc-drawer-body { flex-direction: column; }
        .apc-browse-panel { flex: 2; }
        .apc-assign-panel { flex: 3; }
        .apc-divider { width: auto; height: 2px; align-self: auto; background: linear-gradient(90deg, #e2e8f0, #cbd5e1, #e2e8f0); }
        .apc-browse-item { padding: 10px 16px; }
        .apc-td-pc, .apc-th-pc { padding-left: 16px; padding-right: 16px; }
        .apc-search-bar, .apc-section-hdr, .apc-drawer-hdr { padding-left: 16px; padding-right: 16px; }
    }
</style>

<SpkScheduleMeetingModal @ref="_meetingModal" OnSaved="StateHasChanged" />

@* ── Print All Staff Modal ── *@
@if (_showPrintAllStaff)
{
<div class="psa-overlay" @onclick="() => { if (!_psaBusy) _showPrintAllStaff = false; }">
    <div class="psa-modal" @onclick:stopPropagation="true">
        @* Header *@
        <div class="psa-header">
            <div class="psa-header-glow"></div>
            <div class="d-flex align-items-center gap-3" style="position:relative;z-index:1;">
                <div class="psa-header-icon">
                    <i class="ri-team-line"></i>
                </div>
                <div>
                    <div class="psa-header-title">@LS.T("actions.printStaffReports")</div>
                    <div class="psa-header-sub">Weekly overview for selected staff members</div>
                </div>
            </div>
            @if (!_psaBusy)
            {
                <button class="psa-close" @onclick="() => _showPrintAllStaff = false"><i class="ri-close-line"></i></button>
            }
        </div>

        @* Period selector *@
        <div class="psa-period">
            <button class="psa-period-btn" @onclick="PsaPrevWeek" disabled="@_psaBusy">
                <i class="ri-arrow-left-s-line"></i>
            </button>
            <div class="psa-period-label">
                <i class="ri-calendar-2-line me-1"></i>
                @PsaDayLabel(_psaWeekStart) – @PsaDayLabel(_psaWeekStart.AddDays(6))
            </div>
            <button class="psa-period-btn" @onclick="PsaNextWeek"
                    disabled="@(_psaBusy || _psaWeekStart >= DashboardService.GetWeekStart(DateOnly.FromDateTime(DateTime.Today)))">
                <i class="ri-arrow-right-s-line"></i>
            </button>
        </div>

        @* Body *@
        <div class="psa-body">
            @if (!_psaBusy && !_psaDone)
            {
                @* Select all / deselect all *@
                <div class="psa-toolbar">
                    <button class="psa-select-btn" @onclick="PsaToggleAll">
                        <i class="@(_psaList.All(s => s.Selected) ? "ri-checkbox-circle-fill" : "ri-checkbox-circle-line") me-1"></i>
                        @(_psaList.All(s => s.Selected) ? "Deselect All" : "Select All")
                    </button>
                    <span class="psa-count">@_psaList.Count(s => s.Selected) of @_psaList.Count selected</span>
                </div>

                @* Staff list *@
                <div class="psa-list">
                    @for (int idx = 0; idx < _psaList.Count; idx++)
                    {
                        var i = idx;
                        var item = _psaList[i];
                        <label class="psa-item @(item.Selected ? "psa-item-selected" : "")" style="animation-delay: @(i * 30)ms;">
                            <input type="checkbox" checked="@item.Selected"
                                   @onchange="() => _psaList[i] = item with { Selected = !item.Selected }" />
                            <div class="psa-avatar" style="background:@AvatarColor(item.Staff.PersonId);">
                                @(item.Staff.FullName.Length > 0 ? char.ToUpper(item.Staff.FullName[0]) : '?')
                            </div>
                            <span class="psa-name">@item.Staff.FullName</span>
                            <i class="ri-check-line psa-check"></i>
                        </label>
                    }
                </div>
            }
            else if (_psaBusy)
            {
                @* Progress *@
                <div class="psa-progress-zone">
                    <div class="psa-progress-icon">
                        <div class="psa-spin-ring"></div>
                        <i class="ri-file-pdf-2-line psa-spin-icon"></i>
                    </div>
                    <div class="psa-progress-title">Generating Reports</div>
                    <div class="psa-progress-sub">@_psaCurrentName</div>
                    <div class="psa-bar-track">
                        <div class="psa-bar-fill" style="width:@(_psaTotal > 0 ? (int)(100.0 * _psaProgress / _psaTotal) : 0)%;"></div>
                    </div>
                    <div class="psa-progress-count">@_psaProgress / @_psaTotal</div>
                </div>
            }
            else if (_psaDone)
            {
                @* Done *@
                <div class="psa-done-zone">
                    <div class="psa-done-icon">
                        <i class="ri-check-double-line"></i>
                    </div>
                    <div class="psa-done-title">PDF Ready!</div>
                    <div class="psa-done-sub">@_psaTotal staff reports generated and downloaded</div>
                </div>
            }
        </div>

        @* Footer *@
        <div class="psa-footer">
            @if (!_psaBusy && !_psaDone)
            {
                <button class="psa-cancel-btn" @onclick="() => _showPrintAllStaff = false">@LS.T("common.cancel")</button>
                <button class="psa-generate-btn" disabled="@(_psaList.Count(s => s.Selected) == 0)" @onclick="GenerateAllStaffPdf">
                    <i class="ri-file-pdf-2-line me-2"></i>Generate PDF
                </button>
            }
            else if (_psaDone)
            {
                <button class="psa-generate-btn" @onclick="() => { _showPrintAllStaff = false; _psaDone = false; }">
                    <i class="ri-check-line me-1"></i>Done
                </button>
            }
        </div>
    </div>
</div>
}

@* ── File History Modal ── *@
@if (_showFileHistory)
{
<div class="modal show d-block" tabindex="-1"
     style="background:rgba(0,0,0,.45); z-index:9999;"
     @onclick="() => _showFileHistory = false">
    <div class="modal-dialog modal-dialog-centered modal-lg"
         @onclick:stopPropagation="true">
        <div class="modal-content" style="background:#1e293b;border:1px solid #334155;color:#e2e8f0;">
            <div class="modal-header py-2" style="border-bottom:1px solid #334155;">
                <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                    <i class="ri-history-line"></i>File History
                </h5>
                <button type="button" class="btn-close btn-close-white"
                        @onclick="() => _showFileHistory = false"></button>
            </div>
            <div class="modal-body" style="max-height:70vh;overflow-y:auto;">

                @if (_fhPcId == null)
                {
                    @* Step 1: Select PC *@
                    <label class="form-label" style="font-size:.82rem; color:#64748b;">Select PC</label>
                    <input type="text" class="form-control form-control-sm mb-2"
                           style="background:#0f172a;color:#e2e8f0;border-color:#475569;"
                           placeholder="Search PCs…"
                           @bind="_fhPcSearch" @bind:event="oninput" />
                    <div style="max-height:300px;overflow-y:auto;">
                        @foreach (var pc in _actionAllPcs.Where(p => string.IsNullOrEmpty(_fhPcSearch) || p.FullName.Contains(_fhPcSearch, StringComparison.OrdinalIgnoreCase)))
                        {
                            var thisPc = pc;
                            <div class="act-pc-item" style="color:#e2e8f0;" @onclick="() => FhSelectPc(thisPc.PcId, thisPc.FullName, false)">
                                <i class="ri-user-line" style="color:#3b82f6;opacity:.6;"></i>
                                <span>@thisPc.FullName</span>
                            </div>
                            @if (thisPc.IsAlsoSolo)
                            {
                                <div class="act-pc-item" style="color:#e2e8f0;" @onclick="() => FhSelectPc(thisPc.PcId, thisPc.FullName, true)">
                                    <i class="ri-user-line" style="color:#ef4444;opacity:.7;"></i>
                                    <span>@thisPc.FullName</span>
                                    <span style="font-size:.65rem;color:#ef4444;background:rgba(239,68,68,.12);padding:1px 6px;border-radius:4px;margin-left:4px;">Solo</span>
                                </div>
                            }
                        }
                    </div>
                }
                else if (_fhSelectedFile == null)
                {
                    @* Step 2: Browse files *@
                    <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="() => { _fhPcId = null; _fhFolder = null; }">
                        <i class="ri-arrow-left-s-line"></i> Back to PCs
                    </button>
                    <div class="fw-bold mb-2" style="color:#94a3b8;">@_fhPcName @(_fhSolo ? "(Solo)" : "")</div>

                    @if (_fhFolder != null)
                    {
                        @* Current files on disk *@
                        <div class="fw-semibold mb-1" style="font-size:.78rem;color:#64748b;">Current files:</div>
                        @foreach (var sec in new[] { ("Front_Cover", _fhFolder.FrontCoverTree), ("Back_Cover", _fhFolder.BackCoverTree) })
                        {
                            @if (sec.Item2 != null)
                            {
                                <div class="fw-semibold mt-2 mb-1" style="font-size:.78rem;color:#94a3b8;">
                                    <i class="ri-folder-line me-1"></i>@sec.Item1
                                </div>
                                @RenderFhTree(sec.Item2.Children, 0)
                            }
                        }
                        <div class="fw-semibold mt-2 mb-1" style="font-size:.78rem;color:#94a3b8;">
                            <i class="ri-folder-line me-1"></i>WorkSheets
                        </div>
                        @foreach (var ws in _fhFolder.WorkSheets)
                        {
                            var wsStats = _fhAuditStats.GetValueOrDefault(ws.File.RelativePath);
                            <div class="fh-file-item" @onclick="() => FhSelectFile(ws.File.RelativePath)">
                                <i class="ri-file-pdf-2-line" style="color:#ef5350;font-size:.7rem;"></i>
                                <span style="font-size:.8rem;">@ws.File.FileName</span>
                                @if (wsStats != null)
                                {
                                    <span class="fh-stats-badge">@wsStats.Count</span>
                                    <span class="fh-stats-date">@wsStats.LastChange</span>
                                }
                            </div>
                            @foreach (var att in ws.Attachments)
                            {
                                var attStats = _fhAuditStats.GetValueOrDefault(att.RelativePath);
                                <div class="fh-file-item" style="padding-left:24px;" @onclick="() => FhSelectFile(att.RelativePath)">
                                    <i class="ri-attachment-line" style="color:#94a3b8;font-size:.65rem;"></i>
                                    <span style="font-size:.75rem;">@att.FileName</span>
                                    @if (attStats != null)
                                    {
                                        <span class="fh-stats-badge">@attStats.Count</span>
                                        <span class="fh-stats-date">@attStats.LastChange</span>
                                    }
                                </div>
                            }
                        }

                        @* Files with audit history but no longer on disk *@
                        @if (_fhAuditStats.Any(kv => !_fhDiskFiles.Contains(kv.Key)))
                        {
                            <div class="fw-semibold mt-3 mb-1" style="font-size:.78rem;color:#f59e0b;">
                                <i class="ri-ghost-line me-1"></i>Deleted / moved files with history:
                            </div>
                            @foreach (var kv in _fhAuditStats.Where(kv => !_fhDiskFiles.Contains(kv.Key)))
                            {
                                <div class="fh-file-item" style="opacity:.6;" @onclick="() => FhSelectFile(kv.Key)">
                                    <i class="ri-file-unknow-line" style="color:#64748b;font-size:.7rem;"></i>
                                    <span style="font-size:.8rem;">@kv.Key</span>
                                    <span class="fh-stats-badge">@kv.Value.Count</span>
                                    <span class="fh-stats-date">@kv.Value.LastChange</span>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div style="color:#475569;font-size:.85rem;">Folder not found.</div>
                    }
                }
                else
                {
                    @* Step 3: File history *@
                    <button class="btn btn-sm btn-outline-secondary mb-2" @onclick="() => { _fhSelectedFile = null; _fhEntries = null; }">
                        <i class="ri-arrow-left-s-line"></i> Back to files
                    </button>
                    <div class="fw-bold mb-2" style="font-size:.85rem;color:#94a3b8;word-break:break-all;">@_fhSelectedFile</div>

                    @if (_fhLoading)
                    {
                        <div class="text-center py-3"><div class="spinner-border spinner-border-sm"></div></div>
                    }
                    else if (_fhEntries == null || _fhEntries.Count == 0)
                    {
                        <div style="color:#475569;font-size:.85rem;">No history recorded for this file.</div>
                    }
                    else
                    {
                        <table style="width:100%;border-collapse:collapse;font-size:.75rem;">
                            <thead>
                                <tr style="border-bottom:1px solid #334155;">
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">Date</th>
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">Operation</th>
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">User</th>
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">Size</th>
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">Context</th>
                                    <th style="padding:4px 8px;color:#64748b;font-weight:700;">Detail</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var e in _fhEntries)
                                {
                                    var opColor = e.Operation switch
                                    {
                                        "create" => "#22c55e",
                                        "overwrite" => "#f59e0b",
                                        "delete" => "#ef4444",
                                        "shrink" => "#3b82f6",
                                        "rename" or "move" => "#94a3b8",
                                        "annotation_burn" => "#a855f7",
                                        "excel_edit" => "#14b8a6",
                                        _ => "#64748b"
                                    };
                                    <tr style="border-bottom:1px solid #1e293b;">
                                        <td style="padding:3px 8px;white-space:nowrap;color:#94a3b8;">@e.CreatedAt</td>
                                        <td style="padding:3px 8px;">
                                            <span style="background:@(opColor)22;color:@opColor;padding:1px 6px;border-radius:4px;font-size:.68rem;font-weight:600;">@e.Operation</span>
                                        </td>
                                        <td style="padding:3px 8px;color:#e2e8f0;">@(e.Username ?? "system")</td>
                                        <td style="padding:3px 8px;color:#94a3b8;white-space:nowrap;">@(e.SizeBytes.HasValue ? $"{e.SizeBytes.Value / 1024}KB" : "—")</td>
                                        <td style="padding:3px 8px;color:#64748b;">@e.Context</td>
                                        <td style="padding:3px 8px;color:#64748b;max-width:200px;overflow:hidden;text-overflow:ellipsis;" title="@e.Detail">@(e.Detail ?? "")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                }
            </div>
        </div>
    </div>
</div>
}

<style>
    /* ── Print All Staff Modal ── */
    .psa-overlay {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(0,0,0,.5); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        animation: psaFadeIn .25s ease;
    }
    @@keyframes psaFadeIn { from { opacity: 0; } to { opacity: 1; } }

    .psa-modal {
        width: 480px; max-width: 95vw; max-height: 90vh;
        border-radius: 20px; overflow: hidden;
        background: #fff;
        box-shadow: 0 25px 80px rgba(0,0,0,.3), 0 0 0 1px rgba(255,255,255,.1);
        animation: psaSlideUp .35s cubic-bezier(.16,1,.3,1);
        display: flex; flex-direction: column;
    }
    @@keyframes psaSlideUp { from { opacity: 0; transform: translateY(40px) scale(.96); } to { opacity: 1; transform: none; } }

    /* Header */
    .psa-header {
        position: relative; padding: 24px 24px 20px;
        background: linear-gradient(135deg, #4f46e5, #7c3aed, #a855f7);
        display: flex; align-items: center; justify-content: space-between;
        overflow: hidden;
    }
    .psa-header-glow {
        position: absolute; top: -40px; right: -40px;
        width: 160px; height: 160px; border-radius: 50%;
        background: rgba(255,255,255,.12);
        animation: psaPulseGlow 3s ease-in-out infinite;
    }
    @@keyframes psaPulseGlow { 0%,100% { transform: scale(1); opacity: .12; } 50% { transform: scale(1.2); opacity: .2; } }
    .psa-header-icon {
        width: 48px; height: 48px; border-radius: 14px;
        background: rgba(255,255,255,.2); backdrop-filter: blur(8px);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; color: #fff;
    }
    .psa-header-title { font-size: 1.15rem; font-weight: 800; color: #fff; letter-spacing: -.01em; }
    .psa-header-sub { font-size: .78rem; color: rgba(255,255,255,.7); margin-top: 2px; }
    .psa-close {
        position: relative; z-index: 1;
        background: rgba(255,255,255,.15); border: none; color: #fff;
        border-radius: 10px; width: 36px; height: 36px;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; font-size: 1.1rem; transition: background .15s;
    }
    .psa-close:hover { background: rgba(255,255,255,.3); }

    /* Period selector */
    .psa-period {
        display: flex; align-items: center; justify-content: center; gap: 12px;
        padding: 12px 24px; background: #f8fafc; border-bottom: 1px solid #e2e8f0;
    }
    .psa-period-btn {
        width: 32px; height: 32px; border-radius: 8px; border: 1.5px solid #e2e8f0;
        background: #fff; color: #6366f1; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem; transition: all .15s;
    }
    .psa-period-btn:hover:not(:disabled) { background: #eef2ff; border-color: #c7d2fe; }
    .psa-period-btn:disabled { opacity: .3; cursor: default; }
    .psa-period-label {
        font-size: .88rem; font-weight: 700; color: #1e293b;
        display: flex; align-items: center; min-width: 200px; justify-content: center;
    }

    /* Body */
    .psa-body { padding: 12px 24px; overflow-y: auto; flex: 1; max-height: 50vh; }

    /* Toolbar */
    .psa-toolbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
    .psa-select-btn {
        background: none; border: 1px solid #e2e8f0; border-radius: 8px;
        padding: 6px 14px; font-size: .82rem; font-weight: 600; color: #6366f1;
        cursor: pointer; transition: all .15s;
    }
    .psa-select-btn:hover { background: #f0f0ff; border-color: #c7d2fe; }
    .psa-count { font-size: .78rem; color: #94a3b8; font-weight: 500; }

    /* Staff list */
    .psa-list { display: flex; flex-direction: column; gap: 2px; }
    .psa-item {
        display: flex; align-items: center; gap: 8px;
        padding: 6px 10px; border-radius: 8px;
        cursor: pointer; transition: all .2s; border: 1.5px solid transparent;
        animation: psaItemIn .3s ease backwards;
    }
    @@keyframes psaItemIn { from { opacity: 0; transform: translateX(-12px); } to { opacity: 1; transform: none; } }
    .psa-item:hover { background: #f8fafc; }
    .psa-item-selected { background: #f0f0ff; border-color: #c7d2fe; }
    .psa-item input[type="checkbox"] { display: none; }
    .psa-avatar {
        width: 28px; height: 28px; border-radius: 7px;
        display: flex; align-items: center; justify-content: center;
        font-size: .75rem; font-weight: 700; color: #fff; flex-shrink: 0;
    }
    .psa-name { flex: 1; font-size: .84rem; font-weight: 600; color: #1e293b; }
    .psa-check {
        font-size: .95rem; color: #6366f1;
        opacity: 0; transform: scale(0);
        transition: all .2s cubic-bezier(.34,1.56,.64,1);
    }
    .psa-item-selected .psa-check { opacity: 1; transform: scale(1); }

    /* Progress */
    .psa-progress-zone {
        display: flex; flex-direction: column; align-items: center;
        padding: 32px 16px; text-align: center;
    }
    .psa-progress-icon {
        position: relative; width: 72px; height: 72px;
        display: flex; align-items: center; justify-content: center; margin-bottom: 20px;
    }
    .psa-spin-ring {
        position: absolute; inset: 0; border-radius: 50%;
        border: 3px solid #e2e8f0; border-top-color: #6366f1;
        animation: psaSpin 1s linear infinite;
    }
    @@keyframes psaSpin { to { transform: rotate(360deg); } }
    .psa-spin-icon { font-size: 1.8rem; color: #6366f1; }
    .psa-progress-title { font-size: 1.05rem; font-weight: 700; color: #1e293b; margin-bottom: 4px; }
    .psa-progress-sub { font-size: .85rem; color: #64748b; margin-bottom: 20px; min-height: 1.3em; }
    .psa-bar-track {
        width: 100%; height: 8px; border-radius: 8px;
        background: #e2e8f0; overflow: hidden;
    }
    .psa-bar-fill {
        height: 100%; border-radius: 8px;
        background: linear-gradient(90deg, #6366f1, #a855f7, #ec4899);
        background-size: 200% 100%;
        animation: psaBarShimmer 1.5s ease infinite;
        transition: width .4s ease;
    }
    @@keyframes psaBarShimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .psa-progress-count { font-size: .78rem; color: #94a3b8; margin-top: 8px; font-weight: 600; }

    /* Done */
    .psa-done-zone {
        display: flex; flex-direction: column; align-items: center;
        padding: 40px 16px; text-align: center;
        animation: psaDonePop .5s cubic-bezier(.34,1.56,.64,1);
    }
    @@keyframes psaDonePop { from { opacity: 0; transform: scale(.7); } to { opacity: 1; transform: scale(1); } }
    .psa-done-icon {
        width: 72px; height: 72px; border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #34d399);
        display: flex; align-items: center; justify-content: center;
        font-size: 2rem; color: #fff; margin-bottom: 16px;
        box-shadow: 0 8px 32px rgba(16,185,129,.35);
    }
    .psa-done-title { font-size: 1.15rem; font-weight: 800; color: #059669; }
    .psa-done-sub { font-size: .85rem; color: #64748b; margin-top: 4px; }

    /* Footer */
    .psa-footer {
        padding: 16px 24px; border-top: 1px solid #f1f5f9;
        display: flex; justify-content: flex-end; gap: 10px;
        background: #fafbfc;
    }
    .psa-cancel-btn {
        padding: 10px 20px; border-radius: 10px; font-weight: 600; font-size: .88rem;
        background: #fff; border: 1.5px solid #e2e8f0; color: #64748b;
        cursor: pointer; transition: all .15s;
    }
    .psa-cancel-btn:hover { background: #f8fafc; border-color: #cbd5e1; }
    .psa-generate-btn {
        padding: 10px 24px; border-radius: 10px; font-weight: 700; font-size: .88rem;
        background: linear-gradient(135deg, #6366f1, #8b5cf6); border: none; color: #fff;
        cursor: pointer; display: flex; align-items: center;
        box-shadow: 0 4px 16px rgba(99,102,241,.35);
        transition: all .2s;
    }
    .psa-generate-btn:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 6px 24px rgba(99,102,241,.45); }
    .psa-generate-btn:disabled { opacity: .4; cursor: not-allowed; }

    @@media (max-width: 480px) {
        .psa-modal { border-radius: 16px 16px 0 0; max-height: 95vh; }
        .psa-header { padding: 20px 16px 16px; }
        .psa-body { padding: 12px 16px; }
        .psa-footer { padding: 12px 16px; }
    }
</style>

@* ── Show Stat overlay ── *@
@if (_showStat)
{
    <div class="stat-overlay">
        <div class="stat-header">
            <div class="d-flex align-items-center gap-2">
                <i class="ri-bar-chart-box-line" style="font-size:1.2rem;"></i>
                <span style="font-weight:700;font-size:1.05rem;">Staff Statistics</span>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button class="stat-week-btn" @onclick="StatWeekPrev"><i class="ri-arrow-left-s-line"></i></button>
                <span class="stat-week-label">@_statWeekStart.ToString("dd MMM") — @_statWeekStart.AddDays(6).ToString("dd MMM yyyy")</span>
                <button class="stat-week-btn" @onclick="StatWeekNext" disabled="@StatIsCurrentWeek"><i class="ri-arrow-right-s-line"></i></button>
                @if (!StatIsCurrentWeek)
                {
                    <button class="stat-today-btn" @onclick="StatWeekToday" title="Jump to current week">
                        <i class="ri-calendar-todo-line me-1"></i>Today
                    </button>
                }
            </div>
            <div class="d-flex align-items-center gap-3">
                @if (_statPdfBase64 != null && !_statBusy)
                {
                    <button class="stat-today-btn" @onclick="DownloadStatPdf" title="Download this PDF">
                        <i class="ri-download-2-line me-1"></i>Download
                    </button>
                }
                @if (_statCaching)
                {
                    <span style="font-size:.72rem;color:#64748b;">
                        <span class="spinner-border spinner-border-sm me-1" style="width:.6rem;height:.6rem;border-width:2px;color:#60a5fa;"></span>
                        @_statCacheProgress/@_statCacheTotal
                    </span>
                }
                <button class="btn-close btn-close-white" @onclick="CloseShowStat"></button>
            </div>
        </div>

        <div class="stat-body">
            <div class="stat-sidebar @(_statSidebarOpen ? "" : "stat-sidebar-collapsed")">
                <button class="stat-sidebar-toggle" @onclick="() => _statSidebarOpen = !_statSidebarOpen"
                        title="@(_statSidebarOpen ? "Collapse" : "Expand")">
                    <i class="@(_statSidebarOpen ? "ri-side-bar-fill" : "ri-side-bar-line")"></i>
                </button>
                <div class="stat-sidebar-list">
                    @foreach (var staff in _statStaffList)
                    {
                        var sid = staff.PersonId;
                        var isActive = sid == _statSelectedId;
                        var isCached = _statCache.ContainsKey(sid);
                        <button class="stat-user-btn @(isActive ? "stat-user-active" : "") @(!isCached ? "stat-user-pending" : "")"
                                disabled="@(!isCached)"
                                @onclick="() => SelectStatUser(sid)"
                                title="@(isCached ? staff.FullName : staff.FullName + " (generating...)")">
                            <span class="stat-user-dot" style="background:@(isCached ? StatRoleColor(staff.StaffRole) : "#475569");" title="@staff.StaffRole"></span>
                            @if (_statSidebarOpen)
                            {
                                <span class="stat-user-name">@staff.FullName</span>
                            }
                        </button>
                    }
                </div>
            </div>

            <div class="stat-viewer">
                @if (_statBusy)
                {
                    <div class="stat-loading">
                        <span class="spinner-border" style="width:2rem;height:2rem;border-width:3px;color:#60a5fa;"></span>
                        <span style="margin-top:8px;">Generating report...</span>
                    </div>
                }
                <div id="stat-pdf-viewer" class="stat-pdf-container"></div>
            </div>
        </div>
    </div>
}

<style>
    .stat-overlay {
        position: fixed; inset: 0; z-index: 9999;
        background: #0f172a;
