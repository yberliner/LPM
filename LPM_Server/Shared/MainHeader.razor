    void CheckDuplicateSession()
    {
        _importDuplicate = false;
        _importFileWarning = "";
        if (_importPcId <= 0 || _importSessionFile == null) return;

        var originalName   = Path.GetFileNameWithoutExtension(_importSessionFile.Name);
        var normalizedName = string.IsNullOrEmpty(_importNormalizedFileName) ? originalName : _importNormalizedFileName;

        // Block files containing "_att_" — reserved for attachment naming
        if (originalName.Contains("_att_", StringComparison.OrdinalIgnoreCase) ||
            normalizedName.Contains("_att_", StringComparison.OrdinalIgnoreCase))
        {
            _importDuplicate = true;
            _importFileWarning = "File name cannot contain \"_att_\" — this is reserved for attachments.";
            return;
        }

        // Check original filename
        if (FolderSvc.SessionFileExistsByName(_importPcId, originalName, _isSoloUser))
        {
            _importDuplicate = true;
            _importFileWarning = $"A session named \"{originalName}\" already exists for this PC.";
            return;
        }

        // Check normalized filename (what will actually be saved)
        if (normalizedName != originalName && FolderSvc.SessionFileExistsByName(_importPcId, normalizedName, _isSoloUser))
        {
            _importDuplicate = true;
            _importFileWarning = $"A session named \"{normalizedName}\" already exists for this PC.";
        }
    }

