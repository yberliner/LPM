    @@keyframes ufcRipple {
        0%   { transform: scale(1);   opacity: 0.75; }
        100% { transform: scale(2.6); opacity: 0; }
    }
    @@keyframes ufcPop {
        from { transform: scale(0.15); opacity: 0; }
        to   { transform: scale(1);    opacity: 1; }
    }
    .ufc-fading {
        animation: ufcFadeOut 0.8s ease-in forwards;
