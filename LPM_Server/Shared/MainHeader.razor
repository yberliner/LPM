    // Scanner app name strings to strip from uploaded filenames
    static readonly string[] _scannerAppNames =
    [
        "evernote scannable", "scannable document", "scannable",
        "adobe scan", "adobe_scan",
        "office lens", "microsoft lens", "microsoft office lens",
        "camscanner",
        "swiftscan",
        "genius scan",
        "turboscan",
        "scanner pro",
        "scanbot",
        "docscan",
        "scanned documents", "scanned document", "scanned",
        "doc-",   // WhatsApp document prefix
        "scan",
    ];

    void ComputeNormalizedFileName(string rawBaseName)
    {
        var name = rawBaseName;

        // Strip known scanner app name strings (case-insensitive)
        foreach (var app in _scannerAppNames)
            name = System.Text.RegularExpressions.Regex.Replace(
                name,
                System.Text.RegularExpressions.Regex.Escape(app),
                "",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        // Trim leading residue only (scanner names leave leading separators; trailing chars are intentional)
        name = name.TrimStart(' ', '-', '_');

        if (string.IsNullOrWhiteSpace(name))
        {
            _importDateWasPrepended  = true;
            _importNormalizedSuffix  = "";
            _importNormalizedDate    = DateTime.Today;
            _importNormalizedFileName = DateTime.Today.ToString("yyMMdd");
            return;
        }

        // Already starts with yymmdd (6 digits)? Accept as-is, no further changes
        if (System.Text.RegularExpressions.Regex.IsMatch(name, @"^\d{6}"))
        {
            _importDateWasPrepended  = false;
            _importNormalizedSuffix  = "";
            _importNormalizedDate    = DateTime.Today;
            _importNormalizedFileName = name;
            return;
        }

        // Need to prepend date — collapse separators in the suffix first
        name = System.Text.RegularExpressions.Regex.Replace(name, @"[\s\-_]+", " ").Trim();
        _importDateWasPrepended  = true;
        _importNormalizedSuffix  = name;
        _importNormalizedDate    = DateTime.Today;
        _importNormalizedFileName = $"{DateTime.Today:yyMMdd} {name}";
    }

    void OnNormalizedDateChanged(ChangeEventArgs e)
    {
        if (!DateTime.TryParse(e.Value?.ToString(), out var d)) return;
        _importNormalizedDate    = d;
        _importNormalizedFileName = string.IsNullOrEmpty(_importNormalizedSuffix)
            ? d.ToString("yyMMdd")
            : $"{d:yyMMdd} {_importNormalizedSuffix}";
        _importNameEditError = "";
        CheckDuplicateSession();
    }

    void OnNormalizedNameChanged(ChangeEventArgs e)
    {
        var value = (e.Value?.ToString() ?? "").Trim();
        if (string.IsNullOrEmpty(value))
        {
            _importNameEditError = "Name cannot be empty";
            _importNormalizedFileName = "";
            return;
        }

        // Validate yymmdd prefix (6 leading digits)
        if (!System.Text.RegularExpressions.Regex.IsMatch(value, @"^\d{6}"))
        {
            _importNameEditError = "Name must start with a date prefix (yymmdd — 6 digits)";
            _importNormalizedFileName = value; // still update so the input reflects what user typed
            return;
        }

        _importNameEditError = "";
        _importNormalizedFileName = value;

        // Sync date picker: parse yyMMdd from the first 6 chars
        if (DateTime.TryParseExact(value[..6], "yyMMdd",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out var d))
            _importNormalizedDate = d;

        // Re-derive suffix (everything after "yymmdd" plus optional single space/separator)
        var rest = value.Length > 6 ? value[6..].TrimStart(' ', '-', '_') : "";
        _importNormalizedSuffix  = rest;
        _importDateWasPrepended  = true; // keep the date picker visible

        CheckDuplicateSession();
    }

