    /* ── Animated header logo triangles ── */
    .lpm-hdr-logo { height: 36px; width: auto; overflow: visible; }
    .lpm-hdr-logo-icon { height: 32px; width: 32px; overflow: visible; }

    /* ── Upload Front Cover success ── */
    .ufc-success-wrap {
        position: relative;
        width: 80px; height: 80px;
        margin: 0 auto;
    }
    .ufc-success-circle {
        width: 80px; height: 80px; border-radius: 50%;
        background: linear-gradient(135deg, #065f46, #10b981);
        color: #fff; font-size: 2.6rem;
        display: flex; align-items: center; justify-content: center;
        position: relative; z-index: 1;
        animation: ufcPop 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) both;
        box-shadow: 0 0 32px rgba(16,185,129,0.6), 0 4px 14px rgba(0,0,0,0.35);
    }
    .ufc-ripple {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 2.5px solid rgba(16,185,129,0.7);
        animation: ufcRipple 1.4s ease-out infinite;
    }
    .ufc-ripple-2 {
        animation-delay: 0.55s;
    }
