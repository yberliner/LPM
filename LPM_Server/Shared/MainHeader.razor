                                   @bind="_actionPcSearch" @bind:event="oninput" />
                            <div style="max-height:280px; overflow-y:auto;">
                                @foreach (var pc in _actionAllPcs.Where(p => string.IsNullOrEmpty(_actionPcSearch) || p.FullName.Contains(_actionPcSearch, StringComparison.OrdinalIgnoreCase)))
                                {
                                    var thisPc = pc;
                                    @if (!(_isSoloUser && thisPc.IsAlsoSolo))
                                    {
                                        <div class="act-pc-item" @onclick="() => OnActionSummaryPcSelected(thisPc.PcId, thisPc.FullName, _isSoloUser)">
                                            <i class="ri-user-line" style="color:#8b5cf6; opacity:.6;"></i>
                                            <span>@thisPc.FullName</span>
                                        </div>
                                    }
                                    @if (thisPc.IsAlsoSolo)
                                    {
                                        <div class="act-pc-item" @onclick="() => OnActionSummaryPcSelected(thisPc.PcId, thisPc.FullName, true)">
                                            <i class="ri-user-line" style="color:#ef4444; opacity:.7;"></i>
                                            <span>@thisPc.FullName</span>
                                            <span style="font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
                                                         color:#fff; background:linear-gradient(135deg,#ef4444,#b91c1c);
                                                         border-radius:999px; padding:2px 8px; margin-left:4px;">Solo</span>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-3 px-2 py-2"
                             style="background:#f0f4ff; border-radius:8px; border:1px solid #e2e8f0;">
                            <i class="ri-user-line" style="color:#8b5cf6;"></i>
                            <span style="font-weight:700; font-size:.92rem; color:#1e293b;">@_actionSummaryPcName</span>
                            @if (_actionSummaryIsSoloFolder)
                            {
                                <span style="font-size:.65rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
                                             color:#fff; background:linear-gradient(135deg,#ef4444 0%,#b91c1c 100%);
                                             border-radius:999px; padding:2px 9px;
                                             box-shadow:0 0 8px rgba(239,68,68,0.5);">Solo Folder</span>
                            }
                            <button class="btn btn-sm ms-auto p-0" style="color:#64748b; font-size:.8rem;"
                                    @onclick="() => { _actionSummaryStep = 1; _actionPcSearch = string.Empty; _actionSuccessMsg = string.Empty; }">
                                <i class="ri-arrow-left-s-line me-1"></i>Change
                            </button>
                        </div>
                        <div id="act-summary-editor-wrap">
                            <div id="act-summary-editor"></div>
                        </div>
                    }
                </div>
                @if (_actionSummaryStep == 2)
                {
                    <div class="modal-footer py-2" style="border-color:#e2e8f0; background:#fff !important;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CloseActionSummary()">@LS.T("common.cancel")</button>
                        <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                disabled="@_actionSummaryBusy"
                                @onclick="SubmitActionSummary">
                            @if (_actionSummaryBusy)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="ri-save-line"></i>
                            }
                            Save
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ── Session Manager Modal ─────────────────────────────────────────── *@
@if (_smOpen)
{
    <div class="sm-overlay" @onclick="() => _smOpen = false"></div>
    <div class="sm-modal">
        <div class="sm-header">
            @if (_smAddMode)
            {
                <button class="sm-back-btn" @onclick="SmCancelAdd" title="Back to list">
                    <i class="ri-arrow-left-line"></i>
                </button>
                <span><i class="ri-add-circle-line me-2"></i>Add Session</span>
            }
            else if (_smDetail != null)
            {
                <button class="sm-back-btn" @onclick="SmBackToList" title="Back to list">
                    <i class="ri-arrow-left-line"></i>
                </button>
                <span><i class="ri-file-settings-line me-2"></i>@_smPcName — @_smDetail.SessionDate — #@_smDetail.SessionId</span>
            }
            else
            {
                <span><i class="ri-database-2-line me-2"></i>@LS.T("actions.sessionManager")</span>
            }
            <button class="btn-close btn-close-white btn-close-sm ms-auto" @onclick="() => _smOpen = false"></button>
        </div>

        @if (_smAddMode)
        {
            @* ── Add Session View ── *@
            <div class="sm-body">
                @if (!string.IsNullOrEmpty(_smAddError))
                {
                    <div class="alert alert-danger py-1 px-3 mb-2" style="font-size:.82rem;">@_smAddError</div>
                }

                <div class="sm-card">
                    <div class="sm-field">
                        <label>PC</label>
                        <select class="form-select form-select-sm" value="@_smAddPcId"
                                @onchange="SmAddPcChanged">
                            <option value="0">— Select PC —</option>
                            @foreach (var pc in _actionAllPcs)
                            {
                                <option value="@pc.PcId">@pc.FullName</option>
                            }
                        </select>
                    </div>
                    <div class="sm-field-row">
                        <div class="sm-field">
                            <label>Auditor</label>
                            <select class="form-select form-select-sm" @bind="_smAddAuditorId">
                                <option value="0">Solo (no auditor)</option>
                                @foreach (var s in _smAddAuditorList)
                                {
                                    <option value="@s.PersonId">@s.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="sm-field">
                            <label>CS</label>
                            <select class="form-select form-select-sm" @bind="_smAddCsId">
                                <option value="-1">None</option>
                                @foreach (var s in _smCsList)
                                {
                                    <option value="@s.PersonId">@s.FullName</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="sm-field">
                        <label>Session Date</label>
                        <input type="date" class="form-control form-control-sm" @bind="_smAddDate" />
                    </div>
                    <div class="sm-field-row">
                        <div class="sm-field">
                            <label>Session (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="_smAddLenMin" min="0" />
                        </div>
                        <div class="sm-field">
                            <label>Admin (min)</label>
                            <input type="number" class="form-control form-control-sm" @bind="_smAddAdminMin" min="0" />
                        </div>
                    </div>
                    <div class="sm-field">
                        <label class="d-flex align-items-center gap-2">
                            <input type="checkbox" class="form-check-input" @bind="_smAddIsFree" /> Free Session
                        </label>
                    </div>
                    <div class="sm-field">
                        <label>Notes</label>
                        <textarea class="form-control form-control-sm" rows="2" @bind="_smAddNotes"></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-3 justify-content-end">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="SmCancelAdd">Cancel</button>
                    <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                            disabled="@_smAddSaving" @onclick="SmSaveAdd">
                        @if (_smAddSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="ri-save-line"></i> Create Session
                    </button>
                </div>
            </div>
        }
        else if (_smDetail == null)
        {
            @* ── List View ── *@
            <div class="sm-body">
                @* Mode toggle + PC Selector *@
                <div class="sm-pc-bar">
                    @if (_smSoloMode)
                    {
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" @onclick="SmToggleSoloMode">
                            <i class="ri-arrow-left-line"></i> PC View
                        </button>
                        <div class="btn-group btn-group-sm ms-auto" role="group">
                            <button type="button" class="btn @(_smSoloDays == 3 ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SmSoloDaysChanged(3)">3d</button>
                            <button type="button" class="btn @(_smSoloDays == 7 ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SmSoloDaysChanged(7)">7d</button>
                            <button type="button" class="btn @(_smSoloDays == 30 ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SmSoloDaysChanged(30)">30d</button>
                            <button type="button" class="btn @(_smSoloDays == 0 ? "btn-primary" : "btn-outline-secondary")"
                                    @onclick="() => SmSoloDaysChanged(0)">ALL</button>
                        </div>
                        <button class="btn btn-sm btn-outline-success ms-2 d-flex align-items-center gap-1" @onclick="SmOpenAdd">
                            <i class="ri-add-line"></i> Add
                        </button>
                    }
                    else
                    {
                        <label class="sm-pc-label">PC:</label>
                        <select class="form-select form-select-sm sm-pc-select" value="@_smPcId" @onchange="SmOnPcChanged">
                            <option value="0">— Select PC —</option>
                            @foreach (var pc in _actionAllPcs)
                            {
                                <option value="@pc.PcId">@pc.FullName</option>
                            }
                        </select>
                        <div class="ms-auto d-flex gap-1">
                            <button class="btn btn-sm btn-outline-warning d-flex align-items-center gap-1" @onclick="SmToggleSoloMode">
                                <i class="ri-user-voice-line"></i> Solo
                            </button>
                            <button class="btn btn-sm btn-outline-success d-flex align-items-center gap-1" @onclick="SmOpenAdd">
                                <i class="ri-add-line"></i> Add
                            </button>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_smSuccess))
                {
                    <div class="alert alert-success py-1 px-3 mb-2" style="font-size:.82rem;">
                        <i class="ri-check-line me-1"></i>@_smSuccess
                    </div>
                }

                @if (_smSoloMode)
                {
                    @if (_smSoloList.Count == 0)
                    {
                        <div class="sm-empty"><i class="ri-user-voice-line"></i><div>No solo sessions found</div></div>
                    }
                    else
                    {
                        <div class="sm-table-wrap">
                            <table class="sm-table">
                                <thead>
                                    <tr>
                                        <th>PC Name</th>
                                        <th style="width:100px;">Date</th>
                                        <th style="width:80px;">Duration</th>
                                        <th style="width:75px;">Sess Free</th>
                                        <th style="width:90px;">CS</th>
                                        <th style="width:155px;">CS Free/Bill</th>
                                        <th style="width:85px;">CS Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var s in _smSoloList)
                                    {
                                        var hasReview = s.CsReviewId.HasValue;
                                        var hasEdit = hasReview && _smSoloEdits.ContainsKey(s.CsReviewId!.Value);
                                        var displayNotes = hasEdit ? _smSoloEdits[s.CsReviewId!.Value] : (s.CsNotes ?? "");
                                        var warnRow = hasReview && displayNotes != "Free" && displayNotes != "Bill";

                                        <tr class="sm-row @(warnRow ? "sm-solo-warn" : "")" @onclick="() => SmOpenSoloDetail(s)">
                                            <td>@s.PcName</td>
                                            <td>@s.SessionDate</td>
                                            <td>@FormatSec(s.LengthSec + s.AdminSec)</td>
                                            <td>
                                                @if (s.IsFreeSession) { <span class="badge bg-success" style="font-size:.7rem;">Yes</span> }
                                                else { <span class="badge bg-secondary" style="font-size:.7rem;">No</span> }
                                            </td>
                                            <td style="font-size:.8rem;color:#cbd5e1;">@(s.CsName ?? "—")</td>
                                            <td @onclick:stopPropagation="true">
                                                @if (hasReview)
                                                {
                                                    <div class="d-flex align-items-center gap-1">
                                                        <select class="form-select form-select-sm sm-solo-select"
                                                                value="@displayNotes"
                                                                @onchange="e => SmSoloNoteChanged(s.CsReviewId!.Value, e.Value?.ToString())">
                                                            <option value="">—</option>
                                                            <option value="Free">Free</option>
                                                            <option value="Bill">Bill</option>
                                                        </select>
                                                        @if (hasEdit)
                                                        {
                                                            <button class="btn btn-sm btn-success sm-solo-save-btn"
                                                                    @onclick="() => SmSaveSoloNotes(s.CsReviewId!.Value)" title="Save">
                                                                <i class="ri-check-line"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted" style="font-size:.72rem;font-style:italic;">No review</span>
                                                }
                                            </td>
                                            <td>
                                                @if (hasReview)
                                                {
                                                    <span class="badge @SmStatusBadge(s.CsStatus ?? "")">@(s.CsStatus ?? "—")</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
                else if (_smPcId > 0 && _smList.Count == 0)
                {
                    <div class="sm-empty"><i class="ri-inbox-line"></i><div>No sessions found</div></div>
                }
                else if (_smPcId > 0)
                {
                    <div class="sm-table-wrap">
                        <table class="sm-table">
                            <thead>
                                <tr>
                                    <th style="width:50px;">#</th>
                                    <th style="width:100px;">Date</th>
                                    <th>Name</th>
                                    <th style="width:120px;">Auditor</th>
                                    <th style="width:80px;">Duration</th>
                                    <th style="width:60px;">Free</th>
                                    <th style="width:80px;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _smList)
                                {
                                    <tr class="sm-row" @onclick="() => SmOpenDetail(s.SessionId)">
                                        <td>@s.SessionId</td>
                                        <td>@s.SessionDate</td>
                                        <td class="sm-name-cell" title="@s.Name">@s.Name</td>
                                        <td>@s.AuditorName</td>
                                        <td>@FormatSec(s.LengthSec + s.AdminSec)</td>
                                        <td>@(s.IsFree ? "Yes" : "")</td>
                                        <td><span class="badge @SmStatusBadge(s.VerifiedStatus)">@s.VerifiedStatus</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
            @if (!_smSoloMode && _smPcId > 0 && _smTotal > 50)
            {
                <div class="sm-pager">
                    <button class="btn btn-sm btn-outline-secondary" disabled="@(_smPage == 0)" @onclick="() => SmLoadPage(_smPage - 1)">
                        <i class="ri-arrow-left-s-line"></i> Prev
                    </button>
                    <span class="sm-pager-info">Page @(_smPage + 1) of @((int)Math.Ceiling(_smTotal / 50.0))</span>
                    <button class="btn btn-sm btn-outline-secondary" disabled="@((_smPage + 1) * 50 >= _smTotal)" @onclick="() => SmLoadPage(_smPage + 1)">
                        Next <i class="ri-arrow-right-s-line"></i>
                    </button>
                </div>
            }
        }
        else
        {
            @* ── Detail / Edit View ── *@
            <div class="sm-body sm-detail-body">
                @if (!string.IsNullOrEmpty(_smError))
                {
                    <div class="alert alert-danger py-1 px-3 mb-2" style="font-size:.82rem;">@_smError</div>
                }
                @if (!string.IsNullOrEmpty(_smSuccess))
                {
                    <div class="alert alert-success py-1 px-3 mb-2" style="font-size:.82rem;">
                        <i class="ri-check-line me-1"></i>@_smSuccess
                    </div>
                }

                <div class="sm-detail-grid">
                    @* Left card: Session *@
                    <div class="sm-card">
                        <div class="sm-card-head"><i class="ri-file-list-3-line me-2"></i>Session</div>
                        <div class="sm-field">
                            <label>SessionId</label>
                            <input class="form-control form-control-sm" value="@_smDetail.SessionId" readonly />
                        </div>
                        <div class="sm-field">
                            <label>Name</label>
                            <input class="form-control form-control-sm" @bind="_smEditName" />
                        </div>
                        <div class="sm-field">
                            <label>Date</label>
                            <input type="date" class="form-control form-control-sm" @bind="_smEditDate" />
                        </div>
                        <div class="sm-field-row">
                            <div class="sm-field">
                                <label>Session (sec)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditLenSec" />
                            </div>
                            <div class="sm-field">
                                <label>Admin (sec)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditAdminSec" />
                            </div>
                        </div>
                        <div class="sm-field-row">
                            <div class="sm-field">
                                <label>Charge (sec)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditChargeSec" />
                            </div>
                            <div class="sm-field">
                                <label>Charged Rate (¢/hr)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditChargedRate" />
                            </div>
                        </div>
                        <div class="sm-field-row">
                            <div class="sm-field">
                                <label>Auditor Salary (¢/hr)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditAudSalary" />
                            </div>
                            <div class="sm-field">
                                <label>Status</label>
                                <select class="form-select form-select-sm" @bind="_smEditVerified">
                                    <option value="Draft">Draft</option>
                                    <option value="Approved">Approved</option>
                                </select>
                            </div>
                        </div>
                        <div class="sm-field">
                            <label class="d-flex align-items-center gap-2">
                                <input type="checkbox" class="form-check-input" @bind="_smEditIsFree" /> Free Session
                            </label>
                        </div>
                        <div class="sm-field">
                            <label>Notes</label>
                            <textarea class="form-control form-control-sm" rows="2" @bind="_smEditNotes"></textarea>
                        </div>
                        <div class="sm-field">
                            <label>Auditor</label>
                            <input class="form-control form-control-sm" value="@_smDetail.AuditorName" readonly />
                        </div>
                        <div class="sm-field">
                            <label>Created</label>
                            <input class="form-control form-control-sm" value="@_smDetail.CreatedAt" readonly />
                        </div>
                        <div class="sm-field">
                            <label class="d-flex align-items-center gap-2">
                                <input type="checkbox" class="form-check-input" checked="@_smDetail.IsImported" disabled /> Imported
                            </label>
                        </div>
                    </div>

                    @* Right card: CS Review *@
                    <div class="sm-card">
                        <div class="sm-card-head"><i class="ri-user-star-line me-2"></i>CS Review</div>
                        @if (_smDetail.CsReviewId == null)
                        {
                            <div class="sm-empty-card"><i class="ri-file-unknow-line"></i> No CS review for this session</div>
                        }
                        else
                        {
                            <div class="sm-field">
                                <label>CsReviewId</label>
                                <input class="form-control form-control-sm" value="@_smDetail.CsReviewId" readonly />
                            </div>
                            <div class="sm-field">
                                <label>CS Name</label>
                                <select class="form-select form-select-sm" @bind="_smEditCsId">
                                    <option value="0">— None —</option>
                                    @foreach (var cs in _smCsList)
                                    {
                                        <option value="@cs.PersonId">@cs.FullName</option>
                                    }
                                </select>
                            </div>
                            <div class="sm-field">
                                <label>Review Length (sec)</label>
                                <input type="number" class="form-control form-control-sm" @bind="_smEditCsReviewLen" />
                            </div>
                            <div class="sm-field">
                                <label>Status</label>
                                <select class="form-select form-select-sm" @bind="_smEditCsStatus">
                                    <option value="Not_Done">Not Done</option>
                                    @foreach (var kv in _smCsStatuses)
                                    {
                                        <option value="@kv.Key">@kv.Value</option>
                                    }
                                </select>
                            </div>
                            <div class="sm-field">
                                <label>Notes</label>
                                <textarea class="form-control form-control-sm" rows="2" @bind="_smEditCsNotes"></textarea>
                            </div>
                            <div class="sm-field-row">
                                <div class="sm-field">
                                    <label>CS Salary (¢/hr)</label>
                                    <input type="number" class="form-control form-control-sm" @bind="_smEditCsSalary" />
                                </div>
                                <div class="sm-field">
                                    <label>CS Charged (¢/hr)</label>
                                    <input type="number" class="form-control form-control-sm" @bind="_smEditCsCharged" />
                                </div>
                            </div>
                            <div class="sm-field">
                                <label>Reviewed At</label>
                                <input class="form-control form-control-sm" value="@_smDetail.ReviewedAt" readonly />
                            </div>
                        }
                    </div>
                </div>

                @* ── Delete confirmation overlay ── *@
                @if (_smDelStage1)
                {
                    <div class="sm-del-overlay">
                        <div class="sm-del-card @(_smDelStage2 ? "" : "sm-del-pulse")">
                            <i class="ri-error-warning-fill sm-del-icon"></i>
                            <div class="sm-del-title">Permanently Delete Session?</div>
                            <div class="sm-del-text">
                                This will delete session <strong>#@_smDetail.SessionId</strong> (@_smDetail.Name),
                                all CS reviews, folder summaries, attachments, and worksheet files.<br />
                                <strong>This action cannot be undone.</strong>
                            </div>
                            @if (!_smDelStage2)
                            {
                                <div class="d-flex gap-2 mt-3">
                                    <button class="btn btn-sm btn-outline-light" @onclick="() => _smDelStage1 = false">@LS.T("common.cancel")</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => _smDelStage2 = true">
                                        <i class="ri-delete-bin-line me-1"></i>Yes, I want to delete
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="mt-3">
                                    <label class="sm-del-confirm-label">Type <strong>delete</strong> to confirm:</label>
                                    <input class="form-control form-control-sm sm-del-input" autocomplete="off"
                                           @bind="_smDelInput" @bind:event="oninput" placeholder="delete" />
                                    @if (!string.IsNullOrEmpty(_smDelError))
                                    {
                                        <div class="text-danger mt-1" style="font-size:.78rem;">@_smDelError</div>
                                    }
                                    <div class="d-flex gap-2 mt-2">
                                        <button class="btn btn-sm btn-outline-light" @onclick="SmCancelDelete">@LS.T("common.cancel")</button>
                                        <button class="btn btn-sm btn-danger" disabled="@(!string.Equals(_smDelInput?.Trim(), "delete", StringComparison.OrdinalIgnoreCase) || _smDeleting)"
                                                @onclick="SmDeleteConfirmed">
                                            @if (_smDeleting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                            <i class="ri-delete-bin-2-line me-1"></i>Confirm Delete
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                @* ── Save success overlay ── *@
                @if (_smSaveSuccess)
                {
                    <div class="sm-save-overlay">
                        <div class="sm-save-ripple"></div>
                        <div class="sm-save-icon-wrap">
                            <i class="ri-save-line sm-save-file-icon"></i>
                            <i class="ri-checkbox-circle-fill sm-save-check-icon"></i>
                        </div>
                        <div class="sm-save-msg">Changes Saved</div>
                        <div class="sm-save-sub">@_smSaveSummary</div>
                    </div>
                }
            </div>
            <div class="sm-footer">
                <button class="btn btn-sm btn-danger d-flex align-items-center gap-1" @onclick="SmStartDelete">
