    /// Build memo file name: yymmdd {custom} report
    /// - If custom is empty → "yymmdd report"
    /// - If custom already starts with the date prefix → don't duplicate it
    /// - If custom already contains "report" (case-insensitive) → don't append "report"
    static string BuildMemoFileName(DateOnly date, string custom)
    {
        var datePrefix = date.ToString("yyMMdd");
        var trimmed = custom?.Trim() ?? "";

        // Strip leading date prefix if user typed it
        if (trimmed.StartsWith(datePrefix, StringComparison.Ordinal))
            trimmed = trimmed[datePrefix.Length..].TrimStart(' ', '_', '-');

        // Build: datePrefix + custom + report (if not already present)
        var hasReport = trimmed.Contains("report", StringComparison.OrdinalIgnoreCase);
        if (string.IsNullOrWhiteSpace(trimmed))
            return $"{datePrefix} report";
        if (hasReport)
            return $"{datePrefix} {trimmed}";
        return $"{datePrefix} {trimmed} report";
    }

    void MemoNext()
    {
        _memoStep = 2;
        _memoScanBoxError = "";
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", @"
                if (window._memoQuill) {
                    try {
                        window._memoQuill.container.parentElement.removeChild(window._memoQuill.container.previousSibling);
                        window._memoQuill.container.remove();
                    } catch(e) {}
                }
                var el = document.getElementById('memo-quill-editor');
                if (el) {
                    window._memoQuill = new Quill(el, {
                        theme: 'snow',
                        placeholder: 'Type report text...',
                        modules: {
                            keyboard: { bindings: {
                                tab: { key: 9, handler: function() {
                                    var range = this.quill.getSelection();
                                    if (range) this.quill.insertText(range.index, '\t');
                                    return false;
                                }}
                            }},
                            toolbar: [
                                ['bold', 'italic', 'underline'],
                                [{ 'color': [] }],
                                [{ 'size': ['10px', '14px', '18px', '24px'] }],
                                [{ 'align': [] }],
                                ['clean']
                            ]
                        }
                    });

                    // ── Tooltips on standard buttons ──────────────────────────
                    var tb = window._memoQuill.container.previousSibling;
                    if (tb) {
                        var titles = {
                            'ql-bold':      'Bold',
                            'ql-italic':    'Italic',
                            'ql-underline': 'Underline',
                            'ql-color':     'Text Color',
                            'ql-size':      'Font Size',
                            'ql-align':     'Text Alignment',
                            'ql-clean':     'Clear Formatting'
                        };
                        Object.keys(titles).forEach(function(c) {
                            tb.querySelectorAll('.' + c).forEach(function(b) { b.title = titles[c]; });
                        });

                        // ── Explicit LTR / RTL buttons ────────────────────────
                        var fmts = document.createElement('span');
                        fmts.className = 'ql-formats';

                        var ltrBtn = document.createElement('button');
                        ltrBtn.textContent = 'LTR';
                        ltrBtn.title = 'Set paragraph direction: Left-to-Right';
                        ltrBtn.style.cssText = 'width:auto;padding:0 6px;font-size:11px;font-weight:700;letter-spacing:.5px;';
                        ltrBtn.addEventListener('click', function(e) {
                            e.preventDefault();
                            window._memoQuill.format('direction', false);
                            window._memoQuill.format('align', false);
                        });

                        var rtlBtn = document.createElement('button');
                        rtlBtn.textContent = 'RTL';
                        rtlBtn.title = 'Set paragraph direction: Right-to-Left (Hebrew / Arabic)';
                        rtlBtn.style.cssText = 'width:auto;padding:0 6px;font-size:11px;font-weight:700;letter-spacing:.5px;';
                        rtlBtn.addEventListener('click', function(e) {
                            e.preventDefault();
                            window._memoQuill.format('direction', 'rtl');
                            window._memoQuill.format('align', 'right');
                        });

                        fmts.appendChild(ltrBtn);
                        fmts.appendChild(rtlBtn);
                        tb.appendChild(fmts);
                    }
                }
            ");
        });
    }

    async Task ExecuteMemo()
    {
        // Read HTML while modal is still open and Quill is in DOM
        var html = await JSRuntime.InvokeAsync<string>("eval",
            "window._memoQuill ? window._memoQuill.root.innerHTML : ''");

        var capturedPcId     = _memoPcId;
        var capturedSolo     = _memoSolo || _isSoloUser;
        var capturedAudId    = _msgUserId!.Value;
        var capturedPcName   = _memoPcs.FirstOrDefault(p => p.PcId == _memoPcId)?.FullName ?? "";
        var capturedDate     = _memoDate;
        var capturedMemoName = BuildMemoFileName(_memoDate, _memoFileName);

        Console.WriteLine($"[Memo] Quill HTML: {html}");

        // Close modal immediately, start toast
        _showMemoWizard = false;
        _memoRunning    = true;
        _memoDone       = false;
        _memoError      = "";
        _memoLabel      = capturedSolo ? $"{capturedPcName} [Solo]" : capturedPcName;
        _memoSteps = new List<BgStep>
        {
            new("Generating report PDF"),
            new("Saving to WorkSheets"),
            new("Adding session entry"),
        };
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                var sGen  = _memoSteps[0];
                var sSave = _memoSteps[1];
                var sDb   = _memoSteps[2];

                // Step 1: Generate PDF
                sGen.Status = 1;
                await InvokeAsync(StateHasChanged);
                var pdfBytes = PdfSvc.GenerateMemoPdf(html);
                sGen.Status = 2;
                await InvokeAsync(StateHasChanged);

                // Step 2: Save to WorkSheets
                sSave.Status = 1;
                await InvokeAsync(StateHasChanged);
                var savedName = await Task.Run(() =>
                    FolderSvc.SaveMemoFile(capturedPcId, capturedMemoName, pdfBytes, capturedSolo));
                sSave.Status = 2;
                await InvokeAsync(StateHasChanged);

                // Step 3: Insert session row
                sDb.Status = 1;
                await InvokeAsync(StateHasChanged);
                DashSvc.AddMemoSession(capturedAudId, capturedPcId, savedName, capturedDate, capturedSolo);
                DashSvc.NotifyDataChanged();
                sDb.Status = 2;
                await InvokeAsync(StateHasChanged);

                await InvokeAsync(() =>
                {
                    _memoRunning = false;
                    _memoDone    = true;
                    StateHasChanged();
                });

                await Task.Delay(3000);
                await InvokeAsync(() =>
                {
                    _memoDone = false;
                    StateHasChanged();
                });
            }
            catch (Exception ex)
            {
                foreach (var s in _memoSteps.Where(s => s.Status == 1))
                    s.Status = 3;
                await InvokeAsync(() =>
                {
                    _memoRunning = false;
                    _memoError   = ex.Message;
                    StateHasChanged();
                });
            }
        });
    }

