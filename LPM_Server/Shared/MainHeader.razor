    void OpenMessages()
    {
        if (!_msgUserId.HasValue) return;
        try
        {
            _staffMembers    = DashSvc.GetActiveStaffMembers();
            _pendingMessages = DashSvc.GetPendingMessages(_msgUserId.Value);
            _pendingMsgCount = _pendingMessages.Count;
            _msgStatus       = "";
            _showMessagesModal = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] OpenMessages error: {ex.Message}");
            _msgStatus = $"Error loading messages: {ex.Message}";
            _msgStatusIsError = true;
            _showMessagesModal = true;
        }
    }

    Task SendMessage()
    {
        if (!_msgUserId.HasValue || _msgRecipientId == 0 || string.IsNullOrWhiteSpace(_msgText)) return Task.CompletedTask;
        try
        {
            Console.WriteLine($"[MainHeader] Sending message to recipientId={_msgRecipientId} by '{_logUsername}'");
            DashSvc.SendMessage(_msgUserId.Value, _msgRecipientId, _msgText.Trim());
            _msgText        = "";
            _msgRecipientId = 0;
            _msgStatus      = LS.T("msg.sentSuccess");
            _msgStatusIsError = false;
            Console.WriteLine($"[MainHeader] Message sent OK");
            // Fire-and-forget notify — don't let it crash the circuit
            _ = Task.Run(() => { try { DashSvc.NotifyDataChanged(); } catch { } });
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[MainHeader] SendMessage error: {ex.Message}");
            _msgStatus = $"Error: {ex.Message}";
            _msgStatusIsError = true;
        }
        return Task.CompletedTask;
    }

