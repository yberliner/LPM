    void OnActionSummaryPcSelected(int pcId, string pcName, bool isSoloFolder)
    {
        if (!_msgUserId.HasValue) return;
        var hasPermission = DashSvc.CanAccessPcFolder(_msgUserId.Value, pcId, _logUsername);
        if (!hasPermission)
        {
            DashSvc.CheckOrRequestPermission(_msgUserId.Value, pcId, _logUsername);
            _actionPermMsg = "You do not have permissions for this PC. An approval request was sent to admin.";
            Console.WriteLine($"[MainHeader] Write Folder Summary DENIED + permission requested: PC='{pcName}' (id={pcId}) user='{_logUsername}'");
            return;
        }
        Console.WriteLine($"[MainHeader] Write Folder Summary: opened editor for PC='{pcName}' (id={pcId}) solo={isSoloFolder} user='{_logUsername}'");
        _actionPermMsg = "";
        _actionSummaryPcId = pcId;
        _actionSummaryPcName = pcName;
        _actionSummaryIsSoloFolder = isSoloFolder;
        _actionSummaryStep = 2;
        // Init Quill editor after render
        _ = Task.Run(async () =>
        {
            await Task.Delay(100);
            await JSRuntime.InvokeVoidAsync("eval", @"
                if (window._actSumQuill) { try { window._actSumQuill.container.parentElement.removeChild(window._actSumQuill.container.previousSibling); window._actSumQuill.container.remove(); } catch(e){} }
                var el = document.getElementById('act-summary-editor');
                if (el) {
                    window._actSumQuill = new Quill(el, {
                        theme: 'snow',
                        placeholder: 'Write your folder summary here...',
                        modules: { toolbar: [
                            ['bold', 'italic', 'underline'],
                            [{ 'color': [] }],
                            [{ 'size': ['10px', '14px', '18px', '24px'] }],
                            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
                            ['clean']
                        ]}
                    });
                }
            ");
        });
    }

    async Task SubmitActionSummary()
    {
        if (!_msgUserId.HasValue || _actionSummaryPcId == 0) return;
        _actionSummaryBusy = true;
        _actionSuccessMsg = "";
        StateHasChanged();
        try
        {
            var html = await JSRuntime.InvokeAsync<string>("eval",
                "window._actSumQuill ? window._actSumQuill.root.innerHTML : ''");
            if (html == "<p><br></p>" || string.IsNullOrWhiteSpace(html))
            {
                _actionPermMsg = "Please write something before saving.";
                return;
            }
            DashSvc.AddFolderSummary(null, _actionSummaryPcId, _actionSummaryIsSoloFolder ? null : _msgUserId.Value, html);
            DashSvc.NotifyDataChanged();
            Console.WriteLine($"[MainHeader] Folder summary saved for PC {_actionSummaryPcId} by '{_logUsername}'");
            _actionSummaryBusy = false;
            _actionSummaryStep = 0; // show success screen
            StateHasChanged();
            await Task.Delay(1500);
            CloseActionSummary();
        }
        catch (Exception ex)
        {
            _actionPermMsg = $"Error: {ex.Message}";
        }
        finally
        {
            _actionSummaryBusy = false;
        }
    }

    void CloseActionSummary()
    {
        _showActionSummary = false;
        // Clean up Quill instance
        _ = JSRuntime.InvokeVoidAsync("eval",
            "if(window._actSumQuill) { try { window._actSumQuill = null; } catch(e){} }");
    }

    // ── Add PC ──
    void SaveNewPc((string FirstName, string LastName, string Phone, string Email,
                    string DateOfBirth, string Gender, int OrgId, string Source,
                    string Notes, int CourseId, string Nick) d)
    {
        var firstName = PcService.StripDiacritics(d.FirstName);
        var lastName  = PcService.StripDiacritics(d.LastName);
        var nick      = PcService.StripDiacritics(d.Nick);
        var dup = PcSvc.CheckDuplicatePc(firstName, lastName, nick);
        if (dup == "ACTIVE_DUPLICATE")
        {
            Console.WriteLine($"[MainHeader] New PC BLOCKED (duplicate): '{firstName} {lastName}' nick='{nick}' by '{_logUsername}'");
            return;
        }
        PcSvc.AddPcWithPerson(firstName, lastName, d.Phone, d.Email,
            d.DateOfBirth, d.Gender, orgId: d.OrgId > 0 ? d.OrgId : null, notes: d.Notes, nick: nick);
        Console.WriteLine($"[MainHeader] New PC created: '{firstName} {lastName}' nick='{nick}' phone='{d.Phone}' dob='{d.DateOfBirth}' by '{_logUsername}'");
        // Refresh duplicate-detection set
        _existingPcNames = new HashSet<string>(
            PcSvc.GetAllPcs().Select(p => p.FullName), StringComparer.OrdinalIgnoreCase);
        NavigationManager.NavigateTo("/PCs", forceLoad: true);
    }

    // ── Assign PC modal ──
    void ShowAssignPcModal()
    {
        if (_msgUserId == null) return;
        _apcUserId = _msgUserId.Value;
        ApcRefreshData();
        _apcSearch         = "";
        _showAssignPcModal = true;
    }

    void CloseAssignPcModal() { _showAssignPcModal = false; _apcSearch = ""; }

    void ApcRefreshData()
    {
        _apcMyPcs      = DashSvc.GetUserPcs(_apcUserId);
        _apcAllPcs     = DashSvc.GetAllPcs();
        _apcUnapproved = DashSvc.GetUnapprovedPcIds(_apcUserId, _logUsername);
    }

    async Task ApcAddPcFromModal(int pcId)
    {
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        if (_apcIsAuditor)
        {
            DashSvc.AddUserPc(_apcUserId, pcId, "Auditor");
            DashSvc.CheckOrRequestPermission(_apcUserId, pcId, _logUsername);
            Console.WriteLine($"[MainHeader] Assign PC: added PC='{pcName}' (id={pcId}) as Auditor to userId={_apcUserId} by '{_logUsername}'");
        }
        if (_apcIsCS)
        {
            DashSvc.AddUserPc(_apcUserId, pcId, "CS");
            DashSvc.CheckOrRequestPermission(_apcUserId, pcId, _logUsername);
            Console.WriteLine($"[MainHeader] Assign PC: added PC='{pcName}' (id={pcId}) as CS to userId={_apcUserId} by '{_logUsername}'");
        }
        _apcSearch  = "";
        _apcNewPcId = pcId;
        ApcRefreshData();
        DashSvc.NotifyDataChanged();
        await InvokeAsync(StateHasChanged);
        // Scroll new row into view
        await JSRuntime.InvokeVoidAsync("eval",
            $"setTimeout(()=>document.getElementById('apc-row-{pcId}')?.scrollIntoView({{behavior:'smooth',block:'nearest'}}),50)");
        // Clear highlight after animation completes
        _ = Task.Delay(1800).ContinueWith(_ => InvokeAsync(() => { _apcNewPcId = 0; StateHasChanged(); }));
    }

    async Task ApcTogglePcRole(int pcId, string workCapacity, bool currentlyActive)
    {
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        if (currentlyActive)
        {
            DashSvc.RemoveUserPc(_apcUserId, pcId, workCapacity);
            Console.WriteLine($"[MainHeader] Assign PC: removed role '{workCapacity}' from PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        }
        else
        {
            DashSvc.AddUserPc(_apcUserId, pcId, workCapacity);
            DashSvc.CheckOrRequestPermission(_apcUserId, pcId, _logUsername);
            Console.WriteLine($"[MainHeader] Assign PC: added role '{workCapacity}' to PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        }
        ApcRefreshData();
        DashSvc.NotifyDataChanged();
        await InvokeAsync(StateHasChanged);
    }

    async Task ApcRemovePcAllRoles(int pcId)
    {
        var pcName = _apcAllPcs.FirstOrDefault(p => p.PcId == pcId)?.FullName ?? $"PC {pcId}";
        var roles = string.Join(", ", _apcMyPcs.Where(p => p.PcId == pcId).Select(p => p.WorkCapacity));
        foreach (var pc in _apcMyPcs.Where(p => p.PcId == pcId).ToList())
            DashSvc.RemoveUserPc(_apcUserId, pcId, pc.WorkCapacity);
        Console.WriteLine($"[MainHeader] Assign PC: removed all roles ({roles}) from PC='{pcName}' (id={pcId}) userId={_apcUserId} by '{_logUsername}'");
        ApcRefreshData();
        DashSvc.NotifyDataChanged();
        await InvokeAsync(StateHasChanged);
    }

}