    async Task SmSave()
    {
        if (_smDetail == null) return;
        _smSaving = true; _smError = ""; _smSuccess = "";
        var detail = _smDetail;
        try
        {
            // Build summary of what changed
            var changes = new List<string>();
            if (_smEditName != (detail.Name ?? "")) changes.Add("Name");
            if (_smEditDate.ToString("yyyy-MM-dd") != detail.SessionDate) changes.Add("Date");
            if (_smEditLenSec != detail.LengthSeconds) changes.Add("Duration");
            if (_smEditAdminSec != detail.AdminSeconds) changes.Add("Admin");
            if (_smEditIsFree != detail.IsFreeSession) changes.Add("Free");
            if (_smEditVerified != detail.VerifiedStatus) changes.Add("Status");
            if (_smEditChargeSec != detail.ChargeSeconds) changes.Add("Charge");
            if (_smEditChargedRate != detail.ChargedRateCentsPerHour) changes.Add("Rate");
            if (_smEditAudSalary != detail.AuditorSalaryCentsPerHour) changes.Add("Aud Salary");
            if (detail.CsReviewId.HasValue)
            {
                if (_smEditCsReviewLen != (detail.ReviewLengthSeconds ?? 0)) changes.Add("CS Length");
                if (_smEditCsStatus != (detail.CsStatus ?? "")) changes.Add("CS Status");
                if (_smEditCsSalary != (detail.CsSalaryCentsPerHour ?? 0)) changes.Add("CS Salary");
                if (_smEditCsCharged != (detail.CsChargedCentsRatePerHour ?? 0)) changes.Add("CS Rate");
                if (_smEditCsId > 0 && _smEditCsId != (detail.CsId ?? 0)) changes.Add("CS Reassigned");
            }

            await Task.Run(() =>
            {
                DashSvc.UpdateSessionAdmin(detail.SessionId, _smEditName, _smEditDate.ToString("yyyy-MM-dd"),
                    _smEditLenSec, _smEditAdminSec, _smEditIsFree, _smEditVerified,
                    string.IsNullOrWhiteSpace(_smEditNotes) ? null : _smEditNotes,
                    _smEditChargeSec, _smEditChargedRate, _smEditAudSalary);

                if (detail.CsReviewId.HasValue)
                {
                    DashSvc.UpdateCsReviewAdmin(detail.CsReviewId.Value,
                        _smEditCsReviewLen, _smEditCsStatus,
                        string.IsNullOrWhiteSpace(_smEditCsNotes) ? null : _smEditCsNotes,
                        _smEditCsSalary, _smEditCsCharged);

                    if (_smEditCsId > 0 && _smEditCsId != (detail.CsId ?? 0))
                        DashSvc.ReassignCsReview(detail.CsReviewId.Value, _smEditCsId);
                }
            });

            DashSvc.NotifyDataChanged();
            _smSaving = false;
            _smSaveSummary = changes.Count > 0 ? string.Join(" · ", changes) : "No changes";
            _smSaveSuccess = true;
            StateHasChanged();

            await Task.Delay(1800);
            _smSaveSuccess = false;
            _smDetail = null;
            _smError = "";
            if (_smSoloMode) SmLoadSoloSessions();
            else SmLoadPage(_smPage);
            StateHasChanged();
        }
        catch (Exception ex) { _smError = $"Save failed: {ex.Message}"; _smSaving = false; }
    }

