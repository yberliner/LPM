    async Task ExecuteImport()
    {
        if (!_msgUserId.HasValue || _importPcId == 0 || _importSessionBytes == null) return;
        var pcName = _approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? $"PC {_importPcId}";
        ActivitySvc.RecordActivity(_logUsername, $"Clicked Go on Add Session for: {pcName}", "session");
        // Read final summary from Quill editor before closing modal
        await ReadArfSummaryFromEditor();
        await ReadStep3Html();

        // Capture all needed data now (fields will be reset)
        var capturedPcId        = _importPcId;
        var capturedUserId      = _msgUserId.Value;
        var capturedFileName    = _importNormalizedFileName + ".pdf";
        var capturedBytes       = _importSessionBytes;
        var capturedAttachments = _importAttachmentBytes.ToList();
        var capturedFreeSession = _importFreeSession;
        var capturedGrade       = _arfGrade;
        var capturedSessLen     = _arfSessionLength;
        var capturedAdminTime   = FormatArfTime(_arfAdminTime.Trim());
        var capturedTotalTa     = _arfTotalTa;
        var capturedTaFrom      = _arfTaRangeFrom;
        var capturedTaTo        = _arfTaRangeTo;
        var capturedDate        = _arfDate;
        var capturedSummary     = string.IsNullOrWhiteSpace(_arfSummary) ? null : _arfSummary;
        var capturedRowGroups    = _arfTables.Select(t => t.Rows
            .Where(r => !string.IsNullOrWhiteSpace(r.Process) || !string.IsNullOrWhiteSpace(r.Time))
            .Select(r => new PdfService.ArfRowData(r.Checked, r.Process, r.Time, r.ToneArm, r.Results)).ToList())
            .Where(g => g.Count > 0).ToList();
        var capturedPcName      = _approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "";
        var capturedUsername    = _logUsername;
        var capturedIsSolo      = _isSoloUser;
        var capturedStep3Top    = _step3TopHtml;
        var capturedStep3Bottom = _step3BottomHtml;
        var capturedAuditorName = string.IsNullOrWhiteSpace(_importAuditorFullName) ? _logUsername : _importAuditorFullName;
        var capturedArfEmpty    = IsArfTableEmpty;

        // Close reference float if open
        await JSRuntime.InvokeVoidAsync("wizardRef.closeFloat");
        _refBrowserOpen = false;

        // Clear entire scan inbox
        FolderSvc.ClearScanInbox(_logUsername);

        // Close modal immediately and reset fields
        _showImportWizard        = false;
        _importSessionFile       = null;
        _importSessionBytes      = null;
        _importSessionFileName   = "";
        _importNormalizedFileName = "";
        _importNormalizedSuffix  = "";
        _importDateWasPrepended  = false;
        _importNormalizedDate    = DateTime.Today;
        _step3TopHtml            = "";
        _step3BottomHtml         = "";
        _importAttachments.Clear();
        _importAttachmentBytes.Clear();
        _importPcId      = 0;
        _importStep      = 1;
        _importError     = "";
        _importSuccess   = "";
        _refBrowserOpen  = false;
        _refFileList.Clear();

        // Build step list
        var saveLabel = capturedAttachments.Count > 0
            ? $"Saving to folder (+{capturedAttachments.Count} attachment{(capturedAttachments.Count == 1 ? "" : "s")})"
            : "Saving to folder";
        _bgSteps = new List<BgStep>
        {
            new("Creating session"),
            new("Normalizing pages"),
            new("Generating ARF"),
            new("Generating Next C/S"),
            new(saveLabel),
            new("Updating TAA Excel"),
        };

        // Start background toast
        _bgImportRunning = true;
        _bgImportDone    = false;
        _bgImportError   = "";
        _bgImportLabel   = capturedFileName;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            // Helper: mark a step status and push a render
            async Task Advance(BgStep s, int status)
            {
                s.Status = status;
                await InvokeAsync(StateHasChanged);
            }

            try
            {
                var sessionName   = Path.GetFileNameWithoutExtension(capturedFileName);
                var sessionLenSec = ArfTimeToMinutes(capturedSessLen) * 60;
                if (sessionLenSec < 0) sessionLenSec = 0;
                var adminSec = ArfTimeToMinutes(capturedAdminTime) * 60;
                if (adminSec < 0) adminSec = 0;
                var taRange = string.IsNullOrWhiteSpace(capturedTaTo) ? capturedTaFrom : $"{capturedTaFrom}-{capturedTaTo}";

                var sCreate = _bgSteps[0];
                var sNorm   = _bgSteps[1];
                var sArf    = _bgSteps[2];
                var sNextCs = _bgSteps[3];
                var sSave   = _bgSteps[4];
                var sTaa    = _bgSteps[5];

                // ── Phase 1: run independent work in parallel ──────────────────
                // Normalization runs on capturedBytes first (repairs XRef, finds page size).
                // ARF is generated AFTER normalization so it matches the session page dimensions.
                sCreate.Status = 1; sNorm.Status = 1;
                await InvokeAsync(StateHasChanged);

                int    sessionId       = 0;
                byte[] normalizedBytes = capturedBytes;
                byte[] arfPdfBytes     = Array.Empty<byte>();
                byte[] nextCsPdfBytes  = Array.Empty<byte>();

                await Task.WhenAll(
                    Task.Run(async () =>
                    {
                        // Parse user date dd/MM/yy → yyyy-MM-dd for DB; fall back to today
                        var dbDate = DateTime.TryParseExact(capturedDate, "d/M/yy",
                            System.Globalization.CultureInfo.InvariantCulture,
                            System.Globalization.DateTimeStyles.None, out var _pd)
                            ? DateOnly.FromDateTime(_pd).ToString("yyyy-MM-dd")
                            : null;
                        sessionId = DashSvc.CreateImportedSession(capturedPcId, capturedUserId, sessionName,
                            sessionLenSec, adminSec, capturedFreeSession, isSolo: capturedIsSolo, sessionDate: dbDate);
                        var arfData = new PdfService.ArfData
                        {
                            PcName        = capturedPcName,
                            Date          = capturedDate,
                            Grade         = capturedGrade,
                            SessionLength = capturedSessLen,
                            AdminTime     = capturedAdminTime,
                            TotalTa       = capturedTotalTa,
                            TaRange       = taRange,
                            RowGroups     = capturedRowGroups
                        };
                        DashSvc.AddFolderSummary(sessionId, capturedPcId,
                            capturedIsSolo ? null : capturedUserId,
                            capturedSummary ?? "",
                            System.Text.Json.JsonSerializer.Serialize(arfData),
                            sessionDate: dbDate);
                        await Advance(sCreate, 2);
                    }),
                    Task.Run(async () =>
                    {
                        // TAA Excel — no dependencies on other phases, start immediately
                        sTaa.Status = 1;
                        var sessionMinutes = sessionLenSec / 60;
                        var taaDate = !string.IsNullOrEmpty(capturedDate) ? capturedDate : DateTime.Today.ToString("d.M.yy");
                        if (DateTime.TryParseExact(taaDate, "d/M/yy", System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var parsedDate))
                            taaDate = parsedDate.ToString("d.M.yy");
                        var taaWrittenPath = FolderSvc.AppendTaaRow(capturedPcId, taaDate, sessionMinutes, capturedTotalTa);
                        if (taaWrittenPath != null)
                        {
                            var taaFolder = Path.GetFileName(Path.GetDirectoryName(taaWrittenPath));
                            sTaa.Label = $"TAA Excel → {taaFolder}";
                        }
                        await Advance(sTaa, 2);
                    }),
                    Task.Run(async () =>
                    {
                        // ── fast path (PdfSharpCore, no external tool) ──
                        var direct = FolderSvc.TryNormalizePdfDirect(capturedBytes);
                        if (direct != null)
                        {
                            normalizedBytes = direct;
                            await Advance(sNorm, 2);
                            return;
                        }

                        // ── parallel repair — GS + LibreOffice, 20s each ──
                        const int repairSec = 20;
                        int secsLeft = repairSec;
                        sNorm.SubLabel = $"Ghostscript + LibreOffice: {secsLeft}s";
                        await InvokeAsync(StateHasChanged);

                        using var tickerCts = new System.Threading.CancellationTokenSource();
                        _ = Task.Run(async () =>
                        {
                            while (!tickerCts.Token.IsCancellationRequested && secsLeft > 0)
                            {
                                await Task.Delay(1000);
                                if (tickerCts.Token.IsCancellationRequested) break;
                                secsLeft = Math.Max(0, secsLeft - 1);
                                sNorm.SubLabel = secsLeft > 0
                                    ? $"Ghostscript + LibreOffice: {secsLeft}s"
                                    : "Ghostscript + LibreOffice: finishing…";
                                await InvokeAsync(StateHasChanged);
                            }
                        });

                        var gsTask    = Task.Run(() => FolderSvc.RepairAndNormalizeViaGhostscript(capturedBytes, repairSec * 1000));
                        var libreTask = Task.Run(() => FolderSvc.RepairAndNormalizeViaLibreOffice(capturedBytes, repairSec * 1000));

                        byte[]? result = null;
                        string  winner = "";
                        var pending = new List<Task<byte[]?>> { gsTask, libreTask };
                        while (result == null && pending.Count > 0)
                        {
                            var done = await Task.WhenAny(pending);
                            pending.Remove(done);
                            var val = done.Result;
                            if (val != null)
                            {
                                result = val;
                                winner = done == gsTask ? "Ghostscript" : "LibreOffice";
                            }
                        }
                        if (pending.Count > 0) _ = Task.WhenAll(pending);
                        tickerCts.Cancel();

                        if (result != null)
                        {
                            normalizedBytes = result;
                            sNorm.SubLabel  = $"via {winner}";
                            await Advance(sNorm, 2);
                        }
                        else
                        {
                            normalizedBytes = capturedBytes;
                            sNorm.SubLabel  = "GS and LibreOffice both failed";
                            await Advance(sNorm, 3);
                        }
                    })
                );

                // ── Phase 1.5: generate ARF + Next CS sized to session page ──
                var (targetW, targetH) = FolderSvc.GetFirstPageSizePt(normalizedBytes);
                if (capturedArfEmpty)
                {
                    sArf.SubLabel = "skipped";
                    await Advance(sArf, 2);
                }
                else
                {
                    // Content is locked to A4 proportions inside QuestPDF and scaled via
                    // ScaleToFit — fully vector, no PdfSharpCore post-processing.
                    sArf.Status = 1;
                    await InvokeAsync(StateHasChanged);
                    arfPdfBytes = PdfSvc.GenerateArfPdf(
                        capturedPcName, capturedDate,
                        capturedGrade, capturedSessLen, capturedAdminTime,
                        capturedTotalTa, taRange, capturedRowGroups, capturedSummary,
                        pageWidthPt: targetW, pageHeightPt: targetH,
                        sessionId: sessionId);
                    await Advance(sArf, 2);
                    normalizedBytes = PdfSvc.CombinePdfs(arfPdfBytes, normalizedBytes);
                }

                // Generate Next C/S sized to session page (same as ARF)
                // For solo PCs the footer shows the CS name instead of the auditor.
                sNextCs.Status = 1;
                await InvokeAsync(StateHasChanged);
                string? nextCsFooter = capturedIsSolo ? DashSvc.GetCsNameForPc(capturedPcId) : null;
                nextCsPdfBytes = PdfSvc.GenerateNextCsPdf(
                    capturedPcName, capturedDate,
                    capturedAuditorName, capturedStep3Top, capturedStep3Bottom,
                    footerName: nextCsFooter);
                await Advance(sNextCs, 2);

                // ── Phase 2: save files to folder ───────────────
                sSave.Status = 1;
                await InvokeAsync(StateHasChanged);

                await Task.Run(async () =>
                {
                    var savedSessionFileName = capturedIsSolo
                        ? FolderSvc.SaveSoloUploadedFile(capturedPcId, capturedFileName, normalizedBytes)!
                        : FolderSvc.SaveUploadedFile(capturedPcId, capturedFileName, normalizedBytes)!;

                    foreach (var (name, data, _) in capturedAttachments)
                        FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, name, data, capturedIsSolo);

                    if (!string.IsNullOrWhiteSpace(capturedStep3Bottom))
                        DashSvc.SaveNextCs(sessionId, capturedStep3Bottom);

                    if (nextCsPdfBytes.Length > 0)
                        FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, "Next CS.pdf", nextCsPdfBytes, capturedIsSolo);

                    await Advance(sSave, 2);
                });

                Console.WriteLine($"[MainHeader] Imported session '{capturedFileName}' for PC {capturedPcId} with {capturedAttachments.Count} attachments by '{capturedUsername}'");
                ActivitySvc.RecordActivity(capturedUsername, $"Added session for: {capturedPcName}", "session");

                await InvokeAsync(() =>
                {
                    _bgImportRunning = false;
                    _bgImportDone    = true;
                    StateHasChanged();
                });

                await Task.Delay(500);
                await InvokeAsync(() =>
                {
                    _bgImportDone = false;
                    // Notify other users (singleton event) then hard-reload this user
                    DashSvc.NotifyDataChanged();
                    NavigationManager.NavigateTo("/Home", forceLoad: true);
                });
            }
            catch (Exception ex)
            {
                // Mark any still-running step as failed
                foreach (var s in _bgSteps.Where(s => s.Status == 1))
                    s.Status = 3;
                await InvokeAsync(() =>
                {
                    _bgImportRunning = false;
                    _bgImportDone    = false;
                    _bgImportError   = ex.Message;
                    StateHasChanged();
                });
            }
        });
    }

    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1048576.0:F1} MB";
    }

