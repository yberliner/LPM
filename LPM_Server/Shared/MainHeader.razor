@code {
    private bool _isDisposed = false;
    private string _displayName = "";
    private string? _avatarUrl;

    // ── Add PC state ──
    SpkNewPersonModal _addPcModal = default!;
    HashSet<string>? _existingPcNames;

    // ── Import Session state ──
    bool _showImportWizard;
    int  _importPcId;
    IBrowserFile? _importSessionFile;
    List<IBrowserFile> _importAttachments = [];
    List<DashboardService.ApprovedPc> _approvedPcs = [];
    bool   _importBusy;
    string _importError   = "";
    string _importSuccess = "";

    void OpenImportSession()
    {
        if (!_msgUserId.HasValue) return;
        _approvedPcs = DashSvc.GetApprovedPcsForUser(_msgUserId.Value);
        _importPcId = 0;
        _importSessionFile = null;
        _importAttachments.Clear();
        _importError = "";
        _importSuccess = "";
        _importBusy = false;
        _showImportWizard = true;
    }

    void OnSessionFileSelected(InputFileChangeEventArgs e)
    {
        _importSessionFile = e.File;
        _importError = "";
    }

    void OnAttachmentFilesSelected(InputFileChangeEventArgs e)
    {
        _importAttachments = e.GetMultipleFiles(20).ToList();
        _importError = "";
    }

    async Task ExecuteImport()
    {
        if (!_msgUserId.HasValue || _importPcId == 0 || _importSessionFile == null) return;
        _importBusy = true;
        _importError = "";
        _importSuccess = "";
        StateHasChanged();

        try
        {
            // Use session file name (without extension) as session name
            var sessionName = Path.GetFileNameWithoutExtension(_importSessionFile.Name);

            // Create session record
            var sessionId = DashSvc.CreateImportedSession(_importPcId, _msgUserId.Value, sessionName);

            // Upload session file
            string savedSessionFileName;
            using (var ms = new MemoryStream())
            {
                await _importSessionFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
                savedSessionFileName = FolderSvc.SaveUploadedFile(_importPcId, _importSessionFile.Name, ms.ToArray())!;
            }

            // Upload attachments into _att subfolder
            foreach (var file in _importAttachments)
            {
                using var ms = new MemoryStream();
                await file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024).CopyToAsync(ms);
                FolderSvc.SaveAttachment(_importPcId, savedSessionFileName, file.Name, ms.ToArray());
            }

            var totalFiles = 1 + _importAttachments.Count;
            _importSuccess = $"Session imported ({totalFiles} file(s) uploaded)";
            _importSessionFile = null;
            _importAttachments.Clear();
            _importPcId = 0;

            // Refresh dashboard
            await Task.Delay(1500);
            _showImportWizard = false;
            NavigationManager.NavigateTo("/Home", forceLoad: true);
        }
        catch (Exception ex)
        {
            _importError = ex.Message;
        }
        finally
        {
            _importBusy = false;
        }
    }

    static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1048576) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / 1048576.0:F1} MB";
    }

    // ── Messaging state ──
    int?   _msgUserId;
    int    _pendingMsgCount;
    bool   _showMessagesModal;
    List<StaffMessage> _pendingMessages = [];
    List<StaffMember>  _staffMembers    = [];
    int    _msgRecipientId;
    string _msgText   = "";
    string _msgStatus = "";
    bool   _msgStatusIsError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var name = auth.User.Identity?.Name ?? "";
        _displayName = name.Length > 0
            ? char.ToUpper(name[0]) + name[1..]
            : "LP Management";
        _avatarUrl = UserDb.GetAvatarPath(name.ToLower());

        // Load existing PC names for duplicate detection
        _existingPcNames = new HashSet<string>(
            PcSvc.GetAllPcs().Select(p => p.FullName), StringComparer.OrdinalIgnoreCase);

        // Resolve staff PersonId for messaging
        _msgUserId = DashSvc.GetUserIdByUsername(name);
        if (_msgUserId.HasValue)
        {
            _pendingMsgCount = DashSvc.GetPendingMessageCount(_msgUserId.Value);
            // Subscribe to instant message notifications
            MsgNotifier.OnNewMessage += OnNewMessageReceived;
        }
    }

    [Parameter] public bool ShowMenuToggle { get; set; } = true;

    <!-- ToggleMenu -->
    private async void ToggleMenu() {
        var toggled = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-toggled");
        var verticalStyle = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-vertical-style");
        var navStyle = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-nav-style");
        var isdoubleMenuActive = await JSRuntime.InvokeAsync<bool>("interop.isEleExist", ".double-menu-active");
        var inner = await JSRuntime.InvokeAsync<int>("interop.inner", "innerWidth");

        if (inner <= 992) {
            if (toggled == "open") {
                await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "close");
            } else {
                await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "open");
            }
        } 
        else {
            if (navStyle != null) {
                if (toggled != null) {
                    await JSRuntime.InvokeAsync<string>("interop.removeAttributeFromHtml", "data-toggled");
                } 
                else {
                    await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", navStyle + "-closed");
                }
            } 
            else if (verticalStyle != null) {
                if (verticalStyle == "doublemenu") {
                    if (toggled == "double-menu-open" && isdoubleMenuActive) {
                        await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "double-menu-close");
                    } 
                    else {
                        if (isdoubleMenuActive) {
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "double-menu-open");
                        }
                    }
                } 
                else if (toggled != null) {
                    await JSRuntime.InvokeAsync<string>("interop.removeAttributeFromHtml", "data-toggled");
                } 
                else {
                    switch (verticalStyle) {
                        case "default-menu":
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "close-menu-close");
                            break;
                        case "closed":
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "close-menu-close");
                            break;
                        case "icontext":
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "icon-text-close");
                            break;
                        case "overlay":
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "icon-overlay-close");
                            break;
                        case "detached":
                            await JSRuntime.InvokeAsync<string>("interop.addAttributeToHtml", "data-toggled", "detached-close");
                            break;
                    }
                }
            }
        }
    }

    private AppState currentState => stateService.GetAppState();
    private async void colorthemeFn()
    {
        var val = currentState.ColorTheme == "light" ? "dark" : "light";
        await JSRuntime.InvokeAsync<string>("interop.setLocalStorageItem", "xintracolortheme", val);
        await stateService.colorthemeFn(val, true);
    }

    //sticky-pin //
    private string headerClass = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AttachHeaderScrollListener();
        }
    }

    private async void OnNewMessageReceived(int recipientPersonId)
    {
        if (_isDisposed || !_msgUserId.HasValue || recipientPersonId != _msgUserId.Value) return;
        try
        {
            var newCount = DashSvc.GetPendingMessageCount(_msgUserId.Value);
            if (newCount != _pendingMsgCount)
            {
                _pendingMsgCount = newCount;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* swallow — component may be disposed */ }
    }

    public void Dispose()
    {
        _isDisposed = true;
        MsgNotifier.OnNewMessage -= OnNewMessageReceived;
    }

    private async Task AttachHeaderScrollListener()
    {
        await JSRuntime.InvokeVoidAsync("interop.registerheaderScrollListener", DotNetObjectReference.Create(this));
    }

    [JSInvokable]
    public void SetStickyClass1(int scrollY)
    {
        if (scrollY >= 25)
        {
            headerClass = "sticky-pin";
        }
        else
        {
            headerClass = "";
        }

        StateHasChanged();
    }
    //sticky-pin //

    private async Task SwitchLanguage(string lang)
    {
        LS.SetLanguage(lang);
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "lpm-lang", lang);
        await JSRuntime.InvokeVoidAsync("interop.addAttributeToHtml", "dir", LS.IsRtl ? "rtl" : "ltr");
    }

    // ── Messaging methods ──────────────────────────────────────

    void OpenMessages()
    {
        if (!_msgUserId.HasValue) return;
        _staffMembers    = DashSvc.GetActiveStaffMembers();
        _pendingMessages = DashSvc.GetPendingMessages(_msgUserId.Value);
        _pendingMsgCount = _pendingMessages.Count;
        _msgStatus       = "";
        _showMessagesModal = true;
    }

    void SendMessage()
    {
        if (!_msgUserId.HasValue || _msgRecipientId == 0 || string.IsNullOrWhiteSpace(_msgText)) return;
        DashSvc.SendMessage(_msgUserId.Value, _msgRecipientId, _msgText.Trim());
        _msgText        = "";
        _msgRecipientId = 0;
        _msgStatus      = LS.T("msg.sentSuccess");
        _msgStatusIsError = false;
    }

    void MsgKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SendMessage();
    }

    void AcknowledgeMsg(int messageId)
    {
        DashSvc.AcknowledgeMessage(messageId);
        _pendingMessages = _pendingMessages.Where(m => m.Id != messageId).ToList();
        _pendingMsgCount = _pendingMessages.Count;
    }

    static string FormatMsgTime(string isoDate)
    {
        if (DateTime.TryParse(isoDate, out var dt))
        {
            var diff = DateTime.UtcNow - dt;
            if (diff.TotalMinutes < 1) return "now";
            if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
            if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
            return dt.ToString("dd/MM HH:mm");
        }
        return isoDate;
    }

    // ── Add PC ──
    void SaveNewPc((string FirstName, string LastName, string Phone, string Email,
                    string DateOfBirth, string Gender, int OrgId, string Source,
                    string Notes, int CourseId, string Nick) d)
    {
        var dup = PcSvc.CheckDuplicatePc(d.FirstName, d.LastName, d.Nick);
        if (dup == "ACTIVE_DUPLICATE") return; // modal validation should catch this
        PcSvc.AddPcWithPerson(d.FirstName, d.LastName, d.Phone, d.Email,
            d.DateOfBirth, d.Gender, orgId: d.OrgId > 0 ? d.OrgId : null, notes: d.Notes, nick: d.Nick);
        // Refresh duplicate-detection set
        _existingPcNames = new HashSet<string>(
            PcSvc.GetAllPcs().Select(p => p.FullName), StringComparer.OrdinalIgnoreCase);
        NavigationManager.NavigateTo("/PCs", forceLoad: true);
    }

}