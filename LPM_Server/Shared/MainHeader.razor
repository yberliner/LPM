    // ── Scan Inbox (PWA share target) ──
    string _inboxMessage = "";

    // Strip the ses_/att_ prefix from inbox filenames to get the clean name
    static string StripInboxPrefix(string fileName)
    {
        var name = Path.GetFileNameWithoutExtension(fileName);
        if (name.StartsWith("ses_", StringComparison.OrdinalIgnoreCase))
            name = name[4..];
        else if (name.StartsWith("att_", StringComparison.OrdinalIgnoreCase))
            name = name[4..];
        return name;
    }

    void LoadInboxFiles()
    {
        _inboxMessage = "";
        try
        {
            Console.WriteLine($"[ScanInbox] LoadInboxFiles for user='{_logUsername}'");
            var inboxFiles = FolderSvc.GetScanInboxFiles(_logUsername);
            Console.WriteLine($"[ScanInbox] Found {inboxFiles.Count} file(s)");

            if (inboxFiles.Count == 0) return;

            int sesCount = 0, attCount = 0;
            foreach (var (name, data, isAtt) in inboxFiles)
            {
                Console.WriteLine($"[ScanInbox]   '{name}' ({data.Length} bytes, att={isAtt})");
                if (isAtt)
                {
                    var cleanAttName = StripInboxPrefix(name) + ".pdf";
                    AddAttachmentFile(cleanAttName, data);
                    attCount++;
                }
                else if (_importSessionBytes == null)
                {
                    var cleanName = StripInboxPrefix(name);
                    SetSessionFile(cleanName + ".pdf", data);
                    sesCount++;
                }
            }
            Console.WriteLine($"[ScanInbox] Loaded: {sesCount} session, {attCount} attachment(s)");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ScanInbox] LoadInboxFiles FAILED: {ex}");
        }
    }

    void PickFromInbox()
    {
        _inboxMessage = "";
        try
        {
            var inboxFiles = FolderSvc.GetScanInboxFiles(_logUsername);
            Console.WriteLine($"[ScanInbox] PickFromInbox: user='{_logUsername}', found={inboxFiles.Count}");

            if (inboxFiles.Count == 0)
            {
                _inboxMessage = "Inbox is empty";
                return;
            }

            int sesCount = 0, attCount = 0;
            foreach (var (name, data, isAtt) in inboxFiles)
            {
                if (isAtt)
                {
                    var cleanAttName = StripInboxPrefix(name) + ".pdf";
                    if (!_importAttachmentBytes.Any(a => a.Name == cleanAttName))
                    {
                        AddAttachmentFile(cleanAttName, data);
                        attCount++;
                    }
                }
                else
                {
                    var cleanName = StripInboxPrefix(name);
                    SetSessionFile(cleanName + ".pdf", data);
                    sesCount++;
                }
            }

            var parts = new List<string>();
            if (sesCount > 0) parts.Add($"{sesCount} session file");
            if (attCount > 0) parts.Add($"{attCount} attachment{(attCount > 1 ? "s" : "")}");
            _inboxMessage = parts.Count > 0 ? $"Loaded {string.Join(" + ", parts)} from inbox" : "No new files in inbox";
        }
        catch (Exception ex)
        {
            _inboxMessage = $"Error: {ex.Message}";
            Console.WriteLine($"[ScanInbox] PickFromInbox FAILED: {ex}");
        }
    }

