<SpkNewPersonModal @ref="_addPcModal" Title="@LS.T("pcs.addNewPc")" RequireAllFields="true"
                   ExistingFullNames="@_existingPcNames"
                   OnSaved="SaveNewPc" />

@* ── Assign PC modal ── *@
@if (_showAssignPcModal)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;"
         @onclick="CloseAssignPcModal">
        <div class="modal-dialog modal-dialog-centered modal-lg apc-modal-dialog"
             @onclick:stopPropagation="true">
            <div class="modal-content apc-modal-content">
                <div class="modal-header py-2 apc-modal-header">
                    <h5 class="modal-title fs-15 text-white">
                        <i class="ri-shield-user-line me-2"></i>Manage PC Assignments
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="CloseAssignPcModal"></button>
                </div>
                <div class="modal-body p-0" style="display:flex;flex-direction:column;overflow:hidden;min-height:0;flex:1;">
                    @{
                        var myPcIds2 = _apcMyPcs.Select(p => p.PcId).ToHashSet();
                        var searchResults = (string.IsNullOrWhiteSpace(_apcSearch)
                            ? _apcAllPcs
                            : _apcAllPcs
                                .Where(p => p.FullName.Contains(_apcSearch, StringComparison.OrdinalIgnoreCase)
                                            || p.Nick.Contains(_apcSearch, StringComparison.OrdinalIgnoreCase)))
                            .Where(p => p.PcId != _apcUserId)
                            .ToList();
                        bool isFiltering = !string.IsNullOrWhiteSpace(_apcSearch);
                    }
                    <div class="apc-search-bar px-3 pt-3 pb-2">
                        <div class="input-group">
                            <span class="input-group-text apc-search-icon"><i class="ri-search-line"></i></span>
                            <input class="form-control apc-search-input"
                                   placeholder="Type to filter, or scroll to browse all PCs..."
                                   @bind="_apcSearch" @bind:event="oninput" />
                            @if (!string.IsNullOrEmpty(_apcSearch))
                            {
                                <button class="btn btn-outline-secondary apc-clear-btn"
                                        @onclick='() => _apcSearch = ""' title="Clear filter">
                                    <i class="ri-close-line"></i>
                                </button>
                            }
                        </div>
                        @if (isFiltering)
                        {
                            <div class="apc-filter-hint">
                                <i class="ri-filter-line me-1"></i>@searchResults.Count result@(searchResults.Count != 1 ? "s" : "") for "@_apcSearch"
                            </div>
                        }
                    </div>
                    <div class="apc-search-results">
                        @if (searchResults.Count == 0)
                        {
                            <div class="apc-search-empty">No PCs match "@_apcSearch"</div>
                        }
                        @foreach (var pc in searchResults)
                        {
                            var alreadyAdded = myPcIds2.Contains(pc.PcId);
                            <div class="apc-search-item @(alreadyAdded ? "apc-search-item-added" : "")"
                                 @onclick="async () => { if (!alreadyAdded) await ApcAddPcFromModal(pc.PcId); }">
                                <i class="ri-user-line me-2 opacity-50"></i>
                                <span class="apc-item-name">@pc.FullName</span>
                                @if (!string.IsNullOrEmpty(pc.Nick))
                                {
                                    <span class="apc-nick"> (@pc.Nick)</span>
                                }
                                @if (alreadyAdded)
                                {
                                    <span class="ms-auto apc-already-badge">Added</span>
                                }
                                else
                                {
                                    <i class="ri-add-circle-line ms-auto apc-add-icon"></i>
                                }
                            </div>
                        }
                    </div>
                    @{
                        var assignedGroups = _apcMyPcs
                            .GroupBy(p => p.PcId)
                            .Select(g => new {
                                PcId = g.Key,
                                FullName = g.First().FullName,
                                Nick = g.First().Nick,
                                HasAuditor = g.Any(p => p.WorkCapacity == "Auditor"),
                                HasCS = g.Any(p => p.WorkCapacity == "CS"),
                                IsPending = _apcUnapproved.Contains(g.Key)
                            })
                            .OrderBy(x => x.FullName)
                            .ToList();
                    }
                    @if (assignedGroups.Count == 0)
                    {
                        <div class="apc-empty text-center text-muted py-4">
                            <i class="ri-inbox-line d-block mb-2" style="font-size:2rem;opacity:.4;"></i>
                            No PCs assigned yet. Search above to add one.
                        </div>
                    }
                    else
                    {
                        <div class="apc-table-wrap">
                            <table class="apc-table w-100">
                                <thead>
                                    <tr>
                                        <th class="apc-th-pc">PC / Person</th>
                                        @if (_apcIsAuditor) { <th class="apc-th-role">Auditor</th> }
                                        @if (_apcIsCS)      { <th class="apc-th-role">CS</th> }
                                        <th class="apc-th-remove"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ int apcRowIdx = 0; }
                                    @foreach (var item in assignedGroups)
                                    {
                                        var ri = apcRowIdx++;
                                        <tr id="apc-row-@item.PcId"
                                            class="apc-row @(item.IsPending ? "apc-row-pending" : "") @(item.PcId == _apcNewPcId ? "apc-row-new" : "")"
                                            style="animation-delay:@(ri * 35)ms">
                                            <td class="apc-td-pc">
                                                @if (item.IsPending)
                                                {
                                                    <i class="ri-time-line me-2" style="color:#f59e0b;opacity:.7;"></i>
                                                }
                                                else
                                                {
                                                    <i class="ri-user-line me-2 opacity-40"></i>
                                                }
                                                <span>@item.FullName</span>
                                                @if (!string.IsNullOrEmpty(item.Nick))
                                                {
                                                    <span class="apc-nick"> (@item.Nick)</span>
                                                }
                                                @if (item.IsPending)
                                                {
                                                    <span class="apc-pending-badge ms-2">⏳ Pending</span>
                                                }
                                            </td>
                                            @if (_apcIsAuditor)
                                            {
                                                <td class="apc-td-role">
                                                    <button class="apc-role-pill @(item.HasAuditor ? "apc-pill-active-aud" : "apc-pill-inactive")"
                                                            title="@(item.HasAuditor ? "Remove Auditor role" : "Add as Auditor")"
                                                            @onclick='async () => await ApcTogglePcRole(item.PcId, "Auditor", item.HasAuditor)'>
                                                        <i class="@(item.HasAuditor ? "ri-checkbox-circle-fill" : "ri-add-circle-line") me-1"></i>Aud
                                                    </button>
                                                </td>
                                            }
                                            @if (_apcIsCS)
                                            {
                                                <td class="apc-td-role">
                                                    <button class="apc-role-pill @(item.HasCS ? "apc-pill-active-cs" : "apc-pill-inactive")"
                                                            title="@(item.HasCS ? "Remove CS role" : "Add as CS")"
                                                            @onclick='async () => await ApcTogglePcRole(item.PcId, "CS", item.HasCS)'>
                                                        <i class="@(item.HasCS ? "ri-checkbox-circle-fill" : "ri-add-circle-line") me-1"></i>CS
                                                    </button>
                                                </td>
                                            }
                                            <td class="apc-td-remove">
                                                <button class="apc-remove-btn" title="Remove all roles for this PC"
                                                        @onclick="async () => await ApcRemovePcAllRoles(item.PcId)">
                                                    <i class="ri-delete-bin-line"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Upload to Front Cover modal ── *@
@if (_showUploadFrontCover)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;"
         @onclick="() => _showUploadFrontCover = false">
        <div class="modal-dialog modal-dialog-centered modal-md"
             @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#1e293b; color:#e2e8f0; border:1px solid #334155;">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#065f46,#10b981); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-upload-cloud-2-line"></i>Upload to Front Cover
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showUploadFrontCover = false"></button>
                </div>
                <div class="modal-body">
                    @if (_ufcSuccess)
                    {
                        <div class="ufc-success-content @(_ufcFading ? "ufc-fading" : "")"
                             style="text-align:center; padding:36px 16px 28px;">
                            <div class="ufc-success-wrap">
                                <div class="ufc-ripple"></div>
                                <div class="ufc-ripple ufc-ripple-2"></div>
                                <div class="ufc-ripple ufc-ripple-3"></div>
                                <div class="ufc-success-circle">
                                    <i class="ri-check-line"></i>
                                </div>
                            </div>
                            <div style="color:#10b981; font-weight:700; font-size:1rem; margin-top:18px; letter-spacing:.01em;">
                                Uploaded successfully!
                            </div>
                            <div style="color:#e2e8f0; font-size:.85rem; margin-top:8px; font-weight:600;">@_ufcSuccessPcName</div>
                            <div style="color:#64748b; font-size:.75rem; margin-top:3px;">@_ufcSuccessFileName</div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                            <select class="form-select form-select-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                    value="@_ufcPcId" @onchange="OnUfcPcChanged">
                                <option value="0">— Choose a PC —</option>
                                @foreach (var pc in _ufcAllPcs)
                                {
                                    <option value="@pc.PcId">@pc.FullName</option>
                                }
                            </select>
                        </div>

                        @if (_ufcPcId > 0)
                        {
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">
                                    File <span class="text-danger">*</span> <span class="text-muted">(PDF)</span>
                                </label>
                                <InputFile accept=".pdf" OnChange="OnUfcFileSelected"
                                           class="form-control form-control-sm"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                            </div>

                            @if (_ufcFile != null)
                            {
                                <div class="imp-file-card @(_ufcDuplicate ? "imp-file-dup imp-shake" : "")">
                                    <i class="ri-file-pdf-2-line" style="color:@(_ufcDuplicate ? "#ef4444" : "#10b981");"></i>
                                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @_ufcFile.Name
                                    </span>
                                    <span style="color:#64748b; font-size:.7rem;">@FormatFileSize(_ufcFile.Size)</span>
                                </div>
                                @if (_ufcDuplicate)
                                {
                                    <div class="imp-dup-msg">
                                        <i class="ri-error-warning-fill me-1"></i>A file with this name already exists in this PC's Front Cover. Rename the file and try again.
                                    </div>
                                }
                            }
                        }

                        @if (!string.IsNullOrEmpty(_ufcError))
                        {
                            <div class="alert alert-danger py-1 mt-2" style="font-size:.82rem;">@_ufcError</div>
                        }
                    }
                </div>
                @if (!_ufcSuccess)
                {
                <div class="modal-footer py-2" style="border-top:1px solid #334155;">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showUploadFrontCover = false">Cancel</button>
                    <button class="btn btn-sm btn-success d-flex align-items-center gap-1"
                            disabled="@(_ufcPcId == 0 || _ufcFile == null || _ufcDuplicate || _ufcBusy)"
                            @onclick="DoUploadFrontCover">
                        @if (_ufcBusy)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <i class="ri-upload-cloud-2-line"></i>
                        }
                        Go
                    </button>
                </div>
                }
            </div>
        </div>
    </div>
}

@* ── Add Session Wizard ── *@
@if (_showImportWizard)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.5); z-index:9999;">
        <div class="modal-dialog modal-dialog-centered @(_importStep >= 2 ? "modal-lg" : "modal-md")"
             @onclick:stopPropagation="true">
            <div class="modal-content" style="background:#1e293b; color:#e2e8f0; border:1px solid #334155;">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1565c0,#1e88e5); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-upload-2-line"></i>Add Session
                    </h5>
                    <div class="d-flex align-items-center gap-2 ms-auto me-2">
                        @if (_importStep >= 2 && _importPcId > 0)
                        {
                            <div style="position:relative;">
                                <button class="btn btn-sm py-0 px-2"
                                        style="background:rgba(255,255,255,.15); color:#e2e8f0; border:1px solid rgba(255,255,255,.25); font-size:.75rem; border-radius:4px;"
                                        @onclick="OpenRefBrowser"
                                        title="Open a reference file from this PC's folder">
                                    <i class="ri-eye-line me-1"></i>Reference
                                </button>
                                @if (_refBrowserOpen)
                                {
                                    <div style="position:absolute; right:0; top:calc(100% + 6px);
                                                background:#1e293b; border:1px solid #3b82f6; border-radius:6px;
                                                min-width:290px; max-height:320px; overflow-y:auto;
                                                z-index:10001; box-shadow:0 8px 24px rgba(0,0,0,.6);"
                                         @onclick:stopPropagation="true">
                                        <div style="padding:6px 10px; border-bottom:1px solid #334155;
                                                    font-size:.73rem; color:#94a3b8;
                                                    display:flex; justify-content:space-between; align-items:center;">
                                            <span><i class="ri-folder-open-line me-1"></i>Choose reference file</span>
                                            <button class="btn btn-sm p-0" style="color:#94a3b8; line-height:1;"
                                                    @onclick="() => _refBrowserOpen = false">
                                                <i class="ri-close-line"></i>
                                            </button>
                                        </div>
                                        @if (!_refFileList.Any())
                                        {
                                            <div style="padding:14px; color:#64748b; font-size:.8rem; text-align:center;">
                                                No files found in Front/Back Cover
                                            </div>
                                        }
                                        else
                                        {
                                            @foreach (var grp in _refFileList.GroupBy(f => f.Section))
                                            {
                                                <div style="padding:4px 10px; font-size:.68rem; color:#64748b;
                                                            text-transform:uppercase; letter-spacing:.5px;
                                                            background:rgba(255,255,255,.03); border-bottom:1px solid #0f172a;">
                                                    <i class="ri-folder-line me-1"></i>@grp.Key
                                                </div>
                                                @foreach (var f in grp)
                                                {
                                                    var rf = f;
                                                    <button class="btn btn-sm w-100 text-start px-3 py-1"
                                                            style="color:#e2e8f0; font-size:.8rem; border-radius:0;
                                                                   border:none; background:transparent; border-bottom:1px solid #0f172a;"
                                                            @onclick="async () => await OpenRefFile(rf.RelPath, rf.Name)">
                                                        <i class="ri-file-pdf-2-line me-2" style="color:#ef5350;"></i>@rf.Name
                                                    </button>
                                                }
                                            }
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showImportWizard = false"></button>
                </div>
                <div class="modal-body">

                    @* ── Stepper ── *@
                    <div class="wiz-stepper mb-3">
                        @{
                            var stepLabels = new[] { "Choose PC", "Fill ARF", "Next C/S" };
                        }
                        @for (int s = 1; s <= 3; s++)
                        {
                            var sn = s;
                            var lbl = stepLabels[sn - 1];
                            var isDone   = _importStep > sn;
                            var isActive = _importStep == sn;
                            var cls = isActive ? "wiz-active" : isDone ? "wiz-done" : "wiz-future";
                            <div class="wiz-step @cls">
                                <div class="wiz-circle">
                                    @if (isDone) { <i class="ri-check-line"></i> }
                                    else { @sn }
                                </div>
                                <div class="wiz-label">@lbl</div>
                            </div>
                            @if (sn < 3)
                            {
                                <div class="wiz-conn @(isDone ? "wiz-conn-done" : "")"></div>
                            }
                        }
                    </div>

                    @if (_importStep == 1)
                    {
                        @* ── Step 1: Select PC + Files ── *@
                        @if (!_isSoloUser && _approvedPcs.Count == 0)
                        {
                            <div class="act-noperm-screen" style="padding:28px 16px 20px;">
                                <div class="act-noperm-icon-wrap">
                                    <div class="act-noperm-ring" style="border-color:rgba(220,38,38,.25);"></div>
                                    <i class="ri-lock-line act-noperm-icon"></i>
                                </div>
                                <div class="act-noperm-title" style="color:#e2e8f0;">No Folders Assigned</div>
                                <div class="act-noperm-sub" style="color:#94a3b8;">You haven't been assigned to any PC folders yet.<br>Contact your administrator to request access.</div>
                            </div>
                        }
                        else
                        {
                        <div class="mb-3">
                            <label class="form-label" style="font-size:.82rem; color:#94a3b8;">PC</label>
                            @if (_isSoloUser)
                            {
                                <div class="form-control form-control-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;">
                                    @(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "Solo")
                                    <span class="badge bg-primary ms-2" style="font-size:.7rem;">Solo</span>
                                </div>
                            }
                            else
                            {
                                <select class="form-select form-select-sm" style="background:#0f172a; color:#e2e8f0; border-color:#475569;"
                                        value="@_importPcId" @onchange="OnPcChanged">
                                    <option value="0">— Choose a PC —</option>
                                    @foreach (var pc in _approvedPcs)
                                    {
                                        <option value="@pc.PcId">@pc.FullName</option>
                                    }
                                </select>
                            }
                        </div>

                        @if (_importPcId > 0)
                        {
                            <div class="mb-3 d-flex align-items-center gap-2">
                                <input type="checkbox" id="chk-free-session" class="form-check-input"
                                       checked="@_importFreeSession"
                                       @onchange="e => _importFreeSession = (bool)(e.Value ?? false)"
                                       style="accent-color:#3b82f6; cursor:pointer; width:1rem; height:1rem;" />
                                <label for="chk-free-session" class="form-check-label"
                                       style="font-size:.82rem; color:#94a3b8; cursor:pointer; user-select:none;">
                                    Free Session
                                </label>
                            </div>
                        }
                        } @* end else (has approved PCs) *@
                    }
                    else if (_importStep == 2)
                    {
                        @* ── Step 2: File Upload + Auditor Report Form ── *@

                        @* Files section *@
                        <div class="mb-2">
                            <div class="mb-3">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">
                                    Session File <span class="text-danger">*</span> <span class="text-muted">(PDF, single file)</span>
                                </label>
                                <InputFile accept=".pdf" OnChange="OnSessionFileSelected"
                                           class="form-control form-control-sm"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                            </div>

                            @if (_importSessionFile != null)
                            {
                                <div class="imp-file-card @(_importDuplicate ? "imp-file-dup imp-shake" : "")">
                                    <i class="ri-file-pdf-2-line" style="color:@(_importDuplicate ? "#ef4444" : "#3b82f6");"></i>
                                    <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                        @_importSessionFile.Name
                                    </span>
                                    <span style="color:#64748b; font-size:.7rem;">@FormatFileSize(_importSessionFile.Size)</span>
                                    <button class="btn btn-sm p-0" style="color:#ef5350; font-size:.85rem;"
                                            @onclick="ClearSessionFile">
                                        <i class="ri-close-line"></i>
                                    </button>
                                </div>
                                @if (_importDuplicate)
                                {
                                    <div class="imp-dup-msg">
                                        <i class="ri-error-warning-fill me-1"></i>@_importFileWarning
                                    </div>
                                }
                                @if (_importSessionFile != null)
                                {
                                    <div style="font-size:.75rem; margin-top:6px;">
                                        <div style="display:flex; align-items:center; gap:5px; flex-wrap:wrap;">
                                            <i class="ri-edit-line" style="color:#f59e0b;"></i>
                                            <span style="color:#f59e0b; white-space:nowrap;">Save as:</span>
                                            <div style="display:flex; align-items:center; gap:2px; flex:1; min-width:0;">
                                                <input type="text"
                                                       value="@_importNormalizedFileName"
                                                       @oninput="OnNormalizedNameChanged"
                                                       style="flex:1; min-width:0; background:#0f172a; color:#e2e8f0;
                                                              border:1px solid @(string.IsNullOrEmpty(_importNameEditError) ? "#475569" : "#ef4444");
                                                              border-radius:4px; padding:2px 6px; font-size:.75rem;" />
                                                <span style="color:#94a3b8; white-space:nowrap;">.pdf</span>
                                            </div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(_importNameEditError))
                                        {
                                            <div style="color:#ef4444; margin-top:3px; padding-left:18px;">
                                                <i class="ri-error-warning-line me-1"></i>@_importNameEditError
                                            </div>
                                        }
                                        @if (_importDateWasPrepended)
                                        {
                                            <div style="display:flex; align-items:center; gap:5px; margin-top:4px; padding-left:18px;">
                                                <i class="ri-calendar-line" style="color:#94a3b8;"></i>
                                                <span style="color:#94a3b8;">Change date:</span>
                                                <input type="date"
                                                       value="@_importNormalizedDate.ToString("yyyy-MM-dd")"
                                                       @onchange="OnNormalizedDateChanged"
                                                       style="background:#0f172a; color:#e2e8f0; border:1px solid #475569;
                                                              border-radius:4px; padding:1px 4px; font-size:.75rem; cursor:pointer;" />
                                            </div>
                                        }
                                    </div>
                                }
                            }

                            <div class="mb-2">
                                <label class="form-label" style="font-size:.82rem; color:#94a3b8;">
                                    Attachments <span class="text-muted">(optional, multiple PDFs)</span>
                                </label>
                                <InputFile multiple accept=".pdf" OnChange="OnAttachmentFilesSelected"
                                           class="form-control form-control-sm"
                                           style="background:#0f172a; color:#e2e8f0; border-color:#475569;" />
                            </div>

                            @if (_importAttachments.Count > 0)
                            {
                                <div class="mb-2">
                                    <div style="font-size:.78rem; color:#94a3b8;" class="mb-1">
                                        <i class="ri-attachment-line me-1"></i>@_importAttachments.Count attachment(s):
                                    </div>
                                    @foreach (var f in _importAttachments)
                                    {
                                        var file = f;
                                        <div class="d-flex align-items-center gap-2 py-1 px-2 mb-1"
                                             style="background:rgba(255,255,255,.05); border-radius:4px; font-size:.78rem;">
                                            <i class="ri-file-pdf-2-line" style="color:#ef5350;"></i>
                                            <span style="flex:1; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                                                @file.Name
                                            </span>
                                            <span style="color:#64748b; font-size:.7rem;">
                                                @FormatFileSize(file.Size)
                                            </span>
                                            <button class="btn btn-sm p-0" style="color:#ef5350; font-size:.85rem;"
                                                    @onclick="() => _importAttachments.Remove(file)">
                                                <i class="ri-close-line"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                        <hr style="border-color:#334155; margin:4px 0 12px;" />

                        <div class="arf">
                            <div class="arf-subtitle">Dror Center, Haifa, Israel</div>
                            <div class="arf-title">Auditor Report Form</div>

                            @* Row 1: PC's Name + Date *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">PC's Name</span>
                                    <span class="arf-val">@(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "")</span>
                                </div>
                                <div class="arf-field">
                                    <span class="arf-lbl arf-lbl-right-fixed">Date</span>
                                    <span class="arf-val">@DateTime.Today.ToString("dd/MM/yyyy")</span>
                                </div>
                            </div>

                            @* Row 2: PC's Grade + Session Length *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">PC's Grade</span>
                                    <input type="text" class="form-control form-control-sm arf-input-short"
                                           @bind="_arfGrade" @bind:event="oninput" />
                                </div>
                                <div class="arf-field">
                                    <span class="arf-lbl arf-lbl-right-fixed">Session Length</span>
                                    <input type="text" inputmode="numeric" maxlength="5"
                                           class="form-control form-control-sm arf-input-xs arf-time-input @(!IsValidArfTime(_arfSessionLength) ? "arf-invalid" : "")"
                                           placeholder="H:MM"
                                           value="@_arfSessionLength"
                                           @oninput="e => _arfSessionLength = e.Value?.ToString() ?? string.Empty"
                                           @onchange="e => _arfSessionLength = FormatArfTime(e.Value?.ToString()?.Trim() ?? string.Empty)" />
                                </div>
                            </div>

                            @* Row 3: Admin Time + Total TA *@
                            <div class="arf-row">
                                <div class="arf-field arf-left-col">
                                    <span class="arf-lbl arf-lbl-fixed">
                                        Admin Time
                                        @if (string.IsNullOrWhiteSpace(_arfAdminTime))
                                        {
                                            <span style="color:#ef4444;font-weight:700;margin-left:2px;">*</span>
                                        }
                                    </span>
                                    <input type="text" inputmode="numeric" maxlength="5"
                                           class="form-control form-control-sm arf-input-short arf-time-input @(!IsValidArfTime(_arfAdminTime) ? "arf-invalid" : "")"
                                           style="@(string.IsNullOrWhiteSpace(_arfAdminTime) ? "border:2px solid #ef4444 !important;background:rgba(239,68,68,.08) !important;" : "")"
                                           placeholder="H:MM"
                                           value="@_arfAdminTime"
                                           @oninput="e => _arfAdminTime = e.Value?.ToString() ?? string.Empty"
                                           @onchange="e => _arfAdminTime = FormatArfTime(e.Value?.ToString()?.Trim() ?? string.Empty)" />
                                </div>
                                <div class="arf-field">
                                    <span class="arf-lbl arf-lbl-right-fixed">Total TA</span>
                                    <input type="number" step="any"
                                           class="form-control form-control-sm arf-input-xs"
                                           @bind="_arfTotalTa" @bind:event="oninput" />
                                </div>
                            </div>

                            @* ── Table: Process / Time / Tone Arm Reads / Results and Comments ── *@
                            <table class="arf-table">
                                <thead>
                                    <tr>
                                        <th style="width:3%;"></th>
                                        <th style="width:37%;">Process</th>
                                        <th style="width:10%;">Time</th>
                                        <th style="width:10%;">Tone Arm<br/>Reads</th>
                                        <th style="width:37%;">Results and Comments</th>
                                        <th style="width:3%;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < _arfRows.Count; i++)
                                    {
                                        var idx = i;
                                        <tr>
                                            <td style="text-align:center; vertical-align:middle;">
                                                <input type="checkbox" checked="@_arfRows[idx].Checked"
                                                       @onchange="e => { _arfRows[idx].Checked = (bool)(e.Value ?? false); RebuildArfSummary(); }"
                                                       style="accent-color:#3b82f6; cursor:pointer;" />
                                            </td>
                                            <td>
                                                <input type="text" id="arf-process-@idx"
                                                       class="arf-cell-input @(_arfRows[idx].Touched && string.IsNullOrWhiteSpace(_arfRows[idx].Process) ? "arf-cell-invalid" : "")"
                                                       value="@_arfRows[idx].Process"
                                                       @onblur="() => _arfRows[idx].Touched = true"
                                                       @oninput="e => { _arfRows[idx].Process = e.Value?.ToString() ?? string.Empty; var _kw = HasAutoUncheckKeyword(_arfRows[idx].Process); if (!_kw) _arfRows[idx].AutoUnchecked = false; if (_kw && !_arfRows[idx].AutoUnchecked && _arfRows[idx].Checked) { _arfRows[idx].Checked = false; _arfRows[idx].AutoUnchecked = true; } RebuildArfSummary(); }"/>
                                            </td>
                                            <td>
                                                <input type="text" inputmode="numeric" maxlength="5"
                                                       class="arf-cell-input arf-cell-center arf-time-input @(!IsValidArfTime(_arfRows[idx].Time) || !IsArfTimeOrdered(idx) || (_arfRows[idx].Touched && string.IsNullOrWhiteSpace(_arfRows[idx].Time)) ? "arf-cell-invalid" : "")"
                                                       placeholder="HH:MM"
                                                       value="@_arfRows[idx].Time"
                                                       @onblur="() => _arfRows[idx].Touched = true"
                                                       @onchange="e => SetArfTimeCell(idx, e)"/>
                                            </td>
                                            <td>
                                                <input type="number" step="any"
                                                       class="arf-cell-input arf-cell-center"
                                                       value="@_arfRows[idx].ToneArm"
                                                       @onchange="e => SetArfCell(idx, 2, e)"/>
                                            </td>
                                            <td>
                                                <input type="text" class="arf-cell-input"
                                                       value="@_arfRows[idx].Results"
                                                       @oninput="e => { _arfRows[idx].Results = e.Value?.ToString() ?? string.Empty; RebuildArfSummary(); }"
                                                       @onkeydown="e => OnArfResultsKeyDown(e)"/>
                                            </td>
                                            <td style="text-align:center; vertical-align:middle;">
                                                @if (_arfRows.Count > 1)
                                                {
                                                    <button class="btn btn-sm p-0 arf-del-row-btn" title="Delete row"
                                                            @onclick="() => RemoveArfRow(idx)">
                                                        <i class="ri-close-line"></i>
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                            <button class="btn btn-sm arf-add-row-btn" @onclick="AddArfRow"
                                    disabled="@(!CanAddArfRow)">
                                <i class="ri-add-line me-1"></i>Add Row
                            </button>

                            @* ── TA Range at bottom *@
                            <div class="arf-row mt-3">
                                <div class="arf-field">
                                    <span class="arf-lbl">TA Range</span>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="text" inputmode="decimal" id="arf-ta-from"
                                               class="form-control form-control-sm arf-input-short"
                                               placeholder="from"
                                               value="@_arfTaRangeFrom"
                                               @oninput="SetTaRangeFrom" />
                                        <span style="font-weight:600;">-</span>
                                        <input type="text" inputmode="decimal" id="arf-ta-to"
                                               class="form-control form-control-sm arf-input-short"
                                               placeholder="to"
                                               value="@_arfTaRangeTo"
                                               @oninput="SetTaRangeTo" />
                                    </div>
                                </div>
                            </div>

                            @* ── Exam Report ── *@
                            <div class="arf-row mt-2">
                                <div class="arf-field">
                                    <span class="arf-lbl">Exam report</span>
                                    <div class="d-flex gap-2">
                                        @foreach (var opt in new[] { "F/N", "RT", "YT", "PT" })
                                        {
                                            var examColor = opt switch {
                                                "F/N" => "#16a34a",
                                                "RT"  => "#dc2626",
                                                "YT"  => "#ca8a04",
                                                "PT"  => "#db2777",
                                                _     => "#64748b"
                                            };
                                            <button class="btn btn-sm @(_arfExamReport == opt ? "" : "btn-outline-secondary")"
                                                    style="@(_arfExamReport == opt ? $"background:{examColor};border-color:{examColor};color:#fff;font-weight:600;" : $"color:{examColor};border-color:{examColor};")"
                                                    @onclick="() => { _arfExamReport = opt; RebuildArfSummary(); }">
                                                @opt
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* ── Summary (auto-built from checked rows, also editable with rich text) ── *@
                            <div class="mt-3">
                                <span class="arf-lbl">Summary</span>
                                <div id="arf-summary-wrap">
                                    <div id="arf-summary-editor"></div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        @* ── Step 3: Next C/S Sheet ── *@
                        <div class="arf" style="display:flex; flex-direction:column; min-height:480px;">
                            <div class="arf-subtitle">Dror Center, Haifa, Israel</div>

                            @* extra line *@
                            <div style="height:.9rem;"></div>

                            @* PC Name + Date row — big, red, ":" labels, Date tight *@
                            <div style="display:flex; justify-content:space-between; align-items:baseline; flex-wrap:wrap; gap:8px;">
                                <span style="font-size:1.35rem; font-weight:600; color:#e2e8f0;">
                                    PC's Name:&nbsp;<span style="color:#ef4444;">@(_approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? "")</span>
                                </span>
                                <span style="font-size:1.35rem; font-weight:600; color:#e2e8f0;">
                                    Date:&nbsp;<span style="color:#ef4444;">@DateTime.Today.ToString("dd/MM/yyyy")</span>
                                </span>
                            </div>

                            @* Auditor row — aligned left, same size *@
                            <div style="font-size:1.35rem; font-weight:600; color:#e2e8f0; margin-top:4px;">
                                Auditor:&nbsp;<span style="color:#ef4444;">@(string.IsNullOrWhiteSpace(_importAuditorFullName) ? _logUsername : _importAuditorFullName)</span>
                            </div>

                            @* Free text — above "The Next C/S:" *@
                            <div class="mt-2">
                                <div id="step3-top-editor"></div>
                            </div>

                            @* ~20% spacer *@
                            <div style="min-height:32px;"></div>

                            @* The Next C/S: — centred, bold, underlined *@
                            <div style="text-align:center; font-size:1.7rem; font-weight:700;
                                        text-decoration:underline; color:#e2e8f0; padding:8px 0;">
                                The Next C/S:
                            </div>

                            @* Free text — below "The Next C/S:" *@
                            <div class="mt-2">
                                <div id="step3-bottom-editor"></div>
                            </div>

                            @* lower spacer *@
                            <div style="min-height:32px;"></div>

                            @* Auditor signature — bottom right, big, red *@
                            <div style="text-align:right; color:#ef4444; font-weight:600;
                                        font-size:1.35rem; margin-top:16px;">
                                @(string.IsNullOrWhiteSpace(_importAuditorFullName) ? _logUsername : _importAuditorFullName)
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_importError))
                    {
                        <div class="alert alert-danger py-1 mb-2" style="font-size:.8rem;">
                            <i class="ri-error-warning-line me-1"></i>@_importError
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_importSuccess))
                    {
                        <div class="alert alert-success py-1 mb-2" style="font-size:.8rem;">
                            <i class="ri-check-double-line me-1"></i>@_importSuccess
                        </div>
                    }
                </div>
                <div class="modal-footer py-2" style="border-color:#334155;">
                    @if (_importStep == 1)
                    {
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showImportWizard = false">Cancel</button>
                        @if (_isSoloUser || _approvedPcs.Count > 0)
                        {
                            <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                    disabled="@(_importPcId == 0)"
                                    @onclick="GoToExamStep">
                                Next <i class="ri-arrow-right-s-line"></i>
                            </button>
                        }
                    }
                    else if (_importStep == 2)
                    {
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                @onclick="() => _importStep = 1">
                            <i class="ri-arrow-left-s-line"></i> Back
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showImportWizard = false">Cancel</button>
                        <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                disabled="@(_importSessionBytes == null || _importDuplicate || !string.IsNullOrEmpty(_importNameEditError) || string.IsNullOrEmpty(_importNormalizedFileName) || ArfHasTimeErrors || !IsValidArfTime(_arfAdminTime) || string.IsNullOrWhiteSpace(_arfAdminTime) || !IsValidArfTime(_arfSessionLength) || ArfHasIncompleteRows)"
                                @onclick="GoToStep3">
                            Next <i class="ri-arrow-right-s-line"></i>
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                @onclick="() => _importStep = 2">
                            <i class="ri-arrow-left-s-line"></i> Back
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => _showImportWizard = false">Cancel</button>
                        <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                @onclick="ExecuteImport">
                            <i class="ri-upload-2-line"></i>
                            Go
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Background Import Toast ── *@
@if (_bgImportRunning || _bgImportDone || !string.IsNullOrEmpty(_bgImportError))
{
    var _bgDoneCount  = _bgSteps.Count(s => s.Status == 2);
    var _bgTotalCount = _bgSteps.Count;
    var _bgPct        = _bgTotalCount > 0 ? (int)(_bgDoneCount * 100.0 / _bgTotalCount) : 0;

    <div style="position:fixed;bottom:24px;right:24px;z-index:99999;min-width:310px;max-width:390px;
                border-radius:14px;box-shadow:0 16px 48px rgba(0,0,0,.45);
                background:#0f172a;color:#f1f5f9;overflow:hidden;
                animation:bgImportSlideIn .3s cubic-bezier(.175,.885,.32,1.275) both;">
        <style>
            @@keyframes bgImportSlideIn { from{opacity:0;transform:translateY(24px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
            @@keyframes bgBarPulse { 0%,100%{opacity:1} 50%{opacity:.65} }
        </style>

        @* ── Header ── *@
        <div style="padding:13px 16px 11px;border-bottom:1px solid #1e293b;display:flex;align-items:center;gap:10px;">
            @if (_bgImportRunning)
            {
                <span class="spinner-border spinner-border-sm flex-shrink-0" style="color:#60a5fa;width:15px;height:15px;border-width:2px;"></span>
            }
            else if (_bgImportDone)
            {
                <i class="ri-checkbox-circle-fill flex-shrink-0" style="font-size:1.15rem;color:#22c55e;line-height:1;"></i>
            }
            else
            {
                <i class="ri-error-warning-fill flex-shrink-0" style="font-size:1.15rem;color:#f87171;line-height:1;"></i>
            }
            <div style="flex:1;min-width:0;">
                <div style="font-weight:700;font-size:.875rem;letter-spacing:.01em;line-height:1.3;">
                    @if (_bgImportRunning)      { <text>Uploading Session&hellip;</text> }
                    else if (_bgImportDone)     { <span style="color:#22c55e;">Session Imported!</span> }
                    else                        { <span style="color:#f87171;">Import Failed</span> }
                </div>
                <div style="font-size:.71rem;color:#475569;margin-top:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@_bgImportLabel">
                    @_bgImportLabel
                </div>
            </div>
        </div>

        @* ── Step list (running or done) ── *@
        @if (_bgImportRunning || _bgImportDone)
        {
            <div style="padding:10px 16px 4px;display:flex;flex-direction:column;gap:5px;">
                @foreach (var _bgStep in _bgSteps)
                {
                    var _sc = _bgStep.Status switch {
                        1 => "#e2e8f0",
                        2 => "#22c55e",
                        3 => "#f87171",
                        _ => "#334155"
                    };
                    <div style="display:flex;align-items:flex-start;gap:8px;font-size:.78rem;color:@_sc;">
                        <span style="width:14px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding-top:1px;">
                            @if (_bgStep.Status == 1)
                            {
                                <span class="spinner-border" style="width:10px;height:10px;border-width:1.5px;color:#60a5fa;flex-shrink:0;"></span>
                            }
                            else if (_bgStep.Status == 2)
                            {
                                <i class="ri-check-line" style="color:#22c55e;font-size:.8rem;"></i>
                            }
                            else if (_bgStep.Status == 3)
                            {
                                <i class="ri-close-line" style="color:#f87171;font-size:.8rem;"></i>
                            }
                            else
                            {
                                <span style="width:5px;height:5px;border-radius:50%;background:#1e293b;display:inline-block;"></span>
                            }
                        </span>
                        <div>
                            <div style="@(_bgStep.Status == 1 ? "font-weight:600;" : "")">@_bgStep.Label</div>
                            @if (!string.IsNullOrEmpty(_bgStep.SubLabel))
                            {
                                <div style="font-size:.7rem;color:@(_bgStep.Status == 3 ? "#f87171" : "#64748b");margin-top:1px;font-variant-numeric:tabular-nums;">@_bgStep.SubLabel</div>
                            }
                        </div>
                    </div>
                }
            </div>

            @* ── Progress bar ── *@
            <div style="margin:10px 16px 14px;height:3px;background:#1e293b;border-radius:2px;overflow:hidden;">
                <div style="height:100%;width:@(_bgPct)%;border-radius:2px;
                            background:linear-gradient(90deg,#2563eb,#60a5fa);
                            transition:width .35s ease;
                            @(_bgImportRunning && _bgPct < 100 ? "animation:bgBarPulse 1.8s ease-in-out infinite;" : "")"></div>
            </div>
        }
        else
        {
            @* ── Error detail ── *@
            <div style="padding:10px 16px 14px;">
                @if (_bgSteps.Any(s => s.Status == 3))
                {
                    <div style="display:flex;flex-direction:column;gap:5px;margin-bottom:8px;">
                        @foreach (var _bgStep in _bgSteps)
                        {
                            var _sc2 = _bgStep.Status switch { 2 => "#22c55e", 3 => "#f87171", 1 => "#60a5fa", _ => "#334155" };
                            <div style="display:flex;align-items:center;gap:8px;font-size:.77rem;color:@_sc2;">
                                <span style="width:14px;flex-shrink:0;text-align:center;">
                                    @if (_bgStep.Status == 2) { <i class="ri-check-line"></i> }
                                    else if (_bgStep.Status == 3) { <i class="ri-close-line"></i> }
                                    else { <span style="opacity:.4;">·</span> }
                                </span>
                                @_bgStep.Label
                            </div>
                        }
                    </div>
                }
                <div style="font-size:.75rem;color:#94a3b8;word-break:break-all;">@_bgImportError</div>
                <button class="btn btn-sm btn-outline-secondary mt-2" style="font-size:.72rem;padding:2px 10px;"
                        @onclick="() => { _bgImportError = string.Empty; _bgSteps.Clear(); }">Dismiss</button>
            </div>
        }
    </div>
}

@* ── Messages Modal ── *@
@if (_showMessagesModal)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45); z-index:9999;"
         @onclick="() => _showMessagesModal = false">
        <div class="modal-dialog modal-dialog-centered modal-md"
             @onclick:stopPropagation="true">
            <div class="modal-content hdr-msg-modal">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1a237e,#3949ab); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-mail-send-line"></i>@LS.T("msg.messages")
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showMessagesModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    @* ── Compose ── *@
                    <div class="hdr-msg-compose">
                        <div class="d-flex align-items-center gap-2">
                            <select class="form-select form-select-sm hdr-msg-select" @bind="_msgRecipientId">
                                <option value="0">@LS.T("msg.selectRecipient")</option>
                                @foreach (var s in _staffMembers.Where(s => s.PersonId != _msgUserId))
                                {
                                    <option value="@s.PersonId">@s.FullName</option>
                                }
                            </select>
                            <input class="form-control form-control-sm hdr-msg-input"
                                   placeholder="@LS.T("msg.typeMessage")"
                                   @bind="_msgText" @bind:event="oninput"
                                   @onkeydown="MsgKeyDown" />
                            <button class="btn btn-sm hdr-msg-send-btn" @onclick="SendMessage"
                                    disabled="@(_msgRecipientId == 0 || string.IsNullOrWhiteSpace(_msgText))">
                                <i class="ri-send-plane-2-fill"></i>
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_msgStatus))
                        {
                            <div class="hdr-msg-status @(_msgStatusIsError ? "text-danger" : "text-success")">
                                <i class="@(_msgStatusIsError ? "ri-error-warning-line" : "ri-check-line") me-1"></i>@_msgStatus
                            </div>
                        }
                    </div>

                    @* ── Inbox ── *@
                    <div class="hdr-msg-inbox-header">
                        <i class="ri-inbox-line me-1"></i>@LS.T("msg.inbox")
                        @if (_pendingMessages.Count > 0)
                        {
                            <span class="hdr-msg-inbox-count">@_pendingMessages.Count</span>
                            <button class="btn btn-sm hdr-msg-okall-btn ms-auto"
                                    @onclick="AcknowledgeAllMsgs">
                                <i class="ri-check-double-line me-1"></i>OK All
                            </button>
                        }
                    </div>
                    @if (_pendingMessages.Count == 0)
                    {
                        <div class="hdr-msg-empty">
                            <i class="ri-checkbox-circle-line"></i>
                            <span>@LS.T("msg.noMessages")</span>
                        </div>
                    }
                    else
                    {
                        <div class="hdr-msg-list">
                            @foreach (var msg in _pendingMessages)
                            {
                                <div class="hdr-msg-item">
                                    <div class="hdr-msg-item-content">
                                        <div class="hdr-msg-item-header">
                                            <span class="hdr-msg-from">
                                                <i class="ri-user-3-line me-1"></i>@msg.FromName
                                            </span>
                                            <span class="hdr-msg-time">@FormatMsgTime(msg.CreatedAt)</span>
                                        </div>
                                        <div class="hdr-msg-text">@msg.MsgText</div>
                                    </div>
                                    <button class="btn btn-sm hdr-msg-ack-btn"
                                            @onclick="() => AcknowledgeMsg(msg.Id)">
                                        <i class="ri-check-double-line me-1"></i>OK
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Open Folder Modal ── *@
@if (_showActionOpenFolder)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45); z-index:9999;"
         @onclick="() => _showActionOpenFolder = false">
        <div class="modal-dialog modal-dialog-centered modal-sm"
             @onclick:stopPropagation="true">
            <div class="modal-content" style="border:none; border-radius:16px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.25); background:#fff !important; color:#111827 !important;">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1565c0,#42a5f5); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-folder-open-line"></i>Open Folder
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => _showActionOpenFolder = false"></button>
                </div>
                <div class="modal-body" style="background:#fff !important;">
                    @if (!string.IsNullOrEmpty(_actionPermMsg))
                    {
                        <div class="alert alert-warning py-2 mb-3" style="font-size:.82rem;">
                            <i class="ri-lock-line me-1"></i>@_actionPermMsg
                        </div>
                    }
                    @if (_actionAllPcs.Count == 0)
                    {
                        <div class="act-noperm-screen">
                            <div class="act-noperm-icon-wrap">
                                <div class="act-noperm-ring"></div>
                                <i class="ri-lock-line act-noperm-icon"></i>
                            </div>
                            <div class="act-noperm-title">No Folders Assigned</div>
                            <div class="act-noperm-sub">You haven't been assigned to any PC folders yet.<br>Contact your administrator to request access.</div>
                        </div>
                    }
                    else
                    {
                        <label class="form-label" style="font-size:.82rem; color:#64748b;">Select PC</label>
                        <input type="text" class="form-control form-control-sm mb-2"
                               placeholder="Search PCs..."
                               style="border-color:#cbd5e1; background:#fff !important; color:#111827 !important;"
                               @bind="_actionPcSearch" @bind:event="oninput" />
                        <div style="max-height:280px; overflow-y:auto;">
                            @foreach (var pc in _actionAllPcs.Where(p => string.IsNullOrEmpty(_actionPcSearch) || p.FullName.Contains(_actionPcSearch, StringComparison.OrdinalIgnoreCase)))
                            {
                                var thisPc = pc;
                                @if (!(_isSoloUser && thisPc.IsAlsoSolo))
                                {
                                    <div class="act-pc-item" @onclick="() => OnActionFolderPcSelected(thisPc.PcId, _isSoloUser)">
                                        <i class="ri-user-line" style="color:#3b82f6; opacity:.6;"></i>
                                        <span>@thisPc.FullName</span>
                                    </div>
                                }
                                @if (thisPc.IsAlsoSolo)
                                {
                                    <div class="act-pc-item" @onclick="() => OnActionFolderPcSelected(thisPc.PcId, true)">
                                        <i class="ri-user-line" style="color:#ef4444; opacity:.7;"></i>
                                        <span>@thisPc.FullName</span>
                                        <span style="font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
                                                     color:#fff; background:linear-gradient(135deg,#ef4444,#b91c1c);
                                                     border-radius:999px; padding:2px 8px; margin-left:4px;">Solo</span>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@* ── Write to Folder Summary Modal ── *@
@if (_showActionSummary)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.45); z-index:9999;"
         @onclick="() => CloseActionSummary()">
        <div class="modal-dialog modal-dialog-centered modal-md"
             @onclick:stopPropagation="true">
            <div class="modal-content" style="border:none; border-radius:16px; overflow:hidden; box-shadow:0 20px 60px rgba(0,0,0,.25); background:#fff !important; color:#111827 !important;">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#6d28d9,#8b5cf6); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-file-edit-line"></i>Write to Folder Summary
                    </h5>
                    <button type="button" class="btn-close btn-close-white"
                            @onclick="() => CloseActionSummary()"></button>
                </div>
                <div class="modal-body" style="background:#fff !important;">
                    @if (!string.IsNullOrEmpty(_actionPermMsg))
                    {
                        <div class="alert alert-warning py-2 mb-3" style="font-size:.82rem;">
                            <i class="ri-lock-line me-1"></i>@_actionPermMsg
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_actionSuccessMsg))
                    {
                        <div class="alert alert-success py-2 mb-3" style="font-size:.82rem;">
                            <i class="ri-check-double-line me-1"></i>@_actionSuccessMsg
                        </div>
                    }

                    @if (_actionSummaryStep == 0)
                    {
                        <div class="act-success-screen">
                            <div class="act-success-ring"></div>
                            <div class="act-success-icon">
                                <i class="ri-check-line"></i>
                            </div>
                            <div class="act-success-title">Summary Saved!</div>
                            <div class="act-success-sub">
                                Added to <strong>@_actionSummaryPcName</strong>'s folder
                            </div>
                            <div class="act-success-sparkles">
                                <span class="act-spark" style="--d:0;--x:-40px;--y:-30px;"></span>
                                <span class="act-spark" style="--d:1;--x:45px;--y:-25px;"></span>
                                <span class="act-spark" style="--d:2;--x:-35px;--y:25px;"></span>
                                <span class="act-spark" style="--d:3;--x:40px;--y:30px;"></span>
                                <span class="act-spark" style="--d:4;--x:0px;--y:-45px;"></span>
                                <span class="act-spark" style="--d:5;--x:-50px;--y:0px;"></span>
                            </div>
                        </div>
                    }
                    else if (_actionSummaryStep == 1)
                    {
                        @if (_actionAllPcs.Count == 0)
                        {
                            <div class="act-noperm-screen">
                                <div class="act-noperm-icon-wrap">
                                    <div class="act-noperm-ring"></div>
                                    <i class="ri-lock-line act-noperm-icon"></i>
                                </div>
                                <div class="act-noperm-title">No Folders Assigned</div>
                                <div class="act-noperm-sub">You haven't been assigned to any PC folders yet.<br>Contact your administrator to request access.</div>
                            </div>
                        }
                        else
                        {
                            <label class="form-label" style="font-size:.82rem; color:#64748b;">Select PC</label>
                            <input type="text" class="form-control form-control-sm mb-2"
                                   placeholder="Search PCs..."
                                   style="border-color:#cbd5e1; background:#fff !important; color:#111827 !important;"
                                   @bind="_actionPcSearch" @bind:event="oninput" />
                            <div style="max-height:280px; overflow-y:auto;">
                                @foreach (var pc in _actionAllPcs.Where(p => string.IsNullOrEmpty(_actionPcSearch) || p.FullName.Contains(_actionPcSearch, StringComparison.OrdinalIgnoreCase)))
                                {
                                    var thisPc = pc;
                                    @if (!(_isSoloUser && thisPc.IsAlsoSolo))
                                    {
                                        <div class="act-pc-item" @onclick="() => OnActionSummaryPcSelected(thisPc.PcId, thisPc.FullName, _isSoloUser)">
                                            <i class="ri-user-line" style="color:#8b5cf6; opacity:.6;"></i>
                                            <span>@thisPc.FullName</span>
                                        </div>
                                    }
                                    @if (thisPc.IsAlsoSolo)
                                    {
                                        <div class="act-pc-item" @onclick="() => OnActionSummaryPcSelected(thisPc.PcId, thisPc.FullName, true)">
                                            <i class="ri-user-line" style="color:#ef4444; opacity:.7;"></i>
                                            <span>@thisPc.FullName</span>
                                            <span style="font-size:.62rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase;
                                                         color:#fff; background:linear-gradient(135deg,#ef4444,#b91c1c);
                                                         border-radius:999px; padding:2px 8px; margin-left:4px;">Solo</span>
                                        </div>
                                    }
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2 mb-3 px-2 py-2"
                             style="background:#f0f4ff; border-radius:8px; border:1px solid #e2e8f0;">
                            <i class="ri-user-line" style="color:#8b5cf6;"></i>
                            <span style="font-weight:700; font-size:.92rem; color:#1e293b;">@_actionSummaryPcName</span>
                            @if (_actionSummaryIsSoloFolder)
                            {
                                <span style="font-size:.65rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase;
                                             color:#fff; background:linear-gradient(135deg,#ef4444 0%,#b91c1c 100%);
                                             border-radius:999px; padding:2px 9px;
                                             box-shadow:0 0 8px rgba(239,68,68,0.5);">Solo Folder</span>
                            }
                            <button class="btn btn-sm ms-auto p-0" style="color:#64748b; font-size:.8rem;"
                                    @onclick="() => { _actionSummaryStep = 1; _actionPcSearch = string.Empty; _actionSuccessMsg = string.Empty; }">
                                <i class="ri-arrow-left-s-line me-1"></i>Change
                            </button>
                        </div>
                        <div id="act-summary-editor-wrap">
                            <div id="act-summary-editor"></div>
                        </div>
                    }
                </div>
                @if (_actionSummaryStep == 2)
                {
                    <div class="modal-footer py-2" style="border-color:#e2e8f0; background:#fff !important;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CloseActionSummary()">Cancel</button>
                        <button class="btn btn-sm btn-primary d-flex align-items-center gap-1"
                                disabled="@_actionSummaryBusy"
                                @onclick="SubmitActionSummary">
                            @if (_actionSummaryBusy)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <i class="ri-save-line"></i>
                            }
                            Save
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

<style>
    /* ── Actions PC list items ── */
    .act-pc-item {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 12px; border-radius: 8px; cursor: pointer;
        font-size: .85rem; color: #1e293b; transition: background .15s;
    }
    .act-pc-item:hover { background: #f0f4ff; }
    .act-success-screen {
        text-align: center; padding: 40px 16px; position: relative; overflow: hidden;
    }
    .act-success-ring {
        position: absolute; top: 50%; left: 50%;
        width: 120px; height: 120px; margin: -90px 0 0 -60px;
        border-radius: 50%; border: 3px solid rgba(16,185,129,.3);
        animation: act-ring .6s ease-out forwards;
    }
    .act-success-icon {
        width: 80px; height: 80px; border-radius: 50%;
        background: linear-gradient(135deg, #10b981, #059669);
        color: #fff; font-size: 2.5rem; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        box-shadow: 0 10px 35px rgba(16,185,129,.5);
        animation: act-pop .5s cubic-bezier(0.34,1.56,0.64,1);
        position: relative; z-index: 1;
    }
    .act-success-title {
        font-size: 1.25rem; font-weight: 800; color: #059669;
        margin-top: 16px; letter-spacing: -.3px;
        animation: act-fade-up .4s ease-out .2s both;
    }
    .act-success-sub {
        font-size: .88rem; color: #64748b; margin-top: 6px;
        animation: act-fade-up .4s ease-out .35s both;
    }
    .act-success-sparkles { position: absolute; top: 45%; left: 50%; }
    .act-spark {
        position: absolute; width: 6px; height: 6px; border-radius: 50%;
        background: #10b981;
        animation: act-spark-fly .6s ease-out calc(var(--d) * 0.06s) both;
        transform: translate(0, 0);
    }
    @@keyframes act-pop {
        0%   { transform: scale(0); opacity: 0; }
        60%  { transform: scale(1.15); }
        100% { transform: scale(1); opacity: 1; }
    }
    @@keyframes act-ring {
        0%   { transform: scale(0.3); opacity: 1; }
        100% { transform: scale(2.2); opacity: 0; }
    }
    @@keyframes act-fade-up {
        from { transform: translateY(10px); opacity: 0; }
        to   { transform: translateY(0); opacity: 1; }
    }
    @@keyframes act-spark-fly {
        0%   { transform: translate(0, 0) scale(1); opacity: 1; }
        100% { transform: translate(var(--x), var(--y)) scale(0); opacity: 0; }
    }
    /* ── No-permissions empty state ── */
    .act-noperm-screen {
        text-align: center; padding: 32px 16px 24px; position: relative;
    }
    .act-noperm-icon-wrap {
        position: relative; display: inline-flex; align-items: center;
        justify-content: center; margin-bottom: 16px;
    }
    .act-noperm-ring {
        position: absolute; width: 80px; height: 80px; border-radius: 50%;
        border: 2px solid rgba(220,38,38,.2);
        animation: noperm-pulse 2s ease-in-out infinite;
    }
    .act-noperm-icon {
        font-size: 2.8rem; color: #dc2626;
        animation: noperm-float 3s ease-in-out infinite;
        filter: drop-shadow(0 4px 12px rgba(220,38,38,.35));
    }
    .act-noperm-title {
        font-size: 1.05rem; font-weight: 700; color: #1e293b;
        margin-bottom: 8px; animation: act-fade-up .4s ease-out both;
    }
    .act-noperm-sub {
        font-size: .82rem; color: #64748b; line-height: 1.5;
        animation: act-fade-up .4s ease-out .1s both;
    }
    @@keyframes noperm-float {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(-6px); }
    }
    @@keyframes noperm-pulse {
        0%, 100% { transform: scale(1);   opacity: .6; }
        50%       { transform: scale(1.3); opacity: .15; }
    }
    #act-summary-editor-wrap .ql-editor {
        min-height: 120px; font-size: .88rem;
        background: #fff !important; color: #1e293b !important;
    }
    #act-summary-editor-wrap .ql-toolbar.ql-snow {
        padding: 3px 6px; background: #f1f5f9 !important;
        border-top-left-radius: 8px; border-top-right-radius: 8px;
        border-color: #cbd5e1 !important;
    }
    #act-summary-editor-wrap .ql-toolbar.ql-snow .ql-stroke { stroke: #334155 !important; }
    #act-summary-editor-wrap .ql-toolbar.ql-snow .ql-fill { fill: #334155 !important; }
    #act-summary-editor-wrap .ql-toolbar.ql-snow .ql-picker-label { color: #334155 !important; }
    #act-summary-editor-wrap .ql-container.ql-snow {
        border-bottom-left-radius: 8px; border-bottom-right-radius: 8px;
        background: #fff !important; border-color: #cbd5e1 !important;
    }
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-label::before,
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-item::before { content: 'Normal' !important; }
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='10px']::before,
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='10px']::before { content: 'Tiny' !important; }
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='14px']::before,
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='14px']::before { content: 'Small' !important; }
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='18px']::before,
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='18px']::before { content: 'Medium' !important; }
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-label[data-value='24px']::before,
    #act-summary-editor-wrap .ql-snow .ql-picker.ql-size .ql-picker-item[data-value='24px']::before { content: 'Large' !important; }
</style>

<style>
    /* ── Message button in header ── */
    .hdr-msg-btn {
        border: none; border-radius: 10px; padding: 6px 14px;
        font-size: .85rem; font-weight: 600; cursor: pointer;
        display: inline-flex; align-items: center; gap: 4px;
        transition: all .2s ease; position: relative;
        color: #fff;
    }
    .hdr-msg-green {
        background: linear-gradient(135deg, #16a34a, #22c55e);
        box-shadow: 0 2px 10px rgba(22,163,74,.35);
    }
    .hdr-msg-green:hover { box-shadow: 0 4px 16px rgba(22,163,74,.5); transform: translateY(-1px); }
    .hdr-msg-orange {
        background: #1e293b;
        position: relative;
        z-index: 0;
        overflow: visible;
        border: none;
    }
    .hdr-msg-orange::before {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 12px;
        background: linear-gradient(
            270deg, #f97316, #ef4444, #ec4899, #a855f7, #3b82f6, #06b6d4, #10b981, #f59e0b, #f97316
        );
        background-size: 400% 400%;
        animation: hdrMsgShift 4s linear infinite;
        z-index: -1;
    }
    .hdr-msg-orange::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: 10px;
        background: #1e293b;
        z-index: -1;
    }
    .hdr-msg-orange:hover { transform: translateY(-1px); }
    @@keyframes hdrMsgShift {
        0%   { background-position: 0% 50%; }
        50%  { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }
    .hdr-msg-badge {
        background: #ef4444; color: #fff; font-weight: 800; font-size: .65rem;
        border-radius: 50%; min-width: 18px; height: 18px;
        display: inline-flex; align-items: center; justify-content: center;
        padding: 0 4px; line-height: 1;
    }

    /* ── Message modal ── */
    .hdr-msg-modal {
        border: none; border-radius: 16px; overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,.25);
        background: #fff !important; color: #111827 !important;
    }
    .hdr-msg-compose {
        padding: 16px; background: #f0f4ff !important; border-bottom: 1px solid #e2e8f0;
        color: #111827 !important;
    }
    .hdr-msg-select { max-width: 160px; border-radius: 8px; border-color: #cbd5e1; background: #fff !important; color: #111827 !important; }
    .hdr-msg-input { border-radius: 8px; border-color: #cbd5e1; flex: 1; background: #fff !important; color: #111827 !important; }
    .hdr-msg-send-btn {
        background: linear-gradient(135deg, #3b82f6, #2563eb); color: #fff;
        border: none; border-radius: 8px; padding: 6px 14px;
        transition: all .18s;
    }
    .hdr-msg-send-btn:hover:not(:disabled) { background: linear-gradient(135deg, #2563eb, #1d4ed8); color: #fff; transform: scale(1.05); }
    .hdr-msg-send-btn:disabled { opacity: .4; color: #fff; }
    .hdr-msg-status { font-size: .8rem; margin-top: 8px; font-weight: 500; }
    .hdr-msg-inbox-header {
        font-size: .75rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .08em; color: #64748b; padding: 12px 16px 6px;
        display: flex; align-items: center; gap: 6px;
    }
