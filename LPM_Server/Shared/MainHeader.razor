    void RemoveArfRow(int idx) { if (_arfRows.Count > 1) { _arfRows.RemoveAt(idx); RecalcSessionLength(); RebuildArfSummary(); } }
    async Task OnArfResultsKeyDown(KeyboardEventArgs e)
    {
