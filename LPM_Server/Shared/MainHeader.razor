        StateHasChanged();

        _ = Task.Run(async () =>
        {
            try
            {
                var sSave = _memoSteps[0];
                var sDb   = _memoSteps[1];
                var sClr  = _memoSteps[2];

                // Step 1: Save file to WorkSheets
                sSave.Status = 1;
