                        <input type="text" class="form-control form-control-sm mb-2"
                               placeholder="@LS.T("actions.searchPcs")"
                               style="border-color:#cbd5e1; background:#fff !important; color:#111827 !important;"
                               @bind="_actionPcSearch" @bind:event="oninput" />
                        <div style="max-height:280px; overflow-y:auto;">
