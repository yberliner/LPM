    //sticky-pin //
    private string headerClass = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AttachHeaderScrollListener();
            // Auto-format HH:MM time inputs in real-time + on blur (1-2 digits = minutes)
            await JSRuntime.InvokeVoidAsync("eval", @"
                document.addEventListener('input', function(e) {
                    if (!e.target.classList.contains('arf-time-input')) return;
                    var raw = e.target.value.replace(/[^0-9]/g, '');
                    if (raw.length > 4) raw = raw.slice(0, 4);
                    if (raw.length > 2) {
                        e.target.value = raw.slice(0, raw.length - 2) + ':' + raw.slice(-2);
                    } else {
                        e.target.value = raw;
                    }
                });
                document.addEventListener('change', function(e) {
                    if (!e.target.classList.contains('arf-time-input')) return;
                    var v = e.target.value.trim();
                    if (!v) return;
                    var digits = v.replace(/[^0-9]/g, '');
                    if (v.indexOf(':') === -1 && digits.length <= 2) {
                        var m = parseInt(digits, 10);
                        if (!isNaN(m) && m >= 0 && m <= 59) {
                            e.target.value = '0:' + (m < 10 ? '0' : '') + m;
                        }
                    }
                });
            ");
        }
    }

    private async void OnNewMessageReceived(int recipientPersonId)
    {
        if (_isDisposed || !_msgUserId.HasValue || recipientPersonId != _msgUserId.Value) return;
        try
        {
            var newCount = DashSvc.GetPendingMessageCount(_msgUserId.Value);
            if (newCount != _pendingMsgCount)
            {
                _pendingMsgCount = newCount;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* swallow — component may be disposed */ }
    }

    public void Dispose()
    {
        _isDisposed = true;
        MsgNotifier.OnNewMessage -= OnNewMessageReceived;
    }

