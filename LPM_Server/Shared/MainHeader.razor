    void OpenUploadFrontCover()
    {
        var soloPcIds = DashSvc.GetSoloPcIds();
        _ufcAllPcs  = DashSvc.GetAllPcs().Where(pc => !soloPcIds.Contains(pc.PcId)).ToList();
        _ufcPcId            = 0;
        _ufcFile            = null;
        _ufcDuplicate       = false;
        _ufcBusy            = false;
        _ufcSuccess         = false;
        _ufcFading          = false;
        _ufcSuccessFileName = "";
        _ufcSuccessPcName   = "";
        _ufcError           = "";
        _showUploadFrontCover = true;
    }

    void OnUfcPcChanged(ChangeEventArgs e)
    {
        _ufcPcId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _ufcDuplicate = false;
        if (_ufcPcId > 0 && _ufcFile != null)
            _ufcDuplicate = FolderSvc.SectionFileExists(_ufcPcId, "Front_Cover", _ufcFile.Name);
    }

    void OnUfcFileSelected(InputFileChangeEventArgs e)
    {
        _ufcFile = e.File;
        _ufcDuplicate = false;
        if (_ufcPcId > 0 && _ufcFile != null)
            _ufcDuplicate = FolderSvc.SectionFileExists(_ufcPcId, "Front_Cover", _ufcFile.Name);
    }

    async Task DoUploadFrontCover()
    {
        if (_ufcPcId == 0 || _ufcFile == null || _ufcDuplicate || _ufcBusy) return;
        _ufcBusy    = true;
        _ufcError   = "";
        _ufcSuccess = false;
        try
        {
            await using var stream = _ufcFile.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            FolderSvc.SaveSectionFile(_ufcPcId, "Front_Cover", _ufcFile.Name, ms.ToArray());
            DashSvc.NotifyDataChanged();
            _ufcSuccessFileName = _ufcFile.Name;
            _ufcSuccessPcName   = _ufcAllPcs.FirstOrDefault(p => p.PcId == _ufcPcId)?.FullName ?? "";
            Console.WriteLine($"[MainHeader] Front Cover upload: '{_ufcSuccessFileName}' → PC '{_ufcSuccessPcName}' (id={_ufcPcId}) by '{_logUsername}'");
            _ufcBusy    = false;
            _ufcFading  = false;
            _ufcSuccess = true;
            StateHasChanged();
            await Task.Delay(2200);   // show success
            _ufcFading = true;
            StateHasChanged();
            await Task.Delay(800);    // fade-out duration
            _showUploadFrontCover = false;
        }
        catch (Exception ex)
        {
            _ufcError = $"Upload failed: {ex.Message}";
            Console.WriteLine($"[MainHeader] Front Cover upload FAILED: file='{_ufcFile?.Name}' PC={_ufcPcId} user='{_logUsername}' — {ex}");
        }
        finally
        {
            _ufcBusy = false;
        }
    }

