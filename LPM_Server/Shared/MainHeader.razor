            }
        });
    }

    async Task ExecuteSoloImport()
    {
        if (!_msgUserId.HasValue || _importPcId == 0 || _importSessionBytes == null) return;
        var pcName = _approvedPcs.FirstOrDefault(p => p.PcId == _importPcId)?.FullName ?? $"PC {_importPcId}";
        ActivitySvc.RecordActivity(_logUsername, $"Clicked Go on Solo Add Session for: {pcName} ({_soloSections.Count} sections)", "session");

        // Capture data
        var capturedPcId        = _importPcId;
        var capturedUserId      = _msgUserId.Value;
        var capturedFileName    = _importNormalizedFileName + ".pdf";
        var capturedBytes       = _importSessionBytes;
        var capturedAttachments = _importAttachmentBytes.ToList();
        var capturedFreeSession = _importFreeSession;
        var capturedPcName      = pcName;
        var capturedUsername    = _logUsername;
        var capturedSections    = _soloSections.Select(s => new
        {
            Date = s.Date,
            LengthSec = ArfTimeToMinutes(FormatArfTime(s.SessionLength.Trim())) * 60,
            AdminSec = ArfTimeToMinutes(FormatArfTime(s.AdminTime.Trim())) * 60,
            Summary = s.Summary.Trim()
        }).ToList();

        // Calculate totals
        var totalLengthSec = capturedSections.Sum(s => Math.Max(0, s.LengthSec));
        var totalAdminSec  = capturedSections.Sum(s => Math.Max(0, s.AdminSec));
        var earliestDate   = capturedSections
            .Select(s => DateOnly.TryParse(s.Date, out var d) ? d : DateOnly.FromDateTime(DateTime.Today))
            .Min().ToString("yyyy-MM-dd");

        // Close reference float if open
        await JSRuntime.InvokeVoidAsync("wizardRef.closeFloat");
        _refBrowserOpen = false;
        FolderSvc.ClearScanInbox(_logUsername);

        // Close modal and reset
        _showImportWizard        = false;
        _importSessionFile       = null;
        _importSessionBytes      = null;
        _importSessionFileName   = "";
        _importNormalizedFileName = "";
        _importNormalizedSuffix  = "";
        _importDateWasPrepended  = false;
        _importNormalizedDate    = DateTime.Today;
        _importAttachments.Clear();
        _importAttachmentBytes.Clear();
        _importPcId      = 0;
        _importStep      = 1;
        _importError     = "";
        _importSuccess   = "";
        _refBrowserOpen  = false;
        _refFileList.Clear();

        var saveLabel = capturedAttachments.Count > 0
            ? $"Saving to folder (+{capturedAttachments.Count} attachment{(capturedAttachments.Count == 1 ? "" : "s")})"
            : "Saving to folder";
        _bgSteps = new List<BgStep>
        {
            new("Creating session"),
            new("Normalizing pages"),
            new("Generating Next C/S"),
            new(saveLabel),
        };

        _bgImportRunning = true;
        _bgImportDone    = false;
        _bgImportError   = "";
        _bgImportLabel   = capturedFileName;
        StateHasChanged();

        _ = Task.Run(async () =>
        {
            async Task Advance(BgStep s, int status)
            {
                s.Status = status;
                await InvokeAsync(StateHasChanged);
            }

            try
            {
                var sessionName   = Path.GetFileNameWithoutExtension(capturedFileName);
                var sCreate = _bgSteps[0];
                var sNorm   = _bgSteps[1];
                var sNextCs = _bgSteps[2];
                var sSave   = _bgSteps[3];

                sCreate.Status = 1; sNorm.Status = 1;
                await InvokeAsync(StateHasChanged);

                int    sessionId       = 0;
                byte[] normalizedBytes = capturedBytes;
                byte[] nextCsPdfBytes  = Array.Empty<byte>();

                await Task.WhenAll(
                    Task.Run(async () =>
                    {
                        // Create session with total length/admin, earliest date
                        sessionId = DashSvc.CreateImportedSession(capturedPcId, capturedUserId, sessionName,
                            totalLengthSec, totalAdminSec, capturedFreeSession, isSolo: true, sessionDate: earliestDate);

                        // Create one folder summary per section
                        foreach (var sec in capturedSections)
                        {
                            var dbDate = DateOnly.TryParse(sec.Date, out var pd) ? pd.ToString("yyyy-MM-dd") : earliestDate;
                            var html = $"<p>{System.Net.WebUtility.HtmlEncode(sec.Summary)}</p>";
                            var lenSec = sec.LengthSec > 0 ? sec.LengthSec : (int?)null;
                            var admSec = sec.AdminSec > 0 ? sec.AdminSec : (int?)null;
                            DashSvc.AddFolderSummary(sessionId, capturedPcId, null, html,
                                sessionDate: dbDate,
                                lengthSeconds: lenSec,
                                adminSeconds: admSec,
                                folderSummaryDate: dbDate);
                        }
                        await Advance(sCreate, 2);
                    }),
                    Task.Run(async () =>
                    {
                        var direct = FolderSvc.TryNormalizePdfDirect(capturedBytes);
                        if (direct != null)
                        {
                            normalizedBytes = direct;
                            await Advance(sNorm, 2);
                            return;
                        }
                        const int repairSec = 20;
                        int secsLeft = repairSec;
                        sNorm.SubLabel = $"Ghostscript + LibreOffice: {secsLeft}s";
                        await InvokeAsync(StateHasChanged);
                        using var tickerCts = new System.Threading.CancellationTokenSource();
                        _ = Task.Run(async () =>
                        {
                            while (!tickerCts.Token.IsCancellationRequested && secsLeft > 0)
                            {
                                await Task.Delay(1000);
                                if (tickerCts.Token.IsCancellationRequested) break;
                                secsLeft = Math.Max(0, secsLeft - 1);
                                sNorm.SubLabel = secsLeft > 0 ? $"Ghostscript + LibreOffice: {secsLeft}s" : "finishing…";
                                await InvokeAsync(StateHasChanged);
                            }
                        });
                        var gsTask    = Task.Run(() => FolderSvc.RepairAndNormalizeViaGhostscript(capturedBytes, repairSec * 1000));
                        var loTask    = Task.Run(() => FolderSvc.RepairAndNormalizeViaLibreOffice(capturedBytes, repairSec * 1000));
                        await Task.WhenAll(gsTask, loTask);
                        tickerCts.Cancel();
                        normalizedBytes = gsTask.Result ?? loTask.Result ?? capturedBytes;
                        await Advance(sNorm, 2);
                    })
                );

                // Generate Next C/S (empty content for solo, but PDF with header/footer is still created)
                sNextCs.Status = 1;
                await InvokeAsync(StateHasChanged);
                var firstDate = capturedSections.FirstOrDefault()?.Date is string fd && DateOnly.TryParse(fd, out var fpd)
                    ? fpd.ToString("dd/MM/yy") : DateTime.Today.ToString("dd/MM/yy");
                string? nextCsFooter = DashSvc.GetCsNameForPc(capturedPcId);
                nextCsPdfBytes = PdfSvc.GenerateNextCsPdf(
                    capturedPcName, firstDate,
                    capturedUsername, "", "",
                    footerName: nextCsFooter);
                await Advance(sNextCs, 2);

                // Save to folder
                sSave.Status = 1;
                await InvokeAsync(StateHasChanged);
                var savedSessionFileName = FolderSvc.SaveSoloUploadedFile(capturedPcId, capturedFileName, normalizedBytes);
                if (savedSessionFileName == null)
                    Console.WriteLine($"[SoloImport] Warning: could not save PDF for PC {capturedPcId}");
                else
                {
                    foreach (var (attName, attData, _) in capturedAttachments)
                        FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, attName, attData, solo: true);
                    if (nextCsPdfBytes.Length > 0)
                        FolderSvc.SaveAttachment(capturedPcId, savedSessionFileName, "Next CS.pdf", nextCsPdfBytes, solo: true);
                }
                await Advance(sSave, 2);

                _bgImportDone = true;
                ActivitySvc.RecordActivity(capturedUsername, $"Added solo session for: {capturedPcName} ({capturedSections.Count} sections)", "session");
                await InvokeAsync(StateHasChanged);
                await Task.Delay(1500);
                await InvokeAsync(() => NavigationManager.NavigateTo("/Home", forceLoad: true));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[SoloImport] FAILED: {ex}");
                _bgImportError = ex.Message;
                foreach (var s in _bgSteps.Where(s => s.Status == 1)) s.Status = 3;
                await InvokeAsync(StateHasChanged);
            }
        });
    }

