@using LPM.Services
@inject SessionDataService SdSvc
@inject PdfService PdfSvc
@inject IJSRuntime JS

@if (Show)
{
<div class="sdm-overlay" @onclick="OnBackdropClick">
    <div class="sdm-panel" @onclick:stopPropagation="true">

        @* ── Header ─────────────────────────────────────────────── *@
        <div class="sdm-header">
            <div class="sdm-header-left">
                <i class="ri-booklet-line sdm-header-icon"></i>
                <div class="sdm-header-meta">
                    <div class="sdm-header-pc">
                        <span class="sdm-lbl">PC</span>
                        <span class="sdm-val">@PcName</span>
                    </div>
                    <div class="sdm-header-sub">
                        @if (!string.IsNullOrWhiteSpace(SessionName))
                        {
                            <span class="sdm-chip sdm-chip-session">
                                <i class="ri-calendar-event-line"></i>@SessionName
                            </span>
                        }
                        <span class="sdm-chip sdm-chip-user">
                            <i class="ri-user-line"></i>@CurrentUserName
                        </span>
                    </div>
                </div>
            </div>
            <button class="sdm-close" title="Close" @onclick="OnClose">
                <i class="ri-close-line"></i>
            </button>
        </div>

        @* ── Tabs ───────────────────────────────────────────────── *@
        <div class="sdm-tabs">
            <button class="sdm-tab @(_activeTab == Tab.Evil ? "sdm-tab-active" : "")"
                    @onclick="() => SwitchTab(Tab.Evil)">
                <i class="ri-alert-line"></i>Evil Purposes
                <span class="sdm-tab-count">@_evil.Count</span>
            </button>
            <button class="sdm-tab @(_activeTab == Tab.Serfac ? "sdm-tab-active" : "")"
                    @onclick="() => SwitchTab(Tab.Serfac)">
                <i class="ri-file-copy-line"></i>Service Facsimiles
                <span class="sdm-tab-count">@_serfac.Count</span>
            </button>
            <button class="sdm-tab @(_activeTab == Tab.Pts ? "sdm-tab-active" : "")"
                    @onclick="() => SwitchTab(Tab.Pts)">
                <i class="ri-flashlight-line"></i>PTS Handling
                <span class="sdm-tab-count">@_pts.Count</span>
            </button>
        </div>

        @* ── Toolbar ────────────────────────────────────────────── *@
        <div class="sdm-toolbar">
            <button class="sdm-btn sdm-btn-add" @onclick="AddRow" disabled="@(_editingId != 0 || _isAdding)">
                <i class="ri-add-line"></i>Add row
            </button>
            <button class="sdm-btn sdm-btn-download" title="Download the shown table as PDF"
                    @onclick="DownloadCurrentTableAsync" disabled="@_downloading">
                @if (_downloading)
                {
                    <span class="spinner-border spinner-border-sm" role="status"></span>
                    <span>Preparing…</span>
                }
                else
                {
                    <i class="ri-download-cloud-line"></i>
                    <span>Download PDF</span>
                }
            </button>
            <div class="sdm-toolbar-spacer"></div>
            <button class="sdm-btn sdm-btn-sort" title="Toggle sort order" @onclick="() => _sortDesc = !_sortDesc">
                <i class="@(_sortDesc ? "ri-sort-desc" : "ri-sort-asc")"></i>
                @(_sortDesc ? "Newest first" : "Oldest first")
            </button>
        </div>

        @* ── Body (active tab table) ────────────────────────────── *@
        <div class="sdm-body">
            @if (_activeTab == Tab.Evil)        { @RenderEvilTable }
            else if (_activeTab == Tab.Serfac)  { @RenderSerfacTable }
            else                                { @RenderPtsTable }
        </div>

        @* ── Delete confirmation dialog ─────────────────────────── *@
        @if (_deleting != null)
        {
            <div class="sdm-delete-backdrop" @onclick="CancelDelete">
                <div class="sdm-delete-dialog" @onclick:stopPropagation="true">
                    <div class="sdm-delete-banner">
                        <i class="ri-error-warning-fill"></i>
                        <span>THIS WILL PERMANENTLY DELETE THE ROW</span>
                        <i class="ri-error-warning-fill"></i>
                    </div>
                    <div class="sdm-delete-body">
                        <div class="sdm-delete-preview">
                            <div class="sdm-delete-preview-title">@_deleting.Title</div>
                            <pre class="sdm-delete-preview-content">@_deleting.Content</pre>
                        </div>
                        <label class="sdm-delete-label">
                            Type <code>delete</code> to confirm:
                        </label>
                        <input class="sdm-delete-input @(IsDeleteArmed ? "sdm-delete-input-armed" : "")"
                               placeholder="delete"
                               value="@_deleteInput"
                               @oninput="e => _deleteInput = e.Value?.ToString() ?? string.Empty"
                               autofocus />
                    </div>
                    <div class="sdm-delete-actions">
                        <button class="sdm-btn sdm-btn-cancel" @onclick="CancelDelete">
                            <i class="ri-arrow-left-line"></i>Cancel
                        </button>
                        <button class="sdm-btn sdm-btn-confirm-delete @(IsDeleteArmed ? "sdm-armed" : "")"
                                disabled="@(!IsDeleteArmed)" @onclick="ConfirmDelete">
                            <i class="ri-delete-bin-line"></i>Delete permanently
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_toast))
        {
            <div class="sdm-toast @(_toastIsError ? "sdm-toast-error" : "")">@_toast</div>
        }
    </div>
</div>

<style>
    .sdm-overlay {
        position: fixed; inset: 0; background: rgba(15,23,42,.72); backdrop-filter: blur(3px);
        z-index: 100000; display: flex; align-items: stretch; justify-content: stretch;
    }
    .sdm-panel {
        background: linear-gradient(180deg, #fbfbff 0%, #f5f5fb 100%);
        margin: 2vh 2vw; flex: 1; border-radius: 18px; box-shadow: 0 30px 80px rgba(0,0,0,.35);
        display: flex; flex-direction: column; overflow: hidden; position: relative;
    }
    .sdm-header {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: #fff; padding: 16px 22px; display: flex; align-items: center; justify-content: space-between; gap: 12px;
    }
    .sdm-header-left { display: flex; align-items: center; gap: 14px; min-width: 0; }
    .sdm-header-icon { font-size: 1.7rem; opacity: .95; }
    .sdm-header-meta { min-width: 0; }
    .sdm-header-pc { font-size: 1.05rem; font-weight: 700; display: flex; align-items: baseline; gap: 8px; }
    .sdm-lbl { font-size: .7rem; opacity: .75; font-weight: 500; text-transform: uppercase; letter-spacing: .08em; }
    .sdm-val { }
    .sdm-header-sub { display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
    .sdm-chip {
        display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px;
        background: rgba(255,255,255,.18); border-radius: 999px; font-size: .78rem;
    }
    .sdm-chip i { font-size: .9rem; }
    .sdm-close {
        background: rgba(255,255,255,.15); border: 0; color: #fff; width: 36px; height: 36px;
        border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center;
    }
    .sdm-close:hover { background: rgba(255,255,255,.3); }

    .sdm-tabs {
        display: flex; gap: 6px; padding: 12px 22px 0;
        background: linear-gradient(180deg, rgba(124,58,237,.08), transparent);
    }
    .sdm-tab {
        background: rgba(124,58,237,.07); border: 1px solid transparent;
        color: #4f46e5; padding: 9px 18px; border-radius: 999px; font-weight: 600;
        font-size: .88rem; cursor: pointer; display: inline-flex; align-items: center; gap: 7px;
        transition: all .15s ease;
    }
    .sdm-tab:hover { background: rgba(124,58,237,.15); }
    .sdm-tab-active { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; box-shadow: 0 4px 14px rgba(124,58,237,.35); }
    .sdm-tab-count {
        background: rgba(255,255,255,.35); padding: 1px 8px; border-radius: 999px;
        font-size: .72rem; font-weight: 700;
    }
    .sdm-tab:not(.sdm-tab-active) .sdm-tab-count { background: rgba(124,58,237,.2); color: #4f46e5; }

    .sdm-toolbar {
        padding: 12px 22px; display: flex; gap: 10px; align-items: center;
        border-bottom: 1px solid rgba(79,70,229,.08);
    }
    .sdm-toolbar-spacer { flex: 1; }
    .sdm-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 10px;
        border: 0; font-weight: 600; font-size: .85rem; cursor: pointer; transition: all .15s ease;
        min-height: 44px;
    }
    .sdm-btn:disabled { opacity: .4; cursor: not-allowed; }
    .sdm-btn-add { background: linear-gradient(135deg, #10b981, #059669); color: #fff; }
    .sdm-btn-add:not(:disabled):hover { transform: translateY(-1px); box-shadow: 0 6px 14px rgba(16,185,129,.35); }
    .sdm-btn-sort { background: #eef2ff; color: #4338ca; border: 1px solid rgba(79,70,229,.2); }
    .sdm-btn-sort:hover { background: #e0e7ff; }
    .sdm-btn-download { background: linear-gradient(135deg, #0ea5e9, #6366f1); color: #fff; }
    .sdm-btn-download:not(:disabled):hover { transform: translateY(-1px); box-shadow: 0 6px 14px rgba(99,102,241,.35); }
    .sdm-btn-cancel { background: #f1f5f9; color: #334155; }
    .sdm-btn-cancel:hover { background: #e2e8f0; }
    .sdm-btn-save { background: linear-gradient(135deg, #4f46e5, #7c3aed); color: #fff; }
    .sdm-btn-save:hover { box-shadow: 0 6px 14px rgba(79,70,229,.35); }
    .sdm-btn-edit { background: #fef3c7; color: #92400e; padding: 6px 10px; border-radius: 8px; min-height: 36px; }
    .sdm-btn-edit:hover { background: #fde68a; }
    .sdm-btn-delete { background: #fee2e2; color: #b91c1c; padding: 6px 10px; border-radius: 8px; min-height: 36px; }
    .sdm-btn-delete:hover { background: #fecaca; }
    .sdm-btn-confirm-delete { background: #dc2626; color: #fff; }
    .sdm-btn-confirm-delete.sdm-armed {
        animation: sdm-armed-pulse 1.1s infinite ease-in-out;
    }
    @@keyframes sdm-armed-pulse {
        0%,100% { box-shadow: 0 0 0 0 rgba(220,38,38,.6); }
        50%     { box-shadow: 0 0 0 12px rgba(220,38,38,0); }
    }

    .sdm-body {
        flex: 1; overflow: auto; padding: 0 22px 22px;
    }
    .sdm-empty {
        padding: 60px 20px; text-align: center; color: #64748b; font-size: .95rem;
    }
    .sdm-empty i { display: block; font-size: 3rem; margin-bottom: 10px; opacity: .3; }

    .sdm-table-wrap {
        background: #fff; border-radius: 12px; overflow: auto; box-shadow: 0 2px 8px rgba(15,23,42,.06);
        margin-top: 14px; border: 1px solid rgba(79,70,229,.1);
    }
    .sdm-table { width: 100%; border-collapse: separate; border-spacing: 0; font-size: .88rem; }
    .sdm-table th {
        position: sticky; top: 0; background: #eef2ff; color: #4338ca; text-align: left;
        padding: 10px 12px; font-weight: 700; font-size: .78rem; text-transform: uppercase; letter-spacing: .05em;
        border-bottom: 2px solid rgba(79,70,229,.18); z-index: 1;
    }
    .sdm-table td {
        padding: 10px 12px; border-bottom: 1px solid #f1f5f9; vertical-align: top;
    }
    .sdm-table tr:nth-child(even) td { background: #fafafe; }
    .sdm-table tr:hover td { background: #f5f3ff; }
    .sdm-table tr.sdm-row-editing td { background: #fffbeb !important; }
    .sdm-table tr.sdm-row-new td { background: #ecfdf5 !important; }
    .sdm-cell-id { color: #94a3b8; font-family: ui-monospace, monospace; font-size: .78rem; }
    .sdm-cell-ca  { white-space: nowrap; color: #475569; font-size: .8rem; }
    .sdm-cell-by  { white-space: nowrap; color: #334155; font-weight: 500; }
    .sdm-cell-actions { white-space: nowrap; text-align: right; }
    .sdm-pretext {
        white-space: pre-wrap; word-break: break-word;
        max-width: 360px;
    }
    .sdm-pretext-short { max-width: 160px; }
    .sdm-muted { color: #94a3b8; font-style: italic; }

    .sdm-input, .sdm-textarea, .sdm-select {
        width: 100%; border: 1px solid #cbd5e1; border-radius: 7px; padding: 7px 9px;
        font-size: 16px; background: #fff; box-sizing: border-box;
    }
    .sdm-textarea { min-height: 60px; resize: vertical; font-family: inherit; }
    .sdm-input:focus, .sdm-textarea:focus, .sdm-select:focus {
        outline: none; border-color: #7c3aed; box-shadow: 0 0 0 3px rgba(124,58,237,.15);
    }
    .sdm-input-sm { width: 150px; }

    .sdm-delete-backdrop {
        position: absolute; inset: 0; background: rgba(15,23,42,.6); z-index: 10;
        display: flex; align-items: center; justify-content: center; padding: 20px;
    }
    .sdm-delete-dialog {
        background: #fff; border-radius: 14px; max-width: 520px; width: 100%;
        box-shadow: 0 30px 60px rgba(0,0,0,.4); overflow: hidden;
    }
    .sdm-delete-banner {
        background: linear-gradient(90deg, #dc2626, #b91c1c, #dc2626);
        background-size: 200% 100%;
        color: #fff; padding: 14px 16px; text-align: center; font-weight: 800;
        display: flex; align-items: center; justify-content: center; gap: 10px;
        font-size: .95rem; letter-spacing: .03em;
        animation: sdm-warn-flash 1.3s infinite;
    }
    @@keyframes sdm-warn-flash {
        0%,100% { background-position: 0% 50%; filter: brightness(1); }
        50%     { background-position: 100% 50%; filter: brightness(1.25); }
    }
    .sdm-delete-banner i { font-size: 1.3rem; }
    .sdm-delete-body { padding: 16px; }
    .sdm-delete-preview {
        background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px;
        margin-bottom: 14px; max-height: 180px; overflow: auto;
    }
    .sdm-delete-preview-title { font-size: .8rem; color: #64748b; font-weight: 600; margin-bottom: 6px; }
    .sdm-delete-preview-content {
        font-family: ui-monospace, monospace; font-size: .8rem; color: #0f172a;
        white-space: pre-wrap; word-break: break-word; margin: 0;
    }
    .sdm-delete-label { display: block; font-size: .85rem; color: #334155; margin-bottom: 6px; }
    .sdm-delete-label code { background: #fef2f2; color: #b91c1c; padding: 1px 6px; border-radius: 4px; font-weight: 700; }
    .sdm-delete-input {
        width: 100%; padding: 10px 12px; border: 2px solid #fca5a5; border-radius: 8px;
        font-size: 16px; transition: all .15s; box-sizing: border-box;
    }
    .sdm-delete-input:focus { outline: none; border-color: #dc2626; box-shadow: 0 0 0 3px rgba(220,38,38,.2); }
    .sdm-delete-input-armed { border-color: #dc2626; background: #fef2f2; }
    .sdm-delete-actions {
        display: flex; gap: 10px; justify-content: flex-end; padding: 0 16px 16px;
    }

    .sdm-toast {
        position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
        background: #1e293b; color: #fff; padding: 10px 18px; border-radius: 999px;
        font-size: .85rem; box-shadow: 0 10px 30px rgba(0,0,0,.3); z-index: 20;
    }
    .sdm-toast-error { background: #b91c1c; }

    @@media (max-width: 768px) {
        .sdm-panel { margin: 0; border-radius: 0; }
        .sdm-header { padding: 12px 14px; }
        .sdm-tabs { padding: 10px 10px 0; flex-wrap: wrap; }
        .sdm-tab { font-size: .78rem; padding: 7px 12px; }
        .sdm-toolbar { padding: 10px 12px; }
        .sdm-body { padding: 0 10px 14px; }
        .sdm-pretext { max-width: 200px; }
        .sdm-header-pc { font-size: .95rem; }
    }
    @@media (max-width: 480px) {
        .sdm-tab span.sdm-tab-count { display: none; }
        .sdm-tab { flex: 1; justify-content: center; }
    }
</style>
}

@code {
    // ── Parameters ───────────────────────────────────────────
    [Parameter] public bool Show { get; set; }
    [Parameter] public int PcId { get; set; }
    [Parameter] public string PcName { get; set; } = "";
    [Parameter] public int? CurrentSessionId { get; set; }
    [Parameter] public string? SessionName { get; set; }
    [Parameter] public int CurrentUserId { get; set; }
    [Parameter] public string CurrentUserName { get; set; } = "";
    [Parameter] public EventCallback OnCloseRequested { get; set; }

    enum Tab { Evil, Serfac, Pts }
    Tab _activeTab = Tab.Evil;
    bool _sortDesc = true;

    // Data
    List<EvilPurposeRow>  _evil   = new();
    List<SerfacRow>       _serfac = new();
    List<PtsHandlingRow>  _pts    = new();
    List<SessionLite>     _sessions = new();
    List<UserLite>        _users    = new();

    // Edit/add state (one row at a time per modal)
    int _editingId = 0;  // > 0 when editing an existing row
    bool _isAdding = false;
    EvilPurposeRow?  _editEvil;
    SerfacRow?       _editSerfac;
    PtsHandlingRow?  _editPts;

    // Delete state
    sealed record DeleteTarget(Tab Kind, int Id, string Title, string Content);
    DeleteTarget? _deleting;
    string _deleteInput = "";
    bool IsDeleteArmed => string.Equals((_deleteInput ?? "").Trim(), "delete", StringComparison.OrdinalIgnoreCase);

    // Toast
    string _toast = "";
    bool _toastIsError;
    System.Threading.CancellationTokenSource? _toastCts;

    bool _downloading;

    // Track Show changes to load on open
    bool _loaded;

    protected override async Task OnParametersSetAsync()
    {
        if (Show && !_loaded)
        {
            await LoadAllAsync();
            _loaded = true;
        }
        else if (!Show && _loaded)
        {
            // reset per-open state when closed
            ResetModalState();
            _loaded = false;
        }
    }

    void ResetModalState()
    {
        _activeTab = Tab.Evil;
        _sortDesc = true;
        _editingId = 0;
        _isAdding = false;
        _editEvil = null; _editSerfac = null; _editPts = null;
        _deleting = null;
        _deleteInput = "";
        _toast = "";
        _toastCts?.Cancel();
        _toastCts = null;
        _evil.Clear(); _serfac.Clear(); _pts.Clear();
    }

    async Task LoadAllAsync()
    {
        try
        {
            await Task.Run(() =>
            {
                _evil     = SdSvc.GetEvilPurposes(PcId);
                _serfac   = SdSvc.GetSerfacs(PcId);
                _pts      = SdSvc.GetPtsHandling(PcId);
                _sessions = SdSvc.GetSessionsForPc(PcId);
                _users    = SdSvc.GetActiveUsers();
            });
        }
        catch (Exception ex)
        {
            ShowToast("Failed to load data: " + ex.Message, true);
        }
    }

    async Task OnClose() => await OnCloseRequested.InvokeAsync();

    async Task OnBackdropClick()
    {
        if (_deleting != null) return;  // don't close while delete dialog is open
        await OnClose();
    }

    void SwitchTab(Tab t)
    {
        if (_activeTab == t) return;
        CancelEdit();
        _activeTab = t;
    }

    // ── Sorting ─────────────────────────────────────────────
    IEnumerable<EvilPurposeRow>  SortedEvil   => _sortDesc ? _evil   : _evil.AsEnumerable().Reverse();
    IEnumerable<SerfacRow>       SortedSerfac => _sortDesc ? _serfac : _serfac.AsEnumerable().Reverse();
    IEnumerable<PtsHandlingRow>  SortedPts    => _sortDesc ? _pts    : _pts.AsEnumerable().Reverse();

    // ── Add / Edit / Cancel / Save ──────────────────────────
    void AddRow()
    {
        if (_editingId != 0 || _isAdding) return;
        _isAdding = true;
        var now = DateTime.Now.ToString("yyyy-MM-dd");
        switch (_activeTab)
        {
            case Tab.Evil:
                _editEvil = new EvilPurposeRow(0, PcId, CurrentSessionId, now, "", "", "", "", CurrentUserId, CurrentUserName);
                break;
            case Tab.Serfac:
                _editSerfac = new SerfacRow(0, PcId, CurrentSessionId, now, "", "", "", "", CurrentUserId, CurrentUserName);
                break;
            case Tab.Pts:
                _editPts = new PtsHandlingRow(0, PcId, CurrentSessionId, now, "", "", "", "", "", "", CurrentUserId, CurrentUserName);
                break;
        }
    }

    void StartEditEvil(EvilPurposeRow r)   { CancelEdit(); _editingId = r.Id; _editEvil   = r with { }; }
    void StartEditSerfac(SerfacRow r)      { CancelEdit(); _editingId = r.Id; _editSerfac = r with { }; }
    void StartEditPts(PtsHandlingRow r)    { CancelEdit(); _editingId = r.Id; _editPts    = r with { }; }

    void CancelEdit()
    {
        _editingId = 0;
        _isAdding = false;
        _editEvil = null; _editSerfac = null; _editPts = null;
    }

    async Task SaveEditAsync()
    {
        try
        {
            switch (_activeTab)
            {
                case Tab.Evil:
                    if (_editEvil == null) return;
                    if (_isAdding)
                    {
                        var id = SdSvc.InsertEvilPurpose(_editEvil);
                        _evil.Insert(0, _editEvil with { Id = id, InsertedByName = ResolveUserName(_editEvil.InsertedBy) });
                    }
                    else
                    {
                        SdSvc.UpdateEvilPurpose(_editEvil);
                        var idx = _evil.FindIndex(x => x.Id == _editEvil.Id);
                        if (idx >= 0) _evil[idx] = _editEvil with { InsertedByName = ResolveUserName(_editEvil.InsertedBy) };
                    }
                    break;

                case Tab.Serfac:
                    if (_editSerfac == null) return;
                    if (_isAdding)
                    {
                        var id = SdSvc.InsertSerfac(_editSerfac);
                        _serfac.Insert(0, _editSerfac with { Id = id, CreatedByName = ResolveUserName(_editSerfac.CreatedBy) });
                    }
                    else
                    {
                        SdSvc.UpdateSerfac(_editSerfac);
                        var idx = _serfac.FindIndex(x => x.Id == _editSerfac.Id);
                        if (idx >= 0) _serfac[idx] = _editSerfac with { CreatedByName = ResolveUserName(_editSerfac.CreatedBy) };
                    }
                    break;

                case Tab.Pts:
                    if (_editPts == null) return;
                    if (_isAdding)
                    {
                        var id = SdSvc.InsertPtsHandling(_editPts);
                        _pts.Insert(0, _editPts with { Id = id, CreatedByName = ResolveUserName(_editPts.CreatedBy) });
                    }
                    else
                    {
                        SdSvc.UpdatePtsHandling(_editPts);
                        var idx = _pts.FindIndex(x => x.Id == _editPts.Id);
                        if (idx >= 0) _pts[idx] = _editPts with { CreatedByName = ResolveUserName(_editPts.CreatedBy) };
                    }
                    break;
            }
            CancelEdit();
            ShowToast("Saved", false);
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            ShowToast("Save failed: " + ex.Message, true);
        }
    }

    string ResolveUserName(int userId)
    {
        var u = _users.FirstOrDefault(x => x.Id == userId);
        return u?.DisplayName ?? $"User {userId}";
    }

    // ── Delete ──────────────────────────────────────────────
    void RequestDeleteEvil(EvilPurposeRow r)
    {
        var preview = $"Id: {r.Id}\nCreated: {FmtDate(r.CreatedAt)}\nOriginal: {Short(r.OriginalWording)}\nTranslation: {Short(r.Translation)}\nFPRD: {Short(r.FPRD)}\nOther: {Short(r.Other)}";
        _deleting = new DeleteTarget(Tab.Evil, r.Id, "Evil Purpose", preview);
        _deleteInput = "";
    }
    void RequestDeleteSerfac(SerfacRow r)
    {
        var preview = $"Id: {r.Id}\nCreated: {FmtDate(r.CreatedAt)}\nOriginal: {Short(r.OriginalWording)}\nTranslation: {Short(r.Translation)}\nBrackets: {Short(r.Brackets)}\nR3RA: {Short(r.R3RA)}";
        _deleting = new DeleteTarget(Tab.Serfac, r.Id, "Service Facsimile", preview);
        _deleteInput = "";
    }
    void RequestDeletePts(PtsHandlingRow r)
    {
        var preview = $"Id: {r.Id}\nCreated: {FmtDate(r.CreatedAt)}\nAction: {Short(r.Action)}\nItem: {Short(r.Item)}\nQuad Ruds: {Short(r.QuadRuds)}\nPU: {Short(r.PU)}\nPTS RD: {Short(r.PtsRd)}\nLs: {Short(r.Ls)}";
        _deleting = new DeleteTarget(Tab.Pts, r.Id, "PTS Handling", preview);
        _deleteInput = "";
    }

    static string Short(string? s)
    {
        if (string.IsNullOrEmpty(s)) return "(empty)";
        return s.Length > 120 ? s[..120] + "…" : s;
    }

    void CancelDelete()
    {
        _deleting = null;
        _deleteInput = "";
    }

    async Task ConfirmDelete()
    {
        if (!IsDeleteArmed || _deleting == null) return;
        var d = _deleting;
        try
        {
            switch (d.Kind)
            {
                case Tab.Evil:
                    SdSvc.DeleteEvilPurpose(d.Id);
                    _evil.RemoveAll(x => x.Id == d.Id);
                    break;
                case Tab.Serfac:
                    SdSvc.DeleteSerfac(d.Id);
                    _serfac.RemoveAll(x => x.Id == d.Id);
                    break;
                case Tab.Pts:
                    SdSvc.DeletePtsHandling(d.Id);
                    _pts.RemoveAll(x => x.Id == d.Id);
                    break;
            }
            CancelDelete();
            ShowToast("Row deleted", false);
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            ShowToast("Delete failed: " + ex.Message, true);
        }
    }

    // ── Toast ───────────────────────────────────────────────
    void ShowToast(string msg, bool isError)
    {
        _toast = msg;
        _toastIsError = isError;
        _toastCts?.Cancel();
        _toastCts = new System.Threading.CancellationTokenSource();
        var token = _toastCts.Token;
        _ = Task.Run(async () =>
        {
            try { await Task.Delay(2400, token); }
            catch { return; }
            if (!token.IsCancellationRequested)
                await InvokeAsync(() => { _toast = ""; StateHasChanged(); });
        });
    }

    // ── Helpers used by templates ────────────────────────────
    string FmtSessionLabel(int? sid)
    {
        if (sid is null or 0) return "(no session)";
        var s = _sessions.FirstOrDefault(x => x.SessionId == sid.Value);
        return s?.Label ?? $"Session #{sid} (missing)";
    }

    IEnumerable<SessionLite> SessionOptionsIncluding(int? currentSid)
    {
        var list = _sessions.ToList();
        if (currentSid is > 0 && !list.Any(s => s.SessionId == currentSid.Value))
            list.Insert(0, new SessionLite(currentSid.Value, $"Session #{currentSid} (missing)"));
        return list;
    }

