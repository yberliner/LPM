                            <td><div class="sdm-pretext sdm-pretext-short @(string.IsNullOrEmpty(r.QuadRuds) ? "sdm-muted" : "")">@(string.IsNullOrEmpty(r.QuadRuds) ? "(empty)" : r.QuadRuds)</div></td>
                            <td><div class="sdm-pretext sdm-pretext-short @(string.IsNullOrEmpty(r.PU) ? "sdm-muted" : "")">@(string.IsNullOrEmpty(r.PU) ? "(empty)" : r.PU)</div></td>
                            <td><div class="sdm-pretext sdm-pretext-short @(string.IsNullOrEmpty(r.PtsRd) ? "sdm-muted" : "")">@(string.IsNullOrEmpty(r.PtsRd) ? "(empty)" : r.PtsRd)</div></td>
                            <td><div class="sdm-pretext sdm-pretext-short @(string.IsNullOrEmpty(r.Ls) ? "sdm-muted" : "")">@(string.IsNullOrEmpty(r.Ls) ? "(empty)" : r.Ls)</div></td>
                            <td class="sdm-cell-by">@r.CreatedByName</td>
                            <td class="sdm-cell-actions">
                                <button class="sdm-btn sdm-btn-edit" title="Edit row" @onclick="() => StartEditPts(r)"><i class="ri-pencil-line"></i></button>
                                <button class="sdm-btn sdm-btn-delete" title="Delete row" @onclick="() => RequestDeletePts(r)"><i class="ri-delete-bin-line"></i></button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
        </div>
    };

    static int? ParseNullableInt(object? v)
    {
        var s = v?.ToString();
        if (string.IsNullOrWhiteSpace(s)) return null;
        return int.TryParse(s, out var n) ? n : null;
    }

    static int ParseIntOr(object? v, int fallback)
    {
        var s = v?.ToString();
        return int.TryParse(s, out var n) ? n : fallback;
    }

    // Return the yyyy-MM-dd portion from a CreatedAt string that may be "yyyy-MM-dd HH:mm:ss" or already just a date.
    static string FmtDate(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "";
        if (DateTime.TryParse(s, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.AssumeLocal, out var dt))
            return dt.ToString("yyyy-MM-dd");
        return s.Length >= 10 ? s.Substring(0, 10) : s;
    }

    // ── PDF download ───────────────────────────────────────────
    async Task DownloadCurrentTableAsync()
    {
        if (_downloading) return;
        _downloading = true;
        try
        {
            string title;
            string fileStem;
            string[] headers;
            float[] weights;
            List<string[]> rows;

            switch (_activeTab)
            {
                case Tab.Evil:
                    title = "Evil Purposes";
                    fileStem = "EvilPurposes";
                    headers = new[] { "Id", "Session", "Created", "Original Wording", "Translation", "FPRD", "Other", "Inserted By" };
                    weights = new float[] { 0.6f, 2.0f, 1.6f, 3.0f, 3.0f, 1.2f, 1.4f, 1.6f };
                    rows = SortedEvil.Select(r => new[]
                    {
                        r.Id.ToString(),
                        FmtSessionLabel(r.SessionId),
                        FmtDate(r.CreatedAt),
                        r.OriginalWording ?? "",
                        r.Translation ?? "",
                        r.FPRD ?? "",
                        r.Other ?? "",
                        r.InsertedByName
                    }).ToList();
                    break;

                case Tab.Serfac:
                    title = "Service Facsimiles";
                    fileStem = "Serfacs";
                    headers = new[] { "Id", "Session", "Created", "Original Wording", "Translation", "Brackets", "R3RA", "Created By" };
                    weights = new float[] { 0.6f, 2.0f, 1.6f, 3.0f, 3.0f, 1.6f, 1.6f, 1.6f };
                    rows = SortedSerfac.Select(r => new[]
                    {
                        r.Id.ToString(),
                        FmtSessionLabel(r.SessionId),
                        FmtDate(r.CreatedAt),
                        r.OriginalWording ?? "",
                        r.Translation ?? "",
                        r.Brackets ?? "",
                        r.R3RA ?? "",
                        r.CreatedByName
                    }).ToList();
                    break;

                default: // Tab.Pts
                    title = "PTS Handling";
                    fileStem = "PtsHandling";
                    headers = new[] { "Id", "Session", "Created", "Action", "Item", "Quad Ruds", "PU", "PTS RD", "Ls", "Created By" };
                    weights = new float[] { 0.6f, 2.0f, 1.6f, 1.4f, 1.8f, 1.4f, 1.4f, 1.4f, 1.2f, 1.6f };
                    rows = SortedPts.Select(r => new[]
                    {
                        r.Id.ToString(),
                        FmtSessionLabel(r.SessionId),
                        FmtDate(r.CreatedAt),
                        r.Action ?? "",
                        r.Item ?? "",
                        r.QuadRuds ?? "",
                        r.PU ?? "",
                        r.PtsRd ?? "",
                        r.Ls ?? "",
                        r.CreatedByName
                    }).ToList();
                    break;
            }

            var sortLabel = _sortDesc ? "Sorted newest first" : "Sorted oldest first";
            byte[] bytes = await Task.Run(() =>
                PdfSvc.GenerateSessionDataTablePdf(
                    title, PcName, SessionName, CurrentUserName, sortLabel,
                    headers, weights, rows));

            var safePc = SanitizeForFile(PcName);
            var ts = DateTime.Now.ToString("yyyy-MM-dd_HHmmss");
            var fileName = $"{safePc}_{fileStem}_{ts}.pdf";
            await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(bytes));
            ShowToast("PDF ready", false);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[SessionDataModal] PDF generation failed: {ex.GetType().Name}: {ex.Message}\n{ex.StackTrace}");
            if (ex.InnerException != null)
                Console.WriteLine($"[SessionDataModal] Inner: {ex.InnerException.GetType().Name}: {ex.InnerException.Message}");
            ShowToast("Download failed: " + ex.Message, true);
        }
        finally
        {
            _downloading = false;
        }
    }

    static string SanitizeForFile(string s)
    {
        if (string.IsNullOrWhiteSpace(s)) return "table";
        var invalid = System.IO.Path.GetInvalidFileNameChars();
        var cleaned = new System.Text.StringBuilder(s.Length);
        foreach (var ch in s)
            cleaned.Append(invalid.Contains(ch) || char.IsWhiteSpace(ch) ? '_' : ch);
        var result = cleaned.ToString().Trim('_');
        return string.IsNullOrEmpty(result) ? "table" : result;
    }
}
