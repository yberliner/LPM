@using LPM.Services
@inject WalletService WalletSvc
@inject DashboardService DashSvc
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="modal show d-block" tabindex="-1"
         style="background:rgba(0,0,0,.55); z-index:10000;" @onclick="CloseIfOutside">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-content wallet-modal-content">
                <div class="modal-header py-2"
                     style="background:linear-gradient(135deg,#7c3aed,#a855f7); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-exchange-funds-line"></i> Transfer balance
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DoClose"></button>
                </div>

                <div class="modal-body">
                    @if (_error != null)
                    {
                        <div class="alert alert-danger py-2 mb-2" style="font-size:.82rem;">@_error</div>
                    }
                    @if (_sourceWallet != null)
                    {
                        <div class="mb-3">
                            <label class="wallet-lbl">From wallet</label>
                            <div class="wt-from-pill" style="border-color:@CurrencyColor(_sourceWallet.Currency);">
                                <span class="wt-cur" style="color:@CurrencyColor(_sourceWallet.Currency);">@CurrencySymbol(_sourceWallet.Currency)</span>
                                <div class="wt-pill-body">
                                    <div class="wt-pill-name">@_sourceWallet.Name</div>
                                    <div class="wt-pill-sub">@_sourceWallet.Currency · PC #@_sourceWallet.PcId</div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Target PC -->
                    <div class="mb-3">
                        <label class="wallet-lbl">Target PC <span class="text-danger">*</span></label>
                        <select class="form-select form-select-sm wallet-input"
                                value="@_targetPcId"
                                @onchange='e => { _targetPcId = int.Parse(e.Value?.ToString() ?? "0"); RefreshTargetPreview(); }'>
                            <option value="0">— Choose a PC —</option>
                            @foreach (var pc in _allPcs)
                            {
                                <option value="@pc.PcId">@pc.FullName</option>
                            }
                        </select>
                    </div>

                    @if (_targetPcId > 0 && _sourceWallet != null)
                    {
                        <div class="mb-3">
                            <label class="wallet-lbl">Target wallet</label>
                            @if (_matchingTargetWallets.Count > 1)
                            {
                                <select class="form-select form-select-sm wallet-input"
                                        value="@_targetWalletId"
                                        @onchange='e => _targetWalletId = int.Parse(e.Value?.ToString() ?? "0")'>
                                    @foreach (var w in _matchingTargetWallets)
                                    {
                                        var disabled = w.WalletId == _sourceWallet.WalletId;
                                        <option value="@w.WalletId" disabled="@disabled">
                                            @w.Name (@w.Currency)@(disabled ? " — same as source" : "")
                                        </option>
                                    }
                                </select>
                                <div class="text-muted mt-1" style="font-size:.72rem;">
                                    This PC has multiple @_sourceWallet.Currency wallets — pick which one to receive.
                                </div>
                            }
                            else if (_matchingTargetWallets.Count == 1)
                            {
                                <div class="form-control form-control-sm" style="background:#f1f5f9; border:1px solid #cbd5e1; font-size:.82rem;">
                                    <i class="ri-checkbox-circle-fill me-1" style="color:#10b981;"></i>
                                    <strong>@_matchingTargetWallets[0].Name</strong>
                                    <span class="text-muted"> (@_matchingTargetWallets[0].Currency)</span>
                                </div>
                            }
                            else
                            {
                                <div class="form-control form-control-sm" style="background:#fffbeb; border:1px solid #fbbf24; font-size:.82rem;">
                                    <i class="ri-add-circle-line me-1" style="color:#f59e0b;"></i>
                                    No @_sourceWallet.Currency wallet here — a new one will be created automatically.
                                </div>
                            }
                        </div>
                    }

                    <!-- Amount -->
                    <div class="mb-3">
                        <label class="wallet-lbl">
                            Amount (@(_sourceWallet?.Currency ?? "")) <span class="text-danger">*</span>
                        </label>
                        <input type="number" class="form-control form-control-sm wallet-input"
                               value="@_amountText" min="1" step="1"
                               @oninput="e => _amountText = e.Value?.ToString() ?? string.Empty" />
                    </div>

                    <!-- Notes -->
                    <div class="mb-3">
                        <label class="wallet-lbl">Notes</label>
                        <textarea class="form-control form-control-sm wallet-input" rows="2" maxlength="300"
                                  @bind="_notes"></textarea>
                    </div>
                </div>

                <div class="modal-footer py-2">
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="DoClose" disabled="@_submitting">Cancel</button>
                    <button type="button" class="btn btn-sm btn-primary"
                            style="background:linear-gradient(135deg,#7c3aed,#a855f7); border:none;"
                            @onclick="Submit" disabled="@(!CanSubmit || _submitting)">
                        @if (_submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Transfer
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .wt-from-pill {
        display:flex; align-items:center; gap:12px;
        padding:10px 14px; border-radius:10px;
        border:2px solid; background:#f8fafc; min-height:56px;
    }
    .wt-cur { font-size:2rem; font-weight:900; line-height:1; }
    .wt-pill-name { font-weight:700; color:#1e293b; font-size:.95rem; }
    .wt-pill-sub  { font-size:.75rem; color:#64748b; }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public int? SourceWalletId { get; set; }
    [Parameter] public int  CurrentUserPersonId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnTransferred { get; set; }

    Wallet? _sourceWallet;
    int _targetPcId;
    int _targetWalletId;
    List<Wallet> _matchingTargetWallets = new();
    string _amountText = "";
    string _notes = "";
    List<DashboardService.ApprovedPc> _allPcs = new();
    bool _submitting;
    bool _wasOpen;
    string? _error;

    bool CanSubmit => _sourceWallet != null
                   && _targetPcId > 0
                   && long.TryParse(_amountText, out var a) && a > 0
                   && (_matchingTargetWallets.Count != 1 ||
                       _matchingTargetWallets[0].WalletId != _sourceWallet.WalletId)
                   && (_matchingTargetWallets.Count <= 1 ||
                       (_targetWalletId > 0 && _targetWalletId != _sourceWallet.WalletId));

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_wasOpen) Load();
        _wasOpen = IsOpen;
        await Task.CompletedTask;
    }

    void Load()
    {
        _error = null;
        _submitting = false;
        _targetPcId = 0;
        _targetWalletId = 0;
        _matchingTargetWallets = new();
        _amountText = "";
        _notes = "";
        _sourceWallet = SourceWalletId.HasValue ? WalletSvc.GetWallet(SourceWalletId.Value) : null;
        // Load every PC (admin action). Uses DashSvc.GetApprovedPcsForUser with AllowAll path.
        _allPcs = DashSvc.GetAllPcs().Select(p => new DashboardService.ApprovedPc(p.PcId, p.FullName)).ToList();
    }

    void RefreshTargetPreview()
    {
        if (_sourceWallet == null || _targetPcId <= 0)
        {
            _matchingTargetWallets = new();
            _targetWalletId = 0;
            return;
        }
        _matchingTargetWallets = WalletSvc.GetWalletsForPc(_targetPcId, includeInactive: false)
            .Where(w => w.Currency == _sourceWallet.Currency)
            .ToList();
        // Preselect first non-source wallet (relevant for same-PC transfer)
        var preferred = _matchingTargetWallets.FirstOrDefault(w => w.WalletId != _sourceWallet.WalletId);
        _targetWalletId = preferred?.WalletId ?? 0;
    }

    async Task Submit()
    {
        if (!CanSubmit || _submitting || _sourceWallet == null) return;
        _submitting = true;
        try
        {
            long amount = long.Parse(_amountText);
            int? explicitTarget = _matchingTargetWallets.Count > 1 && _targetWalletId > 0 ? _targetWalletId : null;
            var r = WalletSvc.Transfer(_sourceWallet.WalletId, _targetPcId, amount,
                string.IsNullOrWhiteSpace(_notes) ? null : _notes, CurrentUserPersonId,
                toWalletIdOverride: explicitTarget);
            try { await JS.InvokeVoidAsync("lpmToast", $"Transferred {amount} {_sourceWallet.Currency}", "success"); } catch { }
            await OnTransferred.InvokeAsync();
            await DoClose();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _submitting = false;
        }
    }

    async Task DoClose() { _submitting = false; await OnClose.InvokeAsync(); }
    Task CloseIfOutside() => DoClose();

    static string CurrencySymbol(string c) => c switch { "EUR" => "€", "USD" => "$", _ => "₪" };
    static string CurrencyColor(string c)  => c switch { "EUR" => "#10b981", "USD" => "#0ea5e9", _ => "#3b82f6" };
}
