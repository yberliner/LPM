@inherits LayoutComponentBase
@inject IHttpContextAccessor HttpContextAccessor
@using Microsoft.JSInterop
@inject IJSRuntime JSRuntime
@using System.Text.Json
@inject StateService stateService
@inject SessionService _sessionService
@inject NavigationManager NavigationManager
@inject LPM.Services.ShortcutService ShortcutSvc
@inject LPM.Services.UserActivityService ActivitySvc
@implements IDisposable

<Switcher />

<div class="page">

        <MainHeader ShowMenuToggle="true" />

        <NavMenu @ref="navMenuRef" />

        <div class="main-content app-content" @onclick="() => icontextCloseFn()">
            <div class="container-fluid" @key="LS.CurrentLanguage">
                @Body
            </div>
        </div>

        <Footer />

        @if (ShowButton)
        {
            <!-- Scroll To Top -->
            <div class="scrollToTop"  @onclick="ScrollToTop">
                <span class="arrow lh-1"><i class="ti ti-arrow-narrow-up fs-20"></i></span>
            </div>
            <!-- Scroll To Top -->
        }

</div>

@code {

    NavMenu? navMenuRef;
    bool ShowButton { get; set; } = false;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var savedLang = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "lpm-lang");
                if (!string.IsNullOrEmpty(savedLang) && savedLang != LS.CurrentLanguage)
                    LS.SetLanguage(savedLang);

                await JSRuntime.InvokeVoidAsync("interop.addAttributeToHtml", "dir", LS.IsRtl ? "rtl" : "ltr");
                await stateService.retrieveFromLocalStorage();
                _scrollVisRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("interop.updateScrollVisibility", _scrollVisRef);

                try
                {
                    var sc = ShortcutSvc.GetShortcuts();
                    await JSRuntime.InvokeVoidAsync("lpmLoadShortcuts", sc);
                }
                catch { /* non-critical */ }

                var dataNavLayout = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-nav-layout");
                var inner = await JSRuntime.InvokeAsync<int>("interop.inner", "innerWidth");
                if (dataNavLayout == "horizontal" && inner >= 992)
                    navMenuRef?.closeMenuFn();

                // ── User interaction heartbeat (30s interval) ──
                _heartbeatRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("eval", @"
                    window._lpmStartHeartbeat = function(ref) {
                        if (window._lpmHeartbeatId) clearInterval(window._lpmHeartbeatId);
                        // Remove previously attached listeners
                        if (window._lpmHeartbeatHandler) {
                            var h = window._lpmHeartbeatHandler;
                            ['mousemove','keydown','click','scroll','touchstart'].forEach(function(e) {
                                document.removeEventListener(e, h);
                            });
                        }
                        var active = true;
                        var handler = function() { active = true; };
                        window._lpmHeartbeatHandler = handler;
                        document.addEventListener('mousemove', handler, {passive:true});
                        document.addEventListener('keydown', handler, {passive:true});
                        document.addEventListener('click', handler, {passive:true});
                        document.addEventListener('scroll', handler, {passive:true});
                        document.addEventListener('touchstart', handler, {passive:true});
                        window._lpmHeartbeatId = setInterval(function() {
                            if (active) {
                                try { ref.invokeMethodAsync('OnUserInteraction'); } catch(e) {}
                                active = false;
                            }
                        }, 30000);
                    };
                ");
                await JSRuntime.InvokeVoidAsync("_lpmStartHeartbeat", _heartbeatRef);
            }
            catch (JSDisconnectedException) { /* circuit closed before JS completed — safe to ignore */ }
            catch (TaskCanceledException)   { /* circuit shutdown during await — safe to ignore */ }
        }
    }
    [JSInvokable]
    public void UpdateScrollVisibility(int scrollHeight)
    {
        ShowButton = scrollHeight >= 100;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnUserInteraction()
    {
        if (!string.IsNullOrEmpty(_activityUsername))
            ActivitySvc.RecordInteraction(_activityUsername);
    }
    async Task ScrollToTop()
    {
        await JSRuntime.InvokeVoidAsync("interop.scrollToTop");
    }

    DotNetObjectReference<MainLayout>? _scrollVisRef;
    DotNetObjectReference<MainLayout>? _heartbeatRef;
    private string _activityUsername = "";
    private string _lastNavUrl = "";

    protected override async Task OnInitializedAsync()
    {
        LS.OnLanguageChanged += HandleLanguageChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
        var currentState = new AppState();
        var newState = stateService.GetAppState();
        if(!currentState.Equals(newState)){
            @* await stateService.retrieveFromLocalStorage(); *@
        }
        _activityUsername = HttpContextAccessor.HttpContext?.User?.Identity?.Name ?? "";
        _lastNavUrl = NavigationManager.Uri;
        if (!string.IsNullOrEmpty(_activityUsername))
            ActivitySvc.RecordActivity(_activityUsername,
                "Navigated to " + LPM.Services.UserActivityService.FriendlyPageName(NavigationManager.Uri),
                "navigation");
        StateHasChanged();
        await base.OnInitializedAsync();
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        try
        {
            // Skip if same URL as the one already recorded in OnInitializedAsync
            if (!string.IsNullOrEmpty(_activityUsername) && e.Location != _lastNavUrl)
                ActivitySvc.RecordActivity(_activityUsername,
                    "Navigated to " + LPM.Services.UserActivityService.FriendlyPageName(e.Location),
                    "navigation");
            _lastNavUrl = e.Location;
            var savedLang = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "lpm-lang");
            if (!string.IsNullOrEmpty(savedLang) && savedLang != LS.CurrentLanguage)
            {
                LS.SetLanguage(savedLang);
            }
            await JSRuntime.InvokeVoidAsync("interop.addAttributeToHtml", "dir", LS.IsRtl ? "rtl" : "ltr");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    // Icon ClickOpen Start
    private async void icontextCloseFn()
    {
        try
        {
            var dataToggled = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-toggled");
            var dataNavLayout = await JSRuntime.InvokeAsync<string>("interop.getAttributeToHtml", "data-nav-layout");
            var inner = await JSRuntime.InvokeAsync<int>("interop.inner", "innerWidth");
            if (dataToggled == "icon-text-close") {
                await JSRuntime.InvokeAsync<string>("interop.removeAttributeFromHtml", "data-icon-text");
            }
            if (dataNavLayout == "horizontal" && inner >= 992)
            {
                navMenuRef?.closeMenuFn();
            }
        }
        catch (TaskCanceledException)
        {
            // Suppress expected cancellation exceptions (circuit shutdown, etc.)
            Console.WriteLine("[MainLayout] Task was canceled, likely due to circuit shutdown.");
        }
        catch (JSException)
        {
            Console.WriteLine("[MainLayout] JS interop error in icontextCloseFn, likely due to missing JS function or attribute.");
            // Optionally suppress or log JS interop errors
        }
        catch (Exception ex)
        {
            // Optionally log unexpected exceptions
            Console.WriteLine($"[MainLayout] Exception in icontextCloseFn: {ex}");
        }
    }
    // Icon Clickopen End

    private async void HandleLanguageChanged()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("interop.addAttributeToHtml", "dir", LS.IsRtl ? "rtl" : "ltr");
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    public void Dispose()
    {
        LS.OnLanguageChanged -= HandleLanguageChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
        _scrollVisRef?.Dispose();
        try { _ = JSRuntime.InvokeVoidAsync("eval", @"
            if(window._lpmHeartbeatId){clearInterval(window._lpmHeartbeatId);window._lpmHeartbeatId=null;}
            if(window._lpmHeartbeatHandler){var h=window._lpmHeartbeatHandler;['mousemove','keydown','click','scroll','touchstart'].forEach(function(e){document.removeEventListener(e,h);});window._lpmHeartbeatHandler=null;}
        "); } catch { }
        _heartbeatRef?.Dispose();
    }
}