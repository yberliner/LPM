@using LPM.Services
@inject WalletService WalletSvc
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="modal show d-block wallet-modal-wrap" tabindex="-1"
         style="background:rgba(0,0,0,.55); z-index:10000;" @onclick="CloseIfOutside">
        <div class="modal-dialog modal-dialog-centered" style="max-width:520px;" @onclick:stopPropagation="true">
            <div class="modal-content wallet-modal-content">
                <div class="modal-header py-2" style="background:linear-gradient(135deg,#1e293b,#334155); border-bottom:none;">
                    <h5 class="modal-title fs-15 text-white d-flex align-items-center gap-2">
                        <i class="ri-wallet-3-fill" style="color:#fbbf24;"></i>
                        @(_isEdit ? "Edit Wallet" : "Add Wallet")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="DoClose"></button>
                </div>

                <div class="modal-body">
                    @* Big PC name banner *@
                    <div class="text-center mb-3">
                        <div style="font-size:.7rem; letter-spacing:.08em; color:#94a3b8; text-transform:uppercase; font-weight:600;">PC</div>
                        <div style="font-size:1.7rem; font-weight:800; color:#1e293b; line-height:1.1;">@PcName</div>
                    </div>

                    @if (_loadError != null)
                    {
                        <div class="alert alert-danger py-2 mb-2" style="font-size:.8rem;">@_loadError</div>
                    }

                    @* Live preview card *@
                    <div class="wallet-preview-wrap mb-3">
                        <div class="wallet-preview-card" style="background:@WalletGradient(_currency);">
                            <div class="wp-chip"></div>
                            <div class="wp-currency">@CurrencySymbol(_currency)</div>
                            <div class="wp-name">@(string.IsNullOrWhiteSpace(_name) ? "New wallet" : _name)</div>
                        </div>
                    </div>

                    <!-- Currency picker -->
                    <div class="mb-3">
                        <label class="form-label wallet-lbl">Currency <span class="text-danger">*</span></label>
                        <div class="wallet-cur-grid">
                            @foreach (var cur in new[] { "ILS", "EUR", "USD" })
                            {
                                var selected = _currency == cur;
                                var disabled = _isEdit && !_canChangeCurrency;
                                <button type="button" class="wallet-cur-btn @(selected ? "wallet-cur-active" : "")"
                                        disabled="@disabled"
                                        style="--cur-color:@CurrencyColor(cur);"
                                        @onclick="() => SelectCurrency(cur)">
                                    <span class="wallet-cur-sym">@CurrencySymbol(cur)</span>
                                    <span class="wallet-cur-code">@cur</span>
                                </button>
                            }
                        </div>
                        @if (_isEdit)
                        {
                            var chargedCount = _references.Count(r => r.HasCharge);
                            var zeroCount    = _references.Count - chargedCount;
                            <div class="wallet-lock-wrap" tabindex="0">
                                @if (_canChangeCurrency)
                                {
                                    <span class="wallet-lock-pill wallet-lock-ok">
                                        <i class="ri-lock-unlock-line me-1"></i>Currency can be changed
                                        @if (_references.Count > 0)
                                        {
                                            <span class="wallet-lock-sub">— @_references.Count reference@(_references.Count==1?"":"s"), none charged</span>
                                        }
                                    </span>
                                }
                                else
                                {
                                    <span class="wallet-lock-pill wallet-lock-locked">
                                        <i class="ri-lock-line me-1"></i>Currency locked — @chargedCount charged row@(chargedCount==1?"":"s")
                                    </span>
                                }

                                @if (_references.Count > 0)
                                {
                                    <div class="wallet-lock-card">
                                        <div class="wallet-lock-card-head">
                                            @if (_canChangeCurrency) { <text>No monetary effect yet. These rows still block physical delete:</text> }
                                            else                     { <text>Why this is locked</text> }
                                        </div>
                                        @{
                                            var groups = _references
                                                .GroupBy(r => r.Table)
                                                .OrderBy(g => g.Key switch { "Purchases"=>0, "Sessions"=>1, "CsReviews"=>2, _=>3 });
                                        }
                                        @foreach (var g in groups)
                                        {
                                            var icon = g.Key switch
                                            {
                                                "Purchases" => "ri-shopping-bag-3-line",
                                                "Sessions"  => "ri-time-line",
                                                "CsReviews" => "ri-search-eye-line",
                                                _           => "ri-file-list-line"
                                            };
                                            var label = g.Key switch
                                            {
                                                "Purchases" => "Purchases",
                                                "Sessions"  => "Sessions",
                                                "CsReviews" => "CS Reviews",
                                                _           => g.Key
                                            };
                                            <div class="wallet-lock-group">
                                                <div class="wallet-lock-group-title">
                                                    <i class="@icon me-1"></i>@label (@g.Count())
                                                </div>
                                                @foreach (var row in g)
                                                {
                                                    <div class="wallet-lock-row @(row.HasCharge ? "wallet-lock-row-charged" : "")">
                                                        <span class="wallet-lock-marker" title="@(row.HasCharge ? "Charged — blocks currency change" : "No charge — blocks delete only")">
                                                            @(row.HasCharge ? "⚠️" : "📌")
                                                        </span>
                                                        <span class="wallet-lock-summary">@row.Summary</span>
                                                        @if (!string.IsNullOrEmpty(row.DateText))
                                                        {
                                                            <span class="wallet-lock-date">@FmtDate(row.DateText)</span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                        <div class="wallet-lock-legend">
                                            <span>⚠️ charged · blocks currency change</span>
                                            <span>📌 zero-charge · blocks delete only</span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Name -->
                    <div class="mb-3">
                        <label class="form-label wallet-lbl">Wallet Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm wallet-input"
                               value="@_name" maxlength="80"
                               @oninput="e => _name = e.Value?.ToString() ?? string.Empty"
                               placeholder="@($"{_currency} wallet")" />
                    </div>

                    <!-- Notes -->
                    <div class="mb-3">
                        <label class="form-label wallet-lbl">Notes</label>
                        <textarea class="form-control form-control-sm wallet-input" rows="2" maxlength="500"
                                  @bind="_notes"></textarea>
                    </div>

                    @if (_isEdit)
                    {
                        <div class="mb-2 form-check">
                            <input type="checkbox" class="form-check-input" id="wallet-active"
                                   checked="@_isActive"
                                   @onchange="e => _isActive = (bool)(e.Value ?? false)" />
                            <label for="wallet-active" class="form-check-label" style="font-size:.85rem;">
                                Active (unchecked = deactivated, no new purchases/sessions)
                            </label>
                        </div>
                    }
                </div>

                <div class="modal-footer py-2">
                    @if (_isEdit)
                    {
                        @* Delete is gated on:
                             - wallet is changeable (no charged rows), AND
                             - PC has at least one OTHER wallet to receive the references. *@
                        var canDelete = _canChangeCurrency && _reassignTarget != null;
                        var deleteBlockedReason =
                            !_canChangeCurrency      ? "Charged rows — deactivate instead"
                          : _reassignTarget == null  ? "Can't delete the PC's only wallet"
                          : null;

                        @if (!_confirmDelete)
                        {
                            <button type="button" class="btn btn-sm btn-outline-danger me-auto"
                                    title="@(deleteBlockedReason ?? "")"
                                    @onclick="() => _confirmDelete = true"
                                    disabled="@(!canDelete || _submitting)">
                                <i class="ri-delete-bin-line me-1"></i>Delete wallet
                            </button>
                        }
                        else
                        {
                            <div class="me-auto d-flex flex-column" style="font-size:.78rem; color:#dc2626;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="ri-error-warning-line"></i>
                                    @if (_references.Count == 0)
                                    {
                                        <text>Delete this wallet?</text>
                                    }
                                    else
                                    {
                                        int pN  = _references.Count(r => r.Table == "Purchases");
                                        int sN  = _references.Count(r => r.Table == "Sessions");
                                        int crN = _references.Count(r => r.Table == "CsReviews");
                                        var parts = new List<string>();
                                        if (pN  > 0) parts.Add($"{pN} purchase{(pN==1?"":"s")}");
                                        if (sN  > 0) parts.Add($"{sN} session{(sN==1?"":"s")}");
                                        if (crN > 0) parts.Add($"{crN} CS review{(crN==1?"":"s")}");
                                        <text>Move @(string.Join(", ", parts)) to <strong>@(_reassignTarget?.Name) (@(_reassignTarget?.Currency))</strong> and delete?</text>
                                    }
                                    <button type="button" class="btn btn-sm btn-secondary py-0 px-2"
                                            @onclick="() => _confirmDelete = false" disabled="@_submitting">No</button>
                                    <button type="button" class="btn btn-sm btn-danger py-0 px-2"
                                            @onclick="DoDelete" disabled="@_submitting">Yes, delete</button>
                                </div>
                            </div>
                        }
                    }
                    <button type="button" class="btn btn-sm btn-secondary" @onclick="DoClose" disabled="@_submitting">Cancel</button>
                    <button type="button" class="btn btn-sm btn-primary wallet-submit"
                            @onclick="Submit" disabled="@(!CanSubmit || _submitting)">
                        @if (_submitting) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_isEdit ? "Save" : "Create Wallet")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .wallet-modal-content { border-radius:12px; overflow:hidden; }
    .wallet-modal-content .wallet-lbl { font-size:.82rem; color:#64748b; margin-bottom:.25rem; font-weight:600; }
    .wallet-modal-content .wallet-input { font-size:1rem; min-height:44px; border-radius:8px; }
    @@media (max-width:480px) {
        .wallet-modal-content .wallet-input { font-size:16px; }
    }
    .wallet-modal-content .modal-footer .btn { min-height:44px; min-width:120px; }
    .wallet-modal-content .wallet-submit {
        background: linear-gradient(135deg, #0891b2, #06b6d4);
        border: none; font-weight:600;
    }

    /* Currency picker */
    .wallet-cur-grid { display:grid; grid-template-columns:repeat(3, 1fr); gap:10px; }
    .wallet-cur-btn {
        background:#fff; border:2px solid #e2e8f0; border-radius:10px;
        padding:10px; min-height:72px;
        display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;
        cursor:pointer; color:#475569; transition: all .15s ease;
    }
    .wallet-cur-btn:hover:not(:disabled) { border-color: var(--cur-color); color: var(--cur-color); }
    .wallet-cur-btn.wallet-cur-active {
        border-color: var(--cur-color);
        background: color-mix(in srgb, var(--cur-color) 10%, white);
        color: var(--cur-color);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--cur-color) 20%, transparent);
    }
    .wallet-cur-btn:disabled { opacity:.55; cursor:not-allowed; }
    .wallet-cur-sym { font-size:1.6rem; font-weight:900; line-height:1; }
    .wallet-cur-code { font-size:.72rem; font-weight:700; letter-spacing:.06em; }

    /* Preview card */
    .wallet-preview-wrap { display:flex; justify-content:center; }
    .wallet-preview-card {
        width:100%; max-width:320px; aspect-ratio: 1.6 / 1;
        border-radius:14px; padding:16px; color:#fff;
        box-shadow: 0 14px 32px rgba(15,23,42,.22);
        position:relative; overflow:hidden;
        display:grid; grid-template-rows:auto 1fr auto; grid-template-columns:1fr auto;
    }
    .wallet-preview-card::after {
        content:''; position:absolute; inset:0;
        background: radial-gradient(circle at 80% 10%, rgba(255,255,255,.3), transparent 55%);
        pointer-events:none;
    }
    .wp-chip {
        width:34px; height:26px; border-radius:5px;
        background: linear-gradient(135deg, #fde68a, #f59e0b);
        box-shadow: inset 0 -3px 0 rgba(0,0,0,.15);
        grid-column:1; grid-row:1;
    }
    .wp-currency {
        grid-column:2; grid-row:1 / span 2;
        font-size:56px; font-weight:900; line-height:1;
        text-shadow: 0 4px 16px rgba(0,0,0,.3);
        letter-spacing:-.02em;
    }
    .wp-name {
        grid-column:1 / span 2; grid-row:3;
        font-weight:700; letter-spacing:.02em; font-size:.85rem;
        display:flex; justify-content:space-between; align-items:baseline;
    }
    .wp-rate {
        grid-column:1 / span 2; grid-row:2;
        align-self:end; font-size:.78rem; opacity:.85; font-weight:600;
    }

    /* ── Currency lock/unlock label + hover card ── */
    .wallet-lock-wrap {
        position: relative;
        display: inline-block;
        margin-top: 6px;
        outline: none;
    }
    .wallet-lock-pill {
        display: inline-flex;
        align-items: center;
        font-size: .72rem;
        font-weight: 600;
        padding: 3px 9px;
        border-radius: 999px;
        cursor: help;
        user-select: none;
        letter-spacing: .01em;
    }
    .wallet-lock-ok {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #86efac;
    }
    .wallet-lock-locked {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
    }
    .wallet-lock-sub { opacity: .75; margin-left: 4px; font-weight: 500; }

    .wallet-lock-card {
        position: absolute;
        top: calc(100% + 6px);
        left: 0;
        min-width: 320px;
        max-width: 440px;
        max-height: 340px;
        overflow-y: auto;
        background: #1a1f33;
        color: #e6e9f5;
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 10px;
        padding: 10px 12px;
        box-shadow: 0 14px 34px rgba(0,0,0,.45), 0 3px 10px rgba(0,0,0,.25);
        opacity: 0;
        visibility: hidden;
        transform: translateY(4px);
        transition: opacity 160ms ease, transform 160ms ease, visibility 0s linear 160ms;
        z-index: 20;
        text-align: left;
    }
    .wallet-lock-wrap:hover .wallet-lock-card,
    .wallet-lock-wrap:focus-within .wallet-lock-card,
    .wallet-lock-card:hover {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
        transition: opacity 160ms ease, transform 160ms ease, visibility 0s linear 0s;
    }
    .wallet-lock-card-head {
        font-size: .75rem;
        font-weight: 700;
        color: #fbbf24;
        margin-bottom: 6px;
    }
    .wallet-lock-group { margin-bottom: 6px; }
    .wallet-lock-group-title {
        font-size: .72rem;
        font-weight: 600;
        color: #93c5fd;
        margin-bottom: 3px;
    }
    .wallet-lock-row {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 3px 6px;
        border-radius: 6px;
        font-size: .72rem;
        background: #242a42;
        border: 1px solid rgba(255,255,255,.05);
        margin-bottom: 2px;
    }
    .wallet-lock-row-charged {
        background: #3d2a22;
        border-color: rgba(234,88,12,.5);
    }
    .wallet-lock-marker { flex: 0 0 auto; font-size: .85rem; }
    .wallet-lock-summary {
        flex: 1 1 auto;
        color: #e6e9f5;
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .wallet-lock-date {
        flex: 0 0 auto;
        color: #94a3b8;
        font-size: .68rem;
    }
    .wallet-lock-legend {
        margin-top: 6px;
        padding-top: 6px;
        border-top: 1px solid rgba(255,255,255,.08);
        display: flex;
        flex-direction: column;
        gap: 2px;
        font-size: .66rem;
        color: #94a3b8;
    }

    /* Light theme (in case modal inherits light palette — modal uses dark header but body is light) */
    :root[data-theme-mode="light"] .wallet-lock-card {
        background: #ffffff;
        color: #1f2937;
        border-color: rgba(0,0,0,.1);
        box-shadow: 0 14px 30px rgba(0,0,0,.18), 0 2px 6px rgba(0,0,0,.08);
    }
    :root[data-theme-mode="light"] .wallet-lock-row {
        background: #f8fafc;
        border-color: rgba(0,0,0,.06);
    }
    :root[data-theme-mode="light"] .wallet-lock-row-charged {
        background: #fef3c7;
        border-color: #f59e0b;
    }
    :root[data-theme-mode="light"] .wallet-lock-summary { color: #1f2937; }
    :root[data-theme-mode="light"] .wallet-lock-date    { color: #64748b; }
    :root[data-theme-mode="light"] .wallet-lock-card-head { color: #b45309; }
    :root[data-theme-mode="light"] .wallet-lock-group-title { color: #1d4ed8; }
    :root[data-theme-mode="light"] .wallet-lock-legend {
        color: #64748b;
        border-top-color: rgba(0,0,0,.08);
    }
</style>

@code {
    [Parameter] public bool     IsOpen { get; set; }
    [Parameter] public int      PcId   { get; set; }
    [Parameter] public string   PcName { get; set; } = "";
    [Parameter] public int?     EditingWalletId { get; set; }
    [Parameter] public int      CurrentUserPersonId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<int> OnSaved { get; set; }  // fires with WalletId
    [Parameter] public EventCallback<int> OnDeleted { get; set; } // fires with WalletId

    bool _confirmDelete;

    string _currency = "ILS";
    string _originalCurrency = "ILS";
    string _name     = "";
    string _notes    = "";
    bool   _isActive = true;
    bool   _isEdit   => EditingWalletId.HasValue;
    bool   _wasOpen;
    bool   _submitting;
    string? _loadError;

    IReadOnlyList<WalletService.WalletReferenceRow> _references = Array.Empty<WalletService.WalletReferenceRow>();
    bool _canChangeCurrency = true;
    // Target wallet for delete-with-reassign. Null → PC has no other wallet, so
    // the Delete button is disabled.
    Wallet? _reassignTarget;

    bool CanSubmit => !string.IsNullOrWhiteSpace(_currency)
                   && !string.IsNullOrWhiteSpace(_name);

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_wasOpen) await LoadForOpen();
        _wasOpen = IsOpen;
    }

    async Task LoadForOpen()
    {
        _loadError = null;
        _submitting = false;
        _confirmDelete = false;
        try
        {
            if (_isEdit)
            {
                var w = WalletSvc.GetWallet(EditingWalletId!.Value);
                if (w == null) { _loadError = "Wallet not found."; return; }
                _currency = w.Currency;
                _originalCurrency = w.Currency;
                _name     = w.Name;
                _notes    = w.Notes ?? "";
                _isActive = w.IsActive;
                _references = WalletSvc.GetWalletReferences(EditingWalletId.Value);
                _canChangeCurrency = !_references.Any(r => r.HasCharge);
                // Pre-resolve the reassign target so the Delete button knows whether it's
                // allowed (and can show the target name in the confirm dialog).
                var targetId = WalletSvc.ResolveReassignTarget(EditingWalletId.Value);
                _reassignTarget = targetId.HasValue ? WalletSvc.GetWallet(targetId.Value) : null;
            }
            else
            {
                _currency = "ILS";
                _originalCurrency = "ILS";
                _name     = "";
                _notes    = "";
                _isActive = true;
                _references = Array.Empty<WalletService.WalletReferenceRow>();
                _canChangeCurrency = true;
                _reassignTarget = null;
            }
        }
        catch (Exception ex) { _loadError = $"Failed to load: {ex.Message}"; }
        await InvokeAsync(StateHasChanged);
    }

    void SelectCurrency(string cur)
    {
        if (_isEdit && !_canChangeCurrency) return;
        if (string.Equals(_currency, cur, StringComparison.Ordinal)) return;
        var oldCur = _currency;
        _currency = cur;
        AutoRenameForCurrency(oldCur, cur);
    }

    /// <summary>
    /// If the current name looks like the default `{oldCur} wallet`, retarget it.
    /// Otherwise replace `oldCur` occurrences as a whole word; leave fully custom names alone.
    /// </summary>
    void AutoRenameForCurrency(string oldCur, string newCur)
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _name = $"{newCur} wallet";
            return;
        }
        var trimmed = _name.Trim();
        if (string.Equals(trimmed, $"{oldCur} wallet", StringComparison.OrdinalIgnoreCase) ||
            string.Equals(trimmed, $"{oldCur} Wallet", StringComparison.OrdinalIgnoreCase))
        {
            _name = $"{newCur} wallet";
            return;
        }
        // Whole-word replace of the currency code (case-insensitive)
        var pattern = $@"\b{System.Text.RegularExpressions.Regex.Escape(oldCur)}\b";
        if (System.Text.RegularExpressions.Regex.IsMatch(_name, pattern, System.Text.RegularExpressions.RegexOptions.IgnoreCase))
        {
            _name = System.Text.RegularExpressions.Regex.Replace(
                _name, pattern, newCur,
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        }
        // else: custom name — don't touch
    }

    async Task Submit()
    {
        if (!CanSubmit || _submitting) return;
        _submitting = true;
        try
        {
            string? notes = string.IsNullOrWhiteSpace(_notes) ? null : _notes;
            int walletId;
            if (_isEdit)
            {
                bool currencyChanged = !string.Equals(_currency, _originalCurrency, StringComparison.Ordinal);
                WalletSvc.UpdateWallet(
                    EditingWalletId!.Value, _name.Trim(), notes, _isActive,
                    newCurrency: currencyChanged ? _currency : null);
                walletId = EditingWalletId!.Value;
                var msg = currencyChanged
                    ? $"Wallet updated — {_name} · currency → {_currency}"
                    : $"Wallet updated — {_name}";
                try { await JS.InvokeVoidAsync("lpmToast", msg, "success"); } catch { }
                if (currencyChanged) _originalCurrency = _currency;
            }
            else
            {
                walletId = WalletSvc.AddWallet(PcId, _currency, _name.Trim(), notes, CurrentUserPersonId);
                // JS calls are best-effort — don't fail the wallet creation if they throw
                try { await JS.InvokeVoidAsync("lpmCelebrateWallet", _currency); } catch { }
                try { await JS.InvokeVoidAsync("lpmToast", $"Wallet created — {_name} ({_currency})", "success"); } catch { }
            }
            await OnSaved.InvokeAsync(walletId);
            await DoClose();
        }
        catch (Microsoft.Data.Sqlite.SqliteException sx) when (sx.Message.Contains("UNIQUE", StringComparison.OrdinalIgnoreCase))
        {
            _loadError = $"A wallet named \"{_name.Trim()}\" already exists for this PC. Pick a different name.";
            _submitting = false;
        }
        catch (Exception ex) { _loadError = $"Save failed: {ex.Message}"; _submitting = false; }
    }

    async Task DoClose() { _submitting = false; _confirmDelete = false; await OnClose.InvokeAsync(); }

    async Task DoDelete()
    {
        if (!_isEdit || _submitting) return;
        _submitting = true;
        try
        {
            bool ok;
            string? err;
            string toastMsg;

            if (_references.Count == 0)
            {
                // Fast path — nothing pointing at this wallet, straight DELETE.
                ok = WalletSvc.TryDeleteWallet(EditingWalletId!.Value, out err);
                toastMsg = $"Wallet deleted — {_name}";
            }
            else if (_reassignTarget != null)
            {
                // Reassign path — move FK references to target, then delete.
                ok = WalletSvc.TryDeleteWalletWithReassign(
                    EditingWalletId!.Value, _reassignTarget.WalletId, CurrentUserPersonId, out err);
                toastMsg = $"Wallet deleted — references moved to {_reassignTarget.Name}";
            }
            else
            {
                ok = false;
                err = "Can't delete the PC's only wallet.";
                toastMsg = "";
            }

            if (!ok)
            {
                _loadError = err ?? "Cannot delete — wallet has history. Deactivate it instead.";
                _confirmDelete = false;
                _submitting = false;
                return;
            }
            try { await JS.InvokeVoidAsync("lpmToast", toastMsg, "success"); } catch { }
            await OnDeleted.InvokeAsync(EditingWalletId!.Value);
            await DoClose();
        }
        catch (Exception ex)
        {
            _loadError = $"Delete failed: {ex.Message}";
            _confirmDelete = false;
            _submitting = false;
        }
    }
    Task CloseIfOutside() => DoClose();

    static string CurrencySymbol(string c) => c switch { "EUR" => "€", "USD" => "$", _ => "₪" };
    static string CurrencyColor(string c)  => c switch { "EUR" => "#10b981", "USD" => "#0ea5e9", _ => "#3b82f6" };
    static string WalletGradient(string c) => c switch
    {
        "EUR" => "linear-gradient(135deg,#047857,#10b981)",
        "USD" => "linear-gradient(135deg,#0369a1,#0ea5e9)",
        _     => "linear-gradient(135deg,#1e40af,#3b82f6)"
    };

    static string FmtDate(string isoish)
    {
        if (string.IsNullOrWhiteSpace(isoish)) return "";
        if (DateTime.TryParse(isoish, System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.AssumeLocal, out var dt))
            return dt.ToString("dd/MM/yy");
        return isoish.Length >= 10 ? isoish[..10] : isoish;
    }
}
